{
  "name": "easywi/webinterface-core",
  "description": "Easy-Wi NextGen Symfony 8 core webinterface.",
  "type": "project",
  "license": "proprietary",
  "require": {
    "php": ">=8.4",
    "ext-ctype": "*",
    "ext-iconv": "*",
    "doctrine/doctrine-bundle": "^3.1",
    "doctrine/doctrine-migrations-bundle": "^4.0",
    "doctrine/migrations": "^3.6",
    "doctrine/orm": "^3.4",
    "dragonmantank/cron-expression": "^3.3",
    "symfony/console": "^8.0",
    "symfony/dotenv": "^8.0",
    "symfony/framework-bundle": "^8.0",
    "symfony/http-client": "^8.0",
    "symfony/mailer": "^8.0",
    "symfony/messenger": "^8.0",
    "symfony/mime": "^8.0",
    "symfony/form": "^8.0",
    "symfony/asset": "^8.0",
    "symfony/monolog-bundle": "^4.0",
    "symfony/rate-limiter": "^8.0",
    "symfony/runtime": "^8.0",
    "symfony/security-bundle": "^8.0",
    "symfony/serializer": "^8.0",
    "symfony/translation": "^8.0",
    "symfony/twig-bundle": "^8.0",
    "symfony/uid": "^8.0",
    "symfony/validator": "^8.0",
    "symfony/yaml": "^8.0",
    "symfony/cache": "^8.0",
    "twig/twig": "^3.0",
    "symfony/flex": "^2.0",
    "phpseclib/phpseclib": "^3.0",
    "league/flysystem-bundle": "^3.0",
    "league/flysystem-sftp-v3": "^3.0",
    "endroid/qr-code": "^6.1"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.75",
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^12.5",
    "symfony/browser-kit": "^8.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Tests\\": "tests/"
    }
  },
  "config": {
    "allow-plugins": {
      "symfony/flex": true,
      "symfony/runtime": true
    }
  },
  "scripts": {
    "lint": [
      "find . -name \"*.php\" -not -path \"./vendor/*\" -print0 | xargs -0 -n1 php -l",
      "php bin/console lint:yaml --parse-tags config",
      "php bin/console lint:twig templates",
      "php bin/console lint:container"
    ],
    "phpstan": [
      "php -d memory_limit=-1 vendor/bin/phpstan analyse --configuration=phpstan.neon"
    ],
    "test": [
      "php bin/phpunit"
    ],
    "cs:check": [
      "PHP_CS_FIXER_IGNORE_ENV=1 php vendor/bin/php-cs-fixer fix --dry-run --diff"
    ],
    "auto-scripts": {
      "cache:clear --no-warmup": "symfony-cmd",
      "assets:install %PUBLIC_DIR%": "symfony-cmd"
    },
    "post-install-cmd": [
      "@auto-scripts"
    ],
    "post-update-cmd": [
      "@auto-scripts"
    ]
  },
  "conflict": {
    "symfony/symfony": "*"
  },
  "extra": {
    "symfony": {
      "allow-contrib": false,
      "require": "^8.0"
    }
  }
}
