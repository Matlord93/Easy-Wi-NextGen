APP_ENV=dev
APP_SECRET="change_this_secret"
APP_SHARE_DIR=var/share

DATABASE_URL="sqlite:///%kernel.project_dir%/var/app.db"

DEFAULT_URI=http://localhost

MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0

MAILER_DSN=smtp://localhost
MAIL_FROM_ADDRESS=no-reply@example.com
MAIL_FROM_NAME="Easy-Wi NextGen"

AGENT_SIGNATURE_SKEW_SECONDS=120
AGENT_NONCE_TTL_SECONDS=180
AGENT_REGISTRATION_TOKEN="change_this_secret"

APP_FILESVC_TIMEOUT_SECONDS=10
APP_FILESVC_PORT=8444
APP_FILESVC_SCHEME=https
APP_FILESVC_CLIENT_CERT=
APP_FILESVC_CLIENT_KEY=
APP_FILESVC_CA_CERT=

APP_AGENT_RELEASE_REPOSITORY=Matlord93/Easy-Wi-NextGen
APP_UPDATE_CHECK_CACHE_TTL=3600
APP_CHANGELOG_REPOSITORY=Matlord93/Easy-Wi-NextGen
APP_CORE_RELEASE_REPOSITORY=Matlord93/Easy-Wi-NextGen
APP_CORE_RELEASE_CHANNEL=dev
APP_CORE_VERSION=v1.0.0-dev.20260529.2
APP_CORE_UPDATE_WORKFLOW=webinterface-update.yml
APP_CORE_UPDATE_INSTALL_DIR=/var/www/easywi/core
APP_CORE_UPDATE_RELEASES_DIR=/var/www/easywi/core/releases
APP_CORE_UPDATE_CURRENT_SYMLINK=/var/www/easywi/core/current
APP_CORE_UPDATE_LOCK_FILE=/var/www/easywi/core/tmp/webinterface_update.lock
APP_CORE_UPDATE_JOBS_DIR=/var/www/easywi/core/srv/update/jobs
APP_CORE_UPDATE_LOGS_DIR=/var/www/easywi/core/srv/update/logs
APP_CORE_UPDATE_MANIFEST_URL=http://localhost/update/manifest.json
APP_CORE_UPDATE_RUNNER=
APP_GITHUB_TOKEN=

APP_WINDOWS_NODES_ENABLED=0

AUTH_IDENTIFIER_HASH_PEPPER=change_this_identifier_pepper
REDIS_DSN=redis://127.0.0.1:6379
SYMFONY_TRUSTED_PROXIES=127.0.0.1
