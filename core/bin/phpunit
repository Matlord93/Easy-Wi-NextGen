#!/usr/bin/env php
<?php

declare(strict_types=1);

if (!is_file(dirname(__DIR__) . '/vendor/autoload.php')) {
    echo "You must set up the project dependencies using `composer install`." . PHP_EOL;
    exit(1);
}

$simplePhpUnit = dirname(__DIR__) . '/vendor/bin/simple-phpunit';
$phpUnit = dirname(__DIR__) . '/vendor/bin/phpunit';

if (is_file($simplePhpUnit)) {
    require $simplePhpUnit;
}

if (!is_file($phpUnit)) {
    echo "You must set up the project dependencies using `composer require --dev phpunit/phpunit`." . PHP_EOL;
    exit(1);
}

require $phpUnit;
