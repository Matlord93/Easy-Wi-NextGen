#!/usr/bin/env php
<?php

declare(strict_types=1);

use App\Infrastructure\Runtime\MemoryLimit;
use App\Kernel;
use Symfony\Bundle\FrameworkBundle\Console\Application;
use Symfony\Component\Console\Input\ArgvInput;
use Symfony\Component\Dotenv\Dotenv;
use Symfony\Component\ErrorHandler\Debug;

$projectDir = dirname(__DIR__);
$autoloadPath = $projectDir.'/vendor/autoload.php';

if (!is_file($autoloadPath)) {
    $message = 'Missing Composer dependencies.';
    if (is_file($projectDir.'/composer.json')) {
        $message .= ' Run `cd '.$projectDir.' && composer install` before using `php bin/console`.';
    } else {
        $message .= ' Composer metadata is also missing from '.$projectDir.'. Restore the complete core package, including composer.json, before using `php bin/console`.';
    }

    fwrite(STDERR, $message . PHP_EOL);
    exit(1);
}

require $autoloadPath;

MemoryLimit::ensureMinimum();

if (is_file(dirname(__DIR__).'/.env')) {
    (new Dotenv())->bootEnv(dirname(__DIR__).'/.env');
}

$input = new ArgvInput();

$env = $input->getParameterOption(['--env', '-e'], $_SERVER['APP_ENV'] ?? $_ENV['APP_ENV'] ?? 'dev', true);
$debug = (bool)($_SERVER['APP_DEBUG'] ?? $_ENV['APP_DEBUG'] ?? ($env !== 'prod'));

if ($debug) {
    umask(0000);
    Debug::enable();
}

$kernel = new Kernel($env, $debug);

$application = new Application($kernel);
$application->run($input);
