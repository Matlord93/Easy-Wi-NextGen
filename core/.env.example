### ---------------------------------------------------------------------------
### Core runtime
### ---------------------------------------------------------------------------
APP_ENV=dev
APP_DEBUG=1
APP_SECRET=change_me_to_a_long_random_secret
APP_SECRET_FALLBACKS=
DEFAULT_URI=http://localhost

### ---------------------------------------------------------------------------
### Database / queue / cache
### ---------------------------------------------------------------------------
# Used by tests and local bootstrap tooling.
DATABASE_URL="sqlite:///%kernel.project_dir%/var/app.db"
# Symfony Messenger transport (e.g. doctrine://default?auto_setup=0, amqp://, redis://).
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
# Symfony Mailer DSN.
MAILER_DSN=smtp://localhost
# Redis DSN used for distributed locks / cache-backed workflows.
REDIS_DSN=redis://localhost:6379

### ---------------------------------------------------------------------------
### Security & identity
### ---------------------------------------------------------------------------
# Additional pepper for deterministic identifier hashing.
AUTH_IDENTIFIER_HASH_PEPPER=change_me_identifier_pepper
# Optional key for hosting-panel integrations (secret).
APP_HOSTING_PANEL_SECRET_KEY=
# Comma-separated proxy CIDRs/IPs when running behind reverse proxies.
SYMFONY_TRUSTED_PROXIES=

### ---------------------------------------------------------------------------
### Agent/API behavior
### ---------------------------------------------------------------------------
AGENT_SIGNATURE_SKEW_SECONDS=300
AGENT_NONCE_TTL_SECONDS=600
APP_AGENT_JWT_ISSUER=easywi-panel
APP_AGENT_JWT_AUDIENCE=easywi-agent-api
APP_AGENT_JWT_MAX_TTL_SECONDS=60
APP_AGENT_FILE_TIMEOUT_SECONDS=10
APP_AGENT_SERVICE_PORT=7456

### ---------------------------------------------------------------------------
### Status / platform toggles
### ---------------------------------------------------------------------------
APP_STATUS_AGENT_SHARED_SECRET=
APP_STATUS_AGENT_SIGNATURE_SKEW_SECONDS=300
APP_STATUS_STALE_GRACE_SECONDS=20
APP_WINDOWS_NODES_ENABLED=0
APP_PAYMENT_DUMMY_ENABLED=0
APP_RECOVERY_ALLOWED_IPS=127.0.0.1,::1

### ---------------------------------------------------------------------------
### Release, changelog & updater
### ---------------------------------------------------------------------------
APP_AGENT_RELEASE_REPOSITORY=Matlord93/Easy-Wi-NextGen
APP_AGENT_UPDATE_FEED_URL=
APP_AGENT_RELEASE_CHANNEL=stable
APP_AGENT_RELEASE_CACHE_TTL=300
APP_CHANGELOG_REPOSITORY=Matlord93/Easy-Wi-NextGen
APP_CHANGELOG_CACHE_TTL=300
APP_CORE_RELEASE_REPOSITORY=Matlord93/Easy-Wi-NextGen
APP_CORE_RELEASE_CHANNEL=beta
APP_CORE_RELEASE_CACHE_TTL=300
APP_CORE_VERSION=1.0.0

# Optional override (defaults to APP_CORE_RELEASE_REPOSITORY).
APP_CORE_UPDATE_REPOSITORY=
APP_CORE_UPDATE_WORKFLOW=webinterface-update.yml
# GitHub token (secret) for workflow dispatch.
APP_GITHUB_TOKEN=
APP_CORE_UPDATE_INSTALL_DIR="%kernel.project_dir%"
APP_CORE_UPDATE_MANIFEST_URL=http://localhost/update/manifest.json
APP_CORE_UPDATE_RELEASES_DIR="%kernel.project_dir%/releases"
APP_CORE_UPDATE_CURRENT_SYMLINK="%kernel.project_dir%/current"
APP_CORE_UPDATE_LOCK_FILE="%kernel.project_dir%/tmp/webinterface_update.lock"
APP_CORE_UPDATE_EXCLUDES=.env,config/local*,var/,storage/,uploads/
APP_CORE_UPDATE_JOBS_DIR="%kernel.project_dir%/srv/update/jobs"
APP_CORE_UPDATE_LOGS_DIR="%kernel.project_dir%/srv/update/logs"
APP_CORE_UPDATE_BACKUPS_DIR="%kernel.project_dir%/srv/update/backups"
APP_CORE_UPDATE_RUNNER=/usr/local/bin/easywi-core-runner
APP_CORE_UPDATE_PACKAGE_URL=

### ---------------------------------------------------------------------------
### Mail/cms/admin optional integrations
### ---------------------------------------------------------------------------
APP_ADMIN_AUTHORIZED_KEYS_PATH=/home/easywi/.ssh/authorized_keys
APP_SINUSBOT_QUOTA_MIN=1
APP_SINUSBOT_QUOTA_MAX=100
APP_MAIL_PASSWORD_HASH_ALGORITHM=argon2id
APP_MAIL_ALIAS_MAP_PATH=

### ---------------------------------------------------------------------------
### Setup/runtime helper paths (optional)
### ---------------------------------------------------------------------------
EASYWI_DB_CONFIG_PATH=
EASYWI_SECRET_KEY_PATH=
EASYWI_PHP_BIN=
PHP_CLI_BIN=
