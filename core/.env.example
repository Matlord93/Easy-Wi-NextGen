DATABASE_URL="sqlite:///%kernel.project_dir%/var/app.db"

###> SFTP file manager ###
# Host/port are configured in the admin settings UI and stored in the database (encrypted).
###< SFTP file manager ###

AUTH_IDENTIFIER_HASH_PEPPER=
REDIS_DSN=redis://127.0.0.1:6379
SYMFONY_TRUSTED_PROXIES=127.0.0.1

###> Core domain SSL / Certbot ###
# EASYWI_CERTBOT_BIN=certbot
# EASYWI_CERTBOT_CONFIG_DIR=var/certbot/config
# EASYWI_CERTBOT_WORK_DIR=var/certbot/work
# EASYWI_CERTBOT_LOGS_DIR=var/certbot/logs
# Set to 1 when the runtime user may run passwordless `sudo -n certbot` for nginx changes.
# EASYWI_CERTBOT_USE_SUDO=0
###< Core domain SSL / Certbot ###

###> Easy-Wi GitHub release updates ###
# Updates are installed only from versioned GitHub Releases and their fixed assets.
APP_CORE_RELEASE_REPOSITORY=Matlord93/Easy-Wi-NextGen
APP_AGENT_RELEASE_REPOSITORY=Matlord93/Easy-Wi-NextGen
APP_CORE_RELEASE_CHANNEL=stable
APP_AGENT_RELEASE_CHANNEL=stable
APP_GITHUB_TOKEN=
APP_CORE_RELEASE_CACHE_TTL=300
APP_AGENT_RELEASE_CACHE_TTL=300
# Optional fallback only; GitHub Release asset easywi-core.tar.gz is preferred.
APP_CORE_UPDATE_PACKAGE_URL=
# Private core releases require APP_GITHUB_TOKEN with read access to Releases/Contents.
# Agent update jobs are blocked while APP_GITHUB_TOKEN is set unless a signed panel proxy is implemented,
# because agents must never receive the GitHub token and cannot fetch private GitHub assets directly.
# Never expose APP_GITHUB_TOKEN in the frontend, logs, or agent job payloads.
###< Easy-Wi GitHub release updates ###
