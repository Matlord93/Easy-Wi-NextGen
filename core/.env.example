DATABASE_URL="sqlite:///%kernel.project_dir%/var/app.db"

###> SFTP file manager ###
# Host/port are configured in the admin settings UI and stored in the database (encrypted).
###< SFTP file manager ###

AUTH_IDENTIFIER_HASH_PEPPER=
REDIS_DSN=redis://127.0.0.1:6379
SYMFONY_TRUSTED_PROXIES=127.0.0.1

