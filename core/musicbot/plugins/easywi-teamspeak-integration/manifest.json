{
  "identifier": "easywi.teamspeak.integration",
  "name": "Easy-Wi TeamSpeak Integration",
  "version": "0.2.0",
  "author": "Easy-Wi",
  "description": "First-party Musicbot TeamSpeak chat command/event bridge using the internal plugin API. No external code execution.",
  "permissions": [
    "commands.register",
    "events.subscribe",
    "playback.control",
    "queue.manage",
    "playlist.manage"
  ],
  "supported_platforms": [
    "teamspeak"
  ],
  "first_party": true,
  "removable": false,
  "config_schema": {
    "type": "object",
    "properties": {
      "enabled": {
        "type": "boolean",
        "title": "Enable TeamSpeak integration"
      },
      "command_prefix": {
        "type": "string",
        "title": "Command prefix",
        "default": "!"
      },
      "commands_enabled": {
        "type": "boolean",
        "title": "Enable TeamSpeak commands"
      },
      "events_enabled": {
        "type": "boolean",
        "title": "Enable TeamSpeak events"
      },
      "allowed_server_groups": {
        "type": "array",
        "title": "Allowed server groups"
      },
      "dj_server_groups": {
        "type": "array",
        "title": "DJ server groups"
      },
      "admin_server_groups": {
        "type": "array",
        "title": "Admin server groups"
      },
      "chat_scopes": {
        "type": "array",
        "title": "Enabled chat scopes",
        "items": {
          "enum": [
            "channel",
            "private"
          ]
        }
      },
      "command_config": {
        "type": "object",
        "title": "Per-command configuration"
      }
    }
  },
  "commands": [
    "play",
    "pause",
    "resume",
    "stop",
    "skip",
    "next",
    "volume",
    "queue",
    "clear",
    "shuffle",
    "repeat",
    "radio",
    "yt",
    "youtube",
    "song",
    "np",
    "help"
  ],
  "plugin_api": {
    "hooks": [
      "chat.command.received",
      "playback.action.requested",
      "queue.action.requested"
    ],
    "roles": [
      "user",
      "dj",
      "admin"
    ],
    "chat_scopes": [
      "channel",
      "private"
    ]
  }
}
