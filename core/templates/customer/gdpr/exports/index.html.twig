{% extends 'customer/base.html.twig' %}

{% block title %}{{ t('customer_gdpr_exports_page_title', page_locale()) }}{% endblock %}

{% block content %}
{% set locale = page_locale() %}
<div class="cust-page">

    <div class="cust-hero">
        <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:16px;flex-wrap:wrap;">
            <div>
                <h1 class="cust-hero__title">{{ t('customer_gdpr_exports_title', locale) }}</h1>
                <p class="cust-hero__sub">{{ t('customer_gdpr_exports_intro', locale) }}</p>
            </div>
            <button
                class="ui-button ui-button--primary ui-button--sm"
                hx-post="/gdpr/exports"
                hx-target="#gdpr-export-table"
                hx-swap="outerHTML"
            >{{ t('customer_gdpr_exports_request', locale) }}</button>
        </div>
    </div>

    <div class="cust-panel">
        <div class="cust-panel__head" style="display:flex;align-items:center;justify-content:space-between;">
            <div>
                <h2 class="cust-panel__title">{{ t('customer_gdpr_exports_history_title', locale) }}</h2>
                <p style="font-size:13px;color:var(--color-text-muted,#64748b);margin-top:2px;">{{ t('customer_gdpr_exports_history_intro', locale) }}</p>
            </div>
            <button
                class="ui-button ui-button--ghost ui-button--sm"
                hx-get="/gdpr/exports/table"
                hx-target="#gdpr-export-table"
                hx-swap="outerHTML"
            >{{ t('refresh', locale) }}</button>
        </div>
        <div id="gdpr-export-table" hx-get="/gdpr/exports/table" hx-trigger="gdpr-export-updated from:body" hx-swap="outerHTML">
            {% include 'customer/gdpr/exports/_table.html.twig' with { exports: exports, statusStyles: statusStyles } %}
        </div>
    </div>

</div>
{% endblock %}
