<div id="gdpr-export-table"
    hx-get="/gdpr/exports/table"
    hx-trigger="gdpr-export-updated from:body"
    hx-swap="outerHTML">
<div class="cust-ws-table-wrap">
    <table class="cust-table">
        <thead>
            <tr>
                <th>{{ t('customer_gdpr_exports_status', page_locale()) }}</th>
                <th>{{ t('customer_gdpr_exports_requested', page_locale()) }}</th>
                <th>{{ t('customer_gdpr_exports_expires', page_locale()) }}</th>
                <th>{{ t('customer_gdpr_exports_file', page_locale()) }}</th>
                <th>{{ t('customer_gdpr_exports_actions', page_locale()) }}</th>
            </tr>
        </thead>
        <tbody>
            {% if exports is empty %}
                <tr>
                    <td colspan="5" class="cust-table__empty">{{ t('customer_gdpr_exports_empty', page_locale()) }}</td>
                </tr>
            {% else %}
                {% for export in exports %}
                    <tr>
                        <td>
                            {% if export.status.value == 'ready' %}
                                <span class="ui-badge ui-badge--success">{{ t('customer_gdpr_exports_status_ready', page_locale()) }}</span>
                            {% elseif export.status.value == 'pending' %}
                                <span class="ui-badge ui-badge--warning">{{ t('customer_gdpr_exports_status_pending', page_locale()) }}</span>
                            {% elseif export.status.value == 'failed' %}
                                <span class="ui-badge ui-badge--danger">{{ t('customer_gdpr_exports_status_failed', page_locale()) }}</span>
                            {% else %}
                                <span class="ui-badge ui-badge--neutral">{{ export.status.value }}</span>
                            {% endif %}
                        </td>
                        <td>
                            <div style="font-size:13px;font-weight:600;">{{ export.requestedAt|date('Y-m-d H:i') }}</div>
                            <div style="font-size:11px;color:var(--color-text-muted,#64748b);">{{ t('customer_gdpr_exports_ready', page_locale()) }} {{ export.readyAt ? export.readyAt|date('Y-m-d H:i') : t('customer_gdpr_exports_pending', page_locale()) }}</div>
                        </td>
                        <td style="font-size:12px;color:var(--color-text-muted,#64748b);">{{ export.expiresAt|date('Y-m-d H:i') }}</td>
                        <td>
                            <div style="font-weight:600;font-size:13px;">{{ export.fileName }}</div>
                            <div style="font-size:11px;color:var(--color-text-muted,#64748b);">{{ (export.fileSize / 1024)|number_format(1) }} KB</div>
                        </td>
                        <td>
                            {% if export.status.value == 'ready' and not export.expired %}
                                <a href="/gdpr/exports/{{ export.id }}/download" class="ui-button ui-button--ghost ui-button--sm">{{ t('customer_gdpr_exports_download', page_locale()) }}</a>
                            {% else %}
                                <span style="font-size:12px;color:var(--color-text-muted,#64748b);">{{ t('customer_gdpr_exports_unavailable', page_locale()) }}</span>
                            {% endif %}
                        </td>
                    </tr>
                {% endfor %}
            {% endif %}
        </tbody>
    </table>
</div>
</div>{# end #gdpr-export-table #}
