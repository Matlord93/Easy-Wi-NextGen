{% extends 'customer/base.html.twig' %}

{% block title %}{{ t('customer_gdpr_delete_page_title', page_locale()) }}{% endblock %}

{% block content %}
{% set locale = page_locale() %}
<div class="cust-page">

    <div class="cust-hero">
        <h1 class="cust-hero__title">{{ t('customer_gdpr_delete_title', locale) }}</h1>
        <p class="cust-hero__sub">{{ t('customer_gdpr_delete_intro', locale) }}</p>
    </div>

    <div class="cust-grid-2">
        <div class="cust-panel">
            <div class="cust-panel__head">
                <h2 class="cust-panel__title">{{ t('customer_gdpr_delete_status_title', locale) }}</h2>
                <p style="font-size:13px;color:var(--color-text-muted,#64748b);margin-top:2px;">{{ t('customer_gdpr_delete_status_intro', locale) }}</p>
            </div>
            <div id="gdpr-delete-status" hx-get="/gdpr/delete/status" hx-trigger="gdpr-delete-updated from:body" hx-swap="outerHTML">
                {% include 'customer/gdpr/delete/_status.html.twig' with { request: request, statusStyles: statusStyles } %}
            </div>
        </div>

        <div class="cust-panel">
            <div class="cust-panel__head">
                <h2 class="cust-panel__title">{{ t('customer_gdpr_delete_retention_title', locale) }}</h2>
                <p style="font-size:13px;color:var(--color-text-muted,#64748b);margin-top:2px;">{{ t('customer_gdpr_delete_retention_intro', locale) }}</p>
            </div>
            <div class="cust-panel__body">
                <ul style="display:flex;flex-direction:column;gap:8px;margin:0;padding:0;list-style:none;font-size:13px;color:var(--color-text-muted,#64748b);">
                    <li style="display:flex;gap:8px;"><span style="color:#10b981;">•</span>{{ t('customer_gdpr_delete_retention_item_invoices', locale) }}</li>
                    <li style="display:flex;gap:8px;"><span style="color:#10b981;">•</span>{{ t('customer_gdpr_delete_retention_item_accounting', locale) }}</li>
                    <li style="display:flex;gap:8px;"><span style="color:#10b981;">•</span>{{ t('customer_gdpr_delete_retention_item_audit', locale) }}</li>
                </ul>
                <div class="ng-alert ng-alert--warning" style="margin-top:12px;">
                    {{ t('customer_gdpr_delete_retention_notice', locale) }}
                </div>
            </div>
        </div>
    </div>

</div>
{% endblock %}
