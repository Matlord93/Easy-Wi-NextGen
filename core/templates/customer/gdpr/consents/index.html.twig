{% extends 'customer/base.html.twig' %}
{% set activeNav = 'gdpr' %}
{% set locale = page_locale() %}
{% block title %}{{ t('customer_gdpr_consents_page_title', locale) }}{% endblock %}

{% block content %}
<div style="display:flex;flex-direction:column;gap:20px;">

    {# ── Hero / KPI ── #}
    <div class="ng-card" style="overflow:hidden;">
        <div class="tkt-hero">
            <div class="tkt-hero__inner">
                <div style="display:flex;flex-direction:column;gap:6px;">
                    <div class="tkt-hero__pill">
                        <span class="tkt-hero__pill-dot" style="background:#a78bfa;"></span>
                        {{ t('customer_nav_group_gdpr', locale) }}
                    </div>
                    <h1 class="tkt-hero__title">{{ t('customer_gdpr_consents_title', locale) }}</h1>
                    <p class="tkt-hero__sub">{{ t('customer_gdpr_consents_intro', locale) }}</p>
                </div>
                <div style="display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:8px;margin-top:16px;">
                    <div class="tkt-kpi">
                        <div class="tkt-kpi__label">{{ t('customer_gdpr_consents_history_title', locale) }}</div>
                        <div class="tkt-kpi__value">{{ logs|length }}</div>
                    </div>
                    <div class="tkt-kpi tkt-kpi--open">
                        <div class="tkt-kpi__label">{{ t('customer_gdpr_consents_form_type', locale) }}</div>
                        <div class="tkt-kpi__value">{{ types|length }}</div>
                    </div>
                </div>
            </div>
        </div>
        <div style="padding:14px 16px;border-top:1px solid var(--ng-border);background:var(--ng-surface-soft);">
            <button type="button" class="ui-button ui-button--ghost ui-button--sm"
                hx-get="/gdpr/consents/table"
                hx-target="#consent-table"
                hx-swap="outerHTML">
                ↻ {{ t('refresh', locale) }}
            </button>
        </div>
    </div>

    {# ── Two-column layout: history + form ── #}
    <div style="display:grid;grid-template-columns:minmax(0,1fr) 360px;gap:20px;align-items:start;">

        {# ── Consent history table ── #}
        <div class="ng-card" style="overflow:hidden;">
            <div class="tkt-filter-bar">
                <div class="tkt-filter-bar__top">
                    <div>
                        <h2 class="tkt-filter-bar__title">{{ t('customer_gdpr_consents_history_title', locale) }}</h2>
                        <p class="tkt-filter-bar__sub">{{ t('customer_gdpr_consents_history_intro', locale) }}</p>
                    </div>
                    <button type="button" class="ui-button ui-button--ghost ui-button--sm"
                        hx-get="/gdpr/consents/table"
                        hx-target="#consent-table"
                        hx-swap="outerHTML">
                        ↻ {{ t('refresh', locale) }}
                    </button>
                </div>
            </div>
            <div id="consent-table"
                hx-get="/gdpr/consents/table"
                hx-trigger="consent-log-updated from:body"
                hx-swap="outerHTML">
                {% include 'customer/gdpr/consents/_table.html.twig' with { logs: logs, typeStyles: typeStyles } %}
            </div>
        </div>

        {# ── Record consent form ── #}
        <aside id="consent-form" style="position:sticky;top:20px;">
            <div class="ng-card">
                <div style="padding:14px 16px;border-bottom:1px solid var(--ng-border);">
                    <div style="font-size:0.9375rem;font-weight:700;color:var(--ng-text);">{{ t('customer_gdpr_consents_record_title', locale) }}</div>
                    <div style="font-size:0.8125rem;color:var(--ng-text-muted);margin-top:2px;">{{ t('customer_gdpr_consents_record_intro', locale) }}</div>
                </div>
                <div style="padding:16px;">
                    <form hx-post="/gdpr/consents"
                        hx-target="#consent-table"
                        hx-swap="outerHTML"
                        style="display:flex;flex-direction:column;gap:14px;">
                        <div class="form-field">
                            <label class="form-label">{{ t('customer_gdpr_consents_form_type', locale) }}</label>
                            <select name="type" class="form-input">
                                {% for type in types %}
                                    <option value="{{ type.value }}">{{ typeStyles[type.value].label }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="form-field">
                            <label class="form-label">{{ t('customer_gdpr_consents_form_version', locale) }}</label>
                            <input type="text" name="version" required class="form-input"
                                placeholder="{{ t('customer_gdpr_consents_form_version_placeholder', locale) }}">
                        </div>
                        <button type="submit" class="ui-button ui-button--primary" style="width:100%;">
                            {{ t('customer_gdpr_consents_form_save', locale) }}
                        </button>
                    </form>
                    <div class="ng-alert ng-alert--warning" style="margin-top:12px;font-size:0.75rem;">
                        {{ t('customer_gdpr_consents_version_notice', locale) }}
                    </div>
                </div>
            </div>
        </aside>

    </div>
</div>
{% endblock %}
