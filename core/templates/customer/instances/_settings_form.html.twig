{% set detailMode = detailMode|default(false) %}
{% set templateContext = instance.template ?? {} %}
{% set installResolver = templateContext.install_resolver ?? templateContext.installResolver ?? {} %}
{% set resolverType = installResolver.type ?? '' %}
{% set isMinecraft = resolverType in ['minecraft_vanilla', 'papermc_paper', 'minecraft_bedrock'] %}
{% if detailMode %}
    <form method="post" action="{{ path('customer_instance_settings', {id: instance.id, detail: 1}) }}" class="space-y-5">
{% else %}
    <form class="space-y-5" hx-post="{{ path('customer_instance_settings', {id: instance.id}) }}" hx-target="#instance-card-{{ instance.id }}" hx-swap="outerHTML">
{% endif %}

    <div class="grid gap-4 lg:grid-cols-2">
        {# ─── Update-Richtlinie ─── #}
        <div class="rounded-xl border border-slate-700/60 bg-slate-800/40 p-4">
            <p class="text-xs font-semibold uppercase tracking-widest text-slate-500">{{ t('customer_instance_update_policy', page_locale()) }}</p>
            <div class="mt-3 space-y-2.5">
                <label class="flex cursor-pointer items-center gap-2.5 rounded-lg border border-slate-700/50 bg-slate-900/40 px-3 py-2 text-sm text-slate-300 hover:bg-slate-900/60">
                    <input type="radio" name="update_policy" value="manual"
                        {% if instance.update_policy != 'auto' %}checked{% endif %}
                        class="text-indigo-500 border-slate-500 bg-slate-800 focus:ring-indigo-500">
                    {{ t('customer_instance_policy_manual_only', page_locale()) }}
                </label>
                <label class="flex cursor-pointer items-center gap-2.5 rounded-lg border border-slate-700/50 bg-slate-900/40 px-3 py-2 text-sm text-slate-300 hover:bg-slate-900/60">
                    <input type="radio" name="update_policy" value="auto"
                        {% if instance.update_policy == 'auto' %}checked{% endif %}
                        class="text-indigo-500 border-slate-500 bg-slate-800 focus:ring-indigo-500">
                    {{ t('customer_instance_policy_auto_schedule', page_locale()) }}
                </label>
            </div>
            <div class="mt-4 grid gap-3 sm:grid-cols-2">
                <div>
                    <label class="block text-xs font-semibold uppercase tracking-wide text-slate-500">{{ t('customer_instance_cron_schedule', page_locale()) }}</label>
                    <input type="text" name="cron_expression"
                        value="{{ instance.schedule ? instance.schedule.cron_expression : '0 3 * * *' }}"
                        class="mt-1.5 w-full rounded-lg border border-slate-600/80 bg-slate-900/60 px-3 py-2 text-sm text-slate-200 focus:border-indigo-500 focus:outline-none">
                    <p class="mt-1 text-[11px] text-slate-600">{{ t('customer_instance_cron_default', page_locale()) }}</p>
                </div>
                <div>
                    <label class="block text-xs font-semibold uppercase tracking-wide text-slate-500">{{ t('customer_instance_time_zone', page_locale()) }}</label>
                    <input type="text" name="time_zone"
                        value="{{ instance.schedule ? instance.schedule.time_zone : 'UTC' }}"
                        class="mt-1.5 w-full rounded-lg border border-slate-600/80 bg-slate-900/60 px-3 py-2 text-sm text-slate-200 focus:border-indigo-500 focus:outline-none">
                </div>
            </div>
            <div class="mt-3 rounded-lg border border-slate-700/40 bg-slate-900/40 p-3 text-xs text-slate-400">
                <span class="font-semibold text-slate-300">{{ t('customer_instance_pin_status_label', page_locale()) }}</span>
                {% if (instance.locked_build_id ?? '') != '' or (instance.locked_version ?? '') != '' %}
                    <span class="ml-1 font-semibold text-amber-400">{{ t('customer_instance_pin_locked', page_locale()) }}</span>
                {% else %}
                    <span class="ml-1 font-semibold text-emerald-400">{{ t('customer_instance_pin_unlocked', page_locale()) }}</span>
                {% endif %}
                {% if instance.schedule %}
                    <div class="mt-1 space-y-0.5 text-[11px] text-slate-500">
                        <div>{{ t('customer_instance_schedule_last_run_label', page_locale()) }} {{ instance.schedule.last_run_at ? instance.schedule.last_run_at|date('Y-m-d H:i:s') : '—' }}</div>
                        <div>{{ t('customer_instance_schedule_status_label', page_locale()) }} {{ instance.schedule.last_status ?: '—' }}{% if instance.schedule.last_error_code %} ({{ t('customer_instance_schedule_error_label', page_locale())|replace({'%code%': instance.schedule.last_error_code}) }}){% endif %}</div>
                        {% if instance.schedule.next_run_at %}
                            <div>{{ t('customer_instance_schedule_next_run_label', page_locale()) }} {{ instance.schedule.next_run_at|date('Y-m-d H:i:s') }}</div>
                        {% endif %}
                    </div>
                {% endif %}
            </div>
        </div>

        {# ─── Versionssperre ─── #}
        <div class="rounded-xl border border-slate-700/60 bg-slate-800/40 p-4">
            <p class="text-xs font-semibold uppercase tracking-widest text-slate-500">{{ t('customer_instance_version_lock', page_locale()) }}</p>

            {% if isMinecraft %}
                <div class="mt-3 rounded-lg border border-slate-700/40 bg-slate-900/40 p-3 text-xs text-slate-400">
                    <div class="font-semibold text-slate-300">
                        {% if resolverType == 'papermc_paper' %}{{ t('minecraft_type_paper', page_locale()) }}{% elseif resolverType == 'minecraft_bedrock' %}{{ t('minecraft_type_bedrock', page_locale()) }}{% else %}{{ t('minecraft_type_vanilla', page_locale()) }}{% endif %}
                    </div>
                    <div class="mt-1">{{ t('minecraft_status_installed', page_locale()) }}: <span class="text-slate-200">{{ instance.installed_version ?? instance.current_version ?? '—' }}</span>{% if (instance.installed_build_id ?? instance.current_build_id ?? '') != '' %} Build {{ instance.installed_build_id ?? instance.current_build_id }}{% endif %}</div>
                    <div>{{ t('minecraft_status_java', page_locale()) }}: <span class="text-slate-200">{{ resolverType == 'minecraft_bedrock' ? '—' : (instance.installed_java_version ?? '—') }}</span></div>
                    <div>{{ t('minecraft_status_update_target', page_locale()) }}: <span class="text-slate-200">{{ (instance.locked_version ?? '') == '' and (instance.locked_build_id ?? '') == '' ? t('minecraft_status_latest', page_locale()) : t('minecraft_status_pinned', page_locale()) }}</span></div>
                    {% if instance.minecraft_newer_available ?? null %}
                        <div class="text-emerald-400">{{ t('minecraft_status_new_available', page_locale()) }}: {{ instance.minecraft_newer_available.mcVersion }}{% if instance.minecraft_newer_available.build %} Build {{ instance.minecraft_newer_available.build }}{% endif %}</div>
                    {% endif %}
                </div>
            {% endif %}
            {% if isMinecraft and minecraftCatalog is not empty %}
                {% set versionOptions = resolverType == 'minecraft_vanilla' ? minecraftCatalog.vanilla.versions : (resolverType == 'minecraft_bedrock' ? minecraftCatalog.bedrock.versions : minecraftCatalog.paper.versions) %}
                <div class="mt-4 grid gap-3 sm:grid-cols-2">
                    <div>
                        <label class="block text-xs font-semibold uppercase tracking-wide text-slate-500">{{ t('customer_instance_locked_version', page_locale()) }}</label>
                        <select name="locked_version"
                            class="mt-1.5 w-full rounded-lg border border-slate-600/80 bg-slate-900/60 px-3 py-2 text-sm text-slate-200 focus:border-indigo-500 focus:outline-none"
                            data-minecraft-version>
                            <option value="" {% if (instance.locked_version ?? '') == '' %}selected{% endif %}>{{ t('customer_instance_latest_option', page_locale()) }}</option>
                            {% for version in versionOptions %}
                                <option value="{{ version }}" {% if version == (instance.locked_version ?? '') %}selected{% endif %}>{{ version }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    {% if resolverType == 'papermc_paper' %}
                        <div>
                            <label class="block text-xs font-semibold uppercase tracking-wide text-slate-500">{{ t('customer_instance_locked_build_id', page_locale()) }}</label>
                            <select name="locked_build_id"
                                class="mt-1.5 w-full rounded-lg border border-slate-600/80 bg-slate-900/60 px-3 py-2 text-sm text-slate-200 focus:border-indigo-500 focus:outline-none"
                                data-minecraft-build>
                                <option value="" {% if (instance.locked_build_id ?? '') == '' %}selected{% endif %}>{{ t('customer_instance_latest_option', page_locale()) }}</option>
                                {% for version, builds in minecraftCatalog.paper.builds %}
                                    {% for build in builds %}
                                        <option value="{{ build }}" data-version="{{ version }}" {% if build == (instance.locked_build_id ?? '') %}selected{% endif %}>
                                            {{ build }} ({{ version }})
                                        </option>
                                    {% endfor %}
                                {% endfor %}
                            </select>
                        </div>
                    {% else %}
                        <input type="hidden" name="locked_build_id" value="">
                    {% endif %}
                </div>
                <p class="mt-3 text-xs text-slate-500">{{ t('customer_instance_lock_remove_hint', page_locale()) }}</p>
            {% else %}
                <div class="mt-4 grid gap-3 sm:grid-cols-2">
                    <div>
                        <label class="block text-xs font-semibold uppercase tracking-wide text-slate-500">{{ t('customer_instance_locked_build_id', page_locale()) }}</label>
                        <input type="text" name="locked_build_id" value="{{ instance.locked_build_id ?? '' }}"
                            placeholder="{{ t('customer_instance_locked_build_placeholder', page_locale()) }}"
                            class="mt-1.5 w-full rounded-lg border border-slate-600/80 bg-slate-900/60 px-3 py-2 text-sm text-slate-200 placeholder-slate-600 focus:border-indigo-500 focus:outline-none">
                    </div>
                    <div>
                        <label class="block text-xs font-semibold uppercase tracking-wide text-slate-500">{{ t('customer_instance_lock_label', page_locale()) }}</label>
                        <input type="text" name="locked_version" value="{{ instance.locked_version ?? '' }}"
                            placeholder="{{ t('customer_instance_lock_label_placeholder', page_locale()) }}"
                            class="mt-1.5 w-full rounded-lg border border-slate-600/80 bg-slate-900/60 px-3 py-2 text-sm text-slate-200 placeholder-slate-600 focus:border-indigo-500 focus:outline-none">
                    </div>
                </div>
                <p class="mt-3 text-xs text-slate-500">{{ t('customer_instance_lock_remove_hint', page_locale()) }}</p>
            {% endif %}
        </div>
    </div>

    <div class="flex justify-end">
        <button type="submit"
            class="rounded-lg bg-indigo-600 px-4 py-2 text-xs font-semibold text-white transition hover:bg-indigo-500">
            {{ t('customer_instance_save_update_settings', page_locale()) }}
        </button>
    </div>

    </form>

{% if isMinecraft and resolverType == 'papermc_paper' %}
    <script>
        (() => {
            const versionSelects = document.querySelectorAll('[data-minecraft-version]');
            versionSelects.forEach((versionSelect) => {
                const form = versionSelect.closest('form');
                const buildSelect = form ? form.querySelector('[data-minecraft-build]') : null;
                if (!buildSelect) return;
                const updateBuilds = () => {
                    const version = versionSelect.value;
                    const options = Array.from(buildSelect.options);
                    options.forEach((option, index) => {
                        if (index === 0) { option.hidden = false; option.disabled = false; return; }
                        const optionVersion = option.dataset.version || '';
                        const shouldShow = version === '' || optionVersion === version;
                        option.hidden = !shouldShow;
                        option.disabled = !shouldShow;
                    });
                    if (buildSelect.selectedOptions.length > 0 && buildSelect.selectedOptions[0].disabled) {
                        buildSelect.value = '';
                    }
                };
                updateBuilds();
                versionSelect.addEventListener('change', updateBuilds);
            });
        })();
    </script>
{% endif %}
