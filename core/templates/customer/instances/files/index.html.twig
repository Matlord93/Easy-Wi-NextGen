{% extends 'customer/base.html.twig' %}

{% block content %}
    {% set displayName = instance.server_name ?? instance.name %}
    {% set locale = page_locale() %}
    <div
        class="cust-page"
        id="file-manager-app"
        data-instance-id="{{ instance.id }}"
        data-files-list-url="{{ path('customer_instance_files_api_list', {id: instance.id}) }}"
        data-files-download-url="{{ path('customer_instance_files_api_download', {id: instance.id}) }}"
        data-files-read-url="{{ path('customer_instance_files_api_read', {id: instance.id}) }}"
        data-files-upload-url="{{ path('customer_instance_files_api_upload', {id: instance.id}) }}"
        data-files-save-url="{{ path('customer_instance_files_api_save', {id: instance.id}) }}"
        data-files-mkdir-url="{{ path('customer_instance_files_api_mkdir', {id: instance.id}) }}"
        data-files-delete-url="{{ path('customer_instance_files_api_delete', {id: instance.id}) }}"
        data-files-diagnostics-url="{{ path('customer_instance_files_api_diagnostics', {id: instance.id}) }}"
        data-addons-install-url="{{ path('customer_instance_addons_install', {id: instance.id}) }}"
        data-files-max-upload-bytes="104857600"
    >

        <div class="cust-hero">
            <div class="cust-hero__inner">
                <div>
                    <div class="cust-hero__label">{{ t('customer_instance_files_instance_label', locale) }}</div>
                    <h1 class="cust-hero__title">{{ t('customer_instance_files_title', locale) }}</h1>
                    <p class="cust-hero__desc">{{ t('customer_instance_files_intro', locale) }}</p>
                </div>
            </div>
            <div class="cust-hero__stats" style="grid-template-columns:repeat(2,1fr);max-width:360px;">
                <div class="cust-hero__stat">
                    <div class="cust-hero__stat-label">{{ t('customer_instance_files_instance_label', locale) }}</div>
                    <div class="cust-hero__stat-value" style="font-size:13px;word-break:break-all;">{{ displayName }}</div>
                    <div class="cust-hero__stat-sub">{{ instance.game_key }}</div>
                </div>
                <div class="cust-hero__stat">
                    <div class="cust-hero__stat-label">Node</div>
                    <div class="cust-hero__stat-value" style="font-size:13px;">{{ instance.node.name }}</div>
                    <div class="cust-hero__stat-sub">#{{ instance.node.id }}</div>
                </div>
            </div>
        </div>

        <div class="fm-layout">

            {# ── Sidebar ── #}
            <div class="fm-sidebar">

                <div class="cust-panel" id="file-diagnostics-card">
                    <div class="cust-panel__head">
                        <div>
                            <h3 class="cust-panel__title">{{ t('customer_instance_files_diagnostics_title', locale) }}</h3>
                            <p class="fm-sub">{{ t('customer_instance_files_diagnostics_intro', locale) }}</p>
                        </div>
                    </div>
                    <div class="cust-panel__body">
                        <button type="button" class="ui-button ui-button--ghost ui-button--sm" id="file-diagnostics-run">
                            {{ t('customer_instance_files_diagnostics_run', locale) }}
                        </button>
                        <div class="fm-diag-results" id="file-diagnostics-results"></div>
                        <p class="fm-hint" id="file-diagnostics-status"></p>
                    </div>
                </div>

                <div class="cust-panel">
                    <div class="cust-panel__head">
                        <div>
                            <h3 class="cust-panel__title">{{ t('customer_instance_addons_plugins_title', locale) }}</h3>
                            <p class="fm-sub">{{ t('customer_instance_addons_plugins_intro', locale) }}</p>
                        </div>
                        <span class="fm-hint" id="addons-feedback"></span>
                    </div>
                    <div class="cust-panel__body">
                        {% for plugin in availablePlugins %}
                            <div class="fm-addon-row">
                                <div>
                                    <div class="fm-item-name">{{ plugin.name }}</div>
                                    <div class="fm-hint">{{ plugin.version }}</div>
                                    {% if plugin.description %}
                                        <div class="fm-hint" style="margin-top:3px;">{{ plugin.description }}</div>
                                    {% endif %}
                                </div>
                                <button type="button" class="ui-button ui-button--primary ui-button--sm addon-install-button" data-plugin-id="{{ plugin.id }}">
                                    {{ t('customer_instance_addons_install', locale) }}
                                </button>
                            </div>
                        {% else %}
                            <div class="fm-empty">{{ t('customer_instance_addons_no_plugins_available', locale) }}</div>
                        {% endfor %}
                    </div>
                </div>

                <div class="cust-panel">
                    <div class="cust-panel__head">
                        <div>
                            <h3 class="cust-panel__title">{{ t('customer_instance_files_config_title', locale) }}</h3>
                            <p class="fm-sub">{{ t('customer_instance_files_config_intro', locale) }}</p>
                        </div>
                    </div>
                    <div class="cust-panel__body">
                        {% for config in configFiles %}
                            <div class="fm-config-row">
                                <div class="fm-config-path">{{ config.path }}</div>
                                <div class="fm-hint">{{ config.description ?: t('customer_instance_files_config_description_empty', locale) }}</div>
                                <button type="button" class="ui-button ui-button--ghost ui-button--sm file-open-config" data-path="{{ config.dir }}" data-name="{{ config.name }}">
                                    {{ t('customer_instance_files_config_edit', locale) }}
                                </button>
                            </div>
                        {% else %}
                            <div class="fm-empty">{{ t('customer_instance_files_config_empty', locale) }}</div>
                        {% endfor %}
                    </div>
                </div>

            </div>

            {# ── Main panel ── #}
            <div class="cust-panel fm-main">
                <div class="cust-panel__head">
                    <div>
                        <h3 class="cust-panel__title">{{ t('customer_instance_files_listing_title', locale) }}</h3>
                        <p class="fm-sub">{{ t('customer_instance_files_listing_intro', locale) }}</p>
                    </div>
                </div>
                <div class="cust-panel__body">

                    <form class="fm-path-form" id="file-path-form">
                        <label class="form-label">{{ t('customer_instance_files_relative_path', locale) }}</label>
                        <input id="file-path-input" name="path" value="{{ path }}" readonly class="form-input" style="font-family:monospace;font-size:12px;">
                        <div class="fm-hint">{{ t('customer_instance_files_relative_path_hint', locale) }}</div>
                        <button type="submit" class="ui-button ui-button--primary" style="width:100%;">{{ t('customer_instance_files_load_listing', locale) }}</button>
                    </form>

                    <div class="fm-nav">
                        <div class="fm-nav__info">
                            <span class="fm-nav__label">{{ t('customer_instance_files_root', locale) }}</span>
                            <span class="fm-nav__value" id="file-root-path">—</span>
                        </div>
                        <div class="fm-nav__info">
                            <span class="fm-nav__label">{{ t('customer_instance_files_path', locale) }}</span>
                            <span class="fm-nav__value" id="file-current-path">/</span>
                        </div>
                        <button type="button" class="ui-button ui-button--ghost ui-button--sm" id="file-up-one-level">
                            {{ t('customer_instance_files_up_one_level', locale) }}
                        </button>
                    </div>
                    <div id="file-breadcrumb" class="fm-breadcrumb"></div>

                    <div class="fm-actions-grid">
                        {% if app_setting('customer_file_push_enabled', true) %}
                            <form class="fm-action-form" id="file-upload-form" enctype="multipart/form-data">
                                <input type="hidden" name="path" value="{{ path }}">
                                <label class="form-label">{{ t('customer_instance_files_upload_label', locale) }}</label>
                                <div class="fm-hint">Max upload size: 100 MB</div>
                                <input type="file" name="upload" class="fm-file-input">
                                <button type="submit" class="ui-button ui-button--primary ui-button--sm" style="width:100%;">{{ t('customer_instance_files_upload_action', locale) }}</button>
                            </form>
                        {% else %}
                            <div class="fm-disabled-notice">{{ t('customer_instance_files_upload_disabled', locale) }}</div>
                        {% endif %}
                        <form class="fm-action-form" id="file-mkdir-form">
                            <input type="hidden" name="path" value="{{ path }}">
                            <label class="form-label">{{ t('customer_instance_files_new_folder', locale) }}</label>
                            <input type="text" name="name" placeholder="{{ t('customer_instance_files_folder_placeholder', locale) }}" class="form-input" style="font-size:12px;padding:6px 10px;">
                            <button type="submit" class="ui-button ui-button--ghost ui-button--sm" style="width:100%;">{{ t('customer_instance_files_create_folder', locale) }}</button>
                        </form>
                        <form class="fm-action-form" id="file-create-form">
                            <input type="hidden" name="path" value="{{ path }}">
                            <label class="form-label">{{ t('customer_instance_files_new_file', locale) }}</label>
                            <input type="text" name="name" placeholder="{{ t('customer_instance_files_file_placeholder', locale) }}" class="form-input" style="font-size:12px;padding:6px 10px;">
                            <button type="submit" class="ui-button ui-button--ghost ui-button--sm" style="width:100%;">{{ t('customer_instance_files_create_file', locale) }}</button>
                        </form>
                    </div>
                    <div id="file-feedback" class="fm-feedback"></div>

                    <div class="fm-table-wrap">
                        <table class="fm-table">
                            <thead>
                                <tr>
                                    <th>{{ t('customer_instance_files_table_name', locale) }}</th>
                                    <th>{{ t('customer_instance_files_table_type', locale) }}</th>
                                    <th>{{ t('customer_instance_files_table_size', locale) }}</th>
                                    <th>{{ t('customer_instance_files_table_permissions', locale) }}</th>
                                    <th>{{ t('customer_instance_files_table_modified', locale) }}</th>
                                    <th>{{ t('customer_instance_files_table_actions', locale) }}</th>
                                </tr>
                            </thead>
                            <tbody id="file-listing-body">
                                <tr><td colspan="6" class="fm-table__placeholder">{{ t('customer_instance_files_loading_listing', locale) }}</td></tr>
                            </tbody>
                        </table>
                    </div>

                    <div class="cust-panel" id="file-editor" style="margin:0;border:1px solid var(--ng-border);">
                        <form id="file-editor-form">
                            <div class="cust-panel__body">
                                <div>
                                    <label class="form-label">{{ t('customer_instance_files_file_placeholder', locale) }}</label>
                                    <input type="text" id="file-editor-name" class="form-input" style="font-size:12px;padding:6px 10px;margin-top:4px;" placeholder="{{ t('customer_instance_files_file_placeholder', locale) }}">
                                    <input type="hidden" id="file-editor-path" value="{{ path }}">
                                </div>
                                <div>
                                    <label class="form-label">{{ t('customer_instance_files_config_edit', locale) }}</label>
                                    <textarea id="file-editor-content" rows="10" class="form-input fm-editor-textarea" style="margin-top:4px;"></textarea>
                                </div>
                                <div class="fm-editor-actions">
                                    <button type="submit" class="ui-button ui-button--primary ui-button--sm">{{ t('customer_instance_files_save', locale) }}</button>
                                    <button type="button" class="ui-button ui-button--ghost ui-button--sm" id="file-editor-clear">{{ t('customer_instance_files_editor_empty', locale) }}</button>
                                </div>
                            </div>
                        </form>
                    </div>

                </div>
            </div>
        </div>
    </div>

    <style>
    .fm-layout{display:grid;grid-template-columns:1fr;gap:16px}
    @media(min-width:1024px){.fm-layout{grid-template-columns:280px 1fr;align-items:start}}
    .fm-sidebar{display:flex;flex-direction:column;gap:16px}
    .cust-panel__body{display:flex;flex-direction:column;gap:10px;padding:14px 18px}
    .fm-sub{font-size:11px;color:var(--ng-text-muted);margin-top:2px}
    .fm-hint{font-size:11px;color:var(--ng-text-muted)}
    .fm-addon-row{display:flex;align-items:flex-start;justify-content:space-between;gap:10px;padding:10px;background:var(--ng-surface-soft);border:1px solid var(--ng-border);border-radius:8px}
    .fm-item-name{font-size:13px;font-weight:600;color:var(--ng-text)}
    .fm-config-row{padding:10px;background:var(--ng-surface-soft);border:1px solid var(--ng-border);border-radius:8px;display:flex;flex-direction:column;gap:4px}
    .fm-config-path{font-size:12px;font-weight:600;color:var(--ng-text);font-family:monospace}
    .fm-empty{padding:12px;border:1px dashed var(--ng-border);border-radius:8px;font-size:12px;color:var(--ng-text-muted);text-align:center}
    .fm-path-form{display:flex;flex-direction:column;gap:6px;padding:14px 18px;border-bottom:1px solid var(--ng-border)}
    .fm-nav{display:flex;flex-wrap:wrap;align-items:center;gap:10px;padding:8px 14px;background:var(--ng-surface-soft);border:1px solid var(--ng-border);border-radius:8px}
    .fm-nav__info{display:flex;align-items:center;gap:5px;flex:1;min-width:100px}
    .fm-nav__label{font-size:10px;text-transform:uppercase;letter-spacing:.05em;color:var(--ng-text-muted)}
    .fm-nav__value{font-size:12px;font-weight:600;color:var(--ng-text);font-family:monospace}
    .fm-breadcrumb{display:flex;flex-wrap:wrap;align-items:center;gap:4px;padding:7px 14px;background:var(--ng-surface-soft);border:1px solid var(--ng-border);border-radius:8px;font-size:12px;color:var(--ng-text-muted)}
    .fm-breadcrumb__root,.fm-breadcrumb__item{background:none;border:none;cursor:pointer;padding:1px 3px;border-radius:4px;font-size:12px;font-weight:600}
    .fm-breadcrumb__root{color:var(--ng-primary)}
    .fm-breadcrumb__item{color:var(--ng-text)}
    .fm-breadcrumb__root:hover,.fm-breadcrumb__item:hover{color:var(--ng-primary)}
    .fm-breadcrumb__sep{color:var(--ng-text-muted)}
    .fm-actions-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:10px;padding:12px 14px;background:var(--ng-surface-soft);border:1px solid var(--ng-border);border-radius:8px}
    .fm-action-form{display:flex;flex-direction:column;gap:5px}
    .fm-file-input{font-size:11px;color:var(--ng-text-muted)}
    .fm-disabled-notice{padding:10px;font-size:12px;color:var(--ng-text-muted);border:1px solid var(--ng-border);border-radius:8px}
    .fm-feedback{font-size:12px;min-height:18px;color:var(--ng-text-muted)}
    .fm-table-wrap{overflow-x:auto;border:1px solid var(--ng-border);border-radius:10px}
    .fm-table{width:100%;min-width:680px;border-collapse:collapse;font-size:13px}
    .fm-table thead th{padding:9px 14px;text-align:left;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.05em;color:var(--ng-text-muted);background:var(--ng-surface-soft);border-bottom:1px solid var(--ng-border)}
    .fm-table tbody tr{border-bottom:1px solid var(--ng-border)}
    .fm-table tbody tr:last-child{border-bottom:none}
    .fm-table tbody tr:hover{background:var(--ng-surface-soft)}
    .fm-table td{padding:9px 14px;color:var(--ng-text);vertical-align:middle}
    .fm-table__placeholder{padding:24px;text-align:center;color:var(--ng-text-muted);font-size:13px}
    .fm-badge--dir{display:inline-flex;padding:2px 8px;border-radius:99px;font-size:11px;font-weight:600;background:rgba(99,102,241,.15);color:#818cf8}
    .fm-badge--file{display:inline-flex;padding:2px 8px;border-radius:99px;font-size:11px;font-weight:600;background:var(--ng-surface-soft);color:var(--ng-text-muted);border:1px solid var(--ng-border)}
    .fm-btn-action{background:none;border:1px solid var(--ng-border);border-radius:6px;padding:3px 9px;font-size:11px;font-weight:600;color:var(--ng-text-muted);cursor:pointer}
    .fm-btn-action:hover{border-color:var(--ng-primary);color:var(--ng-primary)}
    .fm-btn-delete{background:none;border:1px solid rgba(239,68,68,.3);border-radius:6px;padding:3px 9px;font-size:11px;font-weight:600;color:#f87171;cursor:pointer}
    .fm-btn-delete:hover{border-color:#f87171}
    .fm-btn-row{display:flex;flex-wrap:wrap;gap:5px}
    .fm-diag-ok{display:flex;flex-direction:column;gap:3px;padding:8px 10px;border:1px solid var(--ng-border);border-radius:8px;background:var(--ng-surface-soft);font-size:12px}
    .fm-diag-ok__head{font-weight:600;color:var(--ng-text)}
    .fm-diag-ok__sub{color:var(--ng-text-muted)}
    .fm-diag-err{display:flex;flex-direction:column;gap:3px;padding:8px 10px;border:1px solid rgba(239,68,68,.3);border-radius:8px;background:rgba(239,68,68,.07);font-size:12px;color:#f87171}
    .fm-diag-err__head{font-weight:600}
    .fm-diag-results{display:flex;flex-direction:column;gap:6px;margin-top:6px}
    .fm-editor-textarea{font-family:monospace;min-height:180px;resize:vertical;margin-top:4px}
    .fm-editor-actions{display:flex;gap:8px;flex-wrap:wrap}
    </style>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="/js/file-manager-errors.js"></script>
    <script>
        (() => {
            const app = document.getElementById('file-manager-app');
            if (!app) {
                return;
            }
            const listUrl = app.dataset.filesListUrl;
            const downloadUrl = app.dataset.filesDownloadUrl;
            const readUrl = app.dataset.filesReadUrl;
            const uploadUrl = app.dataset.filesUploadUrl;
            const saveUrl = app.dataset.filesSaveUrl;
            const mkdirUrl = app.dataset.filesMkdirUrl;
            const deleteUrl = app.dataset.filesDeleteUrl;
            const diagnosticsUrl = app.dataset.filesDiagnosticsUrl;
            const addonsInstallUrl = app.dataset.addonsInstallUrl;
            const maxUploadBytes = Number(app.dataset.filesMaxUploadBytes || 104857600);
            const labels = {
                loading: "{{ t('customer_instance_files_loading_listing', page_locale())|e('js') }}",
                empty: "{{ t('customer_instance_files_empty', page_locale())|e('js') }}",
                typeDirectory: "{{ t('customer_instance_files_type_directory', page_locale())|e('js') }}",
                typeFile: "{{ t('customer_instance_files_type_file', page_locale())|e('js') }}",
                open: "{{ t('customer_instance_files_open', page_locale())|e('js') }}",
                edit: "{{ t('customer_instance_files_edit', page_locale())|e('js') }}",
                download: "{{ t('customer_instance_files_download', page_locale())|e('js') }}",
                listingFailed: "{{ t('customer_instance_files_listing_failed', page_locale())|e('js') }}",
                listingFailedDefault: "{{ t('customer_instance_files_listing_failed_default', page_locale())|e('js') }}",
                delete: "{{ t('customer_instance_files_delete', page_locale())|e('js') }}",
                deleteConfirm: "{{ t('customer_instance_files_delete_confirm', page_locale())|e('js') }}",
                upload: "{{ t('customer_instance_files_upload_action', page_locale())|e('js') }}",
                createFolder: "{{ t('customer_instance_files_create_folder', page_locale())|e('js') }}",
                createFile: "{{ t('customer_instance_files_create_file', page_locale())|e('js') }}",
                save: "{{ t('customer_instance_files_save', page_locale())|e('js') }}",
                editorEmpty: "{{ t('customer_instance_files_editor_empty', page_locale())|e('js') }}",
                configEdit: "{{ t('customer_instance_files_config_edit', page_locale())|e('js') }}",
                folderPlaceholder: "{{ t('customer_instance_files_folder_placeholder', page_locale())|e('js') }}",
                filePlaceholder: "{{ t('customer_instance_files_file_placeholder', page_locale())|e('js') }}",
                requestIdLabel: "{{ t('customer_instance_files_request_id', page_locale())|e('js') }}",
                diagnosticsTitle: "{{ t('customer_instance_files_diagnostics_title', page_locale())|e('js') }}",
                diagnosticsLoading: "{{ t('customer_instance_files_diagnostics_loading', page_locale())|e('js') }}",
                diagnosticsFailed: "{{ t('customer_instance_files_diagnostics_failed', page_locale())|e('js') }}",
                diagnosticsReady: "{{ t('customer_instance_files_diagnostics_ready', page_locale())|e('js') }}",
                diagnosticsAgent: "{{ t('customer_instance_files_diagnostics_agent', page_locale())|e('js') }}",
                diagnosticsEntries: "{{ t('customer_instance_files_diagnostics_entries', page_locale())|e('js') }}",
                diagnosticsDuration: "{{ t('customer_instance_files_diagnostics_duration', page_locale())|e('js') }}",
                listingAgentMisconfigured: "{{ t('customer_instance_files_listing_agent_misconfigured', page_locale())|e('js') }}",
                listingAgentTimeout: "{{ t('customer_instance_files_listing_agent_timeout', page_locale())|e('js') }}",
                listingAgentUnreachable: "{{ t('customer_instance_files_listing_agent_unreachable', page_locale())|e('js') }}",
                listingAgentUnauthorized: "{{ t('customer_instance_files_listing_agent_unauthorized', page_locale())|e('js') }}",
                listingInvalidServerRoot: "{{ t('customer_instance_files_listing_invalid_server_root', page_locale())|e('js') }}",
                listingRootNotFound: "{{ t('customer_instance_files_listing_root_not_found', page_locale())|e('js') }}",
                listingRootNotAccessible: "{{ t('customer_instance_files_listing_root_not_accessible', page_locale())|e('js') }}",
                listingPermissionDenied: "{{ t('customer_instance_files_listing_permission_denied', page_locale())|e('js') }}",
                listingInvalidPath: "{{ t('customer_instance_files_listing_invalid_path', page_locale())|e('js') }}",
                listingTooLarge: "{{ t('customer_instance_files_listing_too_large', page_locale())|e('js') }}",
                listingTimeout: "{{ t('customer_instance_files_listing_timeout', page_locale())|e('js') }}",
                listingInternal: "{{ t('customer_instance_files_listing_internal', page_locale())|e('js') }}",
                listingPathNotFound: "{{ t('customer_instance_files_listing_path_not_found', page_locale())|e('js') }}",
                listingForbidden: "{{ t('customer_instance_files_listing_forbidden', page_locale())|e('js') }}",
                listingUnauthorized: "{{ t('customer_instance_files_listing_unauthorized', page_locale())|e('js') }}",
                addonInstalling: "{{ t('customer_instance_addons_installing', page_locale())|e('js') }}",
                addonInstallSuccess: "{{ t('customer_instance_addons_install_success', page_locale())|e('js') }}",
                addonInstallFailed: "{{ t('customer_instance_addons_install_failed', page_locale())|e('js') }}",
                uploadTooLarge: 'Upload exceeds max size.',
                diskQuotaExceeded: 'Disk quota exceeded for this instance.',
            };
            const listingBody = document.getElementById('file-listing-body');
            const rootPathEl = document.getElementById('file-root-path');
            const currentPathEl = document.getElementById('file-current-path');
            const pathInput = document.getElementById('file-path-input');
            const feedbackEl = document.getElementById('file-feedback');
            const breadcrumbEl = document.getElementById('file-breadcrumb');
            const uploadForm = document.getElementById('file-upload-form');
            const mkdirForm = document.getElementById('file-mkdir-form');
            const createForm = document.getElementById('file-create-form');
            const editorForm = document.getElementById('file-editor-form');
            const editorName = document.getElementById('file-editor-name');
            const editorPath = document.getElementById('file-editor-path');
            const editorContent = document.getElementById('file-editor-content');
            const upButton = document.getElementById('file-up-one-level');
            const clearButton = document.getElementById('file-editor-clear');
            const diagnosticsButton = document.getElementById('file-diagnostics-run');
            const diagnosticsResults = document.getElementById('file-diagnostics-results');
            const diagnosticsStatus = document.getElementById('file-diagnostics-status');
            const addonsFeedback = document.getElementById('addons-feedback');

            let currentPath = pathInput.value || '';
            const helpers = window.EasyWiFileManager || {};
            const buildRequestId = helpers.buildRequestId || (() => `${Date.now().toString(16)}-${Math.random().toString(16).slice(2, 10)}`);
            const normalizeErrorPayload = helpers.normalizeErrorPayload || ((payload, fallbackMessage, requestId) => ({
                message: (payload && (payload.message || payload.error)) || fallbackMessage,
                errorCode: (payload && payload.error_code) || 'unknown_error',
                details: payload && payload.details ? payload.details : {},
                requestId: (payload && payload.request_id) || requestId || '',
            }));
            const formatErrorMessage = helpers.formatErrorMessage || ((error, suffixLabel) => {
                if (!error) {
                    return '';
                }
                if (!error.requestId) {
                    return error.message;
                }
                return `${error.message} (${suffixLabel} ${error.requestId})`;
            });
            const buildHttpError = (status, requestId, fallbackMessage) => ({
                message: status ? `${fallbackMessage} (${status})` : fallbackMessage,
                errorCode: 'http_error',
                details: {
                    status,
                },
                requestId: requestId || '',
            });

            const formatBytes = (bytes) => {
                const value = Number(bytes || 0);
                if (!Number.isFinite(value) || value <= 0) {
                    return '0 B';
                }
                const units = ['B', 'KB', 'MB', 'GB', 'TB'];
                const index = Math.min(units.length - 1, Math.floor(Math.log(value) / Math.log(1024)));
                const size = value / Math.pow(1024, index);
                return `${size.toFixed(1)} ${units[index]}`;
            };

            const buildApiErrorMessage = (error) => {
                if (!error) {
                    return 'Request failed.';
                }
                if (error.errorCode === 'file_too_large') {
                    const max = Number(error.details?.max_bytes || maxUploadBytes);
                    return `${labels.uploadTooLarge} (max ${formatBytes(max)})`;
                }
                if (error.errorCode === 'disk_quota_exceeded') {
                    return error.message || labels.diskQuotaExceeded;
                }
                return error.message || 'Request failed.';
            };

            const setFeedback = (message, type = 'info') => {
                if (!feedbackEl) {
                    return;
                }
                feedbackEl.textContent = message;
                feedbackEl.style.color = type === 'error' ? '#f87171' : 'var(--ng-text-muted)';
            };

            const setDiagnosticsStatus = (message, type = 'info') => {
                if (!diagnosticsStatus) {
                    return;
                }
                diagnosticsStatus.textContent = message;
                diagnosticsStatus.style.color = type === 'error' ? '#f87171' : 'var(--ng-text-muted)';
            };

            const renderDiagnostics = (data) => {
                if (!diagnosticsResults) {
                    return;
                }
                if (!data) {
                    diagnosticsResults.innerHTML = '';
                    return;
                }
                const requestId = data.request_id || '';
                const renderProbe = (probe, label) => {
                    if (!probe) {
                        return `<div class="fm-diag-err"><div class="fm-diag-err__head">${label}: ${labels.diagnosticsFailed}</div></div>`;
                    }
                    if (probe.status === 'ok') {
                        return `
                            <div class="fm-diag-ok">
                                <div class="fm-diag-ok__head">${label}: ${labels.diagnosticsReady}</div>
                                <div class="fm-diag-ok__sub">${labels.diagnosticsEntries} ${probe.entry_count} · ${labels.diagnosticsDuration} ${probe.duration_ms}ms</div>
                            </div>
                        `;
                    }
                    const message = probe.error_code ? `${probe.error_code}: ${probe.message}` : probe.message;
                    const suffix = requestId ? ` (${labels.requestIdLabel} ${requestId})` : '';
                    return `
                        <div class="fm-diag-err">
                            <div class="fm-diag-err__head">${label}: ${labels.diagnosticsFailed}</div>
                            <div>${message}${suffix}</div>
                        </div>
                    `;
                };
                diagnosticsResults.innerHTML = `
                    ${renderProbe(data.agent, labels.diagnosticsAgent)}
                `;
            };

            const readErrorPayload = async (response, fallbackMessage) => {
                const requestId = response.headers.get('X-Request-ID') || '';
                const payload = await response.json().catch(() => null);
                return normalizeErrorPayload(payload, fallbackMessage, requestId);
            };

            const runDiagnostics = async () => {
                if (!diagnosticsUrl) {
                    return;
                }
                setDiagnosticsStatus(labels.diagnosticsLoading);
                if (diagnosticsButton) {
                    diagnosticsButton.disabled = true;
                }
                try {
                    const requestId = buildRequestId();
                    const response = await fetch(`${diagnosticsUrl}${buildQuery({ path: currentPath })}`, {
                        headers: {
                            'Accept': 'application/json',
                            'X-Request-ID': requestId,
                        },
                    });
                    const data = await response.json().catch(() => null);
                    if (!response.ok) {
                        const errorInfo = normalizeErrorPayload(data, labels.diagnosticsFailed, response.headers.get('X-Request-ID'));
                        setDiagnosticsStatus(formatErrorMessage(errorInfo, labels.requestIdLabel) || labels.diagnosticsFailed, 'error');
                        renderDiagnostics(null);
                        return;
                    }
                    renderDiagnostics(data);
                    setDiagnosticsStatus(labels.diagnosticsReady);
                } catch (error) {
                    setDiagnosticsStatus(labels.diagnosticsFailed, 'error');
                    renderDiagnostics(null);
                } finally {
                    if (diagnosticsButton) {
                        diagnosticsButton.disabled = false;
                    }
                }
            };

            const buildQuery = (params) => {
                const search = new URLSearchParams(params);
                const query = search.toString();
                return query ? `?${query}` : '';
            };

            const fetchWithTimeout = async (url, options = {}, timeoutMs = 10000) => {
                const controller = new AbortController();
                const timer = setTimeout(() => controller.abort(), timeoutMs);
                try {
                    const response = await fetch(url, { ...options, signal: controller.signal });
                    return response;
                } finally {
                    clearTimeout(timer);
                }
            };

            const updatePathDisplay = (rootPath, path) => {
                rootPathEl.textContent = rootPath || '—';
                currentPathEl.textContent = path ? `/${path}` : '/';
                pathInput.value = path || '';
                currentPath = path || '';
                if (uploadForm) {
                    uploadForm.querySelector('input[name="path"]').value = currentPath;
                }
                if (mkdirForm) {
                    mkdirForm.querySelector('input[name="path"]').value = currentPath;
                }
                if (createForm) {
                    createForm.querySelector('input[name="path"]').value = currentPath;
                }
                editorPath.value = currentPath;
                renderBreadcrumb(currentPath);
            };

            const renderBreadcrumb = (path) => {
                if (!breadcrumbEl) {
                    return;
                }
                const parts = (path || '').split('/').filter(Boolean);
                let cursor = '';
                let html = `<button type="button" class="fm-breadcrumb__root" data-path="">/</button>`;
                parts.forEach((part) => {
                    cursor = cursor ? `${cursor}/${part}` : part;
                    html += `<span class="fm-breadcrumb__sep">/</span><button type="button" class="fm-breadcrumb__item" data-path="${cursor}">${part}</button>`;
                });
                breadcrumbEl.innerHTML = html;
            };

            const renderEntries = (entries) => {
                if (!entries.length) {
                    listingBody.innerHTML = `<tr><td colspan="6" class="fm-table__placeholder">${labels.empty}</td></tr>`;
                    return;
                }

                listingBody.innerHTML = entries.map((entry) => {
                    const nextPath = currentPath ? `${currentPath}/${entry.name}` : entry.name;
                    const typeBadge = entry.is_dir
                        ? `<span class="fm-badge--dir">${labels.typeDirectory}</span>`
                        : `<span class="fm-badge--file">${labels.typeFile}</span>`;
                    const actionButtons = entry.is_dir
                        ? `<button type="button" class="fm-btn-action" data-action="open" data-path="${nextPath}">${labels.open}</button>`
                        : `
                            <button type="button" class="fm-btn-action" data-action="edit" data-name="${entry.name}">${labels.edit}</button>
                            <button type="button" class="fm-btn-action" data-action="download" data-name="${entry.name}">${labels.download}</button>
                        `;
                    const deleteButton = `<button type="button" class="fm-btn-delete" data-action="delete" data-name="${entry.name}">${labels.delete}</button>`;

                    return `
                        <tr>
                            <td style="font-weight:600">${entry.name}</td>
                            <td>${typeBadge}</td>
                            <td>${entry.size_human}</td>
                            <td style="font-family:monospace;font-size:11px">${entry.mode}</td>
                            <td style="font-size:11px">${entry.modified_at}</td>
                            <td>
                                <div class="fm-btn-row">
                                    ${actionButtons}
                                    ${deleteButton}
                                </div>
                            </td>
                        </tr>
                    `;
                }).join('');
            };

            const loadListing = async (path) => {
                setFeedback(labels.loading);
                listingBody.innerHTML = `<tr><td colspan="6" class="fm-table__placeholder">${labels.loading}</td></tr>`;
                try {
                    const requestId = buildRequestId();
                    const response = await fetchWithTimeout(`${listUrl}${buildQuery({ path })}`, {
                        headers: {
                            'Accept': 'application/json',
                            'X-Request-ID': requestId,
                        },
                    });
                    const responseRequestId = response.headers.get('X-Request-ID');
                    const data = await response.json().catch(() => ({}));
                    const hasEntries = Array.isArray(data.entries);
                    const hasErrorPayload = Boolean(data && (data.error_code || data.error || data.message));
                    const hasListingPayload = hasEntries
                        && Object.prototype.hasOwnProperty.call(data, 'root_path')
                        && Object.prototype.hasOwnProperty.call(data, 'path');
                    if (!response.ok || hasErrorPayload || !hasListingPayload) {
                        const statusForError = response.ok ? null : response.status;
                        const errorInfo = hasErrorPayload
                            ? normalizeErrorPayload(data, labels.listingFailedDefault, responseRequestId)
                            : buildHttpError(statusForError, responseRequestId, labels.listingFailedDefault);
                        const message = resolveListingError(errorInfo);
                        throw new Error(message);
                    }
                    updatePathDisplay(data.root_path, data.path);
                    renderEntries(data.entries || []);
                    setFeedback('');
                } catch (error) {
                    const message = error.name === 'AbortError'
                        ? labels.listingFailedDefault
                        : (error.message || labels.listingFailed);
                    listingBody.innerHTML = `<tr><td colspan="6" class="fm-table__placeholder" style="color:#f87171">${message}</td></tr>`;
                    setFeedback(message, 'error');
                } finally {
                    if (feedbackEl && feedbackEl.textContent === labels.loading) {
                        setFeedback('');
                    }
                }
            };

            const downloadFile = (path, name) => {
                const url = `${downloadUrl}${buildQuery({ path, name })}`;
                window.location.assign(url);
            };

            const resolveListingError = (errorInfo) => {
                if (!errorInfo) {
                    return labels.listingFailedDefault;
                }
                const mapping = {
                    agent_misconfigured: labels.listingAgentMisconfigured,
                    agent_timeout: labels.listingAgentTimeout,
                    agent_unreachable: labels.listingAgentUnreachable,
                    agent_unauthorized: labels.listingAgentUnauthorized,
                    agent_not_found: labels.listingFailedDefault,
                    agent_error: labels.listingFailedDefault,
                    INVALID_SERVER_ROOT: labels.listingInvalidServerRoot,
                    SERVER_ROOT_NOT_FOUND: labels.listingRootNotFound,
                    SERVER_ROOT_NOT_ACCESSIBLE: labels.listingRootNotAccessible,
                    PERMISSION_DENIED: labels.listingPermissionDenied,
                    NOT_FOUND: labels.listingPathNotFound,
                    INVALID_PATH: labels.listingInvalidPath,
                    invalid_path: labels.listingInvalidPath,
                    PATH_OUTSIDE_INSTANCE_ROOT: labels.listingInvalidPath,
                    path_outside_instance_root: labels.listingInvalidPath,
                    TOO_LARGE: labels.listingTooLarge,
                    TIMEOUT: labels.listingTimeout,
                    INTERNAL: labels.listingInternal,
                    files_listing_failed: labels.listingFailedDefault,
                    files_forbidden: labels.listingForbidden,
                    files_unauthorized: labels.listingUnauthorized,
                };
                const message = mapping[errorInfo.errorCode] || errorInfo.message || labels.listingFailedDefault;
                return formatErrorMessage({ ...errorInfo, message }, labels.requestIdLabel);
            };

            const readFile = async (path, name) => {
                try {
                    const response = await fetch(`${readUrl}${buildQuery({ path, name })}`);
                    if (!response.ok) {
                        const data = await response.json().catch(() => ({}));
                        throw new Error(data.error || 'Download failed.');
                    }
                    return await response.text();
                } catch (error) {
                    setFeedback(error.message, 'error');
                    return null;
                }
            };

            if (diagnosticsButton) {
                diagnosticsButton.addEventListener('click', () => {
                    runDiagnostics();
                });
            }

            upButton.addEventListener('click', () => {
                if (!currentPath) {
                    return;
                }
                const parts = currentPath.split('/').filter(Boolean);
                parts.pop();
                loadListing(parts.join('/'));
            });

            listingBody.addEventListener('click', async (event) => {
                const target = event.target.closest('[data-action]');
                if (!target) {
                    return;
                }
                const action = target.dataset.action;
                const name = target.dataset.name || '';
                const path = target.dataset.path || currentPath;

                if (action === 'open') {
                    loadListing(path);
                    return;
                }

                if (action === 'download') {
                    downloadFile(currentPath, name);
                    return;
                }

                if (action === 'edit') {
                    const content = await readFile(currentPath, name);
                    if (content === null) {
                        return;
                    }
                    editorName.value = name;
                    editorPath.value = currentPath;
                    editorContent.value = content;
                    setFeedback(labels.configEdit);
                    return;
                }

                if (action === 'delete') {
                    if (!confirm(labels.deleteConfirm)) {
                        return;
                    }
                    try {
                        const response = await fetch(deleteUrl, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ path: currentPath, name }),
                        });
                        const data = await response.json();
                        if (!response.ok) {
                            throw new Error(data.message || data.error || 'Delete failed.');
                        }
                        setFeedback(labels.delete);
                        loadListing(currentPath);
                    } catch (error) {
                        setFeedback(error.message, 'error');
                    }
                }
            });

            if (breadcrumbEl) {
                breadcrumbEl.addEventListener('click', (event) => {
                    const target = event.target.closest('[data-path]');
                    if (!target) {
                        return;
                    }
                    const path = target.dataset.path || '';
                    loadListing(path);
                });
            }

            if (uploadForm) {
                uploadForm.addEventListener('submit', async (event) => {
                    event.preventDefault();
                    const formData = new FormData(uploadForm);
                    formData.set('path', currentPath);
                    try {
                        const response = await fetch(uploadUrl, {
                            method: 'POST',
                            body: formData,
                        });
                        const data = await response.json();
                        if (!response.ok) {
                            const requestId = response.headers.get('X-Request-ID') || '';
                            const apiError = normalizeErrorPayload(data, 'Upload failed.', requestId);
                            throw new Error(buildApiErrorMessage(apiError));
                        }
                        uploadForm.reset();
                        setFeedback(labels.upload);
                        loadListing(currentPath);
                    } catch (error) {
                        setFeedback(error.message, 'error');
                    }
                });
            }

            mkdirForm.addEventListener('submit', async (event) => {
                event.preventDefault();
                const name = mkdirForm.querySelector('input[name="name"]').value.trim();
                if (!name) {
                    setFeedback(labels.folderPlaceholder, 'error');
                    return;
                }
                try {
                    const response = await fetch(mkdirUrl, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ path: currentPath, name }),
                    });
                    const data = await response.json();
                    if (!response.ok) {
                        throw new Error(data.message || data.error || 'Folder creation failed.');
                    }
                    mkdirForm.reset();
                    setFeedback(labels.createFolder);
                    loadListing(currentPath);
                } catch (error) {
                    setFeedback(error.message, 'error');
                }
            });

            createForm.addEventListener('submit', async (event) => {
                event.preventDefault();
                const name = createForm.querySelector('input[name="name"]').value.trim();
                if (!name) {
                    setFeedback(labels.filePlaceholder, 'error');
                    return;
                }
                try {
                    const response = await fetch(saveUrl, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ path: currentPath, name, content: '' }),
                    });
                    const data = await response.json();
                    if (!response.ok) {
                        throw new Error(data.message || data.error || 'File creation failed.');
                    }
                    createForm.reset();
                    setFeedback(labels.createFile);
                    loadListing(currentPath);
                } catch (error) {
                    setFeedback(error.message, 'error');
                }
            });

            editorForm.addEventListener('submit', async (event) => {
                event.preventDefault();
                const name = editorName.value.trim();
                if (!name) {
                    setFeedback(labels.filePlaceholder, 'error');
                    return;
                }
                try {
                    const response = await fetch(saveUrl, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            path: editorPath.value.trim(),
                            name,
                            content: editorContent.value,
                        }),
                    });
                    const data = await response.json();
                    if (!response.ok) {
                        throw new Error(data.message || data.error || 'Save failed.');
                    }
                    setFeedback(labels.save);
                    loadListing(editorPath.value.trim());
                } catch (error) {
                    setFeedback(error.message, 'error');
                }
            });

            clearButton.addEventListener('click', () => {
                editorName.value = '';
                editorContent.value = '';
                setFeedback(labels.editorEmpty);
            });

            document.querySelectorAll('.file-open-config').forEach((button) => {
                button.addEventListener('click', async () => {
                    const path = button.dataset.path || '';
                    const name = button.dataset.name || '';
                    const content = await readFile(path, name);
                    if (content === null) {
                        return;
                    }
                    editorName.value = name;
                    editorPath.value = path;
                    editorContent.value = content;
                });
            });

            if (addonsInstallUrl) {
                const addonButtons = document.querySelectorAll('.addon-install-button');
                addonButtons.forEach((button) => {
                    button.addEventListener('click', async () => {
                        const pluginId = button.dataset.pluginId;
                        if (!pluginId) {
                            return;
                        }
                        button.disabled = true;
                        if (addonsFeedback) {
                            addonsFeedback.textContent = labels.addonInstalling;
                            addonsFeedback.style.color = 'var(--ng-text-muted)';
                        }
                        try {
                            const response = await fetch(addonsInstallUrl, {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({ plugin_id: pluginId }),
                            });
                            const data = await response.json().catch(() => ({}));
                            if (!response.ok) {
                                throw new Error(data.message || data.error || labels.addonInstallFailed);
                            }
                            if (addonsFeedback) {
                                addonsFeedback.textContent = labels.addonInstallSuccess;
                                addonsFeedback.style.color = '#4ade80';
                            }
                        } catch (error) {
                            if (addonsFeedback) {
                                addonsFeedback.textContent = error.message || labels.addonInstallFailed;
                                addonsFeedback.style.color = '#f87171';
                            }
                        } finally {
                            button.disabled = false;
                        }
                    });
                });
            }
            loadListing(currentPath);
        })();
    </script>
{% endblock %}
