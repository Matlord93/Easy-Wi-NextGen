{% set locale = page_locale() %}
<div class="space-y-5">
    {# ─── Status-Banner ─── #}
    <div class="rounded-xl border {{ setupStatus.is_ready ? 'border-emerald-700/50 bg-emerald-500/10' : 'border-amber-700/50 bg-amber-500/10' }} p-4">
        <div class="flex items-start gap-3">
            {% if setupStatus.is_ready %}
                <svg class="mt-0.5 h-5 w-5 shrink-0 text-emerald-400" fill="currentColor" viewBox="0 0 16 16"><path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zm-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z"/></svg>
                <p class="text-sm text-emerald-300">Alle Pflichtfelder sind gesetzt. Du kannst den Server installieren und starten.</p>
            {% else %}
                <svg class="mt-0.5 h-5 w-5 shrink-0 text-amber-400" fill="currentColor" viewBox="0 0 16 16"><path d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767L8.982 1.566zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5zm.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2z"/></svg>
                <div>
                    <p class="text-sm text-amber-300">Bitte trage die fehlenden Angaben ein, um den Server nutzen zu können.</p>
                    {% if setupMissingLabels is not empty %}
                        <ul class="mt-2 list-disc pl-4 text-xs text-amber-400 space-y-0.5">
                            {% for label in setupMissingLabels %}
                                <li>{{ label }}</li>
                            {% endfor %}
                        </ul>
                    {% else %}
                        <p class="mt-1 text-xs text-amber-500">Einige Felder müssen vom Support ergänzt werden.</p>
                    {% endif %}
                </div>
            {% endif %}
        </div>
    </div>

    <div class="grid gap-5 lg:grid-cols-2">
        {# ─── Variablen ─── #}
        <div class="space-y-5">
            <div class="rounded-xl border border-slate-700/60 bg-slate-800/40">
                <div class="border-b border-slate-700/50 px-4 py-3">
                    <h3 class="text-sm font-semibold text-slate-200">Variablen</h3>
                    <p class="mt-0.5 text-xs text-slate-500">Alle Variablen außer Ports – werden im Start-Skript oder in den Configs gespeichert.</p>
                </div>
                <div class="p-4">
                    {% if setupMessages.vars %}
                        <div class="mb-4 rounded-lg border border-emerald-700/40 bg-emerald-500/10 px-3 py-2 text-sm text-emerald-300">{{ setupMessages.vars }}</div>
                    {% endif %}
                    <form action="{{ path('customer_instance_setup_vars', {id: instance.id}) }}" method="post" class="space-y-4">
                        {% for field in setupVariableVars %}
                            {% if field.key not in ['STEAM_ACCOUNT', 'STEAM_PASSWORD'] or steamLoginMode == 'account' %}
                                <div>
                                    <label class="block text-xs font-semibold uppercase tracking-wide text-slate-400">
                                        {{ field.label }}{% if field.required %} <span class="text-rose-400">*</span>{% endif %}
                                    </label>
                                    {% if field.key == 'STEAM_LOGIN_MODE' %}
                                        <select name="vars[{{ field.key }}]"
                                            class="mt-1.5 w-full rounded-lg border border-slate-600/80 bg-slate-900/60 px-3 py-2 text-sm text-slate-200 focus:border-indigo-500 focus:outline-none">
                                            <option value="anonymous" {{ field.value == 'account' ? '' : 'selected' }}>Anonymous</option>
                                            <option value="account" {{ field.value == 'account' ? 'selected' : '' }}>Steam Account</option>
                                        </select>
                                    {% else %}
                                        <input name="vars[{{ field.key }}]" value="{{ field.value }}"
                                            type="{% if field.type == 'number' %}number{% elseif field.type == 'password' %}password{% else %}text{% endif %}"
                                            class="mt-1.5 w-full rounded-lg border border-slate-600/80 bg-slate-900/60 px-3 py-2 text-sm text-slate-200 placeholder-slate-600 focus:border-indigo-500 focus:outline-none">
                                    {% endif %}
                                    {% if field.helptext %}
                                        <p class="mt-1 text-[11px] text-slate-500">{{ t(field.helptext, locale) }}</p>
                                    {% endif %}
                                    {% if field.error %}
                                        <p class="mt-1 text-xs text-rose-400">{{ field.error }}</p>
                                    {% endif %}
                                </div>
                            {% endif %}
                        {% else %}
                            <p class="text-sm text-slate-500">Keine Variablen definiert.</p>
                        {% endfor %}
                        <button type="submit"
                            class="rounded-lg bg-indigo-600 px-4 py-2 text-xs font-semibold text-white transition hover:bg-indigo-500">
                            Variablen speichern
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <div class="space-y-5">
            {# ─── Config-Variablen ─── #}
            <div class="rounded-xl border border-slate-700/60 bg-slate-800/40">
                <div class="border-b border-slate-700/50 px-4 py-3">
                    <h3 class="text-sm font-semibold text-slate-200">{{ t('customer_instances_setup_title', locale) }}</h3>
                    <p class="mt-0.5 text-xs text-slate-500">Diese Werte werden direkt in der Server-Config gespeichert.</p>
                </div>
                <div class="p-4">
                    {% if setupMessages.vars %}
                        <div class="mb-4 rounded-lg border border-emerald-700/40 bg-emerald-500/10 px-3 py-2 text-sm text-emerald-300">{{ setupMessages.vars }}</div>
                    {% endif %}
                    <form action="{{ path('customer_instance_setup_vars', {id: instance.id}) }}" method="post" class="space-y-4">
                        {% for field in setupConfigVars %}
                            <div>
                                <label class="block text-xs font-semibold uppercase tracking-wide text-slate-400">
                                    {{ field.label }}{% if field.required %} <span class="text-rose-400">*</span>{% endif %}
                                </label>
                                <input name="vars[{{ field.key }}]" value="{{ field.value }}"
                                    type="{% if field.type == 'number' %}number{% elseif field.type == 'password' %}password{% else %}text{% endif %}"
                                    class="mt-1.5 w-full rounded-lg border border-slate-600/80 bg-slate-900/60 px-3 py-2 text-sm text-slate-200 placeholder-slate-600 focus:border-indigo-500 focus:outline-none">
                                {% if field.helptext %}
                                    <p class="mt-1 text-[11px] text-slate-500">{{ t(field.helptext, locale) }}</p>
                                {% endif %}
                                {% if field.error %}
                                    <p class="mt-1 text-xs text-rose-400">{{ field.error }}</p>
                                {% endif %}
                            </div>
                        {% else %}
                            <p class="text-sm text-slate-500">{{ t('customer_instances_setup_none', locale) }}</p>
                        {% endfor %}
                        <button type="submit"
                            class="rounded-lg bg-indigo-600 px-4 py-2 text-xs font-semibold text-white transition hover:bg-indigo-500">
                            {{ t('customer_instances_setup_save', locale) }}
                        </button>
                    </form>
                </div>
            </div>

            {# ─── Secrets ─── #}
            <div class="rounded-xl border border-slate-700/60 bg-slate-800/40">
                <div class="border-b border-slate-700/50 px-4 py-3">
                    <h3 class="text-sm font-semibold text-slate-200">Secrets</h3>
                </div>
                <div class="p-4">
                    {% if setupMessages.secrets %}
                        <div class="mb-4 rounded-lg border border-emerald-700/40 bg-emerald-500/10 px-3 py-2 text-sm text-emerald-300">{{ setupMessages.secrets }}</div>
                    {% endif %}
                    <form action="{{ path('customer_instance_setup_secrets', {id: instance.id}) }}" method="post" class="space-y-4">
                        {% for field in setupSecrets %}
                            <div>
                                <label class="block text-xs font-semibold uppercase tracking-wide text-slate-400">
                                    {{ field.label }}{% if field.required %} <span class="text-rose-400">*</span>{% endif %}
                                </label>
                                <div class="mt-1.5 flex flex-col gap-1.5">
                                    <input name="secrets[{{ field.key }}]"
                                        type="{{ field.type == 'number' ? 'number' : 'password' }}"
                                        class="w-full rounded-lg border border-slate-600/80 bg-slate-900/60 px-3 py-2 text-sm text-slate-200 placeholder-slate-600 focus:border-indigo-500 focus:outline-none"
                                        placeholder="Neues Secret eingeben">
                                    <span class="text-[11px] text-slate-500">
                                        Gesetzt: <span class="{{ field.is_set ? 'text-emerald-400' : 'text-slate-500' }}">{{ field.is_set ? 'Ja' : 'Nein' }}</span>
                                    </span>
                                </div>
                                {% if field.helptext %}
                                    <p class="mt-1 text-[11px] text-slate-500">{{ t(field.helptext, locale) }}</p>
                                {% endif %}
                                {% if field.error %}
                                    <p class="mt-1 text-xs text-rose-400">{{ field.error }}</p>
                                {% endif %}
                            </div>
                        {% else %}
                            <p class="text-sm text-slate-500">Keine Secrets definiert.</p>
                        {% endfor %}
                        <button type="submit"
                            class="rounded-lg bg-indigo-600 px-4 py-2 text-xs font-semibold text-white transition hover:bg-indigo-500">
                            Secrets speichern
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
