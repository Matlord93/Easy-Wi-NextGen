{% set locale = page_locale() %}
<div class="cust-page">
    {# ─── Status-Banner ─── #}
    <div class="ng-alert {{ setupStatus.is_ready ? 'ng-alert--success' : 'ng-alert--warning' }}" style="margin-bottom:1.25rem">
        <div style="display:flex;align-items:flex-start;gap:0.75rem">
            {% if setupStatus.is_ready %}
                <svg style="margin-top:0.125rem;height:1.25rem;width:1.25rem;flex-shrink:0" fill="currentColor" viewBox="0 0 16 16"><path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zm-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z"/></svg>
                <p style="font-size:0.875rem">{{ t('customer_instance_setup_all_required_set', locale) }}</p>
            {% else %}
                <svg style="margin-top:0.125rem;height:1.25rem;width:1.25rem;flex-shrink:0" fill="currentColor" viewBox="0 0 16 16"><path d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767L8.982 1.566zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5zm.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2z"/></svg>
                <div>
                    <p style="font-size:0.875rem">{{ t('customer_instance_setup_missing_fields', locale) }}</p>
                    {% if setupMissingLabels is not empty %}
                        <ul style="margin-top:0.5rem;list-style:disc;padding-left:1rem;font-size:0.75rem;display:flex;flex-direction:column;gap:0.125rem">
                            {% for label in setupMissingLabels %}
                                <li>{{ label }}</li>
                            {% endfor %}
                        </ul>
                    {% else %}
                        <p style="margin-top:0.25rem;font-size:0.75rem">{{ t('customer_instance_setup_support_required', locale) }}</p>
                    {% endif %}
                </div>
            {% endif %}
        </div>
    </div>

    <div class="cust-grid-2">
        {# ─── Variables ─── #}
        <div class="cust-panel">
            <div class="cust-panel__head">
                <h2 class="cust-panel__title">{{ t('customer_instance_setup_variables_title', locale) }}</h2>
                <p style="margin-top:0.125rem;font-size:0.75rem;color:var(--ng-text-muted)">{{ t('customer_instance_setup_variables_intro', locale) }}</p>
            </div>
            <div class="cust-panel__body">
                {% if setupMessages.vars %}
                    <div class="ng-alert ng-alert--success" style="margin-bottom:1rem">{{ setupMessages.vars }}</div>
                {% endif %}
                <form action="{{ path('customer_instance_setup_vars', {id: instance.id}) }}" method="post" style="display:flex;flex-direction:column;gap:1rem">
                    {% for field in setupVariableVars %}
                        {% if field.key not in ['STEAM_ACCOUNT', 'STEAM_PASSWORD'] or steamLoginMode == 'account' %}
                            <div class="form-field">
                                <label class="form-label">
                                    {{ t(field.label, locale) }}{% if field.required %} <span style="color:var(--color-danger,#ef4444)">*</span>{% endif %}
                                </label>
                                {% if field.key == 'STEAM_LOGIN_MODE' %}
                                    <select name="vars[{{ field.key }}]" class="form-input">
                                        <option value="anonymous" {{ field.value == 'account' ? '' : 'selected' }}>Anonymous</option>
                                        <option value="account" {{ field.value == 'account' ? 'selected' : '' }}>Steam Account</option>
                                    </select>
                                {% else %}
                                    <input name="vars[{{ field.key }}]" value="{{ field.value }}"
                                        type="{% if field.type == 'number' %}number{% elseif field.type == 'password' %}password{% else %}text{% endif %}"
                                        class="form-input">
                                {% endif %}
                                {% if field.helptext %}
                                    <p style="margin-top:0.25rem;font-size:0.6875rem;color:var(--ng-text-muted)">{{ t(field.helptext, locale) }}</p>
                                {% endif %}
                                {% if field.error %}
                                    <p style="margin-top:0.25rem;font-size:0.75rem;color:var(--color-danger,#ef4444)">{{ field.error }}</p>
                                {% endif %}
                            </div>
                        {% endif %}
                    {% else %}
                        <p style="font-size:0.875rem;color:var(--ng-text-muted)">{{ t('customer_instance_setup_variables_empty', locale) }}</p>
                    {% endfor %}
                    <div>
                        <button type="submit" class="ui-button ui-button--primary ui-button--sm">
                            {{ t('customer_instance_setup_variables_save', locale) }}
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <div style="display:flex;flex-direction:column;gap:1.25rem">
            {# ─── Config-Variablen ─── #}
            <div class="cust-panel">
                <div class="cust-panel__head">
                    <h2 class="cust-panel__title">{{ t('customer_instances_setup_title', locale) }}</h2>
                    <p style="margin-top:0.125rem;font-size:0.75rem;color:var(--ng-text-muted)">{{ t('customer_instance_setup_config_intro', locale) }}</p>
                </div>
                <div class="cust-panel__body">
                    {% if setupMessages.vars %}
                        <div class="ng-alert ng-alert--success" style="margin-bottom:1rem">{{ setupMessages.vars }}</div>
                    {% endif %}
                    <form action="{{ path('customer_instance_setup_vars', {id: instance.id}) }}" method="post" style="display:flex;flex-direction:column;gap:1rem">
                        {% for field in setupConfigVars %}
                            <div class="form-field">
                                <label class="form-label">
                                    {{ t(field.label, locale) }}{% if field.required %} <span style="color:var(--color-danger,#ef4444)">*</span>{% endif %}
                                </label>
                                <input name="vars[{{ field.key }}]" value="{{ field.value }}"
                                    type="{% if field.type == 'number' %}number{% elseif field.type == 'password' %}password{% else %}text{% endif %}"
                                    class="form-input">
                                {% if field.helptext %}
                                    <p style="margin-top:0.25rem;font-size:0.6875rem;color:var(--ng-text-muted)">{{ t(field.helptext, locale) }}</p>
                                {% endif %}
                                {% if field.error %}
                                    <p style="margin-top:0.25rem;font-size:0.75rem;color:var(--color-danger,#ef4444)">{{ field.error }}</p>
                                {% endif %}
                            </div>
                        {% else %}
                            <p style="font-size:0.875rem;color:var(--ng-text-muted)">{{ t('customer_instances_setup_none', locale) }}</p>
                        {% endfor %}
                        <div>
                            <button type="submit" class="ui-button ui-button--primary ui-button--sm">
                                {{ t('customer_instances_setup_save', locale) }}
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            {# ─── Secrets ─── #}
            <div class="cust-panel">
                <div class="cust-panel__head">
                    <h2 class="cust-panel__title">{{ t('customer_instance_setup_secrets_title', locale) }}</h2>
                </div>
                <div class="cust-panel__body">
                    {% if setupMessages.secrets %}
                        <div class="ng-alert ng-alert--success" style="margin-bottom:1rem">{{ setupMessages.secrets }}</div>
                    {% endif %}
                    <form action="{{ path('customer_instance_setup_secrets', {id: instance.id}) }}" method="post" style="display:flex;flex-direction:column;gap:1rem">
                        {% for field in setupSecrets %}
                            <div class="form-field">
                                <label class="form-label">
                                    {{ t(field.label, locale) }}{% if field.required %} <span style="color:var(--color-danger,#ef4444)">*</span>{% endif %}
                                </label>
                                <div style="display:flex;flex-direction:column;gap:0.375rem">
                                    <input name="secrets[{{ field.key }}]"
                                        type="{{ field.type == 'number' ? 'number' : 'password' }}"
                                        class="form-input"
                                        placeholder="{{ t('customer_instance_setup_secrets_placeholder', locale) }}">
                                    <span style="font-size:0.6875rem;color:var(--ng-text-muted)">
                                        {{ t('customer_instance_setup_secrets_set_label', locale) }} <span style="color:{{ field.is_set ? 'var(--color-success,#10b981)' : 'var(--ng-text-muted)' }}">{{ field.is_set ? t('customer_instance_setup_secrets_yes', locale) : t('customer_instance_setup_secrets_no', locale) }}</span>
                                    </span>
                                </div>
                                {% if field.helptext %}
                                    <p style="margin-top:0.25rem;font-size:0.6875rem;color:var(--ng-text-muted)">{{ t(field.helptext, locale) }}</p>
                                {% endif %}
                                {% if field.error %}
                                    <p style="margin-top:0.25rem;font-size:0.75rem;color:var(--color-danger,#ef4444)">{{ field.error }}</p>
                                {% endif %}
                            </div>
                        {% else %}
                            <p style="font-size:0.875rem;color:var(--ng-text-muted)">{{ t('customer_instance_setup_secrets_empty', locale) }}</p>
                        {% endfor %}
                        <div>
                            <button type="submit" class="ui-button ui-button--primary ui-button--sm">
                                {{ t('customer_instance_setup_secrets_save', locale) }}
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
