<div class="cust-panel">
    <div class="cust-panel__head">
        <div>
            <h2 class="cust-panel__title">{{ t('customer_instance_tab_restart_planner', page_locale()) }}</h2>
            <p style="font-size:.875rem;color:var(--ng-text-muted)">{{ t('customer_instance_restart_planner_intro', page_locale()) }}</p>
        </div>
    </div>

    <div class="cust-panel__body">
        {% if tabNotice %}
            <div class="ng-alert ng-alert--success" style="margin-bottom:1rem">{{ t(tabNotice, page_locale()) }}</div>
        {% endif %}
        {% if tabError %}
            <div class="ng-alert ng-alert--danger" style="margin-bottom:1rem">{{ t(tabError, page_locale()) }}</div>
        {% endif %}

        <form method="post" action="{{ path('customer_instance_restart_planner', {id: instance.id}) }}" style="display:flex;flex-direction:column;gap:1rem">
            <div class="cust-grid-2">
                <div class="form-field">
                    <label class="form-label">{{ t('customer_instance_restart_planner_cron', page_locale()) }}</label>
                    <input type="text" name="cron_expression" value="{{ restartSchedule ? restartSchedule.cron_expression : '0 4 * * *' }}" class="form-input">
                    <p style="margin-top:.5rem;font-size:.75rem;color:var(--ng-text-muted)">{{ t('customer_instance_restart_planner_cron_hint', page_locale()) }}</p>
                </div>
                <div class="form-field">
                    <label class="form-label">{{ t('customer_instance_restart_planner_time_zone', page_locale()) }}</label>
                    <input type="text" name="time_zone" value="{{ restartSchedule ? restartSchedule.time_zone : 'UTC' }}" class="form-input">
                    <p style="margin-top:.5rem;font-size:.75rem;color:var(--ng-text-muted)">{{ t('customer_instance_restart_planner_time_zone_hint', page_locale()) }}</p>
                </div>
            </div>

            <label style="display:flex;align-items:center;gap:.5rem;font-size:.875rem">
                <input type="checkbox" name="enabled" value="1" {% if restartSchedule and restartSchedule.enabled %}checked{% endif %}>
                {{ t('customer_instance_restart_planner_enabled', page_locale()) }}
            </label>

            <div style="padding:.75rem;border:1px solid var(--ng-border);border-radius:.5rem;font-size:.8rem;color:var(--ng-text-muted)">
                Last run: {{ restartSchedule and restartSchedule.last_run_at ? restartSchedule.last_run_at|date('Y-m-d H:i:s') : '—' }} ·
                Last status: {{ restartSchedule and restartSchedule.last_status ? restartSchedule.last_status : '—' }}
                {% if restartSchedule and restartSchedule.last_error_code %}(error: {{ restartSchedule.last_error_code }}){% endif %}
                {% if restartSchedule and restartSchedule.next_run_at %} · Next run: {{ restartSchedule.next_run_at|date('Y-m-d H:i:s') }}{% endif %}
            </div>

            <div style="display:flex;justify-content:flex-end">
                <button type="submit" class="ui-button ui-button--primary">
                    {{ t('customer_instance_restart_planner_save', page_locale()) }}
                </button>
            </div>
        </form>
    </div>
</div>
