{% set locale = page_locale() %}
<div
    id="gameserver-reinstall"
    data-url-options="{{ path('customer_instance_reinstall_api_options', {id: instance.id}) }}"
    data-url-reinstall="{{ path('customer_instance_reinstall_api', {id: instance.id}) }}"
    data-label-loading-options="{{ t('customer_reinstall_loading_options', locale) }}"
    data-label-no-options="{{ t('customer_reinstall_no_options', locale) }}"
    data-label-loading-failed="{{ t('common_loading_failed', locale) }}"
    data-label-starting="{{ t('customer_reinstall_starting', locale) }}"
    data-label-start="{{ t('customer_reinstall_start', locale) }}"
    data-label-confirm-required="{{ t('customer_reinstall_confirm_required', locale) }}"
    data-label-job-queued="{{ t('common_job_queued', locale) }}"
    data-label-reinstall-queued="{{ t('common_reinstall_queued', locale) }}"
    data-label-scheduled="{{ t('customer_reinstall_scheduled', locale) }}"
    data-label-shared-storage-hint-supported="{{ t('customer_instances_shared_storage_hint_supported', locale) }}"
    data-label-shared-storage-hint-unsupported="{{ t('customer_instances_shared_storage_hint_unsupported', locale) }}"
    data-label-shared-storage-hint-migrate="{{ t('customer_instances_shared_storage_hint_migrate', locale) }}"
>
    {# ─── Warning ─── #}
    <div class="ng-alert ng-alert--danger" style="display:flex;align-items:flex-start;gap:.75rem">
        <svg style="margin-top:.125rem;width:1.25rem;height:1.25rem;flex-shrink:0" fill="currentColor" viewBox="0 0 16 16"><path d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767L8.982 1.566zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5zm.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2z"/></svg>
        <div>
            <strong>{{ t('customer_instances_reinstall_title', locale) }}</strong>
            <p style="margin-top:.25rem">{{ t('customer_instances_reinstall_desc', locale) }}</p>
        </div>
    </div>

    {# ─── Reinstall Form ─── #}
    <div class="cust-panel" style="margin-top:1rem">
        <div class="cust-panel__body" style="display:flex;flex-direction:column;gap:1rem">
            <div class="form-field">
                <label class="form-label" for="gs-reinstall-option">
                    {{ t('customer_instances_reinstall_version', locale) }}
                </label>
                <select id="gs-reinstall-option" class="form-input">
                    <option value="">{{ t('customer_reinstall_loading_options', locale) }}</option>
                </select>
            </div>

            <label style="display:flex;cursor:pointer;align-items:center;gap:.625rem;padding:.5rem .75rem;border:1px solid var(--ng-border);border-radius:.5rem;font-size:.875rem">
                <input type="checkbox" id="gs-reinstall-confirm">
                {{ t('customer_instances_reinstall_confirm', locale) }}
            </label>

            <div style="padding:.5rem .75rem;border:1px solid var(--ng-border);border-radius:.5rem">
                <label style="display:flex;cursor:pointer;align-items:center;gap:.625rem;font-size:.875rem">
                    <input type="checkbox" id="gs-reinstall-use-shared-storage">
                    {{ t('customer_instances_shared_storage_reinstall_label', locale) }}
                </label>
                <p id="gs-reinstall-shared-storage-hint" style="margin-top:.5rem;font-size:.8rem;color:var(--ng-text-muted)"></p>
                <p id="gs-reinstall-shared-storage-status" style="margin-top:.25rem;font-size:.8rem;display:none">{{ t('customer_instances_shared_storage_already_enabled', locale) }}</p>
            </div>

            <div style="display:flex;flex-wrap:wrap;align-items:center;gap:.75rem">
                <button type="button" id="gs-reinstall-submit"
                    class="ui-button ui-button--danger ui-button--sm">
                    <svg style="width:.875rem;height:.875rem" fill="currentColor" viewBox="0 0 16 16"><path fill-rule="evenodd" d="M8 3a5 5 0 1 0 4.546 2.914.5.5 0 0 1 .908-.417A6 6 0 1 1 8 2v1z"/><path d="M8 4.466V.534a.25.25 0 0 1 .41-.192l2.36 1.966c.12.1.12.284 0 .384L8.41 4.658A.25.25 0 0 1 8 4.466z"/></svg>
                    {{ t('customer_instances_reinstall_submit', locale) }}
                </button>
                <span id="gs-reinstall-job" style="font-size:.8rem;color:var(--ng-text-muted)"></span>
            </div>

            <div id="gs-reinstall-error" class="ng-alert ng-alert--danger" style="display:none"></div>
        </div>
    </div>
</div>

<script src="{{ asset('js/gameserver/shared/domMount.js') }}"></script>
<script src="{{ asset('js/gameserver/shared/errors.js') }}"></script>
<script src="{{ asset('js/gameserver/shared/apiClient.js') }}"></script>
<script src="{{ asset('js/gameserver/reinstall-app.js') }}"></script>
