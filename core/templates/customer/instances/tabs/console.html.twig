{% set locale = page_locale() %}
<div
    id="gameserver-console"
    data-url-command="{{ path('customer_instance_console_command_v2', {id: instance.id}) }}"
    data-url-logs="{{ path('customer_instance_console_logs_envelope', {id: instance.id}) }}"
    data-url-health="{{ path('customer_instance_console_health_envelope', {id: instance.id}) }}"
    data-stream-url="{{ path('customer_instance_console_stream', {id: instance.id}) }}"
    data-csrf-token="{{ csrf_token('instance_console_' ~ instance.id) }}"
    data-i18n="{{ {
        streamUnavailable: t('customer_instance_console_log_unavailable', locale),
        pollingActive: t('customer_instance_console_polling_active', locale),
        streamConnected: t('customer_instances_console_stream_connected', locale),
        streamReconnecting: t('customer_instances_console_stream_reconnecting', locale),
        relayLost: t('customer_instances_console_relay_lost', locale),
        streamDisconnected: t('customer_instances_console_stream_disconnected', locale),
        serverOffline: t('customer_instances_console_server_offline', locale),
        sending: t('customer_instances_console_sending', locale),
        commandRequired: t('customer_instance_console_send_command_required', locale),
        pause: t('customer_instances_console_pause', locale),
        resume: t('customer_instances_console_resume', locale),
        autoscrollOn: t('customer_instances_console_autoscroll_on', locale),
        autoscrollOff: t('customer_instances_console_autoscroll_off', locale),
    }|json_encode }}"
>
    {# ─── Console Output ─── #}
    <div class="cust-panel">
        <div class="cust-panel__head">
            <div style="display:flex;align-items:center;gap:.5rem">
                <svg style="width:.875rem;height:.875rem;flex-shrink:0" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M6 9a.5.5 0 0 1 .5-.5h3a.5.5 0 0 1 0 1h-3A.5.5 0 0 1 6 9zM3.854 4.146a.5.5 0 1 0-.708.708L4.793 6.5 3.146 8.146a.5.5 0 1 0 .708.708l2-2a.5.5 0 0 0 0-.708l-2-2z"/>
                    <path d="M2 1a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V3a2 2 0 0 0-2-2H2zm12 1a1 1 0 0 1 1 1v10a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1V3a1 1 0 0 1 1-1h12z"/>
                </svg>
                <h2 class="cust-panel__title">{{ t('customer_instances_console_title', locale) }}</h2>
            </div>
            <div style="display:flex;flex-wrap:wrap;align-items:center;gap:.375rem">
                <button type="button" id="gs-console-pause" class="ui-button ui-button--ghost ui-button--sm">
                    {{ t('customer_instances_console_pause', locale) }}
                </button>
                <button type="button" id="gs-console-autoscroll" class="ui-button ui-button--ghost ui-button--sm">
                    {{ t('customer_instances_console_autoscroll_on', locale) }}
                </button>
                <button type="button" id="gs-console-clear" class="ui-button ui-button--ghost ui-button--sm">
                    {{ t('customer_instances_console_clear', locale) }}
                </button>
            </div>
        </div>

        <div id="gs-console-health" style="padding:.5rem 1rem;font-size:.8rem;color:var(--ng-text-muted);border-bottom:1px solid var(--ng-border)"></div>

        <div id="gs-console-error" class="ng-alert ng-alert--danger" style="display:none;border-radius:0;border-left:none;border-right:none"></div>

        <pre id="gs-console-log"
            class="gs-console-log-panel"
            style="height:24rem;overflow-y:auto;overflow-x:auto;padding:1rem;font-size:.75rem;line-height:1.6;font-family:monospace"></pre>
    </div>

    {# ─── Command Input ─── #}
    <div class="cust-panel" style="margin-top:1rem">
        <div class="cust-panel__body">
            <div class="form-field">
                <label class="form-label" for="gs-console-command">{{ t('customer_instances_console_title', locale) }}</label>
                <div style="display:flex;gap:.5rem;margin-top:.5rem">
                    <input
                        id="gs-console-command"
                        type="text"
                        class="form-input"
                        style="font-family:monospace"
                        placeholder="{{ t('customer_instances_console_placeholder', locale) }}"
                        autocomplete="off"
                        spellcheck="false"
                    >
                    <button type="button" id="gs-console-send"
                        class="ui-button ui-button--primary" style="flex-shrink:0">
                        {{ t('customer_instances_console_send', locale) }}
                    </button>
                </div>
                <p style="margin-top:.5rem;font-size:.7rem;color:var(--ng-text-muted)">{{ t('customer_instances_console_instruction', locale) }}</p>
            </div>
        </div>
    </div>
</div>

<script src="{{ asset('js/gameserver/shared/domMount.js') }}"></script>
<script src="{{ asset('js/gameserver/shared/errors.js') }}"></script>
<script src="{{ asset('js/gameserver/shared/apiClient.js') }}"></script>
<script src="{{ asset('js/gameserver/console-app.js') }}"></script>
