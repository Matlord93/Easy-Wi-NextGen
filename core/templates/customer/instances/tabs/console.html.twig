<div
    class="space-y-6"
    id="instance-console"
    data-instance-id="{{ instance.id }}"
    data-instance-status="{{ instance.status }}"
    data-runtime-status="{{ instance.runtime_status ?? '' }}"
    data-runtime-reason="{{ instance.runtime_status_reason ?? '' }}"
    data-runtime-checked-at="{{ instance.runtime_status_last_checked_at ? instance.runtime_status_last_checked_at|date('Y-m-d H:i:s') : '' }}"
    data-console-command-url="{{ path('customer_instance_console_command', {id: instance.id}) }}"
    data-console-logs-url="{{ path('customer_instance_console_logs', {id: instance.id}) }}"
    data-job-logs-url-template="{{ path('customer_job_api_logs', {jobId: '__JOB_ID__'}) }}"
    data-job-url-template="{{ path('customer_job_api_show', {jobId: '__JOB_ID__'}) }}"
>
    <div>
        {% set consoleLabel = app_setting('customer_console_label', t('customer_instance_tab_console', page_locale())) %}
        <h2 class="text-lg font-semibold text-slate-900">{{ consoleLabel }}</h2>
        <p class="text-sm text-slate-700">{{ t('customer_instance_console_intro', page_locale()) }}</p>
        <p class="mt-1 text-xs text-indigo-700">{{ t('customer_instance_console_isolation_notice', page_locale()) }}</p>
    </div>

    <div class="rounded-lg border border-slate-200 bg-slate-50 p-4">
        <div class="flex flex-wrap items-center justify-between gap-2">
            <p class="text-xs font-semibold uppercase text-slate-700">Konsole</p>
            <span id="instance-console-log-status" class="text-xs text-slate-500">{{ t('customer_instance_console_log_loading', page_locale()) }}</span>
        </div>
        <p class="mt-2 text-xs text-slate-500">{{ t('customer_instance_console_live_log_intro', page_locale()) }}</p>
        <pre
            id="instance-console-log"
            class="mt-3 h-64 max-h-64 min-h-64 overflow-y-auto overflow-x-auto whitespace-pre-wrap overscroll-contain rounded-md border border-slate-200 bg-white px-3 py-2 text-xs text-slate-700"
        ></pre>
    </div>

    <div class="rounded-lg border border-slate-200 bg-slate-50 p-4">
        <p class="text-xs font-semibold uppercase text-slate-700">Daten senden</p>
        <p class="mt-2 text-sm text-slate-600">Sendet Daten über die Konsole (nur wenn der Server läuft).</p>
        <div class="mt-4 space-y-2">
            <label for="instance-console-data" class="text-xs font-semibold text-slate-600">Daten</label>
            <input id="instance-console-data" type="text" class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm text-slate-700" placeholder="z. B. say status">
            <div class="flex flex-wrap items-center gap-3">
                <button id="instance-console-send-data" type="button" class="rounded-lg border border-indigo-200 px-4 py-2 text-xs font-semibold text-indigo-700 hover:bg-indigo-50">
                    Daten senden
                </button>
            </div>
            <p id="instance-console-feedback" class="text-xs text-slate-500"></p>
        </div>
    </div>
</div>

<script>
    (() => {
        const container = document.getElementById('instance-console');
        if (!container) {
            return;
        }
        const instanceId = container.dataset.instanceId;
        const status = container.dataset.instanceStatus;
        const commandUrl = container.dataset.consoleCommandUrl;
        const runtimeStatus = (container.dataset.runtimeStatus || '').toLowerCase();
        const runtimeReason = container.dataset.runtimeReason || '';
        const runtimeCheckedAt = container.dataset.runtimeCheckedAt || '';
        const logsUrl = container.dataset.consoleLogsUrl;
        const jobLogsUrlTemplate = container.dataset.jobLogsUrlTemplate;
        const jobUrlTemplate = container.dataset.jobUrlTemplate;
        const input = document.getElementById('instance-console-command');
        const button = document.getElementById('instance-console-send');
        const dataInput = document.getElementById('instance-console-data');
        const dataButton = document.getElementById('instance-console-send-data');
        const feedback = document.getElementById('instance-console-feedback');
        const logContainer = document.getElementById('instance-console-log');
        const logStatus = document.getElementById('instance-console-log-status');

        if (!instanceId || !commandUrl || !logContainer || !logStatus || !dataInput || !dataButton) {
            return;
        }

        let commandAllowed = status === 'running' || runtimeStatus === 'online';
        let commandCooldownUntil = 0;

        const setFeedback = (message, isError = false) => {
            if (!feedback) {
                return;
            }
            feedback.textContent = message;
            feedback.classList.toggle('text-rose-600', isError);
            feedback.classList.toggle('text-slate-500', !isError);
        };

        const updateSendButtonState = () => {
            const now = Date.now();
            const inCooldown = commandCooldownUntil > now;
            const disabled = !commandAllowed || inCooldown;
            dataButton.disabled = disabled;
            if (button) {
                button.disabled = disabled;
                button.classList.toggle('opacity-50', disabled);
                button.classList.toggle('cursor-not-allowed', disabled);
            }
            dataButton.classList.toggle('opacity-50', disabled);
            dataButton.classList.toggle('cursor-not-allowed', disabled);
            if (inCooldown) {
                const retryIn = Math.max(1, Math.ceil((commandCooldownUntil - now) / 1000));
                setFeedback(`Rate limited. Retry in ${retryIn}s.`, true);
            }
        };

        const setLogStatus = (message, isError = false) => {
            logStatus.textContent = message;
            logStatus.classList.toggle('text-rose-600', isError);
            logStatus.classList.toggle('text-slate-500', !isError);
        };

        const pollCommandStatus = (jobId) => {
            if (!jobId) {
                return;
            }
            const jobUrl = jobUrlTemplate.replace('__JOB_ID__', jobId);
            let attempts = 0;
            const maxAttempts = 30;

            const poll = async () => {
                attempts += 1;
                try {
                    const response = await fetch(jobUrl, { credentials: 'same-origin' });
                    const payload = await response.json().catch(() => ({}));
                    if (!response.ok) {
                        setFeedback(payload.error || 'Command failed.', true);
                        return;
                    }

                    const status = (payload.status || '').toLowerCase();
                    if (status === 'succeeded') {
                        setFeedback('{{ t('customer_instance_console_send_status_sent', page_locale()) }}');
                        return;
                    }
                    if (status === 'failed' || status === 'cancelled') {
                        const message = payload.result?.output?.message || 'Command failed.';
                        setFeedback(message, true);
                        return;
                    }
                } catch (err) {
                    setFeedback(err.message || 'Command failed.', true);
                    return;
                }

                if (attempts < maxAttempts) {
                    setTimeout(poll, attempts < 10 ? 1000 : 2500);
                }
            };

            setTimeout(poll, 1000);
        };

        let activeJobId = null;
        let lastLogId = null;
        let outputAppendedForJob = null;

        const shouldAutoScroll = () => (
            logContainer.scrollHeight - logContainer.scrollTop - logContainer.clientHeight < 24
        );

        const appendLogLine = (line) => {
            if (!line) {
                return;
            }
            const autoScroll = shouldAutoScroll();
            if (logContainer.textContent) {
                logContainer.textContent += '\n';
            }
            logContainer.textContent += line;
            if (autoScroll) {
                logContainer.scrollTop = logContainer.scrollHeight;
            }
        };

        const fetchLogSnapshot = async () => {
            if (!logsUrl) {
                return;
            }

            try {
                const response = await fetch(logsUrl, {
                    method: 'POST',
                    credentials: 'same-origin',
                    headers: {
                        'Content-Type': 'application/json',
                        'Accept': 'application/json',
                    },
                    body: JSON.stringify({}),
                });

                const payload = await response.json().catch(() => ({}));
                if (!response.ok) {
                    setLogStatus(payload.error || '{{ t('customer_instance_console_log_error', page_locale()) }}', true);
                    return;
                }

                const jobId = payload.job_id || payload.jobId;
                if (!jobId) {
                    setLogStatus('{{ t('customer_instance_console_log_error', page_locale()) }}', true);
                    return;
                }

                if (jobId !== activeJobId) {
                    activeJobId = jobId;
                    lastLogId = null;
                    outputAppendedForJob = null;
                    if (logContainer.textContent) {
                        appendLogLine('--- {{ t('customer_instance_console_log_session_restart', page_locale()) }} ---');
                    }
                }
                setLogStatus('{{ t('customer_instance_console_log_streaming', page_locale()) }}');
                if (!commandAllowed && ['instance.start', 'instance.restart'].includes(payload.job_type)) {
                    commandAllowed = true;
                    setFeedback('');
                    updateSendButtonState();
                }
            } catch (err) {
                setLogStatus(err.message || '{{ t('customer_instance_console_log_error', page_locale()) }}', true);
            }
        };

        const pollJobLogs = async () => {
            if (!activeJobId || !jobLogsUrlTemplate) {
                return;
            }

            const url = jobLogsUrlTemplate.replace('__JOB_ID__', activeJobId);
            const requestUrl = lastLogId ? `${url}?afterId=${lastLogId}` : url;

            try {
                const response = await fetch(requestUrl, {
                    method: 'GET',
                    credentials: 'same-origin',
                    headers: {
                        'Accept': 'application/json',
                    },
                });
                const payload = await response.json().catch(() => ({}));
                if (!response.ok || !payload.logs) {
                    return;
                }

                payload.logs.forEach((entry) => {
                    if (entry.id) {
                        lastLogId = entry.id;
                    }
                    appendLogLine(entry.message || '');
                });
            } catch (err) {
                setLogStatus(err.message || '{{ t('customer_instance_console_log_error', page_locale()) }}', true);
            }
        };

        const getOutputEntries = (output) => {
            if (!output || typeof output !== 'object') {
                return [];
            }

            const entries = [];
            const appendSection = (label, content) => {
                if (!content || !content.trim()) {
                    return;
                }
                entries.push(`--- ${label} ---`);
                entries.push(...content.split(/\r\n|\r|\n/));
            };

            [
                { key: 'service_name', label: 'SERVICE' },
                { key: 'service_status', label: 'SERVICE STATUS' },
                { key: 'service_status_error', label: 'SERVICE STATUS ERROR' },
                { key: 'logs_error', label: 'LOG ERROR' },
            ].forEach(({ key, label }) => {
                if (typeof output[key] === 'string' && output[key].trim()) {
                    appendSection(label, output[key]);
                }
            });

            ['logs_tail', 'install_log', 'log_text', 'output', 'message'].forEach((key) => {
                if (typeof output[key] === 'string' && output[key].trim()) {
                    entries.push(...output[key].split(/\r\n|\r|\n/));
                }
            });

            if (Array.isArray(output.logs)) {
                output.logs.forEach((entry) => {
                    if (typeof entry === 'string' && entry.trim()) {
                        entries.push(entry);
                    }
                });
            }

            if (typeof output.stdout === 'string') {
                appendSection('STDOUT', output.stdout);
            }

            if (typeof output.stderr === 'string') {
                appendSection('STDERR', output.stderr);
            }

            return entries.map((line) => line.trim()).filter(Boolean);
        };

        const pollJobOutput = async () => {
            if (!activeJobId || !jobUrlTemplate || outputAppendedForJob === activeJobId) {
                return;
            }

            const url = jobUrlTemplate.replace('__JOB_ID__', activeJobId);

            try {
                const response = await fetch(url, {
                    method: 'GET',
                    credentials: 'same-origin',
                    headers: {
                        'Accept': 'application/json',
                    },
                });
                const payload = await response.json().catch(() => ({}));
                const output = payload?.result?.output;
                const entries = getOutputEntries(output);
                if (entries.length === 0) {
                    if (payload?.status && ['succeeded', 'failed', 'cancelled'].includes(payload.status)) {
                        outputAppendedForJob = activeJobId;
                    }
                    return;
                }

                entries.forEach((line) => appendLogLine(line));
                outputAppendedForJob = activeJobId;
            } catch (err) {
                setLogStatus(err.message || '{{ t('customer_instance_console_log_error', page_locale()) }}', true);
            }
        };

        const startLogPolling = () => {
            if (!logsUrl || !jobLogsUrlTemplate) {
                setLogStatus('{{ t('customer_instance_console_log_unavailable', page_locale()) }}', true);
                return;
            }

            const nextLogsDelay = () => {
                if (runtimeStatus === 'unknown') {
                    return 10000;
                }
                if (runtimeStatus === 'offline' || status === 'stopped') {
                    return 6000;
                }
                return activeJobId ? 2000 : 3500;
            };

            const nextSnapshotDelay = () => {
                if (runtimeStatus === 'unknown') {
                    return 20000;
                }
                if (runtimeStatus === 'offline' || status === 'stopped') {
                    return 15000;
                }
                return 12000;
            };

            const nextOutputDelay = () => {
                if (runtimeStatus === 'unknown') {
                    return 12000;
                }
                return activeJobId ? 2500 : 5000;
            };

            const logsLoop = async () => {
                await pollJobLogs();
                setTimeout(logsLoop, nextLogsDelay());
            };

            const snapshotLoop = async () => {
                await fetchLogSnapshot();
                setTimeout(snapshotLoop, nextSnapshotDelay());
            };

            const outputLoop = async () => {
                await pollJobOutput();
                setTimeout(outputLoop, nextOutputDelay());
            };

            snapshotLoop();
            logsLoop();
            outputLoop();
        };

        const applyCommandLock = () => {
            const reason = runtimeReason || '{{ t('customer_instance_console_send_requires_running', page_locale()) }}';
            const checkedSuffix = runtimeCheckedAt ? ` (last checked: ${runtimeCheckedAt})` : '';
            setFeedback(`${reason}${checkedSuffix}`, true);
            updateSendButtonState();
        };

        if (!commandAllowed) {
            applyCommandLock();
        } else {
            updateSendButtonState();
        }

        const sendCommand = async (command, clearInput, triggerButton = null) => {
            updateSendButtonState();
            if (triggerButton && triggerButton.disabled) {
                return;
            }
            if (!command) {
                setFeedback('{{ t('customer_instance_console_send_command_required', page_locale()) }}', true);
                return;
            }

            setFeedback('{{ t('customer_instance_console_send_status_sending', page_locale()) }}');

            try {
                const response = await fetch(commandUrl, {
                    method: 'POST',
                    credentials: 'same-origin',
                    headers: {
                        'Content-Type': 'application/json',
                        'Accept': 'application/json',
                    },
                    body: JSON.stringify({ command }),
                });

                const payload = await response.json().catch(() => ({}));
                if (!response.ok) {
                    if (response.status === 429) {
                        const retryAfter = Number(payload.retry_after || 1);
                        commandCooldownUntil = Date.now() + (Math.max(1, retryAfter) * 1000);
                        updateSendButtonState();
                        setFeedback(`${payload.message || payload.error || 'Rate limited.'} (retry in ${Math.max(1, retryAfter)}s)`, true);
                        return;
                    }
                    setFeedback(payload.message || payload.error || 'Command failed.', true);
                    return;
                }

                if (clearInput) {
                    clearInput.value = '';
                }
                setFeedback('{{ t('customer_instance_console_send_status_sent', page_locale()) }}');
                pollCommandStatus(payload.job_id);
            } catch (err) {
                setFeedback(err.message || 'Command failed.', true);
            }
        };

        if (button && input) {
            button.addEventListener('click', async () => {
                await sendCommand(input.value.trim(), input, button);
            });
        }

        dataButton.addEventListener('click', async () => {
            await sendCommand(dataInput.value.trim(), dataInput, dataButton);
        });

        startLogPolling();
    })();
</script>
