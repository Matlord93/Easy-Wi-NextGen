{% set locale = page_locale() %}
<div
    id="gameserver-tasks"
    class="space-y-5"
    data-url-tasks="{{ path('customer_instance_tasks_api_list', {id: instance.id}) }}"
    data-url-cancel-template="{{ path('customer_instance_tasks_api_cancel', {id: instance.id, taskId: '__TASK_ID__'}) }}"
    data-url-logs="{{ path('customer_instance_tasks_api_logs', {id: instance.id}) }}"
    data-url-health="{{ path('customer_instance_tasks_api_health', {id: instance.id}) }}"
    data-i18n="{{ {
        'noTasksFound': t('customer_instance_tasks_none_js', locale),
        'logs': t('customer_instance_tasks_logs_btn', locale),
        'cancel': t('customer_instance_tasks_cancel_btn', locale),
        'loadingLogs': t('customer_instance_tasks_loading_logs', locale),
        'cancelConfirm': t('customer_instance_tasks_cancel_confirm', locale)
    }|json_encode|e('html_attr') }}"
>
    {# ─── Task-Liste ─── #}
    <div class="rounded-xl border border-slate-700/60 bg-slate-800/40 overflow-hidden">
        <div class="flex items-center gap-2 border-b border-slate-700/50 px-4 py-3">
            <svg class="h-4 w-4 text-slate-400" fill="currentColor" viewBox="0 0 16 16"><path d="M5 10.5a.5.5 0 0 1 .5-.5h2a.5.5 0 0 1 0 1h-2a.5.5 0 0 1-.5-.5zm0-2a.5.5 0 0 1 .5-.5h5a.5.5 0 0 1 0 1h-5a.5.5 0 0 1-.5-.5zm0-2a.5.5 0 0 1 .5-.5h5a.5.5 0 0 1 0 1h-5a.5.5 0 0 1-.5-.5zm0-2a.5.5 0 0 1 .5-.5h5a.5.5 0 0 1 0 1h-5a.5.5 0 0 1-.5-.5zM3 2h10a1 1 0 0 1 1 1v10a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V3a1 1 0 0 1 1-1zm0-1a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V3a2 2 0 0 0-2-2H3z"/></svg>
            <div>
                <h3 class="text-sm font-semibold text-slate-200">{{ t('customer_instance_tab_tasks', page_locale()) }}</h3>
                <p class="text-xs text-slate-500">{{ t('customer_instance_tasks_intro', page_locale()) }}</p>
            </div>
        </div>

        <div id="gs-tasks-error" class="hidden border-b border-rose-700/40 bg-rose-500/10 px-4 py-2 text-sm text-rose-300"></div>

        <div class="overflow-x-auto">
            <table class="w-full text-xs">
                <thead>
                    <tr class="border-b border-slate-700/50 bg-slate-900/40">
                        <th class="px-4 py-2.5 text-left font-semibold uppercase tracking-wide text-slate-500">ID</th>
                        <th class="px-4 py-2.5 text-left font-semibold uppercase tracking-wide text-slate-500">Typ</th>
                        <th class="px-4 py-2.5 text-left font-semibold uppercase tracking-wide text-slate-500">Status</th>
                        <th class="px-4 py-2.5 text-left font-semibold uppercase tracking-wide text-slate-500">Erstellt</th>
                        <th class="px-4 py-2.5 text-right font-semibold uppercase tracking-wide text-slate-500">Aktionen</th>
                    </tr>
                </thead>
                <tbody id="gs-tasks-list">
                    <tr>
                        <td colspan="5" class="px-4 py-6 text-center text-slate-500">{{ t('common_loading', page_locale()) }}</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    {# ─── Task-Logs ─── #}
    <div class="rounded-xl border border-slate-700/60 bg-slate-800/40">
        <div class="flex items-center gap-2 border-b border-slate-700/50 px-4 py-3">
            <svg class="h-4 w-4 text-slate-400" fill="currentColor" viewBox="0 0 16 16"><path d="M6 9a.5.5 0 0 1 .5-.5h3a.5.5 0 0 1 0 1h-3A.5.5 0 0 1 6 9zM3.854 4.146a.5.5 0 1 0-.708.708L4.793 6.5 3.146 8.146a.5.5 0 1 0 .708.708l2-2a.5.5 0 0 0 0-.708l-2-2z"/><path d="M2 1a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V3a2 2 0 0 0-2-2H2zm12 1a1 1 0 0 1 1 1v10a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1V3a1 1 0 0 1 1-1h12z"/></svg>
            <h4 class="text-sm font-semibold text-slate-200">Aufgaben-Logs</h4>
        </div>
        <div id="gs-tasks-logs" data-empty="1"
            class="h-56 overflow-auto bg-slate-950/60 p-4 font-mono text-xs text-slate-400">
            Aufgabe auswählen, um Logs zu laden.
        </div>
    </div>
</div>

<script src="{{ asset('js/gameserver/shared/domMount.js') }}"></script>
<script src="{{ asset('js/gameserver/shared/errors.js') }}"></script>
<script src="{{ asset('js/gameserver/shared/apiClient.js') }}"></script>
<script src="{{ asset('js/gameserver/tasks-app.js') }}"></script>
