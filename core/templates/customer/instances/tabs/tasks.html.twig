{% set locale = page_locale() %}
<div
    id="gameserver-tasks"
    data-url-tasks="{{ path('customer_instance_tasks_api_list', {id: instance.id}) }}"
    data-url-cancel-template="{{ path('customer_instance_tasks_api_cancel', {id: instance.id, taskId: '__TASK_ID__'}) }}"
    data-url-logs="{{ path('customer_instance_tasks_api_logs', {id: instance.id}) }}"
    data-url-health="{{ path('customer_instance_tasks_api_health', {id: instance.id}) }}"
    data-i18n="{{ {
        'noTasksFound': t('customer_instance_tasks_none_js', locale),
        'logs': t('customer_instance_tasks_logs_btn', locale),
        'cancel': t('customer_instance_tasks_cancel_btn', locale),
        'loadingLogs': t('customer_instance_tasks_loading_logs', locale),
        'cancelConfirm': t('customer_instance_tasks_cancel_confirm', locale)
    }|json_encode|e('html_attr') }}"
>
    {# ─── Task List ─── #}
    <div class="cust-panel">
        <div class="cust-panel__head">
            <div style="display:flex;align-items:center;gap:.5rem">
                <svg style="width:1rem;height:1rem;flex-shrink:0" fill="currentColor" viewBox="0 0 16 16"><path d="M5 10.5a.5.5 0 0 1 .5-.5h2a.5.5 0 0 1 0 1h-2a.5.5 0 0 1-.5-.5zm0-2a.5.5 0 0 1 .5-.5h5a.5.5 0 0 1 0 1h-5a.5.5 0 0 1-.5-.5zm0-2a.5.5 0 0 1 .5-.5h5a.5.5 0 0 1 0 1h-5a.5.5 0 0 1-.5-.5zm0-2a.5.5 0 0 1 .5-.5h5a.5.5 0 0 1 0 1h-5a.5.5 0 0 1-.5-.5zM3 2h10a1 1 0 0 1 1 1v10a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V3a1 1 0 0 1 1-1zm0-1a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V3a2 2 0 0 0-2-2H3z"/></svg>
                <div>
                    <h2 class="cust-panel__title">{{ t('customer_instance_tab_tasks', page_locale()) }}</h2>
                    <p style="font-size:.8rem;color:var(--ng-text-muted)">{{ t('customer_instance_tasks_intro', page_locale()) }}</p>
                </div>
            </div>
        </div>

        <div id="gs-tasks-error" class="ng-alert ng-alert--danger" style="display:none;border-radius:0;border-left:none;border-right:none"></div>

        <div class="cust-ws-table-wrap">
            <table class="cust-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Typ</th>
                        <th>Status</th>
                        <th>Erstellt</th>
                        <th>Aktionen</th>
                    </tr>
                </thead>
                <tbody id="gs-tasks-list">
                    <tr>
                        <td colspan="5" class="cust-table__empty">{{ t('common_loading', page_locale()) }}</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    {# ─── Task Logs ─── #}
    <div class="cust-panel" style="margin-top:1rem">
        <div class="cust-panel__head">
            <div style="display:flex;align-items:center;gap:.5rem">
                <svg style="width:1rem;height:1rem;flex-shrink:0" fill="currentColor" viewBox="0 0 16 16"><path d="M6 9a.5.5 0 0 1 .5-.5h3a.5.5 0 0 1 0 1h-3A.5.5 0 0 1 6 9zM3.854 4.146a.5.5 0 1 0-.708.708L4.793 6.5 3.146 8.146a.5.5 0 1 0 .708.708l2-2a.5.5 0 0 0 0-.708l-2-2z"/><path d="M2 1a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V3a2 2 0 0 0-2-2H2zm12 1a1 1 0 0 1 1 1v10a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1V3a1 1 0 0 1 1-1h12z"/></svg>
                <h2 class="cust-panel__title">Aufgaben-Logs</h2>
            </div>
        </div>
        <div id="gs-tasks-logs" data-empty="1"
            style="height:14rem;overflow:auto;padding:1rem;font-family:monospace;font-size:.75rem;color:var(--ng-text-muted)">
            Aufgabe auswählen, um Logs zu laden.
        </div>
    </div>
</div>

<script src="{{ asset('js/gameserver/shared/domMount.js') }}"></script>
<script src="{{ asset('js/gameserver/shared/errors.js') }}"></script>
<script src="{{ asset('js/gameserver/shared/apiClient.js') }}"></script>
<script src="{{ asset('js/gameserver/tasks-app.js') }}"></script>
