<div
    class="space-y-6"
    id="config-schema-app"
    data-instance-id="{{ instance.id }}"
    data-config-list-url="{{ path('customer_instance_configs_api_list', {id: instance.id}) }}"
    data-config-show-url="{{ path('customer_instance_configs_api_show', {id: instance.id, configId: '__CONFIG_ID__'}) }}"
    data-config-generate-url="{{ path('customer_instance_configs_api_generate', {id: instance.id, configId: '__CONFIG_ID__'}) }}"
    data-config-update-url="{{ path('customer_instance_configs_api_update', {id: instance.id, configId: '__CONFIG_ID__'}) }}"
    data-config-apply-url="{{ path('customer_instance_configs_api_apply', {id: instance.id, configId: '__CONFIG_ID__'}) }}"
    data-job-show-url="{{ path('customer_job_api_show', {jobId: '__JOB_ID__'}) }}"
    data-runtime-status="{{ instance.runtime_status ?? "" }}"
    data-runtime-status-reason="{{ instance.runtime_status_reason ?? "" }}"
>
    <div class="flex flex-wrap items-center justify-between gap-3">
        <div class="flex items-center gap-2">
            <svg class="h-5 w-5 text-indigo-400" fill="currentColor" viewBox="0 0 16 16"><path d="M14 4.5V14a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V2a2 2 0 0 1 2-2h5.5L14 4.5zm-3 0A1.5 1.5 0 0 1 9.5 3V1H4a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1V4.5h-2z"/><path d="M8.646 6.646a.5.5 0 0 1 .708 0l2 2a.5.5 0 0 1 0 .708l-2 2a.5.5 0 0 1-.708-.708L10.293 9 8.646 7.354a.5.5 0 0 1 0-.708zm-1.292 0a.5.5 0 0 0-.708 0l-2 2a.5.5 0 0 0 0 .708l2 2a.5.5 0 0 0 .708-.708L5.707 9l1.647-1.646a.5.5 0 0 0 0-.708z"/></svg>
            <div>
                <h2 class="text-sm font-semibold text-slate-200">{{ t('customer_instance_tab_configs', page_locale()) }}</h2>
                <p class="text-xs text-slate-500">{{ t('customer_instance_configs_intro', page_locale()) }}</p>
            </div>
        </div>
        {% if app_setting('customer_data_manager_enabled', true) %}
            <a href="{{ path('customer_instance_files', {id: instance.id}) }}"
               class="rounded-lg border border-slate-600 bg-slate-700/40 px-3 py-1.5 text-xs font-semibold text-slate-300 transition hover:bg-slate-700">
                {{ t('customer_instance_configs_open_files', page_locale()) }}
            </a>
        {% endif %}
    </div>

    <div class="rounded-xl border border-slate-700/60 bg-slate-800/40 p-5">
        <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
            <div>
                <h3 class="text-sm font-semibold text-slate-200">{{ t('customer_instance_configs_schema_title', page_locale()) }}</h3>
                <p class="text-xs text-slate-500">{{ t('customer_instance_configs_schema_intro', page_locale()) }}</p>
            </div>
            <div class="w-full sm:w-64">
                <label class="block text-xs font-semibold uppercase tracking-wide text-slate-500" for="config-schema-select">
                    {{ t('customer_instance_configs_schema_select_label', page_locale()) }}
                </label>
                <select id="config-schema-select"
                    class="mt-1.5 w-full rounded-lg border border-slate-600/80 bg-slate-900/60 px-3 py-2 text-sm text-slate-200 focus:border-indigo-500 focus:outline-none">
                    <option value="">{{ t('customer_instance_configs_schema_select_placeholder', page_locale()) }}</option>
                </select>
            </div>
        </div>

        <div id="config-schema-status" class="mt-4 text-sm text-slate-500">{{ t('customer_instance_configs_schema_loading', page_locale()) }}</div>
        <div id="config-schema-error" class="mt-4 hidden rounded-lg border border-rose-700/50 bg-rose-500/10 p-3 text-sm text-rose-300"></div>

        <div id="config-schema-details" class="mt-4 hidden rounded-lg border border-slate-700/50 bg-slate-900/40 p-4 text-xs">
            <p class="text-sm font-semibold text-slate-200">{{ t('customer_instance_configs_schema_details_title', page_locale()) }}</p>
            <p id="config-schema-details-description" class="mt-1 text-slate-400"></p>
            <dl class="mt-3 grid grid-cols-1 gap-3 sm:grid-cols-2 text-slate-400">
                <div>
                    <dt class="font-semibold text-slate-300">{{ t('customer_instance_configs_schema_details_file', page_locale()) }}</dt>
                    <dd id="config-schema-details-file" class="font-mono text-slate-400"></dd>
                </div>
                <div>
                    <dt class="font-semibold text-slate-300">{{ t('customer_instance_configs_schema_details_format', page_locale()) }}</dt>
                    <dd id="config-schema-details-format" class="text-slate-400"></dd>
                </div>
                <div class="sm:col-span-2">
                    <dt class="font-semibold text-slate-300">Config-Status</dt>
                    <dd id="config-schema-details-apply-status" class="text-slate-400"></dd>
                </div>
            </dl>
        </div>

        <div id="config-schema-warnings" class="mt-4 hidden rounded-lg border border-amber-700/50 bg-amber-500/10 p-3 text-sm text-amber-300">
            <p class="font-semibold">{{ t('customer_instance_configs_schema_warnings_title', page_locale()) }}</p>
            <ul class="mt-2 list-disc pl-5"></ul>
        </div>

        <div id="config-schema-editor" class="mt-5 hidden">
            <div class="grid gap-5 lg:grid-cols-2">
                <div>
                    <h4 class="text-xs font-semibold uppercase tracking-widest text-slate-500">{{ t('customer_instance_configs_schema_fields_title', page_locale()) }}</h4>
                    <div id="config-schema-fields" class="mt-4 space-y-4"></div>
                </div>
                <div>
                    <div class="flex items-center justify-between">
                        <h4 class="text-xs font-semibold uppercase tracking-widest text-slate-500">{{ t('customer_instance_configs_schema_raw_title', page_locale()) }}</h4>
                        <span id="config-schema-format" class="text-xs uppercase tracking-wide text-indigo-400"></span>
                    </div>
                    <textarea id="config-schema-raw" rows="16"
                        class="mt-2 w-full rounded-lg border border-slate-600/80 bg-slate-900/60 px-3 py-2 font-mono text-xs text-slate-200 focus:border-indigo-500 focus:outline-none"></textarea>
                </div>
            </div>

            <div class="mt-5 flex flex-wrap items-center gap-3">
                <button id="config-schema-generate"
                    class="rounded-lg bg-indigo-600 px-4 py-2 text-xs font-semibold text-white transition hover:bg-indigo-500">
                    {{ t('customer_instance_configs_schema_generate_save', page_locale()) }}
                </button>
                <button id="config-schema-save-raw"
                    class="rounded-lg border border-slate-600 bg-slate-700/40 px-4 py-2 text-xs font-semibold text-slate-300 transition hover:bg-slate-700">
                    {{ t('customer_instance_configs_schema_save_raw', page_locale()) }}
                </button>
                <button id="config-schema-apply"
                    class="rounded-lg border border-indigo-600/40 bg-indigo-500/10 px-4 py-2 text-xs font-semibold text-indigo-300 transition hover:bg-indigo-500/20">
                    Config anwenden
                </button>
                <span id="config-schema-feedback" class="text-xs text-slate-400"></span>
            </div>
        </div>

        <div id="config-schema-empty" class="mt-5 hidden rounded-lg border border-dashed border-slate-700 bg-slate-900/30 p-6 text-sm text-slate-500">
            {{ t('customer_instance_configs_schema_empty', page_locale()) }}
        </div>
    </div>
</div>

<script>
    (() => {
        const app = document.getElementById('config-schema-app');
        if (!app) {
            return;
        }
        const instanceId = app.dataset.instanceId;
        const listUrl = app.dataset.configListUrl;
        const showUrlTemplate = app.dataset.configShowUrl;
        const generateUrlTemplate = app.dataset.configGenerateUrl;
        const updateUrlTemplate = app.dataset.configUpdateUrl;
        const applyUrlTemplate = app.dataset.configApplyUrl;
        const jobShowUrlTemplate = app.dataset.jobShowUrl;
        const select = document.getElementById('config-schema-select');
        const status = document.getElementById('config-schema-status');
        const error = document.getElementById('config-schema-error');
        const details = document.getElementById('config-schema-details');
        const detailsDescription = document.getElementById('config-schema-details-description');
        const detailsFile = document.getElementById('config-schema-details-file');
        const detailsFormat = document.getElementById('config-schema-details-format');
        const detailsApplyStatus = document.getElementById('config-schema-details-apply-status');
        const warnings = document.getElementById('config-schema-warnings');
        const warningsList = warnings.querySelector('ul');
        const editor = document.getElementById('config-schema-editor');
        const fieldsContainer = document.getElementById('config-schema-fields');
        const rawEditor = document.getElementById('config-schema-raw');
        const formatBadge = document.getElementById('config-schema-format');
        const emptyState = document.getElementById('config-schema-empty');
        const generateButton = document.getElementById('config-schema-generate');
        const saveRawButton = document.getElementById('config-schema-save-raw');
        const applyButton = document.getElementById('config-schema-apply');
        const feedback = document.getElementById('config-schema-feedback');
        const runtimeStatus = (app.dataset.runtimeStatus || '').toLowerCase();
        const runtimeStatusReason = app.dataset.runtimeStatusReason || '';

        let configs = [];
        let currentConfig = null;
        let currentSchema = null;
        let currentFieldErrors = {};

        const applyState = (() => {
            if (runtimeStatus === '' || runtimeStatus === 'unknown' || runtimeStatus === 'offline') {
                return { disabled: true, reason: runtimeStatusReason || '{{ t('customer_instance_configs_apply_unavailable_runtime', page_locale()) }}' };
            }
            return { disabled: false, reason: '' };
        })();

        if (applyState.disabled) {
            applyButton.disabled = true;
            applyButton.title = applyState.reason;
            feedback.textContent = applyState.reason;
        }

        const setStatus = (message, isError = false) => {
            status.textContent = message || '';
            status.classList.toggle('hidden', !message);
            error.classList.toggle('hidden', !isError);
            if (isError) {
                error.textContent = message;
                status.classList.add('hidden');
            }
        };

        const renderWarnings = (items) => {
            warningsList.innerHTML = '';
            if (!items || items.length === 0) {
                warnings.classList.add('hidden');
                return;
            }
            items.forEach((warning) => {
                const li = document.createElement('li');
                li.textContent = warning;
                warningsList.appendChild(li);
            });
            warnings.classList.remove('hidden');
        };

        const renderFields = (schema, values) => {
            fieldsContainer.innerHTML = '';
            if (!schema || !schema.fields) {
                return;
            }
            schema.fields.forEach((field) => {
                const wrapper = document.createElement('div');
                wrapper.className = 'space-y-1';

                const label = document.createElement('label');
                label.className = 'text-xs font-semibold uppercase tracking-wide text-slate-400';
                label.textContent = field.label || field.key || field.id;
                label.setAttribute('for', `config-field-${field.id}`);
                wrapper.appendChild(label);

                let input;
                if (field.type === 'bool' || field.type === 'boolean') {
                    input = document.createElement('input');
                    input.type = 'checkbox';
                    input.className = 'h-4 w-4 rounded border-slate-500 bg-slate-800 text-indigo-500 focus:ring-indigo-500';
                    input.checked = Boolean(values[field.id]);
                } else if (field.type === 'select' && field.options) {
                    input = document.createElement('select');
                    input.className = 'w-full rounded-lg border border-slate-600/80 bg-slate-900/60 px-3 py-2 text-sm text-slate-200 focus:border-indigo-500 focus:outline-none';
                    Object.entries(field.options).forEach(([value, label]) => {
                        const option = document.createElement('option');
                        option.value = value;
                        option.textContent = label;
                        if (String(values[field.id]) === String(value)) {
                            option.selected = true;
                        }
                        input.appendChild(option);
                    });
                } else {
                    input = document.createElement('input');
                    input.type = field.type === 'int' || field.type === 'integer' || field.type === 'float' || field.type === 'number' ? 'number' : 'text';
                    if (input.type === 'number' && (field.type === 'float' || field.type === 'number')) {
                        input.step = 'any';
                    }
                    input.className = 'w-full rounded-lg border border-slate-600/80 bg-slate-900/60 px-3 py-2 text-sm text-slate-200 focus:border-indigo-500 focus:outline-none';
                    input.value = values[field.id] ?? '';
                }
                input.id = `config-field-${field.id}`;
                input.dataset.fieldId = field.id;
                wrapper.appendChild(input);

                const fieldError = currentFieldErrors[field.id];
                if (fieldError) {
                    input.classList.add('border-rose-500');
                    const errorText = document.createElement('p');
                    errorText.className = 'text-xs text-rose-400';
                    errorText.textContent = fieldError;
                    wrapper.appendChild(errorText);
                }

                if (field.description) {
                    const desc = document.createElement('p');
                    desc.className = 'text-xs text-slate-500 mt-0.5';
                    desc.textContent = field.description;
                    wrapper.appendChild(desc);
                }

                fieldsContainer.appendChild(wrapper);
            });
        };

        const collectValues = () => {
            const values = {};
            fieldsContainer.querySelectorAll('[data-field-id]').forEach((input) => {
                const key = input.dataset.fieldId;
                if (input.type === 'checkbox') {
                    values[key] = input.checked;
                } else {
                    values[key] = input.value;
                }
            });
            return values;
        };

        const updateEditor = (payload) => {
            currentConfig = payload.config;
            currentSchema = payload.schema;
            currentFieldErrors = {};
            renderFields(payload.schema, payload.values || {});
            rawEditor.value = payload.raw || '';
            formatBadge.textContent = payload.config.format || '';
            detailsDescription.textContent = payload.schema.description || '{{ t('customer_instance_configs_description_empty', page_locale()) }}';
            detailsFile.textContent = payload.config.file_path || '-';
            detailsFormat.textContent = payload.config.format || '-';
            const snapshot = payload.snapshot || {};
            const applyStatus = snapshot.last_apply_status || (payload.apply_required ? 'pending' : 'clean');
            const applyError = snapshot.last_apply_error_message || snapshot.last_apply_error_code || '';
            detailsApplyStatus.textContent = applyError ? `${applyStatus}: ${applyError}` : applyStatus;
            detailsApplyStatus.className = applyError ? 'text-rose-400' : 'text-slate-400';
            details.classList.remove('hidden');
            renderWarnings(payload.warnings || []);
            editor.classList.remove('hidden');
            emptyState.classList.add('hidden');
            setStatus('');
        };


        const applyValidationErrors = (payload) => {
            currentFieldErrors = {};
            const fieldErrors = payload?.details?.field_errors || [];
            if (!Array.isArray(fieldErrors)) {
                return false;
            }
            fieldErrors.forEach((item) => {
                if (!item || typeof item !== 'object') {
                    return;
                }
                const field = String(item.field || '');
                const message = String(item.message || 'Invalid value.');
                if (field !== '') {
                    currentFieldErrors[field] = message;
                }
            });
            renderFields(currentSchema, collectValues());
            return Object.keys(currentFieldErrors).length > 0;
        };

        const request = async (url, options = {}) => {
            const response = await fetch(url, options);
            const payload = await response.json().catch(() => ({}));
            if (!response.ok) {
                const message = payload.error || payload.message || 'Request failed.';
                const err = new Error(message);
                err.payload = payload;
                throw err;
            }
            return payload;
        };

        const scheduleConfigPoll = (configId, jobId, attempt = 0) => {
            if (attempt >= 20) {
                setStatus('{{ t('customer_instance_configs_schema_status_timeout', page_locale()) }}', true);
                return;
            }
            window.setTimeout(() => {
                loadConfig(configId, jobId, attempt + 1);
            }, 1500);
        };

        const pollJob = async (jobId, onSuccess, attempt = 0) => {
            if (attempt >= 30) {
                setStatus('{{ t('customer_instance_configs_schema_status_save_failed', page_locale()) }}', true);
                return;
            }
            try {
                const job = await request(jobShowUrlTemplate.replace('__JOB_ID__', jobId));
                if (job.status === 'succeeded') {
                    onSuccess();
                    return;
                }
                if (job.status === 'failed' || job.status === 'cancelled') {
                    const output = job.result && job.result.output ? job.result.output : {};
                    setStatus(output.message || job.last_error || '{{ t('customer_instance_configs_schema_status_save_failed', page_locale()) }}', true);
                    if (currentConfig) {
                        loadConfig(currentConfig.key || currentConfig.id);
                    }
                    return;
                }
                window.setTimeout(() => pollJob(jobId, onSuccess, attempt + 1), 1500);
            } catch (err) {
                setStatus(err.message, true);
            }
        };

        const loadConfigs = async () => {
            try {
                setStatus(status.textContent);
                const payload = await request(listUrl);
                configs = payload.configs || [];
                select.innerHTML = `<option value="">${select.options[0].textContent}</option>`;
                configs.forEach((config) => {
                    const option = document.createElement('option');
                    option.value = config.key || config.id;
                    option.textContent = config.name || config.key;
                    select.appendChild(option);
                });
                if (configs.length === 0) {
                    emptyState.classList.remove('hidden');
                    editor.classList.add('hidden');
                    setStatus('');
                    return;
                }
                const firstConfig = configs[0];
                select.value = firstConfig.key || firstConfig.id;
                await loadConfig(select.value);
            } catch (err) {
                setStatus(err.message, true);
            }
        };

        const loadConfig = async (configId, jobId = null, pollAttempt = 0) => {
            if (!configId) {
                editor.classList.add('hidden');
                details.classList.add('hidden');
                emptyState.classList.remove('hidden');
                return;
            }
            try {
                feedback.textContent = '';
                const url = new URL(showUrlTemplate.replace('__CONFIG_ID__', configId), window.location.origin);
                if (jobId) {
                    url.searchParams.set('jobId', jobId);
                }
                const payload = await request(url.toString());
                if (payload.status === 'ready') {
                    updateEditor(payload);
                    return;
                }
                if (payload.status === 'error') {
                    setStatus(payload.error || 'Request failed.', true);
                    return;
                }
                if (payload.status === 'queued') {
                    setStatus('{{ t('customer_instance_configs_schema_status_queued', page_locale()) }}');
                } else if (payload.status === 'pending') {
                    setStatus('{{ t('customer_instance_configs_schema_status_running', page_locale()) }}');
                }
                if (payload.job_id) {
                    scheduleConfigPoll(configId, payload.job_id, pollAttempt);
                }
            } catch (err) {
                setStatus(err.message, true);
            }
        };

        select.addEventListener('change', () => loadConfig(select.value));

        generateButton.addEventListener('click', async () => {
            if (!currentConfig) {
                return;
            }
            feedback.textContent = '';
            try {
                const payload = await request(generateUrlTemplate.replace('__CONFIG_ID__', currentConfig.key || currentConfig.id), {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ values: collectValues() }),
                });
                if (payload.job_id) {
                    feedback.textContent = '{{ t('customer_instance_configs_schema_status_save_queued', page_locale()) }}';
                    pollJob(payload.job_id, () => {
                        loadConfig(currentConfig.key || currentConfig.id);
                        feedback.textContent = '{{ t('customer_instance_configs_schema_status_saved', page_locale()) }}';
                    });
                }
            } catch (err) {
                if (err.payload && err.payload.error_code === 'config_validation_failed' && applyValidationErrors(err.payload)) {
                    setStatus(err.message, true);
                    return;
                }
                setStatus(err.message, true);
            }
        });

        saveRawButton.addEventListener('click', async () => {
            if (!currentConfig) {
                return;
            }
            feedback.textContent = '';
            try {
                const payload = await request(updateUrlTemplate.replace('__CONFIG_ID__', currentConfig.key || currentConfig.id), {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ content: rawEditor.value }),
                });
                if (payload.job_id) {
                    feedback.textContent = '{{ t('customer_instance_configs_schema_status_save_queued', page_locale()) }}';
                    pollJob(payload.job_id, () => {
                        loadConfig(currentConfig.key || currentConfig.id);
                        feedback.textContent = '{{ t('customer_instance_configs_schema_status_saved', page_locale()) }}';
                    });
                }
            } catch (err) {
                if (err.payload && err.payload.error_code === 'config_validation_failed' && applyValidationErrors(err.payload)) {
                    setStatus(err.message, true);
                    return;
                }
                setStatus(err.message, true);
            }
        });

        applyButton.addEventListener('click', async () => {
            if (!currentConfig) {
                return;
            }
            feedback.textContent = '';
            try {
                const payload = await request(applyUrlTemplate.replace('__CONFIG_ID__', currentConfig.key || currentConfig.id), {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({}),
                });
                if (payload.job_id) {
                    feedback.textContent = payload.message || 'Apply queued.';
                    pollJob(payload.job_id, () => {
                        feedback.textContent = 'Config apply completed.';
                        loadConfig(currentConfig.key || currentConfig.id);
                    });
                    return;
                }
                feedback.textContent = payload.message || 'No apply action queued.';
            } catch (err) {
                setStatus(err.message, true);
            }
        });

        loadConfigs();
    })();
</script>
