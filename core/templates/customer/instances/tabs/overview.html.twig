{% set locale = page_locale() %}

{# ─── Power Panel ─── #}
<div
    id="gameserver-overview-mount"
    class="cust-panel"
    data-power-url="{{ path('customer_instance_power_api', {id: instance.id}) }}"
    data-power-redirect-url="{{ path('customer_instance_tasks_page', {id: instance.id}) }}"
    data-url-query="{{ path('customer_instance_query_api_v2', {id: instance.id}) }}"
    data-i18n="{{ {
        working: t('customer_instances_overview_working', locale),
        queryNotSupported: t('customer_instances_overview_query_not_supported', locale),
        unknown: t('customer_instances_overview_unknown', locale),
        actionQueued: t('customer_instances_overview_action_queued', locale),
    }|json_encode }}"
>
    <div class="cust-panel__head">
        <div style="display:flex;align-items:center;gap:.5rem">
            <svg style="width:1rem;height:1rem;flex-shrink:0" fill="currentColor" viewBox="0 0 16 16">
                <path d="M5.578 4.437a5 5 0 1 0 4.922.044l.5-.866a6 6 0 1 1-5.908-.053l.486.875z"/>
                <path d="M7.5 2h1v7h-1V2z"/>
            </svg>
            <span style="font-weight:600">{{ t('customer_instance_server_status', locale) }}</span>
        </div>

        <div style="display:flex;flex-wrap:wrap;align-items:center;gap:.5rem">
            <button type="button" data-power-action="start"
                class="ui-button ui-button--primary ui-button--sm">
                <svg style="width:.875rem;height:.875rem" fill="currentColor" viewBox="0 0 16 16"><path d="m11.596 8.697-6.363 3.692c-.54.313-1.233-.066-1.233-.697V4.308c0-.63.692-1.01 1.233-.696l6.363 3.692a.802.802 0 0 1 0 1.393z"/></svg>
                {{ t('customer_instances_overview_start', locale) }}
            </button>
            <button type="button" data-power-action="stop"
                class="ui-button ui-button--danger ui-button--sm">
                <svg style="width:.875rem;height:.875rem" fill="currentColor" viewBox="0 0 16 16"><path d="M5 3.5h6A1.5 1.5 0 0 1 12.5 5v6a1.5 1.5 0 0 1-1.5 1.5H5A1.5 1.5 0 0 1 3.5 11V5A1.5 1.5 0 0 1 5 3.5z"/></svg>
                {{ t('customer_instances_overview_stop', locale) }}
            </button>
            <button type="button" data-power-action="restart"
                class="ui-button ui-button--ghost ui-button--sm">
                <svg style="width:.875rem;height:.875rem" fill="currentColor" viewBox="0 0 16 16"><path fill-rule="evenodd" d="M8 3a5 5 0 1 0 4.546 2.914.5.5 0 0 1 .908-.417A6 6 0 1 1 8 2v1z"/><path d="M8 4.466V.534a.25.25 0 0 1 .41-.192l2.36 1.966c.12.1.12.284 0 .384L8.41 4.658A.25.25 0 0 1 8 4.466z"/></svg>
                {{ t('customer_instances_overview_restart', locale) }}
            </button>

            <span class="ui-badge ui-badge--neutral">
                Status: <span id="gameserver-overview-state">{{ instance.status }}</span>
            </span>
        </div>
    </div>

    <div id="gameserver-overview-error" style="display:none"></div>
</div>

{# ─── Detail Card ─── #}
<div id="instance-card-{{ instance.id }}">
    {% include 'customer/instances/_card.html.twig' with { instance: instance } %}
</div>

<script src="{{ asset('js/gameserver/shared/domMount.js') }}"></script>
<script src="{{ asset('js/gameserver/shared/errors.js') }}"></script>
<script src="{{ asset('js/gameserver/shared/apiClient.js') }}"></script>
<script src="{{ asset('js/gameserver/overview-app.js') }}"></script>
