<div
    id="gameserver-settings"
    class="cust-page"
    data-url-settings="{{ path('customer_instance_settings_api_summary', {id: instance.id}) }}"
    data-url-configs="{{ path('customer_instance_configs_envelope_list', {id: instance.id}) }}"
    data-url-config-show="{{ path('customer_instance_configs_envelope_show', {id: instance.id, configId: '__CONFIG_ID__'}) }}"
    data-url-config-save="{{ path('customer_instance_configs_envelope_update', {id: instance.id, configId: '__CONFIG_ID__'}) }}"
    data-url-config-apply="{{ path('customer_instance_configs_envelope_apply', {id: instance.id, configId: '__CONFIG_ID__'}) }}"
    data-url-config-create="{{ path('customer_instance_configs_envelope_create', {id: instance.id}) }}"
    data-url-health="{{ path('customer_instance_settings_api_health', {id: instance.id}) }}"
    data-url-automation="{{ path('customer_instance_settings_api_automation_update', {id: instance.id}) }}"
    data-url-slots="{{ path('customer_instance_slots_update', {id: instance.id}) }}"
    data-url-access-health="{{ path('instances_access_health', {id: instance.id}) }}"
    data-url-access-reveal="{{ path('instances_access_reveal', {id: instance.id}) }}"
    data-url-access-reset="{{ path('instances_access_reset', {id: instance.id}) }}"
    data-i18n="{{ {
        'automationSaved': t('customer_instance_settings_automation_saved', page_locale()),
        'saving': t('customer_instance_settings_saving', page_locale()),
        'saveAutomationBtn': t('customer_instance_settings_automation_save_btn', page_locale()),
        'configNamePrompt': t('customer_instance_settings_config_name_prompt', page_locale()),
        'configFormatPrompt': t('customer_instance_settings_config_format_prompt', page_locale()),
        'creating': t('customer_instance_settings_creating', page_locale()),
        'createBtn': t('customer_instance_settings_create_btn', page_locale()),
        'configCreated': t('customer_instance_settings_config_created', page_locale()),
        'configSaved': t('customer_instance_settings_config_saved', page_locale()),
        'configApplyQueued': t('customer_instance_settings_config_apply_queued', page_locale()),
        'noMatchingConfigs': t('customer_instance_settings_no_matching_configs', page_locale()),
        'selectConfigFirst': t('customer_instance_settings_select_config_first', page_locale()),
        'applying': t('customer_instance_settings_applying', page_locale()),
        'applyBtn': t('customer_instance_settings_apply_btn', page_locale()),
        'saveBtn': t('customer_instance_settings_save_btn', page_locale()),
        'revealBtn': t('customer_instance_sftp_reveal_btn', page_locale()),
        'resetBtn': t('customer_instance_sftp_reset_btn', page_locale()),
        'revealing': t('customer_instance_sftp_revealing', page_locale()),
        'resetting': t('customer_instance_sftp_resetting', page_locale()),
        'accessPasswordRevealed': t('customer_instance_sftp_password_revealed', page_locale()),
        'accessResetQueued': t('customer_instance_sftp_reset_queued', page_locale())
    }|json_encode|e('html_attr') }}"
>
    <input type="hidden" id="slotInput" value="{{ instance.current_slots }}">

    {# ─── Status-Banner ─── #}
    <div class="cust-panel" style="margin-bottom:1.25rem">
        <div class="cust-panel__body">
            <div style="display:flex;flex-wrap:wrap;align-items:center;justify-content:space-between;gap:0.5rem">
                <div style="display:flex;align-items:center;gap:0.5rem">
                    <svg style="height:1rem;width:1rem;color:var(--ng-text-muted)" fill="currentColor" viewBox="0 0 16 16"><path d="M9.405 1.05c-.413-1.4-2.397-1.4-2.81 0l-.1.34a1.464 1.464 0 0 1-2.105.872l-.31-.17c-1.283-.698-2.686.705-1.987 1.987l.169.311c.446.82.023 1.841-.872 2.105l-.34.1c-1.4.413-1.4 2.397 0 2.81l.34.1a1.464 1.464 0 0 1 .872 2.105l-.17.31c-.698 1.283.705 2.686 1.987 1.987l.311-.169a1.464 1.464 0 0 1 2.105.872l.1.34c.413 1.4 2.397 1.4 2.81 0l.1-.34a1.464 1.464 0 0 1 2.105-.872l.31.17c1.283.698 2.686-.705 1.987-1.987l-.169-.311a1.464 1.464 0 0 1 .872-2.105l.34-.1c1.4-.413 1.4-2.397 0-2.81l-.34-.1a1.464 1.464 0 0 1-.872-2.105l.17-.31c.698-1.283-.705-2.686-1.987-1.987l-.311.169a1.464 1.464 0 0 1-2.105-.872l-.1-.34zM8 10.93a2.929 2.929 0 1 1 0-5.86 2.929 2.929 0 0 1 0 5.858z"/></svg>
                    <h3 style="font-size:0.875rem;font-weight:600;color:var(--ng-text)">{{ t('customer_instance_tab_settings', page_locale()) }}</h3>
                </div>
                <p id="gs-settings-meta" style="font-size:0.75rem;color:var(--ng-text-muted)">{{ t('customer_instance_settings_loading', page_locale()) }}</p>
            </div>
            <div id="gs-settings-error" class="ng-alert ng-alert--danger hidden" style="margin-top:0.75rem"></div>
        </div>
    </div>

    {# ─── Config files ─── #}
    <div class="cust-panel" style="margin-bottom:1.25rem">
        <div class="cust-panel__head" style="display:flex;align-items:center;justify-content:space-between">
            <div style="display:flex;align-items:center;gap:0.5rem">
                <svg style="height:1rem;width:1rem;color:var(--ng-text-muted)" fill="currentColor" viewBox="0 0 16 16"><path d="M14 4.5V14a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V2a2 2 0 0 1 2-2h5.5L14 4.5zm-3 0A1.5 1.5 0 0 1 9.5 3V1H4a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1V4.5h-2z"/></svg>
                <h2 class="cust-panel__title">{{ t('customer_instance_config_files_title', page_locale()) }}</h2>
            </div>
            <button type="button" id="gs-settings-create" class="ui-button ui-button--ghost ui-button--sm">
                {{ t('customer_instance_config_files_create', page_locale()) }}
            </button>
        </div>
        <div class="cust-panel__body" style="padding:0">
            <div style="display:grid;grid-template-columns:1fr">
                {# Config list #}
                <div style="border-bottom:1px solid var(--ng-border);padding:1rem">
                    <div style="display:flex;flex-direction:column;gap:0.5rem">
                        <div class="form-field" style="margin-bottom:0">
                            <input id="gs-settings-config-search" type="search"
                                class="form-input"
                                placeholder="{{ t('customer_instance_config_files_search', page_locale()) }}">
                        </div>
                        <div class="form-field" style="margin-bottom:0">
                            <select id="gs-settings-config-scope" class="form-input">
                                <option value="">{{ t('customer_instance_config_files_scope_all', page_locale()) }}</option>
                                <option value="template">Template</option>
                                <option value="instance">{{ t('customer_instance_config_files_scope_instance', page_locale()) }}</option>
                            </select>
                        </div>
                    </div>
                    <ul id="gs-settings-config-list" style="margin-top:0.75rem;display:flex;flex-direction:column;gap:0.25rem">
                        <li style="font-size:0.75rem;color:var(--ng-text-muted)">{{ t('customer_instance_config_files_loading', page_locale()) }}</li>
                    </ul>
                </div>
                {# Editor #}
                <div style="padding:1rem">
                    <div style="display:flex;align-items:center;justify-content:space-between">
                        <h4 style="font-size:0.7rem;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:var(--ng-text-muted)">{{ t('customer_instance_config_editor_label', page_locale()) }}</h4>
                        <p id="gs-settings-selected" style="font-size:0.75rem;color:var(--ng-text-muted)">{{ t('customer_instance_config_files_select', page_locale()) }}</p>
                    </div>
                    <textarea id="gs-settings-content"
                        class="form-input"
                        style="margin-top:0.75rem;height:16rem;font-family:monospace;font-size:0.75rem;resize:vertical"
                        placeholder="{{ t('customer_instance_config_files_select_hint', page_locale()) }}"></textarea>
                    <div style="margin-top:0.75rem;display:flex;flex-wrap:wrap;gap:0.5rem">
                        <button type="button" id="gs-settings-save" class="ui-button ui-button--primary ui-button--sm">
                            {{ t('customer_instance_config_files_save', page_locale()) }}
                        </button>
                        <button type="button" id="gs-settings-apply" class="ui-button ui-button--ghost ui-button--sm">
                            {{ t('customer_instance_config_files_apply', page_locale()) }}
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# ─── Automation ─── #}
    <div class="cust-panel">
        <div class="cust-panel__head" style="display:flex;align-items:center;gap:0.5rem">
            <svg style="height:1rem;width:1rem;color:var(--ng-text-muted)" fill="currentColor" viewBox="0 0 16 16"><path d="M6 .5a.5.5 0 0 1 .5-.5h3a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5H9v1.07a7.001 7.001 0 0 1 3.274 12.474l.601.602a.5.5 0 0 1-.707.708l-.746-.746A6.97 6.97 0 0 1 8 16a6.97 6.97 0 0 1-3.422-.892l-.746.746a.5.5 0 0 1-.707-.708l.601-.602A7.001 7.001 0 0 1 7 3.07V2h-.5A.5.5 0 0 1 6 1.5v-1zm2.5 12.5a.5.5 0 0 0-1 0V14h1v-.5zM8 7.5a.5.5 0 0 1 .5.5v3a.5.5 0 0 1-1 0V8a.5.5 0 0 1 .5-.5z"/></svg>
            <h2 class="cust-panel__title">{{ t('customer_instance_settings_automation_title', page_locale()) }}</h2>
        </div>
        <div class="cust-panel__body">
            <div style="display:grid;gap:1rem;grid-template-columns:repeat(auto-fill,minmax(200px,1fr))">
                {# Auto-Backup #}
                <div style="border:1px solid var(--ng-border);border-radius:8px;background:var(--ng-surface-soft);padding:0.75rem">
                    <div style="display:flex;align-items:center;justify-content:space-between;gap:0.5rem">
                        <span style="font-size:0.75rem;font-weight:600;color:var(--ng-text)">{{ t('customer_instance_settings_auto_backup', page_locale()) }}</span>
                        <label style="position:relative;display:inline-flex;cursor:pointer;align-items:center">
                            <input id="gs-auto-backup-enabled" type="checkbox" class="peer" style="position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);border:0">
                            <div class="peer" style="height:1.25rem;width:2.25rem;border-radius:9999px;border:1px solid var(--ng-border);background:var(--ng-surface-soft)"></div>
                        </label>
                    </div>
                    <div style="margin-top:0.75rem;display:flex;flex-direction:column;gap:0.5rem">
                        <select id="gs-auto-backup-mode" class="form-input" style="font-size:0.75rem;padding:0.375rem 0.5rem">
                            <option value="manual">{{ t('customer_instance_settings_mode_manual', page_locale()) }}</option>
                            <option value="auto">{{ t('customer_instance_settings_mode_auto', page_locale()) }}</option>
                        </select>
                        <div id="gs-auto-backup-time-wrap">
                            <label for="gs-auto-backup-time" class="form-label" style="font-size:0.625rem;text-transform:uppercase;letter-spacing:0.05em">{{ t('customer_instance_settings_time', page_locale()) }}</label>
                            <select id="gs-auto-backup-time" class="form-input" style="font-size:0.75rem;padding:0.375rem 0.5rem;margin-top:0.25rem"></select>
                        </div>
                    </div>
                </div>

                {# Auto-Restart #}
                <div style="border:1px solid var(--ng-border);border-radius:8px;background:var(--ng-surface-soft);padding:0.75rem">
                    <div style="display:flex;align-items:center;justify-content:space-between;gap:0.5rem">
                        <span style="font-size:0.75rem;font-weight:600;color:var(--ng-text)">{{ t('customer_instance_settings_auto_restart', page_locale()) }}</span>
                        <label style="position:relative;display:inline-flex;cursor:pointer;align-items:center">
                            <input id="gs-auto-restart-enabled" type="checkbox" class="peer" style="position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);border:0">
                            <div class="peer" style="height:1.25rem;width:2.25rem;border-radius:9999px;border:1px solid var(--ng-border);background:var(--ng-surface-soft)"></div>
                        </label>
                    </div>
                    <div id="gs-auto-restart-time-wrap" style="margin-top:0.75rem">
                        <label for="gs-auto-restart-time" class="form-label" style="font-size:0.625rem;text-transform:uppercase;letter-spacing:0.05em">{{ t('customer_instance_settings_time', page_locale()) }}</label>
                        <select id="gs-auto-restart-time" class="form-input" style="font-size:0.75rem;padding:0.375rem 0.5rem;margin-top:0.25rem"></select>
                    </div>
                </div>

                {# Auto-Update #}
                <div style="border:1px solid var(--ng-border);border-radius:8px;background:var(--ng-surface-soft);padding:0.75rem">
                    <div style="display:flex;align-items:center;justify-content:space-between;gap:0.5rem">
                        <span style="font-size:0.75rem;font-weight:600;color:var(--ng-text)">{{ t('customer_instance_settings_auto_update', page_locale()) }}</span>
                        <label style="position:relative;display:inline-flex;cursor:pointer;align-items:center">
                            <input id="gs-auto-update-enabled" type="checkbox" class="peer" style="position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);border:0">
                            <div class="peer" style="height:1.25rem;width:2.25rem;border-radius:9999px;border:1px solid var(--ng-border);background:var(--ng-surface-soft)"></div>
                        </label>
                    </div>
                    <div id="gs-auto-update-time-wrap" style="margin-top:0.75rem">
                        <label for="gs-auto-update-time" class="form-label" style="font-size:0.625rem;text-transform:uppercase;letter-spacing:0.05em">{{ t('customer_instance_settings_time', page_locale()) }}</label>
                        <select id="gs-auto-update-time" class="form-input" style="font-size:0.75rem;padding:0.375rem 0.5rem;margin-top:0.25rem"></select>
                    </div>
                </div>

                {# Version lock #}
                <div style="border:1px solid var(--ng-border);border-radius:8px;background:var(--ng-surface-soft);padding:0.75rem">
                    <div style="display:flex;align-items:center;justify-content:space-between;gap:0.5rem">
                        <span style="font-size:0.75rem;font-weight:600;color:var(--ng-text)">{{ t('customer_instance_version_lock', page_locale()) }}</span>
                        <label style="position:relative;display:inline-flex;cursor:pointer;align-items:center">
                            <input id="gs-version-lock-enabled" type="checkbox" class="peer" style="position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);border:0">
                            <div class="peer" style="height:1.25rem;width:2.25rem;border-radius:9999px;border:1px solid var(--ng-border);background:var(--ng-surface-soft)"></div>
                        </label>
                    </div>
                    <div style="margin-top:0.75rem">
                        <label class="form-label" style="font-size:0.625rem;text-transform:uppercase;letter-spacing:0.05em">{{ t('customer_instance_settings_version_label', page_locale()) }}</label>
                        <select id="gs-version-lock-version" class="form-input" style="font-size:0.75rem;padding:0.375rem 0.5rem;margin-top:0.25rem"></select>
                    </div>
                </div>
            </div>

            <div style="border-top:1px solid var(--ng-border);margin-top:1rem;padding-top:0.75rem">
                <button id="gs-automation-save" type="button" class="ui-button ui-button--primary ui-button--sm">
                    {{ t('customer_instance_settings_save_automation', page_locale()) }}
                </button>
            </div>
        </div>
    </div>

    {# ─── SFTP / Zugang ─── #}
    <div class="cust-panel" style="margin-top:1.25rem">
        <div class="cust-panel__head" style="display:flex;align-items:center;gap:0.5rem">
            <svg style="height:1rem;width:1rem;color:var(--ng-text-muted)" fill="currentColor" viewBox="0 0 16 16"><path d="M8 1a2 2 0 0 1 2 2v4H6V3a2 2 0 0 1 2-2zm3 6V3a3 3 0 0 0-6 0v4a2 2 0 0 0-2 2v5a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z"/></svg>
            <h2 class="cust-panel__title">{{ t('customer_instance_sftp_title', page_locale()) }}</h2>
        </div>
        <div class="cust-panel__body">
            <p style="font-size:0.75rem;color:var(--ng-text-muted);margin-bottom:1rem">{{ t('customer_instance_sftp_info', page_locale()) }}</p>
            <div style="display:grid;gap:0.75rem;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));margin-bottom:1rem">
                <div>
                    <p class="form-label" style="font-size:0.625rem;text-transform:uppercase;letter-spacing:0.05em">{{ t('customer_instance_sftp_username_label', page_locale()) }}</p>
                    <p id="gs-access-username" style="font-size:0.8125rem;font-family:monospace;color:var(--ng-text)">—</p>
                </div>
                <div>
                    <p class="form-label" style="font-size:0.625rem;text-transform:uppercase;letter-spacing:0.05em">{{ t('customer_instance_sftp_host_label', page_locale()) }}</p>
                    <p id="gs-access-host" style="font-size:0.8125rem;font-family:monospace;color:var(--ng-text)">—</p>
                </div>
                <div>
                    <p class="form-label" style="font-size:0.625rem;text-transform:uppercase;letter-spacing:0.05em">{{ t('customer_instance_sftp_port_label', page_locale()) }}</p>
                    <p id="gs-access-port" style="font-size:0.8125rem;font-family:monospace;color:var(--ng-text)">—</p>
                </div>
            </div>
            <div id="gs-access-password-wrap" class="hidden" style="margin-bottom:1rem;padding:0.75rem;border:1px solid var(--ng-border);border-radius:6px;background:var(--ng-surface-soft)">
                <p class="form-label" style="font-size:0.625rem;text-transform:uppercase;letter-spacing:0.05em;margin-bottom:0.25rem">{{ t('customer_instance_sftp_password_label', page_locale()) }}</p>
                <code id="gs-access-password" style="font-size:0.875rem;color:var(--ng-text);word-break:break-all"></code>
            </div>
            <div style="display:flex;gap:0.5rem;flex-wrap:wrap">
                <button id="gs-access-reveal" type="button" class="ui-button ui-button--primary ui-button--sm">
                    {{ t('customer_instance_sftp_reveal_btn', page_locale()) }}
                </button>
                <button id="gs-access-reset" type="button" class="ui-button ui-button--ghost ui-button--sm">
                    {{ t('customer_instance_sftp_reset_btn', page_locale()) }}
                </button>
            </div>
        </div>
    </div>
</div>

<script src="{{ asset('js/gameserver/shared/domMount.js') }}"></script>
<script src="{{ asset('js/gameserver/shared/errors.js') }}"></script>
<script src="{{ asset('js/gameserver/shared/apiClient.js') }}"></script>
<script src="{{ asset('js/gameserver/settings-app.js') }}"></script>
