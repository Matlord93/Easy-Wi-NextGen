<div
    id="gameserver-settings"
    class="space-y-5"
    data-url-settings="{{ path('customer_instance_settings_api_summary', {id: instance.id}) }}"
    data-url-configs="{{ path('customer_instance_configs_envelope_list', {id: instance.id}) }}"
    data-url-config-show="{{ path('customer_instance_configs_envelope_show', {id: instance.id, configId: '__CONFIG_ID__'}) }}"
    data-url-config-save="{{ path('customer_instance_configs_envelope_update', {id: instance.id, configId: '__CONFIG_ID__'}) }}"
    data-url-config-apply="{{ path('customer_instance_configs_envelope_apply', {id: instance.id, configId: '__CONFIG_ID__'}) }}"
    data-url-config-create="{{ path('customer_instance_configs_envelope_create', {id: instance.id}) }}"
    data-url-health="{{ path('customer_instance_settings_api_health', {id: instance.id}) }}"
    data-url-automation="{{ path('customer_instance_settings_api_automation_update', {id: instance.id}) }}"
    data-url-slots="{{ path('customer_instance_slots_update', {id: instance.id}) }}"
    data-url-access-health="{{ path('instances_access_health', {id: instance.id}) }}"
    data-url-access-reveal="{{ path('instances_access_reveal', {id: instance.id}) }}"
    data-url-access-reset="{{ path('instances_access_reset', {id: instance.id}) }}"
    data-i18n="{{ {
        'automationSaved': t('customer_instance_settings_automation_saved', page_locale()),
        'saving': t('customer_instance_settings_saving', page_locale()),
        'saveAutomationBtn': t('customer_instance_settings_automation_save_btn', page_locale()),
        'configNamePrompt': t('customer_instance_settings_config_name_prompt', page_locale()),
        'configFormatPrompt': t('customer_instance_settings_config_format_prompt', page_locale()),
        'creating': t('customer_instance_settings_creating', page_locale()),
        'createBtn': t('customer_instance_settings_create_btn', page_locale()),
        'configCreated': t('customer_instance_settings_config_created', page_locale()),
        'configSaved': t('customer_instance_settings_config_saved', page_locale()),
        'configApplyQueued': t('customer_instance_settings_config_apply_queued', page_locale()),
        'noMatchingConfigs': t('customer_instance_settings_no_matching_configs', page_locale()),
        'selectConfigFirst': t('customer_instance_settings_select_config_first', page_locale()),
        'applying': t('customer_instance_settings_applying', page_locale()),
        'applyBtn': t('customer_instance_settings_apply_btn', page_locale()),
        'saveBtn': t('customer_instance_settings_save_btn', page_locale())
    }|json_encode|e('html_attr') }}"
>
    <input type="hidden" id="slotInput" value="{{ instance.current_slots }}">

    {# ─── Status-Banner ─── #}
    <div class="rounded-xl border border-slate-700/60 bg-slate-800/40 px-4 py-3">
        <div class="flex flex-wrap items-center justify-between gap-2">
            <div class="flex items-center gap-2">
                <svg class="h-4 w-4 text-indigo-400" fill="currentColor" viewBox="0 0 16 16"><path d="M9.405 1.05c-.413-1.4-2.397-1.4-2.81 0l-.1.34a1.464 1.464 0 0 1-2.105.872l-.31-.17c-1.283-.698-2.686.705-1.987 1.987l.169.311c.446.82.023 1.841-.872 2.105l-.34.1c-1.4.413-1.4 2.397 0 2.81l.34.1a1.464 1.464 0 0 1 .872 2.105l-.17.31c-.698 1.283.705 2.686 1.987 1.987l.311-.169a1.464 1.464 0 0 1 2.105.872l.1.34c.413 1.4 2.397 1.4 2.81 0l.1-.34a1.464 1.464 0 0 1 2.105-.872l.31.17c1.283.698 2.686-.705 1.987-1.987l-.169-.311a1.464 1.464 0 0 1 .872-2.105l.34-.1c1.4-.413 1.4-2.397 0-2.81l-.34-.1a1.464 1.464 0 0 1-.872-2.105l.17-.31c.698-1.283-.705-2.686-1.987-1.987l-.311.169a1.464 1.464 0 0 1-2.105-.872l-.1-.34zM8 10.93a2.929 2.929 0 1 1 0-5.86 2.929 2.929 0 0 1 0 5.858z"/></svg>
                <h3 class="text-sm font-semibold text-slate-200">{{ t('customer_instance_tab_settings', page_locale()) }}</h3>
            </div>
            <p id="gs-settings-meta" class="text-xs text-slate-400">{{ t('customer_instance_settings_loading', page_locale()) }}</p>
        </div>
        <div id="gs-settings-error" class="hidden mt-3 rounded-lg border border-rose-700/50 bg-rose-500/10 p-3 text-sm text-rose-300"></div>
    </div>

    {# ─── Config files ─── #}
    <div class="rounded-xl border border-slate-700/60 bg-slate-800/40">
        <div class="flex items-center justify-between border-b border-slate-700/50 px-4 py-3">
            <div class="flex items-center gap-2">
                <svg class="h-4 w-4 text-slate-400" fill="currentColor" viewBox="0 0 16 16"><path d="M14 4.5V14a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V2a2 2 0 0 1 2-2h5.5L14 4.5zm-3 0A1.5 1.5 0 0 1 9.5 3V1H4a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1V4.5h-2z"/></svg>
                <h4 class="text-sm font-semibold text-slate-200">{{ t('customer_instance_config_files_title', page_locale()) }}</h4>
            </div>
            <button type="button" id="gs-settings-create"
                class="rounded-lg border border-slate-600 bg-slate-700/40 px-2.5 py-1 text-xs font-semibold text-slate-300 transition hover:bg-slate-700">
                {{ t('customer_instance_config_files_create', page_locale()) }}
            </button>
        </div>
        <div class="grid lg:grid-cols-3">
            {# Config list #}
            <div class="border-b border-slate-700/50 p-4 lg:border-b-0 lg:border-r">
                <div class="space-y-2">
                    <input id="gs-settings-config-search" type="search"
                        class="w-full rounded-lg border border-slate-600/80 bg-slate-900/60 px-3 py-1.5 text-xs text-slate-200 placeholder-slate-600 focus:border-indigo-500 focus:outline-none"
                        placeholder="{{ t('customer_instance_config_files_search', page_locale()) }}">
                    <select id="gs-settings-config-scope"
                        class="w-full rounded-lg border border-slate-600/80 bg-slate-900/60 px-3 py-1.5 text-xs text-slate-200 focus:border-indigo-500 focus:outline-none">
                        <option value="">{{ t('customer_instance_config_files_scope_all', page_locale()) }}</option>
                        <option value="template">Template</option>
                        <option value="instance">{{ t('customer_instance_config_files_scope_instance', page_locale()) }}</option>
                    </select>
                </div>
                <ul id="gs-settings-config-list" class="mt-3 space-y-1">
                    <li class="text-xs text-slate-500">{{ t('customer_instance_config_files_loading', page_locale()) }}</li>
                </ul>
            </div>
            {# Editor #}
            <div class="p-4 lg:col-span-2">
                <div class="flex items-center justify-between">
                    <h4 class="text-xs font-semibold uppercase tracking-widest text-slate-500">{{ t('customer_instance_config_editor_label', page_locale()) }}</h4>
                    <p id="gs-settings-selected" class="text-xs text-slate-500">{{ t('customer_instance_config_files_select', page_locale()) }}</p>
                </div>
                <textarea id="gs-settings-content"
                    class="mt-3 h-64 w-full rounded-lg border border-slate-600/80 bg-slate-900/60 p-3 font-mono text-xs text-slate-200 placeholder-slate-600 focus:border-indigo-500 focus:outline-none"
                    placeholder="{{ t('customer_instance_config_files_select_hint', page_locale()) }}"></textarea>
                <div class="mt-3 flex flex-wrap gap-2">
                    <button type="button" id="gs-settings-save"
                        class="rounded-lg bg-indigo-600 px-3 py-1.5 text-xs font-semibold text-white transition hover:bg-indigo-500">
                        {{ t('customer_instance_config_files_save', page_locale()) }}
                    </button>
                    <button type="button" id="gs-settings-apply"
                        class="rounded-lg border border-slate-600 bg-slate-700/40 px-3 py-1.5 text-xs font-semibold text-slate-300 transition hover:bg-slate-700">
                        {{ t('customer_instance_config_files_apply', page_locale()) }}
                    </button>
                </div>
            </div>
        </div>
    </div>

    {# ─── Automation ─── #}
    <div class="rounded-xl border border-slate-700/60 bg-slate-800/40">
        <div class="flex items-center gap-2 border-b border-slate-700/50 px-4 py-3">
            <svg class="h-4 w-4 text-slate-400" fill="currentColor" viewBox="0 0 16 16"><path d="M6 .5a.5.5 0 0 1 .5-.5h3a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5H9v1.07a7.001 7.001 0 0 1 3.274 12.474l.601.602a.5.5 0 0 1-.707.708l-.746-.746A6.97 6.97 0 0 1 8 16a6.97 6.97 0 0 1-3.422-.892l-.746.746a.5.5 0 0 1-.707-.708l.601-.602A7.001 7.001 0 0 1 7 3.07V2h-.5A.5.5 0 0 1 6 1.5v-1zm2.5 12.5a.5.5 0 0 0-1 0V14h1v-.5zM8 7.5a.5.5 0 0 1 .5.5v3a.5.5 0 0 1-1 0V8a.5.5 0 0 1 .5-.5z"/></svg>
            <h4 class="text-sm font-semibold text-slate-200">{{ t('customer_instance_settings_automation_title', page_locale()) }}</h4>
        </div>
        <div class="grid gap-4 p-4 md:grid-cols-2 xl:grid-cols-4">
            {# Auto-Backup #}
            <div class="rounded-lg border border-slate-700/50 bg-slate-900/50 p-3">
                <div class="flex items-center justify-between gap-2">
                    <span class="text-xs font-semibold text-slate-300">{{ t('customer_instance_settings_auto_backup', page_locale()) }}</span>
                    <label class="relative inline-flex cursor-pointer items-center">
                        <input id="gs-auto-backup-enabled" type="checkbox" class="peer sr-only">
                        <div class="peer h-5 w-9 rounded-full border border-slate-600 bg-slate-700 after:absolute after:left-[2px] after:top-0.5 after:h-4 after:w-4 after:rounded-full after:bg-slate-400 after:transition-all peer-checked:border-indigo-500 peer-checked:bg-indigo-600 peer-checked:after:translate-x-full peer-checked:after:bg-white"></div>
                    </label>
                </div>
                <div class="mt-3 space-y-2">
                    <select id="gs-auto-backup-mode"
                        class="w-full rounded-lg border border-slate-600/70 bg-slate-800/60 px-2 py-1.5 text-xs text-slate-200 focus:outline-none">
                        <option value="manual">{{ t('customer_instance_settings_mode_manual', page_locale()) }}</option>
                        <option value="auto">{{ t('customer_instance_settings_mode_auto', page_locale()) }}</option>
                    </select>
                    <div id="gs-auto-backup-time-wrap">
                        <label for="gs-auto-backup-time" class="block text-[10px] uppercase tracking-wide text-slate-500">{{ t('customer_instance_settings_time', page_locale()) }}</label>
                        <select id="gs-auto-backup-time"
                            class="mt-1 w-full rounded-lg border border-slate-600/70 bg-slate-800/60 px-2 py-1.5 text-xs text-slate-200 focus:outline-none"></select>
                    </div>
                </div>
            </div>

            {# Auto-Restart #}
            <div class="rounded-lg border border-slate-700/50 bg-slate-900/50 p-3">
                <div class="flex items-center justify-between gap-2">
                    <span class="text-xs font-semibold text-slate-300">{{ t('customer_instance_settings_auto_restart', page_locale()) }}</span>
                    <label class="relative inline-flex cursor-pointer items-center">
                        <input id="gs-auto-restart-enabled" type="checkbox" class="peer sr-only">
                        <div class="peer h-5 w-9 rounded-full border border-slate-600 bg-slate-700 after:absolute after:left-[2px] after:top-0.5 after:h-4 after:w-4 after:rounded-full after:bg-slate-400 after:transition-all peer-checked:border-indigo-500 peer-checked:bg-indigo-600 peer-checked:after:translate-x-full peer-checked:after:bg-white"></div>
                    </label>
                </div>
                <div id="gs-auto-restart-time-wrap" class="mt-3">
                    <label for="gs-auto-restart-time" class="block text-[10px] uppercase tracking-wide text-slate-500">{{ t('customer_instance_settings_time', page_locale()) }}</label>
                    <select id="gs-auto-restart-time"
                        class="mt-1 w-full rounded-lg border border-slate-600/70 bg-slate-800/60 px-2 py-1.5 text-xs text-slate-200 focus:outline-none"></select>
                </div>
            </div>

            {# Auto-Update #}
            <div class="rounded-lg border border-slate-700/50 bg-slate-900/50 p-3">
                <div class="flex items-center justify-between gap-2">
                    <span class="text-xs font-semibold text-slate-300">{{ t('customer_instance_settings_auto_update', page_locale()) }}</span>
                    <label class="relative inline-flex cursor-pointer items-center">
                        <input id="gs-auto-update-enabled" type="checkbox" class="peer sr-only">
                        <div class="peer h-5 w-9 rounded-full border border-slate-600 bg-slate-700 after:absolute after:left-[2px] after:top-0.5 after:h-4 after:w-4 after:rounded-full after:bg-slate-400 after:transition-all peer-checked:border-indigo-500 peer-checked:bg-indigo-600 peer-checked:after:translate-x-full peer-checked:after:bg-white"></div>
                    </label>
                </div>
                <div id="gs-auto-update-time-wrap" class="mt-3">
                    <label for="gs-auto-update-time" class="block text-[10px] uppercase tracking-wide text-slate-500">{{ t('customer_instance_settings_time', page_locale()) }}</label>
                    <select id="gs-auto-update-time"
                        class="mt-1 w-full rounded-lg border border-slate-600/70 bg-slate-800/60 px-2 py-1.5 text-xs text-slate-200 focus:outline-none"></select>
                </div>
            </div>

            {# Version lock #}
            <div class="rounded-lg border border-slate-700/50 bg-slate-900/50 p-3">
                <div class="flex items-center justify-between gap-2">
                    <span class="text-xs font-semibold text-slate-300">{{ t('customer_instance_version_lock', page_locale()) }}</span>
                    <label class="relative inline-flex cursor-pointer items-center">
                        <input id="gs-version-lock-enabled" type="checkbox" class="peer sr-only">
                        <div class="peer h-5 w-9 rounded-full border border-slate-600 bg-slate-700 after:absolute after:left-[2px] after:top-0.5 after:h-4 after:w-4 after:rounded-full after:bg-slate-400 after:transition-all peer-checked:border-indigo-500 peer-checked:bg-indigo-600 peer-checked:after:translate-x-full peer-checked:after:bg-white"></div>
                    </label>
                </div>
                <div class="mt-3">
                    <label class="block text-[10px] uppercase tracking-wide text-slate-500">{{ t('customer_instance_settings_version_label', page_locale()) }}</label>
                    <select id="gs-version-lock-version"
                        class="mt-1 w-full rounded-lg border border-slate-600/70 bg-slate-800/60 px-2 py-1.5 text-xs text-slate-200 focus:outline-none"></select>
                </div>
            </div>
        </div>

        <div class="border-t border-slate-700/50 px-4 py-3">
            <button id="gs-automation-save" type="button"
                class="rounded-lg bg-indigo-600 px-4 py-2 text-xs font-semibold text-white transition hover:bg-indigo-500">
                {{ t('customer_instance_settings_save_automation', page_locale()) }}
            </button>
        </div>
    </div>
</div>

<script src="{{ asset('js/gameserver/shared/domMount.js') }}"></script>
<script src="{{ asset('js/gameserver/shared/errors.js') }}"></script>
<script src="{{ asset('js/gameserver/shared/apiClient.js') }}"></script>
<script src="{{ asset('js/gameserver/settings-app.js') }}"></script>
