{% set locale = page_locale() %}
<div
    id="gameserver-addons"
    data-url-health="{{ path('customer_instance_addons_health', {id: instance.id}) }}"
    data-url-list="{{ path('customer_instance_addons_list', {id: instance.id}) }}"
    data-url-install-template="{{ path('customer_instance_addons_install_v2', {id: instance.id, addonId: '__ADDON_ID__'}) }}"
    data-url-update-template="{{ path('customer_instance_addons_update_v2', {id: instance.id, addonId: '__ADDON_ID__'}) }}"
    data-url-remove-template="{{ path('customer_instance_addons_remove_v2', {id: instance.id, addonId: '__ADDON_ID__'}) }}"
    data-i18n="{{ {
        'incompatible': t('customer_instance_addons_incompatible_badge', locale),
        'updateAvailable': t('customer_instance_addons_update_badge', locale),
        'installed': t('customer_instance_addons_installed_badge', locale),
        'available': t('customer_instance_addons_available_badge', locale),
        'noAddons': t('customer_instance_addons_none_js', locale),
        'notSupported': t('customer_instance_addons_not_supported_js', locale),
        'installedVersion': t('customer_instance_addons_installed_version_js', locale),
        'notInstalled': t('customer_instance_addons_not_installed_js', locale),
        'confirmAction': t('customer_instance_addons_confirm_action', locale),
        'actionQueued': t('customer_instance_addons_action_queued', locale),
        'install': t('customer_instance_addons_install', locale),
        'update': t('customer_instance_addons_update', locale),
        'remove': t('customer_instance_addons_remove', locale)
    }|json_encode|e('html_attr') }}"
>
    {# ─── Header ─── #}
    <div class="cust-panel">
        <div class="cust-panel__head">
            <div style="display:flex;align-items:center;gap:.5rem">
                <svg style="width:1.25rem;height:1.25rem;flex-shrink:0" fill="currentColor" viewBox="0 0 16 16"><path d="M1 2.5A1.5 1.5 0 0 1 2.5 1h3A1.5 1.5 0 0 1 7 2.5v3A1.5 1.5 0 0 1 5.5 7h-3A1.5 1.5 0 0 1 1 5.5v-3zm6.5 0A1.5 1.5 0 0 1 8.5 1h3A1.5 1.5 0 0 1 13 2.5v3A1.5 1.5 0 0 1 11.5 7h-3A1.5 1.5 0 0 1 7 5.5v-3zm-6.5 7A1.5 1.5 0 0 1 2.5 8h3A1.5 1.5 0 0 1 7 9.5v3A1.5 1.5 0 0 1 5.5 14h-3A1.5 1.5 0 0 1 1 12.5v-3zm6.5 0A1.5 1.5 0 0 1 8.5 8h3a1.5 1.5 0 0 1 1.5 1.5v3a1.5 1.5 0 0 1-1.5 1.5h-3A1.5 1.5 0 0 1 7 12.5v-3z"/></svg>
                <div>
                    <h2 class="cust-panel__title">{{ t('customer_instance_tab_addons', page_locale()) }}</h2>
                    <p style="font-size:.8rem;color:var(--ng-text-muted)">{{ t('customer_instances_addons_intro', page_locale()) }}</p>
                </div>
            </div>
            <p id="gs-addons-meta" style="font-size:.8rem;color:var(--ng-text-muted)">{{ t('common_loading', page_locale()) }}</p>
        </div>
        <div id="gs-addons-error" class="ng-alert ng-alert--danger" style="display:none"></div>
    </div>

    {# ─── Addon-Raster ─── #}
    <div id="gs-addons-list" class="cust-grid-2" style="margin-top:1rem">
        <div class="cust-panel" style="grid-column:1/-1">
            <div class="cust-panel__body" style="color:var(--ng-text-muted);font-size:.875rem">
                {{ t('common_loading', page_locale()) }}
            </div>
        </div>
    </div>
</div>

<script src="{{ asset('js/gameserver/shared/domMount.js') }}"></script>
<script src="{{ asset('js/gameserver/shared/errors.js') }}"></script>
<script src="{{ asset('js/gameserver/shared/apiClient.js') }}"></script>
<script src="{{ asset('js/gameserver/addons-app.js') }}"></script>
