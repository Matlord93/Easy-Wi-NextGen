                <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 16 16"><path d="M11 2H9v3h2V2zm-2 3H6.5l3 3.3 3-3.3H10V2H8v3zm-2 1H2.5a.5.5 0 0 0-.5.5v9a.5.5 0 0 0 .5.5h11a.5.5 0 0 0 .5-.5V6a.5.5 0 0 0-.5-.5H11V7h2v8H3V7h2v-.5a.5.5 0 0 0-.5-.5H5V6zm3 3a.5.5 0 0 1 .5.5v2.793l1.146-1.147a.5.5 0 0 1 .708.708l-2 2a.5.5 0 0 1-.708 0l-2-2a.5.5 0 0 1 .708-.708L7 12.293V9.5A.5.5 0 0 1 8 9z"/></svg>
