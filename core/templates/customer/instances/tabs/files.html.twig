                <p class="mt-1 text-xs text-slate-400">{{ t('customer_instance_files_tip_body', page_locale()) }}</p>
            </div>
        </div>
    </div>

    {# ─── SFTP-Hinweis ─── #}
    <div class="rounded-xl border border-slate-700/50 bg-slate-800/30 p-4">
        <p class="text-[10px] font-semibold uppercase tracking-widest text-slate-500">{{ t('customer_instance_sftp_title', locale) }}</p>
        <p class="mt-2 text-xs text-slate-400">
            {{ t('customer_instance_sftp_info', locale) }}
            {{ t('customer_instance_sftp_no_ftp', locale) }}
        </p>
