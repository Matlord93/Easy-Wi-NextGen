{% set status = instance.status %}
{% set displayStatus = instance.display_status ?? status %}

{% set statusClass = 'bg-slate-700/60 text-slate-300' %}
{% set statusDot   = 'bg-slate-400' %}
{% if displayStatus == 'running' %}
    {% set statusClass = 'bg-emerald-500/15 text-emerald-300' %}
    {% set statusDot   = 'bg-emerald-400 animate-pulse' %}
{% elseif displayStatus in ['stopped', 'pending_setup'] %}
    {% set statusClass = 'bg-amber-500/15 text-amber-300' %}
    {% set statusDot   = 'bg-amber-400' %}
{% elseif displayStatus in ['suspended', 'error'] %}
    {% set statusClass = 'bg-rose-500/15 text-rose-300' %}
    {% set statusDot   = 'bg-rose-400' %}
{% elseif displayStatus == 'provisioning' %}
    {% set statusClass = 'bg-sky-500/15 text-sky-300' %}
    {% set statusDot   = 'bg-sky-400 animate-pulse' %}
{% endif %}

{% set policyClass = instance.update_policy == 'auto' ? 'bg-indigo-500/15 text-indigo-300' : 'bg-slate-700/50 text-slate-400' %}

{% set diskStateStyles = {
    'ok':         'text-emerald-400 bg-emerald-500/10',
    'warning':    'text-amber-400 bg-amber-500/10',
    'over_limit': 'text-rose-400 bg-rose-500/10',
    'hard_block': 'text-rose-300 bg-rose-500/20'
} %}
{% set diskBadge    = diskStateStyles[instance.disk_state] ?? 'text-slate-400 bg-slate-700/50' %}
{% set diskPercent  = instance.disk_percent|default(0) %}
{% set diskBarWidth = diskPercent > 100 ? 100 : diskPercent %}
{% set diskBarColor = diskPercent > 90 ? 'bg-rose-500' : (diskPercent > 70 ? 'bg-amber-500' : 'bg-indigo-500') %}

{% set installReady  = instance.install_ready|default(false) %}
{% set installError  = instance.install_error_code|default(null) %}
{% set isInstalled   = instance.is_installed|default(instance.current_build_id ?? false) %}
{% set displayName   = instance.server_name ?? instance.template.name %}
{% set query         = instance.query ?? {} %}
{% set configuredSlots = instance.slots_configured ?? null %}
{% set effectiveSlots  = instance.slots_effective ?? null %}
{% set instanceCpu     = instance.instance_cpu_percent ?? null %}
{% set instanceMemBytes   = instance.instance_mem_used_bytes ?? null %}
{% set instanceMemPercent = instance.instance_mem_percent ?? null %}
{% set bookedCpu   = instance.booked_cpu_cores ?? null %}
{% set bookedRamMb = instance.booked_ram_mb ?? null %}
{% set installPath   = instance.installPath ?? instance.install_path ?? instance.data_path ?? null %}
{% set power         = instance.power ?? {} %}
{% set powerDisabled = power.disabled ?? false %}
{% set powerReason   = power.reason ?? null %}
{% set powerActiveJobId = power.active_job_id ?? null %}

{% set queryStatusLabels = {
    'online':       t('customer_instance_query_status_online',       page_locale()),
    'running':      t('customer_instance_query_status_running',      page_locale()),
    'starting':     t('customer_instance_query_status_starting',     page_locale()),
    'offline':      t('customer_instance_query_status_offline',      page_locale()),
    'queued':       t('customer_instance_query_status_queued',       page_locale()),
    'unknown':      t('customer_instance_query_status_unknown',      page_locale()),
    'error':        t('customer_instance_query_status_error',        page_locale()),
    'crashed':      t('customer_instance_query_status_crashed',      page_locale()),
    'stopped':      t('customer_instance_query_status_stopped',      page_locale()),
    'hibernating':  t('customer_instance_query_status_hibernating',  page_locale()),
    'idle':         t('customer_instance_query_status_idle',         page_locale())
} %}
{% set queryStatusKey   = query.status|default('unknown') %}
{% set queryStatusLabel = queryStatusLabels[queryStatusKey] ?? query.status ?? '—' %}
{% set playersOnline = instance.query_players_online %}
{% set playersMax    = instance.query_players_max %}
{% set playersKnown  = playersOnline is not null and playersMax is not null and playersMax > 0 %}

<div
    class="overflow-hidden rounded-xl border border-slate-700/60 bg-slate-800/40"
    data-instance-query="{{ instance.id }}"
    data-query-url="{{ path('customer_instance_query_api', {id: instance.id}) }}"
    data-query-status-labels="{{ queryStatusLabels|json_encode|e('html_attr') }}"
>
    {# ─── Header ─── #}
    <div class="border-b border-slate-700/60 bg-slate-900/40 px-5 py-4">
        <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
            <div class="min-w-0">
                <div class="flex flex-wrap items-center gap-2">
                    {% include 'components/_game_icon.html.twig' with { gameKey: instance.template.game_key, class: 'h-10 w-10 shrink-0 text-indigo-400' } %}
                    <div>
                        <div class="flex flex-wrap items-center gap-2">
                            <h2 class="text-lg font-bold text-slate-100">{{ displayName }}</h2>
                            <span class="inline-flex items-center gap-1 rounded-full px-2.5 py-0.5 text-xs font-medium {{ statusClass }}">
                                <span class="inline-block h-1.5 w-1.5 rounded-full {{ statusDot }}"></span>
                                {{ t('customer_instance_status_' ~ displayStatus, page_locale()) }}
                            </span>
                            <span class="rounded-full px-2.5 py-0.5 text-xs font-medium {{ policyClass }}">
                                {{ instance.update_policy == 'auto' ? t('customer_instance_policy_auto', page_locale()) : t('customer_instance_policy_manual', page_locale()) }}
                            </span>
                            <span class="rounded-full px-2.5 py-0.5 text-xs font-medium {{ diskBadge }}">
                                {{ t('customer_instance_disk_state_' ~ instance.disk_state, page_locale()) }}
                            </span>
                        </div>
                        <p class="mt-1 text-xs text-slate-500">
                            {{ t('customer_instance_id_label', page_locale()) }} #{{ instance.id }}
                            · {{ instance.template.game_key }}
                            · {{ t('customer_instance_node_label', page_locale()) }}: {{ instance.node.name }}
                        </p>
                        <p class="mt-1 max-w-full break-all font-mono text-xs text-slate-400" title="{{ installPath ?: '—' }}">
                            <span class="font-sans uppercase tracking-wide text-slate-500">{{ t('customer_instance_install_path', page_locale()) }}:</span>
                            {{ installPath ?: '—' }}
                        </p>
                    </div>
                </div>

                {% if instance.runtime_status_reason %}
                    <p class="mt-2 text-xs text-amber-400">
                        {{ instance.runtime_status_reason }}
                        {% if instance.runtime_status_error_code %} ({{ instance.runtime_status_error_code }}){% endif %}
                    </p>
                {% endif %}
                <p class="mt-1 text-[11px] text-slate-600">
                    {{ t('customer_instance_live_status', page_locale()) }}:
                    {{ instance.runtime_status_last_checked_at ? instance.runtime_status_last_checked_at|date('Y-m-d H:i:s') : '—' }}
                </p>
                {% if powerReason %}
                    <p class="mt-1 text-xs text-amber-400">
                        {{ powerReason }}
                        {% if powerActiveJobId %} (Job {{ powerActiveJobId }}){% endif %}
                    </p>
                {% endif %}
            </div>

            {# ─── Power Actions ─── #}
            <div class="flex shrink-0 flex-wrap gap-2">
                {% if installReady and status in ['pending_setup', 'error', 'stopped'] and not isInstalled %}
                    <form hx-post="{{ path('customer_instance_install', {id: instance.id}) }}" hx-target="#instance-card-{{ instance.id }}" hx-swap="outerHTML">
                        <button type="submit" class="rounded-lg bg-indigo-600 px-4 py-2 text-xs font-semibold text-white transition hover:bg-indigo-500">
                            {{ t('customer_instance_install', page_locale()) }}
                        </button>
                    </form>
                {% endif %}
                {% if status == 'running' %}
                    <form hx-post="{{ path('customer_instance_power', {id: instance.id}) }}" hx-target="#instance-card-{{ instance.id }}" hx-swap="outerHTML">
                        <input type="hidden" name="action" value="restart">
                        <button type="submit"
                            class="rounded-lg border border-slate-600 bg-slate-700/50 px-3 py-2 text-xs font-semibold text-slate-300 transition hover:bg-slate-700 disabled:cursor-not-allowed disabled:opacity-50"
                            {% if powerDisabled %}disabled title="{{ powerReason }}"{% endif %}>
                            {{ t('customer_instance_restart', page_locale()) }}
                        </button>
                    </form>
                    <form hx-post="{{ path('customer_instance_power', {id: instance.id}) }}" hx-target="#instance-card-{{ instance.id }}" hx-swap="outerHTML">
                        <input type="hidden" name="action" value="stop">
                        <button type="submit"
                            class="rounded-lg border border-rose-700/50 bg-rose-600/10 px-3 py-2 text-xs font-semibold text-rose-400 transition hover:bg-rose-600/20 disabled:cursor-not-allowed disabled:opacity-50"
                            {% if powerDisabled %}disabled title="{{ powerReason }}"{% endif %}>
                            {{ t('customer_instance_stop', page_locale()) }}
                        </button>
                    </form>
                {% elseif status == 'stopped' %}
                    <form hx-post="{{ path('customer_instance_power', {id: instance.id}) }}" hx-target="#instance-card-{{ instance.id }}" hx-swap="outerHTML">
                        <input type="hidden" name="action" value="start">
                        <button type="submit"
                            class="rounded-lg border border-emerald-700/50 bg-emerald-600/10 px-3 py-2 text-xs font-semibold text-emerald-400 transition hover:bg-emerald-600/20 disabled:cursor-not-allowed disabled:opacity-50"
                            {% if powerDisabled %}disabled title="{{ powerReason }}"{% endif %}>
                            {{ t('customer_instance_start', page_locale()) }}
                        </button>
                    </form>
                {% endif %}
                <form hx-post="{{ path('customer_instance_update', {id: instance.id}) }}" hx-target="#instance-card-{{ instance.id }}" hx-swap="outerHTML">
                    <button type="submit"
                        class="rounded-lg border border-slate-600 bg-slate-700/50 px-3 py-2 text-xs font-semibold text-slate-300 transition hover:bg-slate-700">
                        {{ t('customer_instance_manual_update', page_locale()) }}
                    </button>
                </form>
            </div>
        </div>
    </div>

    {# ─── Body ─── #}
    <div class="p-5">
        {# Alerts #}
        {% if instance.notice %}
            <div class="mb-4 rounded-lg border border-indigo-700/50 bg-indigo-500/10 px-4 py-3 text-sm text-indigo-300">{{ instance.notice }}</div>
        {% endif %}
        {% if instance.error %}
            <div class="mb-4 rounded-lg border border-rose-700/50 bg-rose-500/10 px-4 py-3 text-sm text-rose-300">{{ instance.error }}</div>
        {% endif %}
        {% if installError == 'MISSING_REQUIREMENTS' %}
            <div class="mb-4 rounded-lg border border-amber-700/50 bg-amber-500/10 px-4 py-3 text-sm text-amber-300">
                {{ t('customer_instance_setup_required', page_locale()) }}
            </div>
        {% elseif installError == 'INSTALL_APPROVAL_REQUIRED' %}
            <div class="mb-4 rounded-lg border border-slate-600 bg-slate-700/30 px-4 py-3 text-sm text-slate-300">
                {{ t('customer_instance_install_requires_approval', page_locale()) }}
            </div>
        {% endif %}
        {% if instance.disk_state == 'warning' %}
            <div class="mb-4 rounded-lg border border-amber-700/50 bg-amber-500/10 px-4 py-3 text-sm text-amber-300">{{ t('customer_instance_disk_warning_banner', page_locale()) }}</div>
        {% elseif instance.disk_state == 'over_limit' %}
            <div class="mb-4 rounded-lg border border-rose-700/50 bg-rose-500/10 px-4 py-3 text-sm text-rose-300">{{ t('customer_instance_disk_over_limit_banner', page_locale()) }}</div>
        {% elseif instance.disk_state == 'hard_block' %}
            <div class="mb-4 rounded-lg border border-rose-600 bg-rose-500/15 px-4 py-3 text-sm font-semibold text-rose-200">{{ t('customer_instance_disk_hard_block_banner', page_locale()) }}</div>
        {% endif %}

        {# ─── Info Grid ─── #}
        <div class="grid gap-4 lg:grid-cols-3">
            {# Server Info #}
            <div class="rounded-lg border border-slate-700/50 bg-slate-900/40 p-4">
                <p class="text-[10px] font-semibold uppercase tracking-widest text-slate-500">{{ t('customer_instance_server_info', page_locale()) }}</p>
                <div class="mt-3 space-y-2.5">
                    <div class="flex items-center justify-between gap-2 text-sm">
                        <span class="text-slate-400">{{ t('customer_instance_host', page_locale()) }}</span>
                        <div class="flex items-center gap-1.5">
                            <span class="font-medium text-slate-200">{{ instance.connection.host ?? '—' }}</span>
                            {% if instance.connection.host %}
                                <button type="button"
                                    class="rounded border border-slate-600 px-1.5 py-0.5 text-[10px] font-semibold text-slate-400 hover:text-slate-200"
                                    data-copy-value="{{ instance.connection.host }}">
                                    {{ t('customer_copy', page_locale()) }}
                                </button>
                            {% endif %}
                        </div>
                    </div>
                    <div class="flex items-center justify-between gap-2 text-sm">
                        <span class="text-slate-400">{{ t('customer_instance_address', page_locale()) }}</span>
                        <div class="flex items-center gap-1.5">
                            <span class="font-medium text-slate-200">{{ instance.connection.address ?? '—' }}</span>
                            {% if instance.connection.address %}
                                <button type="button"
                                    class="rounded border border-slate-600 px-1.5 py-0.5 text-[10px] font-semibold text-slate-400 hover:text-slate-200"
                                    data-copy-value="{{ instance.connection.address }}">
                                    {{ t('customer_copy', page_locale()) }}
                                </button>
                            {% endif %}
                        </div>
                    </div>
                    {% if instance.connection.quick_connect %}
                        <a href="{{ instance.connection.quick_connect }}"
                           class="inline-flex items-center gap-1.5 rounded-lg border border-indigo-600/40 bg-indigo-500/10 px-3 py-1.5 text-xs font-semibold text-indigo-300 hover:bg-indigo-500/20">
                            <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 16 16"><path d="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6zm2-3a2 2 0 1 1-4 0 2 2 0 0 1 4 0zm4 8c0 1-1 1-1 1H3s-1 0-1-1 1-4 6-4 6 3 6 4zm-1-.004c-.001-.246-.154-.986-.832-1.664C11.516 10.68 10.029 10 8 10c-2.029 0-3.516.68-4.168 1.332-.678.678-.83 1.418-.832 1.664h10z"/></svg>
                            {{ t('customer_instance_quick_connect', page_locale()) }}
                        </a>
                    {% endif %}
                    <div class="flex items-start justify-between gap-2 text-sm">
                        <span class="shrink-0 text-slate-400">{{ t('customer_instance_install_path', page_locale()) }}</span>
                        <span class="break-all text-right font-mono text-xs text-slate-200" title="{{ installPath ?: '—' }}">{{ installPath ?: '—' }}</span>
                    </div>
                    {% if app_setting('gameserver_show_port_range', true) %}
                        {% if instance.connection.port_block %}
                            <p class="text-xs text-slate-500">
                                {{ t('customer_instance_port_block', page_locale()) }}:
                                <span class="font-mono text-slate-400">{{ instance.connection.port_block.start }}-{{ instance.connection.port_block.end }}</span>
                            </p>
                        {% else %}
                            <p class="text-xs text-slate-600">{{ t('customer_instance_port_block_missing', page_locale()) }}</p>
                        {% endif %}
                    {% endif %}
                </div>
            </div>

            {# Disk Usage #}
            <div class="rounded-lg border border-slate-700/50 bg-slate-900/40 p-4">
                <p class="text-[10px] font-semibold uppercase tracking-widest text-slate-500">{{ t('customer_instance_disk_usage', page_locale()) }}</p>
                <div class="mt-3">
                    <div class="flex items-baseline justify-between">
                        <p class="text-lg font-bold text-slate-100">{{ instance.disk_used_human }}</p>
                        <p class="text-sm text-slate-400">/ {{ instance.disk_limit_human }}</p>
                    </div>
                    <div class="mt-2 h-2 w-full overflow-hidden rounded-full bg-slate-700">
                        <div class="h-2 rounded-full transition-all duration-500 {{ diskBarColor }}" style="width: {{ diskBarWidth }}%"></div>
                    </div>
                    <p class="mt-1 text-xs text-slate-500">{{ diskBarWidth }}% {{ t('customer_instance_disk_used', page_locale()) }}</p>
                    <div class="mt-2 flex flex-wrap items-center gap-2">
                        {% include 'components/_disk_widget.html.twig' with {
                            disk_last_scanned_at: instance.disk_last_scanned_at,
                            disk_used_bytes: instance.disk_used_bytes,
                            disk_scan_error: instance.disk_scan_error
                        } %}
                    </div>
                    <p class="mt-2 text-xs text-slate-600">
                        {{ t('customer_instance_disk_last_scan', page_locale()) }}:
                        {{ instance.disk_last_scanned_at ? instance.disk_last_scanned_at|date('Y-m-d H:i') : '—' }}
                    </p>
                    {% if instance.disk_scan_error %}
                        <p class="mt-1 text-xs text-rose-400">{{ instance.disk_scan_error }}</p>
                    {% endif %}
                </div>
            </div>

            {# Slots #}
            <div class="rounded-lg border border-slate-700/50 bg-slate-900/40 p-4">
                <p class="text-[10px] font-semibold uppercase tracking-widest text-slate-500">{{ t('customer_instance_slots_configured', page_locale()) }}</p>
                <div class="mt-3">
                    <div class="flex items-baseline gap-1.5">
                        <p class="text-2xl font-bold text-slate-100">{{ configuredSlots is not null ? configuredSlots : '—' }}</p>
                        <p class="text-sm text-slate-400">/ {{ instance.max_slots > 0 ? instance.max_slots : '—' }}</p>
                    </div>
                    <p class="mt-1 text-xs text-slate-500">{{ t('customer_instance_slots_configured_hint', page_locale()) }}</p>

                    <div class="mt-3 text-xs {{ query.available and (query.players is not null or query.max_players is not null) ? '' : 'hidden' }}" data-query-players-available>
                        <span class="text-slate-400">{{ t('customer_instance_players_online', page_locale()) }}:</span>
                        <span class="ml-1 font-semibold text-slate-200" data-query-players>
                            {% if playersKnown %}{{ playersOnline }} / {{ playersMax }}{% else %}{{ t('customer_instance_players_unknown', page_locale()) }}{% endif %}
                        </span>
                    </div>
                    <p class="mt-1 text-xs text-slate-500 {{ query.available and (query.players is not null or query.max_players is not null) ? '' : 'hidden' }}"
                       data-query-checked data-query-checked-label="{{ t('customer_instance_players_checked', page_locale()) }}">
                        {{ t('customer_instance_players_checked', page_locale()) }}: {{ query.checked_at ? query.checked_at|date('Y-m-d H:i') : '—' }}
                    </p>
                    <p class="mt-2 text-xs text-slate-500 {{ query.available and (query.players is not null or query.max_players is not null) ? 'hidden' : '' }}"
                       data-query-players-unavailable>
                        {{ t('customer_instance_players_unavailable', page_locale()) }}
                    </p>
                </div>
            </div>
        </div>

        {# ─── Live Status + Build + Ports ─── #}
        <div class="mt-4 grid gap-4 lg:grid-cols-3">
            {# Live Status #}
            <div class="rounded-lg border border-slate-700/50 bg-slate-900/40 p-4">
                <p class="text-[10px] font-semibold uppercase tracking-widest text-slate-500">{{ t('customer_instance_live_status', page_locale()) }}</p>
                <div class="mt-3 space-y-2">
                    {% macro stat_row(label, value, attrs='') %}
                        <div class="flex items-center justify-between gap-2 text-xs">
                            <span class="text-slate-400">{{ label }}</span>
                            <span class="font-medium text-slate-200 {{ attrs }}">{{ value }}</span>
                        </div>
                    {% endmacro %}
                    <div class="flex items-center justify-between gap-2 text-xs">
                        <span class="text-slate-400">{{ t('customer_instance_server_status', page_locale()) }}</span>
                        <span class="font-medium text-slate-200">{{ t('customer_instance_status_' ~ displayStatus, page_locale()) }}</span>
                    </div>
                    <div class="flex items-center justify-between gap-2 text-xs">
                        <span class="text-slate-400">{{ t('customer_instance_query_status', page_locale()) }}</span>
                        <span class="font-medium text-slate-200" data-query-status>{{ queryStatusLabel }}</span>
                    </div>
                    <div class="flex items-center justify-between gap-2 text-xs">
                        <span class="text-slate-400">{{ t('customer_instance_players_online', page_locale()) }}</span>
                        <span class="font-medium text-slate-200" data-query-players>
                            {% if playersKnown %}{{ playersOnline }} / {{ playersMax }}{% else %}{{ t('customer_instance_players_unknown', page_locale()) }}{% endif %}
                        </span>
                    </div>
                    <div class="flex items-center justify-between gap-2 text-xs">
                        <span class="text-slate-400">{{ t('customer_instance_slots_configured', page_locale()) }}</span>
                        <span class="font-medium text-slate-200">{{ configuredSlots is not null ? configuredSlots : t('customer_instance_unknown_pending', page_locale()) }}</span>
                    </div>
                    <div class="flex items-center justify-between gap-2 text-xs">
                        <span class="text-slate-400">{{ t('customer_instance_slots_effective', page_locale()) }}</span>
                        <span class="font-medium text-slate-200">{{ effectiveSlots is not null ? effectiveSlots : t('customer_instance_unknown_pending', page_locale()) }}</span>
                    </div>
                    <div class="border-t border-slate-700/40 pt-2"></div>
                    <div class="flex items-center justify-between gap-2 text-xs">
                        <span class="text-slate-400">{{ t('customer_resource_booked_cpu', page_locale()) }}</span>
                        <span class="font-medium text-slate-200">{{ bookedCpu is not null ? bookedCpu|number_format(2, '.', ',') : t('customer_resource_unknown', page_locale()) }}</span>
                    </div>
                    <div class="flex items-center justify-between gap-2 text-xs">
                        <span class="text-slate-400">{{ t('customer_resource_used_cpu', page_locale()) }}</span>
                        <span class="font-medium text-slate-200">{{ instanceCpu is not null ? instanceCpu|number_format(1, '.', ',') ~ '%' : t('customer_resource_unknown', page_locale()) }}</span>
                    </div>
                    <div class="flex items-center justify-between gap-2 text-xs">
                        <span class="text-slate-400">{{ t('customer_resource_booked_ram', page_locale()) }}</span>
                        <span class="font-medium text-slate-200">{{ bookedRamMb is not null ? bookedRamMb ~ ' MiB' : t('customer_resource_unknown', page_locale()) }}</span>
                    </div>
                    <div class="flex items-center justify-between gap-2 text-xs">
                        <span class="text-slate-400">{{ t('customer_resource_used_ram', page_locale()) }}</span>
                        <span class="font-medium text-slate-200">
                            {% if instanceMemBytes is not null %}
                                {{ (instanceMemBytes / 1024 / 1024)|number_format(0, '.', '') }} MiB
                                {% if instanceMemPercent is not null %} ({{ instanceMemPercent|number_format(1, '.', ',') }}%){% endif %}
                            {% else %}{{ t('customer_resource_unknown', page_locale()) }}{% endif %}
                        </span>
                    </div>
                    <div class="border-t border-slate-700/40 pt-2"></div>
                    <div class="flex items-center justify-between gap-2 text-xs">
                        <span class="text-slate-400">{{ t('map', page_locale()) }}</span>
                        <span class="font-medium text-slate-200" data-query-map>{{ query.map ?? '—' }}</span>
                    </div>
                    <div class="flex items-center justify-between gap-2 text-xs">
                        <span class="text-slate-400">Version</span>
                        <span class="font-medium text-slate-200" data-query-version>{{ query.result.reported.version ?? '—' }}</span>
                    </div>
                    <div class="flex items-center justify-between gap-2 text-xs">
                        <span class="text-slate-400">Latenz</span>
                        <span class="font-medium text-slate-200" data-query-latency>{{ query.result.latency_ms is not null ? query.result.latency_ms ~ ' ms' : '—' }}</span>
                    </div>
                    <p class="mt-1 text-[11px] text-slate-600"
                       data-query-checked data-query-checked-label="{{ t('customer_instance_players_checked', page_locale()) }}">
                        {{ t('customer_instance_players_checked', page_locale()) }}: {{ instance.query_checked_at ? instance.query_checked_at|date('Y-m-d H:i') : '—' }}
                    </p>
                    {% if not playersKnown %}
                        <p class="mt-1 text-[11px] text-amber-500">
                            {{ instance.query_reason ?: t('customer_instance_query_status_unknown', page_locale()) }}
                        </p>
                    {% endif %}
                </div>
            </div>

            {# Previous Build #}
            <div class="rounded-lg border border-slate-700/50 bg-slate-900/40 p-4">
                <p class="text-[10px] font-semibold uppercase tracking-widest text-slate-500">{{ t('customer_instance_previous_build', page_locale()) }}</p>
                <div class="mt-3">
                    <p class="text-lg font-bold text-slate-100">{{ instance.previous_build_id ?? '—' }}</p>
                    <p class="mt-1 text-xs text-slate-400">{{ instance.previous_version ?? t('customer_instance_no_prior_version', page_locale()) }}</p>
                    <p class="mt-3 text-xs text-slate-500">{{ t('customer_instance_rollback_hint', page_locale()) }}</p>
                    <form hx-post="{{ path('customer_instance_rollback', {id: instance.id}) }}" hx-target="#instance-card-{{ instance.id }}" hx-swap="outerHTML" class="mt-3">
                        <button type="submit"
                            class="rounded-lg border border-slate-600 bg-slate-700/40 px-3 py-1.5 text-xs font-semibold text-slate-300 transition hover:bg-slate-700">
                            {{ t('customer_instance_rollback', page_locale()) }}
                        </button>
                    </form>
                </div>
            </div>

            {# Ports #}
            <div class="rounded-lg border border-slate-700/50 bg-slate-900/40 p-4">
                <p class="text-[10px] font-semibold uppercase tracking-widest text-slate-500">{{ t('customer_instance_ports', page_locale()) }}</p>
                {% if instance.ports is not empty %}
                    <div class="mt-3 overflow-x-auto">
                        <table class="min-w-full text-xs">
                            <thead>
                                <tr class="text-slate-500 uppercase">
                                    <th class="pb-2 pr-3 text-left font-semibold">{{ t('customer_instance_ports_name', page_locale()) }}</th>
                                    <th class="pb-2 pr-3 text-left font-semibold">{{ t('customer_instance_ports_port', page_locale()) }}</th>
                                    <th class="pb-2 pr-3 text-left font-semibold">Proto</th>
                                    <th class="pb-2 text-left font-semibold">{{ t('customer_instance_ports_mode', page_locale()) }}</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for port in instance.ports %}
                                    <tr class="border-t border-slate-700/40">
                                        <td class="py-1.5 pr-3 text-slate-300">{{ port.name }}</td>
                                        <td class="py-1.5 pr-3 font-mono text-slate-200">{{ port.port }}</td>
                                        <td class="py-1.5 pr-3 text-slate-400">{{ port.protocol|upper }}</td>
                                        <td class="py-1.5 text-slate-400">{{ port.is_auto ? t('customer_instance_ports_auto', page_locale()) : t('customer_instance_ports_manual', page_locale()) }}</td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% else %}
                    <p class="mt-3 text-sm text-slate-500">{{ t('customer_instance_ports_pending', page_locale()) }}</p>
                {% endif %}
            </div>
        </div>
    </div>
</div>
