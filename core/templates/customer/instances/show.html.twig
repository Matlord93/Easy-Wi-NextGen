{% extends 'customer/base.html.twig' %}


{% block content %}
    <div class="customer-dashboard customer-dashboard--revamp flex flex-col gap-6">
        <div>
            <h2 class="text-3xl font-semibold text-slate-100">{{ instance.template.name }} · #{{ instance.id }}</h2>
            <p class="mt-2 text-base text-slate-400">{{ t('customer_instance_detail_intro', page_locale()) }}</p>
        </div>


        <section class="dashboard-panel">
            <div class="dashboard-panel__header">
                <div>
                    <h3>{{ t('customer_instance_detail_kicker', page_locale()) }}</h3>
                    <p>{{ instance.template.game_key }} · {{ instance.node.name }} ({{ instance.node.id }})</p>
                </div>
            </div>

            <div class="mt-4 flex flex-wrap gap-2 border-b border-slate-700 pb-3">
                {% for tab in tabs %}
                    <a
                        href="{{ tab.href }}"
                        class="rounded-lg px-3 py-2 text-xs font-semibold transition {{ tab.key == activeTab ? 'bg-indigo-500 text-white' : 'bg-slate-800 text-slate-300 hover:bg-slate-700 hover:text-slate-100' }}"
                    >
                        {% if tab.label_is_key is defined and not tab.label_is_key %}
                            {{ tab.label }}
                        {% else %}
                            {{ t(tab.label, page_locale()) }}
                        {% endif %}
                    </a>
                {% endfor %}
            </div>

            <div class="mt-4">
                {% include tabTemplate %}
            </div>
        </section>


    </div>
{% endblock %}
