<div class="rounded-lg border border-slate-200 bg-white p-4">
    <p class="text-xs font-semibold uppercase text-slate-700">{{ t('customer_instance_slots_settings_title', page_locale()) }}</p>
    <p class="mt-2 text-sm text-slate-600">{{ t('customer_instance_slots_settings_intro', page_locale()) }}</p>
    <p class="mt-1 text-xs text-slate-500">Maximal {{ instance.max_slots }} Slots möglich.</p>
    <form id="instance-slots-form" class="mt-4 space-y-3" data-slots-url="{{ path('customer_instance_slots_update', {id: instance.id}) }}">
        <label class="text-xs font-semibold uppercase text-slate-700">{{ t('customer_instance_slots_label', page_locale()) }}</label>
        <input id="instance-slots-input" type="number" min="{{ app_setting('gameserver_min_slots', 1) }}" max="{{ instance.max_slots }}" value="{{ instance.current_slots }}" class="mt-2 w-full rounded-lg border border-slate-200 bg-slate-50 px-3 py-2 text-sm" {% if instance.lock_slots %}disabled{% endif %}>
        <div class="flex flex-wrap items-center gap-3">
            <button id="instance-slots-submit" type="submit" class="rounded-lg bg-indigo-600 px-4 py-2 text-xs font-semibold text-white hover:bg-indigo-500" {% if instance.lock_slots %}disabled{% endif %}>
                {{ t('customer_instance_slots_save', page_locale()) }}
            </button>
            <span id="instance-slots-feedback" class="text-xs text-slate-500">
                {% if instance.lock_slots %}
                    {{ t('customer_instance_slots_locked', page_locale()) }}
                {% endif %}
            </span>
        </div>
    </form>
</div>

<script>
    (() => {
        const form = document.getElementById('instance-slots-form');
        if (!form) {
            return;
        }
        const input = document.getElementById('instance-slots-input');
        const feedback = document.getElementById('instance-slots-feedback');
        const button = document.getElementById('instance-slots-submit');
        if (!input || !feedback || !button) {
            return;
        }
        const url = form.dataset.slotsUrl;
        if (!url) {
            return;
        }

        form.addEventListener('submit', async (event) => {
            event.preventDefault();
            if (input.disabled) {
                return;
            }

            feedback.textContent = '{{ t('customer_instance_slots_saving', page_locale()) }}';
            feedback.classList.remove('text-rose-600');
            feedback.classList.add('text-slate-500');

            try {
                const response = await fetch(url, {
                    method: 'POST',
                    credentials: 'same-origin',
                    headers: {
                        'Content-Type': 'application/json',
                        'Accept': 'application/json',
                    },
                    body: JSON.stringify({ slots: input.value }),
                });

                const payload = await response.json().catch(() => ({}));
                if (!response.ok) {
                    feedback.textContent = payload.error || '{{ t('customer_instance_slots_error', page_locale()) }}';
                    feedback.classList.add('text-rose-600');
                    feedback.classList.remove('text-slate-500');
                    return;
                }

                if (payload.current_slots) {
                    input.value = payload.current_slots;
                }
                feedback.textContent = '{{ t('customer_instance_slots_saved', page_locale()) }}';
                feedback.classList.remove('text-rose-600');
                feedback.classList.add('text-slate-500');
            } catch (err) {
                feedback.textContent = err.message || '{{ t('customer_instance_slots_error', page_locale()) }}';
                feedback.classList.add('text-rose-600');
                feedback.classList.remove('text-slate-500');
            }
        });
    })();
</script>
