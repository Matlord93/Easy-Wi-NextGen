{% set status = instance.status %}
{% set displayStatus = instance.display_status ?? status %}

{% set statusClass = 'bg-slate-700/60 text-slate-300' %}
{% set statusDot   = 'bg-slate-400' %}
{% if displayStatus == 'running' %}
    {% set statusClass = 'bg-emerald-500/15 text-emerald-300' %}
    {% set statusDot   = 'bg-emerald-400 animate-pulse' %}
{% elseif displayStatus in ['stopped', 'pending_setup'] %}
    {% set statusClass = 'bg-amber-500/15 text-amber-300' %}
    {% set statusDot   = 'bg-amber-400' %}
{% elseif displayStatus in ['suspended', 'error'] %}
    {% set statusClass = 'bg-rose-500/15 text-rose-300' %}
    {% set statusDot   = 'bg-rose-400' %}
{% elseif displayStatus == 'provisioning' %}
    {% set statusClass = 'bg-sky-500/15 text-sky-300' %}
    {% set statusDot   = 'bg-sky-400 animate-pulse' %}
{% endif %}

{% set diskBadgeClass = 'text-slate-400' %}
{% if instance.disk_state == 'warning' %}{% set diskBadgeClass = 'text-amber-400' %}{% endif %}
{% if instance.disk_state in ['over_limit', 'hard_block'] %}{% set diskBadgeClass = 'text-rose-400' %}{% endif %}

{% set displayName = instance.server_name ?? instance.template.name %}
{% set query = instance.query ?? {} %}
{% set queryDebug = query.result.debug ?? {} %}
{% set queryStatusLabels = {
    'online':      t('customer_instance_query_status_online',   page_locale()),
    'running':     t('customer_instance_query_status_running',  page_locale()),
    'starting':    t('customer_instance_query_status_starting', page_locale()),
    'offline':     t('customer_instance_query_status_offline',  page_locale()),
    'queued':      t('customer_instance_query_status_queued',   page_locale()),
    'unknown':     t('customer_instance_query_status_unknown',  page_locale()),
    'error':       t('customer_instance_query_status_error',    page_locale())
} %}
{% set queryStatusKey   = query.status|default('unknown') %}
{% set queryStatusLabel = queryStatusLabels[queryStatusKey] ?? query.status ?? '—' %}
{% set playersOnline = instance.query_players_online %}
{% set playersMax    = instance.query_players_max %}
{% set playersKnown  = playersOnline is not null and playersMax is not null and playersMax > 0 %}
{% set connection    = instance.connection ?? {} %}
{% set runtimeStatus = (instance.runtime_status ?? displayStatus ?? status)|lower %}
{% set isRunning     = runtimeStatus in ['running', 'online', 'up'] %}
{% set powerState    = instance.power ?? {} %}
{% set powerDisabled = powerState.disabled ?? false %}
{% set powerReason   = powerState.reason ?? '' %}
{% set installPath   = instance.installPath ?? instance.install_path ?? instance.data_path ?? null %}

<div
    class="group relative flex flex-col rounded-xl border border-slate-700/60 bg-slate-800/40 p-4 transition-all duration-200 hover:border-slate-600/70 hover:bg-slate-800/60"
    data-instance-card
    data-instance-id="{{ instance.id }}"
    data-query-url="{{ path('customer_instance_query_api', {id: instance.id}) }}"
    data-query-health-url="{{ path('customer_instance_query_health_api_v2', {id: instance.id}) }}"
    data-power-url="{{ path('customer_instance_power_api', {id: instance.id}) }}"
    data-url-overview="{{ path('customer_instance_overview_page', {id: instance.id}) }}"
>
    {# ─── Header ─── #}
    <div class="flex items-start justify-between gap-3">
        <div class="flex min-w-0 items-center gap-2.5">
            {% include 'components/_game_icon.html.twig' with { gameKey: instance.template.game_key, class: 'h-9 w-9 shrink-0 text-indigo-400' } %}
            <div class="min-w-0">
                <div class="flex flex-wrap items-center gap-1.5">
                    <h2 class="text-sm font-semibold text-slate-100 truncate">{{ displayName }}</h2>
                    <span class="inline-flex shrink-0 items-center gap-1 rounded-full px-2 py-0.5 text-[11px] font-medium {{ statusClass }}">
                        <span class="inline-block h-1.5 w-1.5 rounded-full {{ statusDot }}"></span>
                        {{ t('customer_instance_status_' ~ displayStatus, page_locale()) }}
                    </span>
                </div>
                <p class="mt-0.5 text-[11px] text-slate-500">#{{ instance.id }} · {{ instance.template.game_key }}</p>
                <p class="mt-1 max-w-full break-all font-mono text-[11px] text-slate-400" title="{{ installPath ?: '—' }}">
                    <span class="font-sans uppercase tracking-wide text-slate-500">{{ t('customer_instance_install_path', page_locale()) }}:</span>
                    {{ installPath ?: '—' }}
                </p>
            </div>
        </div>
        <a href="{{ path('customer_instance_overview_page', {id: instance.id}) }}"
           class="shrink-0 rounded-lg border border-slate-600 bg-slate-700/50 px-2.5 py-1 text-[11px] font-semibold text-slate-300 transition hover:border-indigo-500/60 hover:bg-indigo-600/20 hover:text-indigo-300">
            {{ t('customer_instances_open', page_locale()) }}
        </a>
    </div>

    {# ─── Stats Grid ─── #}
    <div class="mt-3 grid grid-cols-2 gap-1.5 text-[11px]">
        <div class="rounded-lg border border-slate-700/40 bg-slate-900/50 px-2.5 py-2">
            <p class="uppercase tracking-wide text-slate-500">{{ t('customer_instance_node_label', page_locale()) }}</p>
            <p class="mt-0.5 font-semibold text-slate-200 truncate">{{ instance.node.name }}</p>
            {% if instance.node.location %}
                <p class="text-slate-500 truncate">{{ instance.node.location }}</p>
            {% endif %}
        </div>
        <div class="rounded-lg border border-slate-700/40 bg-slate-900/50 px-2.5 py-2">
            <p class="uppercase tracking-wide text-slate-500">{{ t('customer_instance_players_online', page_locale()) }}</p>
            <p class="mt-0.5 font-semibold text-slate-200" data-query-players>
                {% if playersKnown %}{{ playersOnline }} / {{ playersMax }}{% else %}{{ t('customer_instance_players_unknown', page_locale()) }}{% endif %}
            </p>
        </div>
        <div class="rounded-lg border border-slate-700/40 bg-slate-900/50 px-2.5 py-2">
            <p class="uppercase tracking-wide text-slate-500">{{ t('customer_instance_query_status', page_locale()) }}</p>
            <p class="mt-0.5 font-semibold text-slate-200" data-query-status>{{ queryStatusLabel }}</p>
        </div>
        <div class="rounded-lg border border-slate-700/40 bg-slate-900/50 px-2.5 py-2">
            <p class="uppercase tracking-wide text-slate-500">{{ t('customer_instance_disk_used', page_locale()) }}</p>
            <p class="mt-0.5 font-semibold {{ diskBadgeClass }}">{{ instance.disk_used_human }} / {{ instance.disk_limit_human }}</p>
        </div>
    </div>

    {# ─── Connection Info ─── #}
    <div class="mt-3 rounded-lg border border-slate-700/40 bg-slate-900/30 p-3 text-[11px]">
        <div class="grid grid-cols-2 gap-x-3 gap-y-1 text-slate-400">
            <div>
                <span class="text-slate-500">{{ t('customer_instances_game_address', page_locale()) }}</span>
                <strong class="block text-slate-200">{{ connection.address ?? '—' }}</strong>
            </div>
            <div>
                <span class="text-slate-500">Map</span>
                <strong class="block text-slate-200" data-query-map>{{ query.map ?? '—' }}</strong>
            </div>
        </div>

        <div class="mt-2 grid grid-cols-3 gap-2 border-t border-slate-700/40 pt-2 text-slate-500">
            <div>Host: <strong class="text-slate-400" data-debug-host>{{ queryDebug.resolved_host ?? connection.host ?? '—' }}</strong></div>
            <div>Port: <strong class="text-slate-400" data-debug-port>{{ queryDebug.resolved_port ?? connection.port ?? '—' }}</strong></div>
            <div>Proto: <strong class="text-slate-400" data-debug-protocol>{{ queryDebug.resolved_protocol ?? 'udp' }}</strong></div>
        </div>

        <details class="mt-1" data-query-details>
            <summary class="cursor-pointer text-slate-600 hover:text-slate-400">Debug-Details</summary>
            <div class="mt-1 space-y-0.5 text-slate-600">
                <div>Host-Quelle: <span data-debug-host-source>{{ queryDebug.resolved_host_source ?? '—' }}</span></div>
                <div>Port-Quelle: <span data-debug-port-source>{{ queryDebug.port_source ?? '—' }}</span></div>
                <div>Timeout: <span data-debug-timeout>{{ queryDebug.timeout_ms ?? '—' }}</span> ms · Fehler: <span data-debug-error>{{ queryDebug.last_error_code ?? '—' }}</span></div>
            </div>
        </details>

        <div class="hidden mt-1 rounded bg-amber-500/10 px-2 py-1 text-amber-400" data-query-error>{{ t('customer_instances_query_error', page_locale()) }}</div>
        <div class="hidden mt-1 rounded bg-slate-700/50 px-2 py-1 text-slate-400" data-query-unsupported>{{ t('customer_instance_query_unsupported', page_locale()) }}</div>

        <p class="mt-1 text-slate-600" data-query-checked>
            {{ t('customer_instance_players_checked', page_locale()) }}: {{ query.checked_at ? query.checked_at|date('Y-m-d H:i') : '—' }}
        </p>
    </div>

    {# ─── Actions ─── #}
    <div class="mt-3 flex flex-wrap items-center justify-between gap-2">
        <label class="inline-flex cursor-pointer items-center gap-1.5 text-[11px] text-slate-500 hover:text-slate-300">
            <input type="checkbox" data-bulk-select-restart
                class="rounded border-slate-600 bg-slate-900 text-indigo-500 focus:ring-indigo-500"
                {% if not isRunning or powerDisabled %}disabled{% if powerReason %} title="{{ powerReason }}"{% endif %}{% endif %}>
            {{ t('customer_instances_select_for_restart', page_locale()) }}
        </label>
        <div class="flex gap-1.5">
            <button type="button" data-power-action="start"
                class="rounded-lg border border-emerald-700/50 bg-emerald-600/10 px-2.5 py-1.5 text-[11px] font-semibold text-emerald-400 transition hover:bg-emerald-600/20 disabled:cursor-not-allowed disabled:opacity-40"
                {% if isRunning or powerDisabled %}disabled{% if powerReason %} title="{{ powerReason }}"{% endif %}{% endif %}>
                {{ t('customer_instance_start', page_locale()) }}
            </button>
            <button type="button" data-power-action="stop"
                class="rounded-lg border border-rose-700/50 bg-rose-600/10 px-2.5 py-1.5 text-[11px] font-semibold text-rose-400 transition hover:bg-rose-600/20 disabled:cursor-not-allowed disabled:opacity-40"
                {% if (not isRunning) or powerDisabled %}disabled{% if powerReason %} title="{{ powerReason }}"{% endif %}{% endif %}>
                {{ t('customer_instance_stop', page_locale()) }}
            </button>
            <button type="button" data-power-action="restart"
                class="rounded-lg border border-slate-600 bg-slate-700/40 px-2.5 py-1.5 text-[11px] font-semibold text-slate-300 transition hover:bg-slate-700/70 disabled:cursor-not-allowed disabled:opacity-40"
                {% if (not isRunning) or powerDisabled %}disabled{% if powerReason %} title="{{ powerReason }}"{% endif %}{% endif %}>
                {{ t('customer_instance_restart', page_locale()) }}
            </button>
        </div>
    </div>
</div>
