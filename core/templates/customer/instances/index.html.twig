{% extends 'customer/base.html.twig' %}

{% block title %}Instances · Easy-Wi NextGen{% endblock %}

{% block content %}
    <div class="customer-dashboard customer-dashboard--revamp flex flex-col gap-6">
        <section class="dashboard-panel">
            <div class="dashboard-panel__header">
                <div>
                    <h3>{{ t('customer_instances_title', page_locale()) }}</h3>
                    <p>{{ t('customer_instances_intro', page_locale()) }}</p>
                </div>
                <button id="gs-instances-refresh" type="button" class="rounded-lg border border-slate-200 px-3 py-2 text-xs font-semibold text-slate-700 hover:border-indigo-200 hover:text-indigo-600">
                    Refresh now
                </button>
            </div>
            <div id="gs-instances-list-error" class="hidden rounded-lg border border-rose-200 bg-rose-50 p-3 text-sm text-rose-700"></div>

            <div id="gameserver-instances-list" data-poll-base-ms="12000" class="mt-4 grid gap-6 lg:grid-cols-2">
                {% for instance in instances %}
                    <div id="instance-card-{{ instance.id }}">
                        {% include 'customer/instances/_summary_card.html.twig' with { instance: instance } %}
                    </div>
                {% else %}
                    <div class="dashboard-table__empty">
                        No instances yet. Ask an admin to provision your first server.
                    </div>
                {% endfor %}
            </div>
        </section>
    </div>
    <script src="{{ asset('js/gameserver/instances-list-app.js') }}"></script>
{% endblock %}
