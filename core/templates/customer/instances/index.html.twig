{% extends 'customer/base.html.twig' %}

{% block title %}{{ t('customer_instances_title', page_locale()) }} · Easy-Wi NextGen{% endblock %}

{% block content %}
    <div class="customer-dashboard customer-dashboard--revamp customer-instances-modern customer-section-gradient flex flex-col gap-6">
        <section class="dashboard-panel">
            <div class="dashboard-panel__header">
                <div>
                    <h3>{{ t('customer_instances_title', page_locale()) }}</h3>
                    <p>{{ t('customer_instances_intro', page_locale()) }}</p>
                </div>
                <button id="gs-instances-refresh" type="button" class="rounded-lg border border-indigo-200 bg-white/90 px-3 py-2 text-xs font-semibold text-indigo-700 hover:border-indigo-300 hover:text-indigo-800">
                    {{ t('customer_instances_refresh_now', page_locale()) }}
                </button>
            </div>
            <div id="gs-instances-list-error" class="hidden rounded-lg border border-rose-200 bg-rose-50 p-3 text-sm text-rose-700"></div>

            <div
                id="gameserver-instances-list"
                data-poll-base-ms="12000"
                data-label-query-unsupported="{{ t('customer_instance_query_unsupported', page_locale()) }}"
                data-label-query-online="{{ t('customer_instance_query_status_online', page_locale()) }}"
                data-label-query-running="{{ t('customer_instance_query_status_running', page_locale()) }}"
                data-label-query-starting="{{ t('customer_instance_query_status_starting', page_locale()) }}"
                data-label-query-offline="{{ t('customer_instance_query_status_offline', page_locale()) }}"
                data-label-query-queued="{{ t('customer_instance_query_status_queued', page_locale()) }}"
                data-label-query-unknown="{{ t('customer_instance_query_status_unknown', page_locale()) }}"
                data-label-query-error="{{ t('customer_instance_query_status_error', page_locale()) }}"
                data-label-query-crashed="{{ t('customer_instance_query_status_crashed', page_locale()) }}"
                data-label-query-stopped="{{ t('customer_instance_query_status_stopped', page_locale()) }}"
                data-label-query-hibernating="{{ t('customer_instance_query_status_hibernating', page_locale()) }}"
                data-label-query-idle="{{ t('customer_instance_query_status_idle', page_locale()) }}"
                data-label-query-player-unknown="{{ t('customer_instance_players_unknown', page_locale()) }}"
                data-label-power-working="{{ t('customer_instances_power_working', page_locale()) }}"
                data-label-power-queued="{{ t('customer_instances_power_queued', page_locale()) }}"
                class="mt-4 grid gap-6 lg:grid-cols-2"
            >
                {% for instance in instances %}
                    <div id="instance-card-{{ instance.id }}">
                        {% include 'customer/instances/_summary_card.html.twig' with { instance: instance } %}
                    </div>
                {% else %}
                    <div class="dashboard-table__empty">
                        {{ t('customer_instances_empty', page_locale()) }}
                    </div>
                {% endfor %}
            </div>
        </section>
    </div>
    <script src="{{ asset('js/gameserver/shared/domMount.js') }}"></script>
    <script src="{{ asset('js/gameserver/shared/errors.js') }}"></script>
    <script src="{{ asset('js/gameserver/shared/apiClient.js') }}"></script>
    <script src="{{ asset('js/gameserver/instances-list-app.js') }}"></script>
{% endblock %}
