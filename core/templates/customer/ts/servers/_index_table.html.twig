{% set locale = page_locale() %}
<div class="cust-page">

    {# ── Hero ── #}
    <div class="cust-hero">
        <div class="cust-hero__inner">
            <div>
                <div class="cust-hero__label">{{ t('customer_voice_page_title', locale) }}</div>
                <h1 class="cust-hero__title">{{ title }}</h1>
                <p class="cust-hero__desc">{{ intro }}</p>
            </div>
        </div>

        {% set onlineServers = servers|filter(row => row.server.status is defined and row.server.status in ['online', 'running', 'active'])|length %}
        <div class="cust-hero__stats" style="grid-template-columns:repeat(2,1fr);max-width:280px;">
            <div class="cust-hero__stat">
                <div class="cust-hero__stat-label">{{ t('customer_voice_total', locale) }}</div>
                <div class="cust-hero__stat-value">{{ servers|length }}</div>
                <div class="cust-hero__stat-sub">{{ t('customer_voice_col_server', locale) }}</div>
            </div>
            <div class="cust-hero__stat">
                <div class="cust-hero__stat-label">{{ t('customer_voice_online', locale) }}</div>
                <div class="cust-hero__stat-value" style="color:#4ade80;">{{ onlineServers }}</div>
                <div class="cust-hero__stat-sub">{{ t('customer_voice_active', locale) }}</div>
            </div>
        </div>
    </div>

    {# Flash messages #}
    {% for message in app.flashes('success') %}
        <div class="cust-alert cust-alert--success">{{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="cust-alert cust-alert--error">{{ message }}</div>
    {% endfor %}

    {# ── Server list ── #}
    {% if servers is empty %}
        <div class="cust-panel">
            <div class="cust-panel__body">
                <div class="cust-empty">
                    <svg viewBox="0 0 16 16" fill="currentColor"><path d="M3.5 6.5A.5.5 0 0 1 4 7v1a4 4 0 0 0 8 0V7a.5.5 0 0 1 1 0v1a5 5 0 0 1-4.5 4.975V15h3a.5.5 0 0 1 0 1h-7a.5.5 0 0 1 0-1h3v-2.025A5 5 0 0 1 3 8V7a.5.5 0 0 1 .5-.5z"/><path d="M10 8a2 2 0 1 1-4 0V3a2 2 0 1 1 4 0v5z"/></svg>
                    {{ emptyText }}
                </div>
            </div>
        </div>
    {% else %}
        <div class="cust-panel" style="padding:0;overflow:hidden;">
            {% for row in servers %}
                {% set server = row.server %}
                {% set status = server.status|default('unknown')|lower %}
                {% set isOnline  = status in ['online', 'running', 'active'] %}
                {% set isOffline = status in ['offline', 'stopped', 'stopping'] %}

                <div class="tsi-row">
                    <div class="tsi-row__stripe" style="background:{{ isOnline ? 'linear-gradient(to bottom,#4ade80,#22c55e)' : (isOffline ? 'linear-gradient(to bottom,#f87171,#ef4444)' : 'var(--ng-border-strong)') }};"></div>
                    <div class="tsi-row__body">
                        <div class="tsi-row__identity">
                            <div class="tsi-row__name">{{ server.name }}</div>
                            <div class="tsi-row__sub">
                                SID #{{ server.sid }} ·
                                {{ row.connectIp ?? server.node.queryConnectIp }}:{{ server.voicePort ?? '—' }}
                                {% if server.filetransferPort is defined %}· FT {{ server.filetransferPort ?? 30033 }}{% endif %}
                            </div>
                        </div>

                        <div class="tsi-row__meta">
                            <span class="tsi-dot tsi-dot--{{ isOnline ? 'success' : (isOffline ? 'danger' : 'warning') }}">{{ status|title }}</span>
                            <span class="tsi-slots" data-summary-url="{{ row.summaryUrl }}" data-slots>—/—</span>
                        </div>

                        <div class="tsi-row__actions">
                            <a class="ui-button ui-button--primary ui-button--sm" href="{{ detailBase }}/{{ server.id }}">{{ t('customer_voice_manage', locale) }}</a>
                            <form method="post" action="{{ detailBase }}/{{ server.id }}/start" style="display:contents;">
                                <input type="hidden" name="_token" value="{{ row.csrf.start }}">
                                <button class="ui-button ui-button--ghost ui-button--sm" style="color:#4ade80;border-color:rgba(34,197,94,.3);" type="submit">{{ t('customer_' ~ variant ~ '_server_start', locale) }}</button>
                            </form>
                            <form method="post" action="{{ detailBase }}/{{ server.id }}/stop" style="display:contents;">
                                <input type="hidden" name="_token" value="{{ row.csrf.stop }}">
                                <button class="ui-button ui-button--ghost ui-button--sm" style="color:#f87171;border-color:rgba(239,68,68,.3);" type="submit">{{ t('customer_' ~ variant ~ '_server_stop', locale) }}</button>
                            </form>
                            <form method="post" action="{{ detailBase }}/{{ server.id }}/restart" style="display:contents;">
                                <input type="hidden" name="_token" value="{{ row.csrf.restart }}">
                                <button class="ui-button ui-button--ghost ui-button--sm" type="submit">{{ t('customer_' ~ variant ~ '_server_restart', locale) }}</button>
                            </form>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}

</div>

<style>
.tsi-row { display:flex;border-bottom:1px solid var(--ng-border);transition:background .12s; }
.tsi-row:last-child { border-bottom:none; }
.tsi-row:hover { background:var(--ng-surface-soft); }
.tsi-row__stripe { width:3px;flex-shrink:0; }
.tsi-row__body { flex:1;min-width:0;padding:14px 18px;display:flex;flex-wrap:wrap;align-items:center;gap:12px; }
.tsi-row__identity { flex:1;min-width:160px; }
.tsi-row__name { font-size:14px;font-weight:700;color:var(--ng-text); }
.tsi-row__sub { font-size:11px;color:var(--ng-text-muted);font-family:monospace;margin-top:3px; }
.tsi-row__meta { display:flex;align-items:center;gap:10px;flex-wrap:wrap; }
.tsi-row__actions { display:flex;gap:6px;flex-wrap:wrap;align-items:center; }
.tsi-dot { display:inline-flex;align-items:center;gap:5px;font-size:11px;font-weight:600;padding:2px 9px;border-radius:99px; }
.tsi-dot::before { content:'';width:6px;height:6px;border-radius:50%;flex-shrink:0; }
.tsi-dot--success { background:rgba(34,197,94,.12);color:#4ade80; }
.tsi-dot--success::before { background:#4ade80; }
.tsi-dot--danger  { background:rgba(239,68,68,.12);color:#f87171; }
.tsi-dot--danger::before  { background:#f87171; }
.tsi-dot--warning { background:rgba(245,158,11,.12);color:#fbbf24; }
.tsi-dot--warning::before { background:#fbbf24; }
.tsi-slots { font-size:12px;font-weight:700;color:var(--ng-text-muted); }
</style>

<script>
(function () {
    const rows = document.querySelectorAll('[data-summary-url][data-slots]');
    if (!rows.length) { return; }
    rows.forEach((slotCell) => {
        const url = slotCell.dataset.summaryUrl;
        if (!url) { return; }
        let attempts = 0;
        const maxAttempts = 6;
        const delayMs = 1500;
        const loadSummary = () => {
            fetch(url)
                .then((r) => r.json())
                .then((data) => {
                    if (!data) { return; }
                    if (data.status === 'pending' && attempts < maxAttempts) {
                        attempts += 1;
                        setTimeout(loadSummary, delayMs);
                        return;
                    }
                    if (data.status === 'pending') { slotCell.textContent = '—/—'; return; }
                    if (data.status !== 'ok') { return; }
                    slotCell.textContent = `${data.clients_online ?? 0}/${data.max_clients ?? 0}`;
                    if ((data.clients_online ?? 0) > 0) slotCell.style.color = '#4ade80';
                })
                .catch(() => {});
        };
        loadSummary();
    });
})();
</script>
