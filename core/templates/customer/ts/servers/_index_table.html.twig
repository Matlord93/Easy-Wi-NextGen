<div class="{{ cssPrefix }}-page">
    <div class="{{ cssPrefix }}-header">
        <div>
            <h1>{{ title }}</h1>
            <p>{{ intro }}</p>
        </div>
    </div>

    {% for message in app.flashes('success') %}
        <div class="{{ cssPrefix }}-alert {{ cssPrefix }}-alert-success">{{ message }}</div>
    {% endfor %}

    <div class="{{ cssPrefix }}-card">
        <table class="{{ cssPrefix }}-table">
            <thead>
            <tr>
                <th>{{ columns.name }}</th>
                <th>{{ columns.address }}</th>
                <th>{{ columns.slots }}</th>
                <th>{{ columns.actions }}</th>
            </tr>
            </thead>
            <tbody>
            {% for row in servers %}
                {% set server = row.server %}
                <tr>
                    <td>
                        <div>{{ server.name }}</div>
                        <div class="{{ cssPrefix }}-muted">#{{ server.sid }}</div>
                    </td>
                    <td>
                        <div>IP: {{ server.node.queryConnectIp }}:{{ server.voicePort ?? '—' }}</div>
                        <div class="{{ cssPrefix }}-muted">FT {{ server.filetransferPort ?? 30033 }}</div>
                    </td>
                    <td>
                        <span data-summary-url="{{ row.summaryUrl }}" data-slots>—</span>
                    </td>
                    <td class="{{ cssPrefix }}-align-right">
                        <div class="{{ cssPrefix }}-actions">
                            <form method="post" action="{{ detailBase }}/{{ server.id }}/start">
                                <input type="hidden" name="_token" value="{{ row.csrf.start }}">
                                <button class="{{ cssPrefix }}-button" type="submit">Start</button>
                            </form>
                            <form method="post" action="{{ detailBase }}/{{ server.id }}/stop">
                                <input type="hidden" name="_token" value="{{ row.csrf.stop }}">
                                <button class="{{ cssPrefix }}-button" type="submit">Stop</button>
                            </form>
                            <form method="post" action="{{ detailBase }}/{{ server.id }}/restart">
                                <input type="hidden" name="_token" value="{{ row.csrf.restart }}">
                                <button class="{{ cssPrefix }}-button" type="submit">Neustart</button>
                            </form>
                            <a class="{{ cssPrefix }}-link" href="{{ detailBase }}/{{ server.id }}">Einstellung</a>
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td class="{{ cssPrefix }}-empty" colspan="4">{{ emptyText }}</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
<script>
    (function () {
        const rows = document.querySelectorAll('[data-summary-url][data-slots]');
        if (!rows.length) { return; }
        rows.forEach((slotCell) => {
            const url = slotCell.dataset.summaryUrl;
            if (!url) { return; }
            let attempts = 0;
            const maxAttempts = 6;
            const delayMs = 1500;
            const loadSummary = () => {
                fetch(url)
                    .then((response) => response.json())
                    .then((data) => {
                        if (!data) { return; }
                        if (data.status === 'pending' && attempts < maxAttempts) {
                            attempts += 1;
                            setTimeout(loadSummary, delayMs);
                            return;
                        }
                        if (data.status !== 'ok') { return; }
                        slotCell.textContent = `${data.clients_online ?? 0}/${data.max_clients ?? 0}`;
                    })
                    .catch(() => {});
            };
            loadSummary();
        });
    })();
</script>
