{% extends 'customer/base.html.twig' %}

{% block content %}
{% set locale = page_locale() %}
<div class="cust-page">

    <div class="cust-hero">
        <div class="cust-hero__inner">
            <div>
                <h1 class="cust-hero__title">{{ t('two_factor_title', locale) }}</h1>
                <p class="cust-hero__desc">{{ t('two_factor_customer_description', locale) }}</p>
            </div>
        </div>
    </div>

    {% if errors is not empty %}
        <div class="ng-alert ng-alert--danger">
            <ul>
                {% for error in errors %}
                    <li>{{ error }}</li>
                {% endfor %}
            </ul>
        </div>
    {% endif %}

    <div class="cust-panel">
        <div class="cust-panel__header">
            <div>
                <div class="cust-panel__title">{{ t('two_factor_title', locale) }}</div>
                <div class="cust-panel__sub">{{ t('two_factor_customer_intro', locale) }}</div>
            </div>
            {% if twoFactor.required and not twoFactor.enabled %}
                <span class="ui-badge ui-badge--warning">{{ t('two_factor_required_badge', locale) }}</span>
            {% elseif twoFactor.enabled %}
                <span class="ui-badge ui-badge--success">{{ t('two_factor_enabled_badge', locale) }}</span>
            {% else %}
                <span class="ui-badge ui-badge--neutral">{{ t('two_factor_disabled_badge', locale) }}</span>
            {% endif %}
        </div>
        <div class="cust-panel__body">

            {% if twoFactor.success %}
                <div class="ng-alert ng-alert--success">
                    {{ t(twoFactor.success, locale) }}
                </div>
            {% endif %}

            {% if twoFactor.enabled %}

                <p>{{ t('two_factor_enabled_intro', locale) }}</p>

                {# ── Regenerate recovery codes ── #}
                <form method="post" action="/profile/security/2fa/recovery" class="cust-2fa-form">
                    <div class="form-field">
                        <label class="form-label">{{ t('two_factor_code_label', locale) }}</label>
                        <input class="form-input" type="text" name="otp" placeholder="123456">
                    </div>
                    <p class="cust-2fa-form__hint">{{ t('two_factor_regenerate_hint', locale) }}</p>
                    <div>
                        <button type="submit" class="ui-button ui-button--ghost">{{ t('two_factor_regenerate', locale) }}</button>
                    </div>
                </form>

                {# ── Disable 2FA ── #}
                <form method="post" action="/profile/security/2fa/disable" class="cust-2fa-form">
                    <div class="form-field">
                        <label class="form-label">{{ t('two_factor_code_or_recovery', locale) }}</label>
                        <input class="form-input" type="text" name="otp" placeholder="123456">
                    </div>
                    <div class="form-field">
                        <label class="form-label">{{ t('two_factor_recovery_label', locale) }}</label>
                        <input class="form-input" type="text" name="recovery_code" placeholder="0000-0000">
                    </div>
                    <div>
                        <button type="submit" class="ui-button ui-button--danger">{{ t('two_factor_disable', locale) }}</button>
                    </div>
                </form>

                {% if twoFactor.recovery_codes is not empty %}
                    <div class="ng-alert ng-alert--warning">
                        <p><strong>{{ t('two_factor_recovery_show_once', locale) }}</strong></p>
                        <div class="cust-recovery-grid">
                            {% for code in twoFactor.recovery_codes %}
                                <div class="cust-recovery-grid__code">{{ code }}</div>
                            {% endfor %}
                        </div>
                    </div>
                {% endif %}

            {% else %}

                {# ── Setup 2FA ── #}
                <div class="cust-grid-2--wide">
                    <div>
                        <p>{{ t('two_factor_setup_intro', locale) }}</p>

                        <div class="form-field">
                            <label class="form-label">{{ t('two_factor_secret_label', locale) }}</label>
                            <div class="cust-2fa-secret">
                                <span class="cust-2fa-secret__value">{{ twoFactor.secret }}</span>
                                <button type="button" class="ui-button ui-button--ghost ui-button--sm" data-copy-value="{{ twoFactor.secret }}">{{ t('copy', locale) }}</button>
                            </div>
                        </div>

                        <form method="post" action="/profile/security/2fa/enable" class="cust-2fa-form">
                            <div class="form-field">
                                <label class="form-label">{{ t('two_factor_code_label', locale) }}</label>
                                <input class="form-input" type="text" name="otp" placeholder="123456">
                            </div>
                            <div>
                                <button type="submit" class="ui-button ui-button--primary">{{ t('two_factor_enable', locale) }}</button>
                            </div>
                        </form>
                    </div>

                    <div class="cust-2fa-qr">
                        <img src="{{ twoFactor.qr }}" alt="QR" class="cust-2fa-qr__img">
                        <p class="cust-2fa-qr__hint">{{ t('two_factor_scan_qr', locale) }}</p>
                    </div>
                </div>

            {% endif %}

        </div>
    </div>

</div>{# /cust-page #}
{% endblock %}
