{% extends 'customer/base.html.twig' %}

{% block content %}
<div class="flex flex-col gap-6">
    <div>
        <h1 class="text-2xl font-semibold">{{ t('two_factor_title', page_locale()) }}</h1>
        <p class="text-sm text-slate-700">{{ t('two_factor_customer_description', page_locale()) }}</p>
    </div>

    {% if errors is not empty %}
        <div class="rounded-xl border border-rose-200 bg-rose-50 px-5 py-4 text-sm text-rose-700">
            <ul class="list-disc space-y-1 pl-4">
                {% for error in errors %}
                    <li>{{ error }}</li>
                {% endfor %}
            </ul>
        </div>
    {% endif %}

    <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
        <div class="flex items-center justify-between">
            <div>
                <h2 class="text-lg font-semibold">{{ t('two_factor_title', page_locale()) }}</h2>
                <p class="text-sm text-slate-700">{{ t('two_factor_customer_intro', page_locale()) }}</p>
            </div>
            {% if twoFactor.required and not twoFactor.enabled %}
                <span class="rounded-full bg-amber-100 px-3 py-1 text-xs font-semibold text-amber-700">{{ t('two_factor_required_badge', page_locale()) }}</span>
            {% elseif twoFactor.enabled %}
                <span class="rounded-full bg-emerald-100 px-3 py-1 text-xs font-semibold text-emerald-700">{{ t('two_factor_enabled_badge', page_locale()) }}</span>
            {% else %}
                <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-600">{{ t('two_factor_disabled_badge', page_locale()) }}</span>
            {% endif %}
        </div>

        {% if twoFactor.success %}
            <div class="mt-4 rounded-lg border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-700">
                {{ t(twoFactor.success, page_locale()) }}
            </div>
        {% endif %}

        {% if twoFactor.enabled %}
            <div class="mt-4 space-y-4">
                <p class="text-sm text-slate-700">{{ t('two_factor_enabled_intro', page_locale()) }}</p>
                <form method="post" action="/profile/security/2fa/recovery" class="flex flex-col gap-3 sm:flex-row sm:items-end">
                    <div>
                        <label class="block text-xs font-semibold uppercase text-slate-700">{{ t('two_factor_code_label', page_locale()) }}</label>
                        <input type="text" name="otp" placeholder="123456" class="mt-2 w-48 rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm">
                    </div>
                    <div class="text-xs text-slate-600">{{ t('two_factor_regenerate_hint', page_locale()) }}</div>
                    <button type="submit" class="rounded-lg border border-slate-200 px-4 py-2 text-sm font-semibold text-slate-700">{{ t('two_factor_regenerate', page_locale()) }}</button>
                </form>

                <form method="post" action="/profile/security/2fa/disable" class="flex flex-col gap-3 sm:flex-row sm:items-end">
                    <div>
                        <label class="block text-xs font-semibold uppercase text-slate-700">{{ t('two_factor_code_or_recovery', page_locale()) }}</label>
                        <input type="text" name="otp" placeholder="123456" class="mt-2 w-48 rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm">
                    </div>
                    <div>
                        <label class="block text-xs font-semibold uppercase text-slate-700">{{ t('two_factor_recovery_label', page_locale()) }}</label>
                        <input type="text" name="recovery_code" placeholder="0000-0000" class="mt-2 w-48 rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm">
                    </div>
                    <button type="submit" class="rounded-lg border border-rose-200 px-4 py-2 text-sm font-semibold text-rose-700">{{ t('two_factor_disable', page_locale()) }}</button>
                </form>

                {% if twoFactor.recovery_codes is not empty %}
                    <div class="rounded-lg border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-800">
                        <p class="font-semibold">{{ t('two_factor_recovery_show_once', page_locale()) }}</p>
                        <div class="mt-2 grid gap-2 sm:grid-cols-2">
                            {% for code in twoFactor.recovery_codes %}
                                <div class="rounded bg-white px-3 py-2 font-mono text-sm text-slate-700">{{ code }}</div>
                            {% endfor %}
                        </div>
                    </div>
                {% endif %}
            </div>
        {% else %}
            <div class="mt-4 grid gap-6 lg:grid-cols-[1fr,240px]">
                <div>
                    <p class="text-sm text-slate-700">{{ t('two_factor_setup_intro', page_locale()) }}</p>
                    <div class="mt-4 space-y-3 text-sm text-slate-700">
                        <div>
                            <p class="text-xs font-semibold uppercase text-slate-700">{{ t('two_factor_secret_label', page_locale()) }}</p>
                            <div class="mt-2 flex flex-wrap items-center gap-2">
                                <span class="rounded-lg border border-slate-200 bg-slate-50 px-3 py-2 font-mono text-sm text-slate-700">{{ twoFactor.secret }}</span>
                                <button type="button" data-copy-value="{{ twoFactor.secret }}" class="rounded-lg border border-slate-200 px-3 py-2 text-xs font-semibold text-slate-600">{{ t('copy', page_locale()) }}</button>
                            </div>
                        </div>
                        <form method="post" action="/profile/security/2fa/enable" class="flex flex-col gap-3 sm:flex-row sm:items-end">
                            <div>
                                <label class="block text-xs font-semibold uppercase text-slate-700">{{ t('two_factor_code_label', page_locale()) }}</label>
                                <input type="text" name="otp" placeholder="123456" class="mt-2 w-48 rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm">
                            </div>
                            <button type="submit" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white">{{ t('two_factor_enable', page_locale()) }}</button>
                        </form>
                    </div>
                </div>
                <div class="flex flex-col items-center gap-2">
                    <img src="{{ twoFactor.qr }}" alt="QR" class="h-44 w-44 rounded-lg border border-slate-200 bg-white p-2">
                    <p class="text-xs text-slate-600">{{ t('two_factor_scan_qr', page_locale()) }}</p>
                </div>
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}
