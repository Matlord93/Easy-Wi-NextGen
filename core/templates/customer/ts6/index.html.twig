{% extends 'customer/base.html.twig' %}

{% block content %}
{% set locale = page_locale() %}
<div class="cust-page">

    {# ── Header ── #}
    <div class="cust-hero">
        <div class="cust-hero__inner">
            <div>
                <div style="display:flex;flex-wrap:wrap;align-items:center;gap:8px;margin-bottom:6px;">
                    <h1 class="cust-hero__title" style="margin:0;">{{ t('customer_ts6_heading', page_locale()) }}</h1>
                    <span class="ui-badge ui-badge--warning">{{ t('customer_ts6_badge_planned', page_locale()) }}</span>
                    <span class="ui-badge ui-badge--info">{{ t('customer_ts6_badge_experimental', page_locale()) }}</span>
                </div>
                <p class="cust-hero__desc">{{ t('customer_ts6_intro', page_locale()) }}</p>
            </div>
        </div>
    </div>

    {% if notice %}
        <div class="cust-alert cust-alert--success">{{ t(notice, page_locale()) }}</div>
    {% endif %}

    {# ── TS6 Instances ── #}
    <div class="cust-panel" style="padding:0;overflow:hidden;">
        <div style="padding:14px 20px;border-bottom:1px solid var(--ng-border);">
            <h2 style="margin:0;font-size:14px;font-weight:700;color:var(--ng-text);">{{ t('customer_ts6_instances_title', page_locale()) }}</h2>
            <p style="margin:3px 0 0;font-size:12px;color:var(--ng-text-muted);">{{ t('customer_ts6_instances_intro', page_locale()) }}</p>
        </div>

        {% if instances is empty %}
            <div style="padding:40px;text-align:center;color:var(--ng-text-muted);font-size:13px;">
                {{ t('customer_ts6_instances_empty', page_locale()) }}
            </div>
        {% else %}
            {% set statusColors = {
                planned:      'rgba(245,158,11,.12)|#fbbf24',
                provisioning: 'rgba(56,189,248,.12)|#38bdf8',
                running:      'rgba(34,197,94,.12)|#4ade80',
                stopped:      'rgba(148,163,184,.12)|#94a3b8',
                error:        'rgba(239,68,68,.12)|#f87171'
            } %}
            {% for instance in instances %}
                {% set parts = (statusColors[instance.status] ?? 'rgba(148,163,184,.12)|#94a3b8')|split('|') %}
                <div class="ts6-instance-row">
                    <div class="ts6-instance-row__info">
                        <div class="ts6-instance-row__name">{{ instance.name }}</div>
                        <div class="ts6-instance-row__sub">Node: {{ instance.node }} · {{ instance.updated_at|date('Y-m-d H:i') }}</div>
                    </div>
                    <div>
                        <span class="ts6-status-badge" style="background:{{ parts[0] }};color:{{ parts[1] }};">
                            {{ t('customer_ts6_status_' ~ instance.status, page_locale()) }}
                        </span>
                    </div>
                    <div class="ts6-instance-row__actions">
                        <form method="post" action="/ts6/{{ instance.id }}/action">
                            <input type="hidden" name="action" value="start">
                            <button class="ui-button ui-button--ghost ui-button--sm" style="color:#4ade80;border-color:rgba(34,197,94,.3);">{{ t('customer_ts6_action_start', page_locale()) }}</button>
                        </form>
                        <form method="post" action="/ts6/{{ instance.id }}/action">
                            <input type="hidden" name="action" value="stop">
                            <button class="ui-button ui-button--ghost ui-button--sm" style="color:#f87171;border-color:rgba(239,68,68,.3);">{{ t('customer_ts6_action_stop', page_locale()) }}</button>
                        </form>
                        <form method="post" action="/ts6/{{ instance.id }}/action">
                            <input type="hidden" name="action" value="restart">
                            <button class="ui-button ui-button--ghost ui-button--sm">{{ t('customer_ts6_action_restart', page_locale()) }}</button>
                        </form>
                        <form method="post" action="/ts6/{{ instance.id }}/action">
                            <input type="hidden" name="action" value="update">
                            <button class="ui-button ui-button--ghost ui-button--sm">{{ t('customer_ts6_action_update', page_locale()) }}</button>
                        </form>
                    </div>
                </div>
            {% endfor %}
        {% endif %}
    </div>

    {# ── Virtual Servers ── #}
    {% if virtual_servers_enabled %}
    <div class="cust-panel" style="padding:0;overflow:hidden;">
        <div style="padding:14px 20px;border-bottom:1px solid var(--ng-border);">
            <h2 style="margin:0;font-size:14px;font-weight:700;color:var(--ng-text);">{{ t('customer_ts6_virtual_title', page_locale()) }}</h2>
            <p style="margin:3px 0 0;font-size:12px;color:var(--ng-text-muted);">{{ t('customer_ts6_virtual_intro', page_locale()) }}</p>
        </div>

        {% if virtual_servers is empty %}
            <div style="padding:40px;text-align:center;color:var(--ng-text-muted);font-size:13px;">
                {{ t('customer_ts6_virtual_empty', page_locale()) }}
            </div>
        {% else %}
            {% set vsStatusColors = {
                planned: 'rgba(245,158,11,.12)|#fbbf24',
                active:  'rgba(34,197,94,.12)|#4ade80',
                stopped: 'rgba(148,163,184,.12)|#94a3b8',
                error:   'rgba(239,68,68,.12)|#f87171'
            } %}
            {% for server in virtual_servers %}
                {% set vparts = (vsStatusColors[server.status] ?? 'rgba(148,163,184,.12)|#94a3b8')|split('|') %}
                <div class="ts6-instance-row">
                    <div class="ts6-instance-row__info">
                        <div class="ts6-instance-row__name">{{ server.name }}</div>
                        <div class="ts6-instance-row__sub">Instanz: {{ server.instance }} · Slots: {{ server.slots }} · {{ server.updated_at|date('Y-m-d H:i') }}</div>
                    </div>
                    <div>
                        <span class="ts6-status-badge" style="background:{{ vparts[0] }};color:{{ vparts[1] }};">
                            {{ t('customer_ts6_status_' ~ server.status, page_locale()) }}
                        </span>
                    </div>
                    <div></div>
                </div>
            {% endfor %}
        {% endif %}
    </div>
    {% endif %}

</div>

<style>
.ts6-instance-row { display:flex;flex-wrap:wrap;align-items:center;gap:12px;padding:12px 20px;border-bottom:1px solid var(--ng-border); }
.ts6-instance-row:last-child { border-bottom:none; }
.ts6-instance-row__info { flex:1;min-width:160px; }
.ts6-instance-row__name { font-size:14px;font-weight:700;color:var(--ng-text); }
.ts6-instance-row__sub { font-size:11px;color:var(--ng-text-muted);margin-top:3px; }
.ts6-instance-row__actions { display:flex;gap:6px;flex-wrap:wrap; }
.ts6-status-badge { font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;padding:3px 9px;border-radius:99px; }
</style>
{% endblock %}
