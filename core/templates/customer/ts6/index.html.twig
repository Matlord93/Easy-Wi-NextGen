{% extends 'customer/base.html.twig' %}

{% block content %}
{% set locale = page_locale() %}
<div class="cust-page">
    <div class="cust-hero"><div class="cust-hero__inner"><div><div style="display:flex;flex-wrap:wrap;align-items:center;gap:8px;margin-bottom:6px;"><h1 class="cust-hero__title" style="margin:0;">{{ t('customer_ts6_heading', locale) }}</h1></div><p class="cust-hero__desc">{{ t('customer_ts6_intro', locale) }}</p></div></div></div>

    <div class="cust-panel" style="padding:0;overflow:hidden;">
        <div style="padding:14px 20px;border-bottom:1px solid var(--ng-border);">
            <h2 style="margin:0;font-size:14px;font-weight:700;">{{ t('customer_ts6_instances_title', locale) }}</h2>
        </div>
        {% for instance in instances %}
        <div class="ts6-instance-row" data-ts6-id="{{ instance.id }}">
            <div class="ts6-instance-row__info">
                <div class="ts6-instance-row__name">{{ instance.name }}</div>
                <div class="ts6-instance-row__sub">Node: {{ instance.node }} · {{ instance.updated_at|date('Y-m-d H:i') }}</div>
                <div class="ts6-instance-row__sub">{{ t('teamspeak.status.installation.' ~ (instance.installation_status ?? 'unknown'), locale) }} · {{ t('teamspeak.status.runtime.' ~ (instance.runtime_status ?? 'unknown'), locale) }}</div>
            </div>
            <div class="ts6-instance-row__actions">
                <button class="ui-button ui-button--ghost ui-button--sm js-ts6-check">{{ t('teamspeak.update.check', locale) }}</button>
                <button class="ui-button ui-button--ghost ui-button--sm js-ts6-install">{{ t('teamspeak.update.install', locale) }}</button>
            </div>
            <div class="ts6-update-panel" style="width:100%;margin-top:10px;border:1px solid var(--ng-border);border-radius:8px;padding:12px;">
                <h3 style="margin:0 0 8px 0;font-size:13px;">{{ t('teamspeak.update.title', locale) }}</h3>
                <div class="ts6-grid">
                    <div><strong>{{ t('teamspeak.update.installed_version', locale) }}:</strong> <span class="f-installed">{{ instance.installed_version ?? '—' }}</span></div>
                    <div><strong>{{ t('teamspeak.update.available_version', locale) }}:</strong> <span class="f-available">{{ instance.available_version ?? '—' }}</span></div>
                    <div><strong>{{ t('teamspeak.update.channel', locale) }}:</strong> <span class="f-channel">{{ instance.update_channel ?? '—' }}</span></div>
                    <div><strong>{{ t('teamspeak.update.last_check', locale) }}:</strong> <span class="f-last-check">{{ instance.last_update_check_at ? instance.last_update_check_at|date('Y-m-d H:i') : '—' }}</span></div>
                    <div><strong>{{ t('teamspeak.update.status', locale) }}:</strong> <span class="f-status">—</span></div>
                    <div><strong>{{ t('teamspeak.update.checksum_status', locale) }}:</strong> <span class="f-checksum-status">—</span></div>
                    <div><strong>{{ t('teamspeak.update.checksum_source', locale) }}:</strong> <span class="f-checksum-source">—</span></div>
                    <div><strong>{{ t('teamspeak.update.last_log', locale) }}:</strong> <span class="f-last-log">—</span></div>
                </div>
                <div style="margin-top:8px;color:#f59e0b;">{{ t('teamspeak.update.warning.server_will_stop', locale) }}</div>
                <div class="f-message" style="margin-top:8px;"></div>
            </div>
        </div>
        {% else %}<div style="padding:20px;">{{ t('customer_ts6_instances_empty', locale) }}</div>{% endfor %}
    </div>
</div>
<style>.ts6-instance-row{padding:12px 20px;border-bottom:1px solid var(--ng-border)}.ts6-instance-row__actions{display:flex;gap:6px}.ts6-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:6px}</style>
<script>
const T={ ok:{{ t('teamspeak.update.install_success',locale)|json_encode|raw }}, fail:{{ t('teamspeak.update.install_failed',locale)|json_encode|raw }}, running:{{ t('teamspeak.update.install_running',locale)|json_encode|raw }}, noUpdate:{{ t('teamspeak.update.no_update_available',locale)|json_encode|raw }}, updAvail:{{ t('teamspeak.update.update_available',locale)|json_encode|raw }}, notFound:{{ t('customer_ts6_update_error_not_found',locale)|json_encode|raw }} };
const ST={installed:{{ t('teamspeak.status.installation.installed',locale)|json_encode|raw }},not_installed:{{ t('teamspeak.status.installation.not_installed',locale)|json_encode|raw }},running:{{ t('teamspeak.status.runtime.running',locale)|json_encode|raw }},stopped:{{ t('teamspeak.status.runtime.stopped',locale)|json_encode|raw }},unknown:{{ t('teamspeak.status.runtime.unknown',locale)|json_encode|raw }}};
const us=(s)=>window.ts6StatusI18n?.[s]||s||'—';
const MK={customer_ts6_update_error_not_found:T.notFound,customer_ts6_update_install_failed:T.fail};
const apiMessage=(d,fb)=>MK[d?.message_key]||d?.error_code||fb;
async function loadLogs(id,row){const r=await fetch(`/ts6/${id}/updates/logs`);const d=await r.json();const last=(d.logs&&d.logs[0])?d.logs[0]:null;row.querySelector('.f-last-log').textContent=last?(last.messageKey||last.errorCode||last.status||'—'):'—'; if(last&&last.step){row.querySelector('.f-status').textContent=us(last.step);} }
async function refresh(id,row){const r=await fetch(`/ts6/${id}/updates`);const d=await r.json();row.querySelector('.f-installed').textContent=d.installed_version||'—';row.querySelector('.f-available').textContent=d.available_version||'—';row.querySelector('.f-channel').textContent=d.update_channel||'—';row.querySelector('.f-last-check').textContent=d.last_update_check_at||'—';}
for (const row of document.querySelectorAll('[data-ts6-id]')){const id=row.dataset.ts6Id; const bCheck=row.querySelector('.js-ts6-check'); const bInstall=row.querySelector('.js-ts6-install'); const msg=row.querySelector('.f-message');
refresh(id,row);loadLogs(id,row);
setInterval(()=>{refresh(id,row).catch(()=>{});loadLogs(id,row).catch(()=>{});},15000);
bCheck.onclick=async()=>{const r=await fetch(`/ts6/${id}/updates/check`,{method:'POST'});const d=await r.json();if(!r.ok){msg.textContent=apiMessage(d,T.fail);return;}row.querySelector('.f-available').textContent=d.available_version||'—';row.querySelector('.f-status').textContent=us(d.status);row.querySelector('.f-checksum-status').textContent=d.checksum?{{ t('teamspeak.update.checksum.available',locale)|json_encode|raw }}:{{ t('teamspeak.update.checksum.not_available',locale)|json_encode|raw }};row.querySelector('.f-checksum-source').textContent=(d.checksum&&d.checksum.source)||'—';const canInstall=!!d.update_available && d.status!=='running' && d.status!=='asset_not_found' && d.status!=='source_not_configured';bInstall.disabled=!canInstall;msg.textContent=d.update_available?T.updAvail:T.noUpdate;};
bInstall.onclick=async()=>{const r=await fetch(`/ts6/${id}/updates/install`,{method:'POST'});const d=await r.json();if(!r.ok){msg.textContent=apiMessage(d,T.fail);return;}msg.textContent=d.status==='running'?T.running:T.ok;await loadLogs(id,row);};
}
</script>
{% endblock %}
