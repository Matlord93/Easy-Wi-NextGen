{% extends 'customer/base.html.twig' %}

{% block title %}TS6 Token · Easy-Wi NextGen{% endblock %}

{% block content %}
    <div class="ts6-page">
        <div class="ts6-header">
            <div>
                <h1>Server Token</h1>
                <p>{{ server.name }} · SID {{ server.sid }}</p>
            </div>
            <div class="ts6-actions">
                <a class="ts6-link" href="{{ path('customer_ts6_servers_show', {id: server.id}) }}">Zurück</a>
            </div>
        </div>

        {% for message in app.flashes('success') %}
            <div class="ts6-alert ts6-alert-success">{{ message }}</div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="ts6-alert ts6-alert-error">{{ message }}</div>
        {% endfor %}

        <div class="ts6-card">
            <div class="ts6-credentials">
                <div><strong>Owner Token</strong></div>
                <div class="ts6-secret">{{ token ?? '—' }}</div>
            </div>
            <form class="ts6-form" method="post" action="{{ path('customer_ts6_servers_token_rotate', {id: server.id}) }}">
                <input type="hidden" name="_token" value="{{ csrf.rotate }}">
                <label for="ts6-server-group">Servergruppe (SGID)</label>
                <select id="ts6-server-group" name="server_group_id" data-url="{{ path('customer_ts6_servers_groups', {id: server.id}) }}">
                    <option value="6">Lade Servergruppen…</option>
                </select>
                <p class="ts6-muted">Nutze die SGID aus <code>servergrouplist</code>, z.B. 6 für Server Admin.</p>
                <button class="ts6-button" type="submit">Token rotieren</button>
            </form>
        </div>

        <div class="ts6-card">
            <div class="ts6-credentials">
                <div><strong>Token-Liste</strong></div>
                {% if tokens is empty %}
                    <div class="ts6-muted">Keine Tokens vorhanden.</div>
                {% else %}
                    <table class="ts6-table">
                        <thead>
                        <tr>
                            <th>Token</th>
                            <th>Typ</th>
                            <th>Status</th>
                            <th>Erstellt</th>
                        </tr>
                        </thead>
                        <tbody>
                        {% for entry in tokens %}
                            <tr>
                                <td class="ts6-secret">{{ entry.token }}</td>
                                <td>{{ entry.type }}</td>
                                <td>{{ entry.active ? 'Aktiv' : 'Inaktiv' }}</td>
                                <td>{{ entry.createdAt|date('Y-m-d H:i') }}</td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                {% endif %}
            </div>
        </div>
    </div>
    <script>
        (function () {
            const select = document.getElementById('ts6-server-group');
            if (!select) { return; }
            const url = select.dataset.url;
            if (!url) { return; }
            let attempts = 0;
            const maxAttempts = 6;
            const delayMs = 1500;
            const loadGroups = () => {
                fetch(url)
                    .then((response) => response.json())
                    .then((data) => {
                        if (!data) { return; }
                        if (data.status === 'pending' && attempts < maxAttempts) {
                            attempts += 1;
                            setTimeout(loadGroups, delayMs);
                            return;
                        }
                        if (data.status === 'pending' || data.status === 'error') {
                            const option = document.createElement('option');
                            option.value = '6';
                            option.textContent = `Fehler: ${data.message ?? 'Server antwortet nicht'} (${data.action_id ?? 'n/a'})`;
                            select.innerHTML = '';
                            select.appendChild(option);
                            return;
                        }
                        if (data.status !== 'ok') { return; }
                        const groups = Array.isArray(data.groups) ? data.groups : [];
                        select.innerHTML = '';
                        groups.forEach((group) => {
                            const option = document.createElement('option');
                            option.value = group.id;
                            option.textContent = `${group.name} (SGID ${group.id})`;
                            if (group.id === 6) {
                                option.selected = true;
                            }
                            select.appendChild(option);
                        });
                        if (groups.length === 0) {
                            const option = document.createElement('option');
                            option.value = '6';
                            option.textContent = 'Keine Servergruppen gefunden';
                            select.appendChild(option);
                        }
                    })
                    .catch(() => {});
            };
            loadGroups();
        })();
    </script>
{% endblock %}
