{% extends 'customer/base.html.twig' %}

{% block title %}TS6 Server · Easy-Wi NextGen{% endblock %}

{% block content %}
    {% set status = server.status|lower %}
    {% set statusClass = status in ['online', 'running', 'active'] ? 'online' : (status in ['offline', 'stopped', 'stopping'] ? 'offline' : (status == 'error' ? 'error' : 'unknown')) %}
    <div class="ts6-page" data-server-id="{{ server.id }}">
        <div class="ts6-header">
            <div>
                <h1>{{ server.name }}</h1>
                <p>SID {{ server.sid }}</p>
            </div>
            <div class="ts6-actions">
                <a class="ts6-link" href="/customer/ts6/servers">Zurück</a>
            </div>
        </div>

        {% for message in app.flashes('success') %}
            <div class="ts6-alert ts6-alert-success">{{ message }}</div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="ts6-alert ts6-alert-error">{{ message }}</div>
        {% endfor %}

        {% if status == 'error' %}
            <div class="ts6-alert ts6-alert-error ts6-error-banner">
                <strong>Serverfehler:</strong> Bitte überprüfe die Logs. Status: {{ server.status }}.
            </div>
        {% endif %}

        <div class="ts6-card ts6-server-card">
            <div class="ts6-meta" data-summary-url="/customer/ts6/servers/{{ server.id }}/summary.json">
                <div>
                    <span class="ts6-status ts6-status-{{ statusClass }}">{{ server.status }}</span>
                </div>
                <div>
                    <strong>Externe Adresse</strong>
                    <div>{{ externalHost }}:{{ server.voicePort ?? '—' }}</div>
                </div>
                <div>
                    <strong>Server ID (SID)</strong>
                    <div>{{ server.sid }}</div>
                </div>
                <div>
                    <strong>Slots</strong>
                    <div data-slots>—</div>
                </div>
            </div>
            <div class="ts6-actions">
                <form method="post" action="/customer/ts6/servers/{{ server.id }}/start">
                    <input type="hidden" name="_token" value="{{ csrf.start }}">
                    <button class="ts6-button" type="submit">Start</button>
                </form>
                <form method="post" action="/customer/ts6/servers/{{ server.id }}/stop">
                    <input type="hidden" name="_token" value="{{ csrf.stop }}">
                    <button class="ts6-button" type="submit">Stop</button>
                </form>
                <form method="post" action="/customer/ts6/servers/{{ server.id }}/restart">
                    <input type="hidden" name="_token" value="{{ csrf.restart }}">
                    <button class="ts6-button" type="submit">Neustart</button>
                </form>
                <button class="ts6-button ts6-button-secondary" type="button" data-settings-trigger>Einstellung</button>
            </div>
        </div>

        <div class="ts6-tabs">
            <button class="ts6-tab is-active" type="button" data-tab="server">Server</button>
            <button class="ts6-tab" type="button" data-tab="viewer">Live Viewer</button>
            <button class="ts6-tab" type="button" data-tab="clients">Clients</button>
            <button class="ts6-tab" type="button" data-tab="channels">Channels</button>
            <button class="ts6-tab" type="button" data-tab="permissions">Permissions</button>
            <button class="ts6-tab" type="button" data-tab="tokens">Tokens</button>
            <button class="ts6-tab" type="button" data-tab="bans">Bans</button>
            <a class="ts6-tab ts6-tab-link" href="/customer/ts6/servers/{{ server.id }}/logs">Logs</a>
            <a class="ts6-tab ts6-tab-link" href="/customer/ts6/servers/{{ server.id }}/backups">Backups</a>
        </div>

        <div class="ts6-tab-content is-active" data-tab-content="server">
            <div class="ts6-panel-grid">
                <div class="ts6-panel">
                    <h3>Server Aktionen</h3>
                    <p class="ts6-muted">Steuere deinen Server direkt.</p>
                    <div class="ts6-actions">
                        <form method="post" action="/customer/ts6/servers/{{ server.id }}/start">
                            <input type="hidden" name="_token" value="{{ csrf.start }}">
                            <button class="ts6-button" type="submit">Start</button>
                        </form>
                        <form method="post" action="/customer/ts6/servers/{{ server.id }}/stop">
                            <input type="hidden" name="_token" value="{{ csrf.stop }}">
                            <button class="ts6-button" type="submit">Stop</button>
                        </form>
                        <form method="post" action="/customer/ts6/servers/{{ server.id }}/restart">
                            <input type="hidden" name="_token" value="{{ csrf.restart }}">
                            <button class="ts6-button" type="submit">Neustart</button>
                        </form>
                    </div>
                </div>

                <div class="ts6-panel">
                    <h3>Verbindung</h3>
                    <p class="ts6-muted">Externe Adresse und Ports.</p>
                    <div class="ts6-credentials">
                        <div><strong>Adresse</strong></div>
                        <div class="ts6-secret">{{ externalHost }}:{{ server.voicePort ?? '—' }}</div>
                    </div>
                </div>

                <div class="ts6-panel">
                    <h3>Status</h3>
                    <p class="ts6-muted">Schnellstatus & Slots.</p>
                    <div class="ts6-status-row">
                        <span class="ts6-status ts6-status-{{ statusClass }}">{{ server.status }}</span>
                        <span data-slots-inline>—</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="ts6-tab-content" data-tab-content="viewer">
            <div class="ts6-viewer-grid">
                <div class="ts6-card ts6-viewer-tree">
                    <div class="ts6-section-header">
                        <h3 class="ts6-section-title">Channel Tree</h3>
                        <span class="ts6-muted" data-viewer-status>Loading…</span>
                    </div>
                    <div class="ts6-tree" data-viewer-tree>
                        <div class="ts6-spinner"></div>
                    </div>
                </div>
                <div class="ts6-card ts6-viewer-details">
                    <div class="ts6-section-header">
                        <h3 class="ts6-section-title">Client Details</h3>
                        <span class="ts6-muted" data-viewer-selected>Kein Client gewählt.</span>
                    </div>
                    <div class="ts6-viewer-actions">
                        <button class="ts6-button" type="button" disabled>Kick</button>
                        <button class="ts6-button" type="button" disabled>Ban</button>
                        <button class="ts6-button" type="button" disabled>Move</button>
                        <button class="ts6-button" type="button" disabled>Mute</button>
                        <button class="ts6-button" type="button" disabled>Deafen</button>
                    </div>
                    <div class="ts6-viewer-info" data-viewer-info>
                        <div class="ts6-muted">Wähle einen Client aus der Liste.</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="ts6-tab-content" data-tab-content="clients" data-query-url="/customer/ts6/servers/{{ server.id }}/clients.json">
            <div class="ts6-card">
                <div class="ts6-section-header">
                    <div>
                        <h3 class="ts6-section-title">Online Clients</h3>
                        <p class="ts6-muted">Aktive Nutzer mit Aktionen.</p>
                    </div>
                </div>
                <div class="ts6-data-state" data-state="loading">
                    <div class="ts6-spinner"></div>
                </div>
                <table class="ts6-table" data-table hidden>
                    <thead>
                    <tr>
                        <th>Nickname</th>
                        <th>CLID</th>
                        <th>Aktionen</th>
                    </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>

        <div class="ts6-tab-content" data-tab-content="channels" data-query-url="/customer/ts6/servers/{{ server.id }}/channels.json">
            <div class="ts6-card">
                <div class="ts6-section-header">
                    <div>
                        <h3 class="ts6-section-title">Channels</h3>
                        <p class="ts6-muted">Channel-Übersicht (CRUD + Order folgt).</p>
                    </div>
                </div>
                <div class="ts6-data-state" data-state="loading">
                    <div class="ts6-spinner"></div>
                </div>
                <table class="ts6-table" data-table hidden>
                    <thead>
                    <tr>
                        <th>Name</th>
                        <th>CID</th>
                    </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>

        <div class="ts6-tab-content" data-tab-content="permissions" data-query-url="/customer/ts6/servers/{{ server.id }}/server-groups.json">
            <div class="ts6-card">
                <div class="ts6-section-header">
                    <div>
                        <h3 class="ts6-section-title">Permissions</h3>
                        <p class="ts6-muted">Server-/Channel-Gruppen & Explorer.</p>
                    </div>
                    <div>
                        <input class="ts6-input" type="search" placeholder="Suche..." data-permission-search>
                    </div>
                </div>
                <div class="ts6-data-state" data-state="loading">
                    <div class="ts6-spinner"></div>
                </div>
                <ul class="ts6-list" data-list hidden></ul>
            </div>
        </div>

        <div class="ts6-tab-content" data-tab-content="tokens">
            <div class="ts6-card">
                <div class="ts6-section-header">
                    <div>
                        <h3 class="ts6-section-title">Token Verwaltung</h3>
                        <p class="ts6-muted">Owner Token und Token Liste.</p>
                    </div>
                </div>
                <div class="ts6-credentials">
                    <div><strong>Owner Token</strong></div>
                    <div class="ts6-secret">{{ token ?? '—' }}</div>
                </div>
                <form class="ts6-form" method="post" action="/customer/ts6/servers/{{ server.id }}/token/rotate">
                    <input type="hidden" name="_token" value="{{ csrf.rotate }}">
                    <label for="ts6-server-group">Servergruppe (SGID)</label>
                    <select id="ts6-server-group" name="server_group_id" data-url="/customer/ts6/servers/{{ server.id }}/server-groups.json">
                        <option value="6">Lade Servergruppen…</option>
                    </select>
                    <p class="ts6-muted">Nutze die SGID aus <code>servergrouplist</code>, z.B. 6 für Server Admin.</p>
                    <button class="ts6-button" type="submit">Token rotieren</button>
                </form>
                {% if tokens is empty %}
                    <div class="ts6-empty-state">Keine Tokens vorhanden.</div>
                {% else %}
                    <table class="ts6-table">
                        <thead>
                        <tr>
                            <th>Token</th>
                            <th>Typ</th>
                            <th>Status</th>
                            <th>Erstellt</th>
                        </tr>
                        </thead>
                        <tbody>
                        {% for entry in tokens %}
                            <tr>
                                <td class="ts6-secret">{{ entry.token }}</td>
                                <td>{{ entry.type }}</td>
                                <td>{{ entry.active ? 'Aktiv' : 'Inaktiv' }}</td>
                                <td>{{ entry.createdAt|date('Y-m-d H:i') }}</td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                {% endif %}
            </div>
        </div>

        <div class="ts6-tab-content" data-tab-content="bans" data-query-url="/customer/ts6/servers/{{ server.id }}/bans.json">
            <div class="ts6-card">
                <div class="ts6-section-header">
                    <div>
                        <h3 class="ts6-section-title">Bans</h3>
                        <p class="ts6-muted">Aktive Banns (ServerQuery).</p>
                    </div>
                </div>
                <div class="ts6-data-state" data-state="loading">
                    <div class="ts6-spinner"></div>
                </div>
                <ul class="ts6-list" data-list hidden></ul>
            </div>
        </div>

        <div class="ts6-drawer" data-settings-drawer hidden>
            <div class="ts6-drawer-overlay" data-settings-close></div>
            <div class="ts6-drawer-content">
                <div class="ts6-spinner"></div>
            </div>
        </div>
    </div>

    <script>
        (function () {
            const tabs = document.querySelectorAll('.ts6-tab[data-tab]');
            const contents = document.querySelectorAll('.ts6-tab-content');
            const activateTab = (name) => {
                tabs.forEach((tab) => tab.classList.toggle('is-active', tab.dataset.tab === name));
                contents.forEach((content) => content.classList.toggle('is-active', content.dataset.tabContent === name));
            };
            tabs.forEach((tab) => {
                tab.addEventListener('click', () => activateTab(tab.dataset.tab));
            });
            activateTab('server');
        })();

        (function () {
            const meta = document.querySelector('.ts6-meta[data-summary-url]');
            if (!meta) { return; }
            const slots = meta.querySelector('[data-slots]');
            const inlineSlots = document.querySelector('[data-slots-inline]');
            const url = meta.dataset.summaryUrl;
            if (!slots || !url) { return; }
            let attempts = 0;
            const maxAttempts = 6;
            const delayMs = 1500;
            const loadSummary = () => {
                fetch(url)
                    .then((response) => response.json())
                    .then((data) => {
                        if (!data) { return; }
                        if (data.status === 'pending' && attempts < maxAttempts) {
                            attempts += 1;
                            setTimeout(loadSummary, delayMs);
                            return;
                        }
                        if (data.status === 'error') {
                            slots.textContent = 'Fehler';
                            if (inlineSlots) { inlineSlots.textContent = 'Fehler'; }
                            return;
                        }
                        if (data.status !== 'ok') { return; }
                        const slotText = `${data.clients_online ?? 0}/${data.max_clients ?? 0}`;
                        slots.textContent = slotText;
                        if (inlineSlots) { inlineSlots.textContent = slotText; }
                    })
                    .catch(() => {});
            };
            loadSummary();
        })();

        (function () {
            const select = document.getElementById('ts6-server-group');
            if (!select) { return; }
            const url = select.dataset.url;
            if (!url) { return; }
            let attempts = 0;
            const maxAttempts = 6;
            const delayMs = 1500;
            const loadGroups = () => {
                fetch(url)
                    .then((response) => response.json())
                    .then((data) => {
                        if (!data) { return; }
                        if (data.status === 'pending' && attempts < maxAttempts) {
                            attempts += 1;
                            setTimeout(loadGroups, delayMs);
                            return;
                        }
                        if (data.status === 'error') {
                            const option = document.createElement('option');
                            option.value = '6';
                            option.textContent = `Fehler: ${data.message ?? 'Unbekannt'} (${data.action_id ?? 'n/a'})`;
                            select.innerHTML = '';
                            select.appendChild(option);
                            return;
                        }
                        if (data.status !== 'ok') { return; }
                        const groups = Array.isArray(data.groups) ? data.groups : [];
                        select.innerHTML = '';
                        groups.forEach((group) => {
                            const option = document.createElement('option');
                            option.value = group.id;
                            option.textContent = `${group.name} (SGID ${group.id})`;
                            if (group.id === 6) {
                                option.selected = true;
                            }
                            select.appendChild(option);
                        });
                        if (groups.length === 0) {
                            const option = document.createElement('option');
                            option.value = '6';
                            option.textContent = 'Keine Servergruppen gefunden';
                            select.appendChild(option);
                        }
                    })
                    .catch(() => {});
            };
            loadGroups();
        })();

        (function () {
            const sections = document.querySelectorAll('.ts6-tab-content[data-query-url]');
            const fetchQuery = (url, onSuccess, onError) => {
                let attempts = 0;
                const maxAttempts = 6;
                const delayMs = 1500;
                const execute = () => {
                    fetch(url)
                        .then((response) => response.json())
                        .then((data) => {
                            if (!data) { return; }
                            if (data.status === 'pending' && attempts < maxAttempts) {
                                attempts += 1;
                                setTimeout(execute, delayMs);
                                return;
                            }
                            if (data.status === 'error') {
                                onError(data.message, data.action_id);
                                return;
                            }
                            if (data.status !== 'ok') { return; }
                            onSuccess(data.payload ?? data.groups ?? {});
                        })
                        .catch(() => {
                            onError('Netzwerkfehler');
                        });
                };
                execute();
            };

            sections.forEach((section) => {
                const url = section.dataset.queryUrl;
                const state = section.querySelector('[data-state]');
                const table = section.querySelector('[data-table]');
                const list = section.querySelector('[data-list]');
                const search = section.querySelector('[data-permission-search]');
                if (!url || !state) { return; }

                const showError = (message, actionId) => {
                    state.innerHTML = '';
                    state.dataset.state = 'error';
                    const error = document.createElement('div');
                    error.className = 'ts6-error-state';
                    error.innerHTML = `<strong>Fehler:</strong> ${message ?? 'Unbekannt'}${actionId ? ` (Action ID: ${actionId})` : ''}`;
                    const retry = document.createElement('button');
                    retry.className = 'ts6-button';
                    retry.type = 'button';
                    retry.textContent = 'Retry';
                    retry.addEventListener('click', () => load());
                    state.appendChild(error);
                    state.appendChild(retry);
                };

                const showEmpty = (text) => {
                    state.innerHTML = '';
                    state.dataset.state = 'empty';
                    const empty = document.createElement('div');
                    empty.className = 'ts6-empty-state';
                    empty.textContent = text;
                    state.appendChild(empty);
                };

                const renderList = (items, formatter) => {
                    if (!list) { return; }
                    list.innerHTML = '';
                    if (!items.length) {
                        list.hidden = true;
                        showEmpty('Keine Einträge');
                        return;
                    }
                    items.forEach((item) => {
                        const li = document.createElement('li');
                        li.textContent = formatter(item);
                        list.appendChild(li);
                    });
                    list.hidden = false;
                    state.innerHTML = '';
                };

                const load = () => {
                    state.innerHTML = '<div class="ts6-spinner"></div>';
                    state.dataset.state = 'loading';
                    fetchQuery(url, (payload) => {
                        const data = payload.bans || payload.channels || payload.clients || payload.logs || payload.snapshot || payload.groups || payload;
                        if (table && Array.isArray(data)) {
                            const tbody = table.querySelector('tbody');
                            tbody.innerHTML = '';
                            if (data.length === 0) {
                                table.hidden = true;
                                showEmpty('Keine Einträge');
                                return;
                            }
                            if (section.dataset.tabContent === 'clients') {
                                data.forEach((client) => {
                                    const row = document.createElement('tr');
                                    row.innerHTML = `
                                        <td>${client.client_nickname ?? '—'}</td>
                                        <td>${client.clid ?? '—'}</td>
                                        <td><span class="ts6-muted">Actions via Query folgen</span></td>
                                    `;
                                    tbody.appendChild(row);
                                });
                            } else {
                                data.forEach((channel) => {
                                    const row = document.createElement('tr');
                                    row.innerHTML = `
                                        <td>${channel.channel_name ?? '—'}</td>
                                        <td>${channel.cid ?? '—'}</td>
                                    `;
                                    tbody.appendChild(row);
                                });
                            }
                            table.hidden = false;
                            state.innerHTML = '';
                            return;
                        }
                        if (list && Array.isArray(data)) {
                            if (section.dataset.tabContent === 'bans') {
                                renderList(data, (ban) => `${ban.name ?? ban.ip ?? 'Ban'} ${ban.ban_reason ?? ''}`.trim());
                                return;
                            }
                            if (section.dataset.tabContent === 'permissions') {
                                const entries = data.map((group) => `${group.name} (SGID ${group.id})`);
                                renderList(entries, (entry) => entry);
                                if (search) {
                                    search.addEventListener('input', (event) => {
                                        const term = event.target.value.toLowerCase();
                                        const filtered = entries.filter((entry) => entry.toLowerCase().includes(term));
                                        renderList(filtered, (entry) => entry);
                                    });
                                }
                                return;
                            }
                        }
                        showEmpty('Keine Einträge');
                    }, showError);
                };

                load();
            });
        })();

        (function () {
            const drawer = document.querySelector('[data-settings-drawer]');
            const trigger = document.querySelector('[data-settings-trigger]');
            if (!drawer || !trigger) { return; }
            const content = drawer.querySelector('.ts6-drawer-content');
            let loaded = false;

            const openDrawer = () => {
                drawer.hidden = false;
                drawer.classList.add('is-open');
                if (!loaded) {
                    content.innerHTML = '<div class="ts6-spinner"></div>';
                    fetch('/customer/ts6/servers/{{ server.id }}/settings')
                        .then((response) => response.text())
                        .then((html) => {
                            content.innerHTML = html;
                            loaded = true;
                            registerSettingsForm();
                        })
                        .catch(() => {
                            content.innerHTML = '<div class="ts6-error-state">Einstellungen konnten nicht geladen werden.</div>';
                        });
                }
            };

            const closeDrawer = () => {
                drawer.classList.remove('is-open');
                drawer.hidden = true;
            };

            const registerSettingsForm = () => {
                const form = drawer.querySelector('[data-settings-form]');
                const message = drawer.querySelector('[data-settings-message]');
                if (!form) { return; }
                form.addEventListener('submit', (event) => {
                    event.preventDefault();
                    const data = new FormData(form);
                    fetch(form.action, {
                        method: 'POST',
                        body: data,
                    })
                        .then((response) => response.json())
                        .then((payload) => {
                            if (!message) { return; }
                            message.hidden = false;
                            if (payload.status !== 'ok') {
                                message.className = 'ts6-settings-message ts6-error-state';
                                message.textContent = payload.message ?? 'Fehler beim Speichern.';
                                return;
                            }
                            message.className = 'ts6-settings-message ts6-success-state';
                            message.textContent = payload.message ?? 'Gespeichert.';
                        })
                        .catch(() => {
                            if (!message) { return; }
                            message.hidden = false;
                            message.className = 'ts6-settings-message ts6-error-state';
                            message.textContent = 'Netzwerkfehler beim Speichern.';
                        });
                });
                drawer.querySelectorAll('[data-settings-close]').forEach((button) => {
                    button.addEventListener('click', closeDrawer);
                });
            };

            trigger.addEventListener('click', openDrawer);
            drawer.querySelectorAll('[data-settings-close]').forEach((button) => {
                button.addEventListener('click', closeDrawer);
            });
        })();

        (function () {
            const tree = document.querySelector('[data-viewer-tree]');
            const status = document.querySelector('[data-viewer-status]');
            const info = document.querySelector('[data-viewer-info]');
            const selected = document.querySelector('[data-viewer-selected]');
            if (!tree || !status) { return; }
            const channelsUrl = '/customer/ts6/servers/{{ server.id }}/channels.json';
            const clientsUrl = '/customer/ts6/servers/{{ server.id }}/clients.json';
            let lastFetch = 0;
            let inFlight = false;
            let cached = { channels: [], clients: [] };

            const buildTree = () => {
                const { channels, clients } = cached;
                tree.innerHTML = '';
                if (!channels.length) {
                    tree.innerHTML = '<div class="ts6-empty-state">Keine Channels</div>';
                    return;
                }
                const byChannel = new Map();
                channels.forEach((channel) => {
                    byChannel.set(channel.cid, { channel, clients: [] });
                });
                clients.forEach((client) => {
                    const cid = client.cid;
                    if (byChannel.has(cid)) {
                        byChannel.get(cid).clients.push(client);
                    }
                });
                byChannel.forEach((entry) => {
                    const wrapper = document.createElement('div');
                    wrapper.className = 'ts6-tree-channel';
                    const title = document.createElement('div');
                    title.className = 'ts6-tree-title';
                    title.textContent = entry.channel.channel_name;
                    wrapper.appendChild(title);
                    const list = document.createElement('ul');
                    list.className = 'ts6-tree-list';
                    entry.clients.forEach((client) => {
                        const li = document.createElement('li');
                        li.textContent = client.client_nickname ?? 'Unknown';
                        li.addEventListener('click', () => {
                            selected.textContent = client.client_nickname ?? 'Client';
                            info.innerHTML = `<div><strong>CLID:</strong> ${client.clid ?? '—'}</div><div><strong>Type:</strong> ${client.client_type ?? '—'}</div>`;
                        });
                        list.appendChild(li);
                    });
                    if (!entry.clients.length) {
                        const empty = document.createElement('li');
                        empty.className = 'ts6-muted';
                        empty.textContent = 'Keine Clients';
                        list.appendChild(empty);
                    }
                    wrapper.appendChild(list);
                    tree.appendChild(wrapper);
                });
            };

            const fetchQuery = (url, setter) => {
                return new Promise((resolve, reject) => {
                    let attempts = 0;
                    const maxAttempts = 6;
                    const delayMs = 1500;
                    const execute = () => {
                        fetch(url)
                            .then((response) => response.json())
                            .then((data) => {
                                if (!data) { return; }
                                if (data.status === 'pending' && attempts < maxAttempts) {
                                    attempts += 1;
                                    setTimeout(execute, delayMs);
                                    return;
                                }
                                if (data.status === 'error') {
                                    reject(data);
                                    return;
                                }
                                if (data.status !== 'ok') { return; }
                                setter(Array.isArray(data.payload?.channels || data.payload?.clients || data.payload) ? (data.payload.channels || data.payload.clients || data.payload) : []);
                                resolve();
                            })
                            .catch(reject);
                    };
                    execute();
                });
            };

            const refreshViewer = () => {
                const now = Date.now();
                if (inFlight || now - lastFetch < 1500) { return; }
                inFlight = true;
                lastFetch = now;
                status.textContent = 'Loading…';
                Promise.all([
                    fetchQuery(channelsUrl, (data) => { cached.channels = data; }),
                    fetchQuery(clientsUrl, (data) => { cached.clients = data; }),
                ])
                    .then(() => {
                        status.textContent = 'Aktualisiert';
                        buildTree();
                    })
                    .catch((error) => {
                        status.textContent = 'Fehler';
                        tree.innerHTML = `<div class="ts6-error-state">Fehler beim Laden${error?.action_id ? ` (Action ID: ${error.action_id})` : ''}</div>`;
                    })
                    .finally(() => {
                        inFlight = false;
                    });
            };

            refreshViewer();
            setInterval(refreshViewer, 2000);
        })();
    </script>
{% endblock %}
