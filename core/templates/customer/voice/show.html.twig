</div>{# /cust-page #}

<style>
/* ── Voice Server Show – scoped styles ── */

/* Tab nav scrollbar hide */
#vs-tab-nav::-webkit-scrollbar { display:none; }

/* Tabs */
.vs-tab { display:inline-flex;align-items:center;gap:6px;padding:13px 16px;border:none;background:none;font-size:12.5px;font-weight:600;color:var(--ng-text-muted);cursor:pointer;white-space:nowrap;border-bottom:2px solid transparent;transition:color .15s,border-color .15s;flex-shrink:0; }
.vs-tab:hover { color:var(--ng-text); }
.vs-tab--active { color:var(--ng-primary);border-bottom-color:var(--ng-primary); }

/* Tab panels */
.vs-tab-panel { animation:vs-fadein .15s ease; }
.vs-tab-panel.hidden { display:none; }
@keyframes vs-fadein { from{opacity:0;transform:translateY(4px)} to{opacity:1;transform:none} }

/* Token list items */
.vs-token-item { border-radius:10px;border:1px solid var(--ng-border);background:var(--ng-surface-soft);padding:14px 16px; }
.vs-token-item__row { display:flex;align-items:flex-start;gap:10px;flex-wrap:wrap; }
.vs-token-item__code { flex:1;min-width:0;word-break:break-all;font-size:11.5px;color:var(--ng-text);background:var(--ng-surface);padding:7px 10px;border-radius:6px;font-family:monospace;display:block; }
.vs-token-item__active { padding:3px 9px;border-radius:99px;font-size:10px;font-weight:700;text-transform:uppercase; }
.vs-token-item__active--yes { background:rgba(34,197,94,.15);color:#4ade80; }
.vs-token-item__active--no  { background:var(--ng-surface);color:var(--ng-text-muted); }
.vs-token-item__meta { margin-top:6px;font-size:11px;color:var(--ng-text-muted); }

/* Log output */
.vs-log-pre { background:var(--ng-surface-soft);border:1px solid var(--ng-border);border-radius:8px;padding:14px;font-family:monospace;font-size:11.5px;color:var(--ng-text-muted);overflow-x:auto;white-space:pre-wrap;word-break:break-all;max-height:400px;overflow-y:auto; }

/* Backup progress bar */
.vs-backup-progress { margin-top:12px;display:flex;flex-direction:column;gap:4px; }
@keyframes vs-bar-slide { 0%{transform:translateX(-100%)} 100%{transform:translateX(400%)} }

/* Restore drop zone */
.vs-restore-drop { border:2px dashed var(--ng-border);border-radius:10px;padding:28px 20px;text-align:center;transition:border-color .15s,background .15s; }
.vs-restore-drop.dragover { border-color:var(--ng-primary);background:var(--ng-primary-soft); }
.vs-restore-drop.has-file { border-color:rgba(34,197,94,.4);background:rgba(34,197,94,.05); }

/* Table action cells */
.vs-td-actions { display:flex;gap:4px;flex-wrap:wrap; }

/* Info rows (used by JS-rendered content) */
.vs-info-row { display:flex;gap:8px;margin-bottom:6px;font-size:13px; }
.vs-info-row:last-child { margin-bottom:0; }
.vs-info-row__label { color:var(--ng-text-muted);font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.05em;width:64px;flex-shrink:0;padding-top:1px; }

/* Responsive KPI grid */
@media(max-width:900px) { #vs-root > div:nth-child(3) { grid-template-columns:repeat(2,1fr) !important; } }
@media(max-width:560px) { #vs-root > div:nth-child(3) { grid-template-columns:1fr !important; } }

/* Responsive overview grid */
@media(max-width:700px) { #vs-tab-overview > div { grid-template-columns:1fr !important; } }
</style>

<script>
(() => {
    const i18n = {
        stale:              {{ t('customer_voice_stale', locale)|json_encode|raw }},
        fresh:              {{ t('customer_voice_fresh', locale)|json_encode|raw }},
        timeout:            {{ t('customer_voice_timeout', locale)|json_encode|raw }},
        clientsLoading:     {{ t('customer_voice_clients_loading', locale)|json_encode|raw }},
        clientsEmpty:       {{ t('customer_voice_clients_empty', locale)|json_encode|raw }},
        channelsLoading:    {{ t('customer_voice_channels_loading', locale)|json_encode|raw }},
        channelsEmpty:      {{ t('customer_voice_channels_empty', locale)|json_encode|raw }},
        groupsLoading:      {{ t('customer_voice_groups_loading', locale)|json_encode|raw }},
        groupsEmpty:        {{ t('customer_voice_groups_empty', locale)|json_encode|raw }},
        bansLoading:        {{ t('customer_voice_bans_loading', locale)|json_encode|raw }},
        bansEmpty:          {{ t('customer_voice_bans_empty', locale)|json_encode|raw }},
        tokensLoading:      {{ t('customer_voice_tokens_loading', locale)|json_encode|raw }},
        tokensEmpty:        {{ t('customer_voice_tokens_empty', locale)|json_encode|raw }},
        logsLoading:        {{ t('customer_voice_logs_loading', locale)|json_encode|raw }},
        logsEmpty:          {{ t('customer_voice_logs_empty', locale)|json_encode|raw }},
        loadingShort:       {{ t('customer_voice_loading_short', locale)|json_encode|raw }},
        refresh:            {{ t('customer_voice_refresh', locale)|json_encode|raw }},
        copy:               {{ t('customer_voice_copy', locale)|json_encode|raw }},
        copied:             {{ t('customer_voice_copied', locale)|json_encode|raw }},
        save:               {{ t('customer_voice_save', locale)|json_encode|raw }},
        saved:              {{ t('customer_voice_saved', locale)|json_encode|raw }},
        snapshotCreated:    {{ t('customer_voice_snapshot_created', locale)|json_encode|raw }},
        noActiveToken:      {{ t('customer_voice_no_active_token', locale)|json_encode|raw }},
        tokenActive:        {{ t('customer_voice_token_active', locale)|json_encode|raw }},
        tokenRevoked:       {{ t('customer_voice_token_revoked', locale)|json_encode|raw }},
        tokenTypeLabel:     {{ t('customer_voice_token_type_label', locale)|json_encode|raw }},
        tokenCreatedLabel:  {{ t('customer_voice_token_created_label', locale)|json_encode|raw }},
        tokenRevokedLabel:  {{ t('customer_voice_token_revoked_label', locale)|json_encode|raw }},
        colName:            {{ t('customer_voice_col_name', locale)|json_encode|raw }},
        colChannel:         {{ t('customer_voice_col_channel', locale)|json_encode|raw }},
        colIdle:            {{ t('customer_voice_col_idle', locale)|json_encode|raw }},
        colCountry:         {{ t('customer_voice_col_country', locale)|json_encode|raw }},
        colType:            {{ t('customer_voice_col_type', locale)|json_encode|raw }},
        colActions:         {{ t('customer_voice_col_actions', locale)|json_encode|raw }},
        colMax:             {{ t('customer_voice_col_max', locale)|json_encode|raw }},
        colPermission:      {{ t('customer_voice_col_permission', locale)|json_encode|raw }},
        colDuration:        {{ t('customer_voice_col_duration', locale)|json_encode|raw }},
        colCreated:         {{ t('customer_voice_col_created', locale)|json_encode|raw }},
        colAction:          {{ t('customer_voice_col_action', locale)|json_encode|raw }},
        colChecked:         {{ t('customer_voice_col_checked', locale)|json_encode|raw }},
        colReason:          {{ t('customer_voice_col_reason', locale)|json_encode|raw }},
        channelDefault:     {{ t('customer_voice_channel_default', locale)|json_encode|raw }},
        channelPermanent:   {{ t('customer_voice_channel_permanent', locale)|json_encode|raw }},
        channelTemp:        {{ t('customer_voice_channel_temp', locale)|json_encode|raw }},
        permanent:          {{ t('customer_voice_permanent', locale)|json_encode|raw }},
        clientQuery:        {{ t('customer_voice_client_query', locale)|json_encode|raw }},
        clientNormal:       {{ t('customer_voice_client_normal', locale)|json_encode|raw }},
        kick:               {{ t('customer_voice_kick', locale)|json_encode|raw }},
        kickReasonPrompt:   {{ t('customer_voice_kick_reason_prompt', locale)|json_encode|raw }},
        poke:               {{ t('customer_voice_poke', locale)|json_encode|raw }},
        pokeMsgPrompt:      {{ t('customer_voice_poke_msg_prompt', locale)|json_encode|raw }},
        banFromClientReasonPrompt: {{ t('customer_voice_ban_from_client_reason_prompt', locale)|json_encode|raw }},
        banDurationPrompt:  {{ t('customer_voice_ban_duration_prompt', locale)|json_encode|raw }},
        banRemove:          {{ t('customer_voice_ban_remove', locale)|json_encode|raw }},
        banRemoveConfirm:   {{ t('customer_voice_ban_remove_confirm', locale)|json_encode|raw }},
        ban:                {{ t('customer_voice_ban_action', locale)|json_encode|raw }},
        banCriteriaRequired:{{ t('customer_voice_ban_criteria_required', locale)|json_encode|raw }},
        backupCreating:     {{ t('customer_voice_backup_creating', locale)|json_encode|raw }},
        backupWaiting:      {{ t('customer_voice_backup_waiting', locale)|json_encode|raw }},
        backupWaitingProgress: {{ t('customer_voice_backup_waiting_progress', locale)|json_encode|raw }},
        backupNoCacheKey:   {{ t('customer_voice_backup_no_cache_key', locale)|json_encode|raw }},
        backupTimeout:      {{ t('customer_voice_backup_timeout', locale)|json_encode|raw }},
        backupDownloaded:   {{ t('customer_voice_backup_downloaded', locale)|json_encode|raw }},
        restoreReady:       {{ t('customer_voice_restore_ready', locale)|json_encode|raw }},
        restoreNoFile:      {{ t('customer_voice_restore_no_file', locale)|json_encode|raw }},
        restoreConfirm:     {{ t('customer_voice_restore_confirm', locale)|json_encode|raw }},
        restoreSending:     {{ t('customer_voice_restore_sending', locale)|json_encode|raw }},
        restoreStarted:     {{ t('customer_voice_restore_started', locale)|json_encode|raw }},
        errorPrefix:        {{ t('customer_voice_error_prefix', locale)|json_encode|raw }},
        resetConfirm:       {{ t('customer_voice_reset_confirm', locale)|json_encode|raw }},
        resetStarted:       {{ t('customer_voice_reset_started', locale)|json_encode|raw }},
        resetBtn:           {{ t('customer_voice_reset', locale)|json_encode|raw }},
        snapshot:           {{ t('customer_voice_snapshot', locale)|json_encode|raw }},
    };

    const root = document.getElementById('vs-root');
    if (!root) return;
    const d = root.dataset;
    const instance = { node: { providerType: {{ instance.node.providerType|json_encode|raw }} } };

    // ── Helpers ──
    const $ = (id) => document.getElementById(id);
    const esc = (v) => String(v ?? '').replace(/[&<>"']/g, (c) => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#039;'}[c]));
    const fmtDate = (v) => v ? new Date(v).toLocaleString('de-DE') : '—';
    const fmtDuration = (secs) => {
        if (!secs) return '—';
        const h = Math.floor(secs/3600), m = Math.floor((secs%3600)/60), s = secs%60;
        return h ? `${h}h ${m}m` : m ? `${m}m ${s}s` : `${s}s`;
    };
    const showError = (msg) => { const el=$('vs-error'); if(el){el.textContent=msg;el.classList.remove('hidden');} };
    const clearError = () => { const el=$('vs-error'); if(el) el.classList.add('hidden'); };
    const showActionStatus = (msg, type='info') => {
        const el=$('vs-action-status'); if(!el) return;
        el.textContent=msg; el.classList.remove('hidden','ng-alert--danger','ng-alert--success','ng-alert--warning');
        el.classList.add(type==='error'?'ng-alert--danger':(type==='success'?'ng-alert--success':'ng-alert--warning'));
    };
    const actionLocks = new Map();
    const setGlobalBusy = (b) => ['vs-btn-probe','vs-btn-start','vs-btn-stop','vs-btn-restart','vs-btn-snapshot','vs-qa-recreate'].forEach(id=>{const el=$(id);if(el)el.disabled=b;});

    const apiFetch = async (url, opts={}) => {
        const r = await fetch(url, {headers:{'Accept':'application/json','Content-Type':'application/json'},...opts});
        const j = await r.json();
        if(!r.ok) throw new Error(j.message||j.error||`HTTP ${r.status}`);
        return j;
    };
    const pollUntilDone = async (url, ms=2200, max=15) => {
        for(let i=0;i<max;i++){
            await new Promise(r=>setTimeout(r,ms));
            const data = await apiFetch(url);
            const st = data.status||data.data?.status;
            if(st==='ok') return data;
        }
        throw new Error(i18n.timeout);
    };

    // ── Tab switching ──
    let activeTab = 'overview';
    const tabLoaded = {};

    const switchTab = (tab) => {
        activeTab = tab;
        document.querySelectorAll('.vs-tab').forEach(b=>{
            b.classList.toggle('vs-tab--active', b.dataset.tab===tab);
        });
        document.querySelectorAll('.vs-tab-panel').forEach(p=>{
            p.classList.toggle('hidden', p.id!=='vs-tab-'+tab);
        });
        if(!tabLoaded[tab]){ tabLoaded[tab]=true; loadTab(tab); }
    };

    $('vs-tab-nav')?.addEventListener('click', e=>{
        const btn = e.target.closest('[data-tab]');
        if(btn) switchTab(btn.dataset.tab);
    });

    // Refresh buttons
    document.querySelectorAll('.vs-refresh-btn[data-refresh-tab]').forEach(btn=>{
        btn.addEventListener('click', ()=>{
            const tab = btn.dataset.refreshTab;
            tabLoaded[tab] = false;
            loadTab(tab);
        });
    });

    // ── Live player count via summary endpoint ──
    const loadSummary = async () => {
        if (!d.urlSummary) return;
        for (let i = 0; i < 12; i++) {
            await new Promise(r => setTimeout(r, i === 0 ? 800 : 2500));
            try {
                const data = await apiFetch(d.urlSummary);
                if (data.status === 'ok') {
                    const online = data.clients_online ?? 0;
                    const max = data.max_clients ?? 0;
                    const kpiP = $('vs-kpi-players');
                    if (kpiP) kpiP.textContent = `${online} / ${max}`;
                    const sd = $('vs-status-details');
                    if (sd) {
                        sd.innerHTML = [
                            `<div class="vs-info-row"><span class="vs-info-row__label">Online</span><span>${esc(String(online))}</span></div>`,
                            `<div class="vs-info-row"><span class="vs-info-row__label">Max</span><span>${esc(String(max))}</span></div>`,
                        ].join('');
                    }
                    return;
                }
            } catch (_) { return; }
        }
    };

    // ── Overview ──
    const loadDetail = async () => {
        try {
            const data = await apiFetch(d.urlDetail);
            const inst   = data.instance || {};
            const connect = data.connect  || {};
            const token  = data.active_token;
            const viewer = data.viewer;

            const host = connect.host||'—';
            const port = connect.port??'';
            const addr = port ? `${host}:${port}` : host;

            // Header badges
            const sb = $('vs-status-badge');
            if(sb){
                const colors={online:'ui-badge--success',offline:'ui-badge--danger',unknown:'ui-badge--warning'};
                sb.className='ui-badge '+(colors[inst.status]||'ui-badge--warning');
                sb.textContent=inst.status||'unknown';
            }
            const pb = $('vs-probe-badge');
            if(pb){ pb.dataset.stale=inst.stale?'1':'0'; pb.innerHTML=inst.stale?`<span class="ui-badge ui-badge--warning" style="font-size:11px;">${esc(i18n.stale)}</span>`:`<span class="ui-badge ui-badge--success" style="font-size:11px;">${esc(i18n.fresh)}</span>`; }
            const ci=$('vs-connect-inline'); if(ci) ci.textContent=addr;

            // KPIs
            const kpiP=$('vs-kpi-players'); if(kpiP) kpiP.textContent=`${inst.players_online??'?'} / ${inst.players_max??'?'}`;
            const kpiS=$('vs-kpi-status');  if(kpiS) kpiS.textContent=inst.status||'—';
            const kpiH=$('vs-kpi-host');    if(kpiH) kpiH.textContent=addr;
            const kpiT=$('vs-kpi-token');
            if(kpiT) kpiT.textContent=token?token.substring(0,20)+'…':'—';

            // Connect details
            const cd=$('vs-connect-details');
            if(cd){
                const hostDisplay = host!=='—'?`<span style="font-family:monospace;">${esc(host)}</span>`:`<span style="color:var(--ng-text-muted);font-size:11px;">— Öffentlichen Host in Einstellungen konfigurieren</span>`;
                cd.innerHTML=[
                    `<div class="vs-info-row"><span class="vs-info-row__label">Host</span>${hostDisplay}</div>`,
                    port?`<div class="vs-info-row"><span class="vs-info-row__label">Port</span><span style="font-family:monospace;">${esc(String(port))}</span></div>`:'',
                    `<div class="vs-info-row"><span class="vs-info-row__label">Status</span><span>${esc(inst.status||'—')}</span></div>`,
                    inst.reason?`<div class="vs-info-row"><span class="vs-info-row__label">${esc(i18n.colReason)}</span><span style="color:#fca5a5;">${esc(inst.reason)}</span></div>`:'',
                    `<div class="vs-info-row"><span class="vs-info-row__label">${esc(i18n.colChecked)}</span><span>${esc(fmtDate(inst.checked_at))}</span></div>`,
                ].filter(Boolean).join('');
            }

            // Status details
            const sd=$('vs-status-details');
            if(sd){
                sd.innerHTML=[
                    `<div class="vs-info-row"><span class="vs-info-row__label">Online</span><span>${esc(String(inst.players_online??'?'))}</span></div>`,
                    `<div class="vs-info-row"><span class="vs-info-row__label">Max</span><span>${esc(String(inst.players_max??'?'))}</span></div>`,
                ].join('');
            }

            // Token
            const tokenEl=$('vs-active-token'), copyBtn=$('vs-copy-token');
            let tokenVal=null;
            if(tokenEl){
                if(token){
                    tokenVal=token;
                    tokenEl.innerHTML=`<code style="display:block;word-break:break-all;padding:8px;border-radius:6px;background:var(--ng-surface);font-size:11px;">${esc(token)}</code>`;
                    if(copyBtn) copyBtn.style.display='';
                } else {
                    tokenEl.innerHTML=`<span style="color:var(--ng-text-muted);">${esc(i18n.noActiveToken)}</span>`;
                    if(copyBtn) copyBtn.style.display='none';
                }
            }
            if(copyBtn&&tokenVal){
                copyBtn.onclick=()=>{ navigator.clipboard?.writeText(tokenVal).then(()=>{ copyBtn.textContent=i18n.copied; setTimeout(()=>{ copyBtn.textContent=i18n.copy; },1800); }); };
            }

            // Viewer settings prefill
            if(viewer){
                const ve=$('vs-viewer-enabled'); if(ve) ve.checked=Boolean(viewer.enabled);
                const vt=$('vs-viewer-ttl');     if(vt) vt.value=viewer.cache_ttl_ms??1500;
                const va=$('vs-viewer-allowlist'); if(va) va.value=viewer.domain_allowlist??'';
                if(viewer.public_id){
                    const vu=$('vs-viewer-url'), vv=$('vs-viewer-url-val');
                    if(vv) vv.textContent=location.origin+'/viewer/'+(instance.node?.providerType||'ts3')+'/'+viewer.public_id;
                    if(vu) vu.classList.remove('hidden');
                }
            }

            if($('vs-settings-host')&&connect.host&&connect.host!=='—'){
                $('vs-settings-host').placeholder=connect.host;
            }

            clearError();
            loadSummary();
        } catch(err){ showError(err.message); }
    };

    // ── Clients ──
    const loadClients = async () => {
        const el=$('vs-clients-list');
        if(!el) return;
        el.innerHTML=`<div style="padding:32px;text-align:center;color:var(--ng-text-muted);font-size:13px;">${esc(i18n.clientsLoading)}</div>`;
        try {
            let data = await apiFetch(`${d.urlQueryBase}/clients`);
            if((data.status||'pending')==='pending') data=await pollUntilDone(`${d.urlQueryBase}/clients`);
            const rawClients=data.data?.payload??data.payload??[];
            const rows=Array.isArray(rawClients)?rawClients:(rawClients?.clients??rawClients?.items??[]);
            if(!rows.length){ el.innerHTML=`<div style="padding:32px;text-align:center;color:var(--ng-text-muted);font-size:13px;">${esc(i18n.clientsEmpty)}</div>`; return; }
            el.innerHTML=`<table class="cust-table">
                <thead><tr>
                    <th>${esc(i18n.colName)}</th><th>${esc(i18n.colChannel)}</th><th>${esc(i18n.colIdle)}</th><th>${esc(i18n.colCountry)}</th><th>${esc(i18n.colType)}</th><th>${esc(i18n.colActions)}</th>
                </tr></thead>
                <tbody>${rows.map(r=>{
                    const clid=r.clid??r.client_id??'';
                    const nick=esc(r.client_nickname??r.nickname??clid);
                    const chan=esc(r.client_channel_id??r.cid??'—');
                    const idle=r.client_idle_time!==undefined?fmtDuration(Math.floor(r.client_idle_time/1000)):'—';
                    const country=esc(r.client_country??'—');
                    const ctype=r.client_type===1?`<span style="color:var(--ng-text-muted);font-size:10px;">${esc(i18n.clientQuery)}</span>`:`<span style="font-size:10px;color:var(--ng-primary);">${esc(i18n.clientNormal)}</span>`;
                    const actionUrlBase = `${d.urlClientsBase}/${encodeURIComponent(String(clid))}`;
                    return `<tr>
                        <td><strong>${nick}</strong></td>
                        <td style="color:var(--ng-text-muted);">${chan}</td>
                        <td style="color:var(--ng-text-muted);">${idle}</td>
                        <td style="color:var(--ng-text-muted);">${country}</td>
                        <td>${ctype}</td>
                        <td><div class="vs-td-actions">
                            <button type="button" class="ui-button ui-button--ghost ui-button--sm vs-kick-btn" data-voice-client-action="kick" data-client-id="${esc(String(clid))}" data-clid="${esc(String(clid))}" data-nick="${nick}" data-action-url="${esc(actionUrlBase)}/kick">${esc(i18n.kick)}</button>
                            <button type="button" class="ui-button ui-button--ghost ui-button--sm vs-poke-btn" data-voice-client-action="poke" data-client-id="${esc(String(clid))}" data-clid="${esc(String(clid))}" data-nick="${nick}" data-action-url="${esc(actionUrlBase)}/poke">${esc(i18n.poke)}</button>
                            <button type="button" class="ui-button ui-button--danger ui-button--sm vs-ban-from-client-btn" data-voice-client-action="ban" data-client-id="${esc(String(clid))}" data-clid="${esc(String(clid))}" data-nick="${nick}" data-action-url="${esc(actionUrlBase)}/ban">${esc(i18n.ban)}</button>
                        </div></td>
                    </tr>`;
                }).join('')}</tbody>
            </table>`;
        } catch(err){ el.innerHTML=`<div style="padding:32px;text-align:center;color:#f87171;font-size:13px;">${esc(err.message)}</div>`; }
    };

    // ── Channels ──
    const loadChannels = async () => {
        const el=$('vs-channels-list');
        if(!el) return;
        el.innerHTML=`<div style="padding:32px;text-align:center;color:var(--ng-text-muted);font-size:13px;">${esc(i18n.channelsLoading)}</div>`;
        try {
            let data = await apiFetch(`${d.urlQueryBase}/channels`);
            if((data.status||'pending')==='pending') data=await pollUntilDone(`${d.urlQueryBase}/channels`);
            const rawChannels=data.data?.payload??data.payload??[];
            const rows=Array.isArray(rawChannels)?rawChannels:(rawChannels?.channels??rawChannels?.items??[]);
            if(!rows.length){ el.innerHTML=`<div style="padding:32px;text-align:center;color:var(--ng-text-muted);font-size:13px;">${esc(i18n.channelsEmpty)}</div>`; return; }
            el.innerHTML=`<table class="cust-table">
                <thead><tr>
                    <th>CID</th><th>${esc(i18n.colName)}</th><th>Clients</th><th>${esc(i18n.colMax)}</th><th>${esc(i18n.colType)}</th>
                </tr></thead>
                <tbody>${rows.map(r=>{
                    const cid=esc(String(r.cid??r.channel_id??''));
                    const name=esc(r.channel_name??r.name??'—');
                    const clients=esc(String(r.total_clients??r.clients??0));
                    const max=r.channel_maxclients!==-1?esc(String(r.channel_maxclients??'∞')):'∞';
                    const flag=r.channel_flag_default==='1'?`<span style="font-size:10px;color:var(--ng-primary);">${esc(i18n.channelDefault)}</span>`:
                               r.channel_flag_permanent==='1'?`<span style="font-size:10px;color:var(--ng-text-muted);">${esc(i18n.channelPermanent)}</span>`:
                               `<span style="font-size:10px;color:var(--ng-text-muted);">${esc(i18n.channelTemp)}</span>`;
                    return `<tr>
                        <td style="color:var(--ng-text-muted);font-family:monospace;">${cid}</td>
                        <td><strong>${name}</strong></td>
                        <td style="color:var(--ng-text-muted);">${clients}</td>
                        <td style="color:var(--ng-text-muted);">${max}</td>
                        <td>${flag}</td>
                    </tr>`;
                }).join('')}</tbody>
            </table>`;
        } catch(err){ el.innerHTML=`<div style="padding:32px;text-align:center;color:#f87171;font-size:13px;">${esc(err.message)}</div>`; }
    };

    // ── Groups – only type=1 (regular), hide type=0 (template) & type=2 (query) ──
    const loadGroups = async () => {
        const el=$('vs-groups-list');
        if(!el) return;
        el.innerHTML=`<div style="padding:32px;text-align:center;color:var(--ng-text-muted);font-size:13px;">${esc(i18n.groupsLoading)}</div>`;
        try {
            let data = await apiFetch(d.urlGroups);
            if((data.status||'pending')==='pending') data=await pollUntilDone(d.urlGroups);
            const allGroups = data.data?.groups||data.groups||[];
            const TEMPLATE_GROUP_IDS = new Set([3, 4, 5]);
            const groups = allGroups.filter(g => {
                const gid = parseInt(String(g.id??g.sgid??''), 10);
                if(TEMPLATE_GROUP_IDS.has(gid)) return false;
                const tRaw = g.type??g.sgtype??g.groupType??g.group_type;
                if(tRaw!==undefined&&tRaw!==null){
                    const t = parseInt(String(tRaw), 10);
                    return t === 1;
                }
                // type field missing: filter by name pattern for known query/template groups
                const name = String(g.name??'').toLowerCase();
                return !name.includes('query') && !name.includes('template') && !name.endsWith(' template');
            });

            // Also populate token group select
            const sel=$('vs-token-group');
            if(sel&&groups.length){
                const cur=sel.value;
                sel.innerHTML=groups.map(g=>{
                    const gid=String(g.id??g.sgid??'');
                    return `<option value="${esc(gid)}"${gid===cur?' selected':''}>${esc(g.name??gid)} (${esc(gid)})</option>`;
                }).join('');
            }

            if(!groups.length){ el.innerHTML=`<div style="padding:32px;text-align:center;color:var(--ng-text-muted);font-size:13px;">${esc(i18n.groupsEmpty)}</div>`; return; }
            el.innerHTML=`<table class="cust-table">
                <thead><tr>
                    <th>ID</th><th>${esc(i18n.colName)}</th><th>${esc(i18n.colPermission)}</th>
                </tr></thead>
                <tbody>${groups.map(g=>{
                    const gid=esc(String(g.id??g.sgid??''));
                    const name=esc(g.name??'');
                    const perm=esc(String(g.n_member_addp??'—'));
                    return `<tr>
                        <td style="color:var(--ng-text-muted);font-family:monospace;">${gid}</td>
                        <td><strong>${name}</strong></td>
                        <td style="color:var(--ng-text-muted);">${perm}</td>
                    </tr>`;
                }).join('')}</tbody>
            </table>`;
        } catch(err){ el.innerHTML=`<div style="padding:32px;text-align:center;color:#f87171;font-size:13px;">${esc(err.message)}</div>`; }
    };

    // ── Bans ──
    const loadBans = async () => {
        const el=$('vs-bans-list');
        if(!el) return;
        el.innerHTML=`<div style="padding:32px;text-align:center;color:var(--ng-text-muted);font-size:13px;">${esc(i18n.bansLoading)}</div>`;
        try {
            let data = await apiFetch(`${d.urlQueryBase}/bans`);
            if((data.status||'pending')==='pending') data=await pollUntilDone(`${d.urlQueryBase}/bans`);
            const rows=data.data?.payload||data.payload||[];
            if(!rows.length){ el.innerHTML=`<div style="padding:32px;text-align:center;color:var(--ng-text-muted);font-size:13px;">${esc(i18n.bansEmpty)}</div>`; return; }
            el.innerHTML=`<table class="cust-table">
                <thead><tr>
                    <th>IP</th><th>${esc(i18n.colName)}</th><th>${esc(i18n.colReason)}</th><th>${esc(i18n.colDuration)}</th><th>${esc(i18n.colCreated)}</th><th>${esc(i18n.colAction)}</th>
                </tr></thead>
                <tbody>${rows.map(r=>{
                    const banid=r.banId??r.banid??r.ban_id??r.id??'';
                    const missingBanId = String(banid).trim()==='';
                    return `<tr>
                        <td style="font-family:monospace;">${esc(r.ip??'—')}</td>
                        <td>${esc(r.name??'—')}</td>
                        <td style="color:var(--ng-text-muted);">${esc(r.banreason??r.reason??'—')}</td>
                        <td style="color:var(--ng-text-muted);">${r.duration?fmtDuration(r.duration):esc(i18n.permanent)}</td>
                        <td style="color:var(--ng-text-muted);">${esc(fmtDate(r.created??r.invoketime_utc))}</td>
                        <td><button type="button" class="ui-button ui-button--danger ui-button--sm vs-ban-remove-btn" data-voice-ban-action="unban" data-ban-id="${esc(String(banid))}" data-action-url="${esc(d.urlBans)}/${esc(String(banid))}/remove" ${missingBanId ? 'disabled title="Ban-ID fehlt, Eintrag kann nicht entfernt werden."' : ''}>${esc(i18n.banRemove)}</button></td>
                    </tr>`;
                }).join('')}</tbody>
            </table>`;
        } catch(err){ el.innerHTML=`<div style="padding:32px;text-align:center;color:#f87171;font-size:13px;">${esc(err.message)}</div>`; }
    };

    // ── Tokens ──
    const loadTokens = async () => {
        const el=$('vs-tokens-list');
        if(!el) return;
        el.innerHTML=`<div style="padding:32px;text-align:center;color:var(--ng-text-muted);font-size:13px;">${esc(i18n.tokensLoading)}</div>`;
        try {
            const data=await apiFetch(d.urlTokens);
            const tokens=data.tokens||[];
            if(!tokens.length){ el.innerHTML=`<div style="padding:32px;text-align:center;color:var(--ng-text-muted);font-size:13px;">${esc(i18n.tokensEmpty)}</div>`; return; }
            el.innerHTML=tokens.map(t=>`
                <div class="vs-token-item">
                    <div class="vs-token-item__row">
                        <code class="vs-token-item__code">${esc(t.token)}</code>
                        <span class="vs-token-item__active ${t.active?'vs-token-item__active--yes':'vs-token-item__active--no'}">${t.active?esc(i18n.tokenActive):esc(i18n.tokenRevoked)}</span>
                    </div>
                    <div class="vs-token-item__meta">${esc(i18n.tokenTypeLabel)} ${esc(t.type)} · ${esc(i18n.tokenCreatedLabel)} ${esc(fmtDate(t.created_at))}${t.revoked_at?' · '+esc(i18n.tokenRevokedLabel)+' '+esc(fmtDate(t.revoked_at)):''}</div>
                </div>
            `).join('');
        } catch(err){ el.innerHTML=`<div style="padding:32px;text-align:center;color:#f87171;font-size:13px;">${esc(err.message)}</div>`; }
