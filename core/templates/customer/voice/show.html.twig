{% extends 'customer/base.html.twig' %}

{% block content %}
{% set locale = page_locale() %}
<div id="vs-root"
    data-url-detail="{{ urlDetail }}"
    data-url-probe="{{ urlProbe }}"
    data-url-actions="{{ urlActions }}"
    data-url-tokens="{{ urlTokens }}"
    data-url-tokens-rotate="{{ urlTokensRotate }}"
    data-url-summary="{{ urlSummary }}"
    data-url-groups="{{ urlGroups }}"
    data-url-query-base="{{ urlQueryBase }}"
    data-url-settings="{{ urlSettings }}"
    data-url-viewer="{{ urlViewer }}"
    data-url-recreate="{{ urlRecreate }}"
    data-url-snapshot="{{ urlSnapshot }}"
    data-url-snapshot-poll="{{ urlSnapshotPoll }}"
    data-url-snapshot-restore="{{ urlSnapshotRestore }}"
    data-url-clients-base="{{ urlClientsBase }}"
    data-url-bans="{{ urlBans }}"
    data-url-list="{{ urlList }}"
    class="cust-page">

{# ── Back + Header ── #}
<div style="display:flex;flex-wrap:wrap;align-items:flex-start;justify-content:space-between;gap:14px;padding:18px 0 4px;">
    <div style="display:flex;flex-direction:column;gap:6px;">
        <a href="{{ urlList }}" style="display:inline-flex;align-items:center;gap:5px;font-size:12px;color:var(--ng-text-muted);text-decoration:none;margin-bottom:4px;">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
            {{ t('customer_voice_back', locale) }}
        </a>
        <div>
            <div style="display:flex;flex-wrap:wrap;align-items:center;gap:6px;margin-bottom:4px;">
                <span id="vs-provider-badge" style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;padding:3px 9px;border-radius:99px;background:rgba(99,102,241,0.15);color:#818cf8;">{{ instance.node.providerType|upper }}</span>
                <span id="vs-status-badge" class="ui-badge ui-badge--warning">—</span>
                <span id="vs-probe-badge"></span>
            </div>
            <h1 style="margin:0;font-size:22px;font-weight:800;color:var(--ng-text);letter-spacing:-.02em;">{{ instance.name }}</h1>
            <div style="font-size:12px;color:var(--ng-text-muted);font-family:monospace;margin-top:2px;" id="vs-connect-inline">—</div>
        </div>
    </div>
    <div style="display:flex;flex-wrap:wrap;gap:6px;align-items:center;">
        <button type="button" id="vs-btn-start"   class="ui-button ui-button--primary ui-button--sm">▶ {{ t('customer_voice_start', locale) }}</button>
        <button type="button" id="vs-btn-stop"    class="ui-button ui-button--danger  ui-button--sm">■ {{ t('customer_voice_stop', locale) }}</button>
        <button type="button" id="vs-btn-restart" class="ui-button ui-button--ghost   ui-button--sm">↺ {{ t('customer_voice_restart', locale) }}</button>
        <div style="display:flex;gap:6px;">
            <button type="button" id="vs-btn-probe"    class="ui-button ui-button--ghost ui-button--sm">{{ t('customer_voice_probe', locale) }}</button>
            <button type="button" id="vs-btn-snapshot" class="ui-button ui-button--ghost ui-button--sm">{{ t('customer_voice_snapshot', locale) }}</button>
        </div>
    </div>
</div>

{# Error bar #}
<div id="vs-error" class="ng-alert ng-alert--danger hidden"></div>
<div id="vs-action-status" class="ng-alert hidden" style="margin-top:8px;"></div>

{# ── KPI Strip ── #}
<div style="display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:10px;">
    <div class="cust-panel" style="display:flex;align-items:center;gap:12px;padding:14px 16px;">
        <div style="width:36px;height:36px;border-radius:9px;display:flex;align-items:center;justify-content:center;flex-shrink:0;background:rgba(100,115,255,.15);color:#818cf8;">
            <svg width="16" height="16" viewBox="0 0 20 20" fill="currentColor"><path d="M9 6a3 3 0 1 1 6 0 3 3 0 0 1-6 0zm-7 9a7 7 0 0 1 14 0H2z"/></svg>
        </div>
        <div>
            <div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--ng-text-muted);margin-bottom:2px;">{{ t('customer_voice_col_players', locale) }}</div>
            <div style="font-size:17px;font-weight:800;color:var(--ng-text);" id="vs-kpi-players">—</div>
        </div>
    </div>
    <div class="cust-panel" style="display:flex;align-items:center;gap:12px;padding:14px 16px;">
        <div style="width:36px;height:36px;border-radius:9px;display:flex;align-items:center;justify-content:center;flex-shrink:0;background:rgba(34,197,94,.12);color:#4ade80;">
            <svg width="16" height="16" viewBox="0 0 20 20" fill="currentColor"><circle cx="10" cy="10" r="4"/></svg>
        </div>
        <div>
            <div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--ng-text-muted);margin-bottom:2px;">{{ t('customer_voice_col_status', locale) }}</div>
            <div style="font-size:17px;font-weight:800;color:var(--ng-text);" id="vs-kpi-status">—</div>
        </div>
    </div>
    <div class="cust-panel" style="display:flex;align-items:center;gap:12px;padding:14px 16px;">
        <div style="width:36px;height:36px;border-radius:9px;display:flex;align-items:center;justify-content:center;flex-shrink:0;background:rgba(56,189,248,.12);color:#38bdf8;">
            <svg width="16" height="16" viewBox="0 0 20 20" fill="currentColor"><path d="M2 5a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v2a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5zm0 8a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v2a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2v-2z"/></svg>
        </div>
        <div>
            <div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--ng-text-muted);margin-bottom:2px;">{{ t('customer_voice_kpi_address', locale) }}</div>
            <div style="font-size:12px;font-weight:800;color:var(--ng-text);font-family:monospace;" id="vs-kpi-host">—</div>
        </div>
    </div>
    <div class="cust-panel" style="display:flex;align-items:center;gap:12px;padding:14px 16px;">
        <div style="width:36px;height:36px;border-radius:9px;display:flex;align-items:center;justify-content:center;flex-shrink:0;background:rgba(245,158,11,.12);color:#fbbf24;">
            <svg width="16" height="16" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M18 8a6 6 0 01-7.743 5.743L10 14l-1 1-1 1H6v2H2v-4l4.257-4.257A6 6 0 1118 8zm-6-4a1 1 0 100 2 2 2 0 012 2 1 1 0 102 0 4 4 0 00-4-4z" clip-rule="evenodd"/></svg>
        </div>
        <div>
            <div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--ng-text-muted);margin-bottom:2px;">{{ t('customer_voice_active_token', locale) }}</div>
            <div style="font-size:10px;font-weight:800;color:var(--ng-text);font-family:monospace;max-width:120px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" id="vs-kpi-token">—</div>
        </div>
    </div>
</div>

{# ── Main Panel with Tabs ── #}
<div class="cust-panel" style="overflow:hidden;">

    {# Tab navigation #}
    <div id="vs-tab-nav" role="tablist" style="display:flex;border-bottom:1px solid var(--ng-border);overflow-x:auto;scrollbar-width:none;">
        <button type="button" class="vs-tab vs-tab--active" data-tab="overview" role="tab">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
            {{ t('customer_voice_tab_overview', locale) }}
        </button>
        <button type="button" class="vs-tab" data-tab="clients" role="tab">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            {{ t('customer_voice_tab_clients', locale) }}
        </button>
        <button type="button" class="vs-tab" data-tab="channels" role="tab">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M7 20l4-16m2 16l4-16M6 9h14M4 15h14"/></svg>
            {{ t('customer_voice_tab_channels', locale) }}
        </button>
        <button type="button" class="vs-tab" data-tab="groups" role="tab">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
            {{ t('customer_voice_tab_groups', locale) }}
        </button>
        <button type="button" class="vs-tab" data-tab="bans" role="tab">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"/></svg>
            {{ t('customer_voice_tab_bans', locale) }}
        </button>
        <button type="button" class="vs-tab" data-tab="tokens" role="tab">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/></svg>
            {{ t('customer_voice_tab_tokens', locale) }}
        </button>
        <button type="button" class="vs-tab" data-tab="backup" role="tab">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
            {{ t('customer_voice_tab_backup', locale) }}
        </button>
        <button type="button" class="vs-tab" data-tab="logs" role="tab">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
            {{ t('customer_voice_tab_logs', locale) }}
        </button>
        <button type="button" class="vs-tab" data-tab="viewer" role="tab">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
            {{ t('customer_voice_tab_viewer', locale) }}
        </button>
        <button type="button" class="vs-tab" data-tab="settings" role="tab">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            {{ t('customer_voice_tab_settings', locale) }}
        </button>
    </div>

    {# ── Overview Tab ── #}
    <div id="vs-tab-overview" class="vs-tab-panel" role="tabpanel">
        <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:12px;padding:20px;">
            <div class="cust-panel" style="padding:16px;">
                <div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--ng-text-muted);margin-bottom:10px;">{{ t('customer_voice_connect_info', locale) }}</div>
                <div id="vs-connect-details" style="font-size:13px;color:var(--ng-text);">
                    <div style="color:var(--ng-text-muted);">{{ t('customer_voice_loading_short', locale) }}</div>
                </div>
            </div>
            <div class="cust-panel" style="padding:16px;">
                <div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--ng-text-muted);margin-bottom:10px;">{{ t('customer_voice_active_token', locale) }}</div>
                <div id="vs-active-token" style="font-size:13px;color:var(--ng-text);">
                    <span style="color:var(--ng-text-muted);">—</span>
                </div>
                <button type="button" id="vs-copy-token" class="ui-button ui-button--ghost ui-button--sm" style="margin-top:8px;display:none;">
                    <svg width="12" height="12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
                    {{ t('customer_voice_copy', locale) }}
                </button>
            </div>
            <div class="cust-panel" style="padding:16px;">
                <div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--ng-text-muted);margin-bottom:10px;">{{ t('customer_voice_block_status', locale) }}</div>
                <div id="vs-status-details" style="font-size:13px;color:var(--ng-text);">
                    <div style="color:var(--ng-text-muted);">{{ t('customer_voice_loading_short', locale) }}</div>
                </div>
            </div>
            <div class="cust-panel" style="padding:16px;">
                <div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--ng-text-muted);margin-bottom:10px;">{{ t('customer_voice_quick_actions', locale) }}</div>
                <div style="font-size:13px;color:var(--ng-text);">
                    <div style="display:flex;flex-direction:column;gap:8px;">
                        <button type="button" id="vs-qa-recreate" class="ui-button ui-button--danger ui-button--sm" style="width:100%;">
                            {{ t('customer_voice_reset', locale) }}
                        </button>
                        <p style="color:var(--ng-text-muted);font-size:11px;margin:4px 0 0;">{{ t('customer_voice_reset_hint', locale) }}</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# ── Clients Tab ── #}
    <div id="vs-tab-clients" class="vs-tab-panel hidden" role="tabpanel">
        <div style="display:flex;align-items:center;justify-content:space-between;gap:12px;padding:16px 20px;border-bottom:1px solid var(--ng-border);">
            <h3 style="margin:0;font-size:14px;font-weight:700;color:var(--ng-text);">{{ t('customer_voice_clients_heading', locale) }}</h3>
            <button type="button" class="ui-button ui-button--ghost ui-button--sm vs-refresh-btn" data-refresh-tab="clients">
                <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
                {{ t('customer_voice_refresh', locale) }}
            </button>
        </div>
        <div id="vs-clients-list" class="cust-ws-table-wrap">
            <div style="padding:32px;text-align:center;color:var(--ng-text-muted);font-size:13px;">{{ t('customer_voice_clients_loading', locale) }}</div>
        </div>
    </div>

    {# ── Channels Tab ── #}
    <div id="vs-tab-channels" class="vs-tab-panel hidden" role="tabpanel">
        <div style="display:flex;align-items:center;justify-content:space-between;gap:12px;padding:16px 20px;border-bottom:1px solid var(--ng-border);">
            <h3 style="margin:0;font-size:14px;font-weight:700;color:var(--ng-text);">{{ t('customer_voice_channels_heading', locale) }}</h3>
            <button type="button" class="ui-button ui-button--ghost ui-button--sm vs-refresh-btn" data-refresh-tab="channels">
                <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
                {{ t('customer_voice_refresh', locale) }}
            </button>
        </div>
        <div id="vs-channels-list" class="cust-ws-table-wrap">
            <div style="padding:32px;text-align:center;color:var(--ng-text-muted);font-size:13px;">{{ t('customer_voice_channels_loading', locale) }}</div>
        </div>
    </div>

    {# ── Groups Tab ── #}
    <div id="vs-tab-groups" class="vs-tab-panel hidden" role="tabpanel">
        <div style="display:flex;align-items:center;justify-content:space-between;gap:12px;padding:16px 20px;border-bottom:1px solid var(--ng-border);">
            <h3 style="margin:0;font-size:14px;font-weight:700;color:var(--ng-text);">{{ t('customer_voice_groups_heading', locale) }}</h3>
            <button type="button" class="ui-button ui-button--ghost ui-button--sm vs-refresh-btn" data-refresh-tab="groups">
                <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
                {{ t('customer_voice_refresh', locale) }}
            </button>
        </div>
        <p style="color:var(--ng-text-muted);font-size:12px;padding:0 20px 12px;">{{ t('customer_voice_groups_note', locale) }}</p>
        <div id="vs-groups-list" class="cust-ws-table-wrap">
            <div style="padding:32px;text-align:center;color:var(--ng-text-muted);font-size:13px;">{{ t('customer_voice_groups_loading', locale) }}</div>
        </div>
    </div>

    {# ── Bans Tab ── #}
    <div id="vs-tab-bans" class="vs-tab-panel hidden" role="tabpanel">
        <div style="display:flex;align-items:center;justify-content:space-between;gap:12px;padding:16px 20px;border-bottom:1px solid var(--ng-border);">
            <h3 style="margin:0;font-size:14px;font-weight:700;color:var(--ng-text);">{{ t('customer_voice_bans_heading', locale) }}</h3>
            <button type="button" class="ui-button ui-button--ghost ui-button--sm vs-refresh-btn" data-refresh-tab="bans">
                <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
                {{ t('customer_voice_refresh', locale) }}
            </button>
        </div>

        {# Add ban form #}
        <div style="margin:20px 20px 20px;">
            <div class="cust-panel" style="padding:14px 16px;">
                <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--ng-text-muted);margin-bottom:12px;">{{ t('customer_voice_ban_add', locale) }}</div>
                <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:10px;">
                    <div class="form-field">
                        <label class="form-label">{{ t('customer_voice_ban_ip', locale) }}</label>
                        <input type="text" id="vs-ban-ip" placeholder="1.2.3.4" class="form-input" style="font-family:monospace;">
                    </div>
                    <div class="form-field">
                        <label class="form-label">{{ t('customer_voice_ban_uid_label', locale) }}</label>
                        <input type="text" id="vs-ban-uid" placeholder="{{ t('customer_voice_ban_uid_placeholder', locale) }}" class="form-input" style="font-family:monospace;">
                    </div>
                    <div class="form-field">
                        <label class="form-label">{{ t('customer_voice_ban_name', locale) }}</label>
                        <input type="text" id="vs-ban-name" placeholder="{{ t('customer_voice_ban_name_placeholder', locale) }}" class="form-input">
                    </div>
                    <div class="form-field">
                        <label class="form-label">{{ t('customer_voice_ban_duration', locale) }}</label>
                        <input type="number" id="vs-ban-time" placeholder="0" min="0" class="form-input">
                    </div>
                    <div class="form-field" style="flex:2;">
                        <label class="form-label">{{ t('customer_voice_ban_reason', locale) }}</label>
                        <input type="text" id="vs-ban-reason" placeholder="{{ t('customer_voice_ban_reason', locale) }}" class="form-input">
                    </div>
                </div>
                <div style="margin-top:10px;">
