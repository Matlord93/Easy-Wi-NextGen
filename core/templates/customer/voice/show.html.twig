            el.innerHTML=`<pre class="vs-log-pre">${text}</pre>`;
        } catch(err){ el.innerHTML=`<div style="padding:32px;text-align:center;color:#f87171;font-size:13px;">${esc(err.message)}</div>`; }
    };

    // ── Tab loader dispatch ──
    const loadTab = (tab) => {
        if(tab==='overview')  { loadDetail();  return; }
        if(tab==='clients')   { loadClients(); return; }
        if(tab==='channels')  { loadChannels();return; }
        if(tab==='groups')    { loadGroups();  return; }
        if(tab==='bans')      { loadBans();    return; }
        if(tab==='tokens')    { loadTokens();  return; }
        if(tab==='logs')      { loadLogs();    return; }
    };

    // ── Client actions (event delegation on clients list) ──
    $('vs-clients-list')?.addEventListener('click', async e=>{
        console.log('[voice-client-action] click', e.target);
        const lockAction = (action, clid) => {
            const key = `voice-client-action:${d.serverType}:${d.serverId}:${clid}:${action}`;
            const until = actionLocks.get(key) || 0;
            if (until > Date.now()) return null;
            actionLocks.set(key, Date.now() + 10000);
            return key;
        };
        const button=e.target.closest('[data-voice-client-action]');
        if(!button) return;
        const action=button.dataset.voiceClientAction||'';
        const url=(button.dataset.actionUrl||'').trim();
        const clid=parseInt(button.dataset.clientId||button.dataset.clid||'0',10);
        console.log('[voice-client-action] action', action);
        console.log('[voice-client-action] url', url);
        console.log('[voice-client-action] clid', clid);
        if(!url){ showError('Aktion fehlgeschlagen: Keine Action-URL vorhanden.'); return; }
        if(!clid){ showError('Aktion fehlgeschlagen: Ungültige Client-ID.'); return; }

        const kickBtn = action === 'kick' ? button : null;
        if(kickBtn){
            const nick=kickBtn.dataset.nick;
            const reason=prompt(i18n.kickReasonPrompt.replace('{nick}',nick),'')??null;
            if(reason===null) return;
            const actionKey = lockAction('kick', clid); if(!actionKey){ showActionStatus('Aktion läuft bereits.', 'info'); return; }
            kickBtn.disabled=true;
            showActionStatus('Kick wird ausgeführt...', 'info');
            try{
                console.log('[voice-client-action] sending request');
                const res = await apiFetch(url,{method:'POST',body:JSON.stringify({reason})});
                if ((res.status||'').toLowerCase() === 'failed') throw new Error(res.message||'Kick fehlgeschlagen.');
                showActionStatus(res.message||'Kick wurde gestartet.', 'success');
                tabLoaded['clients']=false; await loadClients();
                showActionStatus('Client wurde gekickt.', 'success');
            }catch(err){showError(err.message);}
            finally{ kickBtn.disabled=false; actionLocks.delete(actionKey); }
            return;
        }
        const pokeBtn = action === 'poke' ? button : null;
        if(pokeBtn){
            const nick=pokeBtn.dataset.nick;
            const message=prompt(i18n.pokeMsgPrompt.replace('{nick}',nick),'');
            if(!message||!message.trim()){ showError('Poke-Nachricht darf nicht leer sein.'); return; }
            const actionKey = lockAction('poke', clid); if(!actionKey){ showActionStatus('Aktion läuft bereits.', 'info'); return; }
            pokeBtn.disabled=true;
            showActionStatus('Poke wird gesendet...', 'info');
            try{
                console.log('[voice-client-action] sending request');
                const res = await apiFetch(url,{method:'POST',body:JSON.stringify({message})});
                if ((res.status||'').toLowerCase() === 'failed') throw new Error(res.message||'Poke fehlgeschlagen.');
                showActionStatus('Poke wurde gesendet.', 'success');
            }
            catch(err){showError(err.message);}
            finally{ pokeBtn.disabled=false; actionLocks.delete(actionKey); }
            return;
        }
        const banBtn = action === 'ban' ? button : null;
        if(banBtn){
            const nick=banBtn.dataset.nick;
            if(!confirm('Client wirklich bannen?')) return;
            const reason=prompt(i18n.banFromClientReasonPrompt.replace('{nick}',nick),'Banned via panel')??null;
            if(reason===null) return;
            const durationStr=prompt(i18n.banDurationPrompt,'0');
            if(durationStr===null) return;
            const actionKey = lockAction('ban', clid); if(!actionKey){ showActionStatus('Aktion läuft bereits.', 'info'); return; }
            banBtn.disabled=true;
            showActionStatus('Ban wird ausgeführt...', 'info');
            try{
                console.log('[voice-client-action] sending request');
                const res = await apiFetch(url,{method:'POST',body:JSON.stringify({reason,duration:parseInt(durationStr,10)||0})});
                if ((res.status||'').toLowerCase() === 'failed') throw new Error(res.message||'Ban fehlgeschlagen.');
                tabLoaded['clients']=false; await loadClients();
                tabLoaded['bans']=false; await loadBans();
                showActionStatus('Client wurde gebannt.', 'success');
            }catch(err){showError(err.message);}
            finally{ banBtn.disabled=false; actionLocks.delete(actionKey); }
        }
    });

    // ── Ban remove (event delegation on bans list) ──
    $('vs-bans-list')?.addEventListener('click', async event=>{
        console.log('[voice-ban-action] click', event.target);
        const removeBtn=event.target.closest('[data-voice-ban-action]');
        if(!removeBtn) return;

        const action=(removeBtn.dataset.voiceBanAction||'').trim().toLowerCase();
        const banIdRaw=(removeBtn.dataset.banId||removeBtn.dataset.banid||'').trim();
        const banId=parseInt(banIdRaw,10);
        const url=(removeBtn.dataset.actionUrl||'').trim();
        console.log('[voice-ban-action] action', action);
        console.log('[voice-ban-action] banId', banIdRaw);
        console.log('[voice-ban-action] url', url);
        if(action!=='unban') return;
        if(!banIdRaw || Number.isNaN(banId) || banId<=0){ showError('Ban-ID fehlt, Eintrag kann nicht entfernt werden.'); return; }
        if(!url){ showError('Entbannen fehlgeschlagen: Keine Action-URL vorhanden.'); return; }
        if(!confirm(i18n.banRemoveConfirm.replace('{id}',banIdRaw))) return;

        const lockKey=`voice-ban-action:${d.serverType}:${d.serverId}:${banId}:delete`;
        const lockUntil=actionLocks.get(lockKey)||0;
        if(lockUntil>Date.now()){ showActionStatus('Aktion läuft bereits.', 'info'); return; }
        actionLocks.set(lockKey, Date.now()+10000);
        removeBtn.disabled=true;
        showActionStatus('Ban wird entfernt...', 'info');
        try{
            console.log('[voice-ban-action] sending request');
            const res = await apiFetch(url,{method:'POST'});
            if((res.status||'').toLowerCase()==='failed'){ throw new Error(res.message||'Entbannen fehlgeschlagen.'); }
            tabLoaded['bans']=false; await loadBans();
            tabLoaded['clients']=false; await loadClients();
            showActionStatus('Ban wurde entfernt.', 'success');
        }catch(err){
            showError(`Entbannen fehlgeschlagen: ${err.message}`);
        }finally{
            removeBtn.disabled=false;
            actionLocks.delete(lockKey);
        }
    });

    // ── Add ban form ──
    $('vs-btn-ban-add')?.addEventListener('click', async ()=>{
        const btn=$('vs-btn-ban-add');
        const ip=$('vs-ban-ip')?.value?.trim()||'';
        const uid=$('vs-ban-uid')?.value?.trim()||'';
        const name=$('vs-ban-name')?.value?.trim()||'';
        const time=$('vs-ban-time')?.value?.trim()||'';
        const reason=$('vs-ban-reason')?.value?.trim()||'';
        const body={};
        if(ip) body.ip=ip; if(uid) body.uid=uid; if(name) body.name=name;
        if(time) body.time=parseInt(time,10); if(reason) body.banreason=reason;
        if(!Object.keys(body).length){showError(i18n.banCriteriaRequired);return;}
        btn.disabled=true; clearError();
        try{
            await apiFetch(d.urlBans,{method:'POST',body:JSON.stringify(body)});
            ['vs-ban-ip','vs-ban-uid','vs-ban-name','vs-ban-time','vs-ban-reason'].forEach(id=>{const el=$(id);if(el)el.value='';});
            tabLoaded['bans']=false; await loadBans();
        }catch(err){showError(err.message);}
        finally{btn.disabled=false;}
    });

    // ── Rotate token ──
    $('vs-btn-rotate')?.addEventListener('click', async ()=>{
        const btn=$('vs-btn-rotate');
        btn.disabled=true; clearError();
        try{
            const gid=parseInt($('vs-token-group')?.value||'6',10)||6;
            await apiFetch(d.urlTokensRotate,{method:'POST',body:JSON.stringify({server_group_id:gid})});
            tabLoaded['tokens']=false; await loadTokens();
        }catch(err){showError(err.message);}
        finally{btn.disabled=false;}
    });

    // ── Server actions ──
    const sendAction = async (action) => {
        setGlobalBusy(true); clearError();
        try{
            await apiFetch(action==='probe'?d.urlProbe:`${d.urlActions}/${action}`,{method:'POST'});
            await loadDetail();
        }catch(err){showError(err.message);}
        finally{setGlobalBusy(false);}
    };
    $('vs-btn-probe'   )?.addEventListener('click',()=>sendAction('probe'));
    $('vs-btn-start'   )?.addEventListener('click',()=>sendAction('start'));
    $('vs-btn-stop'    )?.addEventListener('click',()=>sendAction('stop'));
    $('vs-btn-restart' )?.addEventListener('click',()=>sendAction('restart'));

    $('vs-btn-snapshot')?.addEventListener('click', async ()=>{
        const btn=$('vs-btn-snapshot');
        btn.disabled=true; clearError();
        try{
            await apiFetch(d.urlSnapshot,{method:'POST'});
            btn.textContent=i18n.snapshotCreated; setTimeout(()=>{btn.textContent=i18n.snapshot;btn.disabled=false;},3000);
        }catch(err){showError(err.message);btn.disabled=false;}
    });

    $('vs-qa-recreate')?.addEventListener('click', async ()=>{
        if(!confirm(i18n.resetConfirm)) return;
        const btn=$('vs-qa-recreate');
        btn.disabled=true; clearError();
        try{
            await apiFetch(d.urlRecreate,{method:'POST'});
            btn.textContent=i18n.resetStarted; setTimeout(()=>{btn.textContent=i18n.resetBtn;btn.disabled=false;loadDetail();},5000);
        }catch(err){showError(err.message);btn.disabled=false;}
    });

    // ── Save viewer ──
    $('vs-btn-save-viewer')?.addEventListener('click', async ()=>{
        const btn=$('vs-btn-save-viewer');
        btn.disabled=true; clearError();
        try{
            const data=await apiFetch(d.urlViewer,{method:'PUT',body:JSON.stringify({
                enabled:$('vs-viewer-enabled')?.checked??true,
                cache_ttl_ms:parseInt($('vs-viewer-ttl')?.value||'1500',10),
                domain_allowlist:$('vs-viewer-allowlist')?.value?.trim()||null,
            })});
            const viewer=data.viewer||{};
            if(viewer.public_id){
                const vv=$('vs-viewer-url-val'); if(vv) vv.textContent=location.origin+'/viewer/'+(instance.node?.providerType||'ts3')+'/'+viewer.public_id;
                const vu=$('vs-viewer-url'); if(vu) vu.classList.remove('hidden');
            }
            btn.textContent=i18n.saved; setTimeout(()=>btn.textContent=i18n.save,1800);
        }catch(err){showError(err.message);}
        finally{btn.disabled=false;}
    });

    // Copy viewer URL
    $('vs-copy-viewer-url')?.addEventListener('click',()=>{
        const val=$('vs-viewer-url-val')?.textContent||'';
        navigator.clipboard?.writeText(val).then(()=>{
            const btn=$('vs-copy-viewer-url'); if(btn){btn.textContent=i18n.copied;setTimeout(()=>btn.textContent=i18n.copy,1800);}
        });
    });

    // ── Save settings ──
    $('vs-btn-save-settings')?.addEventListener('click', async ()=>{
        const btn=$('vs-btn-save-settings');
        btn.disabled=true; clearError();
        try{
            await apiFetch(d.urlSettings,{method:'PUT',body:JSON.stringify({public_host:$('vs-settings-host')?.value?.trim()||null})});
            await loadDetail();
            btn.textContent=i18n.saved; setTimeout(()=>btn.textContent=i18n.save,1800);
        }catch(err){showError(err.message);}
        finally{btn.disabled=false;}
    });

    // ── Backup: Create & Download ──
    let restoreFileContent = null;

    const backupStatus  = $('vs-backup-status');
    const backupProgress= $('vs-backup-progress');
    const backupProgressBar = $('vs-backup-progress-bar');
    const backupProgressLabel = $('vs-backup-progress-label');
    const restoreStatus = $('vs-restore-status');
    const restoreBtn    = $('vs-btn-restore-backup');
    const fileInput     = $('vs-restore-file');
    const dropzone      = $('vs-restore-dropzone');
    const filenameEl    = $('vs-restore-filename');

    const setBackupStatus = (msg, color='') => { if(backupStatus){ backupStatus.textContent=msg; backupStatus.style.color=color||''; } };
    const setBackupProgress = (percent) => {
        if (!backupProgressBar) return;
        const safePercent = Math.max(0, Math.min(100, Number(percent) || 0));
        backupProgressBar.style.width = `${safePercent}%`;
        backupProgressBar.style.animation = safePercent >= 100 ? 'none' : 'vs-bar-slide 1.2s ease-in-out infinite';
    };
    const setBackupProgressLabel = (msg) => { if (backupProgressLabel) backupProgressLabel.textContent = msg || ''; };
    const stopBackupPolling = () => { backupPollingAborted = true; };
    const enableBackupButton = () => { if (backupCreateButton) backupCreateButton.disabled = false; };
    const finishBackupSuccess = (message = 'Backup fertig. Download gestartet.') => {
        stopBackupPolling();
        backupInFlight = false;
        setBackupProgress(100);
        setBackupProgressLabel(message);
        setBackupStatus(i18n.backupDownloaded, '#4ade80');
        enableBackupButton();
    };
    const finishBackupError = (message) => {
        stopBackupPolling();
        backupInFlight = false;
        setBackupProgress(0);
        setBackupProgressLabel(message || 'Backup fehlgeschlagen.');
        setBackupStatus(i18n.errorPrefix + (message || 'Backup fehlgeschlagen.'), '#f87171');
        enableBackupButton();
    };
    const setRestoreStatus = (msg, color='') => { if(restoreStatus){ restoreStatus.textContent=msg; restoreStatus.style.color=color||''; } };
    let backupInFlight = false;
    let backupPollingAborted = false;
    const BACKUP_POLL_INTERVAL_MS = 1500;
    const BACKUP_TIMEOUT_MS = 90000;

    const normalizeBackupResult = (raw) => {
        const payload = raw?.data && typeof raw.data === 'object' ? raw.data : raw;
        const artifact = payload?.artifact && typeof payload.artifact === 'object' ? payload.artifact : null;
        const snapshot = payload?.snapshot || payload?.result?.snapshot || payload?.payload?.snapshot || payload?.resultPayload?.snapshot || null;
        const done = payload?.status === 'ok' || payload?.status === 'done' || payload?.state === 'completed' || payload?.success === true;
        const waiting = payload?.status === 'pending' || payload?.status === 'running' || payload?.state === 'running';
        const failed = payload?.status === 'failed' || payload?.state === 'failed' || payload?.success === false;
        return {
            status: failed ? 'failed' : (done ? 'completed' : (waiting ? 'running' : 'pending')),
            jobId: String(payload?.jobId || payload?.job_id || payload?.data?.jobId || payload?.data?.job_id || '' ) || undefined,
            filename: artifact?.filename || payload?.filename || undefined,
            mimeType: artifact?.mimeType || artifact?.mime_type || payload?.mimeType || payload?.mime_type || undefined,
            downloadUrl: payload?.downloadUrl || payload?.download_url || undefined,
            contentBase64: (artifact?.encoding === 'base64' ? artifact?.content : null) || payload?.contentBase64 || payload?.content_base64 || undefined,
            snapshot: typeof snapshot === 'string' ? snapshot : undefined,
            error: payload?.error || payload?.message || undefined,
        };
    };

    const decodeBase64ToBlob = (base64, mimeType='text/plain') => {
        const binary = atob(base64);
        const bytes = new Uint8Array(binary.length);
        for (let i = 0; i < binary.length; i++) bytes[i] = binary.charCodeAt(i);
        return new Blob([bytes], { type: mimeType });
    };

    const triggerDownloadBlob = (blob, filename) => {
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = filename;
        a.rel = 'noopener';
        a.click();
        setTimeout(() => URL.revokeObjectURL(url), 3000);
    };

    console.log('[voice-backup] script loaded');
    const backupCreateButton = document.querySelector('#voice-backup-create-button');
    console.log('[voice-backup] button found', !!backupCreateButton);

    backupCreateButton?.addEventListener('click', async (event) => {
        event.preventDefault();
        const btn = backupCreateButton;
        console.log('[voice-backup] clicked');
        if (!btn) return;
        if (backupInFlight) {
            console.warn('[voice-backup] ignored click because backup is already in flight');
            return;
        }
        const backupUrl = btn.dataset.backupUrl || d.urlSnapshot;
        const backupPollUrl = btn.dataset.backupPollUrl || d.urlSnapshotPoll;
        console.log('[voice-backup] backupUrl', backupUrl || null);
        if (!backupUrl) {
            const msg = 'Backup-URL fehlt. Request wurde nicht gestartet.';
            setBackupStatus(i18n.errorPrefix+msg, '#f87171');
            showError(msg);
            return;
        }
        backupInFlight = true;
        backupPollingAborted = false;
        btn.disabled=true; clearError();
        setBackupProgress(30);
        setBackupProgressLabel(i18n.backupWaitingProgress);
        setBackupStatus(i18n.backupCreating);
        if(backupProgress) backupProgress.classList.remove('hidden');

        try {
            console.info('[voice-backup] button clicked', { backupUrl, backupPollUrl, serverId: instance?.id, providerType: instance?.node?.providerType });
            console.log('[voice-backup] sending POST', backupUrl);
            const startHttp = await fetch(backupUrl, {method:'POST',headers:{'Accept':'application/json','X-Requested-With':'XMLHttpRequest'}, credentials:'same-origin'});
            let startResp = {};
            try { startResp = await startHttp.json(); } catch { startResp = {}; }
            console.log('[voice-backup] POST response', startHttp.status);
            if (!startHttp.ok) {
                const startErr = startResp?.message || startResp?.error || `HTTP ${startHttp.status}`;
                throw new Error(startErr);
            }
            let result = normalizeBackupResult(startResp);
            console.info('[voice-backup] start response status', { status: startHttp.status });
            console.info('[voice-backup] normalized result', {
                status: result?.status,
                jobId: result?.jobId || null,
                hasSnapshot: typeof result?.snapshot === 'string' && result.snapshot.length > 0,
                snapshotLength: typeof result?.snapshot === 'string' ? result.snapshot.length : 0,
                error: result?.error || null,
            });

            if (result.status === 'failed') {
                throw new Error(result.error || 'Backup failed');
            }

            if (!(result.status === 'completed' && typeof result.snapshot === 'string' && result.snapshot.trim() !== '')) {
                const cacheKey = startResp.cache_key || startResp.data?.cache_key;
                const hasTrackableJob = !!result.jobId || !!cacheKey;
                console.info('[voice-backup] polling started', { started: hasTrackableJob, jobId: result?.jobId || null, cacheKey: cacheKey || null });
                if (!hasTrackableJob) {
                    throw new Error('Backup-Start lieferte weder Snapshot noch Job-ID.');
                }
                if (!backupPollUrl) {
                    throw new Error('Polling-URL fehlt. Job-Status kann nicht abgefragt werden.');
                }
                setBackupStatus(i18n.backupWaiting);
                setBackupProgressLabel(i18n.backupCreating);
                const startedAt = Date.now();

                while ((Date.now() - startedAt) < BACKUP_TIMEOUT_MS && !backupPollingAborted) {
                    await new Promise(r=>setTimeout(r,BACKUP_POLL_INTERVAL_MS));
                    const pollUrl = `${backupPollUrl}?key=${encodeURIComponent(cacheKey || '')}`;
                    const poll = await fetch(pollUrl,{headers:{'Accept':'application/json','X-Requested-With':'XMLHttpRequest'}});
                    let pollData = {};
                    try { pollData = await poll.json(); } catch { pollData = {}; }
                    if (!poll.ok) {
                        const message = pollData?.message || pollData?.error || `HTTP ${poll.status}`;
                        console.warn('[voice-backup] poll failed', { serverId: instance?.id, status: poll.status, error: message });
                        throw new Error(message);
                    }
                    result = normalizeBackupResult(pollData);
                    console.info('[voice-backup] poll status', {
                        serverId: instance?.id,
                        status: result?.status,
                        hasSnapshot: typeof result?.snapshot === 'string' && result.snapshot.length > 0,
                        snapshotLength: typeof result?.snapshot === 'string' ? result.snapshot.length : 0,
                        error: result?.error || null,
                    });
                    if (result.status === 'failed') {
                        throw new Error(result.error || 'Backup failed');
                    }
                    if (result.status === 'completed') {
                        break;
                    }
                }

                if(backupPollingAborted) throw new Error('Backup polling aborted.');
                if(!result || result.status !== 'completed') throw new Error(i18n.backupTimeout);
            }

            const ts  = new Date().toISOString().slice(0,19).replace(/[T:]/g,'-');
            const ext = instance.node?.providerType==='ts6'?'ts6snapshot':'ts3snapshot';
            const filename = result.filename || `backup-${ts}.${ext}`;

            if (typeof result.snapshot === 'string') {
                if (result.snapshot.trim() === '') {
                    throw new Error('Agent hat keinen Snapshot-Inhalt zurückgegeben.');
                }
                const snapshotFilename = `ts6-server-${instance?.id || 'unknown'}-snapshot.txt`;
                const blob = new Blob([result.snapshot], { type: 'text/plain;charset=utf-8' });
                triggerDownloadBlob(blob, snapshotFilename);
                console.info('[voice-backup] download started', { type: 'snapshot', filename: snapshotFilename });
            } else if (result.downloadUrl) {
                window.open(result.downloadUrl, '_blank', 'noopener');
                console.info('[voice-backup] download started', { type: 'url' });
            } else if (result.contentBase64) {
                const blob = decodeBase64ToBlob(result.contentBase64, result.mimeType || 'text/plain');
                triggerDownloadBlob(blob, filename);
                console.info('[voice-backup] download started', { type: 'base64', filename });
            } else {
                throw new Error('Agent hat keinen Snapshot-Inhalt zurückgegeben.');
            }

            finishBackupSuccess();
        } catch(err) {
            console.error('[voice-backup] POST failed', err);
            const message = err?.message || String(err);
            finishBackupError(message);
            showError(message);
        } finally {
            if (!backupInFlight && backupProgress) {
                setTimeout(() => {
                    if (!backupInFlight) backupProgress.classList.add('hidden');
                }, 2000);
            }
        }
    });

    // Drag & drop + file input
    const handleFile = (file) => {
        if(!file) return;
        const reader=new FileReader();
        reader.onload=(e)=>{
            restoreFileContent=e.target?.result||null;
            if(filenameEl) filenameEl.textContent=file.name+' ('+Math.round(file.size/1024)+' KB)';
            if(dropzone) dropzone.classList.add('has-file');
            if(restoreBtn) restoreBtn.disabled=false;
            setRestoreStatus(i18n.restoreReady);
        };
        reader.readAsText(file);
    };

    fileInput?.addEventListener('change', ()=>{ if(fileInput.files?.[0]) handleFile(fileInput.files[0]); });

    if(dropzone){
        dropzone.addEventListener('dragover', e=>{ e.preventDefault(); dropzone.classList.add('dragover'); });
        dropzone.addEventListener('dragleave', ()=>dropzone.classList.remove('dragover'));
        dropzone.addEventListener('drop', e=>{ e.preventDefault(); dropzone.classList.remove('dragover'); const f=e.dataTransfer?.files?.[0]; if(f) handleFile(f); });
    }

    restoreBtn?.addEventListener('click', async ()=>{
        if(!restoreFileContent){ setRestoreStatus(i18n.restoreNoFile, '#f87171'); return; }
        if(!confirm(i18n.restoreConfirm)) return;
        restoreBtn.disabled=true; clearError();
        setRestoreStatus(i18n.restoreSending);
        try {
            const formData=new FormData();
            const blob=new Blob([restoreFileContent],{type:'text/plain'});
            formData.append('snapshot', blob, 'backup.snapshot');
            const resp=await fetch(d.urlSnapshotRestore,{method:'POST',body:formData,headers:{'Accept':'application/json'}});
            const data=await resp.json();
            if(!resp.ok) throw new Error(data.message||`HTTP ${resp.status}`);
            setRestoreStatus(i18n.restoreStarted, '#4ade80');
            restoreFileContent=null;
            if(dropzone) dropzone.classList.remove('has-file');
            if(filenameEl) filenameEl.textContent='';
        } catch(err) {
            setRestoreStatus(i18n.errorPrefix+err.message, '#f87171');
            showError(err.message);
        } finally {
            restoreBtn.disabled=false;
        }
    });

    window.addEventListener('beforeunload', () => { backupPollingAborted = true; });

    // ── Bootstrap ──
    tabLoaded['overview']=true;
    loadDetail().then(async ()=>{
        // auto-probe once when checkedAt is missing or stale so GEPRÜFT shows immediately
        if(document.getElementById('vs-probe-badge')?.dataset?.stale==='1'){
            try{ await fetch(d.urlProbe,{method:'POST',headers:{'Accept':'application/json'}}); await loadDetail(); }catch(_){}
        }
    }).catch(()=>{});
})();
</script>
{% endblock %}
