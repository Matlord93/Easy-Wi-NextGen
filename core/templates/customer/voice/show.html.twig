    // ── Logs ──
    const loadLogs = async () => {
        const el=$('vs-logs-list');
        if(!el) return;
        el.innerHTML=`<div style="padding:32px;text-align:center;color:var(--ng-text-muted);font-size:13px;">${esc(i18n.logsLoading)}</div>`;
        try {
            let data = await apiFetch(`${d.urlQueryBase}/logs`);
            if((data.status||'pending')==='pending') data=await pollUntilDone(`${d.urlQueryBase}/logs`);
            const rows=data.data?.payload||data.payload||[];
            if(!rows.length){ el.innerHTML=`<div style="padding:32px;text-align:center;color:var(--ng-text-muted);font-size:13px;">${esc(i18n.logsEmpty)}</div>`; return; }
