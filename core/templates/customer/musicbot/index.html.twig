{% extends 'customer/base.html.twig' %}

{% set pageTitle = 'Musicbots' %}
{% set pageSubtitle = 'Verwalte deine Musicbot-Instanzen.' %}
{% set activeNav = 'musicbots' %}

{% set statusMap = {
    'running':      'success',
    'stopped':      'neutral',
    'error':        'danger',
    'provisioning': 'primary',
    'installing':   'info'
} %}

{% block content %}
<div style="display:flex;flex-direction:column;gap:20px;">

    {# ── Hero / KPI ── #}
    <div class="ng-card" style="overflow:hidden;">
        <div class="tkt-hero">
            <div class="tkt-hero__inner">
                <div style="display:flex;flex-direction:column;gap:6px;">
                    <div class="tkt-hero__pill">
                        <span class="tkt-hero__pill-dot"></span>
                        Musicbots
                    </div>
                    <h1 class="tkt-hero__title">Meine Musicbots</h1>
                    <p class="tkt-hero__sub">Deine nativen Musicbot-Instanzen und deren Runtime-Status.</p>
                </div>
                <div style="display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:8px;margin-top:16px;">
                    <div class="tkt-kpi">
                        <div class="tkt-kpi__label">Gesamt</div>
                        <div class="tkt-kpi__value">{{ instances|length }}</div>
                    </div>
                    <div class="tkt-kpi tkt-kpi--resolved">
                        <div class="tkt-kpi__label">Running</div>
                        <div class="tkt-kpi__value">{{ instances|filter(r => r.instance.status.value == 'running')|length }}</div>
                    </div>
                    <div class="tkt-kpi tkt-kpi--open">
                        <div class="tkt-kpi__label">Error</div>
                        <div class="tkt-kpi__value">{{ instances|filter(r => r.instance.status.value == 'error')|length }}</div>
                    </div>
                    <div class="tkt-kpi">
                        <div class="tkt-kpi__label">Stopped</div>
                        <div class="tkt-kpi__value">{{ instances|filter(r => r.instance.status.value == 'stopped')|length }}</div>
                    </div>
                </div>
            </div>
        </div>
        <div style="display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:10px;padding:14px 16px;border-top:1px solid var(--ng-border);background:var(--ng-surface-soft);">
            <div class="tkt-qa" style="cursor:default;">
                <div class="tkt-qa__icon" style="background:rgba(99,102,241,0.15);color:#818cf8;">♫</div>
                <div class="tkt-qa__title">Native Musicbots</div>
                <div class="tkt-qa__sub">Keine SinusBot- oder TS3AudioBot-Abhängigkeit</div>
            </div>
            <div class="tkt-qa" style="cursor:default;">
                <div class="tkt-qa__icon" style="background:rgba(34,197,94,0.12);color:#4ade80;">▶</div>
                <div class="tkt-qa__title">Playback-Steuerung</div>
                <div class="tkt-qa__sub">Queue, Playlists und Live-Steuerung</div>
            </div>
            <div class="tkt-qa" style="cursor:default;">
                <div class="tkt-qa__icon" style="background:var(--ng-surface);color:var(--ng-text-muted);">⚙</div>
                <div class="tkt-qa__title">Auto-DJ & Webradio</div>
                <div class="tkt-qa__sub">Streaming und automatisierte Wiedergabe</div>
            </div>
        </div>
    </div>

    {# ── Instanz-Liste ── #}
    <div class="ng-card" style="overflow:hidden;">
        <div class="tkt-filter-bar">
            <div class="tkt-filter-bar__top">
                <div>
                    <h2 class="tkt-filter-bar__title">Meine Instanzen</h2>
                    <p class="tkt-filter-bar__sub">Übersicht deiner Musicbot-Instanzen mit aktuellem Status.</p>
                </div>
            </div>
        </div>

        <table class="ui-table" style="width:100%;">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Status</th>
                    <th>Node</th>
                    <th>TeamSpeak</th>
                    <th>Discord</th>
                    <th>Aktueller Track</th>
                    <th>Queue</th>
                    <th>Aktualisiert</th>
                </tr>
            </thead>
            <tbody>
            {% for row in instances %}
                {% set instance = row.instance %}
                {% set statusClass = statusMap[instance.status.value] ?? 'neutral' %}
                <tr>
                    <td>
                        <a href="{{ path('customer_musicbot_show', {id: instance.id}) }}" style="font-weight:600;color:var(--ng-text);text-decoration:none;">{{ instance.name }}</a>
                    </td>
                    <td>
                        <span class="ui-badge ui-badge--{{ statusClass }}">{{ instance.status.value|title }}</span>
                    </td>
                    <td style="color:var(--ng-text-muted);font-size:13px;">{{ instance.node.name ?: instance.node.id }}</td>
                    <td>
                        {% if row.teamspeakActive %}
                            <span class="ui-badge ui-badge--success">aktiv</span>
                        {% else %}
                            <span class="ui-badge ui-badge--neutral">inaktiv</span>
                        {% endif %}
                    </td>
                    <td>
                        {% if row.discordActive %}
                            <span class="ui-badge ui-badge--success">aktiv</span>
                        {% else %}
                            <span class="ui-badge ui-badge--neutral">inaktiv</span>
                        {% endif %}
                    </td>
                    <td style="font-size:13px;color:var(--ng-text-muted);">
                        {% if row.currentTrack %}{{ row.currentTrack.title }}{% else %}—{% endif %}
                    </td>
                    <td style="font-size:13px;color:var(--ng-text-muted);">{{ row.queueLength }}</td>
                    <td style="font-size:12px;color:var(--ng-text-muted);">{{ instance.updatedAt|date('d.m.Y H:i') }}</td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="8">
                        <div style="text-align:center;padding:48px 20px;">
                            <svg width="40" height="40" fill="none" viewBox="0 0 24 24" style="display:block;margin:0 auto 12px;opacity:.2;color:var(--ng-text-muted);" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3"/></svg>
                            <p style="margin:0;font-size:14px;font-weight:600;color:var(--ng-text);">Du hast noch keine Musicbots.</p>
                            <p style="margin:6px 0 0;font-size:13px;color:var(--ng-text-muted);">Wende dich an deinen Anbieter, um eine Musicbot-Instanz zu erhalten.</p>
                        </div>
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>

</div>
{% endblock %}
