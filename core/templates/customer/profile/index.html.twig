{% extends 'customer/base.html.twig' %}

{% block content %}
<div class="cust-page">

    <div class="cust-hero">
        <div class="cust-hero__inner">
            <div>
                <div class="cust-hero__label">{{ t('profile_billing_title', page_locale()) }}</div>
                <h1 class="cust-hero__title">{{ t('customer_profile_title', page_locale()) }}</h1>
                <p class="cust-hero__desc">{{ t('profile_billing_description', page_locale()) }}</p>
            </div>
            <div class="cust-hero__actions">
                <span class="ui-badge ui-badge--success">{{ t('invoice_ready', page_locale()) }}</span>
            </div>
        </div>
    </div>

    <div class="cust-grid-2">

        {# ── Customer Profile ── #}
        <div class="cust-panel">
            <div class="cust-panel__header">
                <div>
                    <div class="cust-panel__title">{{ t('customer_profile_title', page_locale()) }}</div>
                    <div class="cust-panel__sub">{{ t('customer_profile_description', page_locale()) }}</div>
                </div>
                <span class="ui-badge ui-badge--neutral">{{ t('required', page_locale()) }}</span>
            </div>
            <div class="cust-panel__body">
                <form method="post" action="/customer/profile/customer">

                    {% if profile.success %}
                        <div class="ng-alert ng-alert--success">
                            {{ t('profile_saved_successfully', page_locale()) }}
                        </div>
                    {% endif %}

                    {% if profile.errors %}
                        <div class="ng-alert ng-alert--danger">
                            <p><strong>{{ t('please_fix_following', page_locale()) }}</strong></p>
                            <ul>
                                {% for error in profile.errors %}
                                    <li>{{ t(error, page_locale()) }}</li>
                                {% endfor %}
                            </ul>
                        </div>
                    {% endif %}

                    <div class="cust-grid-2">
                        <div class="form-field">
                            <label class="form-label">{{ t('first_name', page_locale()) }}</label>
                            <input class="form-input" name="firstname" value="{{ profile.firstname }}" required>
                        </div>
                        <div class="form-field">
                            <label class="form-label">{{ t('last_name', page_locale()) }}</label>
                            <input class="form-input" name="lastname" value="{{ profile.lastname }}" required>
                        </div>
                    </div>

                    <div class="form-field">
                        <label class="form-label">{{ t('street_address', page_locale()) }}</label>
                        <input class="form-input" name="address" value="{{ profile.address }}" required>
                    </div>

                    <div class="cust-grid-2">
                        <div class="form-field">
                            <label class="form-label">{{ t('postal_code', page_locale()) }}</label>
                            <input class="form-input" name="postal" value="{{ profile.postal }}" required>
                        </div>
                        <div class="form-field">
                            <label class="form-label">{{ t('city', page_locale()) }}</label>
                            <input class="form-input" name="city" value="{{ profile.city }}" required>
                        </div>
                    </div>

                    <div class="form-field">
                        <label class="form-label">{{ t('country', page_locale()) }}</label>
                        <select class="form-input" name="country" required>
                            {% for code, label in countries %}
                                <option value="{{ code }}" {{ profile.country == code ? 'selected' : '' }}>{{ label }}</option>
                            {% endfor %}
                        </select>
                    </div>

                    <div class="cust-grid-2">
                        <div class="form-field">
                            <label class="form-label">{{ t('phone_optional', page_locale()) }}</label>
                            <input class="form-input" name="phone" value="{{ profile.phone }}">
                        </div>
                        <div class="form-field">
                            <label class="form-label">{{ t('company_optional', page_locale()) }}</label>
                            <input class="form-input" name="company" value="{{ profile.company }}">
                        </div>
                    </div>

                    <div class="form-field">
                        <label class="form-label">{{ t('vat_id_optional', page_locale()) }}</label>
                        <input class="form-input" name="vat_id" value="{{ profile.vat_id }}">
                        <p class="form-hint">{{ t('vat_id_help', page_locale()) }}</p>
                    </div>

                    <div style="display:flex;justify-content:flex-end;">
                        <button type="submit" class="ui-button ui-button--primary">{{ t('save_profile', page_locale()) }}</button>
                    </div>

                </form>
            </div>
        </div>

        {# ── Invoice Preferences ── #}
        <div class="cust-panel">
            <div class="cust-panel__header">
                <div>
                    <div class="cust-panel__title">{{ t('invoice_preferences_title', page_locale()) }}</div>
                    <div class="cust-panel__sub">{{ t('invoice_preferences_description', page_locale()) }}</div>
                </div>
                <span class="ui-badge ui-badge--neutral">{{ t('preferences', page_locale()) }}</span>
            </div>
            <div class="cust-panel__body">
                <form method="post" action="/customer/profile/invoice">

                    {% if preferences.success %}
                        <div class="ng-alert ng-alert--success">
                            {{ t('preferences_updated', page_locale()) }}
                        </div>
                    {% endif %}

                    {% if preferences.errors %}
                        <div class="ng-alert ng-alert--danger">
                            <p><strong>{{ t('please_fix_following', page_locale()) }}</strong></p>
                            <ul>
                                {% for error in preferences.errors %}
                                    <li>{{ t(error, page_locale()) }}</li>
                                {% endfor %}
                            </ul>
                        </div>
                    {% endif %}

                    <div class="form-field">
                        <label class="form-label">{{ t('portal_language', page_locale()) }}</label>
                        <select class="form-input" name="portal_language" required>
                            {% for code, label in portalLanguages %}
                                <option value="{{ code }}" {{ preferences.portal_language == code ? 'selected' : '' }}>{{ label }}</option>
                            {% endfor %}
                        </select>
                    </div>

                    <div class="form-field">
                        <label class="form-label">{{ t('invoice_locale', page_locale()) }}</label>
                        <select class="form-input" name="locale" required>
                            {% for code, label in locales %}
                                <option value="{{ code }}" {{ preferences.locale == code ? 'selected' : '' }}>{{ label }}</option>
                            {% endfor %}
                        </select>
                    </div>

                    <div class="cust-form-card">
                        <label class="cust-form-card__check">
                            <input type="checkbox" name="email_delivery" value="1" {{ preferences.email_delivery ? 'checked' : '' }}>
                            {{ t('email_delivery_label', page_locale()) }}
                        </label>
                        <label class="cust-form-card__check">
                            <input type="checkbox" name="pdf_download_history" value="1" {{ preferences.pdf_download_history ? 'checked' : '' }}>
                            {{ t('pdf_download_history_label', page_locale()) }}
                        </label>
                    </div>

                    <div class="form-field">
                        <label class="form-label">{{ t('default_payment_method', page_locale()) }}</label>
                        <select class="form-input" name="payment_method" required>
                            {% for code, label in paymentMethods %}
                                <option value="{{ code }}" {{ preferences.payment_method == code ? 'selected' : '' }}>{{ label }}</option>
                            {% endfor %}
                        </select>
                    </div>

                    <div style="display:flex;justify-content:flex-end;">
                        <button type="submit" class="ui-button ui-button--primary">{{ t('save_preferences', page_locale()) }}</button>
                    </div>

                </form>
            </div>
        </div>

    </div>{# /cust-grid-2 #}

</div>{# /cust-page #}
{% endblock %}
