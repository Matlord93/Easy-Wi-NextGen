{% set infrastructureItems = [
    moduleGame and customerHasGame ? { key: 'gameservers', label: t('customer_nav_game_servers', page_locale()), href: path('customer_instances'),    iconSvg: icon.gamepad } : null,
    showVoiceserver and customerHasVoice ? { key: 'voiceservers', label: t('customer_nav_voice_servers', page_locale()), href: voiceserverUrl, iconSvg: icon.voice } : null,
    moduleGame and customerHasSinusbot ? { key: 'sinusbot', label: t('customer_nav_sinusbot', page_locale()), href: path('customer_sinusbot_index'), iconSvg: icon.sinusbot } : null
]|filter(v => v) %}

{% set serviceItems = [
    moduleWeb and customerHasWeb ? { key: 'webspaces', label: t('customer_nav_webspace', page_locale()), href: path('customer_webspace'), iconSvg: icon.globe } : null,
    customerHasDatabase ? { key: 'databases', label: t('customer_nav_databases', page_locale()), href: path('customer_databases'), iconSvg: icon.database } : null
]|filter(v => v) %}

{% set domainItems = [
    moduleDns and customerHasDomain ? { key: 'domains', label: t('customer_nav_domains', page_locale()), href: path('customer_domains'), iconSvg: icon.dns } : null,
    moduleMail and customerHasMail  ? { key: 'mail',    label: t('customer_nav_mail', page_locale()),    href: path('customer_mail'),    iconSvg: icon.mail } : null
]|filter(v => v) %}

{% set marketplaceVisible = moduleBilling and customerHasShop %}

{% set profileUser = current_user() %}
{% set profileSummary = profileUser ? {
    name:    profileUser.name ?: profileUser.email,
    email:   profileUser.email,
    initial: (profileUser.name ?: profileUser.email)|slice(0, 1)|upper
} : null %}

{% set sidebarGroups = [
    {
        label: t('customer_nav_group_overview', page_locale()),
        open: true,
        items: [
            { key: 'dashboard', label: t('customer_nav_dashboard', page_locale()), href: path('customer_dashboard'), iconSvg: icon.dashboard },
            { key: 'activity',  label: t('customer_nav_activity', page_locale()),  href: path('customer_activity'),  iconSvg: icon.activity },
            { key: 'notifications', label: t('notifications', page_locale()),      href: path('customer_notifications'), iconSvg: icon.notifications }
        ]
    },
    infrastructureItems is not empty ? {
        label: t('customer_nav_group_infrastructure', page_locale()),
        open: true,
        items: infrastructureItems
    } : null,
    serviceItems is not empty ? {
        label: t('customer_nav_group_services', page_locale()),
        open: true,
        items: serviceItems
    } : null,
    domainItems is not empty ? {
        label: t('customer_nav_group_domains_mail', page_locale()),
        open: false,
        items: domainItems
    } : null,
    {
        label: t('customer_nav_group_support', page_locale()),
        open: true,
        items: [
            { key: 'tickets', label: t('customer_nav_tickets', page_locale()), href: path('customer_tickets'), iconSvg: icon.ticket }
        ]
    },
    {
        label: t('customer_nav_group_account', page_locale()),
        open: false,
        items: [
            { key: 'profile',  label: t('customer_nav_profile', page_locale()),  href: path('customer_profile'),  iconSvg: icon.user },
            { key: 'security', label: t('customer_nav_security', page_locale()), href: path('customer_security'), iconSvg: icon.shield }
        ]
    },
    gdprItems is not empty ? {
        label: t('customer_nav_group_gdpr', page_locale()),
        open: false,
        items: gdprItems|map(item => item|merge({ iconSvg: icon.gdpr }))
    } : null,
    marketplaceVisible ? {
        label: t('customer_nav_group_marketplace', page_locale()),
        open: false,
        items: ([{ key: 'shop', label: t('customer_nav_shop', page_locale()), href: path('customer_shop'), iconSvg: icon.shop }]|merge(marketplaceItems))
    } : null
]|filter(v => v) %}

<div class="ng-layout">
    {% include 'components/_sidebar.html.twig' with {
        title: brandingName,
        logoUrl: brandingLogo ?: asset('easywi-nextgen-logo.svg'),
        activeNav: activeNav,
        groups: sidebarGroups,
        footer: ''
    } %}
    <div class="ng-sidebar-backdrop" data-sidebar-backdrop></div>

    <main class="ng-main" id="main-content">
        {% include 'components/_topbar.html.twig' with {
            title:   pageTitle|default(''),
            subtitle: pageSubtitle|default(''),
            actions: topbarActions|default([]),
            profile: profileSummary
        } %}
        <div class="ng-content">
            {% block content %}{% endblock %}
        </div>
    </main>
</div>

<script>
    (function () {
        /* ── Theme toggle ── */
        var themeToggle = document.getElementById('theme-toggle');
        var iconDark  = themeToggle ? themeToggle.querySelector('.theme-icon-dark')  : null;
        var iconLight = themeToggle ? themeToggle.querySelector('.theme-icon-light') : null;

        function applyTheme() {
            var isDark = document.documentElement.classList.contains('dark');
            if (iconDark)  iconDark.style.display  = isDark  ? '' : 'none';
            if (iconLight) iconLight.style.display = !isDark ? '' : 'none';
        }

        if (themeToggle) {
            applyTheme();
            themeToggle.addEventListener('click', function () {
                var isDark = document.documentElement.classList.toggle('dark');
                localStorage.setItem('theme', isDark ? 'dark' : 'light');
                applyTheme();
            });
        }

        /* ── Sidebar toggle ── */
        var body = document.body;
        var toggles  = document.querySelectorAll('.ng-sidebar-toggle');
        var backdrop = document.querySelector('[data-sidebar-backdrop]');

        if (toggles.length > 0) {
            function toggleSidebar() {
                if (window.matchMedia('(max-width: 768px)').matches) {
                    body.classList.toggle('is-sidebar-open');
                } else {
                    body.classList.toggle('is-sidebar-collapsed');
                }
            }

            toggles.forEach(function (t) { t.addEventListener('click', toggleSidebar); });

            if (backdrop) {
                backdrop.addEventListener('click', function () { body.classList.remove('is-sidebar-open'); });
            }

            window.addEventListener('resize', function () {
                if (!window.matchMedia('(max-width: 768px)').matches) {
                    body.classList.remove('is-sidebar-open');
                }
            });

            window.addEventListener('keydown', function (e) {
                if (e.key === 'Escape') { body.classList.remove('is-sidebar-open'); }
            });
        }

        /* ── User menu ── */
        var userMenuToggle = document.querySelector('[data-user-menu-toggle]');
        var userMenu = document.querySelector('[data-user-menu]');
        if (userMenuToggle && userMenu) {
            userMenuToggle.addEventListener('click', function () {
                userMenu.open = !userMenu.open;
                userMenuToggle.setAttribute('aria-expanded', userMenu.open ? 'true' : 'false');
            });
            document.addEventListener('click', function (e) {
                if (userMenu.open && !userMenu.contains(e.target) && !userMenuToggle.contains(e.target)) {
                    userMenu.open = false;
                }
            });
        }

        /* ── Copy to clipboard ── */
        var copyText = function (value) {
            if (navigator.clipboard && navigator.clipboard.writeText) {
                return navigator.clipboard.writeText(value).then(function () { return true; });
            }
            var ta = document.createElement('textarea');
            ta.value = value;
            ta.style.cssText = 'position:fixed;opacity:0';
            document.body.appendChild(ta);
            ta.focus(); ta.select();
            var ok = document.execCommand('copy');
            ta.remove();
            return Promise.resolve(ok);
        };

        document.addEventListener('click', function (e) {
            var btn = e.target.closest('[data-copy-value]');
            if (!btn) return;
            var val = btn.dataset.copyValue;
            if (!val) return;
            var orig = btn.dataset.copyOriginal || btn.textContent.trim();
            btn.dataset.copyOriginal = orig;
            copyText(val).then(function (ok) {
                if (!ok) return;
                btn.textContent = '{{ t('customer_copy_success', page_locale()) }}';
                setTimeout(function () { btn.textContent = orig; }, 1200);
            });
        });
    })();
</script>
</body>
</html>
