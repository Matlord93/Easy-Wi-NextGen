<!DOCTYPE html>
{% set siteTitle = app_setting('site_title', 'Easy-Wi NextGen') %}
{% set brandingName = app_setting('branding_name', siteTitle) %}
{% set brandingLogo = app_setting('branding_logo_url') %}
<html lang="{{ pageLocale|default(page_locale()) }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script>
        (function () {
            const storedTheme = localStorage.getItem('theme');
            if (storedTheme === 'light') {
                document.documentElement.classList.remove('dark');
            } else {
                document.documentElement.classList.add('dark');
            }
        })();
    </script>
    <title>{{ siteTitle }}</title>
    <link rel="stylesheet" href="{{ asset('ui.css') }}">
    <link rel="stylesheet" href="{{ asset('admin-customer.css') }}">
    <link rel="stylesheet" href="{{ asset('ts6.css') }}">
    <link rel="stylesheet" href="{{ asset('ts3.css') }}">
    <script src="{{ asset('htmx.min.js') }}"></script>
</head>
<body class="customer-interface ng-shell">
{% set activeNav = activeNav|default('') %}
{% set voiceserverUrl = module_enabled('ts6')
    ? path('customer_ts6_servers_index')
    : path('customer_ts3_servers_index')
%}
{% set moduleGame = module_enabled('game') %}
{% set moduleTs = module_enabled('ts') %}
{% set moduleTs6 = module_enabled('ts6') %}
{% set moduleWeb = module_enabled('web') %}
{% set moduleMail = module_enabled('mail') %}
{% set moduleDns = module_enabled('dns') %}
{% set moduleBilling = module_enabled('billing') %}
{% set showVoiceserver = moduleTs6 or moduleTs %}
{% set customerHasGame = customer_has_module('game') %}
{% set customerHasVoice = customer_has_module('voice') %}
{% set customerHasSinusbot = customer_has_module('sinusbot') %}
{% set customerHasWeb = customer_has_module('web') %}
{% set customerHasDatabase = customer_has_module('database') %}
{% set customerHasDomain = customer_has_module('domain') %}
{% set customerHasMail = customer_has_module('mail') %}
{% set customerHasShop = customer_has_module('shop') %}
{% set extensionItems = extension_menu_items('customer') %}
{% set gdprItems = extensionItems is not empty
    ? extensionItems|filter(item => item.href starts with '/gdpr')
    : []
%}
{% set marketplaceItems = extensionItems is not empty
    ? extensionItems|filter(item => not (item.href starts with '/gdpr'))
    : []
%}
{% set infrastructureItems = [
    moduleGame and customerHasGame ? { key: 'gameservers', label: t('customer_nav_game_servers', page_locale()), href: path('customer_instances') } : null,
    showVoiceserver and customerHasVoice ? { key: 'voiceservers', label: t('customer_nav_voice_servers', page_locale()), href: voiceserverUrl } : null,
    moduleGame and customerHasSinusbot ? { key: 'sinusbot', label: t('customer_nav_sinusbot', page_locale()), href: path('customer_sinusbot_index') } : null
]|filter(v => v) %}
{% set serviceItems = [
    moduleWeb and customerHasWeb ? { key: 'webspaces', label: t('customer_nav_webspace', page_locale()), href: path('customer_webspace') } : null,
    customerHasDatabase ? { key: 'databases', label: t('customer_nav_databases', page_locale()), href: path('customer_databases') } : null
]|filter(v => v) %}
{% set domainItems = [
    moduleDns and customerHasDomain ? { key: 'domains', label: t('customer_nav_domains', page_locale()), href: path('customer_domains') } : null,
    moduleMail and customerHasMail ? { key: 'mail', label: t('customer_nav_mail', page_locale()), href: path('customer_mail') } : null
]|filter(v => v) %}
{% set marketplaceVisible = moduleBilling and customerHasShop %}
{% set profileUser = current_user() %}
{% set profileSummary = profileUser ? {
    name: profileUser.name ?: profileUser.email,
    email: profileUser.email,
    initial: (profileUser.name ?: profileUser.email)|slice(0, 1)|upper
} : null %}

{% set sidebarGroups = [
    {
        label: t('customer_nav_group_overview', page_locale()),
        open: true,
        items: [
            { key: 'dashboard', label: t('customer_nav_dashboard', page_locale()), href: path('customer_dashboard') },
            { key: 'activity', label: t('customer_nav_activity', page_locale()), href: path('customer_activity') }
        ]
    },
    infrastructureItems is not empty ? {
        label: t('customer_nav_group_infrastructure', page_locale()),
        open: true,
        items: infrastructureItems
    } : null,
    serviceItems is not empty ? {
        label: t('customer_nav_group_services', page_locale()),
        open: true,
        items: serviceItems
    } : null,
    domainItems is not empty ? {
        label: t('customer_nav_group_domains_mail', page_locale()),
        open: true,
        items: domainItems
    } : null,
    {
        label: t('customer_nav_group_support', page_locale()),
        open: true,
        items: [
            { key: 'tickets', label: t('customer_nav_tickets', page_locale()), href: path('customer_tickets') }
        ]
    },
    {
        label: t('customer_nav_group_account', page_locale()),
        open: true,
        items: [
            { key: 'profile', label: t('customer_nav_profile', page_locale()), href: path('customer_profile') },
            { key: 'security', label: t('customer_nav_security', page_locale()), href: path('customer_security') }
        ]
    },
    gdprItems is not empty ? {
        label: t('customer_nav_group_gdpr', page_locale()),
        open: true,
        items: gdprItems
    } : null,
    marketplaceVisible ? {
        label: t('customer_nav_group_marketplace', page_locale()),
        open: true,
        items: ([{ key: 'shop', label: t('customer_nav_shop', page_locale()), href: path('customer_shop') }]|merge(marketplaceItems))
    } : null
]|filter(v => v) %}

<div class="ng-layout">
    {% include 'components/_sidebar.html.twig' with {
        title: brandingName,
        logoUrl: brandingLogo ?: asset('easywi-nextgen-logo.svg'),
        activeNav: activeNav,
        groups: sidebarGroups,
        footer: ''
    } %}
    <div class="ng-sidebar-backdrop" data-sidebar-backdrop></div>

    <main class="ng-main">
        {% include 'components/_topbar.html.twig' with {
            title: pageTitle|default(''),
            subtitle: pageSubtitle|default(''),
            actions: topbarActions|default([]),
            profile: profileSummary
        } %}
        <div class="ng-content">
            {% block content %}{% endblock %}
        </div>
    </main>
</div>
<script>
    const themeToggle = document.getElementById('theme-toggle');
    if (themeToggle) {
        themeToggle.addEventListener('click', () => {
            const isDark = document.documentElement.classList.toggle('dark');
            localStorage.setItem('theme', isDark ? 'dark' : 'light');
        });
    }

    const copyText = async (value) => {
        if (navigator.clipboard?.writeText) {
            await navigator.clipboard.writeText(value);
            return true;
        }

        const textarea = document.createElement('textarea');
        textarea.value = value;
        textarea.style.position = 'fixed';
        textarea.style.opacity = '0';
        document.body.appendChild(textarea);
        textarea.focus();
        textarea.select();
        const success = document.execCommand('copy');
        textarea.remove();
        return success;
    };

    document.addEventListener('click', (event) => {
        const button = event.target.closest('[data-copy-value]');
        if (!button) {
            return;
        }

        const value = button.dataset.copyValue;
        if (!value) {
            return;
        }

        const originalText = button.dataset.copyOriginal ?? button.textContent?.trim() ?? '';
        button.dataset.copyOriginal = originalText;

        copyText(value).then((success) => {
            if (!success) {
                return;
            }
            button.textContent = '{{ t('customer_copy_success', page_locale()) }}';
            window.setTimeout(() => {
                button.textContent = originalText;
            }, 1200);
        }).catch(() => {
            return;
        });
    });

    (() => {
        const body = document.body;
        const toggles = document.querySelectorAll('.ng-sidebar-toggle');
        const backdrop = document.querySelector('[data-sidebar-backdrop]');
        if (toggles.length === 0) {
            return;
        }
        const toggleSidebar = () => {
            if (window.matchMedia('(max-width: 768px)').matches) {
                body.classList.toggle('is-sidebar-open');
                return;
            }
            body.classList.toggle('is-sidebar-collapsed');
        };
        toggles.forEach((toggle) => toggle.addEventListener('click', toggleSidebar));
        if (backdrop) {
            backdrop.addEventListener('click', () => body.classList.remove('is-sidebar-open'));
        }
        window.addEventListener('resize', () => {
            if (!window.matchMedia('(max-width: 768px)').matches) {
                body.classList.remove('is-sidebar-open');
            }
        });
        window.addEventListener('keydown', (event) => {
            if (event.key === 'Escape') {
                body.classList.remove('is-sidebar-open');
            }
        });

        const userMenuToggle = document.querySelector('[data-user-menu-toggle]');
        const userMenu = document.querySelector('[data-user-menu]');
        if (userMenuToggle && userMenu) {
            userMenuToggle.addEventListener('click', () => {
                userMenu.open = !userMenu.open;
            });
        }
    })();
</script>
</body>
</html>
