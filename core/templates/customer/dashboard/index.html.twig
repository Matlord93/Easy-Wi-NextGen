{% extends 'customer/base.html.twig' %}

{% set profileUser = current_user() %}
{% set customerName = profileUser and profileUser.name ? profileUser.name : (profileUser ? profileUser.email : 'Customer') %}
{% set customerEmail = profileUser ? profileUser.email : '' %}
{% set customerInitial = customerName|slice(0, 1)|upper %}
{% set pageTitle = '' %}
{% set pageSubtitle = '' %}
{% set topbarActions = [{
    label: t('customer_dashboard_action_order', page_locale()),
    href: '/shop',
    variant: 'primary'
}] %}

{% block content %}
{% set storagePercent = resourceUsage.disk %}
{% set billingEnabled = module_enabled('billing') %}
{% set invoiceStatusLabels = {
    'open': t('customer_dashboard_invoice_status_open', page_locale()),
    'past_due': t('customer_dashboard_invoice_status_past_due', page_locale()),
    'paid': t('customer_dashboard_invoice_status_paid', page_locale())
} %}
{% set nextPaymentAmount = nextPayment ? (nextPayment.amount_due / 100)|number_format(2, ',', '.') ~ ' ' ~ nextPayment.currency : '—' %}

<div class="customer-dashboard customer-dashboard--revamp flex flex-col gap-6">

    <div>
        <h2 class="text-3xl font-semibold text-slate-100">{{ t('customer_dashboard_title', page_locale()) }}</h2>
        <p class="mt-2 text-base text-slate-400">{{ t('customer_dashboard_subtitle', page_locale()) }}</p>
    </div>

    <section class="dashboard-stats">
        <article class="dashboard-stat dashboard-stat--contract">
            <div class="dashboard-stat__headline">{{ t('customer_dashboard_contract_title', page_locale()) }}</div>
            {% if billingEnabled and activePlan %}
                <div class="dashboard-stat__value">{{ activePlan.name }}</div>
                <p class="dashboard-stat__meta">
                    {{ t('customer_dashboard_next_payment_label', page_locale()) }} {{ nextPaymentAmount }}
                </p>
            {% else %}
                <div class="dashboard-stat__value">{{ t('customer_dashboard_contract_unavailable', page_locale()) }}</div>
            {% endif %}
        </article>

        <article class="dashboard-stat dashboard-stat--storage">
            <div class="dashboard-stat__topline">
                <span>{{ t('customer_dashboard_usage_title', page_locale()) }}</span>
                <strong>{{ storagePercent|number_format(1, '.', ',') }}%</strong>
            </div>
            <div class="dashboard-stat__meter">
                <div style="width: {{ storagePercent }}%"></div>
            </div>
            <p class="dashboard-stat__meta">
                {% if resourceUsage.disk_limit_human %}
                    {{ resourceUsage.disk_used_human }} / {{ resourceUsage.disk_limit_human }}
                {% else %}
                    {{ t('customer_dashboard_storage_hint', page_locale()) }}
                {% endif %}
            </p>
        </article>

        <article class="dashboard-stat dashboard-stat--tickets">
            <div class="dashboard-stat__topline">
                <span>{{ t('customer_dashboard_ticket_title', page_locale()) }}</span>
                <strong>{{ summary.tickets_open }}</strong>
            </div>
            <div class="dashboard-stat__meter">
                {% set ticketPercent = summary.tickets_total > 0 ? ((summary.tickets_open / summary.tickets_total) * 100)|round(0, 'common') : 0 %}
                <div style="width: {{ ticketPercent }}%"></div>
            </div>
            <p class="dashboard-stat__meta">
                {{ summary.tickets_pending }} {{ t('customer_dashboard_ticket_pending', page_locale()) }} · {{ summary.tickets_total }} {{ t('customer_dashboard_ticket_total', page_locale()) }}
            </p>
        </article>
    </section>

    <section class="dashboard-main-grid">
        <div class="dashboard-panel">
            <div class="dashboard-panel__header">
                <div>
                    <h3>{{ t('customer_dashboard_servers_title', page_locale()) }}</h3>
                    <p>{{ t('customer_dashboard_servers_subtitle', page_locale()) }}</p>
                </div>
                <a href="{{ path('customer_instances') }}" class="ui-button ui-button--ghost">{{ t('customer_dashboard_view_all', page_locale()) }}</a>
            </div>

            <div class="server-grid">
                    {% for slot in 0..3 %}
                        {% set instance = instances[slot] ?? null %}
                        {% if instance %}
                        {% set statusTone = instance.status in ['running', 'online'] ? 'success' : (instance.status in ['stopped', 'offline'] ? 'danger' : 'warning') %}
                        <article class="server-card">
                            <div class="server-card__top">
                                <div>
                                    <h4>{{ instance.server_name ?: instance.name }}</h4>
                                    <p>#{{ instance.id }} · {{ instance.game_key }}</p>
                                </div>
                                {% include 'components/ui/_badge.html.twig' with { label: instance.status_label, tone: statusTone } %}
                            </div>
                            <div class="server-card__meta">
                                <span>{{ t('customer_dashboard_server_ping', page_locale()) }}: {{ instance.latency_ms is not null ? instance.latency_ms ~ ' ms' : '—' }}</span>
                                <span>CPU: {{ instance.cpu_percent is not null ? instance.cpu_percent|number_format(1, '.', ',') ~ '%' : t('customer_instance_unknown_pending', page_locale()) }}</span>
                                <span>RAM: {% if instance.mem_used_bytes is not null %}{{ (instance.mem_used_bytes / 1024 / 1024)|number_format(0, '.', ',') }} MiB / {{ instance.ram_limit ?? '—' }} MiB{% else %}{{ t('customer_instance_unknown_pending', page_locale()) }}{% endif %}</span>
                            </div>
                            <div class="server-card__actions">
                                <form method="post" action="{{ path('customer_instance_power', {id: instance.id}) }}">
                                    <input type="hidden" name="action" value="start">
                                    <button class="ui-button ui-button--primary">{{ t('customer_dashboard_server_start', page_locale()) }}</button>
                                </form>
                                <form method="post" action="{{ path('customer_instance_power', {id: instance.id}) }}">
                                    <input type="hidden" name="action" value="stop">
                                    <button class="ui-button ui-button--danger">{{ t('customer_dashboard_server_stop', page_locale()) }}</button>
                                </form>
                                <form method="post" action="{{ path('customer_instance_power', {id: instance.id}) }}">
                                    <input type="hidden" name="action" value="restart">
                                    <button class="ui-button ui-button--ghost">{{ t('customer_dashboard_server_restart', page_locale()) }}</button>
                                </form>
                            </div>
                        </article>
                    {% else %}
                        <article class="server-card server-card--placeholder">
                            <div class="server-card__top"><div><h4>{{ t('customer_dashboard_no_instances', page_locale()) }}</h4><p>Slot {{ slot + 1 }}</p></div></div>
                            <div class="server-card__meta"><span>—</span></div>
                        </article>
                        {% endif %}
                    {% endfor %}
                </div>
        </div>

        <aside class="dashboard-usage-panel">
            <h3>{{ t('customer_dashboard_usage_title', page_locale()) }}</h3>
            <p>{{ t('customer_dashboard_usage_subtitle', page_locale()) }}</p>
            <div class="dashboard-usage-list">
                {% for instance in instances %}
                    <article class="dashboard-usage-item">
                        <div class="dashboard-usage-item__head">
                            <strong>{{ instance.server_name ?: instance.name }}</strong>
                            <span>#{{ instance.id }}</span>
                        </div>
                        <ul>
                            <li>
                                <span>{{ t('customer_dashboard_cpu_usage', page_locale()) }}</span>
                                <strong>{{ instance.cpu_percent is not null ? instance.cpu_percent|number_format(1, '.', ',') ~ '%' : t('customer_resource_unknown', page_locale()) }}</strong>
                            </li>
                            <li>
                                <span>{{ t('customer_dashboard_ram_usage', page_locale()) }}</span>
                                <strong>{% if instance.mem_used_bytes is not null %}{{ (instance.mem_used_bytes / 1024 / 1024)|number_format(0, '.', ',') }} MiB / {{ instance.ram_limit ?? '—' }} MiB{% else %}{{ t('customer_resource_unknown', page_locale()) }}{% endif %}</strong>
                            </li>
                            <li>
                                <span>{{ t('customer_dashboard_disk_usage', page_locale()) }}</span>
                                <strong>{% if instance.disk_limit_human %}{{ instance.disk_used_human }} / {{ instance.disk_limit_human }}{% else %}{{ instance.disk_used_human }}{% endif %}{% if instance.disk_usage_percent is not null %} ({{ instance.disk_usage_percent|number_format(1, '.', ',') }}%){% endif %}</strong>
                            </li>
                        </ul>
                    </article>
                {% else %}
                    <div class="dashboard-usage-empty">{{ t('customer_dashboard_usage_empty', page_locale()) }}</div>
                {% endfor %}
            </div>
        </aside>
    </section>

    {% if billingEnabled %}
        <section class="dashboard-panel">
            <div class="dashboard-panel__header">
                <div>
                    <h3>{{ t('customer_dashboard_invoice_title', page_locale()) }}</h3>
                    <p>{{ t('customer_dashboard_invoice_subtitle', page_locale()) }}</p>
                </div>
                <a href="{{ path('customer_profile') }}" class="ui-button ui-button--ghost">{{ t('customer_dashboard_invoice_action', page_locale()) }}</a>
            </div>

            <div class="dashboard-table-wrapper">
                <table class="dashboard-table">
                    <thead>
                    <tr>
                        <th>{{ t('customer_dashboard_invoice_table_name', page_locale()) }}</th>
                        <th>{{ t('customer_dashboard_invoice_table_date', page_locale()) }}</th>
                        <th>{{ t('customer_dashboard_invoice_table_amount', page_locale()) }}</th>
                        <th>{{ t('customer_dashboard_invoice_table_status', page_locale()) }}</th>
                        <th>{{ t('customer_dashboard_invoice_table_action', page_locale()) }}</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for invoice in invoices %}
                        {% set statusTone = invoice.status == 'paid' ? 'success' : (invoice.status == 'past_due' ? 'danger' : 'warning') %}
                        {% set statusLabel = invoiceStatusLabels[invoice.status] ?? invoice.status %}
                        <tr>
                            <td>{{ invoice.number }}</td>
                            <td>{{ invoice.due_date|date('Y-m-d') }}</td>
                            <td>{{ (invoice.amount_due / 100)|number_format(2, ',', '.') }} {{ invoice.currency }}</td>
                            <td>{% include 'components/ui/_badge.html.twig' with { label: statusLabel, tone: statusTone } %}</td>
                            <td><a href="{{ path('customer_profile') }}" class="ui-button ui-button--ghost">{{ t('customer_dashboard_invoice_action', page_locale()) }}</a></td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="5" class="dashboard-table__empty">{{ t('customer_dashboard_invoice_empty', page_locale()) }}</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </section>
    {% endif %}
</div>
{% endblock %}
