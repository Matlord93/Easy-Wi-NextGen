{% extends 'customer/base.html.twig' %}

{% block content %}
<div class="customer-section-gradient flex flex-col gap-6">
    <div class="rounded-2xl border border-indigo-100 bg-gradient-to-r from-indigo-600 via-violet-600 to-sky-500 px-6 py-6 text-white shadow-sm">
        <h1 class="text-2xl font-semibold">{{ t('customer_databases_title', page_locale()) }}</h1>
        <p class="mt-2 text-sm text-indigo-100">{{ t('customer_databases_description', page_locale()) }}</p>
    </div>

    {% if errors is defined and errors is not empty %}
        <div class="rounded-xl border border-rose-200 bg-rose-50 px-6 py-4 text-sm text-rose-700">
            <ul class="list-disc space-y-1 pl-5">
                {% for error in errors %}
                    <li>{{ error }}</li>
                {% endfor %}
            </ul>
        </div>
    {% endif %}

    <div class="grid gap-6 lg:grid-cols-[minmax(0,0.85fr)_minmax(0,1.15fr)]">
        <div class="rounded-xl border border-slate-200 bg-white shadow-sm">
            <div class="border-b border-slate-200 px-5 py-4">
                <h2 class="text-lg font-semibold text-slate-900">{{ t('customer_databases_create_title', page_locale()) }}</h2>
                <p class="text-sm text-slate-700">{{ t('customer_databases_create_description', page_locale()) }}</p>
            </div>
            <form method="post" action="/databases" class="space-y-4 px-5 py-4">
                <p class="text-xs text-slate-500">
                    {{ t('customer_databases_limit_label', page_locale()) }}:
                    {{ databaseLimit > 0 ? databaseCount ~ '/' ~ databaseLimit : t('customer_databases_limit_unlimited', page_locale()) }}
                </p>
                <div>
                    <label class="text-xs font-semibold uppercase text-slate-700">{{ t('customer_databases_node_label', page_locale()) }}</label>
                    <select name="node_id" class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm" required>
                        <option value="">{{ t('customer_databases_node_placeholder', page_locale()) }}</option>
                        {% for node in databaseNodes %}
                            <option value="{{ node.id }}">{{ node.name }} ({{ node.engine|upper }} · {{ node.host }}:{{ node.port }})</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="grid gap-3 sm:grid-cols-2">
                    <div>
                        <label class="text-xs font-semibold uppercase text-slate-700">{{ t('customer_databases_name_label', page_locale()) }}</label>
                        <input type="text" name="name" class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm" required>
                    </div>
                    <div>
                        <label class="text-xs font-semibold uppercase text-slate-700">{{ t('customer_databases_user_label', page_locale()) }}</label>
                        <input type="text" name="username" class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm" required>
                    </div>
                </div>
                <div>
                    <label class="text-xs font-semibold uppercase text-slate-700">{{ t('customer_databases_password_label', page_locale()) }}</label>
                    <input type="password" name="password" minlength="8" class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm" required>
                </div>
                <button type="submit" class="w-full rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-500" {{ limitReached or databaseNodes is empty ? 'disabled' : '' }}>
                    {{ limitReached ? t('customer_databases_limit_reached', page_locale()) : t('customer_databases_create_action', page_locale()) }}
                </button>
            </form>
        </div>

        <div class="space-y-4">
            <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
                <h2 class="text-lg font-semibold text-slate-900">{{ t('customer_instances_data_area', page_locale()) }}</h2>
                <p class="mt-1 text-sm text-slate-700">{{ t('customer_databases_overview_description', page_locale()) }}</p>
                <div class="mt-3 grid gap-3 md:grid-cols-2">
                    <div class="rounded-lg border border-slate-200 bg-slate-50 p-3 text-sm text-slate-700"><span class="block text-xs text-slate-500">{{ t('customer_instances_sftp_access', page_locale()) }}</span>{{ t('customer_instances_access_in_filemanager', page_locale()) }}</div>
                    <div class="rounded-lg border border-slate-200 bg-slate-50 p-3 text-sm text-slate-700"><span class="block text-xs text-slate-500">{{ t('customer_instances_ftp_access', page_locale()) }}</span>{{ t('customer_instances_access_in_filemanager', page_locale()) }}</div>
                </div>
            </div>

            <div class="rounded-xl border border-slate-200 bg-white shadow-sm">
                <div class="flex items-center justify-between border-b border-slate-200 px-5 py-4">
                    <div>
                        <h2 class="text-lg font-semibold text-slate-900">{{ t('customer_databases_overview', page_locale()) }}</h2>
                        <p class="text-sm text-slate-700">{{ t('customer_databases_overview_description', page_locale()) }}</p>
                    </div>
                </div>
                {% if databases is empty %}
                    <div class="px-5 py-6 text-sm text-slate-700">{{ t('customer_databases_empty', page_locale()) }}</div>
                {% else %}
                    <div class="grid gap-3 p-4">
                        {% for database in databases %}
                            <article class="rounded-xl border border-slate-200 bg-gradient-to-br from-white to-slate-50 p-4">
                                <div class="flex flex-wrap items-start justify-between gap-3">
                                    <div>
                                        <h3 class="text-base font-semibold text-slate-900">{{ database.name }}</h3>
                                        <p class="text-xs text-slate-500">ID {{ database.id }} · {{ database.engine|upper }}</p>
                                    </div>
                                    <form method="post" action="/databases/{{ database.id }}/delete">
                                        <button class="rounded-lg border border-rose-200 px-3 py-2 text-xs font-semibold text-rose-700 hover:bg-rose-50">{{ t('customer_databases_delete', page_locale()) }}</button>
                                    </form>
                                </div>
                                <div class="mt-3 grid gap-2 text-sm text-slate-700 md:grid-cols-2">
                                    <div><span class="text-slate-500">{{ t('customer_databases_table_host', page_locale()) }}:</span> {{ database.host }}:{{ database.port }}</div>
                                    <div><span class="text-slate-500">{{ t('customer_databases_table_user', page_locale()) }}:</span> {{ database.username }}</div>
                                    <div><span class="text-slate-500">{{ t('customer_databases_table_node', page_locale()) }}:</span> {{ database.node ? database.node.name : t('customer_databases_node_unassigned', page_locale()) }}</div>
                                    <div><span class="text-slate-500">{{ t('customer_databases_table_updated', page_locale()) }}:</span> {{ database.updated_at|date('Y-m-d H:i') }}</div>
                                </div>
                            </article>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}
