{% extends 'customer/base.html.twig' %}

{% set activeNav = 'databases' %}

{% block content %}
{% set locale = page_locale() %}
<div class="cust-page">

    {# ── Hero ── #}
    <div class="cust-hero">
        <div class="cust-hero__inner">
            <div>
                <div class="cust-hero__label">{{ t('customer_databases_hero_label', locale) }}</div>
                <h1 class="cust-hero__title">{{ t('customer_databases_title', locale) }}</h1>
                <p class="cust-hero__desc">{{ t('customer_databases_description', locale) }}</p>
            </div>
        </div>
        <div class="cust-hero__stats" style="grid-template-columns:repeat(2,1fr);max-width:320px;">
            <div class="cust-hero__stat">
                <div class="cust-hero__stat-label">{{ t('customer_databases_overview', locale) }}</div>
                <div class="cust-hero__stat-value">{{ databases|length }}</div>
                <div class="cust-hero__stat-sub">{{ t('customer_databases_hero_intro', locale) }}</div>
            </div>
            <div class="cust-hero__stat">
                <div class="cust-hero__stat-label">{{ t('customer_databases_limit_label', locale) }}</div>
                <div class="cust-hero__stat-value">{{ databaseLimit > 0 ? databaseCount ~ '/' ~ databaseLimit : '∞' }}</div>
                <div class="cust-hero__stat-sub">{{ t('customer_databases_limit_unlimited', locale) }}</div>
            </div>
        </div>
    </div>

    {# ── Errors ── #}
    {% if errors is defined and errors is not empty %}
        <div class="cust-alert cust-alert--error">
            <ul style="margin:0;padding-left:18px;">
                {% for error in errors %}
                    <li>{{ error }}</li>
                {% endfor %}
            </ul>
        </div>
    {% endif %}

    {# ── Create + Overview ── #}
    <div class="cust-grid-2">
        {# Create form #}
        <div class="cust-form-card">
            <div class="cust-form-card__head">
                <h3 class="cust-form-card__title">{{ t('customer_databases_create_title', locale) }}</h3>
                <p class="cust-form-card__sub">{{ t('customer_databases_create_description', locale) }}</p>
            </div>
            <form method="post" action="/databases" class="cust-form-card__body">
                <div>
                    <label class="cust-form-label">{{ t('customer_databases_node_label', locale) }}</label>
                    <select name="node_id" required>
                        <option value="">{{ t('customer_databases_node_placeholder', locale) }}</option>
                        {% for node in databaseNodes %}
                            <option value="{{ node.id }}">{{ node.name }} ({{ node.engine|upper }} · {{ node.host }}:{{ node.port }})</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="cust-form-row">
                    <div>
                        <label class="cust-form-label">{{ t('customer_databases_name_label', locale) }}</label>
                        <input type="text" name="name" required>
                    </div>
                    <div>
                        <label class="cust-form-label">{{ t('customer_databases_user_label', locale) }}</label>
                        <input type="text" name="username" required>
                    </div>
                </div>
                <div>
                    <label class="cust-form-label">{{ t('customer_databases_password_label', locale) }}</label>
                    <input type="password" name="password" minlength="8" required>
                </div>
                <button type="submit" class="ui-button ui-button--primary" style="width:100%;" {{ limitReached or databaseNodes is empty ? 'disabled' : '' }}>
                    {{ limitReached ? t('customer_databases_limit_reached', locale) : t('customer_databases_create_action', locale) }}
                </button>
            </form>
        </div>

        {# Data area info #}
        <div class="cust-panel">
            <div class="cust-panel__head">
                <div>
                    <h3 class="cust-panel__title">{{ t('customer_instances_data_area', locale) }}</h3>
                    <p class="cust-panel__sub">{{ t('customer_databases_overview_description', locale) }}</p>
                </div>
            </div>
            <div class="cust-panel__body">
                <div style="display:flex;flex-direction:column;gap:8px;">
                    <div style="padding:12px;border-radius:8px;border:1px solid var(--ng-border);background:var(--ng-surface-soft);">
                        <span style="display:block;font-size:11px;color:var(--ng-text-muted);">{{ t('customer_instances_sftp_access', locale) }}</span>
                        <span style="font-size:13px;color:var(--ng-text);">{{ t('customer_instances_access_in_filemanager', locale) }}</span>
                    </div>
                    <div style="padding:12px;border-radius:8px;border:1px solid var(--ng-border);background:var(--ng-surface-soft);">
                        <span style="display:block;font-size:11px;color:var(--ng-text-muted);">{{ t('customer_instances_ftp_access', locale) }}</span>
                        <span style="font-size:13px;color:var(--ng-text);">{{ t('customer_instances_access_in_filemanager', locale) }}</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# ── Database list ── #}
    <div class="cust-panel">
        <div class="cust-panel__head">
            <div>
                <h3 class="cust-panel__title">{{ t('customer_databases_overview', locale) }}</h3>
                <p class="cust-panel__sub">{{ t('customer_databases_overview_description', locale) }}</p>
            </div>
        </div>
        <div class="cust-panel__body">
            {% if databases is empty %}
                <div class="cust-empty">{{ t('customer_databases_empty', locale) }}</div>
            {% else %}
                <div style="display:flex;flex-direction:column;gap:12px;">
                    {% for database in databases %}
                        <div style="border:1px solid var(--ng-border);border-radius:10px;padding:16px;background:var(--ng-surface);">
                            <div style="display:flex;flex-wrap:wrap;align-items:flex-start;justify-content:space-between;gap:12px;">
                                <div>
                                    <div style="font-size:15px;font-weight:700;color:var(--ng-text);">{{ database.name }}</div>
                                    <div style="font-size:11px;color:var(--ng-text-muted);margin-top:2px;">ID {{ database.id }} · {{ database.engine|upper }}</div>
                                </div>
                                <form method="post" action="/databases/{{ database.id }}/delete">
                                    <button class="ui-button ui-button--danger ui-button--sm">{{ t('customer_databases_delete', locale) }}</button>
                                </form>
                            </div>
                            <div style="margin-top:12px;display:grid;gap:6px;font-size:13px;color:var(--ng-text);grid-template-columns:repeat(2,1fr);">
                                <div><span style="color:var(--ng-text-muted);">{{ t('customer_databases_table_host', locale) }}:</span> {{ database.host }}:{{ database.port }}</div>
                                <div><span style="color:var(--ng-text-muted);">{{ t('customer_databases_table_user', locale) }}:</span> {{ database.username }}</div>
                                <div><span style="color:var(--ng-text-muted);">{{ t('customer_databases_table_node', locale) }}:</span> {{ database.node ? database.node.name : t('customer_databases_node_unassigned', locale) }}</div>
                                <div><span style="color:var(--ng-text-muted);">{{ t('customer_databases_table_updated', locale) }}:</span> {{ database.updated_at|date('Y-m-d H:i') }}</div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}
        </div>
    </div>

</div>
{% endblock %}
