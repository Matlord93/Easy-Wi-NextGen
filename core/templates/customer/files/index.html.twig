{% extends 'customer/base.html.twig' %}

{% block content %}
    <div class="space-y-6">
        <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <div class="flex flex-wrap items-center justify-between gap-3">
                <div>
                    <h1 class="text-xl font-semibold text-slate-900">Dateimanager</h1>
                    <p class="text-sm text-slate-600">SFTP-basierter Zugriff auf das konfigurierte Root-Verzeichnis.</p>
                </div>
                <form method="post" action="{{ path('customer_files_test_connection') }}" class="flex items-center gap-2">
                    <input type="hidden" name="webspace" value="{{ selectedWebspace.id }}">
                    <input type="hidden" name="path" value="{{ currentPath }}">
                    <button type="submit" class="rounded-lg border border-slate-200 px-3 py-2 text-xs font-semibold text-slate-700 hover:border-indigo-200 hover:text-indigo-600">
                        Verbindung testen
                    </button>
                </form>
            </div>

            <div class="mt-4 space-y-2">
                {% for message in app.flashes('success') %}
                    <div class="rounded-lg border border-emerald-200 bg-emerald-50 px-4 py-2 text-sm text-emerald-700">{{ message }}</div>
                {% endfor %}
                {% for message in app.flashes('error') %}
                    <div class="rounded-lg border border-rose-200 bg-rose-50 px-4 py-2 text-sm text-rose-700">{{ message }}</div>
                {% endfor %}
                {% for result in app.flashes('sftp_test') %}
                    <div class="rounded-lg border {{ result.status == 'ok' ? 'border-emerald-200 bg-emerald-50 text-emerald-700' : 'border-rose-200 bg-rose-50 text-rose-700' }} px-4 py-2 text-sm">
                        <p class="font-semibold">{{ result.message }}</p>
                        {% if result.entries is not empty %}
                            <p class="mt-1 text-xs">Beispieleinträge: {{ result.entries|join(', ') }}</p>
                        {% endif %}
                    </div>
                {% endfor %}
                {% if listError %}
                    <div class="rounded-lg border border-rose-200 bg-rose-50 px-4 py-2 text-sm text-rose-700">
                        Listing fehlgeschlagen: {{ listError }}
                    </div>
                {% endif %}
            </div>
        </section>

        <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            {% if webspaces is not empty %}
                <form method="get" action="{{ path('customer_files_browse') }}" class="mb-4 flex flex-wrap items-end gap-3">
                    <div>
                        <label class="text-xs font-semibold uppercase text-slate-500">Webspace</label>
                        <select name="webspace" class="mt-2 rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm">
                            {% for webspace in webspaces %}
                                <option value="{{ webspace.id }}" {{ webspace.id == selectedWebspace.id ? 'selected' : '' }}>
                                    {{ webspace.domain }} ({{ webspace.system_username }})
                                </option>
                            {% endfor %}
                        </select>
                    </div>
                    <div>
                        <label class="text-xs font-semibold uppercase text-slate-500">Pfad</label>
                        <input type="text" name="path" value="{{ currentPath }}" class="mt-2 rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm" placeholder="/">
                    </div>
                    <button type="submit" class="rounded-lg bg-indigo-600 px-3 py-2 text-xs font-semibold text-white hover:bg-indigo-700">Öffnen</button>
                </form>
            {% endif %}
            <div class="flex flex-wrap items-center justify-between gap-3">
                <div>
                    <h2 class="text-lg font-semibold text-slate-900">Pfad</h2>
                    <p class="text-sm text-slate-600">Aktuelles Verzeichnis: <span class="font-mono text-slate-900">{{ currentPath ?: '/' }}</span></p>
                </div>
            </div>

            <nav class="mt-3 flex flex-wrap items-center gap-2 text-sm">
                {% for crumb in breadcrumbs %}
                    <a href="{{ path('customer_files_browse', { path: crumb.path, webspace: selectedWebspace.id }) }}" class="text-indigo-600 hover:text-indigo-800">
                        {{ crumb.label }}
                    </a>
                    {% if not loop.last %}
                        <span class="text-slate-400">/</span>
                    {% endif %}
                {% endfor %}
            </nav>

            <div class="mt-6 grid gap-4 md:grid-cols-[1fr_280px]">
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-slate-200 text-sm">
                        <thead class="bg-slate-50 text-left text-xs uppercase tracking-wide text-slate-500">
                            <tr>
                                <th class="px-3 py-2">Name</th>
                                <th class="px-3 py-2">Typ</th>
                                <th class="px-3 py-2">Größe</th>
                                <th class="px-3 py-2">Geändert</th>
                                <th class="px-3 py-2 text-right">Aktionen</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100">
                            {% if entries is empty %}
                                <tr>
                                    <td colspan="5" class="px-3 py-6 text-center text-slate-500">Keine Einträge gefunden.</td>
                                </tr>
                            {% endif %}
                            {% for entry in entries %}
                                <tr>
                                    <td class="px-3 py-2">
                                        {% if entry.type == 'dir' %}
                                            <a href="{{ path('customer_files_browse', { path: entry.path, webspace: selectedWebspace.id }) }}" class="font-semibold text-indigo-600 hover:text-indigo-800">{{ entry.name }}/</a>
                                        {% else %}
                                            <span class="font-mono">{{ entry.name }}</span>
                                        {% endif %}
                                    </td>
                                    <td class="px-3 py-2">{{ entry.type == 'dir' ? 'Ordner' : 'Datei' }}</td>
                                    <td class="px-3 py-2">{{ entry.size is not null ? entry.size|number_format(0, ',', '.') ~ ' B' : '-' }}</td>
                                    <td class="px-3 py-2">{{ entry.last_modified ? entry.last_modified|date('Y-m-d H:i') : '-' }}</td>
                                    <td class="px-3 py-2 text-right">
                                        <div class="flex flex-wrap justify-end gap-2">
                                            {% if entry.type == 'file' %}
                                                <a href="{{ path('customer_files_download', { path: entry.path, webspace: selectedWebspace.id }) }}" class="rounded-lg border border-slate-200 px-2 py-1 text-xs font-semibold text-slate-700 hover:border-indigo-200 hover:text-indigo-600">Download</a>
                                                {% if entry.editable %}
                                                    <a href="{{ path('customer_files_edit', { path: entry.path, webspace: selectedWebspace.id }) }}" class="rounded-lg border border-slate-200 px-2 py-1 text-xs font-semibold text-slate-700 hover:border-indigo-200 hover:text-indigo-600">Edit</a>
                                                {% endif %}
                                            {% endif %}
                                            <a href="{{ path('customer_files_rename', { path: entry.path, webspace: selectedWebspace.id }) }}" class="rounded-lg border border-slate-200 px-2 py-1 text-xs font-semibold text-slate-700 hover:border-indigo-200 hover:text-indigo-600">Rename</a>
                                            <form method="post" action="{{ path('customer_files_delete') }}" onsubmit="return confirm('Eintrag wirklich löschen?');">
                                                <input type="hidden" name="webspace" value="{{ selectedWebspace.id }}">
                                                <input type="hidden" name="path" value="{{ entry.path }}">
                                                <button type="submit" class="rounded-lg border border-rose-200 px-2 py-1 text-xs font-semibold text-rose-600 hover:border-rose-300">Delete</button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
                <div class="rounded-xl border border-slate-200 bg-slate-50 p-4">
                    <h3 class="text-sm font-semibold text-slate-900">Upload</h3>
                    {% if uploadForm %}
                        {{ form_start(uploadForm, { attr: { class: 'mt-3 space-y-3' } }) }}
                            <input type="hidden" name="webspace" value="{{ selectedWebspace.id }}">
                            {{ form_widget(uploadForm.path) }}
                            {{ form_row(uploadForm.upload) }}
                            <button type="submit" class="w-full rounded-lg bg-indigo-600 px-3 py-2 text-xs font-semibold text-white hover:bg-indigo-700">Datei hochladen</button>
                        {{ form_end(uploadForm) }}
                    {% else %}
                        <p class="mt-3 text-xs text-slate-600">Kein Webspace verfügbar.</p>
                    {% endif %}
                </div>
            </div>
        </section>
    </div>
{% endblock %}
