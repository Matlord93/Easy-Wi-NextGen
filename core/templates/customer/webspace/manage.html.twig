{% extends 'customer/base.html.twig' %}
{% set activeNav = 'webspaces' %}
{% set locale = page_locale() %}

{% block content %}
<div class="cust-page">

    {# ── Flash messages ── #}
    {% if flashSuccess is defined and flashSuccess %}
        <div class="ng-alert ng-alert--success" style="margin-bottom:16px;">{{ t(flashSuccess, locale) }}</div>
    {% endif %}
    {% if flashError is defined and flashError %}
        <div class="ng-alert ng-alert--danger" style="margin-bottom:16px;">{{ t(flashError, locale) }}</div>
    {% endif %}

    {# ── Hero ── #}
    <div class="cust-hero">
        <div class="cust-hero__inner">
            <div>
                <div class="cust-hero__label">{{ t('customer_webspace_kicker', locale) }}</div>
                <h1 class="cust-hero__title">{{ t('customer_webspace_manage_title', locale) }}</h1>
                <p class="cust-hero__desc">{{ t('customer_webspace_manage_description', locale) }}</p>
            </div>
        </div>
    </div>

    {# ── Domain selector ── #}
    <div class="cust-panel">
        <div class="cust-panel__head">
            <div>
                <h3 class="cust-panel__title">{{ t('customer_webspace_manage_select_title', locale) }}</h3>
                <p class="cust-panel__sub">{{ t('customer_webspace_manage_select_description', locale) }}</p>
            </div>
        </div>
        <div class="cust-panel__body">
            <form method="get" action="/webspace/manage" style="display:flex;flex-wrap:wrap;align-items:flex-end;gap:12px;">
                <div style="flex:1;min-width:220px;">
                    <label class="form-label">{{ t('customer_webspace_manage_domain_label', locale) }}</label>
                    <select name="domain_id" class="form-input" required>
                        <option value="">{{ t('customer_webspace_manage_domain_placeholder', locale) }}</option>
                        {% for domain in domains %}
                            <option value="{{ domain.id }}" {% if selectedDomain and selectedDomain.id == domain.id %}selected{% endif %}>{{ domain.name }}</option>
                        {% endfor %}
                    </select>
                </div>
                <button type="submit" class="ui-button ui-button--primary">
                    {{ t('customer_webspace_manage_select_action', locale) }}
                </button>
            </form>
        </div>
    </div>

    {% if selectedDomain and webspace %}

        {# ── Overview ── #}
        <div class="cust-panel">
            <div class="cust-panel__head">
                <div>
                    <h3 class="cust-panel__title">{{ t('customer_webspace_manage_overview_title', locale) }}</h3>
                    <p class="cust-panel__sub">{{ t('customer_webspace_manage_overview_description', locale) }}</p>
                </div>
                <span class="ui-badge ui-badge--info">{{ selectedDomain.name }}</span>
            </div>
            <div class="cust-panel__body">
                <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:12px;">
                    <div style="padding:14px;border-radius:8px;border:1px solid var(--ng-border);background:var(--ng-surface-soft);">
                        <p style="font-size:11px;text-transform:uppercase;color:var(--ng-text-muted);">{{ t('customer_webspace_manage_webroot_label', locale) }}</p>
                        <p style="margin:6px 0 0;font-weight:700;color:var(--ng-text);font-size:13px;">{{ webspace.path }}</p>
                        <p style="margin:4px 0 0;font-size:11px;color:var(--ng-text-muted);">{{ t('customer_webspace_manage_webroot_hint', locale) }}</p>
                    </div>
                    <div style="padding:14px;border-radius:8px;border:1px solid var(--ng-border);background:var(--ng-surface-soft);">
                        <p style="font-size:11px;text-transform:uppercase;color:var(--ng-text-muted);">{{ t('customer_webspace_manage_docroot_label', locale) }}</p>
                        <p style="margin:6px 0 0;font-weight:700;color:var(--ng-text);font-size:13px;">{{ webspace.docroot }}</p>
                        <p style="margin:4px 0 0;font-size:11px;color:var(--ng-text-muted);">{{ t('customer_webspace_manage_docroot_hint', locale) }}</p>
                    </div>
                    <div style="padding:14px;border-radius:8px;border:1px solid var(--ng-border);background:var(--ng-surface-soft);">
                        <p style="font-size:11px;text-transform:uppercase;color:var(--ng-text-muted);">{{ t('customer_webspace_manage_php_label', locale) }}</p>
                        <p style="margin:6px 0 0;font-weight:700;color:var(--ng-text);font-size:13px;">{{ webspace.php_version }}</p>
                        <p style="margin:4px 0 0;font-size:11px;color:var(--ng-text-muted);">{{ t('customer_webspace_manage_subdomain_hint', locale) }}</p>
                    </div>
                </div>
            </div>
        </div>

        {# ── Domains & SSL table ── #}
        <div id="ssl" class="cust-panel">
            <div class="cust-panel__head">
                <div>
                    <h3 class="cust-panel__title">Domains & SSL</h3>
                </div>
            </div>
            <div class="cust-panel__body" style="border-bottom:1px solid var(--ng-border);">
                <form method="post" action="/webspace/manage/domain/add" style="display:grid;grid-template-columns:2fr 1fr 1fr auto auto auto;gap:8px;align-items:end;">
                    <input type="hidden" name="webspace_id" value="{{ webspace.id }}">
                    <input class="form-input" name="fqdn" placeholder="new.example.com" required>
                    <select class="form-input" name="type">
                        <option value="domain">domain</option>
                        <option value="subdomain">subdomain</option>
                    </select>
                    <input class="form-input" name="target_path" placeholder="public">
                    <label class="form-label" style="white-space:nowrap;cursor:pointer;"><input type="checkbox" name="redirect_https" value="1"> HTTPS</label>
                    <label class="form-label" style="white-space:nowrap;cursor:pointer;"><input type="checkbox" name="redirect_www" value="1"> WWW</label>
                    <button {{ hasActiveWebspaceJob ? 'disabled' : '' }} class="ui-button ui-button--primary ui-button--sm">
                        {{ t('customer_webspace_domain_add_btn', locale) ?? 'Domain hinzufügen' }}
                    </button>
                    <div style="grid-column:1/-1;">
                        <label class="form-label" style="cursor:pointer;"><input type="checkbox" name="request_tls" value="1"> SSL direkt anfordern</label>
                    </div>
                </form>
            </div>
            <div class="cust-panel__body--flush cust-ws-table-wrap">
                <table class="cust-table">
                    <thead>
                        <tr>
                            <th>FQDN</th>
                            <th>{{ t('customer_domains_table_status', locale) }}</th>
                            <th>Apply</th>
                            <th>SSL</th>
                            <th>Redirects</th>
                            <th>{{ t('actions', locale) }}</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for domain in webspaceDomains %}
                        {% set running = hasActiveWebspaceJob or domain.apply_status == 'running' %}
                        {% set sslPending = domain.ssl_status in ['pending', 'renewing'] %}
                        {% set sslActive = domain.ssl_status in ['active', 'expires_soon'] %}
                        <tr>
                            <td>
                                <div style="font-weight:600;color:var(--ng-text);">{{ domain.name }}</div>
                                <div style="font-size:11px;color:var(--ng-text-muted);">{{ domain.type }}</div>
                            </td>
                            <td>
                                <span class="ui-badge ui-badge--{{ domain.status == 'failed' ? 'danger' : 'neutral' }}">{{ domain.status }}</span>
                            </td>
                            <td>
                                <span class="ui-badge ui-badge--{{ domain.apply_status == 'failed' ? 'danger' : 'info' }}">{{ domain.apply_status }}</span>
                            </td>
                            <td>
                                <span class="ui-badge ui-badge--{{ sslActive ? 'success' : 'warning' }}">{{ domain.ssl_status|replace({'_':' '}) }}</span>
                            </td>
                            <td style="font-size:12px;color:var(--ng-text-muted);">
                                {{ domain.redirect_https ? 'HTTPS ✓' : 'HTTPS –' }} · {{ domain.redirect_www ? 'WWW ✓' : 'WWW –' }}
                            </td>
                            <td>
                                <div style="display:flex;flex-wrap:wrap;gap:6px;">
                                    <form method="post" action="/webspace/manage/domain/apply">
                                        <input type="hidden" name="domain_id" value="{{ domain.id }}">
                                        <button {{ running ? 'disabled' : '' }} class="ui-button ui-button--ghost ui-button--sm">↻ Anwenden</button>
                                    </form>
                                    <form method="post" action="/webspace/manage/ssl">
                                        <input type="hidden" name="domain_id" value="{{ domain.id }}">
                                        <button {{ (running or sslPending or sslActive) ? 'disabled' : '' }} class="ui-button ui-button--primary ui-button--sm">SSL</button>
                                    </form>
                                    <form method="post" action="/webspace/manage/ssl/disable">
                                        <input type="hidden" name="domain_id" value="{{ domain.id }}">
                                        <button {{ (running or (not sslActive)) ? 'disabled' : '' }} class="ui-button ui-button--ghost ui-button--sm">SSL aus</button>
                                    </form>
                                    <form method="post" action="/webspace/manage/ssl/renew">
                                        <input type="hidden" name="domain_id" value="{{ domain.id }}">
                                        <button {{ (running or (not sslActive)) ? 'disabled' : '' }} class="ui-button ui-button--ghost ui-button--sm">SSL erneuern</button>
                                    </form>
                                    <form method="post" action="/webspace/manage/domain/delete"
                                          onsubmit="return confirm('{{ t('customer_webspace_domain_delete_confirm', locale) }}');">
                                        <input type="hidden" name="domain_id" value="{{ domain.id }}">
                                        <button {{ running ? 'disabled' : '' }} class="ui-button ui-button--danger ui-button--sm">{{ t('customer_webspace_domain_delete', locale) }}</button>
                                    </form>
                                </div>
                                <form method="post" action="/webspace/manage/domain/update" style="margin-top:8px;display:flex;flex-wrap:wrap;gap:8px;align-items:center;">
                                    <input type="hidden" name="domain_id" value="{{ domain.id }}">
                                    <input class="form-input" style="width:160px;" name="target_path" value="{{ domain.target_path }}" placeholder="target_path">
                                    <label class="form-label" style="cursor:pointer;"><input type="checkbox" name="redirect_https" value="1" {{ domain.redirect_https ? 'checked' : '' }}> HTTPS</label>
                                    <label class="form-label" style="cursor:pointer;"><input type="checkbox" name="redirect_www" value="1" {{ domain.redirect_www ? 'checked' : '' }}> WWW</label>
                                    <button {{ running ? 'disabled' : '' }} class="ui-button ui-button--ghost ui-button--sm">{{ t('customer_webspace_save', locale) }}</button>
                                </form>
                                {% if domain.last_error_code or domain.last_error_message %}
                                    <div style="margin-top:6px;font-size:11px;color:#f87171;">{{ domain.last_error_code }} {{ domain.last_error_message }}</div>
                                {% endif %}
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>

        {# ── Homepage + Subdomains ── #}
        <div class="cust-grid-2">
            <div class="cust-form-card">
                <div class="cust-form-card__head">
                    <h3 class="cust-form-card__title">{{ t('customer_webspace_manage_homepage_title', locale) }}</h3>
                    <p class="cust-form-card__sub">{{ t('customer_webspace_manage_homepage_description', locale) }}</p>
                </div>
                <form method="post" action="/webspace/manage/homepage" class="cust-form-card__body">
                    <div>
                        <label class="form-label">{{ t('customer_webspace_manage_homepage_label', locale) }}</label>
                        <select name="domain_id" class="form-input" required>
                            {% for domain in webspaceDomains %}
                                <option value="{{ domain.id }}" {% if webspace.domain == domain.name %}selected{% endif %}>{{ domain.name }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <button type="submit" class="ui-button ui-button--primary" style="width:100%;">
                        {{ t('customer_webspace_manage_homepage_action', locale) }}
                    </button>
                </form>
            </div>

            <div class="cust-panel">
                <div class="cust-panel__head">
                    <div>
                        <h3 class="cust-panel__title">{{ t('customer_webspace_manage_subdomains_title', locale) }}</h3>
                        <p class="cust-panel__sub">{{ t('customer_webspace_manage_subdomains_description', locale) }}</p>
                    </div>
                    <span class="ui-badge ui-badge--neutral">{{ selectedDomain.status }}</span>
                </div>
                <div class="cust-panel__body">
                    <form method="post" action="/webspace/manage/subdomains/add" style="display:flex;flex-direction:column;gap:12px;">
                        <input type="hidden" name="domain_id" value="{{ selectedDomain.id }}">
                        <div>
                            <label class="form-label">{{ t('customer_webspace_manage_subdomains_label', locale) }}</label>
                            <input type="text" name="subdomain" class="form-input" placeholder="www">
                            <p style="margin:4px 0 0;font-size:11px;color:var(--ng-text-muted);">{{ t('customer_webspace_manage_subdomains_hint', locale) }}</p>
                        </div>
                        <button type="submit" class="ui-button ui-button--primary" style="width:100%;">
                            {{ t('customer_webspace_manage_subdomains_action', locale) }}
                        </button>
                    </form>
                </div>
                {% if selectedDomain.server_aliases is not empty %}
                    <div class="cust-panel__body" style="border-top:1px solid var(--ng-border);">
                        <div style="display:flex;flex-wrap:wrap;gap:8px;">
                            {% for alias in selectedDomain.server_aliases %}
                                <div style="display:flex;align-items:center;gap:6px;padding:4px 10px;border-radius:999px;border:1px solid var(--ng-border);background:var(--ng-surface-soft);">
                                    <span style="font-size:13px;font-weight:600;color:var(--ng-text);">{{ alias }}</span>
                                    <form method="post" action="/webspace/manage/subdomains/remove">
                                        <input type="hidden" name="domain_id" value="{{ selectedDomain.id }}">
                                        <input type="hidden" name="alias" value="{{ alias }}">
                                        <button type="submit" style="background:none;border:none;cursor:pointer;font-size:11px;font-weight:600;color:#f87171;padding:0;">✕</button>
                                    </form>
                                </div>
                            {% endfor %}
                        </div>
                    </div>
                {% endif %}
            </div>
        </div>

        {# ── Docroot + PHP ── #}
        <div class="cust-grid-2">
            <div class="cust-form-card">
                <div class="cust-form-card__head">
                    <h3 class="cust-form-card__title">{{ t('customer_webspace_manage_docroot_title', locale) }}</h3>
                    <p class="cust-form-card__sub">{{ t('customer_webspace_manage_docroot_description', locale) }}</p>
                </div>
                <form method="post" action="/webspace/manage/docroot" class="cust-form-card__body">
                    <input type="hidden" name="webspace_id" value="{{ webspace.id }}">
                    <div>
                        <label class="form-label">{{ t('customer_webspace_manage_docroot_label', locale) }}</label>
                        <input type="text" name="docroot" value="{{ webspace.docroot }}" class="form-input" required>
                        <p style="margin:4px 0 0;font-size:11px;color:var(--ng-text-muted);">{{ t('customer_webspace_manage_docroot_framework_hint', locale) }}</p>
                    </div>
                    <button type="submit" class="ui-button ui-button--primary" style="width:100%;">
                        {{ t('customer_webspace_manage_docroot_action', locale) }}
                    </button>
                </form>
            </div>

            <div class="cust-form-card">
                <div class="cust-form-card__head">
                    <h3 id="php" class="cust-form-card__title">{{ t('customer_webspace_manage_php_settings_title', locale) }}</h3>
                    <p class="cust-form-card__sub">{{ t('customer_webspace_manage_php_settings_description', locale) }}</p>
                </div>
                <form method="post" action="/webspace/manage/php" class="cust-form-card__body">
                    <input type="hidden" name="webspace_id" value="{{ webspace.id }}">
                    <textarea name="php_settings" rows="6" class="form-input" style="font-family:monospace;resize:vertical;" placeholder="memory_limit=512M&#10;upload_max_filesize=64M">{% for key, value in webspace.php_settings %}{{ key }}={{ value }}
{% endfor %}</textarea>
                    <p style="font-size:11px;color:var(--ng-text-muted);">{{ t('customer_webspace_manage_php_settings_hint', locale) }}</p>
                    <button type="submit" class="ui-button ui-button--primary" style="width:100%;">
                        {{ t('customer_webspace_manage_php_settings_action', locale) }}
                    </button>
                </form>
            </div>
        </div>

        {# ── Cron + Git ── #}
        <div class="cust-grid-2">
            <div class="cust-form-card">
                <div class="cust-form-card__head">
                    <h3 class="cust-form-card__title">{{ t('customer_webspace_manage_cron_title', locale) }}</h3>
                    <p class="cust-form-card__sub">{{ t('customer_webspace_manage_cron_description', locale) }}</p>
                </div>
                <form method="post" action="/webspace/manage/cron" class="cust-form-card__body">
                    <input type="hidden" name="webspace_id" value="{{ webspace.id }}">
                    <textarea name="cron_tasks" rows="6" class="form-input" style="font-family:monospace;resize:vertical;" placeholder="*/5 * * * * {{ webspace.path }}/artisan schedule:run">{{ webspace.cron_tasks }}</textarea>
                    <p style="font-size:11px;color:var(--ng-text-muted);">{{ t('customer_webspace_manage_cron_hint', locale) }}</p>
                    <button type="submit" class="ui-button ui-button--primary" style="width:100%;">
                        {{ t('customer_webspace_manage_cron_action', locale) }}
                    </button>
                </form>
            </div>

            <div class="cust-form-card">
                <div class="cust-form-card__head">
                    <h3 class="cust-form-card__title">{{ t('customer_webspace_manage_git_title', locale) }}</h3>
                    <p class="cust-form-card__sub">{{ t('customer_webspace_manage_git_description', locale) }}</p>
                </div>
                <form method="post" action="/webspace/manage/git" class="cust-form-card__body">
                    <input type="hidden" name="webspace_id" value="{{ webspace.id }}">
                    <div>
                        <label class="form-label">{{ t('customer_webspace_manage_git_repo_label', locale) }}</label>
                        <input type="text" name="git_repo_url" value="{{ webspace.git_repo_url }}" class="form-input" placeholder="git@github.com:org/repo.git">
                    </div>
                    <div>
                        <label class="form-label">{{ t('customer_webspace_manage_git_branch_label', locale) }}</label>
                        <input type="text" name="git_branch" value="{{ webspace.git_branch ?? 'main' }}" class="form-input">
                    </div>
                    <button type="submit" class="ui-button ui-button--primary" style="width:100%;">
                        {{ t('customer_webspace_manage_git_action', locale) }}
                    </button>
                </form>
                <div style="border-top:1px solid var(--ng-border);padding:16px;">
                    <form method="post" action="/webspace/manage/composer">
                        <input type="hidden" name="webspace_id" value="{{ webspace.id }}">
                        <p style="margin:0 0 10px;font-size:13px;color:var(--ng-text-muted);">{{ t('customer_webspace_manage_composer_description', locale) }}</p>
                        <button type="submit" class="ui-button ui-button--ghost">
                            {{ t('customer_webspace_manage_composer_action', locale) }}
                        </button>
                    </form>
                </div>
            </div>
        </div>

        {# ── Backup + SSL ── #}
        <div class="cust-grid-2">
            <div class="cust-form-card">
                <div class="cust-form-card__head">
                    <h3 id="backups" class="cust-form-card__title">{{ t('customer_webspace_manage_backup_title', locale) }}</h3>
                    <p class="cust-form-card__sub">{{ t('customer_webspace_manage_backup_description', locale) }}</p>
                </div>
                <form method="post" action="/webspace/manage/backup" class="cust-form-card__body">
                    <input type="hidden" name="webspace_id" value="{{ webspace.id }}">
                    <div>
                        <label class="form-label">{{ t('customer_webspace_manage_backup_label', locale) }}</label>
                        <input type="text" name="backup_label" class="form-input" placeholder="release-2025-02-01">
                    </div>
                    <button type="submit" class="ui-button ui-button--primary" style="width:100%;">
                        {{ t('customer_webspace_manage_backup_action', locale) }}
                    </button>
                </form>
                <div style="border-top:1px solid var(--ng-border);padding:16px;">
                    <form method="post" action="/webspace/manage/restore" style="display:flex;flex-direction:column;gap:12px;">
                        <input type="hidden" name="webspace_id" value="{{ webspace.id }}">
                        <div>
                            <label class="form-label">{{ t('customer_webspace_manage_restore_label', locale) }}</label>
                            <input type="text" name="backup_path" class="form-input" placeholder="/var/lib/easywi/web/backups/{{ webspace.id }}/webspace-YYYYMMDD-HHMMSS.tar.gz">
                        </div>
                        <button type="submit" class="ui-button ui-button--warning" style="width:100%;">
                            {{ t('customer_webspace_manage_restore_action', locale) }}
                        </button>
                    </form>
                </div>
            </div>

            <div class="cust-form-card">
                <div class="cust-form-card__head">
                    <h3 class="cust-form-card__title">{{ t('customer_webspace_manage_ssl_title', locale) }}</h3>
                    <p class="cust-form-card__sub">{{ t('customer_webspace_manage_ssl_description', locale) }}</p>
                </div>
                <div style="padding:14px 16px;border-bottom:1px solid var(--ng-border);">
                    <p style="font-weight:600;font-size:13px;color:var(--ng-text);margin:0 0 6px;">{{ t('customer_webspace_manage_ssl_dns_title', locale) }}</p>
                    <ul style="margin:0;padding-left:18px;font-size:12px;color:var(--ng-text-muted);display:flex;flex-direction:column;gap:3px;">
                        <li>{{ t('customer_webspace_manage_ssl_dns_a', locale) }}</li>
                        <li>{{ t('customer_webspace_manage_ssl_dns_aaaa', locale) }}</li>
                        <li>{{ t('customer_webspace_manage_ssl_dns_http', locale) }}</li>
                        <li>{{ t('customer_webspace_manage_ssl_dns_email', locale) }}</li>
                    </ul>
                </div>
                <form method="post" action="/webspace/manage/ssl" class="cust-form-card__body">
                    <input type="hidden" name="domain_id" value="{{ selectedDomain.id }}">
                    <div>
                        <label class="form-label">{{ t('customer_webspace_manage_ssl_alias_label', locale) }}</label>
                        <input type="text" name="server_aliases" class="form-input" placeholder="www.{{ selectedDomain.name }}">
                    </div>
                    <div>
                        <label class="form-label">{{ t('customer_webspace_manage_ssl_email_label', locale) }}</label>
                        <input type="email" name="email" class="form-input" placeholder="admin@{{ selectedDomain.name }}">
                    </div>
                    <button type="submit" class="ui-button ui-button--primary" style="width:100%;">
                        {{ t('customer_webspace_manage_ssl_action', locale) }}
                    </button>
                </form>
                <div style="border-top:1px solid var(--ng-border);padding:14px 16px;display:flex;gap:8px;flex-wrap:wrap;">
                    <form method="post" action="/webspace/manage/ssl/disable">
                        <input type="hidden" name="domain_id" value="{{ selectedDomain.id }}">
                        <button type="submit" class="ui-button ui-button--ghost">SSL deaktivieren</button>
                    </form>
                    <form method="post" action="/webspace/manage/ssl/renew">
                        <input type="hidden" name="domain_id" value="{{ selectedDomain.id }}">
                        <button type="submit" class="ui-button ui-button--primary">SSL erneuern</button>
                    </form>
                </div>
            </div>
        </div>

        {# ── Logs + Roundcube ── #}
        <div class="cust-grid-2">
            <div class="cust-panel">
                <div class="cust-panel__head">
                    <h3 id="logs" class="cust-panel__title">{{ t('customer_webspace_manage_logs_title', locale) }}</h3>
                    <p class="cust-panel__sub">{{ t('customer_webspace_manage_logs_description', locale) }}</p>
                </div>
                <div class="cust-panel__body">
                    <p style="margin:0 0 12px;font-size:13px;color:var(--ng-text-muted);">{{ t('customer_webspace_manage_logs_hint', locale) }}</p>
