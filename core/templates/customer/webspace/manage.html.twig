{% extends 'customer/base.html.twig' %}


{% block content %}
<div class="customer-webspace-modern customer-webspace-manage-modern flex flex-col gap-6">
    {% if flashSuccess %}
        <div class="rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-800">{{ flashSuccess }}</div>
    {% endif %}
    {% if flashError %}
        <div class="rounded-xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-800">{{ flashError }}</div>
    {% endif %}
    <div>
        <h1 class="text-2xl font-semibold text-slate-900">{{ t('customer_webspace_manage_title', page_locale()) }}</h1>
        <p class="text-sm text-slate-700">{{ t('customer_webspace_manage_description', page_locale()) }}</p>
    </div>

    <div class="rounded-2xl border border-slate-200 bg-white shadow-sm">
        <div class="border-b border-slate-200 px-5 py-4">
            <h2 class="text-lg font-semibold text-slate-900">{{ t('customer_webspace_manage_select_title', page_locale()) }}</h2>
            <p class="text-sm text-slate-700">{{ t('customer_webspace_manage_select_description', page_locale()) }}</p>
        </div>
        <form method="get" action="/webspace/manage" class="flex flex-wrap items-end gap-3 px-5 py-4">
            <div class="min-w-[220px] flex-1">
                <label class="text-xs font-semibold uppercase text-slate-700">{{ t('customer_webspace_manage_domain_label', page_locale()) }}</label>
                <select name="domain_id" class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm" required>
                    <option value="">{{ t('customer_webspace_manage_domain_placeholder', page_locale()) }}</option>
                    {% for domain in domains %}
                        <option value="{{ domain.id }}" {% if selectedDomain and selectedDomain.id == domain.id %}selected{% endif %}>{{ domain.name }}</option>
                    {% endfor %}
                </select>
            </div>
            <button type="submit" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-500">
                {{ t('customer_webspace_manage_select_action', page_locale()) }}
            </button>
        </form>
    </div>

    {% if selectedDomain and webspace %}
        <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
            <div class="flex flex-wrap items-start justify-between gap-4">
                <div>
                    <h2 class="text-lg font-semibold text-slate-900">{{ t('customer_webspace_manage_overview_title', page_locale()) }}</h2>
                    <p class="text-sm text-slate-700">{{ t('customer_webspace_manage_overview_description', page_locale()) }}</p>
                </div>
                <span class="rounded-full bg-indigo-50 px-3 py-1 text-xs font-semibold text-indigo-600">{{ selectedDomain.name }}</span>
            </div>
            <div class="mt-4 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
                <div class="rounded-xl border border-slate-200 bg-slate-50 p-4 text-sm text-slate-700">
                    <p class="text-xs uppercase text-slate-500">{{ t('customer_webspace_manage_webroot_label', page_locale()) }}</p>
                    <p class="mt-2 font-semibold text-slate-900">{{ webspace.path }}</p>
                    <p class="mt-1 text-xs text-slate-500">{{ t('customer_webspace_manage_webroot_hint', page_locale()) }}</p>
                </div>
                <div class="rounded-xl border border-slate-200 bg-slate-50 p-4 text-sm text-slate-700">
                    <p class="text-xs uppercase text-slate-500">{{ t('customer_webspace_manage_docroot_label', page_locale()) }}</p>
                    <p class="mt-2 font-semibold text-slate-900">{{ webspace.docroot }}</p>
                    <p class="mt-1 text-xs text-slate-500">{{ t('customer_webspace_manage_docroot_hint', page_locale()) }}</p>
                </div>
                <div class="rounded-xl border border-slate-200 bg-slate-50 p-4 text-sm text-slate-700">
                    <p class="text-xs uppercase text-slate-500">{{ t('customer_webspace_manage_php_label', page_locale()) }}</p>
                    <p class="mt-2 font-semibold text-slate-900">{{ webspace.php_version }}</p>
                    <p class="mt-1 text-xs text-slate-500">{{ t('customer_webspace_manage_subdomain_hint', page_locale()) }}</p>
                </div>
            </div>
        </div>

        <div class="rounded-2xl border border-slate-200 bg-white shadow-sm">
            <div class="border-b border-slate-200 px-5 py-4">
                <h2 class="text-lg font-semibold text-slate-900">Domains & SSL</h2>
            </div>
            <form method="post" action="/webspace/manage/domain/add" class="grid gap-2 border-b border-slate-200 px-5 py-4 md:grid-cols-6">
                <input type="hidden" name="webspace_id" value="{{ webspace.id }}">
                <input class="rounded border border-slate-300 px-2 py-1" name="fqdn" placeholder="new.example.com" required>
                <select class="rounded border border-slate-300 px-2 py-1" name="type"><option value="domain">domain</option><option value="subdomain">subdomain</option></select>
                <input class="rounded border border-slate-300 px-2 py-1" name="target_path" placeholder="public">
                <label class="text-xs"><input type="checkbox" name="redirect_https" value="1"> HTTPS</label>
                <label class="text-xs"><input type="checkbox" name="redirect_www" value="1"> WWW</label>
                <button {{ hasActiveWebspaceJob ? 'disabled' : '' }} class="rounded bg-indigo-600 px-2 py-1 text-xs text-white disabled:opacity-40">Domain hinzufügen</button>
                <label class="text-xs md:col-span-6"><input type="checkbox" name="request_tls" value="1"> SSL direkt anfordern</label>
            </form>
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-slate-200 text-sm">
                    <thead class="bg-slate-50">
                    <tr>
                        <th class="px-4 py-2 text-left">FQDN</th><th class="px-4 py-2 text-left">Status</th><th class="px-4 py-2 text-left">Apply</th><th class="px-4 py-2 text-left">SSL</th><th class="px-4 py-2 text-left">Redirects</th><th class="px-4 py-2 text-left">Actions</th>
                    </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-200">
                    {% for domain in webspaceDomains %}
                        {% set running = hasActiveWebspaceJob or domain.apply_status == 'running' %}
                        {% set sslPending = domain.ssl_status in ['pending', 'renewing'] %}
                        {% set sslActive = domain.ssl_status in ['active', 'expires_soon'] %}
                        <tr>
                            <td class="px-4 py-2">{{ domain.name }}<div class="text-xs text-slate-500">{{ domain.type }}</div></td>
                            <td class="px-4 py-2"><span class="rounded-full px-2 py-1 text-xs {{ domain.status == 'failed' ? 'bg-rose-100 text-rose-700' : 'bg-slate-100 text-slate-700' }}">{{ domain.status }}</span></td>
                            <td class="px-4 py-2"><span class="rounded-full px-2 py-1 text-xs {{ domain.apply_status == 'failed' ? 'bg-rose-100 text-rose-700' : 'bg-indigo-100 text-indigo-700' }}">{{ domain.apply_status }}</span></td>
                            <td class="px-4 py-2"><span class="rounded-full px-2 py-1 text-xs {{ sslActive ? 'bg-emerald-100 text-emerald-700' : 'bg-amber-100 text-amber-700' }}">{{ domain.ssl_status|replace({'_':' '}) }}</span></td>
                            <td class="px-4 py-2 text-xs">{{ domain.redirect_https ? 'HTTPS on' : 'HTTPS off' }} · {{ domain.redirect_www ? 'WWW on' : 'WWW off' }}</td>
                            <td class="px-4 py-2">
                                <div class="flex flex-wrap gap-2">
                                    <form method="post" action="/webspace/manage/domain/apply"><input type="hidden" name="domain_id" value="{{ domain.id }}"><button {{ running ? 'disabled' : '' }} class="rounded bg-slate-900 px-2 py-1 text-xs text-white disabled:opacity-40">Erneut anwenden</button></form>
                                    <form method="post" action="/webspace/manage/ssl"><input type="hidden" name="domain_id" value="{{ domain.id }}"><button {{ (running or sslPending or sslActive) ? 'disabled' : '' }} class="rounded bg-indigo-600 px-2 py-1 text-xs text-white disabled:opacity-40">SSL aktivieren</button></form>
                                    <form method="post" action="/webspace/manage/ssl/disable"><input type="hidden" name="domain_id" value="{{ domain.id }}"><button {{ (running or (not sslActive)) ? 'disabled' : '' }} class="rounded bg-slate-700 px-2 py-1 text-xs text-white disabled:opacity-40">SSL aus</button></form>
                                    <form method="post" action="/webspace/manage/ssl/renew"><input type="hidden" name="domain_id" value="{{ domain.id }}"><button {{ (running or (not sslActive)) ? 'disabled' : '' }} class="rounded bg-emerald-600 px-2 py-1 text-xs text-white disabled:opacity-40">SSL renew</button></form>
                                    <form method="post" action="/webspace/manage/domain/delete" onsubmit="return confirm('Domain wirklich entfernen?');"><input type="hidden" name="domain_id" value="{{ domain.id }}"><button {{ running ? 'disabled' : '' }} class="rounded bg-rose-600 px-2 py-1 text-xs text-white disabled:opacity-40">Löschen</button></form>
                                </div>
                                <form method="post" action="/webspace/manage/domain/update" class="mt-2 flex flex-wrap gap-2">
                                    <input type="hidden" name="domain_id" value="{{ domain.id }}">
                                    <input class="rounded border border-slate-300 px-2 py-1 text-xs" name="target_path" value="{{ domain.target_path }}" placeholder="target_path">
                                    <label class="text-xs"><input type="checkbox" name="redirect_https" value="1" {{ domain.redirect_https ? 'checked' : '' }}> HTTPS</label>
                                    <label class="text-xs"><input type="checkbox" name="redirect_www" value="1" {{ domain.redirect_www ? 'checked' : '' }}> WWW</label>
                                    <button {{ running ? 'disabled' : '' }} class="rounded bg-indigo-500 px-2 py-1 text-xs text-white disabled:opacity-40">Speichern</button>
                                </form>
                                {% if domain.last_error_code or domain.last_error_message %}
                                    <div class="mt-1 text-xs text-rose-700">{{ domain.last_error_code }} {{ domain.last_error_message }}</div>
                                {% endif %}
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>

        <div class="grid gap-6 lg:grid-cols-2">
            <div class="rounded-2xl border border-slate-200 bg-white shadow-sm">
                <div class="border-b border-slate-200 px-5 py-4">
                    <h2 class="text-lg font-semibold text-slate-900">{{ t('customer_webspace_manage_homepage_title', page_locale()) }}</h2>
                    <p class="text-sm text-slate-700">{{ t('customer_webspace_manage_homepage_description', page_locale()) }}</p>
                </div>
                <form method="post" action="/webspace/manage/homepage" class="space-y-4 px-5 py-4">
                    <div>
                        <label class="text-xs font-semibold uppercase text-slate-700">{{ t('customer_webspace_manage_homepage_label', page_locale()) }}</label>
                        <select name="domain_id" class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm" required>
                            {% for domain in webspaceDomains %}
                                <option value="{{ domain.id }}" {% if webspace.domain == domain.name %}selected{% endif %}>{{ domain.name }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <button type="submit" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-500">
                        {{ t('customer_webspace_manage_homepage_action', page_locale()) }}
                    </button>
                </form>
            </div>

            <div class="rounded-2xl border border-slate-200 bg-white shadow-sm">
                <div class="border-b border-slate-200 px-5 py-4">
                    <div class="flex flex-wrap items-center justify-between gap-2">
                        <div>
                            <h2 class="text-lg font-semibold text-slate-900">{{ t('customer_webspace_manage_subdomains_title', page_locale()) }}</h2>
                            <p class="text-sm text-slate-700">{{ t('customer_webspace_manage_subdomains_description', page_locale()) }}</p>
                        </div>
                        <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-700">
                            {{ t('customer_webspace_manage_subdomains_status', page_locale()) }}: {{ selectedDomain.status }}
                        </span>
                    </div>
                </div>
                <form method="post" action="/webspace/manage/subdomains/add" class="space-y-4 px-5 py-4">
                    <input type="hidden" name="domain_id" value="{{ selectedDomain.id }}">
                    <div>
                        <label class="text-xs font-semibold uppercase text-slate-700">{{ t('customer_webspace_manage_subdomains_label', page_locale()) }}</label>
                        <input type="text" name="subdomain" class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm" placeholder="www">
                        <p class="mt-1 text-xs text-slate-500">{{ t('customer_webspace_manage_subdomains_hint', page_locale()) }}</p>
                    </div>
                    <button type="submit" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-500">
                        {{ t('customer_webspace_manage_subdomains_action', page_locale()) }}
                    </button>
                </form>
                <div class="border-t border-slate-200 px-5 py-4">
                    {% if selectedDomain.server_aliases is empty %}
                        <p class="text-sm text-slate-600">{{ t('customer_webspace_manage_subdomains_empty', page_locale()) }}</p>
                    {% else %}
                        <ul class="flex flex-wrap gap-2 text-sm text-slate-700">
                            {% for alias in selectedDomain.server_aliases %}
                                <li class="flex items-center gap-2 rounded-full border border-slate-200 bg-slate-50 px-3 py-1">
                                    <span class="font-semibold">{{ alias }}</span>
                                    <form method="post" action="/webspace/manage/subdomains/remove">
                                        <input type="hidden" name="domain_id" value="{{ selectedDomain.id }}">
                                        <input type="hidden" name="alias" value="{{ alias }}">
                                        <button type="submit" class="text-xs font-semibold text-rose-600 hover:text-rose-500">
                                            {{ t('customer_webspace_manage_subdomains_remove', page_locale()) }}
                                        </button>
                                    </form>
                                </li>
                            {% endfor %}
                        </ul>
                    {% endif %}
                </div>
            </div>
        </div>

        <div class="grid gap-6 lg:grid-cols-2">
            <div class="rounded-2xl border border-slate-200 bg-white shadow-sm">
                <div class="border-b border-slate-200 px-5 py-4">
                    <h2 class="text-lg font-semibold text-slate-900">{{ t('customer_webspace_manage_docroot_title', page_locale()) }}</h2>
                    <p class="text-sm text-slate-700">{{ t('customer_webspace_manage_docroot_description', page_locale()) }}</p>
                </div>
                <form method="post" action="/webspace/manage/docroot" class="space-y-4 px-5 py-4">
                    <input type="hidden" name="webspace_id" value="{{ webspace.id }}">
                    <div>
                        <label class="text-xs font-semibold uppercase text-slate-700">{{ t('customer_webspace_manage_docroot_label', page_locale()) }}</label>
                        <input type="text" name="docroot" value="{{ webspace.docroot }}" class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm" required>
                        <p class="mt-1 text-xs text-slate-500">{{ t('customer_webspace_manage_docroot_framework_hint', page_locale()) }}</p>
                    </div>
                    <button type="submit" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-500">
                        {{ t('customer_webspace_manage_docroot_action', page_locale()) }}
                    </button>
                </form>
            </div>

            <div class="rounded-2xl border border-slate-200 bg-white shadow-sm">
                <div class="border-b border-slate-200 px-5 py-4">
                    <h2 class="text-lg font-semibold text-slate-900">{{ t('customer_webspace_manage_php_settings_title', page_locale()) }}</h2>
                    <p class="text-sm text-slate-700">{{ t('customer_webspace_manage_php_settings_description', page_locale()) }}</p>
                </div>
                <form method="post" action="/webspace/manage/php" class="space-y-4 px-5 py-4">
                    <input type="hidden" name="webspace_id" value="{{ webspace.id }}">
                    <textarea name="php_settings" rows="6" class="w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm" placeholder="memory_limit=512M&#10;upload_max_filesize=64M">{% for key, value in webspace.php_settings %}{{ key }}={{ value }}
{% endfor %}</textarea>
                    <p class="text-xs text-slate-500">{{ t('customer_webspace_manage_php_settings_hint', page_locale()) }}</p>
                    <button type="submit" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-500">
                        {{ t('customer_webspace_manage_php_settings_action', page_locale()) }}
                    </button>
                </form>
            </div>
        </div>

        <div class="grid gap-6 lg:grid-cols-2">
            <div class="rounded-2xl border border-slate-200 bg-white shadow-sm">
                <div class="border-b border-slate-200 px-5 py-4">
                    <h2 class="text-lg font-semibold text-slate-900">{{ t('customer_webspace_manage_cron_title', page_locale()) }}</h2>
                    <p class="text-sm text-slate-700">{{ t('customer_webspace_manage_cron_description', page_locale()) }}</p>
                </div>
                <form method="post" action="/webspace/manage/cron" class="space-y-4 px-5 py-4">
                    <input type="hidden" name="webspace_id" value="{{ webspace.id }}">
                    <textarea name="cron_tasks" rows="6" class="w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm" placeholder="*/5 * * * * {{ webspace.path }}/artisan schedule:run">{{ webspace.cron_tasks }}</textarea>
                    <p class="text-xs text-slate-500">{{ t('customer_webspace_manage_cron_hint', page_locale()) }}</p>
                    <button type="submit" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-500">
                        {{ t('customer_webspace_manage_cron_action', page_locale()) }}
                    </button>
                </form>
            </div>

            <div class="rounded-2xl border border-slate-200 bg-white shadow-sm">
                <div class="border-b border-slate-200 px-5 py-4">
                    <h2 class="text-lg font-semibold text-slate-900">{{ t('customer_webspace_manage_git_title', page_locale()) }}</h2>
                    <p class="text-sm text-slate-700">{{ t('customer_webspace_manage_git_description', page_locale()) }}</p>
                </div>
                <form method="post" action="/webspace/manage/git" class="space-y-4 px-5 py-4">
                    <input type="hidden" name="webspace_id" value="{{ webspace.id }}">
                    <div>
                        <label class="text-xs font-semibold uppercase text-slate-700">{{ t('customer_webspace_manage_git_repo_label', page_locale()) }}</label>
                        <input type="text" name="git_repo_url" value="{{ webspace.git_repo_url }}" class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm" placeholder="git@github.com:org/repo.git">
                    </div>
                    <div>
                        <label class="text-xs font-semibold uppercase text-slate-700">{{ t('customer_webspace_manage_git_branch_label', page_locale()) }}</label>
                        <input type="text" name="git_branch" value="{{ webspace.git_branch ?? 'main' }}" class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm">
                    </div>
                    <button type="submit" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-500">
                        {{ t('customer_webspace_manage_git_action', page_locale()) }}
                    </button>
                </form>
                <form method="post" action="/webspace/manage/composer" class="border-t border-slate-200 px-5 py-4">
                    <input type="hidden" name="webspace_id" value="{{ webspace.id }}">
                    <p class="text-sm text-slate-700">{{ t('customer_webspace_manage_composer_description', page_locale()) }}</p>
                    <button type="submit" class="mt-3 rounded-lg bg-slate-900 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-800">
                        {{ t('customer_webspace_manage_composer_action', page_locale()) }}
                    </button>
                </form>
            </div>
        </div>

        <div class="grid gap-6 lg:grid-cols-2">
            <div class="rounded-2xl border border-slate-200 bg-white shadow-sm">
                <div class="border-b border-slate-200 px-5 py-4">
                    <h2 class="text-lg font-semibold text-slate-900">{{ t('customer_webspace_manage_backup_title', page_locale()) }}</h2>
                    <p class="text-sm text-slate-700">{{ t('customer_webspace_manage_backup_description', page_locale()) }}</p>
                </div>
                <form method="post" action="/webspace/manage/backup" class="space-y-4 px-5 py-4">
                    <input type="hidden" name="webspace_id" value="{{ webspace.id }}">
                    <div>
                        <label class="text-xs font-semibold uppercase text-slate-700">{{ t('customer_webspace_manage_backup_label', page_locale()) }}</label>
                        <input type="text" name="backup_label" class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm" placeholder="release-2025-02-01">
                    </div>
                    <button type="submit" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-500">
                        {{ t('customer_webspace_manage_backup_action', page_locale()) }}
                    </button>
                </form>
                <form method="post" action="/webspace/manage/restore" class="border-t border-slate-200 space-y-4 px-5 py-4">
                    <input type="hidden" name="webspace_id" value="{{ webspace.id }}">
                    <div>
                        <label class="text-xs font-semibold uppercase text-slate-700">{{ t('customer_webspace_manage_restore_label', page_locale()) }}</label>
                        <input type="text" name="backup_path" class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm" placeholder="/var/lib/easywi/web/backups/{{ webspace.id }}/webspace-YYYYMMDD-HHMMSS.tar.gz">
                    </div>
                    <button type="submit" class="rounded-lg bg-amber-500 px-4 py-2 text-sm font-semibold text-white hover:bg-amber-400">
                        {{ t('customer_webspace_manage_restore_action', page_locale()) }}
                    </button>
                </form>
            </div>

            <div class="rounded-2xl border border-slate-200 bg-white shadow-sm">
                <div class="border-b border-slate-200 px-5 py-4">
                    <h2 class="text-lg font-semibold text-slate-900">{{ t('customer_webspace_manage_ssl_title', page_locale()) }}</h2>
                    <p class="text-sm text-slate-700">{{ t('customer_webspace_manage_ssl_description', page_locale()) }}</p>
                </div>
                <div class="space-y-3 px-5 py-4 text-sm text-slate-700">
                    <p class="font-semibold text-slate-900">{{ t('customer_webspace_manage_ssl_dns_title', page_locale()) }}</p>
                    <ul class="list-disc space-y-1 pl-5">
                        <li>{{ t('customer_webspace_manage_ssl_dns_a', page_locale()) }}</li>
                        <li>{{ t('customer_webspace_manage_ssl_dns_aaaa', page_locale()) }}</li>
                        <li>{{ t('customer_webspace_manage_ssl_dns_http', page_locale()) }}</li>
                        <li>{{ t('customer_webspace_manage_ssl_dns_email', page_locale()) }}</li>
                    </ul>
                </div>
                <form method="post" action="/webspace/manage/ssl" class="space-y-4 border-t border-slate-200 px-5 py-4">
                    <input type="hidden" name="domain_id" value="{{ selectedDomain.id }}">
                    <div>
                        <label class="text-xs font-semibold uppercase text-slate-700">{{ t('customer_webspace_manage_ssl_alias_label', page_locale()) }}</label>
                        <input type="text" name="server_aliases" class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm" placeholder="www.{{ selectedDomain.name }}">
                    </div>
                    <div>
                        <label class="text-xs font-semibold uppercase text-slate-700">{{ t('customer_webspace_manage_ssl_email_label', page_locale()) }}</label>
                        <input type="email" name="email" class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm" placeholder="admin@{{ selectedDomain.name }}">
                    </div>
                    <button type="submit" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-500">
                        {{ t('customer_webspace_manage_ssl_action', page_locale()) }}
                    </button>
                </form>
                <div class="border-t border-slate-200 px-5 py-4 flex flex-wrap gap-2">
                    <form method="post" action="/webspace/manage/ssl/disable">
                        <input type="hidden" name="domain_id" value="{{ selectedDomain.id }}">
                        <button type="submit" class="rounded-lg bg-slate-700 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-600">
                            SSL deaktivieren
                        </button>
                    </form>
                    <form method="post" action="/webspace/manage/ssl/renew">
                        <input type="hidden" name="domain_id" value="{{ selectedDomain.id }}">
                        <button type="submit" class="rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white hover:bg-emerald-500">
                            SSL erneuern
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <div class="grid gap-6 lg:grid-cols-2">
            <div class="rounded-2xl border border-slate-200 bg-white shadow-sm">
                <div class="border-b border-slate-200 px-5 py-4">
                    <h2 class="text-lg font-semibold text-slate-900">{{ t('customer_webspace_manage_logs_title', page_locale()) }}</h2>
                    <p class="text-sm text-slate-700">{{ t('customer_webspace_manage_logs_description', page_locale()) }}</p>
                </div>
                <div class="space-y-3 px-5 py-4 text-sm text-slate-700">
                    <p>{{ t('customer_webspace_manage_logs_hint', page_locale()) }}</p>
                    <a href="{{ path('customer_files', { webspace: webspace.id }) }}" class="inline-flex items-center gap-2 text-sm font-semibold text-indigo-600 hover:text-indigo-500">
                        {{ t('customer_webspace_manage_logs_action', page_locale()) }}
                    </a>
                </div>
            </div>

            <div class="rounded-2xl border border-slate-200 bg-white shadow-sm">
                <div class="border-b border-slate-200 px-5 py-4">
                    <h2 class="text-lg font-semibold text-slate-900">{{ t('customer_webspace_manage_roundcube_title', page_locale()) }}</h2>
                    <p class="text-sm text-slate-700">{{ t('customer_webspace_manage_roundcube_description', page_locale()) }}</p>
                </div>
                <form method="post" action="/webspace/manage/roundcube" class="space-y-4 px-5 py-4">
                    <input type="hidden" name="webspace_id" value="{{ webspace.id }}">
                    <button type="submit" class="rounded-lg bg-slate-900 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-800">
                        {{ t('customer_webspace_manage_roundcube_action', page_locale()) }}
                    </button>
                </form>
                <div class="border-t border-slate-200 px-5 py-4 text-sm text-slate-700">
                    <a href="/roundcube" target="_blank" rel="noopener noreferrer" class="font-semibold text-indigo-600 hover:text-indigo-500">
                        {{ t('customer_webspace_manage_roundcube_link', page_locale()) }}
                    </a>
                </div>
            </div>
        </div>
