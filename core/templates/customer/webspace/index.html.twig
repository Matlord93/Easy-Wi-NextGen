{% extends 'customer/base.html.twig' %}

{% set activeNav = 'webspaces' %}

{% block content %}
<div class="cust-page">

    {# ── Hero ── #}
    <div class="cust-hero">
        <div class="cust-hero__inner">
            <div>
                <div class="cust-hero__label">{{ t('customer_webspace_kicker', page_locale()) }}</div>
                <h1 class="cust-hero__title">{{ t('customer_webspace_title', page_locale()) }}</h1>
                <p class="cust-hero__desc">{{ t('customer_webspace_description', page_locale()) }}</p>
            </div>
            <div class="cust-hero__actions">
                <a href="{{ path('customer_files') }}" class="ui-button ui-button--ghost">
                    <svg viewBox="0 0 16 16" fill="currentColor" width="14" height="14"><path d="M9.828 3h3.982a2 2 0 0 1 1.992 2.181l-.637 7A2 2 0 0 1 13.174 14H2.825a2 2 0 0 1-1.991-1.819l-.637-7a1.99 1.99 0 0 1 .342-1.31L.5 3a2 2 0 0 1 2-2h3.672a2 2 0 0 1 1.414.586l.828.828A2 2 0 0 0 9.828 3z"/></svg>
                    {{ t('customer_webspace_action_files', page_locale()) }}
                </a>
                <a href="{{ path('customer_webspace_manage') }}" class="ui-button ui-button--primary">
                    <svg viewBox="0 0 16 16" fill="currentColor" width="14" height="14"><path d="M8 4.754a3.246 3.246 0 1 0 0 6.492 3.246 3.246 0 0 0 0-6.492zM5.754 8a2.246 2.246 0 1 1 4.492 0 2.246 2.246 0 0 1-4.492 0z"/><path d="M9.796 1.343c-.527-1.79-3.065-1.79-3.592 0l-.094.319a.873.873 0 0 1-1.255.52l-.292-.16c-1.64-.892-3.433.902-2.54 2.541l.159.292a.873.873 0 0 1-.52 1.255l-.319.094c-1.79.527-1.79 3.065 0 3.592l.319.094a.873.873 0 0 1 .52 1.255l-.16.292c-.892 1.64.901 3.434 2.541 2.54l.292-.159a.873.873 0 0 1 1.255.52l.094.319c.527 1.79 3.065 1.79 3.592 0l.094-.319a.873.873 0 0 1 1.255-.52l.292.16c1.64.893 3.434-.902 2.54-2.541l-.159-.292a.873.873 0 0 1 .52-1.255l.319-.094c1.79-.527 1.79-3.065 0-3.592l-.319-.094a.873.873 0 0 1-.52-1.255l.16-.292c.893-1.64-.902-3.433-2.541-2.54l-.292.159a.873.873 0 0 1-1.255-.52l-.094-.319z"/></svg>
                    {{ t('customer_webspace_action_manage', page_locale()) }}
                </a>
            </div>
        </div>

        {# Summary stats #}
        <div class="cust-hero__stats">
            <div class="cust-hero__stat">
                <div class="cust-hero__stat-label">{{ t('customer_webspace_summary_webspaces', page_locale()) }}</div>
                <div class="cust-hero__stat-value">{{ summary.webspaces }}</div>
                <div class="cust-hero__stat-sub">Webspace-Pakete</div>
            </div>
            <div class="cust-hero__stat">
                <div class="cust-hero__stat-label">{{ t('customer_webspace_summary_domains', page_locale()) }}</div>
                <div class="cust-hero__stat-value">{{ summary.domains }}</div>
                <div class="cust-hero__stat-sub">Domains</div>
            </div>
            <div class="cust-hero__stat">
                <div class="cust-hero__stat-label">{{ t('customer_webspace_summary_mailboxes', page_locale()) }}</div>
                <div class="cust-hero__stat-value">{{ summary.mailboxes }}</div>
                <div class="cust-hero__stat-sub">E-Mail-Konten</div>
            </div>
            <div class="cust-hero__stat">
                <div class="cust-hero__stat-label">{{ t('customer_webspace_summary_ssl_expiring', page_locale()) }}</div>
                <div class="cust-hero__stat-value" style="{% if summary.ssl_expiring > 0 %}color:#fbbf24;{% endif %}">{{ summary.ssl_expiring }}</div>
                <div class="cust-hero__stat-sub">{{ t('customer_webspace_summary_ssl_missing', page_locale()) }}: {{ summary.ssl_missing }}</div>
            </div>
        </div>
    </div>

    {# ── Quick actions ── #}
    <div class="cust-ws-action-grid">
        <a href="{{ path('customer_files') }}" class="cust-ws-action">
            <div class="cust-ws-action__icon">
                <svg viewBox="0 0 16 16" fill="currentColor"><path d="M9.828 3h3.982a2 2 0 0 1 1.992 2.181l-.637 7A2 2 0 0 1 13.174 14H2.825a2 2 0 0 1-1.991-1.819l-.637-7a1.99 1.99 0 0 1 .342-1.31L.5 3a2 2 0 0 1 2-2h3.672a2 2 0 0 1 1.414.586l.828.828A2 2 0 0 0 9.828 3z"/></svg>
            </div>
            <div>
                <div class="cust-ws-action__title">{{ t('customer_webspace_action_files', page_locale()) }}</div>
                <div class="cust-ws-action__desc">{{ t('customer_webspace_action_files_description', page_locale()) }}</div>
                <div class="cust-ws-action__count">{{ summary.webspaces }} Webspaces</div>
            </div>
        </a>
        <a href="{{ path('customer_domains') }}" class="cust-ws-action">
            <div class="cust-ws-action__icon">
                <svg viewBox="0 0 16 16" fill="currentColor"><path d="M0 8a8 8 0 1 1 16 0A8 8 0 0 1 0 8zm7.5-6.923c-.67.204-1.335.82-1.887 1.855A7.97 7.97 0 0 0 5.145 4H7.5V1.077zM4.09 4a9.267 9.267 0 0 1 .64-1.539 6.7 6.7 0 0 1 .597-.933A7.025 7.025 0 0 0 2.255 4H4.09z"/></svg>
            </div>
            <div>
                <div class="cust-ws-action__title">{{ t('customer_webspace_action_domains', page_locale()) }}</div>
                <div class="cust-ws-action__desc">{{ t('customer_webspace_action_domains_description', page_locale()) }}</div>
                <div class="cust-ws-action__count">{{ summary.domains }} Domains</div>
            </div>
        </a>
        <a href="{{ path('customer_mail') }}" class="cust-ws-action">
            <div class="cust-ws-action__icon">
                <svg viewBox="0 0 16 16" fill="currentColor"><path d="M0 4a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V4Zm2-1a1 1 0 0 0-1 1v.217l7 4.2 7-4.2V4a1 1 0 0 0-1-1H2z"/></svg>
            </div>
            <div>
                <div class="cust-ws-action__title">{{ t('customer_webspace_action_mail', page_locale()) }}</div>
                <div class="cust-ws-action__desc">{{ t('customer_webspace_action_mail_description', page_locale()) }}</div>
                <div class="cust-ws-action__count">{{ summary.mailboxes }} Postfächer</div>
            </div>
        </a>
        <a href="/roundcube" target="_blank" rel="noopener noreferrer" class="cust-ws-action">
            <div class="cust-ws-action__icon">
                <svg viewBox="0 0 16 16" fill="currentColor"><path d="M8 16a2 2 0 0 0 2-2H6a2 2 0 0 0 2 2zM8 1.918l-.797.161A4.002 4.002 0 0 0 4 6c0 .628-.134 2.197-.459 3.742-.16.767-.376 1.566-.663 2.258h10.244c-.287-.692-.502-1.49-.663-2.258C12.134 8.197 12 6.628 12 6a4.002 4.002 0 0 0-3.203-3.92L8 1.917z"/></svg>
            </div>
            <div>
                <div class="cust-ws-action__title">Roundcube Webmail</div>
                <div class="cust-ws-action__desc">E-Mails direkt im Browser lesen und schreiben.</div>
                <div class="cust-ws-action__count" style="background:rgba(34,197,94,0.15);color:#4ade80;border-color:rgba(34,197,94,0.25);">Öffnen ↗</div>
            </div>
        </a>
    </div>

    {# ── Module grid ── #}
    <div class="cust-panel">
        <div class="cust-panel__head">
            <div>
                <h3 class="cust-panel__title">{{ t('customer_webspace_modules_title', page_locale()) }}</h3>
                <p class="cust-panel__sub">{{ t('customer_webspace_modules_description', page_locale()) }}</p>
            </div>
        </div>
        <div class="cust-panel__body">
            <div class="cust-module-grid">
                <a href="{{ path('customer_files') }}" class="cust-module-link">
                    <svg viewBox="0 0 16 16" fill="currentColor"><path d="M9.828 3h3.982a2 2 0 0 1 1.992 2.181l-.637 7A2 2 0 0 1 13.174 14H2.825a2 2 0 0 1-1.991-1.819l-.637-7a1.99 1.99 0 0 1 .342-1.31L.5 3a2 2 0 0 1 2-2h3.672a2 2 0 0 1 1.414.586l.828.828A2 2 0 0 0 9.828 3z"/></svg>
                    {{ t('customer_webspace_module_files', page_locale()) }}
                </a>
                <a href="{{ path('customer_databases') }}" class="cust-module-link">
                    <svg viewBox="0 0 16 16" fill="currentColor"><path d="M4.318 2.687C5.234 2.271 6.536 2 8 2s2.766.27 3.682.687C12.644 3.125 13 3.627 13 4c0 .374-.356.875-1.318 1.313C10.766 5.729 9.464 6 8 6s-2.766-.27-3.682-.687C3.356 4.875 3 4.373 3 4c0-.374.356-.875 1.318-1.313z"/><path d="M13 5.698V7c0 .374-.356.875-1.318 1.313C10.766 8.729 9.464 9 8 9s-2.766-.27-3.682-.687C3.356 7.875 3 7.373 3 7V5.698c.271.202.58.378.904.525C4.978 6.711 6.427 7 8 7s3.022-.289 4.096-.777A4.92 4.92 0 0 0 13 5.698z"/></svg>
                    {{ t('customer_webspace_module_databases', page_locale()) }}
                </a>
                <a href="{{ path('customer_mail') }}" class="cust-module-link">
                    <svg viewBox="0 0 16 16" fill="currentColor"><path d="M0 4a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V4z"/></svg>
                    {{ t('customer_webspace_module_mail', page_locale()) }}
                </a>
                <a href="/roundcube" target="_blank" rel="noopener noreferrer" class="cust-module-link">
                    <svg viewBox="0 0 16 16" fill="currentColor"><path d="M8 16a2 2 0 0 0 2-2H6a2 2 0 0 0 2 2zM8 1.918l-.797.161A4.002 4.002 0 0 0 4 6c0 .628-.134 2.197-.459 3.742-.16.767-.376 1.566-.663 2.258h10.244c-.287-.692-.502-1.49-.663-2.258C12.134 8.197 12 6.628 12 6a4.002 4.002 0 0 0-3.203-3.92L8 1.917z"/></svg>
                    {{ t('customer_webspace_module_roundcube', page_locale()) }}
                </a>
                <div class="cust-module-disabled">
                    <svg viewBox="0 0 16 16" fill="currentColor"><path d="M12.354 4.354a.5.5 0 0 0-.708-.708L5 11.293 1.854 8.146a.5.5 0 1 0-.708.708l3.5 3.5a.5.5 0 0 0 .708 0l7-7z"/></svg>
                    {{ t('customer_webspace_module_backups', page_locale()) }}
                </div>
                <div class="cust-module-disabled">
                    <svg viewBox="0 0 16 16" fill="currentColor"><path d="M12.354 4.354a.5.5 0 0 0-.708-.708L5 11.293 1.854 8.146a.5.5 0 1 0-.708.708l3.5 3.5a.5.5 0 0 0 .708 0l7-7z"/></svg>
                    {{ t('customer_webspace_module_logs', page_locale()) }}
                </div>
                <div class="cust-module-disabled">
                    <svg viewBox="0 0 16 16" fill="currentColor"><path d="M12.354 4.354a.5.5 0 0 0-.708-.708L5 11.293 1.854 8.146a.5.5 0 1 0-.708.708l3.5 3.5a.5.5 0 0 0 .708 0l7-7z"/></svg>
                    {{ t('customer_webspace_module_php', page_locale()) }}
                </div>
                <div class="cust-module-disabled">
                    <svg viewBox="0 0 16 16" fill="currentColor"><path d="M12.354 4.354a.5.5 0 0 0-.708-.708L5 11.293 1.854 8.146a.5.5 0 1 0-.708.708l3.5 3.5a.5.5 0 0 0 .708 0l7-7z"/></svg>
                    {{ t('customer_webspace_module_ssl', page_locale()) }}
                </div>
            </div>
        </div>
    </div>

    {# ── Webspace table ── #}
    <div class="cust-panel">
        <div class="cust-panel__head">
            <div>
                <h3 class="cust-panel__title">{{ t('customer_webspace_table_title', page_locale()) }}</h3>
                <p class="cust-panel__sub">{{ t('customer_webspace_table_description', page_locale()) }}</p>
            </div>
        </div>
        <div class="cust-panel__body--flush cust-ws-table-wrap">
            {% if webspaces is empty %}
                <div class="cust-empty">
                    <svg viewBox="0 0 16 16" fill="currentColor"><path d="M0 8a8 8 0 1 1 16 0A8 8 0 0 1 0 8zm7.5-6.923c-.67.204-1.335.82-1.887 1.855A7.97 7.97 0 0 0 5.145 4H7.5V1.077z"/></svg>
                    {{ t('customer_webspace_empty', page_locale()) }}
                </div>
            {% else %}
                <table class="cust-table">
                    <thead>
                        <tr>
                            <th>{{ t('customer_webspace_table_webspace', page_locale()) }}</th>
                            <th>{{ t('customer_webspace_table_node', page_locale()) }}</th>
                            <th>{{ t('customer_webspace_table_domain', page_locale()) }}</th>
                            <th>{{ t('customer_webspace_table_php', page_locale()) }}</th>
                            <th>{{ t('customer_webspace_table_quota', page_locale()) }}</th>
                            <th>{{ t('customer_webspace_table_status', page_locale()) }}</th>
                            <th>{{ t('customer_webspace_table_updated', page_locale()) }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for webspace in webspaces %}
                            {% set wsStatus = webspace.status|default('unknown')|lower %}
                            {% set wsBadge = wsStatus in ['active', 'running', 'online'] ? 'success' : (wsStatus in ['error', 'failed'] ? 'danger' : 'warning') %}
                            <tr>
                                <td>
                                    <div style="font-weight:700;color:var(--ng-text);">#{{ webspace.id }}</div>
                                    <div style="font-size:11px;color:var(--ng-text-muted);margin-top:2px;">
                                        {{ webspace.ftp_enabled ? 'FTP' : '' }}{{ (webspace.ftp_enabled and webspace.sftp_enabled) ? ' · ' : '' }}{{ webspace.sftp_enabled ? 'SFTP' : '' }}
                                    </div>
                                </td>
                                <td style="color:var(--ng-text-muted);">{{ webspace.node.name }}</td>
                                <td>
                                    {% if webspace.domain %}
                                        <span style="font-weight:600;color:var(--ng-text);">{{ webspace.domain }}</span>
                                    {% else %}
                                        <span style="color:var(--ng-text-muted);">—</span>
                                    {% endif %}
                                </td>
                                <td>
                                    {% if webspace.php_version %}
                                        <span class="ui-badge ui-badge--info">PHP {{ webspace.php_version }}</span>
                                    {% else %}
                                        <span style="color:var(--ng-text-muted);">—</span>
                                    {% endif %}
                                </td>
                                <td style="font-weight:600;">{{ webspace.quota }} MB</td>
                                <td>
                                    <span class="ui-badge ui-badge--{{ wsBadge }}">{{ wsStatus|replace({'_': ' '})|title }}</span>
                                    {% if webspace.apply_required %}
                                        <span class="ui-badge ui-badge--warning" style="margin-left:4px;">Apply ausstehend</span>
                                    {% endif %}
                                </td>
                                <td style="color:var(--ng-text-muted);font-size:12px;">{{ webspace.updated_at|date('Y-m-d H:i') }}</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            {% endif %}
        </div>
    </div>

</div>
{% endblock %}
