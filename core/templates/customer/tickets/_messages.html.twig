{% set locale = page_locale() %}
<div class="tkt-thread">
    {% for message in messages %}
        {% set isStaff = message.author.type in ['admin', 'superadmin', 'reseller'] %}
        <div class="tkt-msg {{ isStaff ? 'tkt-msg--admin' : '' }}">
            <div class="tkt-avatar {{ isStaff ? 'tkt-avatar--admin' : 'tkt-avatar--customer' }}"
                title="{{ isStaff ? t('customer_ticket_reply_support', locale) : t('customer_ticket_reply_you', locale) }}">
                {{ message.author.email|slice(0,1)|upper }}
            </div>
            <div class="tkt-bubble-wrap">
                <div class="tkt-bubble-meta" style="{{ isStaff ? 'flex-direction:row-reverse;' : '' }}">
                    <span style="font-weight:700;color:{{ isStaff ? 'var(--ng-primary)' : 'var(--ng-text)' }};">
                        {{ isStaff ? t('customer_ticket_reply_support', locale) : t('customer_ticket_reply_you', locale) }}
                    </span>
                    <span>{{ message.created_at|date('d.m.Y H:i') }}</span>
                </div>
                <div class="tkt-bubble {{ isStaff ? 'tkt-bubble--admin' : 'tkt-bubble--customer' }}">
                    {{ message.body }}
                </div>
                {% if message.attachments is not empty %}
                    <div class="tkt-attachments" style="{{ isStaff ? 'justify-content:flex-end;' : '' }}">
                        {% for attachment in message.attachments %}
                            <a href="{{ attachment.download_url }}" class="tkt-att">
                                <svg style="width:12px;height:12px;flex-shrink:0;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3"/>
                                </svg>
                                <span class="tkt-att__name">{{ attachment.name }}</span>
                                <span style="font-weight:400;opacity:.55;flex-shrink:0;font-size:10px;">{{ (attachment.size / 1024)|round(0, 'ceil') }} KB</span>
                            </a>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
        </div>
    {% else %}
        <div style="padding:32px 24px;text-align:center;color:var(--ng-text-muted);font-size:13px;">
            {{ t('admin_tickets_messages_empty', locale) }}
        </div>
    {% endfor %}
</div>
