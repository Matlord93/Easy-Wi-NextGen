{% set locale = locale ?? page_locale() %}
<div class="border-b border-slate-200 px-6 py-4">
    <h3 class="text-base font-semibold text-slate-900">{{ t('admin_tickets_reply_title', locale) }}</h3>
    <p class="text-xs text-slate-500">{{ t('admin_tickets_reply_intro', locale) }}</p>
</div>
<form class="p-5 space-y-4" method="post" action="/tickets/{{ ticket.id }}/messages" hx-post="/tickets/{{ ticket.id }}/messages" hx-target="#ticket-messages" hx-swap="outerHTML">
    <div>
        <label class="text-xs font-semibold uppercase tracking-wide text-slate-600">{{ t('admin_tickets_reply_message', locale) }}</label>
        <textarea name="message" rows="7" class="mt-2 w-full rounded-lg border border-slate-200 bg-slate-50 px-3 py-2 text-sm focus:border-indigo-400 focus:bg-white focus:outline-none" placeholder="{{ t('admin_tickets_reply_placeholder', locale) }}"></textarea>
    </div>
    <button type="submit" class="w-full ui-button ui-button--primary">
        {{ t('admin_tickets_reply_submit', locale) }}
    </button>
</form>
