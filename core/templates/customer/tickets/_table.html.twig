{% if tickets is empty %}
    <div class="cust-empty">
        <svg viewBox="0 0 16 16" fill="currentColor"><path d="M0 4.5A1.5 1.5 0 0 1 1.5 3h13A1.5 1.5 0 0 1 16 4.5V6a.5.5 0 0 1-.5.5 1.5 1.5 0 0 0 0 3 .5.5 0 0 1 .5.5v1.5a1.5 1.5 0 0 1-1.5 1.5h-13A1.5 1.5 0 0 1 0 11.5V10a.5.5 0 0 1 .5-.5 1.5 1.5 0 1 0 0-3A.5.5 0 0 1 0 6V4.5z"/></svg>
        {{ t('customer_ticket_table_empty', page_locale()) }}
    </div>
{% else %}
    {% for ticket in tickets %}
        {% set tStatus = ticket.status|default('open')|lower %}
        {% set tPriority = ticket.priority|default('normal')|lower %}
        {% set statusBadge = tStatus in ['resolved', 'closed'] ? 'success' : (tStatus == 'pending' ? 'primary' : 'warning') %}
        {% set priorityBadge = tPriority == 'urgent' ? 'danger' : (tPriority == 'high' ? 'warning' : (tPriority == 'low' ? 'neutral' : 'info')) %}
        <a href="{{ path('customer_ticket_show', {id: ticket.id}) }}" class="cust-ticket-item">
            <div class="cust-ticket-item__head">
                <div>
                    <p class="cust-ticket-item__subject">{{ ticket.subject }}</p>
                    <div class="cust-ticket-item__meta">
                        <span>#{{ ticket.id }}</span>
                        <span>·</span>
                        <span>{{ ticket.category|title }}</span>
                    </div>
                </div>
                <div style="display:flex;flex-direction:column;gap:4px;align-items:flex-end;flex-shrink:0;">
                    <span class="ui-badge ui-badge--{{ statusBadge }}">{{ tStatus|title }}</span>
                    <span class="ui-badge ui-badge--{{ priorityBadge }} ui-badge--sm">{{ tPriority|title }}</span>
                </div>
            </div>
            <div style="font-size:11px;color:var(--ng-text-muted);">
                {{ t('customer_ticket_table_last_update', page_locale()) }}: {{ ticket.last_message_at|date('d.m.Y H:i') }}
            </div>
        </a>
    {% endfor %}
{% endif %}
