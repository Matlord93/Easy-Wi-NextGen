{% extends 'customer/base.html.twig' %}
{% set locale = page_locale() %}
{% set activeNav = 'tickets' %}
{% set statusLabels = {
    'open':     t('customer_tickets_status_open', locale),
    'pending':  t('customer_tickets_status_pending', locale),
    'resolved': t('customer_tickets_status_resolved', locale),
    'closed':   t('customer_tickets_status_closed', locale),
} %}
{% set priorityLabels = {
    'low':    t('customer_tickets_priority_low', locale),
    'normal': t('customer_tickets_priority_normal', locale),
    'high':   t('customer_tickets_priority_high', locale),
    'urgent': t('customer_tickets_priority_urgent', locale),
} %}

{% block content %}
{% set nowTs = date()|date('U') %}
{% set ageDays = ((nowTs - ticket.created_at|date('U')) / 86400)|round(0, 'floor') %}

<div style="display:flex;flex-direction:column;gap:16px;">

    {# ── Hero ── #}
    <div class="ng-card" style="overflow:hidden;">
        <div class="tkt-hero">
            <div class="tkt-hero__inner">
                <div class="tkt-hero__breadcrumb">
                    <a href="/tickets">← {{ t('customer_tickets_title', locale) }}</a>
                    <span>/</span>
                    <span style="font-family:monospace;">#{{ ticket.id }}</span>
                </div>
                <div style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:10px;">
                    {% include 'components/tickets/_status_badge.html.twig' with { ticket: ticket, statusLabels: statusLabels } %}
                    {% include 'components/tickets/_priority_badge.html.twig' with { ticket: ticket, priorityLabels: priorityLabels } %}
                    <span class="ui-badge ui-badge--neutral">{{ ticket.category|title }}</span>
                </div>
                <h1 class="tkt-hero__title" style="font-size:20px;margin-bottom:6px;">{{ ticket.subject }}</h1>
                <p class="tkt-hero__sub">
                    {{ t('customer_ticket_created_update', locale)
                        |replace({'%created%': ticket.created_at|date('d.m.Y H:i'), '%updated%': ticket.last_message_at|date('d.m.Y H:i')}) }}
                </p>
                <div style="display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:8px;margin-top:14px;max-width:280px;">
                    <div class="tkt-kpi">
                        <div class="tkt-kpi__label">{{ t('customer_tickets_age_label', locale) }}</div>
                        <div class="tkt-kpi__value" style="font-size:20px;">
                            {{ ageDays == 0 ? t('customer_tickets_age_today', locale) : ageDays }}
                        </div>
                    </div>
                    <div class="tkt-kpi">
                        <div class="tkt-kpi__label">{{ t('customer_tickets_last_update', locale) }}</div>
                        <div class="tkt-kpi__value" style="font-size:19px;">{{ ticket.last_message_at|date('d.m.') }}</div>
                        <div style="font-size:11px;color:rgba(226,232,240,.45);margin-top:1px;">{{ ticket.last_message_at|date('H:i') }}</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# ── Main: conversation + sidebar ── #}
    <div style="display:grid;grid-template-columns:minmax(0,1fr) 360px;gap:16px;align-items:start;">

        {# ── Conversation ── #}
        <div class="ng-card" style="overflow:hidden;">
            <div style="padding:14px 20px;border-bottom:1px solid var(--ng-border);display:flex;align-items:center;gap:10px;">
                <div style="width:32px;height:32px;border-radius:8px;background:rgba(99,102,241,0.15);color:#818cf8;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                    <svg style="width:15px;height:15px;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
                    </svg>
                </div>
                <div>
                    <h2 style="margin:0;font-size:14px;font-weight:700;color:var(--ng-text);">{{ t('customer_ticket_conversation_title', locale) }}</h2>
                    <p style="margin:2px 0 0;font-size:11px;color:var(--ng-text-muted);">{{ t('customer_tickets_transparency_hint', locale) }}</p>
                </div>
            </div>
            <div id="ticket-messages">
                {% include 'customer/tickets/_messages.html.twig' with { ticket: ticket, messages: messages } %}
            </div>
        </div>

        {# ── Sidebar ── #}
        <aside style="position:sticky;top:20px;">
            <div class="ng-card" style="overflow:hidden;">
                {% if ticket.status == 'closed' %}
                    <div style="padding:22px 20px;display:flex;flex-direction:column;gap:12px;">
                        <div style="width:40px;height:40px;border-radius:10px;background:var(--ng-surface-soft);color:var(--ng-text-muted);display:flex;align-items:center;justify-content:center;font-size:18px;">✓</div>
                        <p style="margin:0;font-size:14px;font-weight:700;color:var(--ng-text);">{{ statusLabels.closed }}</p>
                        <p style="margin:0;font-size:13px;color:var(--ng-text-muted);">{{ t('customer_ticket_closed_notice', locale) }}</p>
                        <a href="/tickets" class="ui-button ui-button--ghost" style="width:100%;text-align:center;">← {{ t('customer_tickets_title', locale) }}</a>
                    </div>
                {% else %}
                    {% include 'customer/tickets/_message_form.html.twig' with { ticket: ticket, locale: locale } %}
                {% endif %}
            </div>
        </aside>

    </div>
</div>
{% endblock %}
