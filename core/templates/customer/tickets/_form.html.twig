<div class="cust-form-card__head">
    <h3 class="cust-form-card__title">{{ t('customer_ticket_new_title', page_locale()) }}</h3>
    <p class="cust-form-card__sub">{{ t('customer_ticket_new_intro', page_locale()) }}</p>
</div>
<form class="cust-form-card__body" method="post" action="/tickets" hx-post="/tickets" hx-target="#ticket-form" hx-swap="outerHTML">
    {% if form.errors is not empty %}
        <div class="cust-alert cust-alert--error">
            <ul style="margin:0;padding-left:18px;">
                {% for error in form.errors %}
                    <li>{{ error }}</li>
                {% endfor %}
            </ul>
        </div>
    {% endif %}

    <div>
        <label class="cust-form-label">{{ t('customer_ticket_subject', page_locale()) }}</label>
        <input name="subject" value="{{ form.subject }}" placeholder="{{ t('customer_ticket_subject_placeholder', page_locale()) }}">
    </div>

    <div class="cust-form-row">
        <div>
            <label class="cust-form-label">{{ t('customer_ticket_category', page_locale()) }}</label>
            <select name="category">
                <option value="general" {{ form.category == 'general' ? 'selected' : '' }}>{{ t('customer_ticket_category_general', page_locale()) }}</option>
                <option value="billing" {{ form.category == 'billing' ? 'selected' : '' }}>{{ t('customer_ticket_category_billing', page_locale()) }}</option>
                <option value="technical" {{ form.category == 'technical' ? 'selected' : '' }}>{{ t('customer_ticket_category_technical', page_locale()) }}</option>
                <option value="abuse" {{ form.category == 'abuse' ? 'selected' : '' }}>{{ t('customer_ticket_category_abuse', page_locale()) }}</option>
            </select>
        </div>
        <div>
            <label class="cust-form-label">{{ t('customer_ticket_priority', page_locale()) }}</label>
            <select name="priority">
                <option value="low" {{ form.priority == 'low' ? 'selected' : '' }}>{{ t('customer_ticket_priority_low', page_locale()) }}</option>
                <option value="normal" {{ form.priority == 'normal' ? 'selected' : '' }}>{{ t('customer_ticket_priority_normal', page_locale()) }}</option>
                <option value="high" {{ form.priority == 'high' ? 'selected' : '' }}>{{ t('customer_ticket_priority_high', page_locale()) }}</option>
                <option value="urgent" {{ form.priority == 'urgent' ? 'selected' : '' }}>{{ t('customer_ticket_priority_urgent', page_locale()) }}</option>
            </select>
        </div>
    </div>

    <div>
        <label class="cust-form-label">{{ t('customer_ticket_message', page_locale()) }}</label>
        <textarea name="message" rows="5" placeholder="{{ t('customer_ticket_message_placeholder', page_locale()) }}">{{ form.message }}</textarea>
    </div>

    <button type="submit" class="ui-button ui-button--primary" style="width:100%;">
        <svg viewBox="0 0 16 16" fill="currentColor" width="14" height="14"><path d="M15.964.686a.5.5 0 0 0-.65-.65L.767 5.855H.766l-.452.18a.5.5 0 0 0-.082.887l.41.26.001.002 4.995 3.178 3.178 4.995.002.002.26.41a.5.5 0 0 0 .886-.083l6-15Zm-1.833 1.89L6.637 10.07l-.215-.338a.5.5 0 0 0-.154-.154l-.338-.215 7.494-7.494 1.178-.471-.47 1.178Z"/></svg>
        {{ t('customer_ticket_submit', page_locale()) }}
    </button>
</form>
