{% extends 'customer/base.html.twig' %}

{% set activeNav = 'tickets' %}
{% block title %}Tickets · Easy-Wi NextGen{% endblock %}

{% block content %}
<div class="cust-page">

    {# ── Hero ── #}
    <div class="cust-hero">
        <div class="cust-hero__inner">
            <div>
                <div class="cust-hero__label">Support</div>
                <h1 class="cust-hero__title">{{ t('customer_tickets_title', page_locale()) }}</h1>
                <p class="cust-hero__desc">{{ t('customer_tickets_intro', page_locale()) }}</p>
            </div>
        </div>

        {# KPIs inside hero #}
        <div class="cust-hero__stats">
            <div class="cust-hero__stat">
                <div class="cust-hero__stat-label">{{ t('customer_tickets_total', page_locale()) }}</div>
                <div class="cust-hero__stat-value">{{ summary.total }}</div>
                <div class="cust-hero__stat-sub">Tickets gesamt</div>
            </div>
            <div class="cust-hero__stat">
                <div class="cust-hero__stat-label">{{ t('customer_tickets_open', page_locale()) }}</div>
                <div class="cust-hero__stat-value" style="color:#fbbf24;">{{ summary.open }}</div>
                <div class="cust-hero__stat-sub">Offen</div>
            </div>
            <div class="cust-hero__stat">
                <div class="cust-hero__stat-label">{{ t('customer_tickets_pending', page_locale()) }}</div>
                <div class="cust-hero__stat-value" style="color:#818cf8;">{{ summary.pending }}</div>
                <div class="cust-hero__stat-sub">Warten auf Antwort</div>
            </div>
            <div class="cust-hero__stat">
                <div class="cust-hero__stat-label">{{ t('customer_tickets_resolved', page_locale()) }}</div>
                <div class="cust-hero__stat-value" style="color:#4ade80;">{{ summary.resolved }}</div>
                <div class="cust-hero__stat-sub">Gelöst</div>
            </div>
        </div>
    </div>

    {# ── Main grid: list + create ── #}
    <div class="cust-grid-2">

        {# Ticket list #}
        <div class="cust-panel">
            <div class="cust-panel__head">
                <div>
                    <h3 class="cust-panel__title">{{ t('customer_tickets_list_title', page_locale()) }}</h3>
                    <p class="cust-panel__sub">{{ t('customer_tickets_list_intro', page_locale()) }}</p>
                </div>
                <button
                    class="ui-button ui-button--ghost ui-button--sm"
                    hx-get="/tickets/table"
                    hx-target="#tickets-table"
                    hx-swap="outerHTML"
                >
                    <svg viewBox="0 0 16 16" fill="currentColor" width="13" height="13"><path d="M11.534 7h3.932a.25.25 0 0 1 .192.41l-1.966 2.36a.25.25 0 0 1-.384 0l-1.966-2.36a.25.25 0 0 1 .192-.41zm-11 2h3.932a.25.25 0 0 0 .192-.41L2.692 6.23a.25.25 0 0 0-.384 0L.342 8.59A.25.25 0 0 0 .534 9z"/><path fill-rule="evenodd" d="M8 3c-1.552 0-2.94.707-3.857 1.818a.5.5 0 1 1-.771-.636A6.002 6.002 0 0 1 13.917 7H12.9A5.002 5.002 0 0 0 8 3zM3.1 9a5.002 5.002 0 0 0 8.757 2.182.5.5 0 1 1 .771.636A6.002 6.002 0 0 1 2.083 9H3.1z"/></svg>
                    {{ t('refresh', page_locale()) }}
                </button>
            </div>
            <div id="tickets-table" class="cust-panel__body--flush" hx-get="/tickets/table" hx-trigger="tickets-changed from:body" hx-swap="outerHTML">
                {% include 'customer/tickets/_table.html.twig' with { tickets: tickets, statusStyles: statusStyles, priorityStyles: priorityStyles } %}
            </div>
        </div>

        {# New ticket form #}
        <div id="ticket-form" class="cust-form-card" hx-trigger="tickets-changed from:body" hx-get="/tickets/form" hx-swap="outerHTML">
            {% include 'customer/tickets/_form.html.twig' with { form: form } %}
        </div>

    </div>
</div>
{% endblock %}
