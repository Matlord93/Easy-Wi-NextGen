{% extends 'customer/base.html.twig' %}
{% set activeNav = 'tickets' %}
{% set locale = page_locale() %}
{% block title %}{{ t('customer_tickets_title', locale) }}{% endblock %}

{% set statusLabels = {
    'open':     t('customer_tickets_status_open', locale),
    'pending':  t('customer_tickets_status_pending', locale),
    'resolved': t('customer_tickets_status_resolved', locale),
    'closed':   t('customer_tickets_status_closed', locale),
} %}
{% set priorityLabels = {
    'low':    t('customer_tickets_priority_low', locale),
    'normal': t('customer_tickets_priority_normal', locale),
    'high':   t('customer_tickets_priority_high', locale),
    'urgent': t('customer_tickets_priority_urgent', locale),
} %}

{% block content %}
<div style="display:flex;flex-direction:column;gap:20px;">

    {# ── Hero / KPI card ── #}
    <div class="ng-card" style="overflow:hidden;">
        <div class="tkt-hero">
            <div class="tkt-hero__inner">
                <div style="display:flex;flex-direction:column;gap:6px;">
                    <div class="tkt-hero__pill">
                        <span class="tkt-hero__pill-dot"></span>
                        {{ t('customer_tickets_portal_label', locale) }}
                    </div>
                    <h1 class="tkt-hero__title">{{ t('customer_tickets_title', locale) }}</h1>
                    <p class="tkt-hero__sub">{{ t('customer_tickets_modern_intro', locale) }}</p>
                </div>
                <div style="display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:8px;margin-top:16px;">
                    <div class="tkt-kpi">
                        <div class="tkt-kpi__label">{{ t('customer_tickets_total', locale) }}</div>
                        <div class="tkt-kpi__value">{{ summary.total }}</div>
                    </div>
                    <div class="tkt-kpi tkt-kpi--open">
                        <div class="tkt-kpi__label">{{ t('customer_tickets_open', locale) }}</div>
                        <div class="tkt-kpi__value">{{ summary.open }}</div>
                    </div>
                    <div class="tkt-kpi tkt-kpi--pending">
                        <div class="tkt-kpi__label">{{ t('customer_tickets_pending', locale) }}</div>
                        <div class="tkt-kpi__value">{{ summary.pending }}</div>
                    </div>
                    <div class="tkt-kpi tkt-kpi--resolved">
                        <div class="tkt-kpi__label">{{ t('customer_tickets_resolved', locale) }}</div>
                        <div class="tkt-kpi__value">{{ summary.resolved }}</div>
                    </div>
                </div>
            </div>
        </div>
        <div style="display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:10px;padding:14px 16px;border-top:1px solid var(--ng-border);background:var(--ng-surface-soft);">
            <a href="#ticket-form" class="tkt-qa">
                <div class="tkt-qa__icon" style="background:rgba(99,102,241,0.15);color:#818cf8;">+</div>
                <div class="tkt-qa__title">{{ t('customer_ticket_new_title', locale) }}</div>
                <div class="tkt-qa__sub">{{ t('customer_tickets_new_hint', locale) }}</div>
            </a>
            <button type="button" class="tkt-qa" hx-get="/tickets/table" hx-target="#tickets-table" hx-swap="outerHTML">
                <div class="tkt-qa__icon" style="background:var(--ng-surface);color:var(--ng-text-muted);">↻</div>
                <div class="tkt-qa__title">{{ t('refresh', locale) }}</div>
                <div class="tkt-qa__sub">{{ t('customer_tickets_refresh_hint', locale) }}</div>
            </button>
            <div class="tkt-qa" style="cursor:default;">
                <div class="tkt-qa__icon" style="background:rgba(34,197,94,0.12);color:#4ade80;">✓</div>
                <div class="tkt-qa__title">{{ t('customer_tickets_transparency_title', locale) }}</div>
                <div class="tkt-qa__sub">{{ t('customer_tickets_transparency_hint', locale) }}</div>
            </div>
        </div>
    </div>

    {# ── Two-column layout: list + form ── #}
    <div style="display:grid;grid-template-columns:minmax(0,1fr) 380px;gap:20px;align-items:start;">

        {# ── Ticket list ── #}
        <div class="ng-card" style="overflow:hidden;">
            <div class="tkt-filter-bar">
                <div class="tkt-filter-bar__top">
                    <div>
                        <h2 class="tkt-filter-bar__title">{{ t('customer_tickets_list_title', locale) }}</h2>
                        <p class="tkt-filter-bar__sub">{{ t('customer_tickets_list_modern_intro', locale) }}</p>
                    </div>
                    <a href="#ticket-form" class="ui-button ui-button--primary ui-button--sm">
                        + {{ t('ticket_ui_create_new_ticket', locale) }}
                    </a>
                </div>
                <form id="customer-ticket-filters" method="get" action="/tickets"
                    style="display:grid;grid-template-columns:minmax(0,1fr) 160px auto;gap:8px;">
                    <input name="q" value="{{ filters.q|default('') }}"
                        placeholder="{{ t('ticket_ui_customer_search_placeholder', locale) }}">
                    <select name="status">
                        <option value="">{{ t('ticket_ui_all_statuses', locale) }}</option>
                        {% for value, label in statusLabels %}
                        <option value="{{ value }}" {{ filters.status|default('') == value ? 'selected' : '' }}>{{ label }}</option>
                        {% endfor %}
                    </select>
                    <button type="submit" class="ui-button ui-button--ghost ui-button--sm">{{ t('ticket_ui_filter', locale) }}</button>
                </form>
            </div>
            {% include 'customer/tickets/_table.html.twig' with {
                tickets: tickets,
                statusStyles: statusStyles,
                priorityStyles: priorityStyles,
                statusLabels: statusLabels,
                priorityLabels: priorityLabels,
            } %}
        </div>

        {# ── Create form ── #}
        <aside id="ticket-form" style="position:sticky;top:20px;"
            hx-trigger="tickets-changed from:body"
            hx-get="/tickets/form"
            hx-swap="outerHTML">
            {% include 'customer/tickets/_form.html.twig' with { form: form, locale: locale } %}
        </aside>

    </div>
</div>
{% endblock %}
