{% extends 'customer/base.html.twig' %}
{% set activeNav = 'tickets' %}
{% set locale = page_locale() %}
{% block title %}{{ t('customer_tickets_title', locale) }}{% endblock %}

{% set statusLabels = {
    'open':     t('customer_tickets_status_open', locale),
    'pending':  t('customer_tickets_status_pending', locale),
    'resolved': t('customer_tickets_status_resolved', locale),
    'closed':   t('customer_tickets_status_closed', locale),
} %}
{% set priorityLabels = {
    'low':    t('customer_tickets_priority_low', locale),
    'normal': t('customer_tickets_priority_normal', locale),
    'high':   t('customer_tickets_priority_high', locale),
    'urgent': t('customer_tickets_priority_urgent', locale),
} %}

{% block content %}
<div class="flex flex-col gap-5">

    {# Page header #}
    <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
        <div>
            <h1 class="text-2xl font-bold text-slate-900">{{ t('customer_tickets_title', locale) }}</h1>
            <p class="mt-1 text-sm text-slate-500">{{ t('customer_tickets_intro', locale) }}</p>
        </div>
    </div>

    {# KPI strip #}
    <div class="grid grid-cols-2 gap-3 sm:grid-cols-4">
        <div class="rounded-xl border border-slate-200 bg-white px-4 py-3 text-center">
            <div class="text-xs font-semibold uppercase tracking-wide text-slate-500">{{ t('customer_tickets_total', locale) }}</div>
            <div class="mt-1 text-xl font-bold text-slate-900">{{ summary.total }}</div>
        </div>
        <div class="rounded-xl border border-amber-200 bg-amber-50 px-4 py-3 text-center">
            <div class="text-xs font-semibold uppercase tracking-wide text-amber-600">{{ t('customer_tickets_open', locale) }}</div>
            <div class="mt-1 text-xl font-bold text-amber-700">{{ summary.open }}</div>
        </div>
        <div class="rounded-xl border border-indigo-200 bg-indigo-50 px-4 py-3 text-center">
            <div class="text-xs font-semibold uppercase tracking-wide text-indigo-600">{{ t('customer_tickets_pending', locale) }}</div>
            <div class="mt-1 text-xl font-bold text-indigo-700">{{ summary.pending }}</div>
        </div>
        <div class="rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-center">
            <div class="text-xs font-semibold uppercase tracking-wide text-emerald-600">{{ t('customer_tickets_resolved', locale) }}</div>
            <div class="mt-1 text-xl font-bold text-emerald-700">{{ summary.resolved }}</div>
        </div>
    </div>

    {# Main 2-col: list + form #}
    <div class="grid grid-cols-1 gap-5 lg:grid-cols-[1fr_380px]">

        {# Ticket list #}
        <div class="rounded-xl border border-slate-200 bg-white shadow-sm">
            <div class="flex items-center justify-between border-b border-slate-200 px-5 py-4">
                <div>
                    <h2 class="text-base font-semibold text-slate-900">{{ t('customer_tickets_list_title', locale) }}</h2>
                    <p class="text-xs text-slate-500">{{ t('customer_tickets_list_intro', locale) }}</p>
                </div>
                <button class="ui-button ui-button--ghost ui-button--sm" hx-get="/tickets/table" hx-target="#tickets-table" hx-swap="outerHTML">
                    {{ t('refresh', locale) }}
                </button>
            </div>
            <div id="tickets-table" hx-get="/tickets/table" hx-trigger="tickets-changed from:body" hx-swap="outerHTML">
                {% include 'customer/tickets/_table.html.twig' with { tickets: tickets, statusStyles: statusStyles, priorityStyles: priorityStyles, statusLabels: statusLabels, priorityLabels: priorityLabels } %}
            </div>
        </div>

        {# New ticket form #}
        <div id="ticket-form" class="self-start rounded-xl border border-slate-200 bg-white shadow-sm" hx-trigger="tickets-changed from:body" hx-get="/tickets/form" hx-swap="outerHTML">
            {% include 'customer/tickets/_form.html.twig' with { form: form, locale: locale } %}
        </div>

    </div>
</div>
{% endblock %}
