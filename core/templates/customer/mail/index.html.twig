{% extends 'customer/base.html.twig' %}


{% block content %}
<div class="flex flex-col gap-6">
    <div>
        <h1 class="text-2xl font-semibold text-slate-900">{{ t('customer_mail_title', page_locale()) }}</h1>
        <p class="text-sm text-slate-700">{{ t('customer_mail_description', page_locale()) }}</p>
    </div>

    {% if errors is defined and errors is not empty %}
        <div class="rounded-xl border border-rose-200 bg-rose-50 px-6 py-4 text-sm text-rose-700">
            <ul class="list-disc space-y-1 pl-5">
                {% for error in errors %}
                    <li>{{ error }}</li>
                {% endfor %}
            </ul>
        </div>
    {% endif %}

    <div class="grid gap-6 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)]">
        <div class="rounded-xl border border-slate-200 bg-white shadow-sm">
            <div class="border-b border-slate-200 px-5 py-4">
                <h2 class="text-lg font-semibold text-slate-900">{{ t('customer_mail_create_title', page_locale()) }}</h2>
                <p class="text-sm text-slate-700">{{ t('customer_mail_create_description', page_locale()) }}</p>
                <a href="/roundcube" class="mt-3 inline-flex items-center gap-2 text-sm font-semibold text-indigo-600 hover:text-indigo-500" target="_blank" rel="noopener noreferrer">
                    {{ t('customer_mail_roundcube_link', page_locale()) }}
                </a>
                {% if roundcube_bindings is defined and roundcube_bindings is not empty %}
                    <div class="mt-3 space-y-1 text-xs text-slate-600">
                        {% for binding in roundcube_bindings %}
                            <div><span class="font-semibold">{{ binding.domain }}</span> → <a class="text-indigo-600" href="{{ binding.url }}" target="_blank" rel="noopener noreferrer">{{ binding.url }}</a></div>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
            <form method="post" action="/mail" class="space-y-4 px-5 py-4">
                <div>
                    <label class="text-xs font-semibold uppercase text-slate-700">{{ t('customer_mail_domain_label', page_locale()) }}</label>
                    <select name="domain_id" class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm" required>
                        <option value="">{{ t('customer_mail_domain_placeholder', page_locale()) }}</option>
                        {% for domain in domains %}
                            <option value="{{ domain.id }}">{{ domain.name }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div>
                    <label class="text-xs font-semibold uppercase text-slate-700">{{ t('customer_mail_local_part_label', page_locale()) }}</label>
                    <input type="text" name="local_part" class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm" required>
                </div>
                <div class="grid gap-3 sm:grid-cols-2">
                    <div>
                        <label class="text-xs font-semibold uppercase text-slate-700">{{ t('customer_mail_password_label', page_locale()) }}</label>
                        <input type="password" name="password" minlength="8" class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm" required>
                    </div>
                    <div>
                        <label class="text-xs font-semibold uppercase text-slate-700">{{ t('customer_mail_quota_label', page_locale()) }}</label>
                        <input type="number" min="0" name="quota" value="0" class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm" required>
                    </div>
                </div>
                <label class="flex items-center gap-2 text-xs font-semibold uppercase text-slate-700">
                    <input type="checkbox" name="enabled" value="1" class="rounded border-slate-300 text-indigo-600" checked>
                    {{ t('customer_mail_enabled_label', page_locale()) }}
                </label>
                <button type="submit" class="w-full rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-500">
                    {{ t('customer_mail_create_action', page_locale()) }}
                </button>
            </form>
        </div>

        <div class="rounded-xl border border-slate-200 bg-white shadow-sm">
            <div class="flex items-center justify-between border-b border-slate-200 px-5 py-4">
                <div>
                    <h2 class="text-lg font-semibold text-slate-900">{{ t('customer_mail_overview', page_locale()) }}</h2>
                    <p class="text-sm text-slate-700">{{ t('customer_mail_overview_description', page_locale()) }}</p>
                </div>
            </div>
            {% if mailboxes is empty %}
                <div class="px-5 py-6 text-sm text-slate-700">{{ t('customer_mail_empty', page_locale()) }}</div>
            {% else %}
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-slate-200 text-sm">
                        <thead class="bg-slate-50">
                            <tr>
                                <th class="px-5 py-3 text-left text-xs font-semibold uppercase text-slate-700">{{ t('customer_mail_table_address', page_locale()) }}</th>
                                <th class="px-5 py-3 text-left text-xs font-semibold uppercase text-slate-700">{{ t('customer_mail_table_domain', page_locale()) }}</th>
                                <th class="px-5 py-3 text-left text-xs font-semibold uppercase text-slate-700">{{ t('customer_mail_table_quota', page_locale()) }}</th>
                                <th class="px-5 py-3 text-left text-xs font-semibold uppercase text-slate-700">{{ t('customer_mail_table_status', page_locale()) }}</th>
                                <th class="px-5 py-3 text-left text-xs font-semibold uppercase text-slate-700">{{ t('customer_mail_table_updated', page_locale()) }}</th>
                                <th class="px-5 py-3 text-left text-xs font-semibold uppercase text-slate-700">{{ t('customer_mail_table_actions', page_locale()) }}</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-200">
                            {% for mailbox in mailboxes %}
                                <tr>
                                    <td class="px-5 py-4">
                                        <div class="font-semibold text-slate-900">{{ mailbox.address }}</div>
                                        <div class="text-xs text-slate-700">ID {{ mailbox.id }}</div>
                                    </td>
                                    <td class="px-5 py-4 text-slate-600">{{ mailbox.domain }}</td>
                                    <td class="px-5 py-4 text-slate-600">{{ mailbox.quota }} MB</td>
                                    <td class="px-5 py-4 text-slate-600">{{ mailbox.enabled ? t('customer_mail_status_active', page_locale()) : t('customer_mail_status_inactive', page_locale()) }}</td>
                                    <td class="px-5 py-4 text-slate-600">{{ mailbox.updated_at|date('Y-m-d H:i') }}</td>
                                    <td class="px-5 py-4">
                                        <div class="flex flex-col gap-3">
                                            <form method="post" action="/mail/{{ mailbox.id }}/quota" class="flex flex-wrap items-center gap-2">
                                                <input type="number" min="0" name="quota" value="{{ mailbox.quota }}" class="w-24 rounded-lg border border-slate-200 bg-white px-2 py-1 text-xs">
                                                <button type="submit" class="rounded-lg bg-indigo-600 px-3 py-1 text-xs font-semibold text-white hover:bg-indigo-500">
                                                    {{ t('customer_mail_quota_update_action', page_locale()) }}
                                                </button>
                                            </form>
                                            <form method="post" action="/mail/{{ mailbox.id }}/status" class="flex flex-wrap items-center gap-2">
                                                <label class="flex items-center gap-2 text-xs font-semibold text-slate-700">
                                                    <input type="checkbox" name="enabled" value="1" class="rounded border-slate-300 text-indigo-600" {% if mailbox.enabled %}checked{% endif %}>
                                                    {{ t('customer_mail_enabled_label', page_locale()) }}
                                                </label>
                                                <button type="submit" class="rounded-lg border border-slate-200 px-3 py-1 text-xs font-semibold text-slate-700 hover:bg-slate-50">
                                                    {{ t('customer_mail_status_save_action', page_locale()) }}
                                                </button>
                                            </form>
                                            <form method="post" action="/mail/{{ mailbox.id }}/password" class="flex flex-wrap items-center gap-2">
                                                <input type="password" name="password" minlength="8" placeholder="{{ t('customer_mail_password_placeholder', page_locale()) }}" class="w-40 rounded-lg border border-slate-200 bg-white px-2 py-1 text-xs">
                                                <button type="submit" class="rounded-lg border border-slate-200 px-3 py-1 text-xs font-semibold text-slate-700 hover:bg-slate-50">
                                                    {{ t('customer_mail_password_reset_action', page_locale()) }}
                                                </button>
                                            </form>
                                            <form method="post" action="/mail/{{ mailbox.id }}/delete" onsubmit="return confirm('{{ t('customer_mail_delete_confirm', page_locale()) }}');">
                                                <button type="submit" class="text-xs font-semibold text-rose-600 hover:text-rose-500">
                                                    {{ t('customer_mail_delete_action', page_locale()) }}
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </div>
    </div>

    <div class="rounded-xl border border-slate-200 bg-white shadow-sm">
        <div class="border-b border-slate-200 px-5 py-4">
            <h2 class="text-lg font-semibold text-slate-900">{{ t('customer_mail_settings_title', page_locale()) }}</h2>
            <p class="text-sm text-slate-700">{{ t('customer_mail_settings_description', page_locale()) }}</p>
        </div>
        {% if client_settings is empty %}
            <div class="px-5 py-6 text-sm text-slate-700">{{ t('customer_mail_settings_empty', page_locale()) }}</div>
        {% else %}
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-slate-200 text-sm">
                    <thead class="bg-slate-50">
                        <tr>
                            <th class="px-5 py-3 text-left text-xs font-semibold uppercase text-slate-700">{{ t('customer_mail_settings_domain', page_locale()) }}</th>
                            <th class="px-5 py-3 text-left text-xs font-semibold uppercase text-slate-700">{{ t('customer_mail_settings_incoming', page_locale()) }}</th>
                            <th class="px-5 py-3 text-left text-xs font-semibold uppercase text-slate-700">{{ t('customer_mail_settings_outgoing', page_locale()) }}</th>
                            <th class="px-5 py-3 text-left text-xs font-semibold uppercase text-slate-700">DNS</th>
                            <th class="px-5 py-3 text-left text-xs font-semibold uppercase text-slate-700">{{ t('customer_mail_settings_username', page_locale()) }}</th>
                            <th class="px-5 py-3 text-left text-xs font-semibold uppercase text-slate-700">{{ t('customer_mail_settings_password', page_locale()) }}</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-200">
                        {% for setting in client_settings %}
                            <tr>
                                <td class="px-5 py-4 text-slate-700">{{ setting.domain }}</td>
                                <td class="px-5 py-4 text-slate-700">
                                    <div class="text-xs text-slate-500">{{ t('customer_mail_settings_host', page_locale()) }}</div>
                                    <div class="font-semibold text-slate-900">{{ setting.imap.host }}</div>
                                    <div class="text-xs text-slate-500">{{ t('customer_mail_settings_port', page_locale()) }} {{ setting.imap.port }} · {{ setting.imap.encryption }}</div>
                                </td>
                                <td class="px-5 py-4 text-slate-700">
                                    <div class="text-xs text-slate-500">{{ t('customer_mail_settings_host', page_locale()) }}</div>
                                    <div class="font-semibold text-slate-900">{{ setting.smtp.host }}</div>
                                    <div class="text-xs text-slate-500">{{ t('customer_mail_settings_port', page_locale()) }} {{ setting.smtp.port }} · {{ setting.smtp.encryption }}</div>
                                </td>
                                <td class="px-5 py-4 text-xs text-slate-700">
                                    <div><span class="font-semibold">SPF:</span> {{ setting.dns.spf }}</div>
                                    <div><span class="font-semibold">DKIM:</span> {{ setting.dns.dkim }}</div>
                                    <div><span class="font-semibold">DMARC:</span> {{ setting.dns.dmarc }}</div>
                                </td>
                                <td class="px-5 py-4 text-slate-700">{{ t('customer_mail_settings_username_hint', page_locale())|replace({'%domain%': setting.domain}) }}</td>
                                <td class="px-5 py-4 text-slate-700">{{ t('customer_mail_settings_password_hint', page_locale()) }}</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}
