{% extends 'customer/base.html.twig' %}

{% block content %}
<div class="customer-dashboard customer-dashboard--revamp flex flex-col gap-6">
    <section class="rounded-3xl border border-slate-800 bg-slate-900 px-6 py-6 text-slate-100 shadow-sm">
        <h1 class="text-3xl font-semibold">{{ t('customer_mail_title', page_locale()) }}</h1>
        <p class="mt-2 text-sm text-slate-400">{{ t('customer_mail_description', page_locale()) }}</p>
        {% set roundcube_url = (roundcube_bindings|first).url ?? '/roundcube' %}
        <a href="{{ roundcube_url }}" class="mt-4 inline-flex items-center rounded-lg bg-indigo-500 px-4 py-2 text-xs font-semibold text-white hover:bg-indigo-400" target="_blank" rel="noopener noreferrer">
            {{ t('customer_mail_roundcube_link', page_locale()) }}
        </a>
    </section>



    {% if roundcube_bindings is defined and roundcube_bindings is not empty %}
        <section class="dashboard-panel">
            <div class="dashboard-panel__header">
                <div>
                    <h3>Roundcube Bindings</h3>
                    <p>Diese URLs werden pro Domain für Webmail verwendet.</p>
                </div>
            </div>
            <div class="space-y-2 text-sm">
                {% for binding in roundcube_bindings %}
                    <div class="flex flex-wrap items-center justify-between gap-2 rounded-lg border border-slate-200 bg-slate-50 px-3 py-2">
                        <span class="font-semibold text-slate-800">{{ binding.domain }}</span>
                        <a href="{{ binding.url }}" target="_blank" rel="noopener noreferrer" class="text-indigo-600 hover:text-indigo-500">{{ binding.url }}</a>
                    </div>
                {% endfor %}
            </div>
        </section>
    {% endif %}

    {% if errors is defined and errors is not empty %}
        <div class="rounded-xl border border-rose-200 bg-rose-50 px-6 py-4 text-sm text-rose-700">
            <ul class="list-disc space-y-1 pl-5">
                {% for error in errors %}
                    <li>{{ error }}</li>
                {% endfor %}
            </ul>
        </div>
    {% endif %}

    <section class="grid gap-6 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)]">
        <div class="dashboard-panel">
            <div class="dashboard-panel__header">
                <div>
                    <h3>{{ t('customer_mail_create_title', page_locale()) }}</h3>
                    <p>{{ t('customer_mail_create_description', page_locale()) }}</p>
                </div>
            </div>
            <form method="post" action="{{ path('customer_mail_create') }}" class="space-y-4">
                <input type="hidden" name="_token" value="{{ csrf.mailbox_create }}">
                <div>
                    <label class="text-xs font-semibold uppercase text-slate-700">{{ t('customer_mail_domain_label', page_locale()) }}</label>
                    <select name="domain_id" class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm" required>
                        <option value="">{{ t('customer_mail_domain_placeholder', page_locale()) }}</option>
                        {% for domain in domains %}
                            <option value="{{ domain.id }}">{{ domain.name }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div>
                    <label class="text-xs font-semibold uppercase text-slate-700">{{ t('customer_mail_local_part_label', page_locale()) }}</label>
                    <input type="text" name="local_part" class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm" required>
                </div>
                <div class="grid gap-3 sm:grid-cols-2">
                    <div>
                        <label class="text-xs font-semibold uppercase text-slate-700">{{ t('customer_mail_password_label', page_locale()) }}</label>
                        <input type="password" name="password" minlength="8" class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm" required>
                    </div>
                    <div>
                        <label class="text-xs font-semibold uppercase text-slate-700">{{ t('customer_mail_quota_label', page_locale()) }}</label>
                        <input type="number" min="0" name="quota" value="0" class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm" required>
                    </div>
                </div>
                <input type="hidden" name="enabled" value="1">
                <button type="submit" class="ui-button ui-button--primary w-full">{{ t('customer_mail_create_action', page_locale()) }}</button>
            </form>
        </div>

        <div class="dashboard-panel">
            <div class="dashboard-panel__header">
                <div>
                    <h3>{{ t('customer_mail_overview', page_locale()) }}</h3>
                    <p>{{ t('customer_mail_overview_description', page_locale()) }}</p>
                </div>
            </div>
            {% if mailboxes is empty %}
                <div class="text-sm text-slate-500">{{ t('customer_mail_empty', page_locale()) }}</div>
            {% else %}
                <div class="space-y-3">
                    {% for mailbox in mailboxes %}
                        <article class="rounded-xl border border-slate-200 bg-slate-50 px-4 py-3">
                            <div class="flex flex-wrap items-center justify-between gap-2">
                                <div>
                                    <p class="text-sm font-semibold text-slate-900">{{ mailbox.address }}</p>
                                    <p class="text-xs text-slate-600">{{ mailbox.domain }} · {{ mailbox.quota }} MB · {{ mailbox.enabled ? t('customer_mail_status_active', page_locale()) : t('customer_mail_status_inactive', page_locale()) }}</p>
                                </div>
                                <form method="post" action="{{ path('customer_mail_delete', { id: mailbox.id }) }}" onsubmit="return confirm('{{ t('customer_mail_delete_confirm', page_locale()) }}');">
                                    <input type="hidden" name="_token" value="{{ csrf.mailboxes[mailbox.id].delete ?? '' }}">
                                    <button type="submit" class="text-xs font-semibold text-rose-600 hover:text-rose-500">{{ t('customer_mail_delete_action', page_locale()) }}</button>
                                </form>
                            </div>
                            <form method="post" action="{{ path('customer_mail_password_reset', { id: mailbox.id }) }}" class="mt-3 flex flex-wrap items-center gap-2">
                                <input type="hidden" name="_token" value="{{ csrf.mailboxes[mailbox.id].password ?? '' }}">
                                <input type="password" name="password" minlength="8" placeholder="{{ t('customer_mail_password_placeholder', page_locale()) }}" class="w-52 rounded-lg border border-slate-200 bg-white px-2 py-1 text-xs">
                                <button type="submit" class="rounded-lg border border-slate-200 px-3 py-1 text-xs font-semibold text-slate-700 hover:bg-white">{{ t('customer_mail_password_reset_action', page_locale()) }}</button>
                            </form>
                        </article>
                    {% endfor %}
                </div>
            {% endif %}
        </div>
    </section>


    <section class="grid gap-6 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)]">
        <div class="dashboard-panel">
            <div class="dashboard-panel__header">
                <div>
                    <h3>Alias erstellen</h3>
                    <p>Leite eine Adresse auf ein oder mehrere Ziele weiter.</p>
                </div>
            </div>
            <form method="post" action="{{ path('customer_mail_alias_create') }}" class="space-y-4">
                <input type="hidden" name="_token" value="{{ csrf.alias_create }}">
                <div>
                    <label class="text-xs font-semibold uppercase text-slate-700">Domain</label>
                    <select name="domain_id" class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm" required>
                        <option value="">Domain auswählen</option>
                        {% for domain in domains %}
                            <option value="{{ domain.id }}">{{ domain.name }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div>
                    <label class="text-xs font-semibold uppercase text-slate-700">Alias Name</label>
                    <input type="text" name="local_part" class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm" required>
                </div>
                <div>
                    <label class="text-xs font-semibold uppercase text-slate-700">Weiterleiten an</label>
                    <textarea name="destinations" rows="3" class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm" placeholder="user@example.com, admin@example.com" required></textarea>
                    <p class="mt-1 text-xs text-slate-500">Mehrere Ziele mit Komma, Semikolon oder Zeilenumbruch trennen.</p>
                </div>
                <input type="hidden" name="enabled" value="1">
                <button type="submit" class="ui-button ui-button--primary w-full">Alias erstellen</button>
            </form>
        </div>

        <div class="dashboard-panel">
            <div class="dashboard-panel__header">
                <div>
                    <h3>Aliase</h3>
                    <p>Verwalte aktive Weiterleitungen deiner Domains.</p>
                </div>
            </div>
            {% if aliases is empty %}
                <div class="text-sm text-slate-500">Noch keine Mail-Aliase vorhanden.</div>
            {% else %}
                <div class="space-y-3">
                    {% for alias in aliases %}
                        <article class="rounded-xl border border-slate-200 bg-slate-50 px-4 py-3">
                            <div class="flex flex-wrap items-center justify-between gap-2">
                                <div>
                                    <p class="text-sm font-semibold text-slate-900">{{ alias.address }}</p>
                                    <p class="text-xs text-slate-600">{{ alias.enabled ? 'Aktiv' : 'Inaktiv' }} · {{ alias.destinations|join(', ') }}</p>
                                </div>
                                <div class="flex items-center gap-3">
                                    <form method="post" action="{{ path('customer_mail_alias_status_update', { id: alias.id }) }}">
                                        <input type="hidden" name="_token" value="{{ csrf.aliases[alias.id].status ?? '' }}">
                                        <input type="hidden" name="enabled" value="{{ alias.enabled ? '0' : '1' }}">
                                        <button type="submit" class="text-xs font-semibold text-slate-700 hover:text-slate-500">{{ alias.enabled ? 'Deaktivieren' : 'Aktivieren' }}</button>
                                    </form>
                                    <form method="post" action="{{ path('customer_mail_alias_delete', { id: alias.id }) }}" onsubmit="return confirm('Alias wirklich löschen?');">
                                        <input type="hidden" name="_token" value="{{ csrf.aliases[alias.id].delete ?? '' }}">
                                        <button type="submit" class="text-xs font-semibold text-rose-600 hover:text-rose-500">Löschen</button>
                                    </form>
                                </div>
                            </div>
                            <form method="post" action="{{ path('customer_mail_alias_destinations_update', { id: alias.id }) }}" class="mt-3 space-y-2">
                                <input type="hidden" name="_token" value="{{ csrf.aliases[alias.id].destinations ?? '' }}">
                                <textarea name="destinations" rows="2" class="w-full rounded-lg border border-slate-200 bg-white px-2 py-1 text-xs">{{ alias.destinations|join(', ') }}</textarea>
                                <button type="submit" class="rounded-lg border border-slate-200 px-3 py-1 text-xs font-semibold text-slate-700 hover:bg-white">Ziele speichern</button>
                            </form>
                        </article>
                    {% endfor %}
                </div>
            {% endif %}
        </div>
    </section>

    <section class="dashboard-panel">
        <div class="dashboard-panel__header">
            <div>
                <h3>{{ t('customer_mail_settings_title', page_locale()) }}</h3>
                <p>{{ t('customer_mail_settings_description', page_locale()) }}</p>
            </div>
        </div>
        {% if client_settings is empty %}
            <div class="text-sm text-slate-500">{{ t('customer_mail_settings_empty', page_locale()) }}</div>
        {% else %}
            <div class="dashboard-table-wrapper">
                <table class="dashboard-table">
                    <thead>
                    <tr>
                        <th>{{ t('customer_mail_settings_domain', page_locale()) }}</th>
                        <th>{{ t('customer_mail_settings_incoming', page_locale()) }}</th>
                        <th>{{ t('customer_mail_settings_outgoing', page_locale()) }}</th>
                        <th>DNS</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for setting in client_settings %}
                        <tr>
                            <td>{{ setting.domain }}</td>
                            <td>{{ setting.imap.host }}:{{ setting.imap.port }} ({{ setting.imap.encryption }})</td>
                            <td>{{ setting.smtp.host }}:{{ setting.smtp.port }} ({{ setting.smtp.encryption }})</td>
                            <td>SPF: {{ setting.dns.spf }} · DKIM: {{ setting.dns.dkim }} · DMARC: {{ setting.dns.dmarc }}</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
    </section>
</div>
{% endblock %}
