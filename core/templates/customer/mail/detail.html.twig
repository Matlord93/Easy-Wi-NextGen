{% extends 'customer/base.html.twig' %}
{% block content %}
{% set locale = page_locale() %}
<div class="cust-page">

    <div class="cust-panel">
        <div class="cust-panel__head">
            <div>
                <h1 class="cust-panel__title">{{ t('customer_mailbox_detail_title', locale) }}</h1>
            </div>
        </div>
        <div style="display:flex;flex-direction:column;gap:16px;padding:16px;">

            {% if last_job and last_job.status == 'failed' %}
                <div class="cust-alert cust-alert--error">{{ t('customer_mailbox_detail_last_job_failed', locale) }}: {{ last_job.error ?: 'unknown' }}</div>
            {% endif %}
            {% if password_scheduled %}
                <div class="cust-alert" style="border-color:rgba(52,211,153,.3);background:rgba(52,211,153,.08);color:#6ee7b7;">{{ t('customer_mailbox_detail_password_scheduled', locale) }}</div>
            {% endif %}

            {# Mailbox info #}
            <div style="border:1px solid var(--ng-border);border-radius:10px;padding:16px;background:var(--ng-surface);display:flex;flex-direction:column;gap:6px;font-size:13px;">
                <div><strong style="color:var(--ng-text);">{{ t('customer_mailbox_detail_address', locale) }}:</strong> <span style="color:var(--ng-text-muted);">{{ mailbox.address }}</span></div>
                <div><strong style="color:var(--ng-text);">{{ t('customer_mailbox_detail_domain', locale) }}:</strong> <span style="color:var(--ng-text-muted);">{{ mailbox.domain.name }}</span></div>
                <div><strong style="color:var(--ng-text);">{{ t('customer_mailbox_detail_status', locale) }}:</strong>
                    <span class="ui-badge ui-badge--{{ mailbox.enabled ? 'success' : 'neutral' }}" style="margin-left:4px;">{{ mailbox.enabled ? t('customer_mailbox_status_enabled', locale) : t('customer_mailbox_status_disabled', locale) }}</span>
                </div>
                <div><strong style="color:var(--ng-text);">{{ t('customer_mailbox_detail_quota', locale) }}:</strong> <span style="color:var(--ng-text-muted);">{{ mailbox.quota }} MB</span></div>
                <div><strong style="color:var(--ng-text);">{{ t('customer_mailbox_detail_node', locale) }}:</strong> <span style="color:var(--ng-text-muted);">{{ mail_node_name ?: '—' }}</span></div>
            </div>

            {# Storage #}
            <div style="border:1px solid var(--ng-border);border-radius:10px;padding:16px;background:var(--ng-surface);display:flex;flex-direction:column;gap:10px;font-size:13px;">
                <h2 style="font-weight:600;color:var(--ng-text);">{{ t('customer_mailbox_detail_storage_title', locale) }}</h2>
                {% if quota_usage.available %}
                    {% if quota_usage.quota_mb > 0 %}
                        <p style="color:var(--ng-text);">{{ quota_usage.used_mb|number_format(1, ',', '.') }} MB {{ t('customer_mailbox_detail_storage_used_of', locale) }} {{ quota_usage.quota_mb }} MB</p>
                        <div style="height:8px;width:100%;overflow:hidden;border-radius:4px;background:var(--ng-border);">
                            <div style="height:100%;background:var(--ng-primary);width:{{ quota_usage.percent_bar|number_format(1, '.', '') }}%;"></div>
                        </div>
                        <p style="font-size:11px;color:var(--ng-text-muted);">{{ quota_usage.percent|number_format(1, ',', '.') }} % {{ t('customer_mailbox_detail_storage_percent', locale) }}</p>
                    {% else %}
                        <p style="color:var(--ng-text);">{{ quota_usage.used_mb|number_format(1, ',', '.') }} MB {{ t('customer_mailbox_detail_storage_used_unlimited', locale) }}</p>
                    {% endif %}
                    {% if quota_usage.truncated %}
                        <p style="font-size:11px;color:#fbbf24;">{{ t('customer_mailbox_detail_storage_truncated', locale) }}</p>
                    {% endif %}
                {% else %}
                    <p style="color:var(--ng-text-muted);">{{ t('customer_mailbox_detail_storage_missing', locale) }}</p>
                {% endif %}
            </div>

            {# Last job #}
            <div style="border:1px solid var(--ng-border);border-radius:10px;padding:16px;background:var(--ng-surface);font-size:13px;">
                <h2 style="font-weight:600;color:var(--ng-text);margin-bottom:8px;">{{ t('customer_mailbox_detail_job_title', locale) }}</h2>
                {% if last_job %}
                    <div style="color:var(--ng-text-muted);">{{ last_job.type }} · {{ last_job.status }}{% if last_job.error %} · {{ last_job.error }}{% endif %}</div>
                {% else %}
                    <div style="color:var(--ng-text-muted);">{{ t('customer_mailbox_detail_job_empty', locale) }}</div>
                {% endif %}
            </div>

            {# Connection settings #}
            {% set email_address = mailbox.address %}
            {% set setup_text %}{{ t('customer_mailbox_detail_address', locale) }}: {{ email_address }}
{{ t('customer_mailbox_detail_username', locale) }}: {{ username }}

IMAP:
{{ t('customer_mailbox_detail_server', locale) }}: {{ imap.host }}
{{ t('customer_mailbox_detail_port', locale) }}: {{ imap.port }}
{{ t('customer_mailbox_detail_encryption', locale) }}: {{ imap.encryption }}

POP3:
{{ t('customer_mailbox_detail_server', locale) }}: {{ pop3.host }}
{{ t('customer_mailbox_detail_port', locale) }}: {{ pop3.port }}
{{ t('customer_mailbox_detail_encryption', locale) }}: {{ pop3.encryption }}

SMTP:
{{ t('customer_mailbox_detail_server', locale) }}: {{ smtp.host }}
{{ t('customer_mailbox_detail_port', locale) }}: {{ smtp.port }}
{{ t('customer_mailbox_detail_encryption', locale) }}: {{ smtp.encryption }}
{{ t('customer_mailbox_detail_smtp_auth_required', locale) }}
{{ t('customer_mailbox_detail_username', locale) }}: {{ username }}{% endset %}
            <div style="border:1px solid var(--ng-border);border-radius:10px;padding:16px;background:var(--ng-surface);display:flex;flex-direction:column;gap:16px;font-size:13px;">
                <h2 style="font-weight:600;color:var(--ng-text);">{{ t('customer_mailbox_detail_connection_title', locale) }}</h2>
                <div style="display:grid;gap:12px;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));">
                    <div style="border:1px solid var(--ng-border);border-radius:8px;padding:12px;display:flex;flex-direction:column;gap:4px;">
                        <h3 style="font-weight:600;color:var(--ng-text);margin-bottom:4px;">IMAP</h3>
                        <div><strong style="color:var(--ng-text);">{{ t('customer_mailbox_detail_server', locale) }}:</strong> <span style="color:var(--ng-text-muted);">{{ imap.host }}</span></div>
                        <div><strong style="color:var(--ng-text);">{{ t('customer_mailbox_detail_port', locale) }}:</strong> <span style="color:var(--ng-text-muted);">{{ imap.port }}</span></div>
                        <div><strong style="color:var(--ng-text);">{{ t('customer_mailbox_detail_encryption', locale) }}:</strong> <span style="color:var(--ng-text-muted);">{{ imap.encryption }}</span></div>
                        <div><strong style="color:var(--ng-text);">{{ t('customer_mailbox_detail_username', locale) }}:</strong> <span style="color:var(--ng-text-muted);">{{ username }}</span></div>
                    </div>
                    <div style="border:1px solid var(--ng-border);border-radius:8px;padding:12px;display:flex;flex-direction:column;gap:4px;">
                        <h3 style="font-weight:600;color:var(--ng-text);margin-bottom:4px;">POP3</h3>
                        <div><strong style="color:var(--ng-text);">{{ t('customer_mailbox_detail_server', locale) }}:</strong> <span style="color:var(--ng-text-muted);">{{ pop3.host }}</span></div>
                        <div><strong style="color:var(--ng-text);">{{ t('customer_mailbox_detail_port', locale) }}:</strong> <span style="color:var(--ng-text-muted);">{{ pop3.port }}</span></div>
                        <div><strong style="color:var(--ng-text);">{{ t('customer_mailbox_detail_encryption', locale) }}:</strong> <span style="color:var(--ng-text-muted);">{{ pop3.encryption }}</span></div>
                        <div><strong style="color:var(--ng-text);">{{ t('customer_mailbox_detail_username', locale) }}:</strong> <span style="color:var(--ng-text-muted);">{{ username }}</span></div>
                    </div>
                    <div style="border:1px solid var(--ng-border);border-radius:8px;padding:12px;display:flex;flex-direction:column;gap:4px;">
                        <h3 style="font-weight:600;color:var(--ng-text);margin-bottom:4px;">SMTP</h3>
                        <div><strong style="color:var(--ng-text);">{{ t('customer_mailbox_detail_server', locale) }}:</strong> <span style="color:var(--ng-text-muted);">{{ smtp.host }}</span></div>
                        <div><strong style="color:var(--ng-text);">{{ t('customer_mailbox_detail_port', locale) }}:</strong> <span style="color:var(--ng-text-muted);">{{ smtp.port }}</span></div>
                        <div><strong style="color:var(--ng-text);">{{ t('customer_mailbox_detail_encryption', locale) }}:</strong> <span style="color:var(--ng-text-muted);">{{ smtp.encryption }}</span></div>
                        <div style="color:var(--ng-text-muted);">{{ t('customer_mailbox_detail_smtp_auth_required', locale) }}</div>
                        <div><strong style="color:var(--ng-text);">{{ t('customer_mailbox_detail_username', locale) }}:</strong> <span style="color:var(--ng-text-muted);">{{ username }}</span></div>
                    </div>
                </div>

                <div style="display:flex;flex-wrap:wrap;gap:8px;">
                    <button type="button" class="ui-button ui-button--ghost ui-button--sm" onclick="navigator.clipboard.writeText('{{ imap.host|e('js') }}')">{{ t('customer_mailbox_detail_copy_imap', locale) }}</button>
                    <button type="button" class="ui-button ui-button--ghost ui-button--sm" onclick="navigator.clipboard.writeText('{{ pop3.host|e('js') }}')">{{ t('customer_mailbox_detail_copy_pop3', locale) }}</button>
                    <button type="button" class="ui-button ui-button--ghost ui-button--sm" onclick="navigator.clipboard.writeText('{{ smtp.host|e('js') }}')">{{ t('customer_mailbox_detail_copy_smtp', locale) }}</button>
                    <button type="button" class="ui-button ui-button--ghost ui-button--sm" onclick="navigator.clipboard.writeText('{{ username|e('js') }}')">{{ t('customer_mailbox_detail_copy_username', locale) }}</button>
                    <button type="button" class="ui-button ui-button--ghost ui-button--sm" onclick="navigator.clipboard.writeText('{{ setup_text|trim|e('js') }}')">{{ t('customer_mailbox_detail_copy_config', locale) }}</button>
                </div>

                <div style="border:1px solid var(--ng-border);border-radius:8px;padding:12px;background:var(--ng-surface-soft);">
                    <h3 style="font-weight:600;color:var(--ng-text);margin-bottom:8px;">{{ t('customer_mailbox_detail_setup_title', locale) }}</h3>
                    <ul style="list-style:disc;padding-left:20px;font-size:12px;color:var(--ng-text-muted);display:flex;flex-direction:column;gap:4px;">
                        <li>{{ t('customer_mailbox_detail_setup_imap_recommended', locale) }}</li>
                        <li>{{ t('customer_mailbox_detail_setup_intro', locale) }}</li>
                        <li>{{ t('customer_mailbox_detail_setup_smtp_auth_enabled', locale) }}</li>
                        <li>{{ t('customer_mailbox_detail_setup_password_hint', locale) }}</li>
                    </ul>
                </div>

                {% if webmail_url %}
                    <div style="display:flex;flex-direction:column;gap:6px;">
                        <a href="{{ webmail_url }}" target="_blank" rel="noopener" class="ui-button ui-button--primary" style="width:fit-content;">{{ t('customer_mailbox_detail_webmail_open', locale) }}</a>
                        <p style="font-size:12px;color:var(--ng-text-muted);">{{ t('customer_mailbox_detail_webmail_hint', locale) }}</p>
                    </div>
                {% else %}
                    <p style="font-size:12px;color:var(--ng-text-muted);">{{ t('customer_mailbox_detail_webmail_missing', locale) }}</p>
                {% endif %}

                <div style="display:flex;flex-direction:column;gap:6px;">
                    <a href="/.well-known/autoconfig/mail/config-v1.1.xml?emailaddress={{ mailbox.address|url_encode }}" target="_blank" rel="noopener" class="ui-button ui-button--ghost" style="width:fit-content;">{{ t('customer_mailbox_detail_thunderbird_autoconfig', locale) }}</a>
                    <p style="font-size:12px;color:var(--ng-text-muted);">{{ t('customer_mailbox_detail_thunderbird_hint', locale) }}</p>
                </div>

                {% if dns_check is not null and dns_check.checks is defined %}
                    <div style="border:1px solid var(--ng-border);border-radius:8px;padding:12px;background:var(--ng-surface);display:flex;flex-direction:column;gap:8px;">
                        <h3 style="font-weight:600;color:var(--ng-text);">{{ t('customer_mail_dns_title', locale) }}</h3>
                        <p style="font-size:12px;color:var(--ng-text-muted);">{{ dns_check.overall_ok ? t('customer_mail_dns_ok', locale) : t('customer_mail_dns_warning', locale) }}</p>
                        <ul style="list-style:disc;padding-left:20px;font-size:12px;color:var(--ng-text-muted);display:flex;flex-direction:column;gap:3px;">
                            <li>MX: {{ dns_check.checks.mx.ok ? t('customer_mailbox_dns_check_ok', locale) : t('customer_mailbox_dns_check_missing', locale) }}</li>
                            <li>SPF: {{ dns_check.checks.spf.ok ? t('customer_mailbox_dns_check_ok', locale) : t('customer_mailbox_dns_check_missing', locale) }}</li>
                            <li>DMARC: {{ dns_check.checks.dmarc.ok ? t('customer_mailbox_dns_check_ok', locale) : t('customer_mailbox_dns_check_missing', locale) }}</li>
                            <li>DKIM: {{ dns_check.checks.dkim.message }}</li>
                        </ul>
                    </div>
                {% else %}
                    <div style="border:1px solid var(--ng-border);border-radius:8px;padding:12px;background:var(--ng-surface);display:flex;flex-direction:column;gap:8px;">
                        <h3 style="font-weight:600;color:var(--ng-text);">{{ t('customer_mail_dns_title', locale) }}</h3>
                        <a href="?dns_check=1" class="ui-button ui-button--ghost ui-button--sm" style="width:fit-content;">{{ t('customer_mail_dns_run_check', locale) }}</a>
                    </div>
                {% endif %}

                {% if smtp_policy is defined %}
                    <div style="border:1px solid var(--ng-border);border-radius:8px;padding:12px;background:var(--ng-surface);display:flex;flex-direction:column;gap:6px;font-size:13px;">
                        <h3 style="font-weight:600;color:var(--ng-text);">{{ t('customer_mail_policy_title', locale) }}</h3>
                        <div style="color:var(--ng-text-muted);">{{ t('mail_policy_title', locale) }}</div>
                        <div style="color:var(--ng-text-muted);">{{ t('customer_mail_policy_status', locale) }}: {{ smtp_policy.smtp_enabled ? t('mail_policy_smtp_enabled', locale) : t('mail_policy_smtp_disabled', locale) }}</div>
                        {% if smtp_policy.send_limit_hour is not null %}<div style="color:var(--ng-text-muted);">{{ t('customer_mail_policy_send_limit', locale) }}: {{ smtp_policy.send_limit_hour }}</div>{% endif %}
                        {% if smtp_policy.recipient_limit is not null %}<div style="color:var(--ng-text-muted);">{{ t('customer_mail_policy_recipient_limit', locale) }}: {{ smtp_policy.recipient_limit }}</div>{% endif %}
                        <div style="color:var(--ng-text-muted);">{{ t('mail_policy_abuse_enabled', locale) }}: {{ smtp_policy.abuse_policy_enabled ? t('mail_policy_status_enabled', locale) : t('mail_policy_status_disabled', locale) }}</div>
                        <p style="font-size:11px;color:var(--ng-text-muted);">{{ t('mail_policy_enforcement_notice', locale) }}</p>
                    </div>
                {% endif %}

                {# Password change #}
                <div style="border:1px solid var(--ng-border);border-radius:8px;padding:12px;background:var(--ng-surface-soft);display:flex;flex-direction:column;gap:10px;">
                    <h3 style="font-weight:600;color:var(--ng-text);">{{ t('customer_mailbox_detail_password_title', locale) }}</h3>
                    <p style="font-size:12px;color:var(--ng-text-muted);">{{ t('customer_mailbox_detail_password_provisioning_hint', locale) }}</p>
                    <form method="post" action="{{ path('customer_mail_password_reset', { id: mailbox.id }) }}" style="display:flex;flex-direction:column;gap:10px;">
                        <input type="hidden" name="_csrf_token" value='{{ password_csrf }}'>
                        <div>
                            <label for="mailbox-password" class="cust-form-label">{{ t('customer_mailbox_detail_new_password', locale) }}</label>
                            <input id="mailbox-password" name="password" type="password" autocomplete="new-password" required minlength="8">
                        </div>
                        <p style="font-size:11px;color:var(--ng-text-muted);">{{ t('customer_mailbox_detail_password_hint', locale) }}</p>
                        <button type="submit" class="ui-button ui-button--primary" style="width:fit-content;">{{ t('customer_mailbox_detail_password_submit', locale) }}</button>
                    </form>
                </div>
            </div>

        </div>
    </div>

</div>
{% endblock %}
