{% extends 'customer/base.html.twig' %}

{% set activeNav    = 'voiceservers' %}
{% set voiceBaseUrl = voiceBaseUrl|default('/customer/ts3/servers') %}

{% block content %}
{% set locale = page_locale() %}
<div class="cust-page">

    <div class="cust-hero">
        <div class="cust-hero__inner">
            <div>
                <h1 class="cust-hero__title">{{ t('customer_voiceservers_page_title', locale) }}</h1>
                <p class="cust-hero__desc">{{ t('customer_voiceservers_page_desc', locale) }}</p>
            </div>
        </div>
    </div>

    <div class="cust-panel" style="padding:0;overflow:hidden;">

        {% if servers is empty %}
            <div style="padding:48px;text-align:center;color:var(--ng-text-muted);">
                <svg width="40" height="40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.2" style="margin:0 auto 12px;display:block;opacity:.4;"><path stroke-linecap="round" stroke-linejoin="round" d="M3.5 6.5A.5.5 0 014 7v1a4 4 0 008 0V7a.5.5 0 011 0v1a5 5 0 01-4.5 4.975V15h3a.5.5 0 010 1h-7a.5.5 0 010-1h3v-2.025A5 5 0 013 8V7a.5.5 0 01.5-.5z"/></svg>
                <p style="margin:0;font-size:13px;">{{ t('customer_voiceservers_none', locale) }}</p>
            </div>
        {% else %}
            {% for server in servers %}
                {% set st = server.status|default('unknown')|lower %}
                {% set isOnline  = st in ['online','running','active'] %}
                {% set isOffline = st in ['offline','stopped','stopping'] %}
                {% set stripeColor = isOnline ? 'linear-gradient(to bottom,#4ade80,#22c55e)' : (isOffline ? 'linear-gradient(to bottom,#f87171,#ef4444)' : 'var(--ng-border-strong)') %}
                {% set dotClass   = isOnline ? 'vs-dot--success' : (isOffline ? 'vs-dot--danger' : 'vs-dot--warning') %}
                <div class="vsi-row">
                    <div class="vsi-row__stripe" style="background:{{ stripeColor }};"></div>
                    <div class="vsi-row__body">
                        <div class="vsi-row__identity">
                            <div class="vsi-row__name">{{ server.name }}</div>
                            <div class="vsi-row__sub">
                                ID #{{ server.sid }} ·
                                Port <strong>{{ server.voicePort ?? '—' }}</strong>
                                {% if server.filetransferPort is defined and server.filetransferPort %}
                                    · FT <strong>{{ server.filetransferPort }}</strong>
                                {% endif %}
                            </div>
                        </div>
                        <div class="vsi-row__meta">
                            <span class="vsi-dot vsi-dot--{{ isOnline ? 'success' : (isOffline ? 'danger' : 'warning') }}">{{ st|replace({'_':' '})|title }}</span>
                            {% if server.updatedAt is defined %}
                                <span class="vsi-meta-item">{{ server.updatedAt|date('Y-m-d H:i') }}</span>
                            {% endif %}
                        </div>
                        <div class="vsi-row__actions">
                            <a href="{{ voiceBaseUrl }}/{{ server.id }}" class="ui-button ui-button--primary ui-button--sm">{{ t('customer_voiceservers_manage', locale) }}</a>
                        </div>
                    </div>
                </div>
            {% endfor %}
        {% endif %}

    </div>
</div>

<style>
.vsi-row { display:flex;border-bottom:1px solid var(--ng-border); }
.vsi-row:last-child { border-bottom:none; }
.vsi-row__stripe { width:3px;flex-shrink:0; }
.vsi-row__body { flex:1;min-width:0;padding:14px 18px;display:flex;flex-wrap:wrap;align-items:center;gap:12px; }
.vsi-row__identity { flex:1;min-width:160px; }
.vsi-row__name { font-size:14px;font-weight:700;color:var(--ng-text); }
.vsi-row__sub { font-size:11px;color:var(--ng-text-muted);margin-top:3px; }
.vsi-row__meta { display:flex;align-items:center;gap:10px;flex-wrap:wrap; }
.vsi-meta-item { font-size:11px;color:var(--ng-text-muted); }
.vsi-row__actions { display:flex;gap:6px;flex-wrap:wrap; }
.vsi-dot { display:inline-flex;align-items:center;gap:5px;font-size:11px;font-weight:600;padding:2px 9px;border-radius:99px; }
.vsi-dot::before { content:'';width:6px;height:6px;border-radius:50%;flex-shrink:0; }
.vsi-dot--success { background:rgba(34,197,94,.12);color:#4ade80; }
.vsi-dot--success::before { background:#4ade80; }
.vsi-dot--danger  { background:rgba(239,68,68,.12);color:#f87171; }
.vsi-dot--danger::before  { background:#f87171; }
.vsi-dot--warning { background:rgba(245,158,11,.12);color:#fbbf24; }
.vsi-dot--warning::before { background:#fbbf24; }
</style>
{% endblock %}
