{% extends 'customer/base.html.twig' %}

{% set activeNav = 'shop' %}
{% set locale = page_locale() %}
{% block title %}{{ t('customer_shop_title', locale) }} · Easy-Wi NextGen{% endblock %}

{% block content %}
<div class="cust-page">

    <div class="cust-hero">
        <div class="cust-hero__inner">
            <div>
                <div class="cust-hero__label">{{ t('customer_nav_group_marketplace', locale) }}</div>
                <h1 class="cust-hero__title">{{ t('customer_shop_title', locale) }}</h1>
                <p class="cust-hero__desc">{{ t('customer_shop_desc', locale) }}</p>
            </div>
        </div>
    </div>

    {# ── Active rentals ── #}
    <div class="cust-panel">
        <div class="cust-panel__head">
            <div>
                <h3 class="cust-panel__title">{{ t('customer_shop_active_rentals', locale) }}</h3>
            </div>
        </div>
        <div class="cust-panel__body">
            {% if rentals is not empty %}
                <div class="cust-server-grid">
                    {% for rental in rentals %}
                        <div style="border-radius:10px;border:1px solid var(--ng-border);background:var(--ng-surface-soft);padding:16px;">
                            <p style="margin:0;font-size:13px;font-weight:600;color:var(--ng-text);">{{ rental.product_name }}</p>
                            <p style="margin:4px 0 0;font-size:11px;color:var(--ng-text-muted);">Instance #{{ rental.instance_id }}</p>
                            <p style="margin:6px 0 0;font-size:11px;color:var(--ng-text-muted);">{{ t('customer_shop_period', locale) }}: {{ rental.expires_at }}</p>
                            <form class="ng-form" style="margin-top:12px;display:flex;align-items:center;gap:8px;" method="post" action="/marketplace/rentals/{{ rental.id }}/extend">
                                <input type="number" name="months" min="1" value="1" class="form-input" style="width:72px;padding:5px 8px;font-size:12px;" aria-label="{{ t('customer_shop_months_label', locale) }}">
                                <button type="submit" class="ui-button ui-button--primary ui-button--sm">{{ t('customer_shop_extend_button', locale) }}</button>
                            </form>
                        </div>
                    {% endfor %}
                </div>
            {% else %}
                <div class="cust-empty">
                    <svg viewBox="0 0 16 16" fill="currentColor"><path d="M0 1.5A.5.5 0 0 1 .5 1H2a.5.5 0 0 1 .485.379L2.89 3H14.5a.5.5 0 0 1 .49.598l-1 5a.5.5 0 0 1-.465.401l-9.397.472L4.415 11H13a.5.5 0 0 1 0 1H4a.5.5 0 0 1-.491-.408L2.01 3.607 1.61 2H.5a.5.5 0 0 1-.5-.5z"/></svg>
                    {{ t('customer_shop_no_rentals', locale) }}
                </div>
            {% endif %}
        </div>
    </div>

    {# ── Product catalog ── #}
    {% for category in categories %}
        <div class="cust-panel">
            <div class="cust-panel__head">
                <h3 class="cust-panel__title">{{ category.name }}</h3>
            </div>
            <div class="cust-panel__body">
                {% if category.products is not empty %}
                    <div class="cust-server-grid">
                        {% for product in category.products %}
                            <div style="border-radius:10px;border:1px solid var(--ng-border);background:var(--ng-surface-soft);padding:16px;display:flex;flex-direction:column;gap:8px;">
                                {% if product.image_url %}
                                    <img src="{{ product.image_url }}" alt="{{ product.name }}" style="width:100%;height:120px;border-radius:8px;object-fit:cover;">
                                {% endif %}
                                <h4 style="margin:0;font-size:14px;font-weight:700;color:var(--ng-text);">{{ product.name }}</h4>
                                {% if product.description %}
                                    <p style="margin:0;font-size:12px;color:var(--ng-text-muted);">{{ product.description }}</p>
                                {% endif %}
                                <div style="font-size:11px;color:var(--ng-text-muted);">
                                    {{ product.cpu_limit }} CPU · {{ product.ram_limit }} GB RAM · {{ product.disk_limit }} GB SSD
                                </div>
                                <div style="margin-top:auto;display:flex;align-items:center;justify-content:space-between;padding-top:8px;border-top:1px solid var(--ng-border);">
                                    <span style="font-size:13px;font-weight:700;color:var(--ng-text);">€ {{ product.price_monthly }} / {{ t('customer_shop_period', locale) }}</span>
                                </div>
                                <form style="display:flex;align-items:center;gap:8px;" method="post" action="/marketplace/order">
                                    <input type="hidden" name="product_id" value="{{ product.id }}">
                                    <input type="number" name="months" min="1" value="1" class="form-input" style="width:72px;padding:5px 8px;font-size:12px;" aria-label="{{ t('customer_shop_months_label', locale) }}">
                                    <button type="submit" class="ui-button ui-button--primary ui-button--sm" style="flex:1;">{{ t('customer_shop_order', locale) }}</button>
                                </form>
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="cust-empty">
                        <svg viewBox="0 0 16 16" fill="currentColor"><path d="M0 1.5A.5.5 0 0 1 .5 1H2a.5.5 0 0 1 .485.379L2.89 3H14.5a.5.5 0 0 1 .49.598l-1 5a.5.5 0 0 1-.465.401l-9.397.472L4.415 11H13a.5.5 0 0 1 0 1H4a.5.5 0 0 1-.491-.408L2.01 3.607 1.61 2H.5a.5.5 0 0 1-.5-.5z"/></svg>
                        {{ t('customer_shop_none', locale) }}
                    </div>
                {% endif %}
            </div>
        </div>
    {% endfor %}

</div>
{% endblock %}
