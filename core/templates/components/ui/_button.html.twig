{% set label = label|default('') %}
{% set href = href|default('#') %}
{% set variant = variant|default('ghost') %}
{% set icon = icon|default('') %}

<a href="{{ href }}" class="ui-button ui-button--{{ variant }} {{ class|default('') }}">
    {% if icon %}
        {# icon is an SVG string from PHP code, never from user input #}
        <span class="text-base">{{ icon|raw }}</span>
    {% endif %}
    {{ label }}
</a>
