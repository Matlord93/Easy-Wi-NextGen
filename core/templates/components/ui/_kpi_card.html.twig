{% set label = label|default('') %}
{% set value = value|default('—') %}
{% set icon = icon|default('') %}
{% set tone = tone|default('accent') %}

<div class="ui-kpi {{ class|default('') }}">
    <div>
        <div class="ui-kpi__label">{{ label }}</div>
        <div class="ui-kpi__value">{{ value }}</div>
    </div>
    <div class="ui-kpi__icon ui-kpi__icon--{{ tone }}">
        {{ icon|raw }}
    </div>
</div>
