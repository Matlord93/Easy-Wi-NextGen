{% set headers = headers|default([]) %}
{% set rows = rows|default([]) %}

<div class="ui-table__wrap">
    <table class="ui-table {{ class|default('') }}">
        <thead>
            <tr>
                {% for header in headers %}
                    <th>{{ header }}</th>
                {% endfor %}
            </tr>
        </thead>
        <tbody>
            {% for row in rows %}
                <tr>
                    {% for cell in row %}
                        {# cells contain pre-rendered HTML (buttons, badges) built by PHP, never raw user input #}
                        <td>{{ cell|raw }}</td>
                    {% endfor %}
                </tr>
            {% else %}
                <tr>
                    <td colspan="{{ headers|length }}">{{ empty|default('—') }}</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
