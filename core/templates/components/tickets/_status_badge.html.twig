{% set locale = locale ?? page_locale() %}
{% set statusLabels = statusLabels ?? {
    'open':     t('admin_tickets_status_open', locale),
    'pending':  t('admin_tickets_status_pending', locale),
    'resolved': t('admin_tickets_status_resolved', locale),
    'closed':   t('admin_tickets_status_closed', locale),
} %}
{% set badgeClass = {
    'open':     'ui-badge--info',
    'pending':  'ui-badge--warning',
    'resolved': 'ui-badge--success',
    'closed':   'ui-badge--neutral',
} %}
<span class="ui-badge {{ badgeClass[ticket.status] ?? 'ui-badge--neutral' }}">
    <span style="display:inline-block;width:5px;height:5px;border-radius:50%;background:currentColor;opacity:.75;margin-right:2px;vertical-align:middle;"></span>
    {{ statusLabels[ticket.status] ?? ticket.status|title }}
</span>
