{# ─── Command Palette Overlay ─── #}
<div id="cmd-palette" class="cmd-palette" role="dialog" aria-modal="true" aria-label="{{ t('cmd_palette_aria', locale) }}" hidden>
    <div class="cmd-palette__backdrop" id="cmd-backdrop"></div>
    <div class="cmd-palette__panel">
        <div class="cmd-palette__header">
            <svg class="cmd-palette__search-icon" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.099zm-5.598 1.11a5.5 5.5 0 1 1 0-11 5.5 5.5 0 0 1 0 11z"/>
            </svg>
            <input
                id="cmd-input"
                class="cmd-palette__input"
                type="text"
                placeholder="{{ t('cmd_palette_placeholder', locale) }}"
                autocomplete="off"
                spellcheck="false"
            >
            <kbd class="cmd-palette__esc-badge">Esc</kbd>
        </div>

        <div class="cmd-palette__body" id="cmd-body">
            {% for group in hiddenGroups %}
                <div class="cmd-palette__group" data-group>
                    <div class="cmd-palette__group-label">{{ group.label }}</div>
                    {% for item in group.items %}
                        <a href="{{ item.href }}"
                           class="cmd-palette__item"
                           data-label="{{ item.label|lower }}"
                           data-desc="{{ item.desc|lower }}">
                            <span class="cmd-palette__item-icon" aria-hidden="true">{{ item.icon|raw }}</span>
                            <span class="cmd-palette__item-body">
                                <span class="cmd-palette__item-label">{{ item.label }}</span>
                                <span class="cmd-palette__item-desc">{{ item.desc }}</span>
                            </span>
                            <svg class="cmd-palette__item-arrow" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                                <path fill-rule="evenodd" d="M4.646 1.646a.5.5 0 0 1 .708 0l6 6a.5.5 0 0 1 0 .708l-6 6a.5.5 0 0 1-.708-.708L10.293 8 4.646 2.354a.5.5 0 0 1 0-.708z"/>
                            </svg>
                        </a>
                    {% endfor %}
                </div>
            {% endfor %}

            <div class="cmd-palette__empty" id="cmd-empty" hidden>
                <svg viewBox="0 0 20 20" fill="currentColor" width="24" height="24" aria-hidden="true">
                    <path fill-rule="evenodd" d="M9 3.5a5.5 5.5 0 1 0 0 11 5.5 5.5 0 0 0 0-11zM2 9a7 7 0 1 1 12.452 4.391l3.328 3.329a.75.75 0 1 1-1.06 1.06l-3.329-3.328A7 7 0 0 1 2 9z" clip-rule="evenodd"/>
                </svg>
                <span>{{ t('cmd_palette_empty', locale) }}</span>
            </div>
        </div>

        <div class="cmd-palette__footer">
            <span><kbd>↑</kbd><kbd>↓</kbd> {{ t('cmd_palette_kbd_navigate', locale) }}</span>
            <span><kbd>↵</kbd> {{ t('cmd_palette_kbd_open', locale) }}</span>
            <span><kbd>Esc</kbd> {{ t('cmd_palette_kbd_close', locale) }}</span>
            <span class="cmd-palette__footer-hint">
                <kbd>Ctrl</kbd><kbd>K</kbd> {{ t('cmd_palette_kbd_shortcut', locale) }}
            </span>
        </div>
    </div>
</div>

{# ─── Sidebar trigger button (added via JS to sidebar footer) ─── #}
<template id="cmd-trigger-tpl">
    <button type="button" id="cmd-trigger" class="cmd-palette__trigger" aria-label="{{ t('cmd_palette_trigger_aria', locale) }}" title="{{ t('cmd_palette_trigger_title', locale) }}">
        <svg viewBox="0 0 16 16" fill="currentColor" width="14" height="14" aria-hidden="true">
            <path d="M3.5 3.5a.5.5 0 0 0-1 0v8.793l-1.146-1.147a.5.5 0 0 0-.708.708l2 1.999.007.007a.497.497 0 0 0 .7-.006l2-2a.5.5 0 0 0-.707-.708L3.5 12.293V3.5zm4 .5a.5.5 0 0 1 0-1h1a.5.5 0 0 1 0 1h-1zm0 3a.5.5 0 0 1 0-1h3a.5.5 0 0 1 0 1h-3zm0 3a.5.5 0 0 1 0-1h5a.5.5 0 0 1 0 1h-5zM7 12.5a.5.5 0 0 0 .5.5h7a.5.5 0 0 0 0-1h-7a.5.5 0 0 0-.5.5z"/>
        </svg>
        <span>{{ t('cmd_palette_trigger_label', locale) }}</span>
        <span class="cmd-palette__trigger-kbd"><kbd>Ctrl</kbd><kbd>K</kbd></span>
    </button>
</template>

<script>
(function () {
    var palette  = document.getElementById('cmd-palette');
    var input    = document.getElementById('cmd-input');
    var body     = document.getElementById('cmd-body');
    var empty    = document.getElementById('cmd-empty');
    var backdrop = document.getElementById('cmd-backdrop');

    /* ── Sidebar trigger button ── */
    (function injectTrigger() {
        var tpl = document.getElementById('cmd-trigger-tpl');
        if (!tpl) return;
        var sidebar = document.querySelector('.ng-sidebar');
        if (!sidebar) return;

        var footer = sidebar.querySelector('.ng-sidebar__footer');
        if (!footer) {
            footer = document.createElement('div');
            footer.className = 'ng-sidebar__footer';
            sidebar.appendChild(footer);
        }

        var clone = tpl.content.cloneNode(true);
        footer.appendChild(clone);

        var btn = footer.querySelector('#cmd-trigger');
        if (btn) btn.addEventListener('click', openPalette);
    })();

    /* ── Open / close ── */
    function openPalette() {
        palette.hidden = false;
        document.body.classList.add('cmd-palette-open');
        input.value = '';
        filter('');
        requestAnimationFrame(function () { input.focus(); });
    }

    function closePalette() {
        palette.hidden = true;
        document.body.classList.remove('cmd-palette-open');
        clearActive();
    }

    /* ── Keyboard shortcut ── */
    document.addEventListener('keydown', function (e) {
        if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
            e.preventDefault();
            if (palette.hidden) { openPalette(); } else { closePalette(); }
        }
        if (e.key === 'Escape' && !palette.hidden) {
            closePalette();
        }
        if (!palette.hidden) {
            if (e.key === 'ArrowDown') { e.preventDefault(); moveFocus(1); }
            if (e.key === 'ArrowUp')   { e.preventDefault(); moveFocus(-1); }
            if (e.key === 'Enter') {
                var active = body.querySelector('.cmd-palette__item--active');
                if (active) { active.click(); }
            }
        }
    });

    backdrop.addEventListener('click', closePalette);

    /* ── Filter / search ── */
    input.addEventListener('input', function () {
        filter(input.value.trim().toLowerCase());
    });

    function filter(query) {
        clearActive();
        var groups = body.querySelectorAll('[data-group]');
        var totalVisible = 0;

        groups.forEach(function (group) {
            var items = group.querySelectorAll('.cmd-palette__item');
            var groupVisible = 0;

            items.forEach(function (item) {
                var label = item.dataset.label || '';
                var desc  = item.dataset.desc  || '';
                var match = !query || label.includes(query) || desc.includes(query);
                item.hidden = !match;
                if (match) groupVisible++;
            });

            group.hidden = groupVisible === 0;
            totalVisible += groupVisible;
        });

        empty.hidden = totalVisible > 0;

        /* Auto-activate first visible item */
        if (totalVisible > 0) {
            var first = body.querySelector('.cmd-palette__item:not([hidden])');
            if (first) first.classList.add('cmd-palette__item--active');
        }
    }

    /* ── Keyboard navigation ── */
    function moveFocus(dir) {
        var items = Array.from(body.querySelectorAll('.cmd-palette__item:not([hidden])'));
        if (!items.length) return;

        var activeIdx = items.findIndex(function (i) {
            return i.classList.contains('cmd-palette__item--active');
        });

        clearActive();

        var next = activeIdx + dir;
        if (next < 0) next = items.length - 1;
        if (next >= items.length) next = 0;

        items[next].classList.add('cmd-palette__item--active');
        items[next].scrollIntoView({ block: 'nearest' });
    }

    function clearActive() {
        body.querySelectorAll('.cmd-palette__item--active').forEach(function (el) {
            el.classList.remove('cmd-palette__item--active');
        });
    }
})();
</script>
