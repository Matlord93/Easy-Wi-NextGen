{% set title = title|default('') %}
{% set subtitle = subtitle|default('') %}
{% set actions = actions|default([]) %}
{% set profile = profile|default(null) %}
{% set user = current_user() %}
{% set userName = user ? (user.name ?: user.email) : '' %}
{% set userInitial = userName ? userName|slice(0, 1)|upper : 'U' %}
{% set profileName = profile ? (profile.name|default(userName)) : userName %}
{% set profileEmail = profile ? (profile.email|default(user ? user.email : '')) : (user ? user.email : '') %}
{% set profileInitial = profile ? (profile.initial|default(userInitial)) : userInitial %}
{% set profileAvatar = profile ? (profile.avatar|default(null)) : null %}
{% set updateStatus = admin_update_status() %}
{% set notificationsHref = user and user.isAdmin ? path('admin_notifications') : path('customer_notifications') %}
{% set unreadCount = unread_notifications() %}
{% set currentLocale = page_locale() %}
{% set requestPath = app.request ? app.request.pathInfo : '' %}
{% set requestQuery = app.request ? app.request.query.all : {} %}
{% set localeQueryDe = requestQuery|merge({'lang': 'de'}) %}
{% set localeQueryEn = requestQuery|merge({'lang': 'en'}) %}
{% set localeHrefDe = requestPath ? requestPath ~ '?' ~ localeQueryDe|url_encode : '?lang=de' %}
{% set localeHrefEn = requestPath ? requestPath ~ '?' ~ localeQueryEn|url_encode : '?lang=en' %}
{% set profileHref = '/profile' %}
{% set securityHref = '/account/security' %}
{% if user and user.type.value in ['admin', 'superadmin'] %}
    {% set profileHref = path('admin_profile') %}
    {% set securityHref = path('admin_profile') %}
{% endif %}

<header class="ng-topbar" role="banner">
    <div class="ng-topbar__title">
        {# Mobile sidebar toggle – visible only when sidebar is hidden #}
        <button class="ng-icon-button ng-sidebar-toggle" type="button" aria-label="{{ t('admin_nav_dashboard', page_locale()) }}">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
                <line x1="2" y1="4.5" x2="16" y2="4.5"/>
                <line x1="2" y1="9"   x2="16" y2="9"/>
                <line x1="2" y1="13.5" x2="16" y2="13.5"/>
            </svg>
        </button>

        {# Customer: profile pill shown inline in topbar title area #}
        {% if profile %}
            <button class="ng-topbar__profile" type="button" data-user-menu-toggle aria-controls="ng-user-menu" aria-expanded="false">
                {% if profileAvatar %}
                    <img class="ng-topbar__profile-avatar" src="{{ profileAvatar }}" alt="{{ profileName }}">
                {% else %}
                    <div class="ng-topbar__profile-avatar ng-topbar__profile-avatar--initial">{{ profileInitial }}</div>
                {% endif %}
                <div>
                    <div class="ng-topbar__profile-name">{{ profileName }}</div>
                    {% if profileEmail %}
                        <div class="ng-topbar__profile-email">{{ profileEmail }}</div>
                    {% endif %}
                </div>
            </button>
        {% endif %}

        {% if title or subtitle %}
            <div>
                {% if title %}
                    <h1>{{ title }}</h1>
                {% endif %}
                {% if subtitle %}
                    <p>{{ subtitle }}</p>
                {% endif %}
            </div>
        {% endif %}
    </div>

    <div class="ng-topbar__actions">
        {# Language switcher #}
        <div class="ng-language-switcher" role="group" aria-label="{{ t('language', page_locale()) }}">
            <a class="ng-language-switcher__link {{ currentLocale == 'de' ? 'is-active' : '' }}" href="{{ localeHrefDe }}" hreflang="de">
                {{ t('language_short_de', page_locale()) }}
            </a>
            <a class="ng-language-switcher__link {{ currentLocale == 'en' ? 'is-active' : '' }}" href="{{ localeHrefEn }}" hreflang="en">
                {{ t('language_short_en', page_locale()) }}
            </a>
        </div>

        {# Theme toggle #}
        <button class="ng-icon-button" type="button" id="theme-toggle" aria-label="{{ t('topbar_theme_toggle_aria', page_locale()) }}">
            <svg class="theme-icon-dark" viewBox="0 0 20 20" fill="currentColor" width="18" height="18" aria-hidden="true">
                <path d="M17.293 13.293A8 8 0 0 1 6.707 2.707a8.001 8.001 0 1 0 10.586 10.586z"/>
            </svg>
            <svg class="theme-icon-light" viewBox="0 0 20 20" fill="currentColor" width="18" height="18" aria-hidden="true" style="display:none">
                <path fill-rule="evenodd" d="M10 2a1 1 0 0 1 1 1v1a1 1 0 1 1-2 0V3a1 1 0 0 1 1-1zm4 8a4 4 0 1 1-8 0 4 4 0 0 1 8 0zm-.464 4.95.707.707a1 1 0 0 0 1.414-1.414l-.707-.707a1 1 0 0 0-1.414 1.414zm2.12-10.607a1 1 0 0 1 0 1.414l-.706.707a1 1 0 1 1-1.414-1.414l.707-.707a1 1 0 0 1 1.414 0zM17 11a1 1 0 1 0 0-2h-1a1 1 0 1 0 0 2h1zm-7 4a1 1 0 0 1 1 1v1a1 1 0 1 1-2 0v-1a1 1 0 0 1 1-1zM5.05 6.464A1 1 0 1 0 6.465 5.05l-.708-.707a1 1 0 0 0-1.414 1.414l.707.707zm1.414 8.486-.707.707a1 1 0 0 1-1.414-1.414l.707-.707a1 1 0 0 1 1.414 1.414zM4 11a1 1 0 1 0 0-2H3a1 1 0 1 0 0 2h1z" clip-rule="evenodd"/>
            </svg>
        </button>

        {# Page actions (passed from template) #}
        {% for action in actions %}
            {% include 'components/_button.html.twig' with action only %}
        {% endfor %}

        {# Notifications #}
        <a class="ng-icon-button" aria-label="{{ t('notifications', page_locale()) }}" href="{{ notificationsHref }}">
            {% if unreadCount > 0 %}
                <span class="ng-icon-button__dot" aria-label="{{ t('topbar_unread_notifications_aria', page_locale())|replace({'%count%': unreadCount}) }}"></span>
            {% endif %}
            <svg viewBox="0 0 20 20" fill="currentColor" width="18" height="18" aria-hidden="true">
                <path d="M10 2a6 6 0 0 0-6 6v.63l-.72 1.44A2 2 0 0 0 5.06 13h9.88a2 2 0 0 0 1.78-2.93L16 8.63V8a6 6 0 0 0-6-6zm0 16a2 2 0 0 0 2-2H8a2 2 0 0 0 2 2z"/>
            </svg>
        </a>

        {# Update pill (admin only) #}
        {% if updateStatus and updateStatus.hasUpdates %}
            <a class="ng-update-pill" href="{{ path('admin_updates') }}" title="{{ t('admin_updates_available', page_locale()) }}">
                <svg viewBox="0 0 16 16" fill="currentColor" width="13" height="13" aria-hidden="true">
                    <path d="M8 1a.5.5 0 0 1 .5.5v5.793l2.146-2.147a.5.5 0 0 1 .708.708l-3 3a.5.5 0 0 1-.708 0l-3-3a.5.5 0 0 1 .708-.708L7.5 7.293V1.5A.5.5 0 0 1 8 1zm-5.5 9a.5.5 0 0 1 .5.5v1.5h10v-1.5a.5.5 0 0 1 1 0v2a.5.5 0 0 1-.5.5H3a.5.5 0 0 1-.5-.5v-2a.5.5 0 0 1 .5-.5z"/>
                </svg>
                {{ t('admin_updates_available', page_locale()) }}
                {% if updateStatus.agentUpdates > 0 %}
                    <span class="ng-update-pill__count">{{ updateStatus.agentUpdates }}</span>
                {% endif %}
            </a>
        {% endif %}

        {# User menu #}
        <details class="ng-user-menu" id="ng-user-menu" data-user-menu>
            <summary class="ng-user-button" aria-label="{{ t('user_menu_aria', page_locale()) }}">
                <span class="ng-user-button__avatar">{{ userInitial }}</span>
                <span class="ng-user-button__name">{{ userName }}</span>
                <svg viewBox="0 0 16 16" fill="currentColor" width="12" height="12" style="opacity:0.5;flex-shrink:0" aria-hidden="true">
                    <path d="M4 6l4 4 4-4"/>
                </svg>
            </summary>
            <div class="ng-user-menu__dropdown" role="menu">
                <div class="ng-user-menu__label">{{ t('user_menu_account_label', page_locale()) }}</div>
                <a class="ng-user-menu__item" href="{{ profileHref }}" role="menuitem">
                    <svg viewBox="0 0 16 16" fill="currentColor" width="15" height="15" aria-hidden="true">
                        <path d="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6zm-5 6a5 5 0 0 1 10 0H3z"/>
                    </svg>
                    {{ t('public_user_menu_profile', page_locale()) }}
                </a>
                <a class="ng-user-menu__item" href="{{ path('public_logout') }}" role="menuitem">
                    <svg viewBox="0 0 16 16" fill="currentColor" width="15" height="15" aria-hidden="true">
                        <path fill-rule="evenodd" d="M10 12.5a.5.5 0 0 1-.5.5h-8a.5.5 0 0 1-.5-.5v-9a.5.5 0 0 1 .5-.5h8a.5.5 0 0 1 .5.5v2a.5.5 0 0 0 1 0v-2A1.5 1.5 0 0 0 9.5 2h-8A1.5 1.5 0 0 0 0 3.5v9A1.5 1.5 0 0 0 1.5 14h8a1.5 1.5 0 0 0 1.5-1.5v-2a.5.5 0 0 0-1 0v2z"/>
                        <path fill-rule="evenodd" d="M15.854 8.354a.5.5 0 0 0 0-.708l-3-3a.5.5 0 0 0-.708.708L14.293 7.5H5.5a.5.5 0 0 0 0 1h8.793l-2.147 2.146a.5.5 0 0 0 .708.708l3-3z"/>
                    </svg>
                    {{ t('logout', page_locale()) }}
                </a>
            </div>
        </details>
    </div>
</header>
