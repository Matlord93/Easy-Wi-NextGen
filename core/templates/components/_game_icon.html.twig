{% set key = (gameKey|default(''))|lower %}
{% set iconClass = class|default('h-10 w-10 text-indigo-200') %}

{% if key starts with 'minecraft' %}
    <svg class="{{ iconClass }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M3 7l9-4 9 4-9 4-9-4Z"/>
        <path d="M3 7v10l9 4 9-4V7"/>
        <path d="M12 11v10"/>
    </svg>
{% elseif key starts with 'cs' or key starts with 'counter' %}
    <svg class="{{ iconClass }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="8"/>
        <path d="M12 4v4M12 16v4M4 12h4M16 12h4"/>
    </svg>
{% elseif key starts with 'ark' %}
    <svg class="{{ iconClass }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M12 3l9 16H3L12 3Z"/>
        <path d="M12 7v8"/>
        <path d="M9 13h6"/>
    </svg>
{% elseif key starts with 'rust' %}
    <svg class="{{ iconClass }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M12 3c2 2 3 3.5 3 6a4 4 0 0 1-8 0c0-2.5 1-4 5-6Z"/>
        <path d="M8 14a4 4 0 0 0 8 0"/>
    </svg>
{% elseif key starts with 'valheim' %}
    <svg class="{{ iconClass }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M4 6l6 6"/>
        <path d="M6 4l6 6"/>
        <path d="M20 6l-6 6"/>
        <path d="M18 4l-6 6"/>
        <path d="M12 12v8"/>
    </svg>
{% else %}
    <svg class="{{ iconClass }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="4" y="4" width="16" height="6" rx="2"/>
        <rect x="4" y="14" width="16" height="6" rx="2"/>
        <path d="M8 7h.01M8 17h.01"/>
    </svg>
{% endif %}
