{% extends 'themes/' ~ (active_theme|default('minimal')) ~ '/base.html.twig' %}

{% block title %}{{ board.title }} · Forum{% endblock %}

{% block content %}
<div class="mx-auto w-full max-w-5xl space-y-6 px-4 py-10 sm:px-6">
    <div>
        <a href="/forum" class="text-sm text-cyan-300 hover:text-cyan-200">← Forum</a>
        <h1 class="mt-2 text-3xl font-semibold text-slate-100">{{ board.title }}</h1>
        <p class="text-sm text-slate-400">{{ board.description }}</p>
    </div>

    <section class="rounded-2xl border border-slate-800 bg-slate-900/70 p-6">
        <h2 class="text-lg font-semibold text-slate-100">Neues Thema</h2>
        {% if can_post %}
            <form method="post" action="/forum/board/{{ board.slug }}/new-thread" class="mt-4 space-y-3">
                <input type="hidden" name="_token" value="{{ csrf_token('forum_new_thread_' ~ board.id) }}">
                <input type="hidden" name="form_rendered_at" value="{{ 'now'|date('U') }}">
                <input type="text" name="website" value="" class="hidden" tabindex="-1" autocomplete="off" aria-hidden="true">
                <input type="text" name="title" placeholder="Titel" class="w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2 text-sm text-slate-100" required>
                <textarea name="content" rows="4" placeholder="Beitrag" class="w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2 text-sm text-slate-100" required></textarea>
                <button class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white">Thema erstellen</button>
            </form>
        {% else %}
            <p class="mt-3 text-sm text-slate-400">Zum Erstellen von Themen bitte als Mitglied einloggen.</p>
        {% endif %}
    </section>

    <section class="rounded-2xl border border-slate-800 bg-slate-900/70 p-6">
        <h2 class="text-lg font-semibold text-slate-100">Themen</h2>
        <div class="mt-4 space-y-2">
            {% for thread in threads %}
                <a class="block rounded-lg border border-slate-700 p-3 hover:bg-slate-800/70" href="/forum/thread/{{ thread.id }}">
                    <p class="font-semibold text-slate-100">
                        {% if thread.isPinned %}<span class="text-indigo-300">[PINNED]</span> {% endif %}
                        {% if thread.isClosed %}<span class="text-amber-300">[CLOSED]</span> {% endif %}
                        {{ thread.title }}
                    </p>
                    <p class="text-xs text-slate-400">Aktualisiert: {{ thread.lastActivityAt|date('Y-m-d H:i') }}</p>
                </a>
            {% else %}
                <p class="text-sm text-slate-400">Noch keine Themen.</p>
            {% endfor %}
        </div>
        {% if total_pages > 1 %}
            <div class="mt-4 flex items-center justify-between text-sm text-slate-300">
                <a class="text-cyan-300 {% if page <= 1 %}pointer-events-none opacity-50{% endif %}" href="/forum/board/{{ board.slug }}?page={{ page - 1 }}">← Zurück</a>
                <span>Seite {{ page }} / {{ total_pages }}</span>
                <a class="text-cyan-300 {% if page >= total_pages %}pointer-events-none opacity-50{% endif %}" href="/forum/board/{{ board.slug }}?page={{ page + 1 }}">Weiter →</a>
            </div>
        {% endif %}
    </section>
</div>
{% endblock %}
