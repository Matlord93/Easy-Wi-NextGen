<div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {% for card in payload.cards %}
        <article class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
            {% if card.icon is not empty %}<p class="text-xs font-semibold uppercase text-indigo-600">{{ card.icon }}</p>{% endif %}
            {% if card.title is not empty %}<h3 class="mt-1 text-lg font-semibold text-slate-900">{{ card.title }}</h3>{% endif %}
            {% if card.text is not empty %}<p class="mt-2 text-sm text-slate-700">{{ card.text }}</p>{% endif %}
            {% if card.url is not empty %}<a href="{{ card.url }}" class="mt-3 inline-flex text-sm font-semibold text-indigo-600 hover:text-indigo-800">Mehr erfahren</a>{% endif %}
        </article>
    {% endfor %}
</div>
