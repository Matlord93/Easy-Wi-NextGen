<section class="rounded-xl border border-slate-200 bg-slate-900 bg-cover bg-center px-6 py-12 text-white"{% if payload.backgroundImagePath is not empty %} style="background-image: linear-gradient(rgba(15,23,42,.75), rgba(15,23,42,.75)), url('{{ payload.backgroundImagePath }}');"{% endif %}>
    {% if payload.headline is not empty %}<h2 class="text-3xl font-semibold">{{ payload.headline }}</h2>{% endif %}
    {% if payload.subheadline is not empty %}<p class="mt-3 text-slate-100">{{ payload.subheadline }}</p>{% endif %}
    {% if payload.ctaText is not empty and payload.ctaUrl is not empty %}
        <a href="{{ payload.ctaUrl }}" class="mt-5 inline-flex rounded-lg bg-indigo-500 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-600">{{ payload.ctaText }}</a>
    {% endif %}
</section>
