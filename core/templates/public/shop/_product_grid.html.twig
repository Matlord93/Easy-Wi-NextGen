<section class="space-y-6">
    <div class="flex flex-wrap items-center justify-between gap-3">
        <div>
            <p class="text-xs uppercase tracking-[0.3em] text-slate-400">Shop</p>
            <h2 class="mt-2 text-2xl font-semibold text-slate-900">Unsere Produkte</h2>
            <p class="mt-2 text-sm text-slate-600">Wähle dein Paket und wechsle anschließend in den Kundenbereich.</p>
        </div>
        <a href="{{ cta_url }}" class="rounded-full bg-slate-900 px-4 py-2 text-xs font-semibold text-white hover:bg-slate-800">
            Zum Kundenbereich
        </a>
    </div>

    <div class="space-y-8">
        {% for category in categories %}
            <div class="space-y-4">
                <h3 class="text-lg font-semibold text-slate-900">{{ category.name }}</h3>
                <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
                    {% for product in category.products %}
                        <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
                            {% if product.image_url %}
                                <img src="{{ product.image_url }}" alt="{{ product.name }}" class="h-32 w-full rounded-xl object-cover">
                            {% endif %}
                            <h4 class="mt-4 text-base font-semibold text-slate-900">{{ product.name }}</h4>
                            <p class="mt-2 text-sm text-slate-600">{{ product.description }}</p>
                            <div class="mt-4 text-xs text-slate-600">
                                <p>{{ product.cpu_limit }} CPU · {{ product.ram_limit }} GB RAM · {{ product.disk_limit }} GB SSD</p>
                            </div>
                            <div class="mt-4 flex items-center justify-between">
                                <span class="text-sm font-semibold text-slate-900">€ {{ product.price_monthly }} / Monat</span>
                                <a href="{{ cta_url }}" class="rounded-full border border-slate-200 px-3 py-1 text-xs font-semibold text-slate-700 hover:bg-slate-50">Bestellen</a>
                            </div>
                        </div>
                    {% else %}
                        <div class="rounded-xl border border-dashed border-slate-200 bg-white p-6 text-sm text-slate-600">
                            Keine Produkte verfügbar.
                        </div>
                    {% endfor %}
                </div>
            </div>
        {% else %}
            <div class="rounded-xl border border-dashed border-slate-200 bg-white p-6 text-sm text-slate-600">
                Noch keine Produkte verfügbar.
            </div>
        {% endfor %}
    </div>
</section>
