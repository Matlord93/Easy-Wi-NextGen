<section class="space-y-8">
    <div class="flex flex-wrap items-center justify-between gap-3">
        <div>
            <p class="text-xs uppercase tracking-wider text-slate-500">Shop</p>
            <h2 class="mt-1 text-2xl font-bold ng-gradient-text">Unsere Produkte</h2>
            <p class="mt-1 text-sm text-slate-400">Wähle dein Paket und wechsle anschließend in den Kundenbereich.</p>
        </div>
        <a href="{{ cta_url }}" class="ng-btn">Zum Kundenbereich</a>
    </div>

    {% for category in categories %}
        <div class="space-y-4">
            <h3 class="text-base font-semibold text-slate-300">{{ category.name }}</h3>
            <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
                {% for product in category.products %}
                    <div class="group overflow-hidden rounded-xl border border-slate-800 bg-slate-900/70 transition-all duration-300 hover:border-slate-700 hover:shadow-lg hover:shadow-black/30">
                        {% if product.image_url %}
                            <div class="overflow-hidden">
                                <img src="{{ product.image_url }}" alt="{{ product.name }}" class="h-36 w-full object-cover transition-transform duration-500 group-hover:scale-105">
                            </div>
                        {% endif %}
                        <div class="p-5">
                            <h4 class="text-base font-semibold text-slate-100">{{ product.name }}</h4>
                            <p class="mt-2 text-sm text-slate-400">{{ product.description }}</p>
                            <div class="mt-3 flex flex-wrap gap-2 text-xs text-slate-500">
                                <span class="rounded border border-slate-700 px-2 py-0.5">{{ product.cpu_limit }} CPU</span>
                                <span class="rounded border border-slate-700 px-2 py-0.5">{{ product.ram_limit }} GB RAM</span>
                                <span class="rounded border border-slate-700 px-2 py-0.5">{{ product.disk_limit }} GB SSD</span>
                            </div>
                            <div class="mt-4 flex items-center justify-between">
                                <span class="text-sm font-semibold text-slate-200">€ {{ product.price_monthly }} / Monat</span>
                                <a href="{{ cta_url }}" class="ng-btn ng-btn--sm">Bestellen</a>
                            </div>
                        </div>
                    </div>
                {% else %}
                    <div class="ng-empty-state col-span-full">
                        <p>Keine Produkte verfügbar.</p>
                    </div>
                {% endfor %}
            </div>
        </div>
    {% else %}
        <div class="ng-empty-state">
            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
            <p>Noch keine Produkte verfügbar.</p>
        </div>
    {% endfor %}
</section>
