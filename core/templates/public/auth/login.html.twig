{% extends 'public/base.html.twig' %}


{% block content %}
<div class="grid gap-6 lg:grid-cols-[minmax(0,1.2fr)_minmax(0,0.8fr)]">
    <div class="rounded-xl border border-slate-200 bg-white">
        <div class="border-b border-slate-200 px-6 py-4">
            <h1 class="text-lg font-semibold">{{ t('welcome_back', page_locale()) }}</h1>
            <p class="text-sm text-slate-700">{{ t('login_description', page_locale()) }}</p>
        </div>
        <div class="px-6 py-6">
            {% if errors is not empty %}
                <div class="mb-4 rounded-lg border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700">
                    <ul class="list-disc space-y-1 pl-5">
                        {% for error in errors %}
                            <li>{{ error }}</li>
                        {% endfor %}
                    </ul>
                </div>
            {% endif %}
            <form method="post" action="/login" class="space-y-4">
                <div>
                    <label class="text-sm font-medium text-slate-700" for="email">{{ t('email_address', page_locale()) }}</label>
                    <input id="email" name="email" type="email" value="{{ form.email }}" required class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-200" placeholder="{{ t('email_placeholder', page_locale()) }}">
                </div>
                <div>
                    <label class="text-sm font-medium text-slate-700" for="password">{{ t('password', page_locale()) }}</label>
                    <input id="password" name="password" type="password" required class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-200" placeholder="{{ t('password_placeholder', page_locale()) }}">
                </div>
                {% if twoFactorEnabled or requiresTwoFactor %}
                    <div>
                        <label class="text-sm font-medium text-slate-700" for="otp">{{ t('two_factor_code_label', page_locale()) }}</label>
                        <input id="otp" name="otp" type="text" inputmode="numeric" autocomplete="one-time-code" class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-200" placeholder="123456">
                        <p class="mt-2 text-xs text-slate-500">{{ t('two_factor_login_hint', page_locale()) }}</p>
                    </div>
                    <div>
                        <label class="text-sm font-medium text-slate-700" for="recovery_code">{{ t('two_factor_recovery_label', page_locale()) }}</label>
                        <input id="recovery_code" name="recovery_code" type="text" class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-200" placeholder="0000-0000">
                    </div>
                {% endif %}
                {% if enrollmentRequired %}
                    <div class="rounded-lg border border-amber-200 bg-amber-50 px-4 py-3 text-xs text-amber-700">
                        {{ t('two_factor_enrollment_required', page_locale()) }}
                    </div>
                    {% if twoFactorSetup.qr %}
                        <div class="rounded-lg border border-slate-200 bg-slate-50 px-4 py-4 text-xs text-slate-700">
                            <p class="font-semibold text-slate-900">{{ t('two_factor_setup_intro', page_locale()) }}</p>
                            <div class="mt-3 flex flex-col gap-4 sm:flex-row sm:items-center">
                                <div class="rounded-lg border border-slate-200 bg-white p-2">
                                    <img src="{{ twoFactorSetup.qr }}" alt="{{ t('two_factor_scan_qr', page_locale()) }}" class="h-40 w-40">
                                </div>
                                <div class="flex-1">
                                    <p class="text-[0.7rem] font-semibold uppercase tracking-wide text-slate-500">{{ t('two_factor_secret_label', page_locale()) }}</p>
                                    <p class="mt-2 rounded-lg border border-slate-200 bg-white px-3 py-2 font-mono text-xs text-slate-700">{{ twoFactorSetup.secret }}</p>
                                </div>
                            </div>
                        </div>
                    {% endif %}
                {% endif %}
                <button type="submit" class="inline-flex w-full items-center justify-center rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-indigo-500">{{ t('log_in', page_locale()) }}</button>
            </form>
        </div>
    </div>
    <div class="space-y-6">
        {% if registrationAllowed %}
            <div class="rounded-xl border border-slate-200 bg-white px-6 py-5">
                <h2 class="text-sm font-semibold text-slate-900">{{ t('first_time_here', page_locale()) }}</h2>
                <p class="mt-2 text-sm text-slate-600">{{ t('register_intro', page_locale()) }}</p>
                <a href="/register" class="mt-4 inline-flex items-center rounded-lg bg-slate-900 px-4 py-2 text-xs font-semibold text-white transition hover:bg-slate-800">{{ t('register_now', page_locale()) }}</a>
            </div>
        {% else %}
            <div class="rounded-xl border border-amber-200 bg-amber-50 px-6 py-5 text-sm text-amber-700">
                <h2 class="text-sm font-semibold text-amber-900">{{ t('first_time_here', page_locale()) }}</h2>
                <p class="mt-2 text-sm text-amber-700">{{ t('registration_disabled_maintenance', page_locale()) }}</p>
            </div>
        {% endif %}
        <div class="rounded-xl border border-slate-200 bg-white px-6 py-5">
            <h2 class="text-sm font-semibold text-slate-900">{{ t('need_help', page_locale()) }}</h2>
            <p class="mt-2 text-sm text-slate-600">{{ t('login_help', page_locale())|replace({'%site%': siteName}) }}</p>
            <span class="mt-3 inline-flex items-center rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-600">{{ t('support_available', page_locale()) }}</span>
        </div>
    </div>
</div>
{% endblock %}
