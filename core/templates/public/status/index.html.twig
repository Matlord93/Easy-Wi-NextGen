{% extends 'themes/' ~ (active_theme|default('minimal')) ~ '/base.html.twig' %}

{% block title %}{{ t('service_status', page_locale()) }} · {{ app_setting('site_title', 'Easy-Wi NextGen') }}{% endblock %}

{% block content %}
{% set componentStyles = {
    'operational': 'border-green-500/30 bg-green-500/10 text-green-400',
    'degraded':    'border-amber-500/30 bg-amber-500/10 text-amber-400',
    'outage':      'border-rose-500/30 bg-rose-500/10 text-rose-400',
    'maintenance': 'border-purple-500/30 bg-purple-500/10 text-purple-400'
} %}
{% set incidentStyles = {
    'investigating': 'border-amber-500/30 bg-amber-500/10 text-amber-400',
    'identified':    'border-purple-500/30 bg-purple-500/10 text-purple-400',
    'monitoring':    'border-cyan-500/30 bg-cyan-500/10 text-cyan-400',
    'resolved':      'border-green-500/30 bg-green-500/10 text-green-400'
} %}

<div class="ng-page-hero">
    <div class="ng-container">
        <nav class="ng-breadcrumb">
            <a href="/">Home</a>
            <span>{{ t('service_status', page_locale()) }}</span>
        </nav>
        <h1 class="text-3xl font-bold ng-gradient-text">{{ t('service_status', page_locale()) }}</h1>
        <p class="mt-2 text-sm text-slate-400">{{ t('service_status_description', page_locale()) }}</p>
    </div>
</div>

<div class="ng-container ng-section space-y-8">

    <div class="overflow-hidden rounded-xl border border-slate-800 bg-slate-900/60">
        <div class="border-b border-slate-800 px-5 py-4">
            <h2 class="text-base font-semibold text-slate-100">{{ t('service_status', page_locale()) }}</h2>
        </div>
        <div class="overflow-x-auto">
            <table class="min-w-full text-sm">
                <thead class="border-b border-slate-800">
                    <tr>
                        <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wider text-slate-500">{{ t('component', page_locale()) }}</th>
                        <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wider text-slate-500">{{ t('type', page_locale()) }}</th>
                        <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wider text-slate-500">{{ t('status', page_locale()) }}</th>
                        <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wider text-slate-500">{{ t('last_checked', page_locale()) }}</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-800">
                    {% for component in components %}
                        <tr class="transition hover:bg-slate-800/40">
                            <td class="px-5 py-4 font-medium text-slate-200">{{ component.name }}</td>
                            <td class="px-5 py-4 text-slate-400">{{ component.type|capitalize }}</td>
                            <td class="px-5 py-4">
                                <span class="inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-semibold {{ componentStyles[component.status]|default('border-slate-700 bg-slate-800/60 text-slate-400') }}">
                                    {{ t('status_' ~ component.status, page_locale()) }}
                                </span>
                            </td>
                            <td class="px-5 py-4 text-slate-500">{{ component.last_checked_at ? component.last_checked_at|date('d.m.Y H:i') : '—' }}</td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="4" class="px-5 py-8 text-center text-sm text-slate-600">{{ t('no_public_components', page_locale()) }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    <div class="grid gap-6 lg:grid-cols-2">

        <div class="overflow-hidden rounded-xl border border-slate-800 bg-slate-900/60">
            <div class="border-b border-slate-800 px-5 py-4">
                <h2 class="text-base font-semibold text-slate-100">{{ t('current_incidents', page_locale()) }}</h2>
                <p class="mt-0.5 text-xs text-slate-500">{{ t('current_incidents_description', page_locale()) }}</p>
            </div>
            <div class="divide-y divide-slate-800">
                {% for incident in incidents %}
                    <div class="px-5 py-4">
                        <div class="flex items-start justify-between gap-3">
                            <div>
                                <h3 class="text-sm font-semibold text-slate-200">{{ incident.title }}</h3>
                                {% if incident.message %}
                                    <p class="mt-1 text-xs text-slate-500">{{ incident.message }}</p>
                                {% endif %}
                                {% if incident.components is not empty %}
                                    <div class="mt-2 flex flex-wrap gap-1.5">
                                        {% for component in incident.components %}
                                            <span class="rounded-full border border-slate-700 bg-slate-800/60 px-2 py-0.5 text-xs text-slate-400">{{ component.name }}</span>
                                        {% endfor %}
                                    </div>
                                {% endif %}
                            </div>
                            <span class="shrink-0 inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-semibold {{ incidentStyles[incident.status]|default('border-slate-700 bg-slate-800/60 text-slate-400') }}">
                                {{ t('status_' ~ incident.status, page_locale()) }}
                            </span>
                        </div>
                        {% set updates = incidentUpdates[incident.id]|default([]) %}
                        {% if updates is not empty %}
                            <div class="mt-3 space-y-2">
                                {% for update in updates %}
                                    <div class="rounded-lg border border-slate-800 bg-slate-800/40 px-3 py-2 text-xs">
                                        <div class="flex items-center justify-between">
                                            <span class="font-semibold text-slate-300">{{ t('status_' ~ update.status, page_locale()) }}</span>
                                            <span class="text-slate-500">{{ update.created_at|date('d.m.Y H:i') }}</span>
                                        </div>
                                        <p class="mt-1 text-slate-400">{{ update.message }}</p>
                                    </div>
                                {% endfor %}
                            </div>
                        {% else %}
                            <p class="mt-2 text-xs text-slate-600">{{ t('no_public_updates', page_locale()) }}</p>
                        {% endif %}
                    </div>
                {% else %}
                    <div class="px-5 py-10 text-center text-sm text-slate-600">{{ t('no_active_incidents', page_locale()) }}</div>
                {% endfor %}
            </div>
        </div>

        <div class="overflow-hidden rounded-xl border border-slate-800 bg-slate-900/60">
            <div class="border-b border-slate-800 px-5 py-4">
                <h2 class="text-base font-semibold text-slate-100">{{ t('maintenance', page_locale()) }}</h2>
                <p class="mt-0.5 text-xs text-slate-500">{{ t('maintenance_description', page_locale()) }}</p>
            </div>
            <div class="divide-y divide-slate-800">
                {% for window in currentMaintenance %}
                    <div class="px-5 py-4">
                        <div class="flex items-center justify-between gap-3">
                            <h3 class="text-sm font-semibold text-slate-200">{{ window.title }}</h3>
                            <span class="shrink-0 inline-flex items-center rounded-full border border-purple-500/30 bg-purple-500/10 px-2.5 py-0.5 text-xs font-semibold text-purple-400">{{ t('in_progress', page_locale()) }}</span>
                        </div>
                        {% if window.message %}<p class="mt-1 text-xs text-slate-500">{{ window.message }}</p>{% endif %}
                        <p class="mt-2 text-xs text-slate-600">{{ window.start_at|date('d.m.Y H:i') }} → {{ window.end_at|date('d.m.Y H:i') }}</p>
                        {% if window.components is not empty %}
                            <div class="mt-2 flex flex-wrap gap-1.5">
                                {% for component in window.components %}
                                    <span class="rounded-full border border-slate-700 bg-slate-800/60 px-2 py-0.5 text-xs text-slate-400">{{ component.name }}</span>
                                {% endfor %}
                            </div>
                        {% endif %}
                    </div>
                {% endfor %}
                {% for window in upcomingMaintenance %}
                    <div class="px-5 py-4">
                        <div class="flex items-center justify-between gap-3">
                            <h3 class="text-sm font-semibold text-slate-200">{{ window.title }}</h3>
                            <span class="shrink-0 inline-flex items-center rounded-full border border-slate-700 bg-slate-800/60 px-2.5 py-0.5 text-xs font-semibold text-slate-400">{{ t('upcoming', page_locale()) }}</span>
                        </div>
                        {% if window.message %}<p class="mt-1 text-xs text-slate-500">{{ window.message }}</p>{% endif %}
                        <p class="mt-2 text-xs text-slate-600">{{ window.start_at|date('d.m.Y H:i') }} → {{ window.end_at|date('d.m.Y H:i') }}</p>
                        {% if window.components is not empty %}
                            <div class="mt-2 flex flex-wrap gap-1.5">
                                {% for component in window.components %}
                                    <span class="rounded-full border border-slate-700 bg-slate-800/60 px-2 py-0.5 text-xs text-slate-400">{{ component.name }}</span>
                                {% endfor %}
                            </div>
                        {% endif %}
                    </div>
                {% else %}
                    {% if currentMaintenance is empty %}
                        <div class="px-5 py-10 text-center text-sm text-slate-600">{{ t('no_scheduled_maintenance', page_locale()) }}</div>
                    {% endif %}
                {% endfor %}
            </div>
        </div>

    </div>
</div>
{% endblock %}
