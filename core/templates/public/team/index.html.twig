{% extends 'themes/' ~ (active_theme|default('minimal')) ~ '/base.html.twig' %}
{% block title %}Teams · {{ app_setting('site_title', 'Easy-Wi NextGen') }}{% endblock %}
{% block content %}
<div class="ng-container ng-section">
  <h1 class="text-3xl font-bold">Unsere Teams</h1>
  <div class="mt-6 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
    {% for group in team_groups %}
      <a href="/teams/{{ group.slug }}" class="rounded-xl border border-slate-800 overflow-hidden bg-slate-900/70">
        {% if group.imagePath %}<img src="{{ group.imagePath }}" class="h-44 w-full object-cover" alt="{{ group.name }}">{% endif %}
        <div class="p-4 text-lg font-semibold">{{ group.name }}</div>
        <div class="px-4 pb-4 text-sm text-slate-400">{{ group.game }}</div>
      </a>
    {% else %}<p>Keine Teams vorhanden.</p>{% endfor %}
  </div>
</div>
{% endblock %}
