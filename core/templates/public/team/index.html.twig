{% extends 'themes/' ~ (active_theme|default('minimal')) ~ '/base.html.twig' %}

{% block title %}Team · {{ app_setting('site_title', 'Easy-Wi NextGen') }}{% endblock %}

{% block content %}
<div class="ng-page-hero">
    <div class="ng-container">
        <nav class="ng-breadcrumb">
            <a href="/">Home</a>
            <span>Team</span>
        </nav>
        <h1 class="text-3xl font-bold ng-gradient-text">Unser Team</h1>
        <p class="mt-2 text-sm text-slate-400">Lerne die Mitglieder und Rollen im Clan kennen.</p>
    </div>
</div>

<div class="ng-container ng-section">
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {% for member in members %}
            <article class="group relative overflow-hidden rounded-xl border border-slate-800 bg-slate-900/70 transition-all duration-300 hover:border-cyan-500/30 hover:shadow-lg hover:shadow-cyan-500/10">
                {% if member.avatar_path %}
                    <div class="relative h-52 overflow-hidden bg-slate-800">
                        <img src="{{ member.avatar_path }}" alt="{{ member.name }}"
                             class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" />
                        <div class="absolute inset-0 bg-gradient-to-t from-slate-900 via-transparent to-transparent"></div>
                    </div>
                {% else %}
                    <div class="flex h-52 items-center justify-center bg-gradient-to-br from-slate-800 to-slate-900">
                        <div class="flex h-20 w-20 items-center justify-center rounded-full bg-gradient-to-br from-cyan-500 to-purple-600 text-3xl font-bold text-white">
                            {{ member.name|first|upper }}
                        </div>
                    </div>
                {% endif %}
                <div class="p-5">
                    <div class="flex items-start justify-between gap-2">
                        <h2 class="text-lg font-semibold text-slate-100">{{ member.name }}</h2>
                        {% if member.role_title %}
                            <span class="flex-shrink-0 rounded-full border border-cyan-500/30 bg-cyan-500/10 px-2.5 py-0.5 text-xs font-semibold text-cyan-400">
                                {{ member.role_title }}
                            </span>
                        {% endif %}
                    </div>
                    {% if member.bio %}
                        <p class="mt-2 text-sm leading-relaxed text-slate-400">{{ member.bio }}</p>
                    {% endif %}
                </div>
                <div class="absolute inset-x-0 bottom-0 h-0.5 bg-gradient-to-r from-cyan-500 to-purple-600 opacity-0 transition-opacity duration-300 group-hover:opacity-100"></div>
            </article>
        {% else %}
            <div class="ng-empty-state col-span-full">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                <p>Noch keine Mitglieder vorhanden.</p>
            </div>
        {% endfor %}
    </div>
</div>
{% endblock %}
