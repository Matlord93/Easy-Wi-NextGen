{% extends 'themes/' ~ (active_theme|default('minimal')) ~ '/base.html.twig' %}
{% block content %}
<div class="mx-auto max-w-5xl space-y-6 px-4 py-10">
    <div>
        <h1 class="text-3xl font-semibold text-slate-100">Team</h1>
        <p class="mt-2 text-sm text-slate-400">Lerne die Mitglieder und Rollen im Clan kennen.</p>
    </div>
    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        {% for member in members %}
            <article class="rounded-2xl border border-slate-800 bg-slate-900/70 p-4">
                {% if member.avatar_path %}<img src="{{ member.avatar_path }}" alt="{{ member.name }}" class="h-40 w-full rounded object-cover" />{% endif %}
                <h2 class="mt-3 text-lg font-semibold text-slate-100">{{ member.name }}</h2>
                <p class="text-sm text-cyan-300">{{ member.role_title }}</p>
                <p class="mt-2 text-sm text-slate-300">{{ member.bio }}</p>
            </article>
        {% else %}
            <p class="rounded-2xl border border-slate-800 bg-slate-900/60 p-5 text-slate-400">No team members available.</p>
        {% endfor %}
    </div>
</div>
{% endblock %}
