{% extends 'public/base.html.twig' %}

{% block content %}
<div class="grid gap-6 lg:grid-cols-[220px,1fr]">
  {% include 'public/account/_nav.html.twig' %}
  <div>
<div class="mx-auto max-w-2xl rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
  <h1 class="text-xl font-semibold text-slate-900">Profil bearbeiten</h1>
  {% if success %}<p class="mt-3 rounded bg-emerald-50 px-3 py-2 text-sm text-emerald-700">Profil gespeichert.</p>{% endif %}
  {% if errors is not empty %}<div class="mt-3 rounded bg-rose-50 px-3 py-2 text-sm text-rose-700">{% for error in errors %}<p>{{ error }}</p>{% endfor %}</div>{% endif %}

  <form method="post" class="mt-4 space-y-4">
    <input type="hidden" name="_token" value="{{ csrf_token('public_profile_edit') }}">
    <div>
      <label class="block text-sm font-medium text-slate-700">Anzeigename</label>
      <input name="name" value="{{ form.name }}" maxlength="120" class="mt-1 w-full rounded border border-slate-200 px-3 py-2" placeholder="Dein Name">
    </div>
    <div>
      <label class="block text-sm font-medium text-slate-700">E-Mail</label>
      <input name="email" type="email" value="{{ form.email }}" required class="mt-1 w-full rounded border border-slate-200 px-3 py-2">
    </div>
    <div class="flex gap-3">
      <button type="submit" class="rounded bg-indigo-600 px-4 py-2 text-sm font-semibold text-white">Speichern</button>
      <a href="/profile" class="rounded border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700">Abbrechen</a>
    </div>
  </form>
</div>
  </div>
</div>
{% endblock %}
