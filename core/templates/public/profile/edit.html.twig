{% extends 'themes/' ~ (active_theme|default('minimal')) ~ '/base.html.twig' %}

{% block title %}Profil bearbeiten · {{ app_setting('site_title', 'Easy-Wi NextGen') }}{% endblock %}

{% block content %}
<div class="ng-page-hero">
    <div class="ng-container">
        <nav class="ng-breadcrumb">
            <a href="/">Home</a>
            <a href="/profile">Mein Profil</a>
            <span>Bearbeiten</span>
        </nav>
        <h1 class="text-3xl font-bold ng-gradient-text">Profil bearbeiten</h1>
    </div>
</div>

<div class="ng-container ng-section">
    <div class="grid gap-6 lg:grid-cols-[200px,1fr]">
        {% include 'public/account/_nav.html.twig' %}
        {% set isNexus = (active_theme|default('minimal')) == 'nexus-gaming' %}
        <div class="rounded-xl border p-6 {% if isNexus %}border-cyan-500/30 bg-slate-950/70 ng-glow{% else %}border-slate-800 bg-slate-900/60{% endif %}">
            {% if success %}
                <div class="mb-4 rounded-lg border border-green-500/30 bg-green-500/10 px-4 py-3 text-sm text-green-400">Profil gespeichert.</div>
            {% endif %}
            {% if errors is not empty %}
                <div class="mb-4 rounded-lg border border-rose-500/30 bg-rose-500/10 px-4 py-3 text-sm text-rose-400">
                    {% for error in errors %}<p>{{ error }}</p>{% endfor %}
                </div>
            {% endif %}
            <form method="post" class="space-y-4">
                <input type="hidden" name="_token" value="{{ csrf_token('public_profile_edit') }}">
                <div>
                    <label class="mb-1 block text-sm font-medium {% if isNexus %}text-cyan-200/90{% else %}text-slate-400{% endif %}">Anzeigename</label>
                    <input name="name" value="{{ form.name }}" maxlength="120" class="ng-input w-full" placeholder="Dein Name">
                </div>
                <div>
                    <label class="mb-1 block text-sm font-medium {% if isNexus %}text-cyan-200/90{% else %}text-slate-400{% endif %}">E-Mail</label>
                    <input name="email" type="email" value="{{ form.email }}" required class="ng-input w-full">
                </div>
                <div class="flex gap-3 pt-2">
                    <button type="submit" class="ng-btn">Speichern</button>
                    <a href="/profile" class="ng-btn ng-btn--ghost">Abbrechen</a>
                </div>
            </form>
        </div>
    </div>
</div>
{% endblock %}
