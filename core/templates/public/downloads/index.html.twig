{% extends 'themes/' ~ (active_theme|default('minimal')) ~ '/base.html.twig' %}

{% block title %}{{ t('downloads', page_locale()) }} · {{ app_setting('site_title', 'Easy-Wi NextGen') }}{% endblock %}

{% block content %}
<div class="ng-page-hero">
    <div class="ng-container">
        <nav class="ng-breadcrumb">
            <a href="/">Home</a>
            <span>{{ t('downloads', page_locale()) }}</span>
        </nav>
        <h1 class="text-3xl font-bold ng-gradient-text">{{ t('downloads', page_locale()) }}</h1>
        <p class="mt-2 text-sm text-slate-400">{{ t('downloads_description', page_locale()) }}</p>
    </div>
</div>

<div class="ng-container ng-section">
    <div class="overflow-hidden rounded-xl border border-slate-800 bg-slate-900/60">
        <table class="min-w-full text-sm">
            <thead class="border-b border-slate-800">
                <tr>
                    <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wider text-slate-500">{{ t('download', page_locale()) }}</th>
                    <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wider text-slate-500">{{ t('version', page_locale()) }}</th>
                    <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wider text-slate-500">{{ t('size', page_locale()) }}</th>
                    <th class="px-5 py-3 text-right text-xs font-semibold uppercase tracking-wider text-slate-500">{{ t('action', page_locale()) }}</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-800">
                {% for item in items %}
                    <tr class="transition hover:bg-slate-800/40">
                        <td class="px-5 py-4">
                            <div class="font-semibold text-slate-200">{{ item.title }}</div>
                            {% if item.description %}
                                <div class="mt-0.5 text-xs text-slate-500">{{ item.description }}</div>
                            {% endif %}
                        </td>
                        <td class="px-5 py-4 text-slate-400">{{ item.version ?: '—' }}</td>
                        <td class="px-5 py-4 text-slate-400">{{ item.file_size ?: '—' }}</td>
                        <td class="px-5 py-4 text-right">
                            <a href="{{ item.url }}" class="ng-btn ng-btn--sm">
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                                {{ t('download', page_locale()) }}
                            </a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="4" class="px-5 py-10 text-center">
                            <div class="ng-empty-state">
                                <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                                <p>{{ t('no_downloads_available', page_locale()) }}</p>
                            </div>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
