{% extends 'public/base.html.twig' %}

{% set showPortalShell = false %}
{% set contentClass = 'mx-auto w-full max-w-5xl px-4 py-10 sm:px-8' %}

{% block title %}{{ t('cms_blog_title', page_locale()) }} · {{ siteTitle }}{% endblock %}

{% block content %}
<div class="space-y-8">
    <nav class="flex flex-wrap items-center justify-between gap-4 rounded-2xl border border-slate-200 bg-white px-6 py-4 text-xs uppercase tracking-[0.2em] text-slate-500 shadow-sm">
        <div class="font-semibold text-slate-700">Blog</div>
        <div class="flex flex-wrap gap-4 text-[11px] text-slate-500">
            {% for page in cms_pages %}
                {% set link = page.slug == 'startseite' ? '/' : '/' ~ page.slug %}
                <a href="{{ link }}" class="hover:text-slate-700">{{ page.title }}</a>
            {% endfor %}
        </div>
        <div class="flex items-center gap-2 text-xs normal-case">
            {% if current_user() %}
                <a href="/dashboard" class="rounded-full border border-slate-200 px-3 py-1 text-xs font-semibold text-slate-600 hover:border-slate-300">{{ t('customer_portal', page_locale()) }}</a>
            {% else %}
                <a href="{{ path('public_login') }}" class="rounded-full border border-slate-200 px-3 py-1 text-xs font-semibold text-slate-600 hover:border-slate-300">{{ t('login', page_locale()) }}</a>
            {% endif %}
        </div>
    </nav>

    <header class="space-y-2">
        <h1 class="text-3xl font-semibold text-slate-900">{{ t('cms_blog_title', page_locale()) }}</h1>
        <p class="text-sm text-slate-600">{{ t('cms_blog_public_subtitle', page_locale()) }}</p>
    </header>

    <section class="space-y-5">
        {% for post in posts %}
            <article class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
                <div class="flex flex-wrap items-center justify-between gap-2">
                    <h2 class="text-xl font-semibold text-slate-900">
                        <a href="/blog/{{ post.slug }}" class="hover:text-indigo-600">{{ post.title }}</a>
                    </h2>
                    <span class="text-xs text-slate-500">{{ post.published_at ? post.published_at|date('d.m.Y') : '' }}</span>
                </div>
                {% if post.excerpt %}
                    <p class="mt-3 text-sm text-slate-600">{{ post.excerpt }}</p>
                {% endif %}
                <div class="mt-4">
                    <a href="/blog/{{ post.slug }}" class="text-xs font-semibold text-indigo-600 hover:text-indigo-500">{{ t('cms_blog_read_more', page_locale()) }}</a>
                </div>
            </article>
        {% else %}
            <div class="rounded-2xl border border-dashed border-slate-200 bg-white p-6 text-sm text-slate-600">
                {{ t('cms_blog_public_empty', page_locale()) }}
            </div>
        {% endfor %}
    </section>
</div>
{% endblock %}
