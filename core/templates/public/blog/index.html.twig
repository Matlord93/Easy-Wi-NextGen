{% extends 'themes/' ~ (active_theme|default('minimal')) ~ '/base.html.twig' %}

{% set siteTitle = app_setting('site_title', 'Easy-Wi NextGen') %}

{% block head %}
    <title>{{ t('cms_blog_title', page_locale()) }} · {{ siteTitle }}</title>
{% endblock %}

{% block content %}
<div class="ng-page-hero">
    <div class="ng-container">
        <nav class="ng-breadcrumb">
            <a href="/">Home</a>
            <span>{{ t('cms_blog_title', page_locale()) }}</span>
        </nav>
        <h1 class="text-3xl font-bold ng-gradient-text">{{ t('cms_blog_title', page_locale()) }}</h1>
        <p class="mt-2 text-sm text-slate-400">{{ t('cms_blog_public_subtitle', page_locale()) }}</p>
    </div>
</div>

<div class="ng-container ng-section">
    <form method="get" action="/blog"
          class="mb-8 grid gap-3 rounded-xl border border-slate-800 bg-slate-900/70 p-4 backdrop-blur-sm md:grid-cols-4">
        <input type="text" name="q" value="{{ filters.q }}" placeholder="Beiträge suchen …"
               class="ng-input md:col-span-2" />
        <select name="category" class="ng-input">
            <option value="">Alle Kategorien</option>
            {% for category in categories %}
                <option value="{{ category.slug }}" {% if category.is_active %}selected{% endif %}>{{ category.name }}</option>
            {% endfor %}
        </select>
        <select name="tag" class="ng-input">
            <option value="">Alle Tags</option>
            {% for tag in tags %}
                <option value="{{ tag.slug }}" {% if tag.is_active %}selected{% endif %}>{{ tag.name }}</option>
            {% endfor %}
        </select>
        <button class="ng-btn ng-btn--primary md:col-span-4 md:justify-self-start">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
            Filtern
        </button>
    </form>

    <div class="space-y-6">
        {% for post in posts %}
            <article class="group overflow-hidden rounded-xl border border-slate-800 bg-slate-900/70 transition-all duration-300 hover:border-slate-700">
                {% if post.featured_image_path %}
                    <div class="relative h-52 overflow-hidden">
                        <img src="{{ post.featured_image_path }}" alt="{{ post.title }}"
                             class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" />
                        <div class="absolute inset-0 bg-gradient-to-t from-slate-900/80 to-transparent"></div>
                    </div>
                {% endif %}
                <div class="p-6">
                    <div class="flex flex-wrap items-center gap-2 mb-3">
                        {% if post.category %}
                            <span class="rounded-full border border-cyan-500/30 bg-cyan-500/10 px-2.5 py-0.5 text-xs font-semibold text-cyan-400">{{ post.category.name }}</span>
                        {% endif %}
                        {% if post.tags is not empty %}
                            {% for tag in post.tags %}
                                <span class="rounded-full border border-slate-700 bg-slate-800/60 px-2 py-0.5 text-xs text-slate-400">{{ tag.name }}</span>
                            {% endfor %}
                        {% endif %}
                        <span class="ml-auto text-xs text-slate-500">{{ post.published_at ? post.published_at|date('d.m.Y') : '' }}</span>
                    </div>
                    <h2 class="text-xl font-semibold text-slate-100">
                        <a href="/blog/{{ post.slug }}" class="hover:text-cyan-300 transition-colors">{{ post.title }}</a>
                    </h2>
                    {% if post.excerpt %}
                        <p class="mt-2 text-sm leading-relaxed text-slate-400">{{ post.excerpt }}</p>
                    {% endif %}
                    <div class="mt-4">
                        <a href="/blog/{{ post.slug }}" class="inline-flex items-center gap-1.5 text-sm font-semibold text-cyan-400 hover:text-cyan-300 transition-colors">
                            {{ t('cms_blog_read_more', page_locale()) }}
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                        </a>
                    </div>
                </div>
            </article>
        {% else %}
            <div class="ng-empty-state">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                <p>{{ t('cms_blog_public_empty', page_locale()) }}</p>
            </div>
        {% endfor %}
    </div>
</div>
{% endblock %}
