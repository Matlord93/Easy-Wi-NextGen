{% set siteTitle = app_setting('site_title', 'Easy-Wi NextGen') %}
{% set brandingName = app_setting('branding_name', siteTitle) %}
{% set brandingLogo = app_setting('branding_logo_url') %}
<!DOCTYPE html>
<html lang="{{ page_locale() }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script>
        (function () {
            const storedTheme = localStorage.getItem('theme');
            if (storedTheme === 'light') {
                document.documentElement.classList.remove('dark');
            } else {
                document.documentElement.classList.add('dark');
            }
        })();
    </script>
    <title>{{ siteTitle }}</title>
    {% block head %}{% endblock %}
    <link rel="stylesheet" href="{{ asset('ui.css') }}">
    <link rel="stylesheet" href="{{ asset('admin-customer.css') }}">
    <link rel="stylesheet" href="{{ asset('ts6.css') }}">
    <link rel="stylesheet" href="{{ asset('ts3.css') }}">
    <script src="{{ asset('htmx.min.js') }}"></script>
</head>
<body class="bg-slate-950 text-slate-100">
{% set showPortalShell = showPortalShell is defined ? showPortalShell : true %}
{% set contentClass = contentClass is defined ? contentClass : 'mx-auto w-full max-w-6xl px-4 py-6 sm:px-6' %}
{% set currentUser = current_user() %}
{% set lang = app.request ? app.request.query.get('lang') : null %}
{% set langSuffix = lang in ['de', 'en'] ? '?lang=' ~ lang : '' %}
{% if showPortalShell %}
{% set activeNav = activeNav|default('') %}
<main class="min-h-screen flex flex-col">
    <header class="sticky top-0 z-20 border-b border-cyan-500/20 bg-slate-900/95 backdrop-blur shadow-lg shadow-black/20">
            <div class="mx-auto flex w-full max-w-6xl items-center justify-between px-4 py-4 sm:px-6">
                <div class="flex items-center gap-6">
                    <a href="/" class="text-lg font-bold tracking-wide text-cyan-300">{{ brandingName }}</a>
                    {% set navPages = cms_pages|default([]) %}
                    {% if navPages is not empty %}
                        <nav class="hidden items-center gap-4 text-sm text-slate-300 lg:flex">
                            {% for navPage in navPages %}
                                {% set href = navPage.slug == 'startseite' ? '/' : '/' ~ navPage.slug %}
                                <a href="{{ href }}" class="transition hover:text-cyan-300">{{ navPage.title }}</a>
                            {% endfor %}
                        </nav>
                    {% endif %}
                </div>
                <div class="hidden items-center gap-4 sm:flex">
                    <div class="text-right">
                        <p class="text-sm font-semibold text-slate-100">{{ t('hosting_updates_title', page_locale()) }}</p>
                        <p class="text-xs text-slate-400">{{ t('hosting_updates_subtitle', page_locale()) }}</p>
                    </div>
                    <div class="flex items-center gap-2">
                        {% if currentUser %}
                            {% set displayName = currentUser.name ?? currentUser.email %}
                            {% set panelPath = null %}
                            {% set securityPath = '/account/security' %}
                            {% if currentUser.type.value in ['admin', 'superadmin'] %}
                                {% set panelPath = '/admin' %}
                                {% set securityPath = '/admin/profile' %}
                            {% elseif currentUser.type.value == 'reseller' %}
                                {% set panelPath = '/reseller' %}
                            {% elseif currentUser.type.value == 'customer' and currentUser.customerAccessEnabled %}
                                {% set panelPath = '/customer' %}
                            {% endif %}
                            <details class="relative">
                                <summary class="cursor-pointer list-none rounded-lg border border-slate-700 bg-slate-900 px-3 py-1.5 text-xs font-semibold text-slate-200">{{ t('public_user_menu_greeting', page_locale())|replace({'%name%': displayName}) }}</summary>
                                <div class="absolute right-0 mt-2 min-w-[180px] rounded-lg border border-slate-700 bg-slate-900 p-2 text-sm shadow-lg shadow-black/30">
                                    <a href="/profile{{ langSuffix }}" class="block rounded px-3 py-2 hover:bg-slate-800">{{ t('public_user_menu_profile', page_locale()) }}</a>
                                    <a href="{{ securityPath }}{{ langSuffix }}" class="block rounded px-3 py-2 hover:bg-slate-800">{{ t('public_user_menu_security', page_locale()) }}</a>
                                    {% if panelPath %}<a href="{{ panelPath }}{{ langSuffix }}" class="block rounded px-3 py-2 hover:bg-slate-800">{{ t('public_user_menu_panel', page_locale()) }}</a>{% endif %}
                                    <a href="{{ path('public_logout') }}{{ langSuffix }}" class="block rounded px-3 py-2 hover:bg-slate-800">{{ t('logout', page_locale()) }}</a>
                                </div>
                            </details>
                        {% else %}
                            {% set registrationEnabled = app_setting('registration_enabled', false) %}
                            <a href="{{ path('public_login') }}?target={{ (app.request ? app.request.requestUri : '/')|url_encode }}{% if langSuffix %}&lang={{ lang }}{% endif %}" class="btn rounded-lg border border-slate-700 px-3 py-1.5 text-xs font-semibold text-slate-200 transition hover:border-cyan-400 hover:bg-slate-800">{{ t('login', page_locale()) }}</a>
                            {% if registrationEnabled %}
                                <a href="{{ path('public_register') }}{{ langSuffix }}" class="btn rounded-lg bg-indigo-600 px-3 py-1.5 text-xs font-semibold text-white transition hover:bg-indigo-500">{{ t('register', page_locale()) }}</a>
                            {% endif %}
                        {% endif %}
                    </div>
                </div>
            </div>
        </header>

        <section class="{{ contentClass }}">
            {% block content %}{% endblock %}
        </section>

        <footer class="border-t border-slate-800 bg-slate-900">
            <div class="mx-auto flex w-full max-w-6xl flex-col gap-3 px-4 py-6 text-xs text-slate-400 sm:flex-row sm:items-center sm:justify-between sm:px-6">
                <div class="flex flex-col gap-1">
                    <span class="text-[11px] text-slate-500">© Easy-Wi Nextgen 2024 - 2026</span>
                </div>
                <div class="flex flex-wrap gap-4">
                    <a href="{{ path('public_cms_page_slug', {slug: 'impressum'}) }}" class="hover:text-cyan-300">{{ t('imprint', page_locale()) }}</a>
                    <a href="{{ path('public_cms_page_slug', {slug: 'agb'}) }}" class="hover:text-cyan-300">{{ t('terms_of_service', page_locale()) }}</a>
                    <a href="{{ path('public_cms_page_slug', {slug: 'datenschutz'}) }}" class="hover:text-cyan-300">{{ t('privacy_policy', page_locale()) }}</a>
                    <a href="{{ path('public_cms_page_slug', {slug: 'cookies'}) }}" class="hover:text-cyan-300">{{ t('cookie_policy', page_locale()) }}</a>
                </div>
            </div>
        </footer>
    </main>
{% else %}
<main class="min-h-screen flex flex-col">
    <section class="{{ contentClass }}">
        {{ block('content') }}
    </section>
    <footer class="mt-auto border-t border-slate-200 bg-white">
        <div class="mx-auto flex w-full max-w-6xl flex-col gap-3 px-4 py-6 text-xs text-slate-700 sm:flex-row sm:items-center sm:justify-between sm:px-6">
            <div class="flex flex-col gap-1">
                <span class="text-[11px] text-slate-500">© Easy-Wi Nextgen 2024 - 2026</span>
            </div>
            <div class="flex flex-wrap gap-4">
                <a href="{{ path('public_cms_page_slug', {slug: 'impressum'}) }}" class="hover:text-slate-700">{{ t('imprint', page_locale()) }}</a>
                <a href="{{ path('public_cms_page_slug', {slug: 'agb'}) }}" class="hover:text-slate-700">{{ t('terms_of_service', page_locale()) }}</a>
                <a href="{{ path('public_cms_page_slug', {slug: 'datenschutz'}) }}" class="hover:text-slate-700">{{ t('privacy_policy', page_locale()) }}</a>
                <a href="{{ path('public_cms_page_slug', {slug: 'cookies'}) }}" class="hover:text-slate-700">{{ t('cookie_policy', page_locale()) }}</a>
            </div>
        </div>
    </footer>
</main>
{% endif %}

<div id="cookie-banner" class="fixed inset-x-4 bottom-4 z-40 hidden rounded-2xl border border-slate-200 bg-white p-4 shadow-lg sm:inset-x-auto sm:right-6 sm:max-w-lg">
    <div class="flex flex-col gap-4">
        <div>
            <h2 class="text-sm font-semibold text-slate-900">{{ t('cookie_banner_title', page_locale()) }}</h2>
            <p class="mt-2 text-xs text-slate-600">{{ t('cookie_banner_description', page_locale()) }}</p>
        </div>
        <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-end">
            <button class="rounded-lg border border-slate-200 px-3 py-2 text-xs font-semibold text-slate-600 hover:bg-slate-50" data-cookie-reject>{{ t('cookie_reject_optional', page_locale()) }}</button>
            <button class="rounded-lg border border-slate-200 px-3 py-2 text-xs font-semibold text-slate-700 hover:bg-slate-50" data-cookie-settings>{{ t('cookie_settings', page_locale()) }}</button>
            <button class="rounded-lg bg-slate-900 px-3 py-2 text-xs font-semibold text-white hover:bg-slate-800" data-cookie-accept>{{ t('cookie_accept_all', page_locale()) }}</button>
        </div>
    </div>
</div>

<div id="cookie-settings-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-slate-900/40 px-4 py-6">
    <div class="w-full max-w-2xl rounded-2xl border border-slate-200 bg-white p-6 shadow-xl">
        <div class="flex items-start justify-between gap-4">
            <div>
                <h2 class="text-lg font-semibold">{{ t('cookie_settings_title', page_locale()) }}</h2>
                <p class="mt-2 text-sm text-slate-600">{{ t('cookie_settings_description', page_locale()) }}</p>
            </div>
            <button type="button" class="text-xs font-semibold text-slate-700 hover:text-slate-700" data-cookie-close>{{ t('cookie_settings_close', page_locale()) }}</button>
        </div>

        <div class="mt-6 space-y-4">
            <div class="flex items-center justify-between rounded-xl border border-slate-200 bg-slate-50 px-4 py-3">
                <div>
                    <p class="text-sm font-semibold">{{ t('cookie_category_necessary_title', page_locale()) }}</p>
                    <p class="text-xs text-slate-700">{{ t('cookie_category_necessary_description', page_locale()) }}</p>
                </div>
                <input type="checkbox" checked disabled class="h-4 w-4 rounded border-slate-300 text-slate-700">
            </div>
            <label class="flex items-center justify-between rounded-xl border border-slate-200 bg-white px-4 py-3">
                <div>
                    <p class="text-sm font-semibold">{{ t('cookie_category_statistics_title', page_locale()) }}</p>
                    <p class="text-xs text-slate-700">{{ t('cookie_category_statistics_description', page_locale()) }}</p>
                </div>
                <input type="checkbox" class="h-4 w-4 rounded border-slate-300 text-indigo-600" data-cookie-toggle="statistics">
            </label>
            <label class="flex items-center justify-between rounded-xl border border-slate-200 bg-white px-4 py-3">
                <div>
                    <p class="text-sm font-semibold">{{ t('cookie_category_marketing_title', page_locale()) }}</p>
                    <p class="text-xs text-slate-700">{{ t('cookie_category_marketing_description', page_locale()) }}</p>
                </div>
                <input type="checkbox" class="h-4 w-4 rounded border-slate-300 text-indigo-600" data-cookie-toggle="marketing">
            </label>
        </div>


        <div class="mt-6 rounded-xl border border-slate-200 bg-slate-50 p-4">
            <h3 class="text-sm font-semibold text-slate-900">Cookie-Details dieser Seite</h3>
            <p class="mt-1 text-xs text-slate-600">Notwendige Cookies sind immer aktiv. Statistik und Marketing kannst du deaktivieren. Aktuell werden optionale Kategorien nur nach Zustimmung aktiviert.</p>
            <div class="mt-3 overflow-x-auto">
                <table class="min-w-full text-xs text-slate-700">
                    <thead class="text-left text-slate-500">
                        <tr>
                            <th class="px-2 py-1">Name</th>
                            <th class="px-2 py-1">Zweck</th>
                            <th class="px-2 py-1">Kategorie</th>
                            <th class="px-2 py-1">Deaktivierbar</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr><td class="px-2 py-1 font-mono">easywi_session</td><td class="px-2 py-1">Admin-/Backend-Sitzung</td><td class="px-2 py-1">Notwendig</td><td class="px-2 py-1">Nein</td></tr>
                        <tr><td class="px-2 py-1 font-mono">easywi_customer_session</td><td class="px-2 py-1">Kundenbereich-Sitzung</td><td class="px-2 py-1">Notwendig</td><td class="px-2 py-1">Nein</td></tr>
                        <tr><td class="px-2 py-1 font-mono">PHPSESSID</td><td class="px-2 py-1">Temporäre Session/CSRF</td><td class="px-2 py-1">Notwendig</td><td class="px-2 py-1">Nein</td></tr>
                        <tr><td class="px-2 py-1 font-mono">{{ cookie_consent_cookie_name() }}</td><td class="px-2 py-1">Speichert deine Einwilligung</td><td class="px-2 py-1">Notwendig</td><td class="px-2 py-1">Nein</td></tr>
                        <tr><td class="px-2 py-1 font-mono">portal_language</td><td class="px-2 py-1">Sprachpräferenz</td><td class="px-2 py-1">Notwendig</td><td class="px-2 py-1">Nein</td></tr>
                        <tr><td class="px-2 py-1 font-mono">Optionale Statistik-Cookies</td><td class="px-2 py-1">Nutzungsanalyse zur Verbesserung</td><td class="px-2 py-1">Statistik</td><td class="px-2 py-1">Ja</td></tr>
                        <tr><td class="px-2 py-1 font-mono">Optionale Marketing-Cookies</td><td class="px-2 py-1">Externe Inhalte/Kampagnen</td><td class="px-2 py-1">Marketing</td><td class="px-2 py-1">Ja</td></tr>
                    </tbody>
                </table>
            </div>
        </div>

        <div class="mt-6 flex flex-col gap-2 sm:flex-row sm:justify-end">
            <button class="rounded-lg border border-slate-200 px-4 py-2 text-xs font-semibold text-slate-600 hover:bg-slate-50" data-cookie-close>{{ t('cookie_settings_close', page_locale()) }}</button>
            <button class="rounded-lg bg-indigo-600 px-4 py-2 text-xs font-semibold text-white hover:bg-indigo-700" data-cookie-save>{{ t('cookie_settings_save', page_locale()) }}</button>
        </div>
    </div>
</div>

{% if cookie_has_consent('statistics') %}
    <script data-optional-consent="statistics-enabled">window.__easywiConsentStatistics = true;</script>
{% endif %}
{% if cookie_has_consent('marketing') %}
    <script data-optional-consent="marketing-enabled">window.__easywiConsentMarketing = true;</script>
{% endif %}

<script>
    const consentCookieName = '{{ cookie_consent_cookie_name() }}';
    const consentVersion = {{ cookie_consent_version() }};
    const defaultConsent = {
        version: consentVersion,
        necessary: true,
        statistics: false,
        marketing: false,
    };

    const banner = document.getElementById('cookie-banner');
    const modal = document.getElementById('cookie-settings-modal');
    const toggles = Array.from(document.querySelectorAll('[data-cookie-toggle]'));

    const getCookie = (name) => {
        return document.cookie
            .split('; ')
            .find((row) => row.startsWith(name + '='))
            ?.split('=')[1];
    };

    const readConsent = () => {
        const stored = getCookie(consentCookieName);
        if (!stored) {
            return null;
        }

        try {
            const parsed = JSON.parse(decodeURIComponent(stored));
            return {
                ...defaultConsent,
                version: Number(parsed.version) || consentVersion,
                statistics: Boolean(parsed.statistics),
                marketing: Boolean(parsed.marketing),
            };
        } catch (error) {
            return null;
        }
    };

    const setConsentCookieLocal = (consent) => {
        const secureFlag = window.location.protocol === 'https:' ? '; secure' : '';
        document.cookie = `${consentCookieName}=${encodeURIComponent(JSON.stringify(consent))}; path=/; max-age=31536000; samesite=lax${secureFlag}`;
    };

    const persistConsent = async (consent) => {
        setConsentCookieLocal(consent);

        try {
            await fetch('/cookie-consent', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest',
                },
                body: JSON.stringify(consent),
                credentials: 'same-origin',
            });
        } catch (error) {
            // fallback remains local cookie
        }
    };

    const applyConsentToForm = (consent) => {
        toggles.forEach((toggle) => {
            const key = toggle.dataset.cookieToggle;
            toggle.checked = Boolean(consent?.[key]);
        });
    };

    const showBannerIfNeeded = () => {
        const consent = readConsent();
        if (!consent && banner) {
            banner.classList.remove('hidden');
        }
    };

    const openModal = () => {
        applyConsentToForm(readConsent() ?? defaultConsent);
        modal?.classList.remove('hidden');
        modal?.classList.add('flex');
    };

    const closeModal = () => {
        modal?.classList.add('hidden');
        modal?.classList.remove('flex');
    };

    const saveConsent = async (statistics, marketing) => {
        await persistConsent({
            version: consentVersion,
            necessary: true,
            statistics,
            marketing,
        });

        banner?.classList.add('hidden');
        closeModal();
        window.location.reload();
    };

    document.querySelectorAll('[data-cookie-open]').forEach((button) => {
        button.addEventListener('click', openModal);
    });

    document.querySelectorAll('[data-cookie-settings]').forEach((button) => {
        button.addEventListener('click', () => {
            banner?.classList.add('hidden');
            openModal();
        });
    });

    document.querySelectorAll('[data-cookie-close]').forEach((button) => {
        button.addEventListener('click', closeModal);
    });

    document.querySelectorAll('[data-cookie-accept]').forEach((button) => {
        button.addEventListener('click', () => {
            saveConsent(true, true);
        });
    });

    document.querySelectorAll('[data-cookie-reject]').forEach((button) => {
        button.addEventListener('click', () => {
            saveConsent(false, false);
        });
    });

    document.querySelectorAll('[data-cookie-save]').forEach((button) => {
        button.addEventListener('click', () => {
            const statistics = toggles.find((toggle) => toggle.dataset.cookieToggle === 'statistics')?.checked ?? false;
            const marketing = toggles.find((toggle) => toggle.dataset.cookieToggle === 'marketing')?.checked ?? false;
            saveConsent(statistics, marketing);
        });
    });

    showBannerIfNeeded();
</script>
</body>
</html>
