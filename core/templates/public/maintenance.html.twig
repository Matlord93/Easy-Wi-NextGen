{% extends 'public/base.html.twig' %}

{% block content %}
    <div class="mx-auto flex w-full max-w-3xl flex-col gap-6 rounded-2xl border border-slate-200 bg-white p-8 text-center shadow-sm">
        <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-indigo-50 text-indigo-600">
            <span class="text-xl">🛠️</span>
        </div>
        <div>
            <p class="text-xs font-semibold uppercase tracking-[0.3em] text-indigo-500">{{ t('cms_maintenance_kicker', page_locale()) }}</p>
            <h1 class="mt-3 text-3xl font-semibold text-slate-900">{{ t('cms_maintenance_heading', page_locale()) }}</h1>
            <p class="mt-3 text-sm text-slate-600">{{ message is not empty ? message : t('cms_maintenance_default_message', page_locale()) }}</p>
        </div>

        {% if starts_at or ends_at %}
            <div class="rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-700">
                <p class="font-semibold">{{ t('cms_maintenance_window_title', page_locale()) }}</p>
                <p class="mt-1">
                    {% if starts_at %}
                        {{ t('cms_maintenance_window_start', page_locale()) }} {{ starts_at|date('Y-m-d H:i') }}
                    {% endif %}
                    {% if ends_at %}
                        {% if starts_at %} · {% endif %}
                        {{ t('cms_maintenance_window_end', page_locale()) }} {{ ends_at|date('Y-m-d H:i') }}
                    {% endif %}
                </p>
            </div>
        {% endif %}

        <div class="text-xs text-slate-500">
            {% set scopeLabel = scope == 'site' ? t('cms_maintenance_scope_site_label', page_locale()) : t('cms_maintenance_scope_global_label', page_locale()) %}
            {{ t('cms_maintenance_scope_note', page_locale())|replace({'%scope%': scopeLabel}) }}
        </div>
    </div>
{% endblock %}
