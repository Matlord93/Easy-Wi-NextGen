{% extends 'themes/' ~ (active_theme|default('minimal')) ~ '/base.html.twig' %}

{% block shell %}{% block content %}
{% set brandingLogo = app_setting('branding_logo_url') %}
<div class="flex min-h-screen items-center justify-center px-4 py-12">
    <div class="w-full max-w-lg text-center">

        {% if brandingLogo is not empty %}
            <div class="mx-auto mb-6 w-fit overflow-hidden rounded-xl border border-slate-800 bg-slate-900/70 p-4">
                <img src="{{ brandingLogo }}" alt="{{ app_setting('branding_name', 'Easy-Wi NextGen') }}" class="max-h-14 w-auto object-contain">
            </div>
        {% endif %}

        <div class="mx-auto mb-6 flex h-14 w-14 items-center justify-center rounded-full border border-cyan-500/20 bg-cyan-500/10 text-2xl">
            🛠️
        </div>

        {% if graphic_path is not empty %}
            <div class="mx-auto mb-6 overflow-hidden rounded-xl border border-slate-800 bg-slate-900/70 p-3">
                <img src="{{ graphic_path }}" alt="Maintenance" class="mx-auto max-h-56 w-auto object-contain">
            </div>
        {% endif %}

        <p class="mb-2 text-xs font-semibold uppercase tracking-widest text-cyan-400">{{ t('cms_maintenance_kicker', page_locale()) }}</p>
        <h1 class="text-3xl font-bold text-white">{{ t('cms_maintenance_heading', page_locale()) }}</h1>
        <div class="mx-auto mt-4 max-w-sm text-sm text-slate-400">
            {{ (message is not empty ? message : t('cms_maintenance_default_message', page_locale()))|bbcode }}
        </div>

        {% if starts_at or ends_at %}
            <div class="mx-auto mt-6 max-w-sm rounded-xl border border-slate-800 bg-slate-900/60 px-4 py-3 text-sm text-slate-300">
                <p class="font-semibold text-slate-200">{{ t('cms_maintenance_window_title', page_locale()) }}</p>
                <p class="mt-1 text-slate-400">
                    {% if starts_at %}{{ t('cms_maintenance_window_start', page_locale()) }} {{ starts_at|date('d.m.Y H:i') }}{% endif %}
                    {% if ends_at %}{% if starts_at %} · {% endif %}{{ t('cms_maintenance_window_end', page_locale()) }} {{ ends_at|date('d.m.Y H:i') }}{% endif %}
                </p>
            </div>
        {% endif %}

        <p class="mt-6 text-xs text-slate-600">
            {% set scopeLabel = scope == 'site' ? t('cms_maintenance_scope_site_label', page_locale()) : t('cms_maintenance_scope_global_label', page_locale()) %}
            {{ t('cms_maintenance_scope_note', page_locale())|replace({'%scope%': scopeLabel}) }}
        </p>
    </div>
</div>
{% endblock %}{% endblock %}
