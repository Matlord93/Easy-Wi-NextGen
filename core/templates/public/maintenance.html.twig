{% extends 'public/base.html.twig' %}

{% block content %}
    {% set brandingLogo = app_setting('branding_logo_url') %}
    <div class="mx-auto flex w-full max-w-3xl flex-col gap-6 rounded-2xl border border-cyan-500/20 bg-slate-900/95 p-8 text-center shadow-xl shadow-black/20">
        {% if brandingLogo is not empty %}
            <div class="mx-auto overflow-hidden rounded-xl border border-slate-700 bg-slate-950/70 p-4">
                <img src="{{ brandingLogo }}" alt="{{ app_setting('branding_name', app_setting('site_title', 'Easy-Wi NextGen')) }}" class="max-h-16 w-auto object-contain">
            </div>
        {% endif %}

        <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-cyan-500/10 text-cyan-300">
            <span class="text-xl">🛠️</span>
        </div>

        {% if graphic_path is not empty %}
            <div class="mx-auto overflow-hidden rounded-xl border border-slate-700 bg-slate-950/70 p-2">
                <img src="{{ graphic_path }}" alt="Maintenance graphic" class="max-h-64 w-auto object-contain">
            </div>
        {% endif %}

        <div>
            <p class="text-xs font-semibold uppercase tracking-[0.3em] text-cyan-300">{{ t('cms_maintenance_kicker', page_locale()) }}</p>
            <h1 class="mt-3 text-3xl font-semibold text-white">{{ t('cms_maintenance_heading', page_locale()) }}</h1>
            <div class="prose prose-sm prose-invert mx-auto mt-3 max-w-none text-slate-300">{{ (message is not empty ? message : t('cms_maintenance_default_message', page_locale()))|bbcode }}</div>
        </div>

        {% if starts_at or ends_at %}
            <div class="rounded-xl border border-slate-700 bg-slate-950/70 px-4 py-3 text-sm text-slate-200">
                <p class="font-semibold text-slate-100">{{ t('cms_maintenance_window_title', page_locale()) }}</p>
                <p class="mt-1">
                    {% if starts_at %}
                        {{ t('cms_maintenance_window_start', page_locale()) }} {{ starts_at|date('Y-m-d H:i') }}
                    {% endif %}
                    {% if ends_at %}
                        {% if starts_at %} · {% endif %}
                        {{ t('cms_maintenance_window_end', page_locale()) }} {{ ends_at|date('Y-m-d H:i') }}
                    {% endif %}
                </p>
            </div>
        {% endif %}

        <div class="text-xs text-slate-400">
            {% set scopeLabel = scope == 'site' ? t('cms_maintenance_scope_site_label', page_locale()) : t('cms_maintenance_scope_global_label', page_locale()) %}
            {{ t('cms_maintenance_scope_note', page_locale())|replace({'%scope%': scopeLabel}) }}
        </div>
    </div>
{% endblock %}
