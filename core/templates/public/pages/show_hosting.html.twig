{% extends 'themes/' ~ (active_theme|default('minimal')) ~ '/base.html.twig' %}

{% set isHomepage = page.slug == 'startseite' %}
{% set heroBlock = blocks[0] ?? null %}

{% block title %}{{ page.title }} · {{ app_setting('site_title', 'Easy-Wi NextGen') }}{% endblock %}

{% block content %}
<div class="ng-page-hero">
    <div class="ng-container">
        <nav class="ng-breadcrumb">
            <a href="/">Home</a>
            <span>{{ page.title }}</span>
        </nav>
        <p class="mb-1 text-xs uppercase tracking-wider text-slate-500">{{ t('hosting_hero_kicker', page_locale()) }}</p>
        <h1 class="text-3xl font-bold ng-gradient-text">{{ page.title }}</h1>
        <p class="mt-2 text-sm text-slate-400">{{ t('hosting_hero_subtitle', page_locale()) }}</p>
        <div class="mt-4 flex flex-wrap gap-3">
            <a href="/shop" class="ng-btn">{{ t('hosting_hero_cta_primary', page_locale()) }}</a>
            <a href="/preise" class="ng-btn ng-btn--ghost">{{ t('hosting_hero_cta_secondary', page_locale()) }}</a>
        </div>
    </div>
</div>

<div class="ng-container ng-section space-y-8">

    {% if isHomepage and shop_categories is not empty %}
        {% include 'public/shop/_product_grid.html.twig' with {
            categories: shop_categories,
            cta_url: current_user() ? '/marketplace' : path('public_login')
        } %}
    {% endif %}

    {% if isHomepage %}
        <div class="rounded-xl border border-slate-800 bg-slate-900/60 p-6">
            <div class="mb-6 text-center">
                <p class="text-xs uppercase tracking-wider text-slate-500">{{ t('hosting_features_kicker', page_locale()) }}</p>
                <h2 class="mt-2 text-2xl font-bold ng-gradient-text">{{ t('hosting_features_title', page_locale()) }}</h2>
                <p class="mt-2 text-sm text-slate-400">{{ t('hosting_features_subtitle', page_locale()) }}</p>
            </div>
            <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
                {% set features = [
                    {icon: '👤', key: 'user_friendly'},
                    {icon: '🛡️', key: 'ddos'},
                    {icon: '🎧', key: 'support'},
                    {icon: '💳', key: 'billing'},
                    {icon: '🎁', key: 'freebies'},
                    {icon: '💾', key: 'ssd'}
                ] %}
                {% for feature in features %}
                    <div class="flex items-start gap-3 rounded-lg border border-slate-800 bg-slate-900/80 p-4">
                        <span class="text-xl">{{ feature.icon }}</span>
                        <div>
                            <p class="text-sm font-semibold text-slate-200">{{ t('hosting_feature_' ~ feature.key, page_locale()) }}</p>
                            <p class="mt-1 text-xs text-slate-500">{{ t('hosting_feature_' ~ feature.key ~ '_desc', page_locale()) }}</p>
                        </div>
                    </div>
                {% endfor %}
            </div>
        </div>

        <div class="rounded-xl border border-slate-800 bg-slate-900/60 p-6">
            <div class="mb-4 text-center">
                <p class="text-xs uppercase tracking-wider text-slate-500">{{ t('hosting_locations_kicker', page_locale()) }}</p>
                <h2 class="mt-2 text-xl font-bold text-slate-100">{{ t('hosting_locations_title', page_locale()) }}</h2>
            </div>
            <div class="flex flex-wrap justify-center gap-3">
                {% for location in ['Frankfurt', 'Amsterdam', 'Dallas', 'Singapur', 'Sydney'] %}
                    <span class="rounded-full border border-slate-700 bg-slate-800/60 px-3 py-1 text-xs text-slate-400">{{ location }}</span>
                {% endfor %}
            </div>
        </div>

        <div class="flex flex-col items-start gap-4 rounded-xl border border-cyan-500/20 bg-gradient-to-r from-cyan-500/5 to-purple-500/5 p-6 sm:flex-row sm:items-center sm:justify-between">
            <div>
                <p class="text-xs uppercase tracking-wider text-slate-500">{{ t('hosting_guarantee_kicker', page_locale()) }}</p>
                <h3 class="mt-1 text-lg font-semibold text-slate-100">{{ t('hosting_guarantee_title', page_locale()) }}</h3>
            </div>
            <a href="/shop" class="ng-btn shrink-0">{{ t('hosting_hero_cta_primary', page_locale()) }}</a>
        </div>

    {% else %}

        {% if page.slug == 'shop' and shop_categories is not empty %}
            {% include 'public/shop/_product_grid.html.twig' with {
                categories: shop_categories,
                cta_url: current_user() ? '/marketplace' : path('public_login')
            } %}
        {% endif %}

        <div class="grid gap-6 lg:grid-cols-3">
            {% for block in blocks %}
                <div class="rounded-xl border border-slate-800 bg-slate-900/60 p-6">
                    {% include 'public/blocks/_block.html.twig' with { block: block, text_class: 'prose prose-invert prose-sm max-w-none text-slate-300 prose-headings:text-slate-100 prose-a:text-cyan-400' } only %}
                </div>
            {% else %}
                <div class="ng-empty-state col-span-full">
                    <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/></svg>
                    <p>Noch keine Inhalte vorhanden.</p>
                </div>
            {% endfor %}
        </div>

    {% endif %}
</div>
{% endblock %}
