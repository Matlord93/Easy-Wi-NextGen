{% extends 'themes/' ~ (active_theme|default('minimal')) ~ '/base.html.twig' %}

{% block title %}{{ page.title }} · {{ app_setting('site_title', 'Easy-Wi NextGen') }}{% endblock %}

{% block content %}
<div class="ng-page-hero">
    <div class="ng-container">
        <nav class="ng-breadcrumb">
            <a href="/">Home</a>
            <span>{{ page.title }}</span>
        </nav>
        <p class="mb-1 text-xs uppercase tracking-wider text-slate-500">Privat</p>
        <h1 class="text-3xl font-bold ng-gradient-text">{{ page.title }}</h1>
        <p class="mt-2 text-sm text-slate-400">Persönliche Inhalte und Projekte.</p>
    </div>
</div>

<div class="ng-container ng-section">
    <div class="mx-auto max-w-3xl space-y-6">
        {% for block in blocks %}
            <article class="rounded-xl border border-slate-800 bg-slate-900/60 p-6">
                {% include 'public/blocks/_block.html.twig' with { block: block, text_class: 'prose prose-invert prose-sm max-w-none text-slate-300 prose-headings:text-slate-100 prose-a:text-cyan-400 prose-strong:text-slate-100' } only %}
            </article>
        {% else %}
            <div class="ng-empty-state">
                <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/></svg>
                <p>Noch keine Inhalte vorhanden.</p>
            </div>
        {% endfor %}
    </div>
</div>
{% endblock %}
