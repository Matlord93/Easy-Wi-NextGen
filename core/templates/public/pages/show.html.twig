{% extends 'public/base.html.twig' %}

{% block title %}{{ page.title }} · Easy-Wi NextGen{% endblock %}

{% block content %}
<div class="space-y-6">
    <div>
        <h1 class="text-2xl font-semibold">{{ page.title }}</h1>
    </div>

    {% for block in blocks %}
        <div class="rounded-xl border border-slate-200 bg-white p-6">
            {% include 'public/blocks/_block.html.twig' with { block: block } only %}
        </div>
    {% else %}
        <div class="rounded-xl border border-slate-200 bg-white p-6 text-sm text-slate-700">{{ t('no_blocks_available', page_locale()) }}</div>
    {% endfor %}
</div>
{% endblock %}
