{% extends 'themes/' ~ (active_theme|default('minimal')) ~ '/base.html.twig' %}

{% block title %}{{ page.title }} · {{ app_setting('site_title', 'Easy-Wi NextGen') }}{% endblock %}

{% block content %}
<div class="ng-page-hero">
    <div class="ng-container">
        <nav class="ng-breadcrumb">
            <a href="/">Home</a>
            <span>{{ page.title }}</span>
        </nav>
        <p class="mb-1 text-xs uppercase tracking-wider text-slate-500">Clan Command Center</p>
        <h1 class="text-3xl font-bold ng-gradient-text">{{ page.title }}</h1>
        <p class="mt-2 text-sm text-slate-400">Community, Teams &amp; Events auf einen Blick.</p>
    </div>
</div>

<div class="ng-container ng-section">
    <div class="grid gap-8 lg:grid-cols-[2fr,1fr]">
        <section class="space-y-6">
            {% for block in blocks %}
                <div class="rounded-xl border border-slate-800 bg-slate-900/70 p-6">
                    {% include 'public/blocks/_block.html.twig' with { block: block, text_class: 'prose prose-invert prose-sm max-w-none text-slate-300 prose-headings:text-slate-100 prose-a:text-cyan-400 prose-strong:text-slate-100' } only %}
                </div>
            {% else %}
                <div class="ng-empty-state">
                    <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/></svg>
                    <p>Noch keine Inhalte vorhanden.</p>
                </div>
            {% endfor %}
        </section>

        <aside class="space-y-6">
            {% if cms_recent_events|default([])|length > 0 %}
                <div class="rounded-xl border border-slate-800 bg-slate-900/70 p-5">
                    <h2 class="mb-3 text-sm font-semibold uppercase tracking-wider text-slate-400">Nächste Events</h2>
                    <ul class="space-y-2">
                        {% for event in cms_recent_events|slice(0, 4) %}
                            <li class="border-b border-slate-800 pb-2 last:border-0 last:pb-0">
                                <a href="/events/{{ event.slug }}" class="text-sm text-slate-300 hover:text-cyan-400 transition">{{ event.title }}</a>
                                {% if event.start_at is defined %}
                                    <span class="block text-xs text-slate-600">{{ event.start_at|date('d.m.Y') }}</span>
                                {% endif %}
                            </li>
                        {% endfor %}
                    </ul>
                </div>
            {% endif %}

            <div class="rounded-xl border border-slate-800 bg-slate-900/70 p-5">
                <h2 class="mb-3 text-sm font-semibold uppercase tracking-wider text-slate-400">Navigation</h2>
                <nav class="flex flex-col gap-1 text-sm">
                    <a href="/team" class="rounded-lg px-3 py-2 text-slate-400 hover:bg-slate-800 hover:text-slate-200 transition">Team</a>
                    <a href="/events" class="rounded-lg px-3 py-2 text-slate-400 hover:bg-slate-800 hover:text-slate-200 transition">Events</a>
                    <a href="/forum" class="rounded-lg px-3 py-2 text-slate-400 hover:bg-slate-800 hover:text-slate-200 transition">Forum</a>
                    {% if module_toggles.blog|default(true) %}
                        <a href="/blog" class="rounded-lg px-3 py-2 text-slate-400 hover:bg-slate-800 hover:text-slate-200 transition">Blog</a>
                    {% endif %}
                </nav>
            </div>
        </aside>
    </div>
</div>
{% endblock %}
