{% extends 'themes/' ~ (active_theme|default('minimal')) ~ '/base.html.twig' %}

{% block title %}{{ t('contact_title', page_locale()) }} · {{ app_setting('site_title', 'Easy-Wi NextGen') }}{% endblock %}

{% block content %}
<div class="ng-page-hero">
    <div class="ng-container">
        <nav class="ng-breadcrumb">
            <a href="/">{{ t('common_home', page_locale()) }}</a>
            <span>{{ t('contact_title', page_locale()) }}</span>
        </nav>
        <h1 class="text-3xl font-bold ng-gradient-text">{{ t('contact_title', page_locale()) }}</h1>
        <p class="mt-2 text-sm text-slate-400">{{ t('contact_subtitle', page_locale()) }}</p>
    </div>
</div>

<div class="ng-container ng-section">
    <div class="mx-auto max-w-xl">
        {% if success %}
            <div class="mb-6 rounded-lg border border-green-500/30 bg-green-500/10 px-4 py-3 text-sm text-green-400">
                {{ t('contact_success', page_locale()) }}
            </div>
        {% endif %}
        {% if errors is not empty %}
            <div class="mb-6 rounded-lg border border-rose-500/30 bg-rose-500/10 px-4 py-3 text-sm text-rose-400">
                {% for error in errors %}<p>{{ t(error, page_locale()) }}</p>{% endfor %}
            </div>
        {% endif %}

        <div class="rounded-xl border border-slate-800 bg-slate-900/60 p-6">
            <form method="post" class="space-y-4">
                <input type="hidden" name="_token" value="{{ csrf_token('public_contact') }}">
                <div>
                    <label class="mb-1 block text-sm font-medium text-slate-400">{{ t('common_name', page_locale()) }}</label>
                    <input name="name" placeholder="{{ t('contact_name_placeholder', page_locale()) }}" class="ng-input w-full" required>
                </div>
                <div>
                    <label class="mb-1 block text-sm font-medium text-slate-400">{{ t('contact_email_label', page_locale()) }}</label>
                    <input name="email" type="email" placeholder="{{ t('contact_email_placeholder', page_locale()) }}" class="ng-input w-full" required>
                </div>
                <div>
                    <label class="mb-1 block text-sm font-medium text-slate-400">{{ t('contact_subject_label', page_locale()) }}</label>
                    <input name="subject" placeholder="{{ t('contact_subject_label', page_locale()) }}" class="ng-input w-full" required>
                </div>
                <div>
                    <label class="mb-1 block text-sm font-medium text-slate-400">{{ t('contact_message_label', page_locale()) }}</label>
                    <textarea name="message" rows="6" class="ng-input w-full" required></textarea>
                </div>
                <input type="text" name="website" class="hidden" autocomplete="off" tabindex="-1">
                <input type="hidden" name="pow_solution" id="pow_solution">
                {% if captcha_question %}
                    <div>
                        <label class="mb-1 block text-sm font-medium text-slate-400">{{ captcha_question }}</label>
                        <input name="captcha_answer" class="ng-input w-full" required>
                    </div>
                {% endif %}
                <button class="ng-btn">{{ t('contact_submit', page_locale()) }}</button>
            </form>
        </div>
    </div>
</div>
<script>
(async()=>{const nonce='{{ anti_abuse_nonce }}';const diff={{ pow_difficulty|default(4) }};const out=document.getElementById('pow_solution');if(!nonce||!out||!window.crypto?.subtle){return;}const target='0'.repeat(diff);const enc=new TextEncoder();for(let i=0;i<2000000;i++){const bytes=enc.encode(nonce+String(i));const hash=await crypto.subtle.digest('SHA-256',bytes);const hex=[...new Uint8Array(hash)].map(b=>b.toString(16).padStart(2,'0')).join('');if(hex.startsWith(target)){out.value=String(i);break;}}})();
</script>
{% endblock %}
