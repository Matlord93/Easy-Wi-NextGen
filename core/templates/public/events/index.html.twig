{% extends 'themes/' ~ (active_theme|default('minimal')) ~ '/base.html.twig' %}
{% block content %}
<div class="mx-auto max-w-5xl space-y-6 px-4 py-10">
    <div>
        <h1 class="text-3xl font-semibold text-slate-100">Events</h1>
        <p class="mt-2 text-sm text-slate-400">Alle kommenden Clan-Termine und Community-Events im Überblick.</p>
    </div>
    {% for event in events %}
        <article class="rounded-2xl border border-slate-800 bg-slate-900/70 p-5 shadow-lg shadow-black/20">
            <h2 class="text-xl font-semibold text-slate-100"><a href="/events/{{ event.slug }}" class="hover:text-cyan-300">{{ event.title }}</a></h2>
            <p class="text-xs text-slate-400">{{ event.start_at|date('d.m.Y H:i') }}{% if event.location %} · {{ event.location }}{% endif %} · {{ event.status }}</p>
            {% if event.cover_image_path %}<img src="{{ event.cover_image_path }}" alt="{{ event.title }}" class="mt-3 h-48 w-full rounded object-cover" />{% endif %}
            <p class="mt-3 text-sm text-slate-300">{{ event.description|slice(0, 180) }}{% if event.description|length > 180 %}…{% endif %}</p>
        </article>
    {% else %}
        <p class="rounded-2xl border border-slate-800 bg-slate-900/60 p-5 text-slate-400">No events available.</p>
    {% endfor %}
</div>
{% endblock %}
