{% extends 'themes/' ~ (active_theme|default('minimal')) ~ '/base.html.twig' %}

{% block title %}Events · {{ app_setting('site_title', 'Easy-Wi NextGen') }}{% endblock %}

{% block content %}
<div class="ng-page-hero">
    <div class="ng-container">
        <nav class="ng-breadcrumb">
            <a href="/">Home</a>
            <span>Events</span>
        </nav>
        <h1 class="text-3xl font-bold ng-gradient-text">Events</h1>
        <p class="mt-2 text-sm text-slate-400">Alle kommenden Clan-Termine und Community-Events im Überblick.</p>
    </div>
</div>

<div class="ng-container ng-section">
    <div class="space-y-5">
        {% for event in events %}
            {% set statusClass = 'border-slate-700 bg-slate-800/60 text-slate-400' %}
            {% set statusLabel = event.status %}
            {% if event.status == 'live' or event.status == 'running' %}
                {% set statusClass = 'border-green-500/40 bg-green-500/10 text-green-400' %}
                {% set statusLabel = 'Live' %}
            {% elseif event.status == 'upcoming' or event.status == 'scheduled' %}
                {% set statusClass = 'border-cyan-500/40 bg-cyan-500/10 text-cyan-400' %}
                {% set statusLabel = 'Demnächst' %}
            {% elseif event.status == 'finished' or event.status == 'past' %}
                {% set statusClass = 'border-slate-700 bg-slate-800/40 text-slate-500' %}
                {% set statusLabel = 'Abgeschlossen' %}
            {% endif %}

            <article class="group overflow-hidden rounded-xl border border-slate-800 bg-slate-900/70 transition-all duration-300 hover:border-slate-700 md:flex">
                {% if event.cover_image_path %}
                    <div class="relative h-48 flex-shrink-0 overflow-hidden md:h-auto md:w-56">
                        <img src="{{ event.cover_image_path }}" alt="{{ event.title }}"
                             class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" />
                        <div class="absolute inset-0 bg-gradient-to-r from-transparent to-slate-900/50 md:block hidden"></div>
                    </div>
                {% endif %}
                <div class="flex flex-1 flex-col p-6">
                    <div class="flex flex-wrap items-start justify-between gap-3 mb-2">
                        <h2 class="text-xl font-semibold text-slate-100">
                            <a href="/events/{{ event.slug }}" class="hover:text-cyan-300 transition-colors">{{ event.title }}</a>
                        </h2>
                        <span class="flex-shrink-0 rounded-full border px-2.5 py-0.5 text-xs font-semibold {{ statusClass }}">
                            {{ statusLabel }}
                        </span>
                    </div>
                    <p class="mb-3 text-xs text-slate-500">
                        <svg class="inline-block mr-1" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                        {{ event.start_at|date('d.m.Y H:i') }}
                        {% if event.location %}
                            <span class="mx-1">·</span>
                            <svg class="inline-block mr-0.5" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                            {{ event.location }}
                        {% endif %}
                    </p>
                    {% if event.description %}
                        <p class="text-sm leading-relaxed text-slate-400 flex-1">
                            {{ event.description|slice(0, 200) }}{% if event.description|length > 200 %}…{% endif %}
                        </p>
                    {% endif %}
                    <div class="mt-4">
                        <a href="/events/{{ event.slug }}" class="inline-flex items-center gap-1.5 text-sm font-semibold text-cyan-400 hover:text-cyan-300 transition-colors">
                            Mehr erfahren
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                        </a>
                    </div>
                </div>
            </article>
        {% else %}
            <div class="ng-empty-state">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                <p>Keine Events verfügbar.</p>
            </div>
        {% endfor %}
    </div>
</div>
{% endblock %}
