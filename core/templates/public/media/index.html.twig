{% extends 'themes/' ~ (active_theme|default('minimal')) ~ '/base.html.twig' %}

{% block content %}
<div class="mx-auto max-w-6xl space-y-4 px-4 py-10">
    <h1 class="text-3xl font-semibold">Media</h1>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {% for asset in assets %}
            <figure class="rounded-2xl border bg-white p-3 shadow-sm">
                <img src="{{ asset.path }}" alt="{{ asset.alt ?: asset.title ?: 'Media' }}" class="h-56 w-full rounded object-cover" />
                {% if asset.title %}
                    <figcaption class="mt-2 text-sm text-slate-700">{{ asset.title }}</figcaption>
                {% endif %}
            </figure>
        {% else %}
            <p class="text-slate-500">No media assets available.</p>
        {% endfor %}
    </div>
</div>
{% endblock %}
