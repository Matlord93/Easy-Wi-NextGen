{% extends 'themes/' ~ (active_theme|default('minimal')) ~ '/base.html.twig' %}

{% set consentCookieName = consent_cookie_name|default(cookie_consent_cookie_name()) %}
{% set consentVersion = consent_version|default(cookie_consent_version()) %}

{% block title %}Cookie-Richtlinie{% endblock %}

{% block content %}
<div class="mx-auto w-full max-w-5xl space-y-6 px-4 py-10 sm:px-6">
    <header class="rounded-2xl border border-slate-800 bg-slate-900/70 p-6">
        <h1 class="text-3xl font-semibold text-slate-100">Cookie-Richtlinie</h1>
        <p class="mt-2 text-sm text-slate-300">
            Hier siehst du transparent, welche Cookies diese Seite nutzt, wofür sie gebraucht werden und wie lange sie gespeichert werden.
            Du kannst deine Auswahl jederzeit ändern.
        </p>
    </header>

    <section class="rounded-2xl border border-slate-800 bg-slate-900/70 p-6">
        <h2 class="text-lg font-semibold text-slate-100">Welche Kategorien gibt es?</h2>
        <div class="mt-4 grid gap-4 md:grid-cols-3">
            <article class="rounded-xl border border-slate-700 bg-slate-900 p-4">
                <h3 class="text-sm font-semibold text-slate-100">Notwendig</h3>
                <p class="mt-2 text-sm text-slate-300">Für Login, Sicherheit, Session-Management und grundlegende Funktionen. Diese Cookies sind immer aktiv.</p>
            </article>
            <article class="rounded-xl border border-slate-700 bg-slate-900 p-4">
                <h3 class="text-sm font-semibold text-slate-100">Statistik (optional)</h3>
                <p class="mt-2 text-sm text-slate-300">Hilft uns zu verstehen, wie die Seite genutzt wird, damit wir Struktur, Inhalte und Performance verbessern können.</p>
            </article>
            <article class="rounded-xl border border-slate-700 bg-slate-900 p-4">
                <h3 class="text-sm font-semibold text-slate-100">Marketing (optional)</h3>
                <p class="mt-2 text-sm text-slate-300">Ermöglicht externe Inhalte und Kampagnenfunktionen. Wird nur gesetzt, wenn du zustimmst.</p>
            </article>
        </div>
    </section>

    <section class="rounded-2xl border border-slate-800 bg-slate-900/70 p-6">
        <h2 class="text-lg font-semibold text-slate-100">Deine aktuelle Auswahl</h2>
        <ul class="mt-4 space-y-2 text-sm text-slate-300">
            <li>Notwendig: <span class="font-semibold text-emerald-300">Immer aktiv</span></li>
            <li>Statistik: <span class="font-semibold {{ cookie_has_consent('statistics') ? 'text-emerald-300' : 'text-amber-300' }}">{{ cookie_has_consent('statistics') ? 'Aktiv' : 'Nicht aktiv' }}</span></li>
            <li>Marketing: <span class="font-semibold {{ cookie_has_consent('marketing') ? 'text-emerald-300' : 'text-amber-300' }}">{{ cookie_has_consent('marketing') ? 'Aktiv' : 'Nicht aktiv' }}</span></li>
        </ul>
        <p class="mt-3 text-xs text-slate-400">
            Gespeichert wird deine Auswahl im Cookie <code class="rounded bg-slate-800 px-1 py-0.5">{{ consentCookieName }}</code>
            mit Version <code class="rounded bg-slate-800 px-1 py-0.5">{{ consentVersion }}</code>.
        </p>
    </section>

    <section class="rounded-2xl border border-slate-800 bg-slate-900/70 p-6">
        <h2 class="text-lg font-semibold text-slate-100">Cookie-Liste</h2>
        <div class="mt-4 overflow-x-auto">
            <table class="min-w-full text-sm text-slate-200">
                <thead class="bg-slate-800 text-left text-slate-200">
                    <tr>
                        <th class="px-4 py-2">Name</th>
                        <th class="px-4 py-2">Zweck</th>
                        <th class="px-4 py-2">Kategorie</th>
                        <th class="px-4 py-2">Laufzeit</th>
                        <th class="px-4 py-2">Provider</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-700">
                    {% for cookie in cookies %}
                        <tr>
                            <td class="px-4 py-2 font-mono text-xs">{{ cookie.name }}</td>
                            <td class="px-4 py-2">{{ cookie.purpose }}</td>
                            <td class="px-4 py-2">{{ cookie.category|capitalize }}</td>
                            <td class="px-4 py-2">{{ cookie.duration }}</td>
                            <td class="px-4 py-2">{{ cookie.provider }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </section>
</div>
{% endblock %}
