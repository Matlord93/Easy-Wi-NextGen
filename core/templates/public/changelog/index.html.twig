{% extends 'themes/' ~ (active_theme|default('minimal')) ~ '/base.html.twig' %}

{% block title %}{{ t('changelog', page_locale()) }} · {{ app_setting('site_title', 'Easy-Wi NextGen') }}{% endblock %}

{% block content %}
<div class="ng-page-hero">
    <div class="ng-container">
        <nav class="ng-breadcrumb">
            <a href="/">Home</a>
            <span>{{ t('changelog', page_locale()) }}</span>
        </nav>
        <h1 class="text-3xl font-bold ng-gradient-text">{{ t('changelog', page_locale()) }}</h1>
        <p class="mt-2 text-sm text-slate-400">{{ t('changelog_description', page_locale()) }}</p>
    </div>
</div>

<div class="ng-container ng-section">
    {% if repository %}
        <div class="mb-6 rounded-lg border border-slate-800 bg-slate-900/60 px-4 py-3 text-sm text-slate-400">
            {{ t('pulling_releases_from', page_locale()) }}
            <span class="font-semibold text-slate-300">{{ repository }}</span>
        </div>
    {% endif %}

    <div class="space-y-4">
        {% for entry in entries %}
            <div class="rounded-xl border border-slate-800 bg-slate-900/60 p-5 transition hover:border-slate-700">
                <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
                    <div>
                        <h2 class="text-lg font-semibold text-slate-100">{{ entry.title }}</h2>
                        <p class="text-xs uppercase tracking-wider text-slate-500">
                            {{ entry.published_at ? entry.published_at|date('d.m.Y') : t('unscheduled', page_locale()) }}
                        </p>
                    </div>
                    <div class="flex items-center gap-2">
                        {% if entry.version %}
                            <span class="rounded-full border border-cyan-500/30 bg-cyan-500/10 px-3 py-0.5 text-xs font-semibold text-cyan-400">{{ entry.version }}</span>
                        {% endif %}
                        <span class="rounded-full border border-slate-700 bg-slate-800/60 px-3 py-0.5 text-xs font-semibold text-slate-400">{{ entry.source|capitalize }}</span>
                    </div>
                </div>
                {% if entry.content %}
                    <div class="mt-3 whitespace-pre-line text-sm text-slate-400">{{ entry.content }}</div>
                {% else %}
                    <p class="mt-3 text-sm text-slate-600">{{ t('no_details_provided', page_locale()) }}</p>
                {% endif %}
            </div>
        {% else %}
            <div class="ng-empty-state">
                <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                <p>{{ t('no_changelog_entries', page_locale()) }}</p>
            </div>
        {% endfor %}
    </div>
</div>
{% endblock %}
