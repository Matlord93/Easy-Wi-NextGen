{% set isNexus = (active_theme|default('minimal')) == 'nexus-gaming' %}
<aside class="rounded-xl border p-4 {% if isNexus %}border-cyan-500/30 bg-slate-950/70 ng-glow{% else %}border-slate-800 bg-slate-900/60{% endif %}">
    <nav class="flex flex-col gap-1 text-sm">
        <a href="/profile" class="rounded-lg px-3 py-2 font-medium transition
            {{ app.request.pathInfo starts with '/profile' and not (app.request.pathInfo starts with '/profile/security') ? (isNexus ? 'bg-cyan-500/20 text-cyan-300 border border-cyan-400/40 shadow-[0_0_24px_rgba(34,211,238,0.2)]' : 'bg-cyan-500/10 text-cyan-400 border border-cyan-500/20') : (isNexus ? 'text-slate-300 hover:bg-slate-800/80 hover:text-cyan-200 border border-transparent hover:border-cyan-500/20' : 'text-slate-400 hover:bg-slate-800 hover:text-slate-200') }}">
            Mein Profil
        </a>
        <a href="/account/security" class="rounded-lg px-3 py-2 font-medium transition
            {{ app.request.pathInfo starts with '/account/security' ? (isNexus ? 'bg-cyan-500/20 text-cyan-300 border border-cyan-400/40 shadow-[0_0_24px_rgba(34,211,238,0.2)]' : 'bg-cyan-500/10 text-cyan-400 border border-cyan-500/20') : (isNexus ? 'text-slate-300 hover:bg-slate-800/80 hover:text-cyan-200 border border-transparent hover:border-cyan-500/20' : 'text-slate-400 hover:bg-slate-800 hover:text-slate-200') }}">
            Sicherheit
        </a>
    </nav>
</aside>
