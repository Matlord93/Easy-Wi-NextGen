{% extends 'admin/base.html.twig' %}

{% block content %}
<div class="flex flex-col gap-6">
    <div class="rounded-2xl border border-slate-200 bg-gradient-to-r from-slate-900 to-indigo-900 px-6 py-7 text-white shadow-sm">
        <h1 class="text-2xl font-semibold">{{ t('user_management_title', page_locale()) }}</h1>
        <p class="mt-2 max-w-2xl text-sm text-slate-100">{{ t('user_management_description', page_locale()) }}</p>
        <div class="mt-4 flex flex-wrap gap-3 text-xs font-medium">
            <span class="rounded-full bg-white/10 px-3 py-1">{{ users|length }} {{ t('users', page_locale())|default('Benutzer') }}</span>
            <span class="rounded-full bg-white/10 px-3 py-1">{{ users|filter(u => u.type == 'customer')|length }} {{ t('user_type_customer', page_locale()) }}</span>
            <span class="rounded-full bg-white/10 px-3 py-1">{{ users|filter(u => u.type in ['admin', 'superadmin'])|length }} Admin</span>
        </div>
    </div>

    {% if errors is not empty %}
        <div class="rounded-xl border border-rose-200 bg-rose-50 px-6 py-4 text-sm text-rose-700">
            <ul class="list-disc space-y-1 pl-5">
                {% for error in errors %}
                    <li>{{ error }}</li>
                {% endfor %}
            </ul>
        </div>
    {% endif %}

    {% if success is not empty %}
        <div class="rounded-xl border border-emerald-200 bg-emerald-50 px-6 py-4 text-sm text-emerald-700">
            <ul class="list-disc space-y-1 pl-5">
                {% for message in success %}
                    <li>{{ message }}</li>
                {% endfor %}
            </ul>
        </div>
    {% endif %}

    {% if canManageUsers %}
        <details class="group rounded-xl border border-slate-200 bg-white p-6 shadow-sm" {{ errors is not empty ? 'open' : '' }}>
            <summary class="flex cursor-pointer list-none items-center justify-between gap-3">
                <div>
                    <h2 class="text-lg font-semibold text-slate-900">{{ t('user_management_create_title', page_locale()) }}</h2>
                    <p class="text-sm text-slate-600">{{ t('user_management_create_intro', page_locale()) }}</p>
                </div>
                <span class="rounded-lg bg-indigo-600 px-4 py-2 text-xs font-semibold text-white">Benutzer/User erstellen</span>
            </summary>

            <form method="post" action="/admin/users" class="mt-6 grid gap-4 md:grid-cols-4">
                <div class="md:col-span-2">
                    <label class="text-xs font-semibold uppercase text-slate-700">{{ t('email', page_locale()) }}</label>
                    <input type="email" name="email" value="{{ createForm.email }}" class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm" required>
                </div>
                <div>
                    <label class="text-xs font-semibold uppercase text-slate-700">{{ t('type', page_locale()) }}</label>
                    <select name="type" class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm">
                        <option value="customer" {{ createForm.type == 'customer' ? 'selected' : '' }}>{{ t('user_type_customer', page_locale()) }}</option>
                        <option value="reseller" {{ createForm.type == 'reseller' ? 'selected' : '' }}>{{ t('user_type_reseller', page_locale()) }}</option>
                        <option value="admin" {{ createForm.type == 'admin' ? 'selected' : '' }}>{{ t('user_type_admin', page_locale()) }}</option>
                    </select>
                </div>
                <div>
                    <label class="text-xs font-semibold uppercase text-slate-700">{{ t('password', page_locale()) }}</label>
                    <input type="password" name="password" class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm" required>
                </div>
                <div class="md:col-span-2">
                    <label class="text-xs font-semibold uppercase text-slate-700">{{ t('password_confirm', page_locale()) }}</label>
                    <input type="password" name="password_confirm" class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm" required>
                </div>
                <div>
                    <label class="text-xs font-semibold uppercase text-slate-700">{{ t('user_database_limit_label', page_locale()) }}</label>
                    <input type="number" min="0" name="database_limit" value="{{ createForm.database_limit }}" class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm">
                </div>
                <div class="md:col-span-2 flex flex-wrap items-center gap-4">
                    <label class="flex items-center gap-2 text-xs text-slate-700">
                        <input type="hidden" name="member_access_enabled" value="0">
                        <input type="checkbox" name="member_access_enabled" value="1" class="h-4 w-4 rounded border-slate-300 text-indigo-600" {{ createForm.member_access_enabled ? 'checked' : '' }}>
                        Member access (ROLE_MEMBER)
                    </label>
                    <label class="flex items-center gap-2 text-xs text-slate-700">
                        <input type="hidden" name="customer_access_enabled" value="0">
                        <input type="checkbox" name="customer_access_enabled" value="1" class="h-4 w-4 rounded border-slate-300 text-indigo-600" {{ createForm.customer_access_enabled ? 'checked' : '' }}>
                        Customer access flag (ROLE_CUSTOMER)
                    </label>
                </div>
                <div class="md:col-span-2 flex items-end justify-end">
                    <button type="submit" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white">{{ t('user_management_create_action', page_locale()) }}</button>
                </div>
            </form>
        </details>
    {% else %}
        <div class="rounded-xl border border-amber-200 bg-amber-50 px-6 py-4 text-sm text-amber-800">
            Nur Superadmins können Kunden/User erstellen oder bearbeiten.
        </div>
    {% endif %}

    {% if canManageSshKeys and pendingSshKeys is not empty %}
        <div class="rounded-xl border border-amber-200 bg-amber-50 p-6 shadow-sm">
            <h2 class="text-lg font-semibold text-amber-900">{{ t('user_management_ssh_pending_title', page_locale()) }}</h2>
            <div class="mt-4 space-y-4">
                {% for pending in pendingSshKeys %}
                    <div class="rounded-lg border border-amber-200 bg-white p-4">
                        <div class="flex flex-wrap items-center justify-between gap-3">
                            <p class="text-sm font-semibold text-slate-900">{{ pending.email }}</p>
                            <div class="flex items-center gap-2">
                                <form method="post" action="/admin/users/{{ pending.id }}/ssh-key/approve">
                                    <button type="submit" class="rounded-lg bg-emerald-600 px-3 py-1.5 text-xs font-semibold text-white">{{ t('user_management_ssh_pending_approve', page_locale()) }}</button>
                                </form>
                                <form method="post" action="/admin/users/{{ pending.id }}/ssh-key/reject">
                                    <button type="submit" class="rounded-lg border border-slate-200 px-3 py-1.5 text-xs font-semibold text-slate-700">{{ t('user_management_ssh_pending_reject', page_locale()) }}</button>
                                </form>
                            </div>
                        </div>
                        <textarea rows="3" class="mt-3 w-full rounded-lg border border-slate-200 bg-slate-50 px-3 py-2 text-xs text-slate-600" readonly>{{ pending.key }}</textarea>
                    </div>
                {% endfor %}
            </div>
        </div>
    {% endif %}

    <div class="rounded-xl border border-slate-200 bg-white shadow-sm">
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-slate-200 text-sm">
                <thead class="bg-slate-50 text-left text-xs font-semibold uppercase tracking-wide text-slate-700">
                    <tr>
                        <th class="px-4 py-3">{{ t('email', page_locale()) }}</th>
                        <th class="px-4 py-3">{{ t('type', page_locale()) }}</th>
                        <th class="px-4 py-3">{{ t('created', page_locale()) }}</th>
                        <th class="px-4 py-3">Status</th>
                        <th class="px-4 py-3">Aktion</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-200">
                    {% for user in users %}
                        <tr class="bg-white">
                            <td class="px-4 py-3 font-medium text-slate-900">{{ user.email }}</td>
                            <td class="px-4 py-3 text-xs uppercase text-slate-700">{{ user.type }}</td>
                            <td class="px-4 py-3 text-xs text-slate-700">{{ user.created_at|date('Y-m-d H:i') }}</td>
                            <td class="px-4 py-3 text-xs text-slate-600">
                                {% if user.type in ['admin', 'superadmin'] %}
                                    {{ user.ssh_key_set ? t('user_management_ssh_key_present', page_locale()) : t('user_management_ssh_key_missing', page_locale()) }}
                                {% else %}
                                    {{ t('portal_language', page_locale()) }}: {{ user.portal_language|upper }}
                                {% endif %}
                            </td>
                            <td class="px-4 py-3">
                                {% if canManageUsers %}
                                    <details>
                                        <summary class="cursor-pointer rounded-lg border border-slate-200 px-3 py-1.5 text-xs font-semibold text-slate-700">Kunde/User bearbeiten</summary>
                                        <form method="post" action="/admin/users/{{ user.id }}/details" class="mt-3 grid gap-3 rounded-lg border border-slate-200 bg-slate-50 p-4 md:grid-cols-6">
                                            <div class="md:col-span-2">
                                                <label class="text-xs font-semibold uppercase text-slate-700">{{ t('email', page_locale()) }}</label>
                                                <input type="email" name="email" value="{{ user.email }}" class="mt-1 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm">
                                            </div>
                                            <div>
                                                <label class="text-xs font-semibold uppercase text-slate-700">{{ t('type', page_locale()) }}</label>
                                                <select name="type" class="mt-1 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm">
                                                    <option value="customer" {{ user.type == 'customer' ? 'selected' : '' }}>{{ t('user_type_customer', page_locale()) }}</option>
                                                    <option value="reseller" {{ user.type == 'reseller' ? 'selected' : '' }}>{{ t('user_type_reseller', page_locale()) }}</option>
                                                    <option value="admin" {{ user.type == 'admin' ? 'selected' : '' }}>{{ t('user_type_admin', page_locale()) }}</option>
                                                </select>
                                            </div>
                                            <div>
                                                <label class="text-xs font-semibold uppercase text-slate-700">{{ t('new_password', page_locale()) }}</label>
                                                <input type="password" name="password" class="mt-1 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm">
                                            </div>
                                            <div>
                                                <label class="text-xs font-semibold uppercase text-slate-700">{{ t('password_confirm', page_locale()) }}</label>
                                                <input type="password" name="password_confirm" class="mt-1 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm">
                                            </div>
                                            <div>
                                                <label class="text-xs font-semibold uppercase text-slate-700">{{ t('user_database_limit_label', page_locale()) }}</label>
                                                <input type="number" min="0" name="database_limit" value="{{ user.database_limit }}" class="mt-1 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm" {{ user.type != 'customer' ? 'disabled' : '' }}>
                                            </div>
                                            <div class="md:col-span-4 flex flex-wrap items-center gap-4">
                                                <label class="flex items-center gap-2 text-xs text-slate-700">
                                                    <input type="hidden" name="member_access_enabled" value="0">
                                                    <input type="checkbox" name="member_access_enabled" value="1" class="h-4 w-4 rounded border-slate-300 text-indigo-600" {{ user.member_access_enabled ? 'checked' : '' }}>
                                                    Member access
                                                </label>
                                                <label class="flex items-center gap-2 text-xs text-slate-700">
                                                    <input type="hidden" name="customer_access_enabled" value="0">
                                                    <input type="checkbox" name="customer_access_enabled" value="1" class="h-4 w-4 rounded border-slate-300 text-indigo-600" {{ user.customer_access_enabled ? 'checked' : '' }}>
                                                    Customer access
                                                </label>
                                            </div>
                                            <div class="md:col-span-2 flex items-end justify-end gap-2">
                                                <button type="submit" class="rounded-lg bg-slate-900 px-4 py-2 text-xs font-semibold text-white">{{ t('user_management_update_action', page_locale()) }}</button>
                                                {% if canImpersonate and user.type == 'customer' %}
                                                    <button type="submit" formaction="/admin/users/{{ user.id }}/impersonate" formmethod="post" formtarget="_blank" class="rounded-lg bg-indigo-600 px-4 py-2 text-xs font-semibold text-white">{{ t('user_management_impersonate_action', page_locale()) }}</button>
                                                {% endif %}
                                            </div>
                                        </form>

                                        <form method="post" action="/admin/users/{{ user.id }}/preferences" class="mt-3 flex flex-wrap items-end gap-2 rounded-lg border border-slate-200 bg-white p-4">
                                            <div>
                                                <label class="text-xs font-semibold uppercase text-slate-700">{{ t('portal_language', page_locale()) }}</label>
                                                <select name="portal_language" class="mt-1 rounded-lg border border-slate-200 bg-white px-2 py-1 text-xs">
                                                    {% for code, label in portalLanguages %}
                                                        <option value="{{ code }}" {{ user.portal_language == code ? 'selected' : '' }}>{{ label }}</option>
                                                    {% endfor %}
                                                </select>
                                            </div>
                                            <div>
                                                <label class="text-xs font-semibold uppercase text-slate-700">{{ t('invoice_locale', page_locale()) }}</label>
                                                <select name="locale" class="mt-1 rounded-lg border border-slate-200 bg-white px-2 py-1 text-xs">
                                                    {% for code, label in locales %}
                                                        <option value="{{ code }}" {{ user.locale == code ? 'selected' : '' }}>{{ label }}</option>
                                                    {% endfor %}
                                                </select>
                                            </div>
                                            <button type="submit" class="rounded-lg bg-indigo-600 px-3 py-1 text-xs font-semibold text-white">{{ t('save', page_locale()) }}</button>
                                        </form>
                                    </details>
                                {% else %}
                                    <span class="text-xs text-slate-500">Nur Ansicht</span>
                                {% endif %}
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="5" class="px-4 py-6 text-center text-sm text-slate-600">{{ t('no_users_found', page_locale()) }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
