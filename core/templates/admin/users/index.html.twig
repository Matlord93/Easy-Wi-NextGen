{% extends 'admin/base.html.twig' %}

{% set pageTitle = t('user_management_title', page_locale()) %}
{% set pageSubtitle = t('user_management_description', page_locale()) %}
{% set activeNav = 'users' %}
{% set locale = page_locale() %}

{% block content %}
<div style="display:flex;flex-direction:column;gap:20px;">

    {# ── Flash Messages ── #}
    {% if errors is not empty %}
        <div class="ng-alert ng-alert--danger">
            <ul style="margin:0;padding-left:18px;">{% for error in errors %}<li>{{ error }}</li>{% endfor %}</ul>
        </div>
    {% endif %}
    {% if success is not empty %}
        <div class="ng-alert ng-alert--success">
            <ul style="margin:0;padding-left:18px;">{% for message in success %}<li>{{ message }}</li>{% endfor %}</ul>
        </div>
    {% endif %}

    {# ── Hero with KPI ── #}
    <section class="ng-card" style="overflow:hidden;">
        <div class="tkt-hero" style="background:linear-gradient(135deg,#07101f 0%,#0f1f3d 50%,#0a1220 100%);">
            <div class="tkt-hero__inner">
                <div style="display:flex;flex-direction:column;gap:16px;">
                    <div>
                        <div class="tkt-hero__pill">
                            <span class="tkt-hero__pill-dot" style="background:#60a5fa;"></span>
                            {{ t('admin_users_workbench_label', locale) }}
                        </div>
                        <h1 class="tkt-hero__title" style="margin-top:10px;">{{ t('user_management_title', locale) }}</h1>
                        <p class="tkt-hero__sub">{{ t('admin_users_workbench_intro', locale) }}</p>
                    </div>
                    <div style="display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:10px;">
                        <div class="tkt-kpi">
                            <div class="tkt-kpi__label">{{ t('users', locale) }}</div>
                            <div class="tkt-kpi__value">{{ users|length }}</div>
                        </div>
                        <div class="tkt-kpi" style="border-color:rgba(96,165,250,.25);background:rgba(96,165,250,.07);">
                            <div class="tkt-kpi__label" style="color:rgba(147,197,253,.7);">{{ t('user_type_customer', locale) }}</div>
                            <div class="tkt-kpi__value" style="color:#93c5fd;">{{ users|filter(u => u.type == 'customer')|length }}</div>
                        </div>
                        <div class="tkt-kpi" style="border-color:rgba(252,211,77,.25);background:rgba(252,211,77,.07);">
                            <div class="tkt-kpi__label" style="color:rgba(252,211,77,.7);">{{ t('user_type_reseller_plural', locale) }}</div>
                            <div class="tkt-kpi__value" style="color:#fcd34d;">{{ users|filter(u => u.type == 'reseller')|length }}</div>
                        </div>
                        <div class="tkt-kpi" style="border-color:rgba(196,181,253,.25);background:rgba(196,181,253,.07);">
                            <div class="tkt-kpi__label" style="color:rgba(196,181,253,.7);">{{ t('user_type_admin_plural', locale) }}</div>
                            <div class="tkt-kpi__value" style="color:#c4b5fd;">{{ users|filter(u => u.type in ['admin', 'superadmin'])|length }}</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        {# ── Action bar ── #}
        <div style="display:grid;grid-template-columns:1.2fr .8fr;gap:12px;padding:16px;border-top:1px solid var(--ng-border);background:var(--ng-surface-soft);">
            {% if canManageUsers %}
                <button type="button" class="tkt-oldest" onclick="document.getElementById('create-user-section').classList.toggle('hidden')">
                    <div style="display:flex;align-items:center;gap:14px;min-width:0;">
                        <div class="tkt-oldest__icon">
                            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
                        </div>
                        <div style="min-width:0;">
                            <div class="tkt-oldest__label">{{ t('admin_users_quick_create_title', locale) }}</div>
                            <div class="tkt-oldest__subject">{{ t('admin_users_quick_create_sub', locale) }}</div>
                        </div>
                    </div>
                    <div class="tkt-oldest__btn">
                        {{ t('user_management_create_action', locale) }}
                        <svg style="width:14px;height:14px;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
                    </div>
                </button>
            {% else %}
                <div class="tkt-all-clear">
                    <div class="tkt-all-clear__icon">
                        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
                    </div>
                    <div>
                        <p style="margin:0;font-size:14px;font-weight:700;color:var(--ng-text);">{{ t('admin_users_restricted_title', locale) }}</p>
                        <p style="margin:3px 0 0;font-size:12px;color:var(--ng-text-muted);">{{ t('user_management_superadmin_only', locale) }}</p>
                    </div>
                </div>
            {% endif %}
            <div style="display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:10px;">
                <button type="button" class="tkt-qa" onclick="document.getElementById('ssh-pending-section') && document.getElementById('ssh-pending-section').scrollIntoView({behavior:'smooth'})">
                    <div class="tkt-qa__icon" style="position:relative;">
                        🔑
                        {% if canManageSshKeys and pendingSshKeys is not empty %}
                            <span style="position:absolute;top:-6px;right:-6px;background:#f59e0b;color:#000;border-radius:999px;font-size:9px;font-weight:700;padding:1px 5px;line-height:1.4;">{{ pendingSshKeys|length }}</span>
                        {% endif %}
                    </div>
                    <div class="tkt-qa__title">{{ t('user_management_ssh_pending_title', locale) }}</div>
                    <div class="tkt-qa__sub">{{ canManageSshKeys and pendingSshKeys is not empty ? pendingSshKeys|length ~ ' ' ~ t('pending', locale) : t('admin_users_ssh_none_pending', locale) }}</div>
                </button>
                <button type="button" class="tkt-qa" onclick="document.getElementById('user-search').focus()">
                    <div class="tkt-qa__icon" style="background:var(--ng-surface);color:var(--ng-text-muted);">⌕</div>
                    <div class="tkt-qa__title">{{ t('admin_users_filter_search', locale) }}</div>
                    <div class="tkt-qa__sub">{{ t('admin_users_filter_search_hint', locale) }}</div>
                </button>
            </div>
        </div>
    </section>

    {# ── Create User (collapsible) ── #}
    <section id="create-user-section" class="ng-card hidden" style="overflow:hidden;">
        <div class="tkt-filter-bar">
            <div class="tkt-filter-bar__top">
                <div>
                    <h2 class="tkt-filter-bar__title">{{ t('admin_users_quick_create_title', locale) }}</h2>
                    <p class="tkt-filter-bar__sub">{{ t('admin_users_quick_create_sub', locale) }}</p>
                </div>
                <button type="button" class="ui-button ui-button--ghost ui-button--sm" onclick="document.getElementById('create-user-section').classList.add('hidden')">{{ t('cancel', locale) }}</button>
            </div>
        </div>
        <form method="post" action="/admin/users" style="padding:16px 20px 20px;">
            <div style="display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:12px;">
                <div class="form-field" style="grid-column:1/3;">
                    <label class="form-label">{{ t('email', locale) }}</label>
                    <input type="email" name="email" value="{{ createForm.email }}" class="form-input" required placeholder="user@example.com">
                </div>
                <div class="form-field">
                    <label class="form-label">{{ t('type', locale) }}</label>
                    <select name="type" class="form-input">
                        <option value="customer" {{ createForm.type == 'customer' ? 'selected' : '' }}>{{ t('user_type_customer', locale) }}</option>
                        <option value="reseller" {{ createForm.type == 'reseller' ? 'selected' : '' }}>{{ t('user_type_reseller', locale) }}</option>
                        <option value="admin"    {{ createForm.type == 'admin'    ? 'selected' : '' }}>{{ t('user_type_admin', locale) }}</option>
                    </select>
                </div>
                <div class="form-field">
                    <label class="form-label">{{ t('user_database_limit_label', locale) }}</label>
                    <input type="number" min="0" name="database_limit" value="{{ createForm.database_limit }}" class="form-input">
                </div>
                <div class="form-field">
                    <label class="form-label">{{ t('password', locale) }}</label>
                    <input type="password" name="password" class="form-input" required>
                </div>
                <div class="form-field">
                    <label class="form-label">{{ t('password_confirm', locale) }}</label>
                    <input type="password" name="password_confirm" class="form-input" required>
                </div>
                <div class="form-field" style="grid-column:3/5;display:flex;flex-direction:row;align-items:center;gap:20px;flex-wrap:wrap;padding-top:20px;">
                    <label style="display:flex;align-items:center;gap:8px;font-size:13px;color:var(--ng-text-muted);font-weight:500;cursor:pointer;">
                        <input type="hidden" name="member_access_enabled" value="0">
                        <input type="checkbox" name="member_access_enabled" value="1" style="accent-color:var(--ng-primary);width:15px;height:15px;" {{ createForm.member_access_enabled ? 'checked' : '' }}>
                        {{ t('user_member_access_label', locale) }}
                    </label>
                    <label style="display:flex;align-items:center;gap:8px;font-size:13px;color:var(--ng-text-muted);font-weight:500;cursor:pointer;">
                        <input type="hidden" name="customer_access_enabled" value="0">
                        <input type="checkbox" name="customer_access_enabled" value="1" style="accent-color:var(--ng-primary);width:15px;height:15px;" {{ createForm.customer_access_enabled ? 'checked' : '' }}>
                        {{ t('user_customer_access_label', locale) }}
                    </label>
                </div>
            </div>
            <div style="margin-top:16px;display:flex;justify-content:flex-end;gap:8px;">
                <button type="button" class="ui-button ui-button--ghost" onclick="document.getElementById('create-user-section').classList.add('hidden')">{{ t('cancel', locale) }}</button>
                <button type="submit" class="ui-button ui-button--primary">{{ t('user_management_create_action', locale) }}</button>
            </div>
        </form>
    </section>

    {# ── Pending SSH Keys ── #}
    {% if canManageSshKeys and pendingSshKeys is not empty %}
        <section id="ssh-pending-section" class="ng-card" style="overflow:hidden;">
            <div class="tkt-filter-bar">
                <div class="tkt-filter-bar__top">
                    <div>
                        <h2 class="tkt-filter-bar__title">{{ t('user_management_ssh_pending_title', locale) }}</h2>
                        <p class="tkt-filter-bar__sub">{{ pendingSshKeys|length }} {{ t('pending', locale) }}</p>
                    </div>
                    <span class="ui-badge ui-badge--warning">{{ pendingSshKeys|length }} {{ t('pending', locale) }}</span>
                </div>
            </div>
            <div style="padding:16px 20px 20px;display:flex;flex-direction:column;gap:12px;">
                {% for pending in pendingSshKeys %}
                    <div style="border:1px solid var(--ng-border);border-radius:10px;padding:14px;background:var(--ng-surface-soft);">
                        <div style="display:flex;flex-wrap:wrap;align-items:center;justify-content:space-between;gap:12px;">
                            <p style="font-size:13px;font-weight:600;color:var(--ng-text);margin:0;">{{ pending.email }}</p>
                            <div style="display:flex;gap:8px;">
                                <form method="post" action="/admin/users/{{ pending.id }}/ssh-key/approve">
                                    <button type="submit" class="ui-button ui-button--sm" style="background:rgba(34,197,94,0.15);color:#4ade80;border-color:rgba(34,197,94,0.35);">{{ t('user_management_ssh_pending_approve', locale) }}</button>
                                </form>
                                <form method="post" action="/admin/users/{{ pending.id }}/ssh-key/reject">
                                    <button type="submit" class="ui-button ui-button--ghost ui-button--sm">{{ t('user_management_ssh_pending_reject', locale) }}</button>
                                </form>
                            </div>
                        </div>
                        <textarea rows="2" style="margin-top:10px;width:100%;font-size:11px;font-family:monospace;background:var(--ng-elevated);border-color:var(--ng-border);border-radius:8px;padding:8px;color:var(--ng-text-muted);box-sizing:border-box;" readonly>{{ pending.key }}</textarea>
                    </div>
                {% endfor %}
            </div>
        </section>
    {% endif %}

    {# ── Users Table ── #}
    <section class="ng-card" style="overflow:hidden;">
        <div class="tkt-filter-bar">
            <div class="tkt-filter-bar__top">
                <div>
                    <h2 class="tkt-filter-bar__title">{{ t('user_management_all_users', locale) }}</h2>
                    <p class="tkt-filter-bar__sub">{{ t('user_management_subtitle', locale) }}</p>
                </div>
            </div>
            <div style="display:flex;gap:8px;align-items:flex-end;flex-wrap:wrap;">
                <div class="form-field" style="flex:1;min-width:200px;">
                    <label class="form-label">{{ t('admin_users_filter_search', locale) }}</label>
                    <input id="user-search" type="text" class="form-input" placeholder="{{ t('admin_users_filter_search_placeholder', locale) }}" oninput="filterUsers()">
                </div>
                <div class="form-field" style="min-width:150px;">
                    <label class="form-label">{{ t('type', locale) }}</label>
                    <select id="user-type-filter" class="form-input" onchange="filterUsers()">
                        <option value="">{{ t('admin_users_filter_all_types', locale) }}</option>
                        <option value="customer">{{ t('user_type_customer', locale) }}</option>
                        <option value="reseller">{{ t('user_type_reseller', locale) }}</option>
                        <option value="admin">{{ t('user_type_admin', locale) }}</option>
                        <option value="superadmin">Superadmin</option>
                    </select>
                </div>
                <button type="button" class="ui-button ui-button--ghost" onclick="document.getElementById('user-search').value='';document.getElementById('user-type-filter').value='';filterUsers();">{{ t('admin_users_filter_reset', locale) }}</button>
            </div>
        </div>
        <div class="cust-ws-table-wrap">
            <table class="cust-table">
                <thead>
                    <tr>
                        <th>{{ t('email', locale) }}</th>
                        <th>{{ t('type', locale) }}</th>
                        <th>{{ t('created', locale) }}</th>
                        <th>{{ t('status', locale) }}</th>
                        {% if canManageUsers %}<th>{{ t('actions', locale) }}</th>{% endif %}
                    </tr>
                </thead>
                <tbody id="users-tbody">
                    {% for user in users %}
                        <tr data-email="{{ user.email|lower }}" data-type="{{ user.type }}">
                            <td>
                                <div style="font-weight:600;color:var(--ng-text);">{{ user.email }}</div>
                            </td>
                            <td>
                                {% if user.type == 'superadmin' %}
                                    <span class="ui-badge ui-badge--danger">{{ user.type }}</span>
                                {% elseif user.type == 'admin' %}
                                    <span class="ui-badge ui-badge--primary">{{ user.type }}</span>
                                {% elseif user.type == 'reseller' %}
                                    <span class="ui-badge ui-badge--warning">{{ user.type }}</span>
                                {% else %}
                                    <span class="ui-badge ui-badge--neutral">{{ user.type }}</span>
                                {% endif %}
                            </td>
                            <td style="color:var(--ng-text-muted);font-size:12px;">{{ user.created_at|date('d.m.Y H:i') }}</td>
                            <td style="font-size:12px;color:var(--ng-text-muted);">
                                {% if user.type in ['admin', 'superadmin'] %}
                                    {% if user.ssh_key_set %}
                                        <span class="ui-badge ui-badge--success" style="font-size:10px;">{{ t('user_ssh_key_set', locale) }}</span>
                                    {% else %}
                                        <span class="ui-badge ui-badge--warning" style="font-size:10px;">{{ t('user_no_ssh_key', locale) }}</span>
                                    {% endif %}
                                {% else %}
                                    {{ t('portal_language', locale) }}: <strong>{{ user.portal_language|upper }}</strong>
                                {% endif %}
                            </td>
                            {% if canManageUsers %}
                            <td>
                                <details class="ng-overflow">
                                    <summary class="ng-overflow__trigger">
                                        <span class="ng-overflow__dots"></span>
                                    </summary>
                                    <div class="ng-overflow__menu" style="min-width:340px;right:0;padding:14px;display:flex;flex-direction:column;gap:12px;">
                                        <form method="post" action="/admin/users/{{ user.id }}/details" style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
                                            <div class="form-field" style="grid-column:1/-1;">
                                                <label class="form-label">{{ t('email', locale) }}</label>
                                                <input type="email" name="email" value="{{ user.email }}" class="form-input">
                                            </div>
                                            <div class="form-field">
                                                <label class="form-label">{{ t('type', locale) }}</label>
                                                <select name="type" class="form-input">
                                                    <option value="customer" {{ user.type == 'customer' ? 'selected' : '' }}>{{ t('user_type_customer', locale) }}</option>
                                                    <option value="reseller" {{ user.type == 'reseller' ? 'selected' : '' }}>{{ t('user_type_reseller', locale) }}</option>
                                                    <option value="admin"    {{ user.type == 'admin'    ? 'selected' : '' }}>{{ t('user_type_admin', locale) }}</option>
                                                </select>
                                            </div>
                                            <div class="form-field">
                                                <label class="form-label">{{ t('user_database_limit_label', locale) }}</label>
                                                <input type="number" min="0" name="database_limit" value="{{ user.database_limit }}" class="form-input" {{ user.type != 'customer' ? 'disabled' : '' }}>
                                            </div>
                                            <div class="form-field">
                                                <label class="form-label">{{ t('new_password', locale) }}</label>
                                                <input type="password" name="password" class="form-input">
                                            </div>
                                            <div class="form-field">
                                                <label class="form-label">{{ t('password_confirm', locale) }}</label>
                                                <input type="password" name="password_confirm" class="form-input">
                                            </div>
                                            <div style="grid-column:1/-1;display:flex;flex-wrap:wrap;gap:12px;align-items:center;">
                                                <label style="display:flex;align-items:center;gap:6px;font-size:12px;color:var(--ng-text-muted);cursor:pointer;">
                                                    <input type="hidden" name="member_access_enabled" value="0">
                                                    <input type="checkbox" name="member_access_enabled" value="1" style="accent-color:var(--ng-primary);" {{ user.member_access_enabled ? 'checked' : '' }}>
                                                    {{ t('user_member_access_label', locale) }}
                                                </label>
                                                <label style="display:flex;align-items:center;gap:6px;font-size:12px;color:var(--ng-text-muted);cursor:pointer;">
                                                    <input type="hidden" name="customer_access_enabled" value="0">
                                                    <input type="checkbox" name="customer_access_enabled" value="1" style="accent-color:var(--ng-primary);" {{ user.customer_access_enabled ? 'checked' : '' }}>
                                                    {{ t('user_customer_access_label', locale) }}
                                                </label>
                                            </div>
                                            <div style="grid-column:1/-1;display:flex;gap:8px;justify-content:flex-end;flex-wrap:wrap;">
                                                <button type="submit" class="ui-button ui-button--ghost ui-button--sm">{{ t('user_management_update_action', locale) }}</button>
                                                {% if canImpersonate and user.type == 'customer' %}
                                                    <button type="submit" formaction="/admin/users/{{ user.id }}/impersonate" formmethod="post" formtarget="_blank" class="ui-button ui-button--primary ui-button--sm">{{ t('user_management_impersonate_action', locale) }}</button>
                                                {% endif %}
                                            </div>
                                        </form>

                                        <form method="post" action="/admin/users/{{ user.id }}/preferences" style="display:flex;flex-wrap:wrap;gap:8px;align-items:flex-end;padding-top:10px;border-top:1px solid var(--ng-border);">
                                            <div class="form-field" style="min-width:120px;">
                                                <label class="form-label">{{ t('portal_language', locale) }}</label>
                                                <select name="portal_language" class="form-input form-input--slim">
                                                    {% for code, label in portalLanguages %}
                                                        <option value="{{ code }}" {{ user.portal_language == code ? 'selected' : '' }}>{{ label }}</option>
                                                    {% endfor %}
                                                </select>
                                            </div>
                                            <div class="form-field" style="min-width:120px;">
                                                <label class="form-label">{{ t('invoice_locale', locale) }}</label>
                                                <select name="locale" class="form-input form-input--slim">
                                                    {% for code, label in locales %}
                                                        <option value="{{ code }}" {{ user.locale == code ? 'selected' : '' }}>{{ label }}</option>
                                                    {% endfor %}
                                                </select>
                                            </div>
                                            <button type="submit" class="ui-button ui-button--primary ui-button--sm">{{ t('save', locale) }}</button>
                                        </form>
                                    </div>
                                </details>
                            </td>
                            {% endif %}
                        </tr>
                    {% endfor %}
                    <tr id="no-users-row"{% if users is not empty %} style="display:none;"{% endif %}>
                        <td colspan="5" style="text-align:center;padding:40px;color:var(--ng-text-muted);">{{ t('no_users_found', locale) }}</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </section>

</div>

<script>
function filterUsers() {
    var search = document.getElementById('user-search').value.toLowerCase();
    var typeFilter = document.getElementById('user-type-filter').value.toLowerCase();
    var rows = document.querySelectorAll('#users-tbody tr[data-email]');
    var visible = 0;
    rows.forEach(function(row) {
        var email = (row.getAttribute('data-email') || '').toLowerCase();
        var type = (row.getAttribute('data-type') || '').toLowerCase();
        var matchSearch = !search || email.indexOf(search) !== -1;
        var matchType = !typeFilter || type === typeFilter;
        if (matchSearch && matchType) {
            row.style.display = '';
            visible++;
        } else {
            row.style.display = 'none';
        }
    });
    var emptyRow = document.getElementById('no-users-row');
    if (emptyRow) {
        emptyRow.style.display = visible === 0 ? '' : 'none';
    }
}
</script>
{% endblock %}
