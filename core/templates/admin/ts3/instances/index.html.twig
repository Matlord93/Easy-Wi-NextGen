{% extends 'admin/base.html.twig' %}

{% set pageTitle = t('admin_ts3_heading', page_locale()) %}
{% set pageSubtitle = t('admin_ts3_intro', page_locale()) %}
{% set activeNav = 'ts3-instances' %}

{% block content %}
{% set locale = page_locale() %}
<div style="display:flex;flex-direction:column;gap:20px;">

    <section class="ng-card" style="overflow:hidden;">
        <div class="tkt-hero">
            <div class="tkt-hero__inner">
                <div style="display:flex;flex-direction:column;gap:16px;">
                    <div>
                        <div class="tkt-hero__pill">
                            <span class="tkt-hero__pill-dot"></span>
                            TeamSpeak 3
                        </div>
                        <h1 class="tkt-hero__title" style="margin-top:10px;">{{ t('admin_ts3_heading', locale) }}</h1>
                        <p class="tkt-hero__sub">{{ t('admin_ts3_intro', locale) }}</p>
                    </div>
                    <div style="display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:10px;">
                        <div class="tkt-kpi tkt-kpi--open">
                            <div class="tkt-kpi__label">{{ t('admin_ts3_total_instances', locale) }}</div>
                            <div class="tkt-kpi__value">{{ summary.total }}</div>
                        </div>
                        <div class="tkt-kpi tkt-kpi--resolved">
                            <div class="tkt-kpi__label">{{ t('admin_ts3_running', locale) }}</div>
                            <div class="tkt-kpi__value">{{ summary.running }}</div>
                        </div>
                        <div class="tkt-kpi tkt-kpi--pending">
                            <div class="tkt-kpi__label">{{ t('admin_ts3_stopped', locale) }}</div>
                            <div class="tkt-kpi__value">{{ summary.stopped }}</div>
                        </div>
                        <div class="tkt-kpi tkt-kpi--open">
                            <div class="tkt-kpi__label">{{ t('admin_ts3_needs_attention', locale) }}</div>
                            <div class="tkt-kpi__value">{{ summary.error }}</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <div id="ts3-instances-table"
         hx-get="/admin/ts3/instances/table"
         hx-trigger="ts3-instances-changed from:body"
         hx-swap="outerHTML">
        <div class="ng-data-card">
            <div class="ng-data-card__header">
                <div>
                    <h2 class="ng-data-card__title">{{ t('admin_ts3_heading', locale) }}</h2>
                    <p class="ng-data-card__sub">{{ t('admin_ts3_intro', locale) }}</p>
                </div>
                <div class="ng-data-card__actions">
                    <button
                        class="ui-button ui-button--ghost ui-button--sm"
                        hx-get="/admin/ts3/instances/table"
                        hx-target="#ts3-instances-table"
                        hx-swap="outerHTML"
                    >{{ t('refresh', locale) }}</button>
                    <a class="ui-button ui-button--primary ui-button--sm" href="/admin/ts3/instances/new">{{ t('admin_ts3_new_instance', locale) }}</a>
                </div>
            </div>
            <div class="ng-data-card__body ng-data-card__body--flush">
                {% include 'admin/ts3/instances/_table.html.twig' with { instances: instances } %}
            </div>
        </div>
    </div>

</div>
{% endblock %}
