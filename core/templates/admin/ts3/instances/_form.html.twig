<form hx-post="{{ form.action_url }}"
      hx-target="#ts3-instance-form"
      hx-swap="outerHTML">
    <div class="ng-data-card__body ng-data-card__body--flush">
        <div style="padding:20px;display:flex;flex-direction:column;gap:16px;">

            {% if form.errors is not empty %}
                <div class="ng-alert ng-alert--danger">
                    <ul style="margin:0;padding-left:20px;">
                        {% for error in form.errors %}
                            <li>{{ error }}</li>
                        {% endfor %}
                    </ul>
                </div>
            {% endif %}

            <div class="form-field">
                <label class="form-label">{{ t('admin_ts3_customer_label', page_locale()) }}</label>
                <select name="customer_id" class="form-input">
                    <option value="">{{ t('admin_ts3_customer_select', page_locale()) }}</option>
                    {% for customer in customers %}
                        <option value="{{ customer.id }}" {{ customer.id == form.customer_id ? 'selected' : '' }}>{{ customer.email }}</option>
                    {% endfor %}
                </select>
            </div>

            <div class="form-field">
                <label class="form-label">{{ t('admin_ts3_node_label', page_locale()) }}</label>
                <select name="node_id" class="form-input">
                    <option value="">{{ t('admin_ts3_node_select', page_locale()) }}</option>
                    {% for node in nodes %}
                        <option value="{{ node.id }}" {{ node.id == form.node_id ? 'selected' : '' }}>{{ node.name ?? node.id }}</option>
                    {% endfor %}
                </select>
            </div>

            <div class="form-field">
                <label class="form-label">{{ t('admin_ts3_instance_name_label', page_locale()) }}</label>
                <input name="name" value="{{ form.name }}" class="form-input" placeholder="TS3 - EU Central">
            </div>

            <div style="display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:16px;">
                <div class="form-field">
                    <label class="form-label">{{ t('admin_ts3_voice_port', page_locale()) }}</label>
                    <input name="voice_port" value="{{ form.voice_port }}" class="form-input" placeholder="9987">
                </div>
                <div class="form-field">
                    <label class="form-label">{{ t('admin_ts3_query_port', page_locale()) }}</label>
                    <input name="query_port" value="{{ form.query_port }}" class="form-input" placeholder="10011">
                </div>
                <div class="form-field">
                    <label class="form-label">{{ t('admin_ts3_file_port', page_locale()) }}</label>
                    <input name="file_port" value="{{ form.file_port }}" class="form-input" placeholder="30033">
                </div>
            </div>

            <div style="display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:16px;">
                <div class="form-field">
                    <label class="form-label">{{ t('admin_ts3_db_mode', page_locale()) }}</label>
                    <select name="db_mode" class="form-input">
                        <option value="sqlite" {{ form.db_mode == 'sqlite' ? 'selected' : '' }}>{{ t('admin_ts3_db_mode_sqlite', page_locale()) }}</option>
                        <option value="mysql" {{ form.db_mode == 'mysql' ? 'selected' : '' }}>{{ t('admin_ts3_db_mode_mysql', page_locale()) }}</option>
                    </select>
                </div>
                <div class="form-field">
                    <label class="form-label">{{ t('admin_ts3_db_host', page_locale()) }}</label>
                    <input name="db_host" value="{{ form.db_host }}" class="form-input" placeholder="127.0.0.1">
                </div>
                <div class="form-field">
                    <label class="form-label">{{ t('admin_ts3_db_port', page_locale()) }}</label>
                    <input name="db_port" value="{{ form.db_port }}" class="form-input" placeholder="3306">
                </div>
                <div class="form-field">
                    <label class="form-label">{{ t('admin_ts3_db_name', page_locale()) }}</label>
                    <input name="db_name" value="{{ form.db_name }}" class="form-input" placeholder="ts3">
                </div>
                <div class="form-field">
                    <label class="form-label">{{ t('admin_ts3_db_username', page_locale()) }}</label>
                    <input name="db_username" value="{{ form.db_username }}" class="form-input" placeholder="ts3_user">
                </div>
                <div class="form-field">
                    <label class="form-label">{{ t('admin_ts3_db_password', page_locale()) }}</label>
                    <input type="password" name="db_password" class="form-input" placeholder="••••••••">
                </div>
            </div>

            <div style="display:flex;justify-content:flex-end;margin-top:4px;">
                <button class="ui-button ui-button--primary" type="submit">{{ form.submit_label }}</button>
            </div>

        </div>
    </div>
</form>
