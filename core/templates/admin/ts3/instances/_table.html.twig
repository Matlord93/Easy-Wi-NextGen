<div class="ng-data-card__header">
    <div>
        <h2 class="ng-data-card__title">{{ t('admin_ts3_instances_title', page_locale()) }}</h2>
        <p class="ng-data-card__sub">{{ t('admin_ts3_instances_intro', page_locale()) }}</p>
    </div>
</div>
<div class="ng-data-card__body ng-data-card__body--flush">
    <div class="cust-ws-table-wrap">
        <table class="cust-table">
            <thead>
            <tr>
                <th>{{ t('admin_ts3_table_instance', page_locale()) }}</th>
                <th>{{ t('admin_ts3_table_customer', page_locale()) }}</th>
                <th>{{ t('admin_ts3_table_node', page_locale()) }}</th>
                <th>{{ t('admin_ts3_table_ports', page_locale()) }}</th>
                <th>{{ t('admin_ts3_table_db_mode', page_locale()) }}</th>
                <th>{{ t('admin_ts3_table_status', page_locale()) }}</th>
                <th>{{ t('admin_ts3_table_actions', page_locale()) }}</th>
            </tr>
            </thead>
            <tbody>
            {% for instance in instances %}
                <tr>
                    <td>
                        <p style="font-weight:600;">{{ instance.name }}</p>
                        <p style="font-size:.75rem;color:var(--color-text-muted,#64748b);">{{ t('admin_label_id', page_locale()) }} {{ instance.id }}</p>
                    </td>
                    <td>
                        <p>{{ instance.customer.email }}</p>
                        <p style="font-size:.75rem;color:var(--color-text-muted,#64748b);">#{{ instance.customer.id }}</p>
                    </td>
                    <td>
                        <p>{{ instance.node.name }}</p>
                        <p style="font-size:.75rem;color:var(--color-text-muted,#64748b);">{{ instance.node.id }}</p>
                    </td>
                    <td>
                        V {{ instance.voice_port }} · Q {{ instance.query_port }} · F {{ instance.file_port }}
                    </td>
                    <td>
                        <span class="ui-badge ui-badge--neutral">{{ instance.db_mode|upper }}</span>
                    </td>
                    <td>
                        {% if instance.status == 'running' %}
                            <span class="ui-badge ui-badge--success">{{ t('admin_ts3_status_running', page_locale()) }}</span>
                        {% elseif instance.status == 'stopped' %}
                            <span class="ui-badge ui-badge--warning">{{ t('admin_ts3_status_stopped', page_locale()) }}</span>
                        {% elseif instance.status == 'error' %}
                            <span class="ui-badge ui-badge--danger">{{ t('admin_ts3_status_error', page_locale()) }}</span>
                        {% elseif instance.status == 'provisioning' %}
                            <span class="ui-badge ui-badge--info">{{ t('admin_ts3_status_provisioning', page_locale()) }}</span>
                        {% else %}
                            <span class="ui-badge ui-badge--neutral">{{ t('admin_ts3_status_unknown', page_locale()) }}</span>
                        {% endif %}
                    </td>
                    <td>
                        <div style="display:flex;flex-wrap:wrap;gap:6px;">
                            <button class="ui-button ui-button--ghost ui-button--sm"
                                    hx-post="/admin/ts3/instances/{{ instance.id }}/action"
                                    hx-vals='{"action":"start"}'
                                    hx-target="#ts3-instances-table"
                                    hx-swap="outerHTML">{{ t('admin_ts3_action_start', page_locale()) }}</button>
                            <button class="ui-button ui-button--ghost ui-button--sm"
                                    hx-post="/admin/ts3/instances/{{ instance.id }}/action"
                                    hx-vals='{"action":"stop"}'
                                    hx-target="#ts3-instances-table"
                                    hx-swap="outerHTML">{{ t('admin_ts3_action_stop', page_locale()) }}</button>
                            <button class="ui-button ui-button--ghost ui-button--sm"
                                    hx-post="/admin/ts3/instances/{{ instance.id }}/action"
                                    hx-vals='{"action":"restart"}'
                                    hx-target="#ts3-instances-table"
                                    hx-swap="outerHTML">{{ t('admin_ts3_action_restart', page_locale()) }}</button>
                            <button class="ui-button ui-button--ghost ui-button--sm"
                                    hx-post="/admin/ts3/instances/{{ instance.id }}/action"
                                    hx-vals='{"action":"update"}'
                                    hx-target="#ts3-instances-table"
                                    hx-swap="outerHTML">{{ t('admin_ts3_action_update', page_locale()) }}</button>
                            <button class="ui-button ui-button--ghost ui-button--sm"
                                    hx-post="/admin/ts3/instances/{{ instance.id }}/action"
                                    hx-vals='{"action":"backup"}'
                                    hx-target="#ts3-instances-table"
                                    hx-swap="outerHTML">{{ t('admin_ts3_action_backup', page_locale()) }}</button>
                            <button class="ui-button ui-button--ghost ui-button--sm"
                                    hx-post="/admin/ts3/instances/{{ instance.id }}/action"
                                    hx-vals='{"action":"token_reset"}'
                                    hx-target="#ts3-instances-table"
                                    hx-swap="outerHTML">{{ t('admin_ts3_action_reset_token', page_locale()) }}</button>
                            <button class="ui-button ui-button--ghost ui-button--sm"
                                    hx-post="/admin/ts3/instances/{{ instance.id }}/action"
                                    hx-vals='{"action":"logs"}'
                                    hx-target="#ts3-instances-table"
                                    hx-swap="outerHTML">{{ t('admin_ts3_action_export_logs', page_locale()) }}</button>
                        </div>
                        <div style="display:flex;flex-direction:column;gap:8px;margin-top:10px;">
                            <form style="display:flex;align-items:center;gap:8px;"
                                  hx-post="/admin/ts3/instances/{{ instance.id }}/action"
                                  hx-target="#ts3-instances-table"
                                  hx-swap="outerHTML">
                                <input type="hidden" name="action" value="slots">
                                <input name="slots" class="form-input" style="width:96px;" placeholder="{{ t('admin_ts3_slots_placeholder', page_locale()) }}">
                                <button class="ui-button ui-button--ghost ui-button--sm">{{ t('admin_ts3_action_set_slots', page_locale()) }}</button>
                            </form>
                            <form style="display:flex;align-items:center;gap:8px;"
                                  hx-post="/admin/ts3/instances/{{ instance.id }}/action"
                                  hx-target="#ts3-instances-table"
                                  hx-swap="outerHTML">
                                <input type="hidden" name="action" value="restore">
                                <input name="restore_path" class="form-input" style="width:192px;" placeholder="/backups/ts3.tar.gz">
                                <button class="ui-button ui-button--ghost ui-button--sm">{{ t('admin_ts3_action_restore', page_locale()) }}</button>
                            </form>
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="7" class="cust-table__empty">{{ t('admin_ts3_empty', page_locale()) }}</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
