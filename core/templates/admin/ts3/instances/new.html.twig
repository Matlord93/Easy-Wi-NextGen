{% extends 'admin/base.html.twig' %}


{% block content %}
<div style="display:flex;flex-direction:column;gap:20px;">

    <div class="ng-data-card">
        <div class="ng-data-card__header">
            <div>
                <h2 class="ng-data-card__title">{{ t('admin_ts3_create_title', page_locale()) }}</h2>
                <p class="ng-data-card__sub">{{ t('admin_ts3_create_intro', page_locale()) }}</p>
            </div>
            <div class="ng-data-card__actions">
                <a class="ui-button ui-button--ghost ui-button--sm" href="/admin/ts3/instances">{{ t('admin_ts3_back', page_locale()) }}</a>
            </div>
        </div>
        <div class="ng-data-card__body">
            <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:16px;">
                <div class="ng-data-card" style="margin:0;">
                    <div class="ng-data-card__header">
                        <div>
                            <h2 class="ng-data-card__title">{{ t('admin_ts3_option_ts3_title', page_locale()) }}</h2>
                        </div>
                    </div>
                    <div class="ng-data-card__body">
                        <p style="font-size:.875rem;color:var(--color-text-muted,#64748b);margin-bottom:16px;">{{ t('admin_ts3_option_ts3_intro', page_locale()) }}</p>
                        <a class="ui-button ui-button--primary ui-button--sm" href="/admin/ts3/instances/provision">
                            {{ t('admin_ts3_option_ts3_action', page_locale()) }}
                        </a>
                    </div>
                </div>
                {% if module_enabled('ts_virtual') %}
                    <div class="ng-data-card" style="margin:0;border-style:dashed;">
                        <div class="ng-data-card__header">
                            <div style="display:flex;flex-wrap:wrap;align-items:center;gap:8px;">
                                <h2 class="ng-data-card__title">{{ t('admin_ts3_option_virtual_title', page_locale()) }}</h2>
                                <span class="ui-badge ui-badge--warning">{{ t('admin_ts3_option_virtual_badge_planned', page_locale()) }}</span>
                                <span class="ui-badge ui-badge--info">{{ t('admin_ts3_option_virtual_badge_experimental', page_locale()) }}</span>
                            </div>
                        </div>
                        <div class="ng-data-card__body">
                            <p style="font-size:.875rem;color:var(--color-text-muted,#64748b);margin-bottom:16px;">{{ t('admin_ts3_option_virtual_intro', page_locale()) }}</p>
                            <span class="ui-badge ui-badge--neutral">{{ t('admin_ts3_option_virtual_action', page_locale()) }}</span>
                        </div>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>

</div>
{% endblock %}
