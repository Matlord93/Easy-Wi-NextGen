{% extends 'admin/base.html.twig' %}

{% block title %}{{ t('admin_ts3_node_new_title', page_locale()) }} · Easy-Wi NextGen{% endblock %}

{% block content %}
{% set locale = page_locale() %}
    <div class="ng-data-card">
        <div class="ng-data-card__header">
            <div>
                <h2 class="ng-data-card__title">{{ t('admin_ts3_node_new_title', locale) }}</h2>
                <p class="ng-data-card__sub">{{ t('admin_ts3_node_new_intro', locale) }}</p>
            </div>
            <div class="ng-data-card__actions">
                <a class="ui-button ui-button--ghost ui-button--sm" href="/admin/ts3/nodes">{{ t('admin_ts3_node_back', locale) }}</a>
            </div>
        </div>
        <div class="ng-data-card__body">
            <p style="margin-bottom:16px;color:var(--color-text-muted,#64748b);font-size:.875rem;">{{ t('admin_ts3_node_agent_hint', locale) }}</p>
            {{ form_start(form) }}
                {{ form_errors(form) }}
                <div style="display:flex;flex-direction:column;gap:16px;">
                    {{ form_row(form.name, { label: t('admin_ts3_node_form_name', locale) }) }}
                    {{ form_row(form.agentNodeId, { label: t('admin_ts3_node_form_agent_node', locale) }) }}
                    {{ form_row(form.downloadUrl, { label: t('admin_ts3_node_form_download_url', locale) }) }}
                    <p style="color:var(--color-text-muted,#64748b);font-size:.875rem;">{{ t('admin_ts3_node_download_hint', locale) }}</p>
                    {{ form_row(form.installPath, { label: t('admin_ts3_node_form_install_path', locale) }) }}
                    {{ form_row(form.instanceName, { label: t('admin_ts3_node_form_instance_name', locale) }) }}
                    {{ form_row(form.serviceName, { label: t('admin_ts3_node_form_service_name', locale) }) }}
                    {{ form_row(form.queryBindIp, { label: t('admin_ts3_node_form_query_bind_ip', locale) }) }}
                    {{ form_row(form.queryPort, { label: t('admin_ts3_node_form_query_port', locale) }) }}
                    {{ form_row(form.filetransferPort, { label: t('admin_ts3_node_form_filetransfer_port', locale) }) }}
                </div>
                <div style="display:flex;justify-content:flex-end;margin-top:20px;">
                    <button class="ui-button ui-button--primary" type="submit">{{ t('admin_ts3_node_save', locale) }}</button>
                </div>
            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}
