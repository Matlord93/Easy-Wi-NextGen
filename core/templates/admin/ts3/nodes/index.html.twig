{% extends 'admin/base.html.twig' %}

{% set pageTitle = t('admin_ts3_nodes_title', page_locale()) %}
{% set pageSubtitle = t('admin_ts3_nodes_intro', page_locale()) %}
{% set activeNav = 'ts3-nodes' %}

{% block content %}
{% set locale = page_locale() %}
<div style="display:flex;flex-direction:column;gap:20px;">

    {# ── Hero / KPI ── #}
    <section class="ng-card" style="overflow:hidden;">
        <div class="tkt-hero">
            <div class="tkt-hero__inner">
                <div>
                    <div class="tkt-hero__pill">
                        <span class="tkt-hero__pill-dot" style="background:#22d3ee;"></span>
                        TeamSpeak 3
                    </div>
                    <h1 class="tkt-hero__title" style="margin-top:10px;">{{ t('admin_ts3_nodes_title', locale) }}</h1>
                    <p class="tkt-hero__sub">{{ t('admin_ts3_nodes_intro', locale) }}</p>
                </div>
                <div style="display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:10px;margin-top:16px;">
                    <div class="tkt-kpi">
                        <div class="tkt-kpi__label">{{ t('total', locale) }}</div>
                        <div class="tkt-kpi__value">{{ nodes|length }}</div>
                    </div>
                    <div class="tkt-kpi tkt-kpi--open">
                        <div class="tkt-kpi__label">{{ t('admin_ts3_running', locale) }}</div>
                        <div class="tkt-kpi__value">{{ nodes|filter(n => n.running)|length }}</div>
                    </div>
                    <div class="tkt-kpi tkt-kpi--pending">
                        <div class="tkt-kpi__label">{{ t('admin_ts3_stopped', locale) }}</div>
                        <div class="tkt-kpi__value">{{ nodes|filter(n => not n.running)|length }}</div>
                    </div>
                </div>
            </div>
        </div>
        <div style="padding:14px 16px;border-top:1px solid var(--ng-border);background:var(--ng-surface-soft);display:flex;gap:8px;align-items:center;">
            <a class="ui-button ui-button--primary ui-button--sm" href="/admin/ts3/nodes/new">{{ t('admin_ts3_nodes_add', locale) }}</a>
            <a class="ui-button ui-button--ghost ui-button--sm" href="/admin/ts3/instances">{{ t('admin_ts3_heading', locale) }}</a>
            <a class="ui-button ui-button--ghost ui-button--sm" href="/admin/ts3/servers">{{ t('admin_ts3_servers_title', locale) }}</a>
        </div>
    </section>

    {% for message in app.flashes('success') %}
        <div class="ng-alert ng-alert--success">{{ message }}</div>
    {% endfor %}

    <div class="ng-data-card">
        <div class="ng-data-card__header">
            <div>
                <h2 class="ng-data-card__title">{{ t('admin_ts3_nodes_title', locale) }}</h2>
                <p class="ng-data-card__sub">{{ t('admin_ts3_nodes_intro', locale) }}</p>
            </div>
            <div class="ng-data-card__actions">
                <a class="ui-button ui-button--primary ui-button--sm" href="/admin/ts3/nodes/new">{{ t('admin_ts3_nodes_add', locale) }}</a>
            </div>
        </div>
        <div class="ng-data-card__body ng-data-card__body--flush">
            <div class="cust-ws-table-wrap">
                <table class="cust-table">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Agent URL</th>
                            <th>{{ t('admin_ts3_nodes_status', locale) }}</th>
                            <th>{{ t('admin_ts3_nodes_version', locale) }}</th>
                            <th>{{ t('admin_ts3_nodes_updated', locale) }}</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for node in nodes %}
                            <tr>
                                <td>
                                    <div>{{ node.name }}</div>
                                    <div style="font-size:.75rem;color:var(--color-text-muted,#64748b);">#{{ node.id }}</div>
                                </td>
                                <td>{{ node.agentBaseUrl }}</td>
                                <td>
                                    {% set ts3StatusLabel = node.installStatus %}
                                    {% if node.installStatus == 'installed' %}
                                        {% set ts3StatusLabel = node.running ? 'running' : 'stopped' %}
                                    {% endif %}
                                    {% set statusBadge = ts3StatusLabel == 'running' ? 'success' : (ts3StatusLabel == 'stopped' ? 'warning' : 'neutral') %}
                                    <span class="ui-badge ui-badge--{{ statusBadge }}">{{ t('admin_node_status_' ~ ts3StatusLabel, locale) }}</span>
                                </td>
                                <td>{{ node.installedVersion ?? '—' }}</td>
                                <td>{{ node.updatedAt|date('Y-m-d H:i') }}</td>
                                <td style="text-align:right;">
                                    <a class="ui-button ui-button--ghost ui-button--sm" href="/admin/ts3/nodes/{{ node.id }}">{{ t('admin_ts3_nodes_details', locale) }}</a>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="6" class="cust-table__empty">{{ t('admin_ts3_nodes_empty', locale) }}</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>
{% endblock %}
