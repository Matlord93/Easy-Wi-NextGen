{% extends 'admin/base.html.twig' %}

{% block title %}TS3 Node · Easy-Wi NextGen{% endblock %}

{% block content %}
{% set locale = page_locale() %}

    <section class="ng-card" style="overflow:hidden;">
        <div class="tkt-hero">
            <div class="tkt-hero__inner">
                <div style="display:flex;flex-direction:column;gap:16px;">
                    <div>
                        <div class="tkt-hero__pill">
                            <span class="tkt-hero__pill-dot"></span>
                            TS3 Node
                        </div>
                        <h1 class="tkt-hero__title" style="margin-top:10px;">{{ node.name }}</h1>
                        <p class="tkt-hero__sub">Agent: {{ node.agentBaseUrl }}</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    {% for message in app.flashes('success') %}
        <div class="ng-alert ng-alert--success">{{ message }}</div>
    {% endfor %}

    <div style="display:flex;flex-direction:column;gap:20px;">

        <div class="ng-data-card">
            <div class="ng-data-card__header">
                <div>
                    <h2 class="ng-data-card__title">{{ t('admin_ts3_node_status_title', locale) }}</h2>
                </div>
                <div class="ng-data-card__actions">
                    <a class="ui-button ui-button--ghost ui-button--sm" href="/admin/ts3/nodes">{{ t('admin_ts3_node_show_back', locale) }}</a>
                    <form method="post" action="/admin/ts3/nodes/{{ node.id }}/delete" onsubmit="return confirm('{{ t('admin_ts3_node_delete_confirm', locale) }}');">
                        <input type="hidden" name="_token" value="{{ csrf.delete }}">
                        <button class="ui-button ui-button--danger ui-button--sm" type="submit">{{ t('admin_ts3_node_delete', locale) }}</button>
                    </form>
                </div>
            </div>
            <div class="ng-data-card__body">
                <div style="display:flex;flex-direction:column;gap:8px;margin-bottom:20px;">
                    <div><strong>{{ t('admin_ts3_node_install_status', locale) }}</strong> {{ node.installStatus }}</div>
                    <div><strong>{{ t('admin_ts3_node_runtime', locale) }}</strong> {{ node.running ? 'running' : 'stopped' }}</div>
                    <div><strong>{{ t('admin_ts3_node_version', locale) }}</strong> {{ node.installedVersion ?? '—' }}</div>
                    <div><strong>{{ t('admin_ts3_node_service', locale) }}</strong> {{ node.serviceName }}</div>
                    <div><strong>{{ t('admin_ts3_node_running_label', locale) }}</strong> {{ node.running ? 'Ja' : 'Nein' }}</div>
                    <div><strong>{{ t('admin_ts3_node_last_error', locale) }}</strong> {{ node.lastError ?? '—' }}</div>
                </div>
                <div style="display:flex;flex-wrap:wrap;gap:8px;">
                    <form method="post" action="/admin/ts3/nodes/{{ node.id }}/install">
                        <input type="hidden" name="_token" value="{{ csrf.install }}">
                        <button class="ui-button ui-button--ghost ui-button--sm" type="submit">{{ t('admin_ts3_node_install', locale) }}</button>
                    </form>
                    <form method="post" action="/admin/ts3/nodes/{{ node.id }}/start">
                        <input type="hidden" name="_token" value="{{ csrf.start }}">
                        <button class="ui-button ui-button--ghost ui-button--sm" type="submit">{{ t('admin_ts3_node_start', locale) }}</button>
                    </form>
                    <form method="post" action="/admin/ts3/nodes/{{ node.id }}/stop">
                        <input type="hidden" name="_token" value="{{ csrf.stop }}">
                        <button class="ui-button ui-button--ghost ui-button--sm" type="submit">{{ t('admin_ts3_node_stop', locale) }}</button>
                    </form>
                    <form method="post" action="/admin/ts3/nodes/{{ node.id }}/restart">
                        <input type="hidden" name="_token" value="{{ csrf.restart }}">
                        <button class="ui-button ui-button--ghost ui-button--sm" type="submit">{{ t('admin_ts3_node_restart', locale) }}</button>
                    </form>
                </div>
            </div>
        </div>

        <div class="ng-data-card">
            <div class="ng-data-card__header">
                <div>
                    <h2 class="ng-data-card__title">{{ t('admin_ts3_node_jobs_title', locale) }}</h2>
                </div>
            </div>
            <div class="ng-data-card__body">
                {% if agent_jobs is not empty %}
                    <div style="display:flex;flex-direction:column;gap:20px;">
                    {% for job in agent_jobs %}
                        <div style="display:flex;flex-direction:column;gap:8px;">
                            <div><strong>{{ t('admin_ts3_node_job_type', locale) }}</strong> {{ job.type }}</div>
                            <div><strong>{{ t('admin_ts3_node_job_status', locale) }}</strong> {{ job.status.value }}</div>
                            <div><strong>{{ t('admin_ts3_node_job_started', locale) }}</strong> {{ job.startedAt ? job.startedAt|date('Y-m-d H:i') : '—' }}</div>
                            <div><strong>{{ t('admin_ts3_node_job_finished', locale) }}</strong> {{ job.finishedAt ? job.finishedAt|date('Y-m-d H:i') : '—' }}</div>
                            <div><strong>{{ t('admin_ts3_node_job_error', locale) }}</strong> {{ job.errorText ?? '—' }}</div>
                            {% if job.logText %}
                                <pre style="background:var(--color-surface-2,#f8fafc);border:1px solid var(--color-border,#e2e8f0);border-radius:6px;padding:12px;font-size:.8rem;overflow-x:auto;">{{ job.logText }}</pre>
                            {% endif %}
                            {% if job.resultPayload %}
                                <pre style="background:var(--color-surface-2,#f8fafc);border:1px solid var(--color-border,#e2e8f0);border-radius:6px;padding:12px;font-size:.8rem;overflow-x:auto;">{{ job.resultPayload|json_encode(constant('JSON_PRETTY_PRINT')) }}</pre>
                            {% endif %}
                        </div>
                        {% if not loop.last %}
                            <hr style="border:none;border-top:1px solid var(--color-border,#e2e8f0);">
                        {% endif %}
                    {% endfor %}
                    </div>
                {% else %}
                    <p style="color:var(--color-text-muted,#64748b);font-size:.875rem;">{{ t('admin_ts3_node_no_jobs', locale) }}</p>
                {% endif %}
            </div>
        </div>

        <div class="ng-data-card">
            <div class="ng-data-card__header">
                <div>
                    <h2 class="ng-data-card__title">{{ t('admin_ts3_node_credentials_title', locale) }}</h2>
                </div>
            </div>
            <div class="ng-data-card__body">
                <p style="color:var(--color-text-muted,#64748b);font-size:.875rem;margin-bottom:16px;">{{ t('admin_ts3_node_credentials_note', locale) }}</p>
                {% if admin_password %}
                    <div style="display:flex;flex-direction:column;gap:8px;margin-bottom:16px;">
                        <div><strong>{{ node.adminUsername }}</strong></div>
                        <div style="font-family:monospace;background:var(--color-surface-2,#f8fafc);border:1px solid var(--color-border,#e2e8f0);border-radius:6px;padding:8px 12px;">{{ admin_password }}</div>
                    </div>
                    <button class="ui-button ui-button--ghost ui-button--sm" type="button" data-ts3-copy="{{ admin_password }}">{{ t('admin_ts3_node_copy', locale) }}</button>
                {% else %}
                    <div style="display:flex;flex-direction:column;gap:8px;margin-bottom:16px;">
                        <div><strong>{{ node.adminUsername }}</strong></div>
                        <div style="font-family:monospace;background:var(--color-surface-2,#f8fafc);border:1px solid var(--color-border,#e2e8f0);border-radius:6px;padding:8px 12px;">••••••••</div>
                    </div>
                {% endif %}
                <form method="post" action="/admin/ts3/nodes/{{ node.id }}/show-admin-credentials" style="margin-top:12px;">
                    <input type="hidden" name="_token" value="{{ csrf.show_admin }}">
                    <button class="ui-button ui-button--primary ui-button--sm" type="submit">{{ t('admin_ts3_node_show', locale) }}</button>
                </form>
                {% if node.adminPasswordShownOnceAt %}
                    <p style="color:var(--color-text-muted,#64748b);font-size:.875rem;margin-top:12px;">{{ t('admin_ts3_node_last_shown', locale) }} {{ node.adminPasswordShownOnceAt|date('Y-m-d H:i') }}</p>
                {% endif %}
            </div>
        </div>

    </div>

    <script>
        document.querySelectorAll('[data-ts3-copy]').forEach(function (button) {
            button.addEventListener('click', function () {
                navigator.clipboard?.writeText(button.dataset.ts3Copy || '');
            });
        });
    </script>
{% endblock %}
