{% extends 'admin/base.html.twig' %}

{% block title %}{{ t('admin_ts3_server_create_title', page_locale()) }} · Easy-Wi NextGen{% endblock %}

{% block content %}
{% set locale = page_locale() %}
    <div style="display:flex;flex-direction:column;gap:20px;">

        {% for message in app.flashes('success') %}
            <div class="ng-alert ng-alert--success">{{ message }}</div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="ng-alert ng-alert--danger">{{ message }}</div>
        {% endfor %}

        <div class="ng-data-card">
            <div class="ng-data-card__header">
                <div>
                    <h2 class="ng-data-card__title">{{ t('admin_ts3_server_create_title', locale) }}</h2>
                    <p class="ng-data-card__sub">{{ t('admin_ts3_server_create_intro', locale) }}</p>
                </div>
                <div class="ng-data-card__actions">
                    <a class="ui-button ui-button--ghost ui-button--sm" href="/admin/ts3/servers">{{ t('admin_ts3_server_create_overview', locale) }}</a>
                    <a class="ui-button ui-button--ghost ui-button--sm" href="/admin/ts3/nodes">{{ t('admin_ts3_servers_manage_nodes', locale) }}</a>
                </div>
            </div>
            <div class="ng-data-card__body">
                {{ form_start(form) }}
                    <div style="display:flex;flex-direction:column;gap:16px;">
                        {{ form_row(form.customerId, { label: t('admin_ts3_servers_col_customer', locale) }) }}
                        {{ form_row(form.nodeId, { label: t('admin_ts3_servers_col_node', locale) }) }}
                        {{ form_row(form.name, { label: 'Servername' }) }}
                        {{ form_row(form.voicePort, { label: 'Voice Port' }) }}
                        {{ form_row(form.filetransferPort, { label: 'Filetransfer Port' }) }}
                    </div>
                    <div style="display:flex;justify-content:flex-end;margin-top:20px;">
                        <button class="ui-button ui-button--primary" type="submit">{{ t('admin_ts3_server_create_btn', locale) }}</button>
                    </div>
                {{ form_end(form) }}
            </div>
        </div>

    </div>
{% endblock %}
