{% extends 'admin/base.html.twig' %}

{% set pageTitle = t('admin_ts3_servers_title', page_locale()) %}
{% set pageSubtitle = t('admin_ts3_servers_intro', page_locale()) %}
{% set activeNav = 'ts3-servers' %}

{% block content %}
{% set locale = page_locale() %}
<div class="flex flex-col gap-6">

    {% for message in app.flashes('success') %}
        <div class="ng-alert ng-alert--success">{{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="ng-alert ng-alert--danger">{{ message }}</div>
    {% endfor %}

    <div class="ng-data-card">
        <div class="ng-data-card__header">
            <div>
                <h2 class="ng-data-card__title">{{ t('admin_ts3_servers_title', locale) }}</h2>
                <p class="ng-data-card__sub">{{ t('admin_ts3_servers_intro', locale) }}</p>
            </div>
            <div class="ng-data-card__actions">
                <a class="ui-button ui-button--ghost ui-button--sm" href="/admin/ts3/nodes">{{ t('admin_ts3_servers_manage_nodes', locale) }}</a>
                <a class="ui-button ui-button--primary ui-button--sm" href="/admin/ts3/servers/create">{{ t('admin_ts3_servers_create', locale) }}</a>
            </div>
        </div>
        <div class="ng-data-card__body ng-data-card__body--flush">
            <div class="cust-ws-table-wrap">
                <table class="cust-table">
                    <thead>
                        <tr>
                            <th>{{ t('admin_ts3_servers_col_server', locale) }}</th>
                            <th>{{ t('admin_ts3_servers_col_customer', locale) }}</th>
                            <th>{{ t('admin_ts3_servers_col_node', locale) }}</th>
                            <th>{{ t('admin_ts3_servers_col_ports', locale) }}</th>
                            <th>{{ t('admin_ts3_servers_col_status', locale) }}</th>
                            <th>{{ t('admin_ts3_servers_col_updated', locale) }}</th>
                            <th>{{ t('admin_ts3_servers_col_assignment', locale) }}</th>
                            <th>{{ t('admin_ts3_servers_col_actions', locale) }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for server in servers %}
                            {% set customer = customerMap[server.customerId] ?? null %}
                            <tr>
                                <td>
                                    <div>{{ server.name }}</div>
                                    <div class="text-xs text-slate-500">SID {{ server.sid }} · #{{ server.id }}</div>
                                </td>
                                <td>
                                    {% if customer %}
                                        <div>{{ customer.name ?? customer.email }}</div>
                                        <div class="text-xs text-slate-500">#{{ customer.id }}</div>
                                    {% else %}
                                        <span class="text-slate-500 text-xs">{{ t('admin_ts3_servers_unknown_customer', locale) }}</span>
                                    {% endif %}
                                </td>
                                <td>
                                    <div>{{ server.node.name }}</div>
                                    <div class="text-xs text-slate-500">#{{ server.node.id }}</div>
                                </td>
                                <td class="text-xs">
                                    <div>Voice: {{ server.voicePort ?? '—' }}</div>
                                    <div class="text-slate-500">File: {{ server.filetransferPort ?? '—' }}</div>
                                </td>
                                <td>
                                    {% set statusBadge = server.status == 'running' ? 'success' : (server.status == 'stopped' ? 'warning' : (server.status == 'error' ? 'danger' : 'neutral')) %}
                                    <span class="ui-badge ui-badge--{{ statusBadge }}">{{ server.status }}</span>
                                </td>
                                <td>{{ server.updatedAt|date('Y-m-d H:i') }}</td>
                                <td>
                                    <form method="post" action="/admin/ts3/servers/{{ server.id }}/assign" class="flex gap-2 items-center">
                                        <input type="hidden" name="_token" value="{{ csrf[server.id] ?? '' }}">
                                        <select name="customer_id" class="form-input text-xs py-1 px-2">
                                            {% for customerOption in customers %}
                                                <option value="{{ customerOption.id }}" {{ customerOption.id == server.customerId ? 'selected' : '' }}>
                                                    {{ customerOption.name ?? customerOption.email }}
                                                </option>
                                            {% endfor %}
                                        </select>
                                        <button type="submit" class="ui-button ui-button--ghost ui-button--sm">{{ t('admin_ts3_servers_assign', locale) }}</button>
                                    </form>
                                </td>
                                <td>
                                    <form method="post" action="/admin/ts3/servers/{{ server.id }}/delete">
                                        <input type="hidden" name="_token" value="{{ deleteTokens[server.id] ?? '' }}">
                                        <button type="submit" class="ui-button ui-button--danger ui-button--sm">{{ t('admin_ts3_servers_delete', locale) }}</button>
                                    </form>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="8" class="cust-table__empty">{{ t('admin_ts3_servers_empty', locale) }}</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>
{% endblock %}
