{% extends 'admin/base.html.twig' %}

{% block title %}{{ t('admin_ts3_servers_title', page_locale()) }} · Easy-Wi NextGen{% endblock %}

{% block content %}
{% set locale = page_locale() %}
    <div class="ts3-page">
        <div class="ts3-header">
            <div>
                <h1>{{ t('admin_ts3_servers_title', locale) }}</h1>
                <p>{{ t('admin_ts3_servers_intro', locale) }}</p>
            </div>
            <div class="ts3-actions">
                <a class="ts3-link" href="/admin/ts3/servers/create">{{ t('admin_ts3_servers_create', locale) }}</a>
                <a class="ts3-link" href="/admin/ts3/nodes">{{ t('admin_ts3_servers_manage_nodes', locale) }}</a>
            </div>
        </div>

        {% for message in app.flashes('success') %}
            <div class="ts3-alert ts3-alert-success">{{ message }}</div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="ts3-alert ts3-alert-error">{{ message }}</div>
        {% endfor %}

        <div class="ts3-card">
            <table class="ts3-table">
                <thead>
                <tr>
                    <th>{{ t('admin_ts3_servers_col_server', locale) }}</th>
                    <th>{{ t('admin_ts3_servers_col_customer', locale) }}</th>
                    <th>{{ t('admin_ts3_servers_col_node', locale) }}</th>
                    <th>{{ t('admin_ts3_servers_col_ports', locale) }}</th>
                    <th>{{ t('admin_ts3_servers_col_status', locale) }}</th>
                    <th>{{ t('admin_ts3_servers_col_updated', locale) }}</th>
                    <th>{{ t('admin_ts3_servers_col_assignment', locale) }}</th>
                    <th>{{ t('admin_ts3_servers_col_actions', locale) }}</th>
                </tr>
                </thead>
                <tbody>
                {% for server in servers %}
                    {% set customer = customerMap[server.customerId] ?? null %}
                    <tr>
                        <td>
                            <div>{{ server.name }}</div>
                            <div class="ts3-muted">SID {{ server.sid }} · #{{ server.id }}</div>
                        </td>
                        <td>
                            {% if customer %}
                                <div>{{ customer.name ?? customer.email }}</div>
                                <div class="ts3-muted">#{{ customer.id }}</div>
                            {% else %}
                                <span class="ts3-muted">{{ t('admin_ts3_servers_unknown_customer', locale) }}</span>
                            {% endif %}
                        </td>
                        <td>
                            <div>{{ server.node.name }}</div>
                            <div class="ts3-muted">#{{ server.node.id }}</div>
                        </td>
                        <td>
                            <div>Voice: {{ server.voicePort ?? '—' }}</div>
                            <div class="ts3-muted">File: {{ server.filetransferPort ?? '—' }}</div>
                        </td>
                        <td><span class="ts3-pill">{{ server.status }}</span></td>
                        <td>{{ server.updatedAt|date('Y-m-d H:i') }}</td>
                        <td>
                            <form method="post" action="/admin/ts3/servers/{{ server.id }}/assign" class="flex gap-2">
                                <input type="hidden" name="_token" value="{{ csrf[server.id] ?? '' }}">
                                <select name="customer_id" class="rounded-lg border border-slate-200 px-2 py-1 text-xs">
                                    {% for customerOption in customers %}
                                        <option value="{{ customerOption.id }}" {{ customerOption.id == server.customerId ? 'selected' : '' }}>
                                            {{ customerOption.name ?? customerOption.email }}
                                        </option>
                                    {% endfor %}
                                </select>
                                <button class="ts3-button" type="submit">{{ t('admin_ts3_servers_assign', locale) }}</button>
                            </form>
                        </td>
                        <td>
                            <form method="post" action="/admin/ts3/servers/{{ server.id }}/delete">
                                <input type="hidden" name="_token" value="{{ deleteTokens[server.id] ?? '' }}">
                                <button class="ts3-button" type="submit">{{ t('admin_ts3_servers_delete', locale) }}</button>
                            </form>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="8" class="ts3-empty">{{ t('admin_ts3_servers_empty', locale) }}</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
