<div class="border-b border-slate-200 p-6">
    <div class="space-y-2">
        <h2 class="text-lg font-semibold text-slate-900">{{ t('admin_instances_table_title', page_locale()) }}</h2>
        <p class="text-sm text-slate-700">{{ t('admin_instances_table_intro', page_locale()) }}</p>
    </div>
    {% if errors is defined and errors is not empty %}
        <div class="mt-4 rounded-lg border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700">
            <ul class="list-disc space-y-1 pl-4">{% for error in errors %}<li>{{ error }}</li>{% endfor %}</ul>
        </div>
    {% endif %}
</div>

<div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-slate-200 text-sm">
        <thead class="bg-slate-50">
            <tr>
                <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-700">ID</th>
                <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-700">Kunde / Template</th>
                <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-700">Node</th>
                <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-700">Ressourcen</th>
                <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-700">Disk</th>
                <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-700">Status</th>
                <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-700">Setup</th>
                <th class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wide text-slate-700">Aktionen</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-slate-200 bg-white">
            {% for instance in instances %}
                {% set displayStatus = instance.display_status ?? instance.status %}
                {% set statusColor = 'text-slate-600 bg-slate-100' %}
                {% if displayStatus == 'running' %}{% set statusColor = 'text-emerald-700 bg-emerald-50' %}{% endif %}
                {% if displayStatus in ['error', 'suspended'] %}{% set statusColor = 'text-rose-700 bg-rose-50' %}{% endif %}
                {% if displayStatus in ['pending_setup', 'provisioning', 'stopped'] %}{% set statusColor = 'text-amber-700 bg-amber-50' %}{% endif %}

                {% set installBadge = instance.install_ready ? 'text-emerald-700 bg-emerald-50' : 'text-amber-700 bg-amber-50' %}
                {% set diskStateStyles = {'ok': 'text-emerald-700 bg-emerald-50', 'warning': 'text-amber-700 bg-amber-50', 'over_limit': 'text-rose-700 bg-rose-50', 'hard_block': 'text-rose-700 bg-rose-100'} %}
                {% set diskBadge = diskStateStyles[instance.disk_state] ?? 'text-slate-600 bg-slate-100' %}
                {% set diskPercent = instance.disk_percent|default(0) %}
                {% set diskBarWidth = diskPercent > 100 ? 100 : diskPercent %}

                <tr class="hover:bg-slate-50/70 align-top">
                    <td class="px-4 py-4 text-slate-700">#{{ instance.id }}<div class="text-[11px] text-slate-500 mt-1">{{ instance.updated_at ? instance.updated_at|date('Y-m-d H:i') : '—' }}</div></td>
                    <td class="px-4 py-4">
                        <div class="font-medium text-slate-900">{{ instance.customer_email }}</div>
                        <div class="mt-1 text-xs text-slate-700">{{ instance.template_name }} ({{ instance.game_key }})</div>
                        <div class="mt-2 text-xs text-slate-500">SFTP: {{ instance.sftp_username ?: '—' }}</div>
                    </td>
                    <td class="px-4 py-4 text-slate-700">{{ instance.node }}</td>
                    <td class="px-4 py-4">
                        <div class="text-xs text-slate-700">{{ instance.cpu_limit }} vCPU · {{ instance.ram_limit }} MB · {{ instance.disk_limit }} MB</div>
                        <details class="mt-2">
                            <summary class="cursor-pointer text-xs font-semibold text-indigo-600">{{ t('admin_instances_update_resources', page_locale()) }}</summary>
                            <form class="mt-2 grid gap-2" hx-post="{{ path('admin_instances_update_resources', {id: instance.id}) }}" hx-target="#instances-table" hx-swap="outerHTML">
                                <div class="grid grid-cols-3 gap-2">
                                    <input name="cpu_limit" type="number" min="{{ instance.cpu_limit }}" value="{{ instance.cpu_limit }}" class="rounded-md border border-slate-200 px-2 py-1 text-xs">
                                    <input name="ram_limit" type="number" min="{{ instance.ram_limit }}" value="{{ instance.ram_limit }}" class="rounded-md border border-slate-200 px-2 py-1 text-xs">
                                    <input name="disk_limit" type="number" min="{{ instance.disk_limit }}" value="{{ instance.disk_limit }}" class="rounded-md border border-slate-200 px-2 py-1 text-xs">
                                </div>
                                <button class="w-fit rounded-md bg-indigo-600 px-3 py-1 text-[11px] font-semibold uppercase text-white">{{ t('admin_instances_update_resources_submit', page_locale()) }}</button>
                            </form>
                        </details>
                    </td>
                    <td class="px-4 py-4">
                        <div class="flex items-center gap-2">
                            <span class="rounded-full px-2.5 py-1 text-[11px] font-semibold {{ diskBadge }}">{{ instance.disk_state|replace({'_': ' '})|title }}</span>
                            <span class="text-xs text-slate-600">{{ instance.disk_used_human }} / {{ instance.disk_limit_human }}</span>
                        </div>
                        <div class="mt-2 h-2 w-full rounded-full bg-slate-100"><div class="h-2 rounded-full bg-indigo-500" style="width: {{ diskBarWidth }}%"></div></div>
                    </td>
                    <td class="px-4 py-4">
                        <span class="rounded-full px-3 py-1 text-xs font-semibold {{ statusColor }}">{{ t('customer_instance_status_' ~ displayStatus, page_locale()) }}</span>
                        {% if instance.runtime_status_reason %}
                            <div class="mt-1 text-xs text-amber-700">{{ instance.runtime_status_reason }}</div>
                        {% endif %}
                    </td>
                    <td class="px-4 py-4">
                        <span class="rounded-full px-3 py-1 text-xs font-semibold {{ installBadge }}">
                            {{ instance.install_ready ? 'Install bereit' : 'Setup offen' }}
                        </span>
                        {% if instance.install_error_code %}
                            <div class="mt-1 text-xs text-amber-700">{{ instance.install_error_code }}</div>
                        {% endif %}
                    </td>
                    <td class="px-4 py-4 text-right">
                        <div class="flex flex-col items-end gap-2">
                            <a href="{{ path('customer_instance_detail', {id: instance.id, tab: 'settings'}) }}" class="rounded-lg border border-slate-200 px-3 py-2 text-xs font-semibold text-slate-700">Kunde-Einstellungen</a>
                            <a href="{{ path('customer_instance_detail', {id: instance.id, tab: 'files'}) }}" class="rounded-lg border border-slate-200 px-3 py-2 text-xs font-semibold text-slate-700">{{ t('admin_instances_file_manager', page_locale()) }}</a>
                            {% if not instance.sftp_ready %}
                                <button class="rounded-lg border border-indigo-200 px-3 py-2 text-xs font-semibold text-indigo-600" hx-post="{{ path('admin_instances_sftp_provision', {id: instance.id}) }}">{{ t('admin_instances_sftp_provision', page_locale()) }}</button>
                            {% endif %}
                            <button class="rounded-lg border border-rose-200 px-3 py-2 text-xs font-semibold text-rose-600" hx-post="{{ path('admin_instances_delete_form', {id: instance.id}) }}" hx-confirm="{{ t('admin_instances_delete_confirm', page_locale()) }}">{{ t('delete', page_locale()) }}</button>
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr><td class="px-4 py-8 text-center text-sm text-slate-700" colspan="8">{{ t('admin_instances_empty', page_locale()) }}</td></tr>
            {% endfor %}
        </tbody>
    </table>
</div>
