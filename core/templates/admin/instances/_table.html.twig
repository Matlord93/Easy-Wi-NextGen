{% set activeFilters = filters|default({'q': '', 'status': '', 'node': ''}) %}

<div id="instances-table">

<div class="tkt-filter-bar">
    <div class="tkt-filter-bar__top">
        <form class="tkt-filter-bar__fields"
              hx-get="{{ path('admin_instances_table') }}"
              hx-target="#instances-table"
              hx-swap="outerHTML">
            <div class="form-field">
                <input type="text"
                       name="q"
                       value="{{ activeFilters.q }}"
                       placeholder="ID, Kunde, Hostname, Template, Game …"
                       class="form-input">
            </div>
            <div class="form-field">
                <select name="status" class="form-input">
                    <option value="">Alle Status</option>
                    <option value="running" {{ activeFilters.status == 'running' ? 'selected' : '' }}>Running</option>
                    <option value="stopped" {{ activeFilters.status == 'stopped' ? 'selected' : '' }}>Stopped</option>
                    <option value="pending_setup" {{ activeFilters.status == 'pending_setup' ? 'selected' : '' }}>Pending setup</option>
                    <option value="provisioning" {{ activeFilters.status == 'provisioning' ? 'selected' : '' }}>Provisioning</option>
                    <option value="suspended" {{ activeFilters.status == 'suspended' ? 'selected' : '' }}>Suspended</option>
                    <option value="error" {{ activeFilters.status == 'error' ? 'selected' : '' }}>Error</option>
                </select>
            </div>
            <div class="form-field">
                <input type="text"
                       name="node"
                       value="{{ activeFilters.node }}"
                       placeholder="{{ t('admin_instances_node_contains_placeholder', page_locale()) }}"
                       class="form-input">
            </div>
            <div style="display:flex;gap:8px;align-items:center;">
                <button type="submit" class="ui-button ui-button--primary ui-button--sm">Filter</button>
                <a href="{{ path('admin_instances_table') }}" class="ui-button ui-button--ghost ui-button--sm">Reset</a>
            </div>
        </form>
    </div>

    {% if errors is defined and errors is not empty %}
        <div class="ng-alert ng-alert--danger" style="margin:12px 16px 0;">
            <ul style="margin:0;padding-left:18px;">{% for error in errors %}<li>{{ error }}</li>{% endfor %}</ul>
        </div>
    {% endif %}
</div>

<div class="cust-ws-table-wrap">
    <table class="cust-table">
        <thead>
            <tr>
                <th>ID</th>
                <th>{{ t('admin_instances_customer_game', page_locale())|default('Kunde / Gameserver') }}</th>
                <th>Node</th>
                <th>{{ t('admin_instances_resources', page_locale())|default('Ressourcen') }}</th>
                <th>Disk</th>
                <th>Status</th>
                <th>Setup</th>
                <th style="text-align:right;">{{ t('admin_instances_actions', page_locale())|default('Aktionen') }}</th>
            </tr>
        </thead>
        <tbody>
            {% for instance in instances %}
                {% set displayStatus = instance.display_status ?? instance.status %}
                {% if displayStatus == 'running' %}
                    {% set statusVariant = 'success' %}
                {% elseif displayStatus in ['error', 'suspended'] %}
                    {% set statusVariant = 'danger' %}
                {% elseif displayStatus in ['pending_setup', 'provisioning', 'stopped'] %}
                    {% set statusVariant = 'warning' %}
                {% else %}
                    {% set statusVariant = 'neutral' %}
                {% endif %}

                {% set installVariant = instance.install_ready ? 'success' : 'warning' %}

                {% if instance.disk_state == 'ok' %}
                    {% set diskVariant = 'success' %}
                {% elseif instance.disk_state in ['over_limit', 'hard_block'] %}
                    {% set diskVariant = 'danger' %}
                {% elseif instance.disk_state == 'warning' %}
                    {% set diskVariant = 'warning' %}
                {% else %}
                    {% set diskVariant = 'neutral' %}
                {% endif %}

                {% set diskPercent = instance.disk_percent|default(0) %}
                {% set diskBarWidth = diskPercent > 100 ? 100 : diskPercent %}

                <tr>
                    <td>
                        <span style="font-weight:600;">#{{ instance.id }}</span>
                        <div style="font-size:11px;color:var(--color-text-muted,#94a3b8);margin-top:2px;">
                            {{ instance.updated_at ? instance.updated_at|date('Y-m-d H:i') : '—' }}
                        </div>
                    </td>
                    <td>
                        <div style="font-weight:600;font-size:14px;">{{ instance.template_name }}</div>
                        <div style="margin-top:3px;font-size:12px;color:var(--color-text-muted,#64748b);">
                            {{ t('admin_instances_hostname', page_locale()) }}: <span style="font-weight:600;color:var(--color-text,#0f172a);">{{ instance.server_name ?: '—' }}</span>
                        </div>
                        <div style="margin-top:3px;">
                            <span class="ui-badge ui-badge--neutral" style="font-size:10px;">{{ instance.game_key }}</span>
                        </div>
                        <div style="margin-top:6px;font-size:12px;color:var(--color-text-muted,#64748b);">{{ instance.customer_email }}</div>
                        <div style="margin-top:4px;font-size:11px;color:var(--color-text-muted,#94a3b8);">
                            SFTP: {{ instance.sftp_username ?: '—' }} · {{ instance.sftp_host ?: '—' }}:{{ instance.sftp_port ?: '—' }} · {{ instance.sftp_status }}
                        </div>
                        {% if instance.sftp_expires_at %}
                            <div style="font-size:11px;color:var(--color-text-muted,#94a3b8);">
                                {{ t('admin_instances_sftp_expires', page_locale()) }}: {{ instance.sftp_expires_at|date('Y-m-d H:i') }}
                            </div>
                        {% endif %}
                        {% if instance.sftp_last_error %}
                            <div style="font-size:11px;color:#ef4444;">{{ t('admin_instances_sftp_error_label', page_locale()) }}: {{ instance.sftp_last_error }}</div>
                        {% endif %}
                    </td>
                    <td>{{ instance.node }}</td>
                    <td>
                        <div style="font-size:12px;">{{ instance.cpu_limit }} vCPU · {{ instance.ram_limit }} MB · {{ instance.disk_limit }} MB</div>
                        <details style="margin-top:6px;">
                            <summary style="cursor:pointer;font-size:11px;font-weight:600;color:#6366f1;">{{ t('admin_instances_update_resources', page_locale()) }}</summary>
                            <form style="margin-top:8px;display:grid;gap:6px;"
                                  hx-post="{{ path('admin_instances_update_resources', {id: instance.id}) }}"
                                  hx-target="#instances-table"
                                  hx-swap="outerHTML">
                                <input type="hidden" name="q" value="{{ activeFilters.q }}">
                                <input type="hidden" name="status" value="{{ activeFilters.status }}">
                                <input type="hidden" name="node" value="{{ activeFilters.node }}">
                                <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:6px;">
                                    <input name="cpu_limit" type="number" min="{{ instance.cpu_limit }}" value="{{ instance.cpu_limit }}" class="form-input" style="font-size:11px;padding:4px 6px;">
                                    <input name="ram_limit" type="number" min="{{ instance.ram_limit }}" value="{{ instance.ram_limit }}" class="form-input" style="font-size:11px;padding:4px 6px;">
                                    <input name="disk_limit" type="number" min="{{ instance.disk_limit }}" value="{{ instance.disk_limit }}" class="form-input" style="font-size:11px;padding:4px 6px;">
                                </div>
                                <button class="ui-button ui-button--primary ui-button--sm" style="justify-self:start;">{{ t('admin_instances_update_resources_submit', page_locale()) }}</button>
                            </form>
                        </details>
                    </td>
                    <td>
                        <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;">
                            <span class="ui-badge ui-badge--{{ diskVariant }}">{{ instance.disk_state|replace({'_': ' '})|title }}</span>
                            <span style="font-size:11px;color:var(--color-text-muted,#64748b);">{{ instance.disk_used_human }} / {{ instance.disk_limit_human }}</span>
                        </div>
                        <div style="margin-top:6px;height:4px;background:#e2e8f0;border-radius:2px;overflow:hidden;">
                            <div style="height:4px;background:#6366f1;border-radius:2px;width:{{ diskBarWidth }}%;"></div>
                        </div>
                    </td>
                    <td>
                        <span class="ui-badge ui-badge--{{ statusVariant }}">
                            {{ t('customer_instance_status_' ~ displayStatus, page_locale()) }}
                        </span>
                        {% if instance.runtime_status_reason %}
                            <div style="margin-top:4px;font-size:11px;color:#d97706;">{{ instance.runtime_status_reason }}</div>
                        {% endif %}
                        {% if instance.latest_lifecycle_job_id %}
                            <div style="margin-top:4px;font-size:11px;color:var(--color-text-muted,#94a3b8);">
                                {{ instance.latest_lifecycle_job_type }} · {{ instance.latest_lifecycle_job_status }}
                                {% if instance.latest_lifecycle_job_error_code %}
                                    <span style="color:#ef4444;">({{ instance.latest_lifecycle_job_error_code }})</span>
                                {% endif %}
                            </div>
                        {% endif %}
                    </td>
                    <td>
                        <span class="ui-badge ui-badge--{{ installVariant }}">
                            {{ instance.install_ready ? t('admin_instances_install_ready', page_locale()) : t('admin_instances_setup_open', page_locale()) }}
                        </span>
                        {% if instance.install_error_code %}
                            <div style="margin-top:4px;font-size:11px;color:#d97706;">{{ instance.install_error_code }}</div>
                        {% endif %}
                    </td>
                    <td style="text-align:right;">
                        <div style="display:flex;flex-direction:column;align-items:flex-end;gap:6px;">
                            <form method="post"
                                  action="{{ path('admin_users_impersonate', {id: instance.customer_id}) }}"
                                  style="display:contents;">
                                <input type="hidden" name="redirect" value="{{ path('customer_instance_detail', {id: instance.id, tab: 'settings'}) }}">
                                <button type="submit" class="ui-button ui-button--ghost ui-button--sm">
                                    {{ t('admin_instances_customer_settings', page_locale()) }}
                                </button>
                            </form>
                            <form method="post"
                                  action="{{ path('admin_users_impersonate', {id: instance.customer_id}) }}"
                                  style="display:contents;">
                                <input type="hidden" name="redirect" value="{{ path('customer_instance_detail', {id: instance.id, tab: 'files'}) }}">
                                <button type="submit" class="ui-button ui-button--ghost ui-button--sm">
                                    {{ t('admin_instances_file_manager', page_locale()) }}
                                </button>
                            </form>
                            {% if not instance.sftp_ready %}
                                <div style="font-size:11px;color:var(--color-text-muted,#94a3b8);">{{ t('admin_instances_sftp_password_once', page_locale()) }}</div>
                                <button class="ui-button ui-button--ghost ui-button--sm"
                                        style="border-color:#818cf8;color:#6366f1;"
                                        hx-post="{{ path('admin_instances_sftp_provision', {id: instance.id}) }}">
                                    {{ t('admin_instances_sftp_provision', page_locale()) }}
                                </button>
                            {% endif %}
                            <button class="ui-button ui-button--ghost ui-button--sm"
                                    style="border-color:#fca5a5;color:#ef4444;"
                                    hx-post="{{ path('admin_instances_delete_form', {id: instance.id}) }}"
                                    hx-confirm="{{ t('admin_instances_delete_confirm', page_locale()) }}">
                                {{ t('delete', page_locale()) }}
                            </button>
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="8" class="cust-table__empty">{{ t('admin_instances_empty', page_locale()) }}</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>

</div>{# end #instances-table #}
