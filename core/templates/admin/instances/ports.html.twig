{% extends 'admin/base.html.twig' %}

{% set activeNav = 'game-instances' %}

{% block content %}
<div style="display:flex;flex-direction:column;gap:20px;">

    <div class="ng-data-card">
        <div class="ng-data-card__header">
            <div>
                <h2 class="ng-data-card__title">Instance Ports</h2>
                <p class="ng-data-card__sub">{{ instance.getServerName() ?? 'Instance' }} · #{{ instance.getId() }}</p>
            </div>
            <div class="ng-data-card__actions">
                <a class="ui-button ui-button--ghost ui-button--sm" href="{{ path('admin_instances') }}">Zurück</a>
            </div>
        </div>
        <div class="ng-data-card__body--flush">
            <div class="cust-ws-table-wrap">
                <table class="cust-table">
                    <thead>
                        <tr>
                            <th>Role</th>
                            <th>Proto</th>
                            <th>Port</th>
                            <th>Purpose</th>
                            <th>Pool</th>
                            <th>Last check</th>
                            <th>Host free</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for allocation in allocations %}
                            <tr>
                                <td><span style="font-weight:600;">{{ allocation.getRoleKey() }}</span></td>
                                <td>{{ allocation.getProto() }}</td>
                                <td><span style="font-weight:600;">{{ allocation.getPort() }}</span></td>
                                <td>{{ allocation.getPurpose() ?? '—' }}</td>
                                <td>{{ allocation.getPoolTag() ?? '—' }}</td>
                                <td>{{ allocation.getLastCheckedAt() ? allocation.getLastCheckedAt()|date('Y-m-d H:i') : '—' }}</td>
                                <td>{% if allocation.getLastHostFree() is same as(true) %}Ja{% elseif allocation.getLastHostFree() is same as(false) %}Nein{% else %}—{% endif %}</td>
                            </tr>
                        {% else %}
                            <tr><td colspan="7" class="cust-table__empty">Keine Zuweisungen.</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="ng-data-card">
        <div class="ng-data-card__header">
            <div>
                <h2 class="ng-data-card__title">Pool Availability</h2>
                <p class="ng-data-card__sub">Counts are based on database allocations.</p>
            </div>
        </div>
        <div class="ng-data-card__body--flush">
            <div class="cust-ws-table-wrap">
                <table class="cust-table">
                    <thead>
                        <tr>
                            <th>Tag</th>
                            <th>Name</th>
                            <th>Total</th>
                            <th>Allocated</th>
                            <th>Free</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for stat in poolStats %}
                            <tr>
                                <td><span style="font-weight:600;">{{ stat.tag }}</span></td>
                                <td>{{ stat.name }}</td>
                                <td>{{ stat.total }}</td>
                                <td>{{ stat.allocated }}</td>
                                <td>{{ stat.free }}</td>
                            </tr>
                        {% else %}
                            <tr><td colspan="5" class="cust-table__empty">No pools configured.</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>
{% endblock %}
