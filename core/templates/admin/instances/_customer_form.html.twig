<div style="padding:20px;border-bottom:1px solid var(--color-border,#e2e8f0);">
    <h2 style="font-size:1rem;font-weight:600;margin-bottom:4px;">{{ t('admin_instances_customer_create_title', page_locale()) }}</h2>
    <p style="font-size:.875rem;color:var(--color-text-muted,#64748b);">{{ t('admin_instances_customer_create_intro', page_locale()) }}</p>
</div>
<form style="padding:20px;display:flex;flex-direction:column;gap:16px;"
      hx-post="{{ path('admin_instances_customers_create') }}"
      hx-target="#instance-customer-form"
      hx-swap="outerHTML">

    {% if customerForm.success %}
        <div class="ng-alert ng-alert--success">{{ customerForm.success }}</div>
    {% endif %}

    {% if customerForm.errors is not empty %}
        <div class="ng-alert ng-alert--danger">
            <ul style="margin:0;padding-left:18px;">
                {% for error in customerForm.errors %}
                    <li>{{ error }}</li>
                {% endfor %}
            </ul>
        </div>
    {% endif %}

    <div class="form-field">
        <label class="form-label">{{ t('admin_instances_customer_email', page_locale()) }}</label>
        <input name="email" value="{{ customerForm.email }}" class="form-input" placeholder="{{ t('admin_instances_customer_email_placeholder', page_locale()) }}">
    </div>
    <div class="form-field">
        <label class="form-label">{{ t('admin_instances_customer_password', page_locale()) }}</label>
        <input type="password" name="password" class="form-input" placeholder="{{ t('admin_instances_customer_password_placeholder', page_locale()) }}">
    </div>

    <div>
        <button type="submit" class="ui-button ui-button--primary">{{ t('admin_instances_customer_submit', page_locale()) }}</button>
    </div>
</form>
