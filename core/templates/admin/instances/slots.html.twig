{% extends 'admin/base.html.twig' %}

{% set activeNav = 'game-instances' %}

{% block content %}
<div style="display:flex;flex-direction:column;gap:20px;">

    {% if notice %}
        <div class="ng-alert ng-alert--success">{{ notice }}</div>
    {% endif %}
    {% if error %}
        <div class="ng-alert ng-alert--danger">{{ error }}</div>
    {% endif %}

    <div class="ng-data-card">
        <div class="ng-data-card__header">
            <div>
                <h2 class="ng-data-card__title">Instance Slots</h2>
                <p class="ng-data-card__sub">{{ instance.getServerName() ?? 'Instance' }} (ID {{ instance.getId() }})</p>
            </div>
            <div class="ng-data-card__actions">
                <a class="ui-button ui-button--ghost ui-button--sm" href="{{ path('admin_instances') }}">{{ t('admin_back_btn', page_locale()) }}</a>
            </div>
        </div>
        <div class="ng-data-card__body">
            <form method="post" style="display:flex;flex-direction:column;gap:16px;">
                <div style="display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:16px;">
                    <div class="form-field">
                        <label class="form-label">Max slots</label>
                        <input type="number" min="1" max="{{ app_setting('gameserver_max_slots', instance.getMaxSlots()) }}" name="max_slots" value="{{ instance.getMaxSlots() }}" class="form-input">
                    </div>
                    <div class="form-field">
                        <label class="form-label">Current slots</label>
                        <input type="number" min="1" max="{{ instance.getMaxSlots() }}" name="current_slots" value="{{ instance.getCurrentSlots() }}" class="form-input">
                    </div>
                </div>
                <label style="display:flex;align-items:center;gap:8px;font-size:.875rem;font-weight:500;">
                    <input type="checkbox" name="lock_slots" value="1" {% if instance.isLockSlots() %}checked{% endif %}>
                    Lock slots to max
                </label>
                <div>
                    <button type="submit" class="ui-button ui-button--primary">{{ t('action_save', page_locale()) }}</button>
                </div>
            </form>
        </div>
    </div>

</div>
{% endblock %}
