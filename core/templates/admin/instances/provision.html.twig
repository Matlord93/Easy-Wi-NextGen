{% extends 'admin/base.html.twig' %}

{% block content %}
<div class="flex flex-col gap-6">
    <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <div class="flex flex-wrap items-start justify-between gap-4">
            <div>
                <h1 class="text-2xl font-semibold text-slate-900">{{ t('admin_instances_provision_page_title', page_locale()) }}</h1>
                <p class="mt-2 text-sm text-slate-700">{{ t('admin_instances_provision_page_intro', page_locale()) }}</p>
                <p class="mt-2 text-xs text-emerald-700 font-medium">Automatik aktiv: Erstellen → Installieren → Kunde muss nur noch konfigurieren und starten.</p>
            </div>
            <a class="rounded-lg border border-slate-200 px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50" href="{{ path('admin_instances') }}">
                {{ t('admin_instances_back', page_locale()) }}
            </a>
        </div>
    </div>

    <div id="instance-form"
         class="rounded-xl bg-white border border-slate-200 shadow-sm"
         hx-get="{{ path('admin_instances_form') }}"
         hx-trigger="instances-form-refresh from:body"
         hx-swap="outerHTML">
        {% include 'admin/instances/_form.html.twig' with { customers: customers, nodes: nodes, templates: templates, form: form } %}
    </div>
</div>
{% endblock %}
