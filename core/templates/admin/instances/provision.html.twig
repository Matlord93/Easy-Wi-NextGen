{% extends 'admin/base.html.twig' %}

{% set activeNav = 'game-instances' %}

{% block content %}
<div style="display:flex;flex-direction:column;gap:20px;">

    <div class="ng-data-card">
        <div class="ng-data-card__header">
            <div>
                <h2 class="ng-data-card__title">{{ t('admin_instances_provision_page_title', page_locale()) }}</h2>
                <p class="ng-data-card__sub">{{ t('admin_instances_provision_page_intro', page_locale()) }}</p>
            </div>
            <div class="ng-data-card__actions">
                <a class="ui-button ui-button--ghost ui-button--sm" href="{{ path('admin_instances') }}">{{ t('admin_instances_back', page_locale()) }}</a>
            </div>
        </div>
    </div>

    <div class="ng-data-card">
        <div id="instance-form"
             hx-get="{{ path('admin_instances_form') }}"
             hx-trigger="instances-form-refresh from:body"
             hx-swap="outerHTML">
            {% include 'admin/instances/_form.html.twig' with { customers: customers, nodes: nodes, templates: templates, form: form } %}
        </div>
    </div>

</div>
{% endblock %}
