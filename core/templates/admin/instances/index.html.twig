{% extends 'admin/base.html.twig' %}

{% set pageTitle = t('admin_instances_title', page_locale()) %}
{% set pageSubtitle = 'Status, Ressourcen, SFTP und Setup auf einen Blick.' %}
{% set activeNav = 'game-instances' %}
{% set topbarActions = [
    { label: t('admin_instances_new', page_locale()), href: path('admin_instances_provision'), variant: 'primary' }
] %}

{% block content %}
<div class="flex flex-col gap-6">

    {# ── KPI Row ── #}
    <div class="ng-kpi-row">
        <div class="ng-kpi-box">
            <div class="ng-kpi-box__label">{{ t('admin_instances_total', page_locale()) }}</div>
            <div class="ng-kpi-box__value">{{ summary.total }}</div>
        </div>
        <div class="ng-kpi-box">
            <div class="ng-kpi-box__label">{{ t('admin_instances_running', page_locale()) }}</div>
            <div class="ng-kpi-box__value ng-kpi-box__value--success">{{ summary.running }}</div>
        </div>
        <div class="ng-kpi-box">
            <div class="ng-kpi-box__label">{{ t('admin_instances_pending_setup', page_locale()) }}</div>
            <div class="ng-kpi-box__value ng-kpi-box__value--warning">{{ summary.pending_setup }}</div>
        </div>
        <div class="ng-kpi-box">
            <div class="ng-kpi-box__label">{{ t('admin_instances_provisioning', page_locale()) }}</div>
            <div class="ng-kpi-box__value ng-kpi-box__value--info">{{ summary.provisioning }}</div>
        </div>
        <div class="ng-kpi-box">
            <div class="ng-kpi-box__label">{{ t('admin_instances_suspended', page_locale()) }}</div>
            <div class="ng-kpi-box__value ng-kpi-box__value--warning">{{ summary.suspended }}</div>
        </div>
        <div class="ng-kpi-box">
            <div class="ng-kpi-box__label">{{ t('admin_instances_needs_attention', page_locale()) }}</div>
            <div class="ng-kpi-box__value ng-kpi-box__value--danger">{{ summary.error }}</div>
        </div>
    </div>

    {# ── Ops Overview ── #}
    <div class="ng-data-card">
        <div class="ng-data-card__header">
            <div>
                <h2 class="ng-data-card__title">{{ t('admin_instances_ops_overview_title', page_locale()) }}</h2>
                <p class="ng-data-card__sub">{{ t('admin_instances_ops_overview_intro', page_locale()) }}</p>
            </div>
        </div>
        <div class="ng-data-card__body">
            <div class="ng-ops-grid">
                <div class="ng-ops-box">
                    <div class="ng-ops-box__label">{{ t('admin_instances_ops_offline_agents', page_locale()) }}</div>
                    <div class="ng-ops-box__value ng-ops-box__value--danger">{{ ops.offline_agents }}</div>
                </div>
                <div class="ng-ops-box">
                    <div class="ng-ops-box__label">{{ t('admin_instances_ops_disk_warnings', page_locale()) }}</div>
                    <div class="ng-ops-box__value ng-ops-box__value--warning">{{ ops.disk_problem_instances }}</div>
                </div>
                <div class="ng-ops-box">
                    <div class="ng-ops-box__label">{{ t('admin_instances_ops_runtime_unknown', page_locale()) }}</div>
                    <div class="ng-ops-box__value ng-ops-box__value--info">{{ ops.runtime_unknown_instances }}</div>
                </div>
                <div class="ng-ops-box">
                    <div class="ng-ops-box__label">{{ t('admin_instances_ops_blocked_schedules', page_locale()) }}</div>
                    <div class="ng-ops-box__value ng-ops-box__value--danger">{{ ops.blocked_schedules }}</div>
                </div>
            </div>
        </div>
    </div>

    {# ── Flash notice ── #}
    {% if createNotice %}
        <div class="ng-alert ng-alert--{{ createNotice.type == 'success' ? 'success' : 'warning' }}">
            {{ createNotice.message }}
        </div>
    {% endif %}

    {# ── Instances Table ── #}
    <div class="ng-data-card">
        <div class="ng-data-card__header">
            <div>
                <h2 class="ng-data-card__title">{{ t('admin_instances_title', page_locale()) }}</h2>
                <p class="ng-data-card__sub">Alle verwalteten Game-Server Instanzen</p>
            </div>
            <div class="ng-data-card__actions">
                <button
                    class="ui-button ui-button--ghost ui-button--sm"
                    hx-get="{{ path('admin_instances_table') }}"
                    hx-target="#instances-table"
                    hx-swap="outerHTML"
                >
                    <svg viewBox="0 0 16 16" fill="currentColor"><path d="M11.534 7h3.932a.25.25 0 0 1 .192.41l-1.966 2.36a.25.25 0 0 1-.384 0l-1.966-2.36a.25.25 0 0 1 .192-.41zm-11 2h3.932a.25.25 0 0 0 .192-.41L2.692 6.23a.25.25 0 0 0-.384 0L.342 8.59A.25.25 0 0 0 .534 9z"/><path fill-rule="evenodd" d="M8 3c-1.552 0-2.94.707-3.857 1.818a.5.5 0 1 1-.771-.636A6.002 6.002 0 0 1 13.917 7H12.9A5.002 5.002 0 0 0 8 3zM3.1 9a5.002 5.002 0 0 0 8.757 2.182.5.5 0 1 1 .771.636A6.002 6.002 0 0 1 2.083 9H3.1z"/></svg>
                    {{ t('admin_instances_refresh', page_locale()) }}
                </button>
                <a class="ui-button ui-button--primary ui-button--sm" href="{{ path('admin_instances_provision') }}">
                    <svg viewBox="0 0 16 16" fill="currentColor"><path d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4z"/></svg>
                    {{ t('admin_instances_new', page_locale()) }}
                </a>
            </div>
        </div>
        <div class="ng-data-card__body--flush">
            <div id="instances-table"
                 hx-get="{{ path('admin_instances_table') }}"
                 hx-trigger="instances-changed from:body"
                 hx-swap="outerHTML">
                {% include 'admin/instances/_table.html.twig' with { instances: instances } %}
            </div>
        </div>
    </div>

</div>
{% endblock %}
