{% extends 'admin/base.html.twig' %}

{% set activeNav = 'game-instances' %}

{% block content %}
<div style="display:flex;flex-direction:column;gap:20px;">

    <div class="ng-data-card">
        <div class="ng-data-card__header">
            <div>
                <h2 class="ng-data-card__title">{{ t('admin_instances_new_title', page_locale()) }}</h2>
                <p class="ng-data-card__sub">{{ t('admin_instances_new_intro', page_locale()) }}</p>
            </div>
            <div class="ng-data-card__actions">
                <a class="ui-button ui-button--ghost ui-button--sm" href="{{ path('admin_instances') }}">{{ t('admin_instances_back', page_locale()) }}</a>
            </div>
        </div>
        <div class="ng-data-card__body">
            <h2 style="font-size:1rem;font-weight:600;margin-bottom:8px;">{{ t('admin_instances_new_overview_title', page_locale()) }}</h2>
            <p style="font-size:.875rem;color:var(--color-text-muted,#64748b);margin-bottom:12px;">{{ t('admin_instances_new_overview_intro', page_locale()) }}</p>
            <ul style="font-size:.875rem;color:var(--color-text-muted,#64748b);display:flex;flex-direction:column;gap:6px;margin-bottom:16px;padding-left:18px;">
                <li>{{ t('admin_instances_new_overview_step_template', page_locale()) }}</li>
                <li>{{ t('admin_instances_new_overview_step_customer', page_locale()) }}</li>
                <li>{{ t('admin_instances_new_overview_step_resources', page_locale()) }}</li>
            </ul>
            <p style="font-size:.875rem;color:var(--color-text-muted,#64748b);margin-bottom:20px;">{{ t('admin_instances_new_overview_note', page_locale()) }}</p>
            <a class="ui-button ui-button--primary" href="{{ path('admin_instances_provision') }}">
                {{ t('admin_instances_new_action', page_locale()) }}
            </a>
        </div>
    </div>

</div>
{% endblock %}
