{% set locale = page_locale() %}
<div class="divide-y divide-slate-100">
    {% for message in messages %}
        {% set isAdmin = message.author.type in ['admin', 'superadmin', 'reseller'] %}
        <div class="px-6 py-5 {{ isAdmin ? 'bg-indigo-50' : 'bg-white' }}">
            <div class="flex items-start gap-3">
                <div class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full text-xs font-bold {{ isAdmin ? 'bg-indigo-600 text-white' : 'bg-slate-200 text-slate-600' }}">
                    {{ message.author.email|slice(0,1)|upper }}
                </div>
                <div class="flex-1 min-w-0">
                    <div class="flex items-baseline gap-2">
                        <span class="text-sm font-semibold {{ isAdmin ? 'text-indigo-900' : 'text-slate-900' }}">{{ message.author.email }}</span>
                        <span class="text-xs text-slate-400">{{ message.created_at|date('d.m.Y H:i') }}</span>
                        {% if isAdmin %}
                            <span class="rounded-full bg-indigo-100 px-2 py-0.5 text-xs font-medium text-indigo-700">{{ t('type', locale) }}</span>
                        {% endif %}
                    </div>
                    <p class="mt-2 whitespace-pre-line text-sm {{ isAdmin ? 'text-indigo-800' : 'text-slate-700' }}">{{ message.body }}</p>
                </div>
            </div>
        </div>
    {% else %}
        <div class="px-6 py-8 text-center text-sm text-slate-500">{{ t('admin_tickets_messages_empty', locale) }}</div>
    {% endfor %}
</div>
