{% extends 'admin/base.html.twig' %}
{% set pageTitle = t('admin_tickets_heading', page_locale()) %}
{% set pageSubtitle = t('admin_tickets_intro', page_locale()) %}
{% set activeNav = 'tickets' %}
{% set locale = page_locale() %}

{% block content %}
{% set statusLabels = {
    'open':     t('admin_tickets_status_open', locale),
    'pending':  t('admin_tickets_status_pending', locale),
    'resolved': t('admin_tickets_status_resolved', locale),
    'closed':   t('admin_tickets_status_closed', locale),
} %}
{% set priorityLabels = {
    'low':    t('admin_tickets_priority_label_low', locale),
    'normal': t('admin_tickets_priority_label_normal', locale),
    'high':   t('admin_tickets_priority_label_high', locale),
    'urgent': t('admin_tickets_priority_label_urgent', locale),
} %}
{% set categoryLabels = {
    'general':   t('admin_tickets_category_label_general', locale),
    'billing':   t('admin_tickets_category_label_billing', locale),
    'technical': t('admin_tickets_category_label_technical', locale),
    'abuse':     t('admin_tickets_category_label_abuse', locale),
} %}

{% set oldestOpen = null %}
{% for ticket in tickets %}
    {% if ticket.status in ['open', 'pending'] %}
        {% if oldestOpen is null or ticket.id < oldestOpen.id %}
            {% set oldestOpen = ticket %}
        {% endif %}
    {% endif %}
{% endfor %}

<div style="display:flex;flex-direction:column;gap:20px;">

    {% if success is not empty %}
        <div class="ng-alert ng-alert--success">
            <ul style="margin:0;padding-left:18px;">{% for msg in success %}<li>{{ msg }}</li>{% endfor %}</ul>
        </div>
    {% endif %}

    {# ── Hero with KPI ── #}
    <section class="ng-card" style="overflow:hidden;">
        <div class="tkt-hero">
            <div class="tkt-hero__inner">
                <div style="display:flex;flex-direction:column;gap:16px;">
                    <div>
                        <div class="tkt-hero__pill">
                            <span class="tkt-hero__pill-dot"></span>
                            {{ t('admin_tickets_workbench_label', locale) }}
                        </div>
                        <h1 class="tkt-hero__title" style="margin-top:10px;">{{ t('admin_tickets_heading', locale) }}</h1>
                        <p class="tkt-hero__sub">{{ t('admin_tickets_workbench_intro', locale) }}</p>
                    </div>
                    <div style="display:grid;grid-template-columns:repeat(5,minmax(0,1fr));gap:10px;">
                        <div class="tkt-kpi tkt-kpi--open">
                            <div class="tkt-kpi__label">{{ t('ticket_ui_kpi_open_tickets', locale) }}</div>
                            <div class="tkt-kpi__value">{{ summary.open }}</div>
                        </div>
                        <div class="tkt-kpi tkt-kpi--pending">
                            <div class="tkt-kpi__label">{{ t('ticket_ui_kpi_waiting_customer', locale) }}</div>
                            <div class="tkt-kpi__value">{{ summary.pending }}</div>
                        </div>
                        <div class="tkt-kpi" style="border-color:rgba(239,68,68,.25);background:rgba(239,68,68,.07);">
                            <div class="tkt-kpi__label" style="color:rgba(252,165,165,.7);">{{ t('ticket_ui_kpi_high_priority', locale) }}</div>
                            <div class="tkt-kpi__value" style="color:#fca5a5;">{{ summary.high_priority }}</div>
                        </div>
                        <div class="tkt-kpi tkt-kpi--resolved">
                            <div class="tkt-kpi__label">{{ t('ticket_ui_kpi_resolved_today', locale) }}</div>
                            <div class="tkt-kpi__value">{{ summary.resolved_today }}</div>
                        </div>
                        <div class="tkt-kpi">
                            <div class="tkt-kpi__label">{{ t('ticket_ui_my_tickets', locale) }}</div>
                            <div class="tkt-kpi__value">{{ summary.assigned_to_me }}</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        {# ── Action bar ── #}
        <div style="display:grid;grid-template-columns:1.2fr .8fr;gap:12px;padding:16px;border-top:1px solid var(--ng-border);background:var(--ng-surface-soft);">
            {% if oldestOpen %}
                {% set nowTs = date()|date('U') %}
                {% set createdTs = oldestOpen.created_at|date('U') %}
                {% set ageDays = ((nowTs - createdTs) / 86400)|round(0, 'floor') %}
                <a href="/admin/tickets/{{ oldestOpen.id }}" class="tkt-oldest">
                    <div style="display:flex;align-items:center;gap:14px;min-width:0;">
                        <div class="tkt-oldest__icon">
                            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                        </div>
                        <div style="min-width:0;">
                            <div class="tkt-oldest__label">{{ t('admin_tickets_oldest_open_banner_title', locale) }}</div>
                            <div class="tkt-oldest__subject">#{{ oldestOpen.id }} — {{ oldestOpen.subject }}</div>
                            <div class="tkt-oldest__meta">{{ oldestOpen.customer.email }} · {{ ageDays == 0 ? t('admin_tickets_age_today', locale) : ageDays ~ t('admin_tickets_age_days_suffix', locale) }} · {{ priorityLabels[oldestOpen.priority] ?? oldestOpen.priority }}</div>
                        </div>
                    </div>
                    <div class="tkt-oldest__btn">
                        {{ t('admin_tickets_oldest_open_open', locale) }}
                        <svg style="width:14px;height:14px;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
                    </div>
                </a>
            {% else %}
                <div class="tkt-all-clear">
                    <div class="tkt-all-clear__icon">
                        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    </div>
                    <div>
                        <p style="margin:0;font-size:14px;font-weight:700;color:var(--ng-text);">{{ t('admin_tickets_no_oldest', locale) }}</p>
                        <p style="margin:3px 0 0;font-size:12px;color:var(--ng-text-muted);">{{ t('admin_tickets_focus_empty', locale) }}</p>
                    </div>
                </div>
            {% endif %}
            <div style="display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:10px;">
                <button type="button" class="tkt-qa" onclick="document.getElementById('new-ticket-section').classList.toggle('hidden')">
                    <div class="tkt-qa__icon">+</div>
                    <div class="tkt-qa__title">{{ t('admin_tickets_new_ticket_btn', locale) }}</div>
                    <div class="tkt-qa__sub">{{ t('admin_tickets_create_shortcut', locale) }}</div>
                </button>
                <button type="button" class="tkt-qa" hx-get="/admin/tickets/table" hx-target="#tickets-table-wrap" hx-swap="outerHTML">
                    <div class="tkt-qa__icon" style="background:var(--ng-surface);color:var(--ng-text-muted);">↻</div>
                    <div class="tkt-qa__title">{{ t('refresh', locale) }}</div>
                    <div class="tkt-qa__sub">{{ t('admin_tickets_refresh_hint', locale) }}</div>
                </button>
                <a href="#ticket-tools" class="tkt-qa">
                    <div class="tkt-qa__icon" style="background:var(--ng-surface);color:var(--ng-text-muted);">⌘</div>
                    <div class="tkt-qa__title">{{ t('admin_tickets_section_tools', locale) }}</div>
                    <div class="tkt-qa__sub">{{ t('admin_tickets_tools_hint', locale) }}</div>
                </a>
            </div>
        </div>
    </section>

    {# ── Ticket list ── #}
    <section class="ng-card" style="overflow:hidden;">
        <div class="tkt-filter-bar">
            <div class="tkt-filter-bar__top">
                <div>
                    <h2 class="tkt-filter-bar__title">{{ t('admin_tickets_inbox_title', locale) }}</h2>
                    <p class="tkt-filter-bar__sub">{{ t('ticket_ui_admin_filter_intro', locale) }}</p>
                </div>
                <button type="button" class="ui-button ui-button--primary" onclick="document.getElementById('new-ticket-section').classList.remove('hidden')">+ {{ t('ticket_ui_create_ticket', locale) }}</button>
            </div>
            <form id="admin-ticket-filters" method="get" action="/admin/tickets" style="display:grid;grid-template-columns:minmax(200px,1.4fr) repeat(4,minmax(130px,1fr)) auto;gap:8px;align-items:end;">
                <div class="form-field">
                    <label class="form-label">{{ t('ticket_ui_search', locale) }}</label>
                    <input name="q" value="{{ filters.q|default('') }}" placeholder="{{ t('ticket_ui_admin_search_placeholder', locale) }}">
                </div>
                <div class="form-field">
                    <label class="form-label">{{ t('ticket_ui_status', locale) }}</label>
                    <select name="status">
                        <option value="">{{ t('ticket_ui_all_statuses', locale) }}</option>
                        {% for value,label in statusLabels %}<option value="{{ value }}" {{ filters.status|default('') == value ? 'selected' : '' }}>{{ label }}</option>{% endfor %}
                    </select>
                </div>
                <div class="form-field">
                    <label class="form-label">{{ t('ticket_ui_priority', locale) }}</label>
                    <select name="priority">
                        <option value="">{{ t('ticket_ui_all_priorities', locale) }}</option>
                        {% for value,label in priorityLabels %}<option value="{{ value }}" {{ filters.priority|default('') == value ? 'selected' : '' }}>{{ label }}</option>{% endfor %}
                    </select>
                </div>
                <div class="form-field">
                    <label class="form-label">{{ t('ticket_ui_category', locale) }}</label>
                    <select name="category">
                        <option value="">{{ t('ticket_ui_all_categories', locale) }}</option>
                        {% for value,label in categoryLabels %}<option value="{{ value }}" {{ filters.category|default('') == value ? 'selected' : '' }}>{{ label }}</option>{% endfor %}
                    </select>
                </div>
                <div class="form-field">
                    <label class="form-label">{{ t('ticket_ui_assignee', locale) }}</label>
                    <select name="assignee">
                        <option value="">{{ t('ticket_ui_all_assignees', locale) }}</option>
                        <option value="me" {{ filters.assignee|default('') == 'me' ? 'selected' : '' }}>{{ t('ticket_ui_my_tickets', locale) }}</option>
                        <option value="unassigned" {{ filters.assignee|default('') == 'unassigned' ? 'selected' : '' }}>{{ t('ticket_ui_unassigned', locale) }}</option>
                        {% for staff in staffUsers|default([]) %}
                            <option value="{{ staff.id }}" {{ filters.assignee|default('') == (staff.id ~ '') ? 'selected' : '' }}>{{ staff.email }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div style="display:flex;gap:6px;align-self:flex-end;">
                    <button type="submit" class="ui-button ui-button--primary">{{ t('ticket_ui_filter', locale) }}</button>
                    <a href="/admin/tickets" class="ui-button ui-button--ghost">{{ t('ticket_ui_reset', locale) }}</a>
                </div>
            </form>
        </div>
        {% include 'admin/tickets/_table.html.twig' with {
            tickets: tickets,
            statusStyles: statusStyles,
            priorityStyles: priorityStyles,
            statusLabels: statusLabels,
            priorityLabels: priorityLabels,
            categoryLabels: categoryLabels
        } %}
    </section>

    {# ── New ticket (hidden) ── #}
    <div id="new-ticket-section" class="hidden">
        <div id="ticket-form" hx-trigger="tickets-changed from:body" hx-get="/admin/tickets/form" hx-swap="outerHTML">
            {% include 'admin/tickets/_form.html.twig' with {
                form: form,
                customers: customers,
                templates: templates,
                adminSignature: adminSignature
            } %}
        </div>
    </div>

    {# ── Tools (templates + quick replies) ── #}
    <details id="ticket-tools" class="ng-card" style="overflow:hidden;">
        <summary style="display:flex;align-items:center;justify-content:space-between;padding:16px 20px;cursor:pointer;user-select:none;list-style:none;color:var(--ng-text);font-size:14px;font-weight:700;transition:background .15s;">
            <span>{{ t('admin_tickets_section_tools', locale) }}</span>
            <svg style="width:16px;height:16px;color:var(--ng-text-muted);transition:transform .2s;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
        </summary>
        <summary::-webkit-details-marker { display:none; }
        <div style="border-top:1px solid var(--ng-border);padding:20px;">
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;">

                {# Ticket Templates #}
                <div style="display:flex;flex-direction:column;gap:14px;">
                    <div>
                        <h3 style="margin:0;font-size:14px;font-weight:700;color:var(--ng-text);">{{ t('admin_tickets_templates_title', locale) }}</h3>
                        <p style="margin:3px 0 0;font-size:12px;color:var(--ng-text-muted);">{{ t('admin_tickets_templates_intro', locale) }}</p>
                    </div>
                    {% if templateErrors is not empty %}
                        <div class="ng-alert ng-alert--danger"><ul style="margin:0;padding-left:18px;">{% for error in templateErrors %}<li>{{ error }}</li>{% endfor %}</ul></div>
                    {% endif %}
                    <form method="post" action="/admin/tickets/templates" style="display:flex;flex-direction:column;gap:12px;background:var(--ng-surface-soft);border:1px solid var(--ng-border);border-radius:var(--ng-radius);padding:16px;">
                        <input type="hidden" name="_token" value="{{ csrf_token('admin_ticket_template_create') }}">
                        <div class="form-field"><label class="form-label">{{ t('admin_tickets_template_title', locale) }}</label><input name="title" value="{{ templateForm.title }}"></div>
                        <div class="form-field"><label class="form-label">{{ t('admin_tickets_template_subject', locale) }}</label><input name="subject" value="{{ templateForm.subject }}"></div>
                        <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
                            <div class="form-field"><label class="form-label">{{ t('admin_tickets_form_category', locale) }}</label>
                                <select name="category">
                                    <option value="general" {{ templateForm.category == 'general' ? 'selected' : '' }}>{{ t('admin_tickets_category_general', locale) }}</option>
                                    <option value="billing" {{ templateForm.category == 'billing' ? 'selected' : '' }}>{{ t('admin_tickets_category_billing', locale) }}</option>
                                    <option value="technical" {{ templateForm.category == 'technical' ? 'selected' : '' }}>{{ t('admin_tickets_category_technical', locale) }}</option>
                                    <option value="abuse" {{ templateForm.category == 'abuse' ? 'selected' : '' }}>{{ t('admin_tickets_category_abuse', locale) }}</option>
                                </select>
                            </div>
                            <div class="form-field"><label class="form-label">{{ t('admin_tickets_form_priority', locale) }}</label>
                                <select name="priority">
                                    <option value="low" {{ templateForm.priority == 'low' ? 'selected' : '' }}>{{ t('admin_tickets_priority_low', locale) }}</option>
                                    <option value="normal" {{ templateForm.priority == 'normal' ? 'selected' : '' }}>{{ t('admin_tickets_priority_normal', locale) }}</option>
                                    <option value="high" {{ templateForm.priority == 'high' ? 'selected' : '' }}>{{ t('admin_tickets_priority_high', locale) }}</option>
                                    <option value="urgent" {{ templateForm.priority == 'urgent' ? 'selected' : '' }}>{{ t('admin_tickets_priority_urgent', locale) }}</option>
                                </select>
                            </div>
                        </div>
                        <div class="form-field"><label class="form-label">{{ t('admin_tickets_template_body', locale) }}</label><textarea name="body" rows="4">{{ templateForm.body }}</textarea></div>
                        <div><button type="submit" class="ui-button ui-button--primary ui-button--sm">{{ t('admin_tickets_template_create', locale) }}</button></div>
                    </form>
                    {% if templates is empty %}
                        <p style="text-align:center;font-size:13px;color:var(--ng-text-muted);">{{ t('admin_tickets_templates_empty', locale) }}</p>
                    {% else %}
                        <div style="display:flex;flex-direction:column;gap:10px;">
                            {% for template in templates %}
                                <form method="post" action="/admin/tickets/templates/{{ template.id }}" style="display:flex;flex-direction:column;gap:8px;background:var(--ng-surface-soft);border:1px solid var(--ng-border);border-radius:var(--ng-radius);padding:14px;">
                                    <input type="hidden" name="_token" value="{{ csrf_token('admin_ticket_template_' ~ template.id) }}">
                                    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:4px;">
                                        <span style="font-size:12px;font-weight:700;color:var(--ng-text);">{{ template.title }}</span>
                                        <span style="font-size:11px;color:var(--ng-text-muted);">{{ template.updated_at|date('d.m.Y H:i') }}</span>
                                    </div>
                                    <input name="title" value="{{ template.title }}" class="form-input">
                                    <input name="subject" value="{{ template.subject }}" class="form-input">
                                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;">
                                        <select name="category" class="form-input">
                                            <option value="general" {{ template.category == 'general' ? 'selected' : '' }}>{{ t('admin_tickets_category_general', locale) }}</option>
                                            <option value="billing" {{ template.category == 'billing' ? 'selected' : '' }}>{{ t('admin_tickets_category_billing', locale) }}</option>
                                            <option value="technical" {{ template.category == 'technical' ? 'selected' : '' }}>{{ t('admin_tickets_category_technical', locale) }}</option>
                                            <option value="abuse" {{ template.category == 'abuse' ? 'selected' : '' }}>{{ t('admin_tickets_category_abuse', locale) }}</option>
                                        </select>
                                        <select name="priority" class="form-input">
                                            <option value="low" {{ template.priority == 'low' ? 'selected' : '' }}>{{ t('admin_tickets_priority_low', locale) }}</option>
                                            <option value="normal" {{ template.priority == 'normal' ? 'selected' : '' }}>{{ t('admin_tickets_priority_normal', locale) }}</option>
                                            <option value="high" {{ template.priority == 'high' ? 'selected' : '' }}>{{ t('admin_tickets_priority_high', locale) }}</option>
                                            <option value="urgent" {{ template.priority == 'urgent' ? 'selected' : '' }}>{{ t('admin_tickets_priority_urgent', locale) }}</option>
                                        </select>
                                    </div>
                                    <textarea name="body" rows="3" class="form-input">{{ template.body }}</textarea>
                                    <div style="display:flex;gap:8px;">
                                        <button type="submit" class="ui-button ui-button--ghost ui-button--sm">{{ t('admin_tickets_template_save', locale) }}</button>
                                        <button type="submit" name="_token" value="{{ csrf_token('admin_ticket_template_delete_' ~ template.id) }}" formaction="/admin/tickets/templates/{{ template.id }}/delete" class="ui-button ui-button--danger ui-button--sm">{{ t('admin_tickets_template_delete', locale) }}</button>
                                    </div>
                                </form>
                            {% endfor %}
                        </div>
                    {% endif %}
                </div>

                {# Quick Replies #}
                <div style="display:flex;flex-direction:column;gap:14px;">
                    <div>
                        <h3 style="margin:0;font-size:14px;font-weight:700;color:var(--ng-text);">{{ t('admin_tickets_quick_replies_title', locale) }}</h3>
                        <p style="margin:3px 0 0;font-size:12px;color:var(--ng-text-muted);">{{ t('admin_tickets_quick_replies_intro', locale) }}</p>
                    </div>
                    {% if quickReplyErrors is not empty %}
                        <div class="ng-alert ng-alert--danger"><ul style="margin:0;padding-left:18px;">{% for error in quickReplyErrors %}<li>{{ error }}</li>{% endfor %}</ul></div>
                    {% endif %}
                    <form method="post" action="/admin/tickets/quick-replies" style="display:flex;flex-direction:column;gap:12px;background:var(--ng-surface-soft);border:1px solid var(--ng-border);border-radius:var(--ng-radius);padding:16px;">
                        <input type="hidden" name="_token" value="{{ csrf_token('admin_ticket_quick_reply_create') }}">
                        <div class="form-field"><label class="form-label">{{ t('admin_tickets_quick_reply_title', locale) }}</label><input name="title" value="{{ quickReplyForm.title }}"></div>
                        <div class="form-field"><label class="form-label">{{ t('admin_tickets_quick_reply_body', locale) }}</label><textarea name="body" rows="4">{{ quickReplyForm.body }}</textarea></div>
                        <div><button type="submit" class="ui-button ui-button--primary ui-button--sm">{{ t('admin_tickets_quick_reply_create', locale) }}</button></div>
                    </form>
                    {% if quickReplies is empty %}
                        <p style="text-align:center;font-size:13px;color:var(--ng-text-muted);">{{ t('admin_tickets_quick_replies_empty', locale) }}</p>
                    {% else %}
                        <div style="display:flex;flex-direction:column;gap:10px;">
                            {% for reply in quickReplies %}
                                <form method="post" action="/admin/tickets/quick-replies/{{ reply.id }}" style="display:flex;flex-direction:column;gap:8px;background:var(--ng-surface-soft);border:1px solid var(--ng-border);border-radius:var(--ng-radius);padding:14px;">
                                    <input type="hidden" name="_token" value="{{ csrf_token('admin_ticket_quick_reply_' ~ reply.id) }}">
                                    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:4px;">
                                        <span style="font-size:12px;font-weight:700;color:var(--ng-text);">{{ reply.title }}</span>
                                        <span style="font-size:11px;color:var(--ng-text-muted);">{{ reply.updated_at|date('d.m.Y H:i') }}</span>
                                    </div>
                                    <input name="title" value="{{ reply.title }}" class="form-input">
                                    <textarea name="body" rows="3" class="form-input">{{ reply.body }}</textarea>
                                    <div style="display:flex;gap:8px;">
                                        <button type="submit" class="ui-button ui-button--ghost ui-button--sm">{{ t('admin_tickets_quick_reply_save', locale) }}</button>
                                        <button type="submit" name="_token" value="{{ csrf_token('admin_ticket_quick_reply_delete_' ~ reply.id) }}" formaction="/admin/tickets/quick-replies/{{ reply.id }}/delete" class="ui-button ui-button--danger ui-button--sm">{{ t('admin_tickets_quick_reply_delete', locale) }}</button>
                                    </div>
                                </form>
                            {% endfor %}
                        </div>
                    {% endif %}
                </div>

            </div>
        </div>
    </details>

</div>
{% endblock %}
