{% extends 'admin/base.html.twig' %}
{% set locale = page_locale() %}
{% set activeNav = 'tickets' %}

{% set statusLabels = {
    'open':     t('admin_tickets_status_open', locale),
    'pending':  t('admin_tickets_status_pending', locale),
    'resolved': t('admin_tickets_status_resolved', locale),
    'closed':   t('admin_tickets_status_closed', locale),
} %}
{% set priorityLabels = {
    'low':    t('admin_tickets_priority_label_low', locale),
    'normal': t('admin_tickets_priority_label_normal', locale),
    'high':   t('admin_tickets_priority_label_high', locale),
    'urgent': t('admin_tickets_priority_label_urgent', locale),
} %}
{% set categoryLabels = {
    'general':   t('admin_tickets_category_label_general', locale),
    'billing':   t('admin_tickets_category_label_billing', locale),
    'technical': t('admin_tickets_category_label_technical', locale),
    'abuse':     t('admin_tickets_category_label_abuse', locale),
} %}

{% block content %}
<div class="flex flex-col gap-5">

    {# Ticket header card #}
    <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
        <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
            <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 mb-1">
                    <a href="/admin/tickets" class="text-xs text-slate-500 hover:text-slate-700">← {{ t('admin_tickets_heading', locale) }}</a>
                    <span class="text-xs text-slate-300">/</span>
                    <span class="text-xs font-mono text-slate-500">#{{ ticket.id }}</span>
                </div>
                <h1 class="text-xl font-bold text-slate-900 truncate">{{ ticket.subject }}</h1>
                <p class="mt-1 text-sm text-slate-500">
                    {{ categoryLabels[ticket.category] ?? ticket.category }}
                    · {{ ticket.customer.email }}
                    · {{ t('admin_ticket_timestamps', locale)|replace({'%created%': ticket.created_at|date('d.m.Y H:i'), '%updated%': ticket.last_message_at|date('d.m.Y H:i')}) }}
                </p>
            </div>
            <div class="flex flex-wrap items-center gap-3 flex-shrink-0">
                <div id="ticket-status-badge">
                    {% include 'admin/tickets/_status_badge.html.twig' with { ticket: ticket, statusStyles: statusStyles, statusLabels: statusLabels } %}
                </div>
                <span class="inline-flex items-center rounded-full border px-3 py-1 text-xs font-semibold {{ priorityStyles[ticket.priority] ?? 'border-slate-200 bg-slate-50 text-slate-600' }}">
                    {{ priorityLabels[ticket.priority] ?? ticket.priority }}
                </span>
                <form class="flex items-center gap-2" method="post" action="/admin/tickets/{{ ticket.id }}/status" hx-post="/admin/tickets/{{ ticket.id }}/status" hx-target="#ticket-status-badge" hx-swap="outerHTML">
                    <select name="status" class="rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm">
                        <option value="open" {{ ticket.status == 'open' ? 'selected' : '' }}>{{ statusLabels.open }}</option>
                        <option value="pending" {{ ticket.status == 'pending' ? 'selected' : '' }}>{{ statusLabels.pending }}</option>
                        <option value="resolved" {{ ticket.status == 'resolved' ? 'selected' : '' }}>{{ statusLabels.resolved }}</option>
                        <option value="closed" {{ ticket.status == 'closed' ? 'selected' : '' }}>{{ statusLabels.closed }}</option>
                    </select>
                    <button type="submit" class="ui-button ui-button--ghost ui-button--sm">{{ t('admin_tickets_update_status', locale) }}</button>
                </form>
            </div>
        </div>
    </div>

    {# Conversation + reply side by side #}
    <div class="grid grid-cols-1 gap-5 lg:grid-cols-[1fr_380px]">

        {# Message thread #}
        <div class="rounded-xl border border-slate-200 bg-white shadow-sm">
            <div class="border-b border-slate-200 px-6 py-4">
                <h2 class="text-base font-semibold text-slate-900">{{ t('admin_tickets_conversation_title', locale) }}</h2>
                <p class="text-xs text-slate-500">{{ t('admin_tickets_conversation_intro', locale) }}</p>
            </div>
            <div id="ticket-messages">
                {% include 'admin/tickets/_messages.html.twig' with { ticket: ticket, messages: messages, statusStyles: statusStyles, priorityStyles: priorityStyles, statusLabels: statusLabels } %}
            </div>
        </div>

        {# Reply form #}
        <div class="rounded-xl border border-slate-200 bg-white shadow-sm self-start sticky top-5">
            {% include 'admin/tickets/_message_form.html.twig' with { ticket: ticket, quickReplies: quickReplies, adminSignature: adminSignature, locale: locale } %}
        </div>

    </div>
</div>
{% endblock %}
