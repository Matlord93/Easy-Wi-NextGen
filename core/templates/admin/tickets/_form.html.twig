{% set locale = page_locale() %}
<div class="ng-card" style="overflow:hidden;">
    <div style="padding:18px 20px;border-bottom:1px solid var(--ng-border);">
        <h2 style="margin:0;font-size:15px;font-weight:700;color:var(--ng-text);">{{ t('admin_tickets_form_title', locale) }}</h2>
        <p style="margin:3px 0 0;font-size:12px;color:var(--ng-text-muted);">{{ t('admin_tickets_form_intro', locale) }}</p>
    </div>
    <form style="padding:20px;display:flex;flex-direction:column;gap:14px;" method="post" action="/admin/tickets" enctype="multipart/form-data" hx-encoding="multipart/form-data" hx-post="/admin/tickets" hx-target="#ticket-form" hx-swap="outerHTML">
        <input type="hidden" name="_token" value="{{ csrf_token('admin_ticket_create') }}">

        {% if form.errors is not empty %}
            <div class="ng-alert ng-alert--danger">
                <ul style="margin:0;padding-left:18px;">{% for error in form.errors %}<li>{{ error }}</li>{% endfor %}</ul>
            </div>
        {% endif %}

        {% if templates is not empty %}
            <div class="form-field">
                <label class="form-label">{{ t('admin_tickets_template_label', locale) }}</label>
                <select id="admin-ticket-template-select">
                    <option value="">{{ t('admin_tickets_template_placeholder', locale) }}</option>
                    {% for template in templates %}
                        <option value="{{ template.id }}"
                            data-subject="{{ template.subject|e('html_attr') }}"
                            data-category="{{ template.category }}"
                            data-priority="{{ template.priority }}"
                            data-body="{{ template.body|e('html_attr') }}"
                        >{{ template.title }}</option>
                    {% endfor %}
                </select>
            </div>
        {% endif %}

        <div class="form-field">
            <label class="form-label">{{ t('admin_tickets_form_customer', locale) }}</label>
            <select name="customer_id">
                <option value="">{{ t('admin_tickets_form_customer_select', locale) }}</option>
                {% for customer in customers %}
                    <option value="{{ customer.id }}" {{ form.customer_id == customer.id ? 'selected' : '' }}>{{ customer.email }}</option>
                {% endfor %}
            </select>
        </div>

        <div class="form-field">
            <label class="form-label">{{ t('admin_tickets_form_subject', locale) }}</label>
            <input id="admin-ticket-subject" name="subject" value="{{ form.subject }}" placeholder="{{ t('admin_tickets_form_subject_placeholder', locale) }}">
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
            <div class="form-field">
                <label class="form-label">{{ t('admin_tickets_form_category', locale) }}</label>
                <select id="admin-ticket-category" name="category">
                    <option value="general" {{ form.category == 'general' ? 'selected' : '' }}>{{ t('admin_tickets_category_general', locale) }}</option>
                    <option value="billing" {{ form.category == 'billing' ? 'selected' : '' }}>{{ t('admin_tickets_category_billing', locale) }}</option>
                    <option value="technical" {{ form.category == 'technical' ? 'selected' : '' }}>{{ t('admin_tickets_category_technical', locale) }}</option>
                    <option value="abuse" {{ form.category == 'abuse' ? 'selected' : '' }}>{{ t('admin_tickets_category_abuse', locale) }}</option>
                </select>
            </div>
            <div class="form-field">
                <label class="form-label">{{ t('admin_tickets_form_priority', locale) }}</label>
                <select id="admin-ticket-priority" name="priority">
                    <option value="low" {{ form.priority == 'low' ? 'selected' : '' }}>{{ t('admin_tickets_priority_low', locale) }}</option>
                    <option value="normal" {{ form.priority == 'normal' ? 'selected' : '' }}>{{ t('admin_tickets_priority_normal', locale) }}</option>
                    <option value="high" {{ form.priority == 'high' ? 'selected' : '' }}>{{ t('admin_tickets_priority_high', locale) }}</option>
                    <option value="urgent" {{ form.priority == 'urgent' ? 'selected' : '' }}>{{ t('admin_tickets_priority_urgent', locale) }}</option>
                </select>
            </div>
        </div>

        <div class="form-field">
            <label class="form-label">{{ t('admin_tickets_form_message', locale) }}</label>
            <textarea id="admin-ticket-message" name="message" rows="5" placeholder="{{ t('admin_tickets_form_message_placeholder', locale) }}">{{ form.message }}</textarea>
        </div>

        <label style="display:flex;align-items:center;gap:8px;padding:9px 12px;border-radius:var(--ng-radius-sm);border:1px dashed var(--ng-border);background:var(--ng-surface-soft);font-size:12px;font-weight:600;color:var(--ng-text-muted);cursor:pointer;transition:border-color .15s;">
            <input type="file" name="attachments[]" style="display:none;" multiple>
            <svg style="width:14px;height:14px;flex-shrink:0;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M18.375 12.739l-7.693 7.693a4.5 4.5 0 01-6.364-6.364l10.94-10.94A3 3 0 1119.5 7.372L8.552 18.32m.009-.01l-.01.01m5.699-9.941l-7.81 7.81a1.5 1.5 0 002.112 2.13"/></svg>
            {{ t('ticket_ui_attach_file', locale) }} <span style="font-weight:400;opacity:.7;">({{ t('ticket_ui_attachment_limits', locale) }})</span>
        </label>

        {% if adminSignature %}
            <label style="display:flex;align-items:center;gap:8px;font-size:13px;color:var(--ng-text-muted);cursor:pointer;">
                <input type="checkbox" name="include_signature" value="1" style="width:auto;min-height:auto;" {{ form.include_signature ? 'checked' : '' }}>
                {{ t('admin_tickets_signature_toggle', locale) }}
            </label>
        {% endif %}

        <div style="display:flex;justify-content:flex-end;gap:8px;">
            <button type="button" class="ui-button ui-button--ghost" onclick="document.getElementById('new-ticket-section').classList.add('hidden')">{{ t('ticket_ui_cancel', locale) }}</button>
            <button type="submit" class="ui-button ui-button--primary">{{ t('admin_tickets_form_submit', locale) }}</button>
        </div>
    </form>
</div>

{% if templates is not empty %}
<script>(()=>{
    const sel=document.getElementById('admin-ticket-template-select');
    const sub=document.getElementById('admin-ticket-subject');
    const cat=document.getElementById('admin-ticket-category');
    const pri=document.getElementById('admin-ticket-priority');
    const msg=document.getElementById('admin-ticket-message');
    if(!sel)return;
    sel.addEventListener('change',()=>{
        const o=sel.selectedOptions[0];
        if(!o||!o.dataset.subject)return;
        if(sub)sub.value=o.dataset.subject||'';
        if(cat)cat.value=o.dataset.category||'';
        if(pri)pri.value=o.dataset.priority||'';
        if(msg)msg.value=o.dataset.body||'';
    });
})();</script>
{% endif %}
