{% set locale = page_locale() %}
{% set statusLabels = statusLabels ?? {
    'open':     t('admin_tickets_status_open', locale),
    'pending':  t('admin_tickets_status_pending', locale),
    'resolved': t('admin_tickets_status_resolved', locale),
    'closed':   t('admin_tickets_status_closed', locale),
} %}
{% set priorityLabels = priorityLabels ?? {
    'low':    t('admin_tickets_priority_label_low', locale),
    'normal': t('admin_tickets_priority_label_normal', locale),
    'high':   t('admin_tickets_priority_label_high', locale),
    'urgent': t('admin_tickets_priority_label_urgent', locale),
} %}
{% set categoryLabels = categoryLabels ?? {
    'general':   t('admin_tickets_category_label_general', locale),
    'billing':   t('admin_tickets_category_label_billing', locale),
    'technical': t('admin_tickets_category_label_technical', locale),
    'abuse':     t('admin_tickets_category_label_abuse', locale),
} %}
<div id="tickets-table-wrap" hx-get="/admin/tickets/table" hx-include="#admin-ticket-filters" hx-trigger="tickets-changed from:body" hx-swap="outerHTML">
    {% if tickets is empty %}
        <div style="padding:16px;">
            {% include 'components/tickets/_empty_state.html.twig' with {
                title: t('ticket_ui_no_tickets_found', locale),
                text: t('ticket_ui_admin_empty_filtered_text', locale)
            } %}
        </div>
    {% else %}
        <div style="overflow-x:auto;">
            <table style="width:100%;border-collapse:collapse;">
                <thead>
                    <tr>
                        <th>{{ t('ticket_ui_ticket', locale) }}</th>
                        <th>{{ t('ticket_ui_customer', locale) }}</th>
                        <th>{{ t('ticket_ui_status', locale) }}</th>
                        <th>{{ t('ticket_ui_priority', locale) }}</th>
                        <th>{{ t('ticket_ui_category', locale) }}</th>
                        <th>{{ t('ticket_ui_assigned', locale) }}</th>
                        <th>{{ t('ticket_ui_last_reply', locale) }}</th>
                        <th>{{ t('ticket_ui_created', locale) }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for ticket in tickets %}
                        <tr style="cursor:pointer;" onclick="window.location='{{ path('admin_ticket_show', {id: ticket.id}) }}'">
                            <td style="max-width:280px;">
                                <div style="font-size:11px;font-weight:700;font-family:monospace;color:var(--ng-text-muted);">#{{ ticket.id }}</div>
                                <div style="margin-top:3px;font-weight:700;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;color:var(--ng-text);">{{ ticket.subject }}</div>
                            </td>
                            <td>
                                <div style="font-weight:600;color:var(--ng-text);">{{ ticket.customer.email }}</div>
                                <div style="font-size:11px;color:var(--ng-text-muted);">{{ t('ticket_ui_customer', locale) }} #{{ ticket.customer.id }}</div>
                            </td>
                            <td>{% include 'components/tickets/_status_badge.html.twig' with { ticket: ticket, statusLabels: statusLabels } %}</td>
                            <td>{% include 'components/tickets/_priority_badge.html.twig' with { ticket: ticket, priorityLabels: priorityLabels } %}</td>
                            <td><span class="ui-badge ui-badge--neutral">{{ categoryLabels[ticket.category] ?? ticket.category|title }}</span></td>
                            <td>
                                {% if ticket.assigned_to %}
                                    <span style="font-weight:600;color:var(--ng-text);">{{ ticket.assigned_to.email }}</span>
                                {% else %}
                                    <span style="color:var(--ng-text-muted);">{{ t('ticket_ui_unassigned', locale) }}</span>
                                {% endif %}
                            </td>
                            <td>
                                <div style="font-weight:600;color:var(--ng-text);">{{ ticket.last_message_at|date('d.m.Y') }}</div>
                                <div style="font-size:11px;color:var(--ng-text-muted);">{{ ticket.last_message_at|date('H:i') }}</div>
                            </td>
                            <td style="color:var(--ng-text-muted);">{{ ticket.created_at|date('d.m.Y') }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

        {# Mobile card view #}
        <div style="display:none;" class="tkt-mobile-list">
            {% for ticket in tickets %}
                <a href="{{ path('admin_ticket_show', {id: ticket.id}) }}" class="tkt-item" style="display:block;text-decoration:none;padding:14px 16px;border-bottom:1px solid var(--ng-border);">
                    <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:12px;">
                        <div style="min-width:0;">
                            <div style="font-size:11px;font-weight:700;font-family:monospace;color:var(--ng-text-muted);">#{{ ticket.id }}</div>
                            <div style="margin-top:3px;font-size:14px;font-weight:700;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;color:var(--ng-text);">{{ ticket.subject }}</div>
                            <div style="margin-top:4px;font-size:11px;color:var(--ng-text-muted);">{{ ticket.customer.email }} · {{ categoryLabels[ticket.category] ?? ticket.category|title }} · {{ ticket.assigned_to ? ticket.assigned_to.email : t('ticket_ui_unassigned', locale) }}</div>
                        </div>
                        {% include 'components/tickets/_status_badge.html.twig' with { ticket: ticket, statusLabels: statusLabels } %}
                    </div>
                    <div style="display:flex;flex-wrap:wrap;align-items:center;gap:8px;margin-top:10px;">
                        {% include 'components/tickets/_priority_badge.html.twig' with { ticket: ticket, priorityLabels: priorityLabels } %}
                        <span style="font-size:11px;color:var(--ng-text-muted);">{{ t('ticket_ui_last_reply', locale) }} {{ ticket.last_message_at|date('d.m.Y H:i') }}</span>
                    </div>
                </a>
            {% endfor %}
        </div>
    {% endif %}
</div>
