{% set locale = page_locale() %}
{% set rowBg = {
    'urgent': 'bg-rose-50 hover:bg-rose-100',
    'high':   'bg-orange-50 hover:bg-orange-100',
    'normal': 'bg-white hover:bg-slate-50',
    'low':    'bg-slate-50 hover:bg-slate-100',
} %}
<div class="overflow-x-auto">
    <table class="min-w-full text-sm">
        <thead class="border-b border-slate-200 bg-slate-50 text-xs uppercase tracking-wide text-slate-500">
            <tr>
                <th class="px-5 py-3 text-left font-semibold">{{ t('admin_tickets_col_id_age', locale) }}</th>
                <th class="px-5 py-3 text-left font-semibold">{{ t('admin_tickets_col_subject_cat', locale) }}</th>
                <th class="px-5 py-3 text-left font-semibold">{{ t('admin_tickets_table_customer', locale) }}</th>
                <th class="px-5 py-3 text-left font-semibold">{{ t('admin_tickets_table_priority', locale) }}</th>
                <th class="px-5 py-3 text-left font-semibold">{{ t('admin_tickets_table_status', locale) }}</th>
                <th class="px-5 py-3 text-left font-semibold">{{ t('admin_tickets_col_last_activity', locale) }}</th>
                <th class="px-5 py-3 text-right font-semibold">{{ t('actions', locale) }}</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
            {% for ticket in tickets %}
                {% set nowTs = date()|date('U') %}
                {% set createdTs = ticket.created_at|date('U') %}
                {% set ageDays = ((nowTs - createdTs) / 86400)|round(0, 'floor') %}
                {% set bg = rowBg[ticket.priority] ?? 'bg-white hover:bg-slate-50' %}
                <tr class="{{ bg }} transition-colors" data-ticket-status="{{ ticket.status }}">
                    <td class="px-5 py-4">
                        <div class="font-mono text-sm font-bold text-slate-800">#{{ ticket.id }}</div>
                        <div class="mt-0.5 text-xs text-slate-500">
                            {{ ageDays == 0 ? t('admin_tickets_age_today', locale) : ageDays ~ t('admin_tickets_age_days_suffix', locale) }}
                        </div>
                    </td>
                    <td class="px-5 py-4">
                        <div class="font-semibold text-slate-900">{{ ticket.subject }}</div>
                        <div class="mt-0.5 text-xs text-slate-500">{{ categoryLabels[ticket.category] ?? ticket.category|title }}</div>
                    </td>
                    <td class="px-5 py-4">
                        <div class="text-sm text-slate-800">{{ ticket.customer.email }}</div>
                        <div class="text-xs text-slate-500">ID {{ ticket.customer.id }}</div>
                    </td>
                    <td class="px-5 py-4">
                        <span class="inline-flex items-center rounded-full border px-2.5 py-1 text-xs font-semibold {{ priorityStyles[ticket.priority] ?? 'border-slate-200 bg-slate-50 text-slate-600' }}">
                            {{ priorityLabels[ticket.priority] ?? ticket.priority }}
                        </span>
                    </td>
                    <td class="px-5 py-4">
                        <span class="inline-flex items-center rounded-full border px-2.5 py-1 text-xs font-semibold {{ statusStyles[ticket.status] ?? 'border-slate-200 bg-slate-50 text-slate-600' }}">
                            {{ statusLabels[ticket.status] ?? ticket.status }}
                        </span>
                    </td>
                    <td class="px-5 py-4 text-xs text-slate-500">
                        {{ ticket.last_message_at|date('d.m.Y') }}<br>{{ ticket.last_message_at|date('H:i') }}
                    </td>
                    <td class="px-5 py-4 text-right">
                        <a href="/admin/tickets/{{ ticket.id }}" class="inline-flex items-center gap-1 rounded-lg border border-slate-200 px-3 py-1.5 text-xs font-semibold text-slate-700 hover:bg-slate-50 transition-colors">
                            {{ t('admin_tickets_open_action', locale) }}
                            <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
                        </a>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="7" class="px-5 py-10 text-center text-sm text-slate-500">{{ t('admin_tickets_empty', locale) }}</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
