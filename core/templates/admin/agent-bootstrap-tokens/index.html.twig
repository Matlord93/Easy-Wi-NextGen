{% extends 'admin/base.html.twig' %}

{% set pageTitle = t('admin_bootstrap_tokens_title', page_locale()) %}
{% set pageSubtitle = t('admin_bootstrap_tokens_intro', page_locale()) %}
{% set activeNav = 'agent-bootstrap-tokens' %}

{% block content %}
{% set locale = page_locale() %}

{# ── Hero ── #}
<div class="ng-card" style="overflow:hidden;">
    <div class="tkt-hero">
        <div class="tkt-hero__inner">
            <div style="display:flex;flex-direction:column;gap:16px;">
                <div>
                    <div class="tkt-hero__pill">
                        <span class="tkt-hero__pill-dot" style="background:#60a5fa;"></span>
                        {{ t('admin_bootstrap_tokens_title', locale) }}
                    </div>
                    <h1 class="tkt-hero__title" style="margin-top:10px;">{{ t('admin_bootstrap_tokens_title', locale) }}</h1>
                    <p class="tkt-hero__sub">{{ t('admin_bootstrap_tokens_intro', locale) }}</p>
                </div>
                <div style="display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:10px;">
                    {% set totalTokens = tokens|length %}
                    {% set activeTokens = tokens|filter(t => t.status == 'active')|length %}
                    {% set usedTokens = tokens|filter(t => t.status == 'used')|length %}
                    <div class="tkt-kpi">
                        <div class="tkt-kpi__label">{{ t('admin_bootstrap_tokens_list', locale) }}</div>
                        <div class="tkt-kpi__value">{{ totalTokens }}</div>
                    </div>
                    <div class="tkt-kpi tkt-kpi--open">
                        <div class="tkt-kpi__label">{{ t('admin_bootstrap_tokens_status_active', locale) }}</div>
                        <div class="tkt-kpi__value">{{ activeTokens }}</div>
                    </div>
                    <div class="tkt-kpi tkt-kpi--pending">
                        <div class="tkt-kpi__label">{{ t('admin_bootstrap_tokens_status_used', locale) }}</div>
                        <div class="tkt-kpi__value">{{ usedTokens }}</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div style="display:flex;flex-direction:column;gap:20px;margin-top:20px;">

    <div class="ng-layout-2col">

        {# ── Create Token Form ── #}
        <div class="ng-data-card">
            <div class="ng-data-card__header">
                <div>
                    <h2 class="ng-data-card__title">{{ t('admin_bootstrap_tokens_create_title', locale) }}</h2>
                    <p class="ng-data-card__sub">{{ t('admin_bootstrap_tokens_create_intro', locale) }}</p>
                </div>
            </div>
            <div class="ng-data-card__body">

                {% if errors is not empty %}
                    <div class="ng-alert ng-alert--danger">
                        <ul class="list-disc pl-5">
                            {% for error in errors %}
                                <li>{{ error }}</li>
                            {% endfor %}
                        </ul>
                    </div>
                {% endif %}

                {% if createdToken %}
                    <div class="ng-alert ng-alert--success">
                        <p class="font-semibold">{{ t('admin_bootstrap_tokens_created', locale) }}</p>
                        <p class="mt-2 break-all font-mono text-xs">{{ createdToken }}</p>
                        <p class="mt-2 text-xs">{{ t('admin_bootstrap_tokens_created_hint', locale) }}</p>
                    </div>
                {% endif %}

                <form method="post" style="display:flex;flex-direction:column;gap:16px;margin-top:16px;">
                    <div class="form-field">
                        <label class="form-label" for="name">{{ t('admin_bootstrap_tokens_name', locale) }}</label>
                        <input
                            id="name"
                            name="name"
                            type="text"
                            value="{{ form.name }}"
                            placeholder="{{ t('admin_bootstrap_tokens_name_placeholder', locale) }}"
                            class="form-input"
                        >
                    </div>
                    <div class="form-field">
                        <label class="form-label" for="expires_in">{{ t('admin_bootstrap_tokens_expires', locale) }}</label>
                        <input
                            id="expires_in"
                            name="expires_in"
                            type="number"
                            min="1"
                            max="1440"
                            value="{{ form.expires_in }}"
                            class="form-input"
                        >
                        <p class="form-hint">{{ t('admin_bootstrap_tokens_expires_hint', locale) }}</p>
                    </div>
                    <div class="form-field">
                        <label class="form-label" for="bound_cidr">{{ t('admin_bootstrap_tokens_cidr', locale) }}</label>
                        <input
                            id="bound_cidr"
                            name="bound_cidr"
                            type="text"
                            value="{{ form.bound_cidr }}"
                            placeholder="203.0.113.0/24"
                            class="form-input"
                        >
                        <p class="form-hint">{{ t('admin_bootstrap_tokens_cidr_hint', locale) }}</p>
                    </div>
                    <div class="form-field">
                        <label class="form-label" for="bound_node_name">{{ t('admin_bootstrap_tokens_node_name', locale) }}</label>
                        <input
                            id="bound_node_name"
                            name="bound_node_name"
                            type="text"
                            value="{{ form.bound_node_name }}"
                            placeholder="node-eu-01"
                            class="form-input"
                        >
                        <p class="form-hint">{{ t('admin_bootstrap_tokens_node_name_hint', locale) }}</p>
                    </div>
                    <div>
                        <button type="submit" class="ui-button ui-button--primary">{{ t('admin_bootstrap_tokens_create', locale) }}</button>
                    </div>
                </form>

            </div>
        </div>

        {# ── Token List ── #}
        <div class="ng-data-card">
            <div class="ng-data-card__header">
                <div>
                    <h2 class="ng-data-card__title">{{ t('admin_bootstrap_tokens_list', locale) }}</h2>
                    <p class="ng-data-card__sub">{{ t('admin_bootstrap_tokens_list_intro', locale) }}</p>
                    <p class="ng-data-card__sub">{{ t('admin_bootstrap_tokens_recent_hint', locale)|replace({'%count%': recentTokenLimit}) }}</p>
                </div>
            </div>
            <div class="ng-data-card__body ng-data-card__body--flush">

                <div class="cust-ws-table-wrap">
                    <table class="cust-table">
                        <thead>
                            <tr>
                                <th>{{ t('admin_bootstrap_tokens_table_name', locale) }}</th>
                                <th>{{ t('admin_bootstrap_tokens_table_prefix', locale) }}</th>
                                <th>{{ t('admin_bootstrap_tokens_table_constraints', locale) }}</th>
                                <th>{{ t('admin_bootstrap_tokens_table_expires', locale) }}</th>
                                <th>{{ t('admin_bootstrap_tokens_table_status', locale) }}</th>
                                <th>{{ t('admin_bootstrap_tokens_table_actions', locale) }}</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for token in tokens %}
                                <tr>
                                    <td>
                                        <div class="font-medium" style="color: var(--ng-text)">{{ token.name }}</div>
                                        {% if token.usedAt %}
                                            <div class="text-xs" style="color: var(--ng-text-muted)">{{ t('admin_bootstrap_tokens_used_at', locale)|replace({'%time%': token.usedAt|date('Y-m-d H:i')}) }}</div>
                                        {% endif %}
                                    </td>
                                    <td class="font-mono text-xs">{{ token.prefix }}</td>
                                    <td class="text-xs" style="color: var(--ng-text)">
                                        {% if token.boundCidr %}
                                            <div>{{ t('admin_bootstrap_tokens_bound_cidr', locale)|replace({'%cidr%': token.boundCidr}) }}</div>
                                        {% endif %}
                                        {% if token.boundNodeName %}
                                            <div>{{ t('admin_bootstrap_tokens_bound_node', locale)|replace({'%node%': token.boundNodeName}) }}</div>
                                        {% endif %}
                                        {% if not token.boundCidr and not token.boundNodeName %}
                                            <span style="color: var(--ng-text-muted)">{{ t('admin_bootstrap_tokens_unbound', locale) }}</span>
                                        {% endif %}
                                    </td>
                                    <td class="text-xs">{{ token.expiresAt|date('Y-m-d H:i') }}</td>
                                    <td>
                                        {% set statusBadge = {
                                            'active': 'success',
                                            'used': 'warning',
                                            'expired': 'neutral',
                                            'revoked': 'danger'
                                        } %}
                                        <span class="ui-badge ui-badge--{{ statusBadge[token.status] ?? 'neutral' }}">
                                            {{ t('admin_bootstrap_tokens_status_' ~ token.status, locale) }}
                                        </span>
                                    </td>
                                    <td>
                                        {% if token.status == 'active' %}
                                            <form method="post" action="/admin/agent-bootstrap-tokens/{{ token.id }}/revoke">
                                                <button type="submit" class="ui-button ui-button--danger ui-button--sm">{{ t('admin_bootstrap_tokens_revoke', locale) }}</button>
                                            </form>
                                        {% else %}
                                            <span class="text-xs" style="color: var(--ng-text-muted)">—</span>
                                        {% endif %}
                                    </td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="6" class="cust-table__empty">{{ t('admin_bootstrap_tokens_empty', locale) }}</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>

            </div>
        </div>

    </div>

</div>
{% endblock %}
