<div id="plugin-import" style="display:flex;flex-direction:column;gap:16px;">
    {% if import.success_message is not empty %}
        <div class="ng-alert ng-alert--success">{{ import.success_message }}</div>
    {% endif %}

    {% if import.errors is not empty %}
        <div class="ng-alert ng-alert--danger">
            <p style="font-weight:600;margin-bottom:4px;">{{ t('admin_plugins_import_failed', page_locale()) }}</p>
            <ul style="list-style:disc;padding-left:20px;margin-top:4px;">
                {% for error in import.errors %}
                    <li>{{ error }}</li>
                {% endfor %}
            </ul>
        </div>
    {% endif %}

    <form
        style="display:flex;flex-direction:column;gap:12px;"
        hx-post="/admin/plugins/import"
        hx-target="#plugin-import"
        hx-swap="outerHTML"
    >
        <div class="form-field">
            <label class="form-label">{{ t('admin_plugins_import_label', page_locale()) }}</label>
            <textarea name="payload" rows="8" class="form-textarea" style="font-family:monospace;" placeholder='[{"game_key":"cs2","name":"Metamod:Source","version":"1.11.0","checksum":"b3c94b...","download_url":"https://example.com/metamod.zip","description":"..."}]'>{{ import.payload }}</textarea>
        </div>
        <p style="font-size:12px;color:var(--text-muted);">{{ t('admin_plugins_import_required', page_locale()) }}</p>
        <div>
            <button type="submit" class="ui-button ui-button--primary">{{ t('admin_plugins_import_submit', page_locale()) }}</button>
        </div>
    </form>
</div>
