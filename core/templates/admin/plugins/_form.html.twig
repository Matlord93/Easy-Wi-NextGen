{% if form.errors is not empty %}
    <div class="ng-alert ng-alert--danger" style="margin-bottom:16px;">
        <p style="font-weight:600;margin-bottom:4px;">{{ t('admin_form_fix_following', page_locale()) }}</p>
        <ul style="list-style:disc;padding-left:20px;margin-top:4px;">
            {% for error in form.errors %}
                <li>{{ error }}</li>
            {% endfor %}
        </ul>
    </div>
{% endif %}

<form
    hx-post="{{ form.action_url }}"
    hx-target="#plugin-form"
    hx-swap="outerHTML"
    style="display:flex;flex-direction:column;gap:16px;"
>
    <div class="form-field">
        <label class="form-label">Game / Engine</label>
        <select name="game_key" class="form-input">
            <option value="">{{ t('admin_plugins_game_select_placeholder', page_locale()) }}</option>
            {% for template in templates %}
                <option value="{{ template.game_key }}" {% if form.game_key == template.game_key %}selected{% endif %}>{{ template.label }}</option>
            {% endfor %}
        </select>
    </div>

    <div class="form-field">
        <label class="form-label">{{ t('admin_plugins_name_label', page_locale()) }}</label>
        <input type="text" name="name" value="{{ form.name }}" class="form-input" placeholder="Metamod:Source">
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
        <div class="form-field">
            <label class="form-label">{{ t('admin_plugins_version_label', page_locale()) }}</label>
            <input type="text" name="version" value="{{ form.version }}" class="form-input" placeholder="1.11.0">
        </div>
        <div class="form-field">
            <label class="form-label">{{ t('admin_plugins_checksum_label', page_locale()) }}</label>
            <input type="text" name="checksum" value="{{ form.checksum }}" class="form-input" style="font-family:monospace;" placeholder="b3c94b...">
        </div>
    </div>

    <div class="form-field">
        <label class="form-label">{{ t('admin_plugins_download_url_label', page_locale()) }}</label>
        <input type="url" name="download_url" value="{{ form.download_url }}" class="form-input" placeholder="https://example.com/plugins/metamod.zip">
    </div>

    <div class="form-field">
        <label class="form-label">{{ t('admin_plugins_description_label', page_locale()) }}</label>
        <textarea name="description" rows="3" class="form-textarea" placeholder="{{ t('admin_plugins_description_placeholder', page_locale()) }}">{{ form.description }}</textarea>
    </div>

    <div>
        <button type="submit" class="ui-button ui-button--primary" style="width:100%;">
            {{ t(form.submit_label, page_locale()) }}
        </button>
    </div>
</form>
