<div id="plugins-table" class="cust-ws-table-wrap" hx-trigger="plugins-changed from:body" hx-get="/admin/plugins/table" hx-swap="outerHTML">
    <table class="cust-table">
        <thead>
            <tr>
                <th>{{ t('admin_plugins_table_plugin', page_locale()) }}</th>
                <th>{{ t('admin_plugins_table_game_key', page_locale()) }}</th>
                <th>{{ t('admin_plugins_table_version', page_locale()) }}</th>
                <th>{{ t('admin_plugins_table_checksum', page_locale()) }}</th>
                <th>{{ t('admin_plugins_table_updated', page_locale()) }}</th>
                <th style="text-align:right;">{{ t('admin_plugins_table_actions', page_locale()) }}</th>
            </tr>
        </thead>
        <tbody>
            {% for plugin in plugins %}
                <tr>
                    <td>
                        <div style="font-weight:600;">{{ plugin.name }}</div>
                        <div style="font-size:11px;color:var(--text-muted);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:260px;">{{ plugin.download_url }}</div>
                    </td>
                    <td>
                        <span class="ui-badge ui-badge--neutral">{{ plugin.template.gameKey|upper }}</span>
                        <div style="margin-top:4px;font-size:11px;color:var(--text-muted);">{{ t('admin_plugins_game_key_hint', page_locale()) }}</div>
                    </td>
                    <td>{{ plugin.version }}</td>
                    <td style="font-family:monospace;font-size:12px;">{{ plugin.checksum }}</td>
                    <td>{{ plugin.updated_at ? plugin.updated_at|date('Y-m-d H:i') : '—' }}</td>
                    <td style="text-align:right;white-space:nowrap;">
                        <a
                            class="ui-button ui-button--ghost ui-button--sm"
                            href="/admin/plugins/{{ plugin.id }}/preview"
                        >{{ t('admin_plugins_preview', page_locale()) }}</a>
                        <a
                            class="ui-button ui-button--ghost ui-button--sm"
                            href="/admin/plugins/{{ plugin.id }}/edit"
                        >{{ t('edit', page_locale()) }}</a>
                        <button
                            class="ui-button ui-button--danger ui-button--sm"
                            hx-post="/admin/plugins/{{ plugin.id }}/delete"
                            hx-confirm="{{ t('admin_plugins_delete_confirm', page_locale())|replace({'%name%': plugin.name}) }}"
                        >{{ t('delete', page_locale()) }}</button>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="6" class="cust-table__empty">{{ t('admin_plugins_empty', page_locale()) }}</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
