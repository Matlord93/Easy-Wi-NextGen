{% extends 'admin/base.html.twig' %}

{% set pageTitle = t('admin_plugins_heading', page_locale()) %}
{% set pageSubtitle = t('admin_plugins_intro', page_locale()) %}
{% set activeNav = 'plugins' %}
{% set topbarActions %}
    <button
        class="ui-button ui-button--ghost ui-button--sm"
        hx-get="/admin/plugins/table"
        hx-target="#plugins-table"
        hx-swap="outerHTML"
    >{{ t('refresh', page_locale()) }}</button>
    <button
        class="ui-button ui-button--ghost ui-button--sm"
        hx-post="/admin/plugins/seed"
        hx-target="#plugins-table"
        hx-swap="none"
    >{{ t('admin_plugins_add_standard_button', page_locale()) }}</button>
    <a class="ui-button ui-button--ghost ui-button--sm" href="/admin/plugins/import">{{ t('admin_plugins_import_button', page_locale()) }}</a>
    <a class="ui-button ui-button--primary ui-button--sm" href="/admin/plugins/new">{{ t('admin_plugins_create_button', page_locale()) }}</a>
{% endset %}

{% block content %}
<div style="display:flex;flex-direction:column;gap:20px;">

    {# hero section #}
    <section class="ng-card" style="overflow:hidden;">
        <div class="tkt-hero">
            <div class="tkt-hero__inner">
                <div>
                    <div class="tkt-hero__pill"><span class="tkt-hero__pill-dot"></span> {{ t('admin_plugins_heading', page_locale()) }}</div>
                    <h1 class="tkt-hero__title" style="margin-top:10px;">{{ t('admin_plugins_catalog_entries', page_locale()) }}</h1>
                    <p class="tkt-hero__sub">{{ t('admin_plugins_intro', page_locale()) }}</p>
                </div>
                <div style="display:flex;gap:16px;flex-wrap:wrap;margin-top:16px;">
                    <div class="tkt-kpi">
                        <div class="tkt-kpi__label">{{ t('admin_plugins_total_label', page_locale()) }}</div>
                        <div class="tkt-kpi__value">{{ summary.total }}</div>
                    </div>
                    <div class="tkt-kpi tkt-kpi--open">
                        <div class="tkt-kpi__label">{{ t('admin_plugins_templates_covered', page_locale()) }}</div>
                        <div class="tkt-kpi__value">{{ summary.game_keys }}</div>
                    </div>
                    <div class="tkt-kpi tkt-kpi--resolved">
                        <div class="tkt-kpi__label">{{ t('admin_plugins_integrity', page_locale()) }}</div>
                        <div class="tkt-kpi__value">{{ t('admin_plugins_checksums', page_locale()) }}</div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    {# data card with table #}
    <div class="ng-data-card">
        <div class="ng-data-card__header">
            <div>
                <h2 class="ng-data-card__title">{{ t('admin_plugins_catalog_entries', page_locale()) }}</h2>
                <p class="ng-data-card__sub">{{ t('admin_plugins_catalog_intro', page_locale()) }}</p>
            </div>
            <div class="ng-data-card__actions">
                <button
                    class="ui-button ui-button--ghost ui-button--sm"
                    hx-get="/admin/plugins/table"
                    hx-target="#plugins-table"
                    hx-swap="outerHTML"
                >{{ t('refresh', page_locale()) }}</button>
                <button
                    class="ui-button ui-button--ghost ui-button--sm"
                    hx-post="/admin/plugins/seed"
                    hx-target="#plugins-table"
                    hx-swap="none"
                >{{ t('admin_plugins_add_standard_button', page_locale()) }}</button>
                <a class="ui-button ui-button--ghost ui-button--sm" href="/admin/plugins/import">{{ t('admin_plugins_import_button', page_locale()) }}</a>
                <a class="ui-button ui-button--primary ui-button--sm" href="/admin/plugins/new">
                    <svg viewBox="0 0 16 16" fill="currentColor" width="14" height="14"><path d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4z"/></svg>
                    {{ t('admin_plugins_create_button', page_locale()) }}
                </a>
            </div>
        </div>
        <div class="ng-data-card__body--flush">
            {% include 'admin/plugins/_table.html.twig' with { plugins: plugins } %}
        </div>
    </div>

</div>
{% endblock %}
