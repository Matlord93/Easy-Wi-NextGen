<div style="display:flex;flex-direction:column;gap:12px;">

    <div class="ng-data-card" style="margin:0;">
        <div class="ng-data-card__header">
            <div>
                <h3 class="ng-data-card__title" style="font-size:12px;text-transform:uppercase;letter-spacing:0.05em;">
                    {{ t('admin_plugins_preview_details', 'de') }} / {{ t('admin_plugins_preview_details', 'en') }}
                </h3>
            </div>
        </div>
        <div class="ng-data-card__body">
            <p style="font-weight:600;margin-bottom:4px;">{{ plugin.name }}</p>
            <p style="font-size:12px;color:var(--text-muted);">
                {{ t('admin_plugins_preview_template', 'de') }} / {{ t('admin_plugins_preview_template', 'en') }}:
                {{ plugin.template.name }}
            </p>
            <p style="font-size:12px;color:var(--text-muted);">
                {{ t('admin_plugins_preview_version', 'de') }} / {{ t('admin_plugins_preview_version', 'en') }}:
                {{ plugin.version }}
            </p>
            <p style="font-size:12px;color:var(--text-muted);">
                {{ t('admin_plugins_preview_checksum', 'de') }} / {{ t('admin_plugins_preview_checksum', 'en') }}:
                <span style="font-family:monospace;">{{ plugin.checksum }}</span>
            </p>
        </div>
    </div>

    <div class="ng-data-card" style="margin:0;">
        <div class="ng-data-card__header">
            <div>
                <h3 class="ng-data-card__title" style="font-size:12px;text-transform:uppercase;letter-spacing:0.05em;">
                    {{ t('admin_plugins_preview_download_url', 'de') }} / {{ t('admin_plugins_preview_download_url', 'en') }}
                </h3>
            </div>
        </div>
        <div class="ng-data-card__body">
            <p style="font-size:12px;color:var(--text-muted);word-break:break-all;">{{ plugin.download_url }}</p>
        </div>
    </div>

    <div class="ng-data-card" style="margin:0;">
        <div class="ng-data-card__header">
            <div>
                <h3 class="ng-data-card__title" style="font-size:12px;text-transform:uppercase;letter-spacing:0.05em;">
                    {{ t('admin_plugins_preview_description', 'de') }} / {{ t('admin_plugins_preview_description', 'en') }}
                </h3>
            </div>
        </div>
        <div class="ng-data-card__body">
            {% if plugin.description %}
                <p style="font-size:12px;color:var(--text-muted);">{{ plugin.description }}</p>
            {% else %}
                <p style="font-size:12px;color:var(--text-muted);">
                    {{ t('admin_plugins_preview_no_description', 'de') }} / {{ t('admin_plugins_preview_no_description', 'en') }}
                </p>
            {% endif %}
        </div>
    </div>

</div>
