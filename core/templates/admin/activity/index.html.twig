{% extends 'admin/base.html.twig' %}

{% set pageTitle = t('activity_title', page_locale()) %}
{% set pageSubtitle = t('admin_activity_intro', page_locale()) %}
{% set activeNav = 'activity' %}

{% block content %}
{% set locale = page_locale() %}

{# ─── Hero ─── #}
<section class="ng-card" style="overflow:hidden;">
    <div class="tkt-hero" style="background:linear-gradient(135deg,#07101f 0%,#0c1a3a 50%,#0a1220 100%);">
        <div class="tkt-hero__inner">
            <div style="display:flex;flex-direction:column;gap:16px;">
                <div>
                    <div class="tkt-hero__pill">
                        <span class="tkt-hero__pill-dot" style="background:#22d3ee;"></span>
                        {{ t('admin_activity_workbench_label', locale) }}
                    </div>
                    <h1 class="tkt-hero__title" style="margin-top:10px;">{{ t('activity_title', locale) }}</h1>
                    <p class="tkt-hero__sub">{{ t('admin_activity_intro', locale) }}</p>
                </div>
                <div style="display:grid;grid-template-columns:repeat(1,minmax(0,1fr));gap:10px;">
                    <div class="tkt-kpi">
                        <div class="tkt-kpi__label">{{ t('admin_activity_total_entries', locale) }}</div>
                        <div class="tkt-kpi__value">{{ entries|length }}</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div style="padding:14px 16px;border-top:1px solid var(--ng-border);background:var(--ng-surface-soft);display:flex;align-items:center;gap:10px;">
        <span style="font-size:0.8125rem;color:var(--ng-text-muted);">{{ t('admin_activity_total_entries', locale) }}:</span>
        <span class="ui-badge ui-badge--info">{{ entries|length }}</span>
    </div>
</section>

{# ─── Activity Timeline ─── #}
<section class="ng-card" style="margin-top:20px;">
    <div class="tkt-filter-bar">
        <div class="tkt-filter-bar__top">
            <div>
                <div class="tkt-filter-bar__title">{{ t('activity_title', locale) }}</div>
                <div class="tkt-filter-bar__sub">{{ t('admin_activity_intro', locale) }}</div>
            </div>
        </div>
    </div>
    <div style="padding:0;">
        {% for entry in entries %}
            <div style="display:flex;flex-direction:column;gap:10px;padding:14px 16px;border-bottom:1px solid var(--ng-border);">
                <div style="display:flex;flex-wrap:wrap;align-items:center;justify-content:space-between;gap:12px;">
                    <div style="display:flex;align-items:center;gap:12px;">
                        <div style="display:flex;align-items:center;justify-content:center;height:2.5rem;width:2.5rem;border-radius:9999px;background:var(--ng-primary);color:#fff;flex-shrink:0;">
                            <span style="font-size:0.75rem;font-weight:600;">{{ entry.action|slice(0,2)|upper }}</span>
                        </div>
                        <div>
                            <div style="font-size:0.875rem;font-weight:600;color:var(--ng-text);">{{ t('audit_event_' ~ entry.action|replace({'.': '_'}), locale) }}</div>
                            <div style="font-size:0.75rem;color:var(--ng-text-muted);">{{ entry.actor }}</div>
                        </div>
                    </div>
                    <span class="ui-badge ui-badge--neutral">{{ entry.created_at|date('Y-m-d H:i') }}</span>
                </div>
                <details style="padding:10px 14px;border-radius:6px;border:1px solid var(--ng-border);background:var(--ng-surface-soft);font-size:0.75rem;">
                    <summary style="cursor:pointer;font-size:0.75rem;font-weight:600;color:var(--ng-text-muted);">{{ t('admin_activity_payload', locale) }}</summary>
                    <pre style="margin-top:10px;white-space:pre-wrap;color:var(--ng-text);">{{ entry.payload }}</pre>
                </details>
            </div>
        {% else %}
            <div class="tkt-all-clear">
                <div class="tkt-all-clear__icon">
                    <svg viewBox="0 0 20 20" fill="currentColor" width="28" height="28"><path fill-rule="evenodd" d="M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16zm3.857-9.809a.75.75 0 0 0-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 1 0-1.06 1.061l2.5 2.5a.75.75 0 0 0 1.137-.089l4-5.5z" clip-rule="evenodd"/></svg>
                </div>
                {{ t('no_results', locale) }}
            </div>
        {% endfor %}
    </div>
</section>

{% endblock %}
