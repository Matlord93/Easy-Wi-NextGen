{% extends 'admin/base.html.twig' %}

{% set pageTitle = t('activity_title', page_locale()) %}
{% set pageSubtitle = t('admin_activity_intro', page_locale()) %}
{% set activeNav = 'activity' %}

{% block content %}
<div class="flex flex-col gap-6">
    <div class="ng-kpi-row">
        <div class="ng-kpi-box">
            <div class="ng-kpi-box__label">{{ t('admin_activity_total_entries', page_locale()) }}</div>
            <div class="ng-kpi-box__value ng-kpi-box__value--info">{{ entries|length }}</div>
        </div>
    </div>

    <div class="ng-data-card">
        <div class="ng-data-card__header">
            <div>
                <h2 class="ng-data-card__title">{{ t('activity_title', page_locale()) }}</h2>
            </div>
        </div>
        <div class="ng-data-card__body">
            {% for entry in entries %}
                <div class="ng-data-card" style="margin-bottom: 0.75rem;">
                    <div class="ng-data-card__body">
                        <div style="display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 1rem;">
                            <div style="display: flex; align-items: center; gap: 1rem;">
                                <div style="display: flex; align-items: center; justify-content: center; height: 2.5rem; width: 2.5rem; border-radius: 9999px; background: var(--color-primary-subtle);">
                                    <span style="font-size: 0.75rem; font-weight: 600;">{{ entry.action|slice(0, 2)|upper }}</span>
                                </div>
                                <div>
                                    <p style="font-size: 0.875rem; font-weight: 600;">{{ entry.action }}</p>
                                    <p style="font-size: 0.75rem;">{{ entry.actor }}</p>
                                </div>
                            </div>
                            <span class="ui-badge ui-badge--neutral">{{ entry.created_at|date('Y-m-d H:i') }}</span>
                        </div>
                        <details style="margin-top: 1rem; padding: 0.75rem 1rem; border-radius: 0.5rem; border: 1px solid var(--color-border); background: var(--color-surface-subtle); font-size: 0.75rem;">
                            <summary style="cursor: pointer; font-size: 0.75rem; font-weight: 600;">{{ t('admin_activity_payload', page_locale()) }}</summary>
                            <pre style="margin-top: 0.75rem; white-space: pre-wrap;">{{ entry.payload }}</pre>
                        </details>
                    </div>
                </div>
            {% else %}
                <div class="cust-empty">{{ t('no_results', page_locale()) }}</div>
            {% endfor %}
        </div>
    </div>
</div>
{% endblock %}
