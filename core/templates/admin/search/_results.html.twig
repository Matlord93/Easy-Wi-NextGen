{% set locale = page_locale() %}
{% if query is empty %}
    <div class="ng-data-card">
        <div class="ng-data-card__body" style="padding:20px;font-size:13px;color:var(--color-text-muted,#64748b);">
            {{ t('no_results', locale) }}
        </div>
    </div>
{% else %}
    <div class="ng-data-card">
        <div class="ng-data-card__body" style="padding:20px;">
            <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:24px;">
                <div>
                    <h2 style="font-size:13px;font-weight:600;color:var(--ng-text);">{{ t('admin_search_customers', locale) }}</h2>
                    <div style="margin-top:12px;display:flex;flex-direction:column;gap:8px;">
                        {% for customer in results.customers %}
                            <div style="border:1px solid var(--ng-border);border-radius:6px;padding:10px 12px;">
                                <p style="font-size:13px;font-weight:600;color:var(--ng-text);margin:0;">{{ customer.email }}</p>
                                <p style="font-size:11px;color:var(--color-text-muted,#64748b);margin:2px 0 0;">ID {{ customer.id }}</p>
                            </div>
                        {% else %}
                            <p style="font-size:12px;color:var(--color-text-muted,#64748b);">{{ t('no_results', locale) }}</p>
                        {% endfor %}
                    </div>
                </div>
                <div>
                    <h2 style="font-size:13px;font-weight:600;color:var(--ng-text);">{{ t('admin_search_instances', locale) }}</h2>
                    <div style="margin-top:12px;display:flex;flex-direction:column;gap:8px;">
                        {% for instance in results.instances %}
                            <div style="border:1px solid var(--ng-border);border-radius:6px;padding:10px 12px;">
                                <p style="font-size:13px;font-weight:600;color:var(--ng-text);margin:0;">Instance #{{ instance.id }} · {{ instance.template }}</p>
                                <p style="font-size:11px;color:var(--color-text-muted,#64748b);margin:2px 0 0;">{{ instance.customer }} · {{ instance.status|title }}</p>
                            </div>
                        {% else %}
                            <p style="font-size:12px;color:var(--color-text-muted,#64748b);">{{ t('no_results', locale) }}</p>
                        {% endfor %}
                    </div>
                </div>
                <div>
                    <h2 style="font-size:13px;font-weight:600;color:var(--ng-text);">{{ t('admin_search_domains', locale) }}</h2>
                    <div style="margin-top:12px;display:flex;flex-direction:column;gap:8px;">
                        {% for domain in results.domains %}
                            <div style="border:1px solid var(--ng-border);border-radius:6px;padding:10px 12px;">
                                <p style="font-size:13px;font-weight:600;color:var(--ng-text);margin:0;">{{ domain.name }}</p>
                                <p style="font-size:11px;color:var(--color-text-muted,#64748b);margin:2px 0 0;">{{ domain.customer }} · {{ domain.status|title }}</p>
                            </div>
                        {% else %}
                            <p style="font-size:12px;color:var(--color-text-muted,#64748b);">{{ t('no_results', locale) }}</p>
                        {% endfor %}
                    </div>
                </div>
                <div>
                    <h2 style="font-size:13px;font-weight:600;color:var(--ng-text);">{{ t('admin_search_tickets', locale) }}</h2>
                    <div style="margin-top:12px;display:flex;flex-direction:column;gap:8px;">
                        {% for ticket in results.tickets %}
                            <div style="border:1px solid var(--ng-border);border-radius:6px;padding:10px 12px;">
                                <p style="font-size:13px;font-weight:600;color:var(--ng-text);margin:0;">{{ ticket.subject }}</p>
                                <p style="font-size:11px;color:var(--color-text-muted,#64748b);margin:2px 0 0;">{{ ticket.customer }} · {{ ticket.status|title }}</p>
                                <a href="/admin/tickets/{{ ticket.id }}" class="ui-button ui-button--ghost ui-button--sm" style="margin-top:6px;display:inline-flex;">{{ t('admin_search_open_ticket', locale) }}</a>
                            </div>
                        {% else %}
                            <p style="font-size:12px;color:var(--color-text-muted,#64748b);">{{ t('no_results', locale) }}</p>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endif %}
