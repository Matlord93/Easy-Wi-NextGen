{% extends 'admin/base.html.twig' %}

{% set pageTitle = t('admin_server_ports_title', page_locale()) %}
{% set pageSubtitle = t('admin_server_ports_intro', page_locale()) %}
{% set activeNav = 'port-pools' %}

{% block content %}
<div class="flex flex-col gap-6">

    {% if notice %}
        <div class="ng-alert ng-alert--success">{{ notice }}</div>
    {% endif %}
    {% if error %}
        <div class="ng-alert ng-alert--danger">{{ error }}</div>
    {% endif %}

    {# Hero #}
    <div class="ng-card" style="overflow:hidden;">
        <div class="tkt-hero">
            <div class="tkt-hero__inner">
                <div style="display:flex;flex-direction:column;gap:16px;">
                    <div>
                        <div class="tkt-hero__pill">
                            <span class="tkt-hero__pill-dot" style="background:#f59e0b;"></span>
                            {{ t('admin_server_ports_title', page_locale()) }}
                        </div>
                        <h1 class="tkt-hero__title" style="margin-top:10px;">{{ t('admin_server_ports_title', page_locale()) }}</h1>
                        <p class="tkt-hero__sub">{{ t('admin_server_ports_intro', page_locale()) }}</p>
                    </div>
                    <div style="display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:10px;">
                        <div class="tkt-kpi tkt-kpi--open">
                            <div class="tkt-kpi__label">{{ t('admin_server_ports_pool_list_title', page_locale()) }}</div>
                            <div class="tkt-kpi__value">{{ portPools|length }}</div>
                        </div>
                        <div class="tkt-kpi tkt-kpi--pending">
                            <div class="tkt-kpi__label">{{ t('admin_server_ports_blocks_title', page_locale()) }}</div>
                            <div class="tkt-kpi__value">{{ portBlocks|length }}</div>
                        </div>
                        <div class="tkt-kpi tkt-kpi--resolved">
                            <div class="tkt-kpi__label">{{ t('admin_status_enabled', page_locale()) }}</div>
                            <div class="tkt-kpi__value">{{ portPools|filter(p => p.enabled)|length }}</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# Create forms: pool + block assign #}
    <div class="ng-layout-2col--equal">
        {# Create pool #}
        <div class="ng-data-card">
            <div class="ng-data-card__header">
                <div>
                    <h2 class="ng-data-card__title">{{ t('admin_server_ports_pool_create_title', page_locale()) }}</h2>
                </div>
            </div>
            <div class="ng-data-card__body">
                <form class="flex flex-col gap-4" method="post" action="{{ path('admin_port_pools_create_page') }}">
                    <div class="form-field">
                        <label class="form-label">{{ t('admin_port_pools_node_label', page_locale()) }}</label>
                        <select name="node_id" class="form-input" required>
                            <option value="">{{ t('admin_port_pools_node_placeholder', page_locale()) }}</option>
                            {% for node in nodes %}
                                <option value="{{ node.id }}">{{ node.name ?? node.id }}</option>
                            {% endfor %}
                        </select>
                    </div>

                    <div class="grid grid-cols-2 gap-3">
                        <div class="form-field">
                            <label class="form-label">{{ t('admin_port_pools_name_label', page_locale()) }}</label>
                            <input type="text" name="name" placeholder="{{ t('admin_port_pools_name_placeholder', page_locale()) }}" class="form-input" required>
                        </div>
                        <div class="form-field">
                            <label class="form-label">{{ t('admin_port_pools_tag_label', page_locale()) }}</label>
                            <input type="text" name="tag" placeholder="GAME_UDP" class="form-input" required>
                        </div>
                    </div>

                    <div class="form-field">
                        <label class="form-label">{{ t('admin_port_pools_range_label', page_locale()) }}</label>
                        <div class="grid grid-cols-2 gap-2">
                            <input type="number" min="1" name="start_port" placeholder="{{ t('admin_port_pools_range_start_placeholder', page_locale()) }}" class="form-input" required>
                            <input type="number" min="1" name="end_port" placeholder="{{ t('admin_port_pools_range_end_placeholder', page_locale()) }}" class="form-input" required>
                        </div>
                        <p class="mt-1 text-xs" style="color:var(--ng-text-muted)">{{ t('admin_port_pools_range_hint', page_locale()) }}</p>
                    </div>

                    <div class="form-field">
                        <label class="form-label">{{ t('admin_server_ports_strategy_label', page_locale()) }}</label>
                        <select name="allocation_mode" class="form-input">
                            <option value="next">{{ t('admin_server_ports_strategy_next', page_locale()) }}</option>
                            <option value="gap10">{{ t('admin_server_ports_strategy_gap10', page_locale()) }}</option>
                        </select>
                        <p class="mt-1 text-xs" style="color:var(--ng-text-muted)">{{ t('admin_server_ports_strategy_hint', page_locale()) }}</p>
                    </div>

                    <label class="flex items-center gap-2 text-xs font-semibold uppercase cursor-pointer" style="color:var(--ng-text)">
                        <input type="checkbox" name="enabled" value="1" checked class="h-4 w-4 rounded" style="border-color:var(--ng-border)">
                        {{ t('admin_status_enabled', page_locale()) }}
                    </label>

                    <button type="submit" class="ui-button ui-button--primary">
                        {{ t('admin_port_pools_create_action', page_locale()) }}
                    </button>
                </form>
            </div>
        </div>

        {# Assign block #}
        <div class="ng-data-card">
            <div class="ng-data-card__header">
                <div>
                    <h2 class="ng-data-card__title">{{ t('admin_server_ports_block_assign_title', page_locale()) }}</h2>
                </div>
            </div>
            <div class="ng-data-card__body">
                <form class="flex flex-col gap-4" method="post" action="{{ path('admin_port_pools_assign_block') }}">
                    <div class="form-field">
                        <label class="form-label">{{ t('admin_port_blocks_pool_label', page_locale()) }}</label>
                        <select name="pool_id" class="form-input" required>
                            <option value="">{{ t('admin_port_blocks_pool_placeholder', page_locale()) }}</option>
                            {% for pool in portPools %}
                                <option value="{{ pool.id }}">{{ pool.name }} · {{ pool.node.name ?? pool.node.id }} ({{ pool.start_port }}-{{ pool.end_port }})</option>
                            {% endfor %}
                        </select>
                    </div>

                    <div class="form-field">
                        <label class="form-label">{{ t('admin_port_blocks_customer_label', page_locale()) }}</label>
                        <select name="customer_id" class="form-input" required>
                            <option value="">{{ t('admin_port_blocks_customer_placeholder', page_locale()) }}</option>
                            {% for customer in customers %}
                                <option value="{{ customer.id }}">{{ customer.email }} (#{{ customer.id }})</option>
                            {% endfor %}
                        </select>
                    </div>

                    <div class="form-field">
                        <label class="form-label">{{ t('admin_port_blocks_size_label', page_locale()) }}</label>
                        <input type="number" min="1" name="size" value="5" class="form-input" required>
                    </div>

                    <div class="form-field">
                        <label class="form-label">{{ t('admin_port_blocks_range_input_label', page_locale()) }}</label>
                        <div class="grid grid-cols-2 gap-2">
                            <input type="number" min="1" name="start_port" placeholder="{{ t('admin_port_blocks_range_start_placeholder', page_locale()) }}" class="form-input">
                            <input type="number" min="1" name="end_port" placeholder="{{ t('admin_port_blocks_range_end_placeholder', page_locale()) }}" class="form-input">
                        </div>
                        <p class="mt-1 text-xs" style="color:var(--ng-text-muted)">{{ t('admin_server_ports_block_assign_hint', page_locale()) }}</p>
                    </div>

                    <button type="submit" class="ui-button ui-button--primary">
                        {{ t('admin_port_blocks_create_action', page_locale()) }}
                    </button>
                </form>
            </div>
        </div>
    </div>

    {# Port pools list #}
    <div class="ng-data-card">
        <div class="ng-data-card__header">
            <div>
                <h2 class="ng-data-card__title">{{ t('admin_server_ports_pool_list_title', page_locale()) }}</h2>
                <p class="ng-data-card__sub">{{ t('admin_port_pools_list_intro', page_locale()) }}</p>
            </div>
            <div class="ng-data-card__actions">
                <span class="ui-badge ui-badge--neutral">{{ portPools|length }}</span>
            </div>
        </div>
        <div class="ng-data-card__body ng-data-card__body--flush">
            <div class="cust-ws-table-wrap">
                <table class="cust-table">
                    <thead>
                        <tr>
                            <th>{{ t('admin_label_id', page_locale()) }}</th>
                            <th>{{ t('admin_port_pools_name_label', page_locale()) }}</th>
                            <th>{{ t('admin_port_pools_node_label', page_locale()) }}</th>
                            <th>{{ t('admin_port_pools_range_label', page_locale()) }}</th>
                            <th>{{ t('admin_server_ports_strategy_label', page_locale()) }}</th>
                            <th>{{ t('admin_status_enabled', page_locale()) }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for pool in portPools %}
                            <tr>
                                <td class="font-mono text-xs" style="color:var(--ng-text)">{{ pool.id }}</td>
                                <td>
                                    <div class="font-semibold" style="color:var(--ng-text)">{{ pool.name }}</div>
                                    <div class="text-xs" style="color:var(--ng-text-muted)">{{ pool.tag }}</div>
                                </td>
                                <td>{{ pool.node.name ?? pool.node.id }}</td>
                                <td><span class="ui-badge ui-badge--info">{{ pool.start_port }}-{{ pool.end_port }}</span></td>
                                <td>{{ pool.allocation_step == 10 ? t('admin_server_ports_strategy_gap10', page_locale()) : t('admin_server_ports_strategy_next', page_locale()) }}</td>
                                <td>
                                    {% if pool.enabled %}
                                        <span class="ui-badge ui-badge--success">{{ t('admin_status_enabled', page_locale()) }}</span>
                                    {% else %}
                                        <span class="ui-badge ui-badge--neutral">{{ t('admin_status_disabled', page_locale()) }}</span>
                                    {% endif %}
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="6" class="cust-table__empty">{{ t('admin_port_pools_empty', page_locale()) }}</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    {# Port blocks list #}
    <div class="ng-data-card">
        <div class="ng-data-card__header">
            <div>
                <h2 class="ng-data-card__title">{{ t('admin_server_ports_blocks_title', page_locale()) }}</h2>
                <p class="ng-data-card__sub">{{ t('admin_port_blocks_list_intro', page_locale()) }}</p>
            </div>
            <div class="ng-data-card__actions">
                <span class="ui-badge ui-badge--neutral">{{ portBlocks|length }}</span>
            </div>
        </div>
        <div class="ng-data-card__body ng-data-card__body--flush">
            <div class="cust-ws-table-wrap">
                <table class="cust-table">
                    <thead>
                        <tr>
                            <th>{{ t('admin_label_id', page_locale()) }}</th>
                            <th>{{ t('admin_port_blocks_pool_label', page_locale()) }}</th>
                            <th>{{ t('admin_port_blocks_customer_label', page_locale()) }}</th>
                            <th>{{ t('admin_port_blocks_range_label', page_locale()) }}</th>
                            <th>{{ t('admin_port_blocks_instance_label', page_locale()) }}</th>
                            <th>{{ t('admin_port_blocks_assigned_label', page_locale()) }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for block in portBlocks %}
                            <tr>
                                <td class="font-mono text-xs" style="color:var(--ng-text)">{{ block.id }}</td>
                                <td>{{ block.pool.name }}</td>
                                <td>{{ block.customer.email }}</td>
                                <td><span class="ui-badge ui-badge--info">{{ block.start_port }}-{{ block.end_port }}</span></td>
                                <td>{{ block.instance_id ? '#' ~ block.instance_id : '—' }}</td>
                                <td>{{ block.assigned_at|date('Y-m-d H:i') }}</td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="6" class="cust-table__empty">{{ t('admin_port_blocks_empty', page_locale()) }}</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>
{% endblock %}
