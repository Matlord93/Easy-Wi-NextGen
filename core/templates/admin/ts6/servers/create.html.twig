{% extends 'admin/base.html.twig' %}

{% block title %}TS6 Virtual Server anlegen · Easy-Wi NextGen{% endblock %}

{% block content %}
{% set locale = page_locale() %}
    <div class="ng-data-card">
        <div class="ng-data-card__header">
            <div>
                <h2 class="ng-data-card__title">TS6 Virtual Server anlegen</h2>
                <p class="ng-data-card__sub">Ordne einem Kunden einen TS6 Virtual Server zu.</p>
            </div>
            <div class="ng-data-card__actions">
                <a class="ui-button ui-button--ghost ui-button--sm" href="/admin/ts6/servers">{{ t('overview', locale) }}</a>
                <a class="ui-button ui-button--ghost ui-button--sm" href="/admin/ts6/nodes">Nodes verwalten</a>
            </div>
        </div>
        <div class="ng-data-card__body">
            {% for message in app.flashes('success') %}
                <div class="ng-alert ng-alert--success" style="margin-bottom:16px;">{{ message }}</div>
            {% endfor %}
            {% for message in app.flashes('error') %}
                <div class="ng-alert ng-alert--danger" style="margin-bottom:16px;">{{ message }}</div>
            {% endfor %}
            {{ form_start(form) }}
                {{ form_row(form.customerId) }}
                {{ form_row(form.nodeId) }}
                {{ form_row(form.name) }}
                {{ form_row(form.slots) }}
                {{ form_row(form.voicePort) }}
                <div style="margin-top:20px;">
                    <button class="ui-button ui-button--primary" type="submit">Server erstellen</button>
                </div>
            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}
