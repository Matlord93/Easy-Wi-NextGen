{% extends 'admin/base.html.twig' %}

{% set pageTitle = t('admin_ts6_servers_title', page_locale()) %}
{% set pageSubtitle = t('admin_ts6_servers_intro', page_locale()) %}
{% set activeNav = 'ts6-servers' %}

{% block content %}
{% set locale = page_locale() %}
<div style="display:flex;flex-direction:column;gap:20px;">

    {# ── Hero / KPI ── #}
    <section class="ng-card" style="overflow:hidden;">
        <div class="tkt-hero">
            <div class="tkt-hero__inner">
                <div>
                    <div class="tkt-hero__pill">
                        <span class="tkt-hero__pill-dot" style="background:#a855f7;"></span>
                        TeamSpeak 6
                    </div>
                    <h1 class="tkt-hero__title" style="margin-top:10px;">{{ t('admin_ts6_servers_title', locale) }}</h1>
                    <p class="tkt-hero__sub">{{ t('admin_ts6_servers_intro', locale) }}</p>
                </div>
                <div style="display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:10px;margin-top:16px;">
                    <div class="tkt-kpi">
                        <div class="tkt-kpi__label">{{ t('total', locale) }}</div>
                        <div class="tkt-kpi__value">{{ servers|length }}</div>
                    </div>
                    <div class="tkt-kpi tkt-kpi--open">
                        <div class="tkt-kpi__label">{{ t('admin_ts3_running', locale) }}</div>
                        <div class="tkt-kpi__value">{{ servers|filter(s => s.status == 'running')|length }}</div>
                    </div>
                    <div class="tkt-kpi tkt-kpi--pending">
                        <div class="tkt-kpi__label">{{ t('admin_ts3_stopped', locale) }}</div>
                        <div class="tkt-kpi__value">{{ servers|filter(s => s.status == 'stopped')|length }}</div>
                    </div>
                </div>
            </div>
        </div>
        <div style="padding:14px 16px;border-top:1px solid var(--ng-border);background:var(--ng-surface-soft);display:flex;gap:8px;align-items:center;">
            <a class="ui-button ui-button--primary ui-button--sm" href="/admin/ts6/servers/create">{{ t('admin_ts6_servers_create', locale) }}</a>
            <a class="ui-button ui-button--ghost ui-button--sm" href="/admin/ts6/nodes">{{ t('admin_ts6_servers_manage_nodes', locale) }}</a>
        </div>
    </section>

    {% for message in app.flashes('success') %}
        <div class="ng-alert ng-alert--success">{{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="ng-alert ng-alert--danger">{{ message }}</div>
    {% endfor %}

    <div class="ng-data-card">
        <div class="ng-data-card__header">
            <div>
                <h2 class="ng-data-card__title">{{ t('admin_ts6_servers_title', locale) }}</h2>
                <p class="ng-data-card__sub">{{ t('admin_ts6_servers_intro', locale) }}</p>
            </div>
            <div class="ng-data-card__actions">
                <a class="ui-button ui-button--ghost ui-button--sm" href="/admin/ts6/nodes">{{ t('admin_ts6_servers_manage_nodes', locale) }}</a>
                <a class="ui-button ui-button--primary ui-button--sm" href="/admin/ts6/servers/create">{{ t('admin_ts6_servers_create', locale) }}</a>
            </div>
        </div>
        <div class="ng-data-card__body ng-data-card__body--flush">
            <div class="cust-ws-table-wrap">
                <table class="cust-table">
                    <thead>
                        <tr>
                            <th>{{ t('admin_ts6_servers_col_server', locale) }}</th>
                            <th>{{ t('admin_ts6_servers_col_customer', locale) }}</th>
                            <th>{{ t('admin_ts6_servers_col_node', locale) }}</th>
                            <th>{{ t('admin_ts6_servers_col_slots', locale) }}</th>
                            <th>{{ t('admin_ts6_servers_col_ports', locale) }}</th>
                            <th>{{ t('admin_ts6_servers_col_status', locale) }}</th>
                            <th>{{ t('updated', locale) }}</th>
                            <th>{{ t('admin_ts6_assignment', locale) }}</th>
                            <th>{{ t('actions', locale) }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for server in servers %}
                            {% set customer = customerMap[server.customerId] ?? null %}
                            <tr>
                                <td>
                                    <div>{{ server.name }}</div>
                                    <div style="font-size:.75rem;color:var(--color-text-muted,#64748b);">SID {{ server.sid }} · #{{ server.id }}</div>
                                </td>
                                <td>
                                    {% if customer %}
                                        <div>{{ customer.name ?? customer.email }}</div>
                                        <div style="font-size:.75rem;color:var(--color-text-muted,#64748b);">#{{ customer.id }}</div>
                                    {% else %}
                                        <span style="color:var(--color-text-muted,#64748b);font-size:.75rem;">{{ t('customer_ts_unknown', locale) }}</span>
                                    {% endif %}
                                </td>
                                <td>
                                    <div>{{ server.node.name }}</div>
                                    <div style="font-size:.75rem;color:var(--color-text-muted,#64748b);">#{{ server.node.id }}</div>
                                </td>
                                <td>{{ server.slots }}</td>
                                <td style="font-size:.75rem;">
                                    <div>Voice: {{ server.voicePort ?? '—' }}</div>
                                    <div style="color:var(--color-text-muted,#64748b);">File: {{ server.filetransferPort ?? '—' }}</div>
                                </td>
                                <td>
                                    {% set statusBadge = server.status == 'running' ? 'success' : (server.status == 'stopped' ? 'warning' : (server.status == 'error' ? 'danger' : 'neutral')) %}
                                    <span class="ui-badge ui-badge--{{ statusBadge }}">{{ t('admin_ts6_status_' ~ server.status, locale) }}</span>
                                    {% set error = serverErrors[server.id] ?? null %}
                                    {% if error %}
                                        <div style="font-size:.75rem;color:#e11d48;margin-top:4px;"><strong>{{ t('customer_ts_action_error_prefix', locale) }}:</strong> {{ error.error ?? t('admin_ts6_unknown_error', locale) }}</div>
                                    {% elseif server.status == 'external' %}
                                        <div style="font-size:.75rem;color:var(--color-text-muted,#64748b);margin-top:4px;">{{ t('admin_ts6_status_external_hint', locale) }}</div>
                                    {% elseif server.status == 'missing' %}
                                        <div style="font-size:.75rem;color:var(--color-text-muted,#64748b);margin-top:4px;">{{ t('admin_ts6_status_missing_hint', locale) }}</div>
                                    {% elseif server.status == 'error' %}
                                        <div style="font-size:.75rem;color:var(--color-text-muted,#64748b);margin-top:4px;">{{ t('admin_ts6_status_error_hint', locale) }}</div>
                                    {% endif %}
                                </td>
                                <td>{{ server.updatedAt|date('Y-m-d H:i') }}</td>
                                <td>
                                    <form method="post" action="/admin/ts6/servers/{{ server.id }}/assign" style="display:flex;gap:8px;align-items:center;">
                                        <input type="hidden" name="_token" value="{{ csrf[server.id] ?? '' }}">
                                        <select name="customer_id" class="form-input" style="font-size:.75rem;padding:4px 8px;">
                                            {% for customerOption in customers %}
                                                <option value="{{ customerOption.id }}" {{ customerOption.id == server.customerId ? 'selected' : '' }}>
                                                    {{ customerOption.name ?? customerOption.email }}
                                                </option>
                                            {% endfor %}
                                        </select>
                                        <button type="submit" class="ui-button ui-button--ghost ui-button--sm">{{ t('admin_ts6_assign', locale) }}</button>
                                    </form>
                                </td>
                                <td>
                                    <form method="post" action="/admin/ts6/servers/{{ server.id }}/delete" onsubmit="return confirm('{{ t('admin_ts6_server_delete_confirm', locale) }}');">
                                        <input type="hidden" name="_token" value="{{ deleteTokens[server.id] ?? '' }}">
                                        <button type="submit" class="ui-button ui-button--danger ui-button--sm">{{ t('admin_ts6_server_delete', locale) }}</button>
                                    </form>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="9" class="cust-table__empty">{{ t('admin_ts6_servers_empty', locale) }}</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>
{% endblock %}
