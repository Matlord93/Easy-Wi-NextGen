{% extends 'admin/base.html.twig' %}

{% block title %}TS6 Node · Easy-Wi NextGen{% endblock %}

{% block content %}
{% set locale = page_locale() %}

    {# ── Hero ── #}
    <section class="ng-card" style="overflow:hidden;">
        <div class="tkt-hero">
            <div class="tkt-hero__inner">
                <div>
                    <div class="tkt-hero__pill">
                        <span class="tkt-hero__pill-dot" style="background:#a78bfa;"></span>
                        TeamSpeak 6
                    </div>
                    <h1 class="tkt-hero__title" style="margin-top:10px;">{{ node.name }}</h1>
                    <p class="tkt-hero__sub" style="font-family:monospace;">{{ node.agentBaseUrl }}</p>
                </div>
                <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
                    <a class="ui-button ui-button--ghost ui-button--sm" href="/admin/ts6/nodes">{{ t('admin_ts6_node_show_back', locale) }}</a>
                    <form method="post" action="/admin/ts6/nodes/{{ node.id }}/delete" onsubmit="return confirm('{{ t('admin_ts6_node_delete_confirm', locale) }}');">
                        <input type="hidden" name="_token" value="{{ csrf.delete }}">
                        <button class="ui-button ui-button--danger ui-button--sm" type="submit">{{ t('admin_ts6_node_delete', locale) }}</button>
                    </form>
                </div>
            </div>
        </div>
    </section>

    {% for message in app.flashes('success') %}
        <div class="ng-alert ng-alert--success" style="margin-top:16px;">{{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="ng-alert ng-alert--danger" style="margin-top:16px;">{{ message }}</div>
    {% endfor %}

    <div style="display:flex;flex-direction:column;gap:20px;margin-top:20px;">

        {# ── Status & Actions ── #}
        <div class="ng-data-card">
            <div class="ng-data-card__header">
                <div>
                    <h2 class="ng-data-card__title">{{ t('admin_ts6_node_status_title', locale) }}</h2>
                </div>
            </div>
            <div class="ng-data-card__body">
                <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:10px;margin-bottom:16px;">
                    <div style="padding:10px 14px;border-radius:var(--ng-radius);background:var(--ng-surface-soft);border:1px solid var(--ng-border);">
                        <p style="margin:0 0 2px;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--ng-text-muted);">{{ t('admin_ts6_node_install_status', locale) }}</p>
                        <p style="margin:0;font-size:14px;font-weight:600;color:var(--ng-text);">{{ node.installStatus }}</p>
                    </div>
                    <div style="padding:10px 14px;border-radius:var(--ng-radius);background:var(--ng-surface-soft);border:1px solid var(--ng-border);">
                        <p style="margin:0 0 2px;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--ng-text-muted);">{{ t('admin_ts6_node_version', locale) }}</p>
                        <p style="margin:0;font-size:14px;font-weight:600;color:var(--ng-text);font-family:monospace;">{{ node.installedVersion ?? '—' }}</p>
                    </div>
                    <div style="padding:10px 14px;border-radius:var(--ng-radius);background:var(--ng-surface-soft);border:1px solid var(--ng-border);">
                        <p style="margin:0 0 2px;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--ng-text-muted);">{{ t('admin_ts6_node_service', locale) }}</p>
                        <p style="margin:0;font-size:14px;font-weight:600;color:var(--ng-text);">{{ node.serviceName }}</p>
                    </div>
                    <div style="padding:10px 14px;border-radius:var(--ng-radius);background:{% if node.running %}rgba(34,197,94,.07){% else %}rgba(245,158,11,.07){% endif %};border:1px solid {% if node.running %}rgba(34,197,94,.25){% else %}rgba(245,158,11,.25){% endif %};">
                        <p style="margin:0 0 2px;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--ng-text-muted);">{{ t('admin_ts6_node_running_label', locale) }}</p>
                        <p style="margin:0;font-size:14px;font-weight:600;color:{% if node.running %}#4ade80{% else %}#fbbf24{% endif %};">{{ node.running ? t('admin_ts6_node_status_yes', locale) : t('admin_ts6_node_status_no', locale) }}</p>
                    </div>
                    {% if node.lastError %}
                    <div style="grid-column:span 2;padding:10px 14px;border-radius:var(--ng-radius);background:rgba(244,63,94,.07);border:1px solid rgba(244,63,94,.25);">
                        <p style="margin:0 0 2px;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:rgba(252,165,165,.7);">{{ t('admin_ts6_node_last_error', locale) }}</p>
                        <p style="margin:0;font-size:13px;color:#fca5a5;font-family:monospace;word-break:break-all;">{{ node.lastError }}</p>
                    </div>
                    {% endif %}
                </div>
                <div style="display:flex;flex-wrap:wrap;gap:8px;padding-top:4px;border-top:1px solid var(--ng-border);">
                    <form method="post" action="/admin/ts6/nodes/{{ node.id }}/install">
                        <input type="hidden" name="_token" value="{{ csrf.install }}">
                        <button class="ui-button ui-button--ghost ui-button--sm" type="submit">{{ t('admin_ts6_node_install', locale) }}</button>
                    </form>
                    <form method="post" action="/admin/ts6/nodes/{{ node.id }}/start">
                        <input type="hidden" name="_token" value="{{ csrf.start }}">
                        <button class="ui-button ui-button--ghost ui-button--sm" style="color:#4ade80;border-color:rgba(34,197,94,.3);" type="submit">{{ t('admin_ts6_node_start', locale) }}</button>
                    </form>
                    <form method="post" action="/admin/ts6/nodes/{{ node.id }}/stop">
                        <input type="hidden" name="_token" value="{{ csrf.stop }}">
                        <button class="ui-button ui-button--ghost ui-button--sm" style="color:#f87171;border-color:rgba(239,68,68,.3);" type="submit">{{ t('admin_ts6_node_stop', locale) }}</button>
                    </form>
                    <form method="post" action="/admin/ts6/nodes/{{ node.id }}/restart">
                        <input type="hidden" name="_token" value="{{ csrf.restart }}">
                        <button class="ui-button ui-button--ghost ui-button--sm" type="submit">{{ t('admin_ts6_node_restart', locale) }}</button>
                    </form>
                </div>
            </div>
        </div>

        {# ── Update ── #}
        <div class="ng-data-card">
            <div class="ng-data-card__header">
                <div>
                    <h2 class="ng-data-card__title">{{ t('admin_ts6_node_update_title', locale) }}</h2>
                    <p class="ng-data-card__sub">{{ t('admin_ts6_node_update_intro', locale) }}</p>
                </div>
                {% if latest_release and latest_release.updateAvailable %}
                <div>
                    <span style="display:inline-flex;align-items:center;gap:5px;padding:4px 10px;border-radius:999px;font-size:11px;font-weight:700;background:rgba(74,222,128,.1);color:#4ade80;border:1px solid rgba(74,222,128,.3);animation:pulse-badge 2s ease-in-out infinite;">
                        <svg style="width:11px;height:11px;" viewBox="0 0 16 16" fill="currentColor"><path fill-rule="evenodd" d="M8 3a5 5 0 1 0 4.546 2.914.5.5 0 0 1 .908-.417A6 6 0 1 1 8 2v1z"/><path d="M8 4.466V.534a.25.25 0 0 1 .41-.192l2.36 1.966c.12.1.12.284 0 .384L8.41 4.658A.25.25 0 0 1 8 4.466z"/></svg>
                        {{ t('admin_ts6_node_update_available', locale) }}: v{{ latest_release.availableVersion }}
                    </span>
                </div>
                {% elseif node.installedVersion %}
                <div>
                    <span style="display:inline-flex;align-items:center;gap:5px;padding:4px 10px;border-radius:999px;font-size:11px;font-weight:700;background:rgba(167,139,250,.1);color:#a78bfa;border:1px solid rgba(167,139,250,.25);">
                        <svg style="width:11px;height:11px;" viewBox="0 0 16 16" fill="currentColor"><path fill-rule="evenodd" d="M8 3a5 5 0 1 0 4.546 2.914.5.5 0 0 1 .908-.417A6 6 0 1 1 8 2v1z"/><path d="M8 4.466V.534a.25.25 0 0 1 .41-.192l2.36 1.966c.12.1.12.284 0 .384L8.41 4.658A.25.25 0 0 1 8 4.466z"/></svg>
                        v{{ node.installedVersion }}
                    </span>
                </div>
                {% endif %}
            </div>
            <div class="ng-data-card__body">

                {# Update-available banner #}
                {% if latest_release and latest_release.updateAvailable %}
                <div style="display:flex;align-items:center;gap:12px;padding:12px 14px;margin-bottom:16px;border-radius:var(--ng-radius);background:rgba(74,222,128,.07);border:1px solid rgba(74,222,128,.25);">
                    <svg style="width:18px;height:18px;flex-shrink:0;color:#4ade80;" viewBox="0 0 16 16" fill="currentColor"><path fill-rule="evenodd" d="M8 3a5 5 0 1 0 4.546 2.914.5.5 0 0 1 .908-.417A6 6 0 1 1 8 2v1z"/><path d="M8 4.466V.534a.25.25 0 0 1 .41-.192l2.36 1.966c.12.1.12.284 0 .384L8.41 4.658A.25.25 0 0 1 8 4.466z"/></svg>
                    <div style="flex:1;min-width:0;">
                        <p style="margin:0 0 2px;font-size:13px;font-weight:700;color:#4ade80;">{{ t('admin_ts6_node_update_available_banner', locale) }}</p>
                        <p style="margin:0;font-size:12px;color:var(--ng-text-muted);">
                            {{ latest_release.releaseTag ?? ('v' ~ latest_release.availableVersion) }}
                            {% if latest_release.assetName %} · {{ latest_release.assetName }}{% endif %}
                        </p>
                    </div>
                </div>
                {% endif %}

                <div style="display:grid;grid-template-columns:1fr 1fr{% if latest_release and latest_release.availableVersion %} 1fr{% endif %};gap:10px;margin-bottom:16px;">
                    <div style="padding:12px 14px;border-radius:var(--ng-radius);background:var(--ng-surface-soft);border:1px solid var(--ng-border);">
                        <p style="margin:0 0 4px;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--ng-text-muted);">{{ t('admin_ts6_node_update_installed', locale) }}</p>
                        <p style="margin:0;font-size:18px;font-weight:700;color:var(--ng-text);font-family:monospace;">{{ node.installedVersion ?? '—' }}</p>
                    </div>
                    {% if latest_release and latest_release.availableVersion %}
                    <div style="padding:12px 14px;border-radius:var(--ng-radius);background:{% if latest_release.updateAvailable %}rgba(74,222,128,.06){% else %}var(--ng-surface-soft){% endif %};border:1px solid {% if latest_release.updateAvailable %}rgba(74,222,128,.2){% else %}var(--ng-border){% endif %};">
                        <p style="margin:0 0 4px;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--ng-text-muted);">{{ t('admin_ts6_node_update_available_version', locale) }}</p>
                        <p style="margin:0;font-size:18px;font-weight:700;color:{% if latest_release.updateAvailable %}#4ade80{% else %}var(--ng-text){% endif %};font-family:monospace;">{{ latest_release.availableVersion }}</p>
                    </div>
                    {% endif %}
                    <div style="padding:12px 14px;border-radius:var(--ng-radius);background:var(--ng-surface-soft);border:1px solid var(--ng-border);">
                        <p style="margin:0 0 4px;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--ng-text-muted);">{{ t('admin_ts6_node_update_last_updated', locale) }}</p>
                        <p style="margin:0;font-size:13px;font-weight:600;color:var(--ng-text);">{{ node.updatedAt ? node.updatedAt|date('Y-m-d H:i') : '—' }}</p>
                    </div>
                </div>
                <div style="padding:12px 14px;margin-bottom:16px;border-radius:var(--ng-radius);background:rgba(167,139,250,.06);border:1px solid rgba(167,139,250,.2);font-size:13px;color:var(--ng-text-muted);">
                    <svg style="width:14px;height:14px;display:inline;vertical-align:-2px;margin-right:5px;color:#a78bfa;" viewBox="0 0 16 16" fill="currentColor"><path d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16zm.93-9.412-1 4.705c-.07.34.029.533.304.533.194 0 .487-.07.686-.246l-.088.416c-.287.346-.92.598-1.465.598-.703 0-1.002-.422-.808-1.319l.738-3.468c.064-.293.006-.399-.287-.47l-.451-.081.082-.381 2.29-.287zM8 5.5a1 1 0 1 1 0-2 1 1 0 0 1 0 2z"/></svg>
                    {{ t('admin_ts6_node_update_hint', locale) }}
                </div>
                <form method="post" action="/admin/ts6/nodes/{{ node.id }}/update">
                    <input type="hidden" name="_token" value="{{ csrf.update }}">
                    <button class="ui-button ui-button--primary" {% if latest_release and latest_release.updateAvailable %}style="background:#16a34a;border-color:#16a34a;"{% endif %} type="submit">
                        <svg style="width:13px;height:13px;" viewBox="0 0 16 16" fill="currentColor"><path fill-rule="evenodd" d="M8 3a5 5 0 1 0 4.546 2.914.5.5 0 0 1 .908-.417A6 6 0 1 1 8 2v1z"/><path d="M8 4.466V.534a.25.25 0 0 1 .41-.192l2.36 1.966c.12.1.12.284 0 .384L8.41 4.658A.25.25 0 0 1 8 4.466z"/></svg>
                        {% if latest_release and latest_release.updateAvailable %}
                            {{ t('admin_ts6_node_update_btn_install', locale) }} v{{ latest_release.availableVersion }}
                        {% else %}
                            {{ t('admin_ts6_node_update_btn', locale) }}
                        {% endif %}
                    </button>
                </form>
            </div>
        </div>
        <style>@keyframes pulse-badge{0%,100%{opacity:1}50%{opacity:.65}}</style>

        {# ── Recent Jobs ── #}
        <div class="ng-data-card">
            <div class="ng-data-card__header">
                <div>
                    <h2 class="ng-data-card__title">{{ t('admin_ts6_node_jobs_title', locale) }}</h2>
                    <p class="ng-data-card__sub">{{ t('admin_ts6_node_jobs_intro', locale) }}</p>
                </div>
            </div>
            {% set jobStatusLabels = {
                'queued':  t('agent_job_status_queued', locale),
                'running': t('agent_job_status_running', locale),
                'success': t('agent_job_status_success', locale),
                'failed':  t('agent_job_status_failed', locale),
            } %}
            {% if agent_jobs is not empty %}
            <div class="ng-data-card__body ng-data-card__body--flush">
                <div class="cust-ws-table-wrap">
                    <table class="cust-table">
                        <thead>
                            <tr>
                                <th>{{ t('admin_ts6_node_job_type', locale) }}</th>
                                <th>{{ t('admin_ts6_node_job_status', locale) }}</th>
                                <th>{{ t('admin_ts6_node_job_started', locale) }}</th>
                                <th>{{ t('admin_ts6_node_job_finished', locale) }}</th>
                                <th>{{ t('admin_ts6_node_job_error', locale) }}</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for job in agent_jobs %}
                            {% set jobStatusBadge = job.status.value in ['success','done','finished'] ? 'success' : (job.status.value == 'failed' ? 'danger' : (job.status.value in ['pending','queued'] ? 'warning' : 'info')) %}
                            {% set jobTypeKey = 'agent_job_type_' ~ job.type|replace({'.': '_'}) %}
                            {% set jobTypeLabel = t(jobTypeKey, locale) %}
                            {% set jobTypeLabel = jobTypeLabel == jobTypeKey ? job.type : jobTypeLabel %}
                            <tr>
                                <td>
                                    <span style="font-weight:600;font-size:13px;color:var(--ng-text);">{{ jobTypeLabel }}</span>
                                    <span style="display:block;font-family:monospace;font-size:10px;color:var(--ng-text-muted);margin-top:1px;">{{ job.type }}</span>
                                </td>
                                <td>
                                    <span class="ui-badge ui-badge--{{ jobStatusBadge }}">{{ jobStatusLabels[job.status.value] ?? job.status.value }}</span>
                                </td>
                                <td style="font-size:12px;color:var(--ng-text-muted);">{{ job.startedAt ? job.startedAt|date('Y-m-d H:i') : '—' }}</td>
                                <td style="font-size:12px;color:var(--ng-text-muted);">{{ job.finishedAt ? job.finishedAt|date('Y-m-d H:i') : '—' }}</td>
                                <td style="font-size:12px;color:#f87171;max-width:220px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{{ job.errorText ?? '—' }}</td>
                                <td>
                                    {% if job.logText or job.resultPayload %}
                                    <button type="button" class="ui-button ui-button--ghost ui-button--sm" onclick="this.closest('tr').nextElementSibling.classList.toggle('hidden')">
                                        {{ t('admin_ts6_node_jobs_details', locale) }}
                                    </button>
                                    {% endif %}
                                </td>
                            </tr>
                            {% if job.logText or job.resultPayload %}
                            <tr class="hidden">
                                <td colspan="6" style="padding:0;">
                                    <div style="padding:12px 16px;background:var(--ng-surface-soft);border-top:1px solid var(--ng-border);">
                                        {% if job.logText %}
                                        <pre style="margin:0 0 10px;max-height:200px;overflow:auto;border-radius:6px;border:1px solid var(--ng-border);background:var(--ng-surface);padding:10px;font-size:11px;color:var(--ng-text);line-height:1.6;">{{ job.logText }}</pre>
                                        {% endif %}
                                        {% if job.resultPayload %}
                                        <pre style="margin:0;max-height:160px;overflow:auto;border-radius:6px;border:1px solid var(--ng-border);background:var(--ng-surface);padding:10px;font-size:11px;color:var(--ng-text);line-height:1.6;">{{ job.resultPayload|json_encode(constant('JSON_PRETTY_PRINT')) }}</pre>
                                        {% endif %}
                                    </div>
                                </td>
                            </tr>
                            {% endif %}
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
            {% else %}
            <div class="ng-data-card__body">
                <div style="text-align:center;padding:24px 0;">
                    <svg style="width:32px;height:32px;color:var(--ng-text-muted);margin-bottom:8px;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
                    <p style="margin:0;font-size:13px;color:var(--ng-text-muted);">{{ t('admin_ts6_node_no_jobs', locale) }}</p>
                </div>
            </div>
            {% endif %}
        </div>

        {# ── Admin Credentials ── #}
        <div class="ng-data-card">
            <div class="ng-data-card__header">
                <div>
                    <h2 class="ng-data-card__title">{{ t('admin_ts6_node_credentials_title', locale) }}</h2>
                    <p class="ng-data-card__sub">{{ t('admin_ts6_node_credentials_note', locale) }}</p>
                </div>
                <div>
                    <span style="display:inline-flex;align-items:center;gap:5px;padding:4px 10px;border-radius:999px;font-size:11px;font-weight:700;background:rgba(148,163,184,.1);color:var(--ng-text-muted);border:1px solid var(--ng-border);">
                        <svg style="width:11px;height:11px;" viewBox="0 0 16 16" fill="currentColor"><path d="M8 1a2 2 0 0 1 2 2v4H6V3a2 2 0 0 1 2-2zm3 6V3a3 3 0 0 0-6 0v4a2 2 0 0 0-2 2v5a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z"/></svg>
                        {{ t('admin_ts6_node_credentials_admin_only', locale) }}
                    </span>
                </div>
            </div>
            <div class="ng-data-card__body">
                <div style="display:flex;flex-direction:column;gap:10px;margin-bottom:16px;">
                    <div style="padding:10px 14px;border-radius:var(--ng-radius);background:var(--ng-surface-soft);border:1px solid var(--ng-border);">
                        <p style="margin:0 0 4px;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--ng-text-muted);">{{ t('admin_ts6_node_credentials_username', locale) }}</p>
                        <p style="margin:0;font-size:14px;font-weight:600;color:var(--ng-text);font-family:monospace;">{{ node.adminUsername }}</p>
                    </div>
                    <div style="padding:10px 14px;border-radius:var(--ng-radius);background:var(--ng-surface-soft);border:1px solid var(--ng-border);">
                        <p style="margin:0 0 4px;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--ng-text-muted);">{{ t('admin_ts6_node_credentials_password', locale) }}</p>
                        {% if admin_password %}
                        <div style="display:flex;align-items:center;gap:10px;margin-top:4px;">
                            <p style="margin:0;font-size:14px;font-weight:600;color:var(--ng-text);font-family:monospace;flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{{ admin_password }}</p>
                            <button class="ui-button ui-button--ghost ui-button--sm" type="button" data-ts6-copy="{{ admin_password }}" style="flex-shrink:0;">
                                <svg style="width:13px;height:13px;" viewBox="0 0 16 16" fill="currentColor"><path d="M4 1.5H3a2 2 0 0 0-2 2V14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V3.5a2 2 0 0 0-2-2h-1v1h1a1 1 0 0 1 1 1V14a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V3.5a1 1 0 0 1 1-1h1v-1z"/><path d="M9.5 1a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-3a.5.5 0 0 1-.5-.5v-1a.5.5 0 0 1 .5-.5h3zm-3-1A1.5 1.5 0 0 0 5 1.5v1A1.5 1.5 0 0 0 6.5 4h3A1.5 1.5 0 0 0 11 2.5v-1A1.5 1.5 0 0 0 9.5 0h-3z"/></svg>
                                {{ t('admin_ts6_node_copy', locale) }}
                            </button>
                        </div>
                        {% else %}
                        <p style="margin:4px 0 0;font-size:14px;font-weight:600;color:var(--ng-text-muted);font-family:monospace;letter-spacing:3px;">••••••••••••</p>
                        {% endif %}
                    </div>
                </div>
                <div style="display:flex;align-items:center;gap:10px;">
                    <form method="post" action="/admin/ts6/nodes/{{ node.id }}/show-admin-credentials">
                        <input type="hidden" name="_token" value="{{ csrf.show_admin }}">
                        <button class="ui-button ui-button--primary ui-button--sm" type="submit">
                            <svg style="width:13px;height:13px;" viewBox="0 0 16 16" fill="currentColor"><path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8zM1.173 8a13.133 13.133 0 0 1 1.66-2.043C4.12 4.668 5.88 3.5 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13.133 13.133 0 0 1 14.828 8c-.058.087-.122.183-.195.288-.335.48-.83 1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5c-2.12 0-3.879-1.168-5.168-2.457A13.134 13.134 0 0 1 1.172 8z"/><path d="M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5zM4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0z"/></svg>
                            {{ t('admin_ts6_node_show', locale) }}
                        </button>
                    </form>
                    {% if node.adminPasswordShownOnceAt %}
                    <p style="margin:0;font-size:12px;color:var(--ng-text-muted);">
                        {{ t('admin_ts6_node_last_shown', locale) }} {{ node.adminPasswordShownOnceAt|date('Y-m-d H:i') }}
                    </p>
                    {% endif %}
                </div>
            </div>
        </div>

    </div>

    <script>
        document.querySelectorAll('[data-ts6-copy]').forEach(function (button) {
            var original = button.innerHTML;
            button.addEventListener('click', function () {
                navigator.clipboard?.writeText(button.dataset.ts6Copy || '');
                button.textContent = '✓';
                setTimeout(function () { button.innerHTML = original; }, 1500);
            });
        });
    </script>
{% endblock %}
