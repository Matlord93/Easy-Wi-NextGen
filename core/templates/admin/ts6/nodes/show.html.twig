{% extends 'admin/base.html.twig' %}

{% block title %}TS6 Node · Easy-Wi NextGen{% endblock %}

{% block content %}
{% set locale = page_locale() %}
    <div class="ts6-page">
        <div class="ts6-header">
            <div>
                <h1>{{ node.name }}</h1>
                <p>Agent: {{ node.agentBaseUrl }}</p>
            </div>
            <div class="ts6-actions">
                <a class="ts6-link" href="/admin/ts6/nodes">{{ t('admin_ts6_node_show_back', locale) }}</a>
                <form method="post" action="/admin/ts6/nodes/{{ node.id }}/delete" onsubmit="return confirm('{{ t('admin_ts6_node_delete_confirm', locale) }}');">
                    <input type="hidden" name="_token" value="{{ csrf.delete }}">
                    <button class="ts6-button" type="submit">{{ t('admin_ts6_node_delete', locale) }}</button>
                </form>
            </div>
        </div>

        {% for message in app.flashes('success') %}
            <div class="ts6-alert ts6-alert-success">{{ message }}</div>
        {% endfor %}

        <div class="ts6-grid">
            <div class="ts6-card">
                <h2>{{ t('admin_ts6_node_status_title', locale) }}</h2>
                <div class="ts6-meta">
                    <div><strong>{{ t('admin_ts6_node_install_status', locale) }}</strong> {{ node.installStatus }}</div>
                    <div><strong>{{ t('admin_ts6_node_runtime', locale) }}</strong> {{ node.running ? 'running' : 'stopped' }}</div>
                    <div><strong>{{ t('admin_ts6_node_version', locale) }}</strong> {{ node.installedVersion ?? '—' }}</div>
                    <div><strong>{{ t('admin_ts6_node_service', locale) }}</strong> {{ node.serviceName }}</div>
                    <div><strong>{{ t('admin_ts6_node_running_label', locale) }}</strong> {{ node.running ? 'Ja' : 'Nein' }}</div>
                    <div><strong>{{ t('admin_ts6_node_last_error', locale) }}</strong> {{ node.lastError ?? '—' }}</div>
                </div>
                <div class="ts6-actions">
                    <form method="post" action="/admin/ts6/nodes/{{ node.id }}/install">
                        <input type="hidden" name="_token" value="{{ csrf.install }}">
                        <button class="ts6-button" type="submit">{{ t('admin_ts6_node_install', locale) }}</button>
                    </form>
                    <form method="post" action="/admin/ts6/nodes/{{ node.id }}/start">
                        <input type="hidden" name="_token" value="{{ csrf.start }}">
                        <button class="ts6-button" type="submit">{{ t('admin_ts6_node_start', locale) }}</button>
                    </form>
                    <form method="post" action="/admin/ts6/nodes/{{ node.id }}/stop">
                        <input type="hidden" name="_token" value="{{ csrf.stop }}">
                        <button class="ts6-button" type="submit">{{ t('admin_ts6_node_stop', locale) }}</button>
                    </form>
                    <form method="post" action="/admin/ts6/nodes/{{ node.id }}/restart">
                        <input type="hidden" name="_token" value="{{ csrf.restart }}">
                        <button class="ts6-button" type="submit">{{ t('admin_ts6_node_restart', locale) }}</button>
                    </form>
                </div>
            </div>

            <div class="ts6-card">
                <h2>{{ t('admin_ts6_node_jobs_title', locale) }}</h2>
                {% if agent_jobs is not empty %}
                    {% for job in agent_jobs %}
                        <div class="ts6-meta">
                            <div><strong>{{ t('admin_ts6_node_job_type', locale) }}</strong> {{ job.type }}</div>
                            <div><strong>{{ t('admin_ts6_node_job_status', locale) }}</strong> {{ job.status.value }}</div>
                            <div><strong>{{ t('admin_ts6_node_job_started', locale) }}</strong> {{ job.startedAt ? job.startedAt|date('Y-m-d H:i') : '—' }}</div>
                            <div><strong>{{ t('admin_ts6_node_job_finished', locale) }}</strong> {{ job.finishedAt ? job.finishedAt|date('Y-m-d H:i') : '—' }}</div>
                            <div><strong>{{ t('admin_ts6_node_job_error', locale) }}</strong> {{ job.errorText ?? '—' }}</div>
                        </div>
                        {% if job.logText %}
                            <div class="ts6-code"><pre>{{ job.logText }}</pre></div>
                        {% endif %}
                        {% if job.resultPayload %}
                            <div class="ts6-code"><pre>{{ job.resultPayload|json_encode(constant('JSON_PRETTY_PRINT')) }}</pre></div>
                        {% endif %}
                        {% if not loop.last %}
                            <p class="ts6-muted">—</p>
                        {% endif %}
                    {% endfor %}
                {% else %}
                    <p class="ts6-muted">{{ t('admin_ts6_node_no_jobs', locale) }}</p>
                {% endif %}
            </div>

            <div class="ts6-card">
                <h2>{{ t('admin_ts6_node_credentials_title', locale) }}</h2>
                <p class="ts6-muted">{{ t('admin_ts6_node_credentials_note', locale) }}</p>
                {% if admin_password %}
                    <div class="ts6-credentials">
                        <div><strong>{{ node.adminUsername }}</strong></div>
                        <div class="ts6-secret">{{ admin_password }}</div>
                    </div>
                    <button class="ts6-button" type="button" data-ts6-copy="{{ admin_password }}">{{ t('admin_ts6_node_copy', locale) }}</button>
                {% else %}
                    <div class="ts6-credentials">
                        <div><strong>{{ node.adminUsername }}</strong></div>
                        <div class="ts6-secret">••••••••</div>
                    </div>
                {% endif %}
                <form method="post" action="/admin/ts6/nodes/{{ node.id }}/show-admin-credentials">
                    <input type="hidden" name="_token" value="{{ csrf.show_admin }}">
                    <button class="ts6-button" type="submit">{{ t('admin_ts6_node_show', locale) }}</button>
                </form>
                {% if node.adminPasswordShownOnceAt %}
                    <p class="ts6-muted">{{ t('admin_ts6_node_last_shown', locale) }} {{ node.adminPasswordShownOnceAt|date('Y-m-d H:i') }}</p>
                {% endif %}
            </div>
        </div>
    </div>
    <script>
        document.querySelectorAll('[data-ts6-copy]').forEach(function (button) {
            button.addEventListener('click', function () {
                navigator.clipboard?.writeText(button.dataset.ts6Copy || '');
            });
        });
    </script>
{% endblock %}
