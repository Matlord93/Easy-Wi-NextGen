{% extends 'admin/base.html.twig' %}

{% block title %}{{ t('admin_ts6_nodes_title', page_locale()) }} · Easy-Wi NextGen{% endblock %}

{% block content %}
{% set locale = page_locale() %}
    <div class="ts6-page">
        <div class="ts6-header">
            <div>
                <h1>{{ t('admin_ts6_nodes_title', locale) }}</h1>
                <p>{{ t('admin_ts6_nodes_intro', locale) }}</p>
            </div>
            <div class="ts6-actions">
                <a class="ts6-button" href="/admin/ts6/nodes/new">{{ t('admin_ts6_nodes_add', locale) }}</a>
            </div>
        </div>

        {% for message in app.flashes('success') %}
            <div class="ts6-alert ts6-alert-success">{{ message }}</div>
        {% endfor %}

        <div class="ts6-card">
            <table class="ts6-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>{{ t('admin_ts6_nodes_status', locale) }}</th>
                        <th>Agent</th>
                        <th>{{ t('admin_ts6_nodes_version', locale) }}</th>
                        <th>{{ t('admin_ts6_nodes_updated', locale) }}</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    {% for node in nodes %}
                        <tr>
                            <td>
                                <strong>{{ node.name }}</strong>
                                <div class="ts6-muted">#{{ node.id }}</div>
                            </td>
                            <td>
                                {% set ts6StatusLabel = node.installStatus %}
                                {% if node.installStatus == 'installed' %}
                                    {% set ts6StatusLabel = node.running ? 'running' : 'stopped' %}
                                {% endif %}
                                <span class="ts6-pill">{{ ts6StatusLabel }}</span>
                            </td>
                            <td>{{ node.agentBaseUrl }}</td>
                            <td>{{ node.installedVersion ?? '—' }}</td>
                            <td>{{ node.updatedAt|date('Y-m-d H:i') }}</td>
                            <td class="ts6-align-right">
                                <a class="ts6-link" href="/admin/ts6/nodes/{{ node.id }}">{{ t('admin_ts6_nodes_details', locale) }}</a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="6" class="ts6-empty">{{ t('admin_ts6_nodes_empty', locale) }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
