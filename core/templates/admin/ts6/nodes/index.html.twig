{% extends 'admin/base.html.twig' %}

{% set pageTitle = t('admin_ts6_nodes_title', page_locale()) %}
{% set pageSubtitle = t('admin_ts6_nodes_intro', page_locale()) %}
{% set activeNav = 'ts6-nodes' %}

{% block content %}
{% set locale = page_locale() %}
<div style="display:flex;flex-direction:column;gap:20px;">

    {% for message in app.flashes('success') %}
        <div class="ng-alert ng-alert--success">{{ message }}</div>
    {% endfor %}

    <div class="ng-data-card">
        <div class="ng-data-card__header">
            <div>
                <h2 class="ng-data-card__title">{{ t('admin_ts6_nodes_title', locale) }}</h2>
                <p class="ng-data-card__sub">{{ t('admin_ts6_nodes_intro', locale) }}</p>
            </div>
            <div class="ng-data-card__actions">
                <a class="ui-button ui-button--primary ui-button--sm" href="/admin/ts6/nodes/new">{{ t('admin_ts6_nodes_add', locale) }}</a>
            </div>
        </div>
        <div class="ng-data-card__body ng-data-card__body--flush">
            <div class="cust-ws-table-wrap">
                <table class="cust-table">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>{{ t('admin_ts6_nodes_status', locale) }}</th>
                            <th>Agent</th>
                            <th>{{ t('admin_ts6_nodes_version', locale) }}</th>
                            <th>{{ t('admin_ts6_nodes_updated', locale) }}</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for node in nodes %}
                            <tr>
                                <td>
                                    <div class="font-medium">{{ node.name }}</div>
                                    <div class="text-xs text-slate-500">#{{ node.id }}</div>
                                </td>
                                <td>
                                    {% set ts6StatusLabel = node.installStatus %}
                                    {% if node.installStatus == 'installed' %}
                                        {% set ts6StatusLabel = node.running ? 'running' : 'stopped' %}
                                    {% endif %}
                                    {% set statusBadge = ts6StatusLabel == 'running' ? 'success' : (ts6StatusLabel == 'stopped' ? 'warning' : 'neutral') %}
                                    <span class="ui-badge ui-badge--{{ statusBadge }}">{{ t('admin_node_status_' ~ ts6StatusLabel, locale) }}</span>
                                </td>
                                <td>{{ node.agentBaseUrl }}</td>
                                <td>{{ node.installedVersion ?? '—' }}</td>
                                <td>{{ node.updatedAt|date('Y-m-d H:i') }}</td>
                                <td class="text-right">
                                    <a class="ui-button ui-button--ghost ui-button--sm" href="/admin/ts6/nodes/{{ node.id }}">{{ t('admin_ts6_nodes_details', locale) }}</a>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="6" class="cust-table__empty">{{ t('admin_ts6_nodes_empty', locale) }}</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>
{% endblock %}
