{% extends 'admin/base.html.twig' %}

{% block title %}{{ t('admin_ts6_node_new_title', page_locale()) }} · Easy-Wi NextGen{% endblock %}

{% block content %}
{% set locale = page_locale() %}
    <div class="ts6-page">
        <div class="ts6-header">
            <div>
                <h1>{{ t('admin_ts6_node_new_title', locale) }}</h1>
                <p>{{ t('admin_ts6_node_new_intro', locale) }}</p>
            </div>
        </div>

        <div class="ts6-card">
            <p class="ts6-muted">{{ t('admin_ts6_node_agent_hint', locale) }}</p>
            {{ form_start(form, { attr: { class: 'ts6-form' } }) }}
                {{ form_errors(form) }}
                <div class="ts6-grid">
                    {{ form_row(form.name) }}
                    {{ form_row(form.agentNodeId, { label: 'Agent Node' }) }}
                    {{ form_row(form.osType) }}
                    {{ form_row(form.downloadUrl) }}
                    <div class="ts6-muted">{{ t('admin_ts6_node_download_hint', locale) }}</div>
                    {{ form_row(form.installPath, { label: 'Installationspfad' }) }}
                    {{ form_row(form.instanceName) }}
                    {{ form_row(form.serviceName) }}
                    {{ form_row(form.queryBindIp) }}
                    {{ form_row(form.queryHttpsPort) }}
                    {{ form_row(form.voicePort, { label: 'Default Voice Port' }) }}
                </div>
                <div class="ts6-actions">
                    <button class="ts6-button" type="submit">{{ t('admin_ts6_node_save', locale) }}</button>
                </div>
            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}
