{% extends 'admin/base.html.twig' %}

{% block title %}{{ t('admin_ts6_node_new_title', page_locale()) }} · Easy-Wi NextGen{% endblock %}

{% block content %}
{% set locale = page_locale() %}
    <div class="ng-data-card">
        <div class="ng-data-card__header">
            <div>
                <h2 class="ng-data-card__title">{{ t('admin_ts6_node_new_title', locale) }}</h2>
                <p class="ng-data-card__sub">{{ t('admin_ts6_node_new_intro', locale) }}</p>
            </div>
            <div class="ng-data-card__actions">
                <a class="ui-button ui-button--ghost ui-button--sm" href="/admin/ts6/nodes">{{ t('admin_ts6_node_show_back', locale) }}</a>
            </div>
        </div>
        <div class="ng-data-card__body">
            <p style="color:#64748b;font-size:14px;margin-bottom:16px;">{{ t('admin_ts6_node_agent_hint', locale) }}</p>
            {{ form_start(form) }}
                {{ form_errors(form) }}
                {{ form_row(form.name) }}
                {{ form_row(form.agentNodeId, { label: 'Agent Node' }) }}
                {{ form_row(form.osType) }}
                {{ form_row(form.downloadUrl) }}
                <p style="color:#64748b;font-size:13px;margin-bottom:8px;">{{ t('admin_ts6_node_download_hint', locale) }}</p>
                {{ form_row(form.installPath, { label: 'Installationspfad' }) }}
                {{ form_row(form.instanceName) }}
                {{ form_row(form.serviceName) }}
                {{ form_row(form.queryBindIp) }}
                {{ form_row(form.queryHttpsPort) }}
                {{ form_row(form.voicePort, { label: 'Default Voice Port' }) }}
                <div style="margin-top:20px;">
                    <button class="ui-button ui-button--primary" type="submit">{{ t('admin_ts6_node_save', locale) }}</button>
                </div>
            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}
