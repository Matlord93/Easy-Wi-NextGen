{% extends 'admin/base.html.twig' %}

{% set pageTitle = t('admin_ts6_heading', page_locale()) %}
{% set pageSubtitle = t('admin_ts6_intro', page_locale()) %}
{% set activeNav = 'ts6' %}

{% block content %}
{% set locale = page_locale() %}
<div style="display:flex;flex-direction:column;gap:20px;">

    <section class="ng-card" style="overflow:hidden;">
        <div class="tkt-hero">
            <div class="tkt-hero__inner">
                <div>
                    <div class="tkt-hero__pill"><span class="tkt-hero__pill-dot"></span> TeamSpeak 6 (Experimental)</div>
                    <h1 class="tkt-hero__title" style="margin-top:10px;">{{ t('admin_ts6_heading', locale) }}</h1>
                    <p class="tkt-hero__sub">{{ t('admin_ts6_intro', locale) }}</p>
                </div>
            </div>
        </div>
    </section>

    <div class="ng-data-card">
        <div class="ng-data-card__header">
            <div>
                <h2 class="ng-data-card__title">
                    {{ t('admin_ts6_heading', locale) }}
                    <span class="ui-badge ui-badge--warning">{{ t('admin_ts6_badge_planned', locale) }}</span>
                    <span class="ui-badge ui-badge--primary">{{ t('admin_ts6_badge_experimental', locale) }}</span>
                </h2>
                <p class="ng-data-card__sub">{{ t('admin_ts6_intro', locale) }}</p>
            </div>
        </div>
        {% if notice %}
            <div class="ng-data-card__body">
                <div class="ng-alert ng-alert--success">{{ t(notice, locale) }}</div>
            </div>
        {% endif %}
    </div>

    <div class="ng-data-card">
        <div class="ng-data-card__header">
            <div>
                <h2 class="ng-data-card__title">{{ t('admin_ts6_instances_title', locale) }}</h2>
                <p class="ng-data-card__sub">{{ t('admin_ts6_instances_intro', locale) }}</p>
            </div>
        </div>
        <div class="ng-data-card__body">
            <form class="ng-layout-2col--equal" method="post" action="/admin/ts6/create">
                <div class="form-field">
                    <label class="form-label">{{ t('admin_ts6_customer_label', locale) }}</label>
                    <select name="customer_id" class="form-input">
                        <option value="">{{ t('admin_ts6_customer_select', locale) }}</option>
                        {% for customer in customers %}
                            <option value="{{ customer.id }}">{{ customer.email }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="form-field">
                    <label class="form-label">{{ t('admin_ts6_node_label', locale) }}</label>
                    <select name="node_id" class="form-input">
                        <option value="">{{ t('admin_ts6_node_select', locale) }}</option>
                        {% for node in nodes_for_form %}
                            <option value="{{ node.id }}">{{ node.name ?? node.id }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="form-field">
                    <label class="form-label">{{ t('admin_ts6_instance_name_label', locale) }}</label>
                    <input name="name" class="form-input" placeholder="TS6 Node">
                </div>
                <div style="display:flex;align-items:flex-end;">
                    <button type="submit" class="ui-button ui-button--primary">{{ t('admin_ts6_create_action', locale) }}</button>
                </div>
            </form>
        </div>
        <div class="ng-data-card__body ng-data-card__body--flush">
            <div class="cust-ws-table-wrap">
                <table class="cust-table">
                    <thead>
                        <tr>
                            <th>{{ t('admin_ts6_table_instance', locale) }}</th>
                            <th>{{ t('admin_ts6_table_customer', locale) }}</th>
                            <th>{{ t('admin_ts6_table_node', locale) }}</th>
                            <th>{{ t('admin_ts6_table_status', locale) }}</th>
                            <th>{{ t('admin_ts6_table_updated', locale) }}</th>
                            <th>{{ t('admin_ts6_table_actions', locale) }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% set statusBadgeMap = {
                            planned: 'warning',
                            provisioning: 'info',
                            running: 'success',
                            stopped: 'neutral',
                            error: 'danger'
                        } %}
                        {% for instance in instances %}
                            <tr>
                                <td>
                                    <div style="font-weight:500;">{{ instance.name }}</div>
                                    <div style="font-size:11px;color:#94a3b8;">#{{ instance.id }}</div>
                                </td>
                                <td>
                                    <div>{{ instance.customer.email }}</div>
                                    <div style="font-size:11px;color:#94a3b8;">#{{ instance.customer.id }}</div>
                                </td>
                                <td>
                                    <div>{{ instance.node.name }}</div>
                                    <div style="font-size:11px;color:#94a3b8;">{{ instance.node.id }}</div>
                                </td>
                                <td>
                                    <span class="ui-badge ui-badge--{{ statusBadgeMap[instance.status] ?? 'neutral' }}">
                                        {{ t('admin_ts6_status_' ~ instance.status, locale) }}
                                    </span>
                                </td>
                                <td>{{ instance.updated_at|date('Y-m-d H:i') }}</td>
                                <td>
                                    <div style="display:flex;flex-wrap:wrap;gap:8px;">
                                        <form method="post" action="/admin/ts6/{{ instance.id }}/action">
                                            <input type="hidden" name="action" value="start">
                                            <button type="submit" class="ui-button ui-button--ghost ui-button--sm">{{ t('admin_ts6_action_start', locale) }}</button>
                                        </form>
                                        <form method="post" action="/admin/ts6/{{ instance.id }}/action">
                                            <input type="hidden" name="action" value="stop">
                                            <button type="submit" class="ui-button ui-button--ghost ui-button--sm">{{ t('admin_ts6_action_stop', locale) }}</button>
                                        </form>
                                        <form method="post" action="/admin/ts6/{{ instance.id }}/action">
                                            <input type="hidden" name="action" value="restart">
                                            <button type="submit" class="ui-button ui-button--ghost ui-button--sm">{{ t('admin_ts6_action_restart', locale) }}</button>
                                        </form>
                                        <form method="post" action="/admin/ts6/{{ instance.id }}/action">
                                            <input type="hidden" name="action" value="update">
                                            <button type="submit" class="ui-button ui-button--ghost ui-button--sm">{{ t('admin_ts6_action_update', locale) }}</button>
                                        </form>
                                    </div>
                                    <div style="margin-top:8px;display:flex;flex-wrap:wrap;gap:8px;">
                                        <form method="post" action="/admin/ts6/{{ instance.id }}/action" style="display:flex;flex-wrap:wrap;align-items:center;gap:8px;">
                                            <input type="hidden" name="action" value="backup">
                                            <input name="backup_path" class="form-input" style="font-size:11px;padding:4px 8px;width:160px;" placeholder="{{ t('admin_ts6_backup_placeholder', locale) }}">
                                            <button type="submit" class="ui-button ui-button--ghost ui-button--sm">{{ t('admin_ts6_action_backup', locale) }}</button>
                                        </form>
                                        <form method="post" action="/admin/ts6/{{ instance.id }}/action" style="display:flex;flex-wrap:wrap;align-items:center;gap:8px;">
                                            <input type="hidden" name="action" value="restore">
                                            <input name="restore_path" class="form-input" style="font-size:11px;padding:4px 8px;width:160px;" placeholder="{{ t('admin_ts6_restore_placeholder', locale) }}">
                                            <button type="submit" class="ui-button ui-button--ghost ui-button--sm">{{ t('admin_ts6_action_restore', locale) }}</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="6" class="cust-table__empty">{{ t('admin_ts6_instances_empty', locale) }}</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="ng-layout-2col">

        <div class="ng-data-card">
            <div class="ng-data-card__header">
                <div>
                    <h2 class="ng-data-card__title">{{ t('admin_ts6_capabilities_title', locale) }}</h2>
                    <p class="ng-data-card__sub">{{ t('admin_ts6_capabilities_intro', locale) }}</p>
                </div>
            </div>
            <div class="ng-data-card__body ng-data-card__body--flush">
                <div class="cust-ws-table-wrap">
                    <table class="cust-table">
                        <thead>
                            <tr>
                                <th>{{ t('admin_ts6_table_node', locale) }}</th>
                                <th>{{ t('admin_ts6_table_status', locale) }}</th>
                                <th>{{ t('admin_ts6_table_capability', locale) }}</th>
                                <th>{{ t('admin_ts6_table_last_seen', locale) }}</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for node in nodes %}
                                <tr>
                                    <td>
                                        <div style="font-weight:500;">{{ node.name ?? node.id }}</div>
                                        <div style="font-size:11px;color:#94a3b8;">{{ node.id }}</div>
                                    </td>
                                    <td>
                                        <span class="ui-badge ui-badge--neutral">{{ node.status }}</span>
                                    </td>
                                    <td>
                                        {% if node.ts6_supported %}
                                            <span class="ui-badge ui-badge--success">{{ t('admin_ts6_capability_supported', locale) }}</span>
                                        {% else %}
                                            <span class="ui-badge ui-badge--neutral">{{ t('admin_ts6_capability_missing', locale) }}</span>
                                        {% endif %}
                                    </td>
                                    <td>{{ node.last_seen_at ? node.last_seen_at|date('Y-m-d H:i') : '—' }}</td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="4" class="cust-table__empty">{{ t('admin_ts6_nodes_empty', locale) }}</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="ng-data-card">
            <div class="ng-data-card__header">
                <div>
                    <h2 class="ng-data-card__title">{{ t('admin_ts6_planned_title', locale) }}</h2>
                    <p class="ng-data-card__sub">{{ t('admin_ts6_planned_intro', locale) }}</p>
                </div>
            </div>
            <div class="ng-data-card__body">
                <ul style="display:flex;flex-direction:column;gap:8px;font-size:14px;color:#334155;list-style:none;padding:0;margin:0;">
                    <li style="display:flex;align-items:flex-start;gap:8px;">
                        <span style="margin-top:4px;width:8px;height:8px;border-radius:50%;background:#6366f1;flex-shrink:0;display:inline-block;"></span>
                        <span>{{ t('admin_ts6_planned_item_physical', locale) }}</span>
                    </li>
                    <li style="display:flex;align-items:flex-start;gap:8px;">
                        <span style="margin-top:4px;width:8px;height:8px;border-radius:50%;background:#6366f1;flex-shrink:0;display:inline-block;"></span>
                        <span>{{ t('admin_ts6_planned_item_virtual', locale) }}</span>
                    </li>
                </ul>
                {% if virtual_servers_enabled %}
                    <div style="margin-top:16px;" class="ng-alert ng-alert--info">
                        <div style="font-weight:600;">{{ t('admin_ts6_virtual_flag_title', locale) }}</div>
                        <p style="margin-top:4px;">{{ t('admin_ts6_virtual_flag_body', locale) }}</p>
                    </div>
                {% else %}
                    <div style="margin-top:16px;" class="ng-alert ng-alert--neutral">
                        <div style="font-weight:600;">{{ t('admin_ts6_virtual_disabled_title', locale) }}</div>
                        <p style="margin-top:4px;">{{ t('admin_ts6_virtual_disabled_body', locale) }}</p>
                    </div>
                {% endif %}
            </div>
        </div>

    </div>

</div>
{% endblock %}
