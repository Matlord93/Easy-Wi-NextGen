{% extends 'admin/base.html.twig' %}

{% set pageTitle = 'Backups' %}
{% set activeNav = 'backups' %}
{% set topbarActions = [
    { label: 'Targets', href: path('admin_backups_targets'), variant: 'ghost' },
    { label: 'Settings', href: path('admin_settings_backups'), variant: 'ghost' }
] %}

{% block content %}
<div class="flex flex-col gap-6">
    <div class="ng-data-card">
        <div class="ng-data-card__header">
            <div>
                <h2 class="ng-data-card__title">Backups</h2>
            </div>
            <div class="ng-data-card__actions">
                <a href="{{ path('admin_backups_targets') }}" class="ui-button ui-button--ghost ui-button--sm">Targets</a>
                <a href="{{ path('admin_settings_backups') }}" class="ui-button ui-button--ghost ui-button--sm">Settings</a>
            </div>
        </div>
        <div class="ng-data-card__body--flush">
            <div class="cust-ws-table-wrap">
                <table class="cust-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Instance</th>
                            <th>Customer</th>
                            <th>Target</th>
                            <th>Status</th>
                            <th>Size</th>
                            <th>Created</th>
                            <th>Error</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for backup in backups %}
                            <tr>
                                <td>{{ backup.id }}</td>
                                <td>{{ backup.instance_id }}</td>
                                <td>{{ backup.customer_id }}</td>
                                <td>{{ backup.target ?: 'default' }}</td>
                                <td>{{ backup.status }}</td>
                                <td>{{ backup.size_bytes ?: '—' }}</td>
                                <td>{{ backup.created_at|date('Y-m-d H:i') }}</td>
                                <td>{{ backup.error ?: '—' }}</td>
                            </tr>
                        {% else %}
                            <tr><td colspan="8" class="cust-table__empty">No backups yet.</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{% endblock %}
