{% extends 'admin/base.html.twig' %}

{% block title %}Backup Overview{% endblock %}

{% block body %}
<div class="space-y-4">
    <div class="flex items-center justify-between">
        <h1 class="text-lg font-semibold">Backups</h1>
        <div class="flex gap-2">
            <a class="rounded bg-slate-800 px-3 py-2 text-xs text-white" href="{{ path('admin_backups_targets') }}">Targets</a>
            <a class="rounded bg-slate-800 px-3 py-2 text-xs text-white" href="{{ path('admin_settings_backups') }}">Settings</a>
        </div>
    </div>

    <div class="rounded border border-slate-200 bg-white p-3">
        <table class="min-w-full text-xs">
            <thead><tr><th>ID</th><th>Instance</th><th>Customer</th><th>Target</th><th>Status</th><th>Size</th><th>Created</th><th>Error</th></tr></thead>
            <tbody>
            {% for backup in backups %}
                <tr class="border-t border-slate-100">
                    <td>{{ backup.id }}</td>
                    <td>{{ backup.instance_id }}</td>
                    <td>{{ backup.customer_id }}</td>
                    <td>{{ backup.target ?: 'default' }}</td>
                    <td>{{ backup.status }}</td>
                    <td>{{ backup.size_bytes ?: '—' }}</td>
                    <td>{{ backup.created_at|date('Y-m-d H:i') }}</td>
                    <td>{{ backup.error ?: '—' }}</td>
                </tr>
            {% else %}
                <tr><td colspan="8" class="py-4 text-slate-500">No backups yet.</td></tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
