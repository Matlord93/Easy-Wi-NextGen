{% extends 'admin/base.html.twig' %}

{% set pageTitle = t('admin_backups_title', page_locale()) %}
{% set activeNav = 'backups' %}
{% set topbarActions = [
    { label: t('admin_backups_nav_targets', page_locale()), href: path('admin_backups_targets'), variant: 'ghost' },
    { label: t('admin_backups_nav_settings', page_locale()), href: path('admin_settings_backups'), variant: 'ghost' }
] %}

{% block content %}
<div class="flex flex-col gap-6">
    <div class="ng-data-card">
        <div class="ng-data-card__header">
            <div>
                <h2 class="ng-data-card__title">{{ t('admin_backups_title', page_locale()) }}</h2>
            </div>
            <div class="ng-data-card__actions">
                <a href="{{ path('admin_backups_targets') }}" class="ui-button ui-button--ghost ui-button--sm">{{ t('admin_backups_nav_targets', page_locale()) }}</a>
                <a href="{{ path('admin_settings_backups') }}" class="ui-button ui-button--ghost ui-button--sm">{{ t('admin_backups_nav_settings', page_locale()) }}</a>
            </div>
        </div>
        <div class="ng-data-card__body--flush">
            <div class="cust-ws-table-wrap">
                <table class="cust-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>{{ t('admin_backups_col_instance', page_locale()) }}</th>
                            <th>{{ t('admin_backups_col_customer', page_locale()) }}</th>
                            <th>{{ t('admin_backups_col_target', page_locale()) }}</th>
                            <th>{{ t('status', page_locale()) }}</th>
                            <th>{{ t('size', page_locale()) }}</th>
                            <th>{{ t('created', page_locale()) }}</th>
                            <th>{{ t('error', page_locale()) }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for backup in backups %}
                            <tr>
                                <td>{{ backup.id }}</td>
                                <td>{{ backup.instance_id }}</td>
                                <td>{{ backup.customer_id }}</td>
                                <td>{{ backup.target ?: 'default' }}</td>
                                <td>{{ backup.status }}</td>
                                <td>{{ backup.size_bytes ?: '—' }}</td>
                                <td>{{ backup.created_at|date('Y-m-d H:i') }}</td>
                                <td>{{ backup.error ?: '—' }}</td>
                            </tr>
                        {% else %}
                            <tr><td colspan="8" class="cust-table__empty">{{ t('admin_backups_list_empty', page_locale()) }}</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{% endblock %}
