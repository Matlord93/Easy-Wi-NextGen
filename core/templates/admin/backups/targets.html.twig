{% extends 'admin/base.html.twig' %}
{% set pageTitle = t('admin_backups_targets_title', page_locale()) %}
{% block content %}
{% set locale = page_locale() %}
<div style="display:flex;flex-direction:column;gap:20px;" data-target-upsert-url="{{ path('admin_backups_targets_upsert') }}">

  <section class="ng-card" style="overflow:hidden;">
    <div class="tkt-hero">
      <div class="tkt-hero__inner">
        <div>
          <div class="tkt-hero__pill"><span class="tkt-hero__pill-dot"></span> {{ t('admin_backups_targets_title', locale) }}</div>
          <h1 class="tkt-hero__title" style="margin-top:10px;">{{ t('admin_backups_targets_title', locale) }}</h1>
        </div>
      </div>
    </div>
    <div style="padding:14px 16px;border-top:1px solid var(--ng-border);background:var(--ng-surface-soft);">
      <a class="ui-button ui-button--ghost ui-button--sm" href="{{ path('admin_backups_overview') }}">{{ t('overview', locale) }}</a>
    </div>
  </section>

  <p id="targets-feedback" style="font-size:12px;"></p>

  <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:16px;">
    {% for target in targets %}
      <div class="ng-card" style="padding:14px;" data-target-id="{{ target.id }}" data-target-test-url="{{ path('admin_backups_target_test', {id: target.id}) }}">
        <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:8px;">
          <div>
            <div style="font-size:13px;font-weight:600;color:var(--ng-text);">{{ target.name }}</div>
            <div style="font-size:12px;color:var(--ng-text-muted);">{{ target.type }} · {{ target.enabled ? t('enabled', locale) : t('disabled', locale) }}</div>
            <div style="font-size:12px;color:var(--ng-text-muted);">{{ t('admin_backups_secret_label', locale) }}: {{ target.secret_set ? t('admin_backups_secret_set', locale) : t('admin_backups_secret_not_set', locale) }}</div>
            {% if target.config.url is defined %}<div style="font-size:12px;color:var(--ng-text-muted);">{{ t('host', locale) }}: {{ target.config.url|replace({'https://':'','http://':''})|split('/')[0] }}</div>{% endif %}
            {% if target.config.remote_path is defined %}<div style="font-size:12px;color:var(--ng-text-muted);">{{ t('admin_backups_target_remote_path', locale) }}: {{ target.config.remote_path }}</div>{% endif %}
          </div>
          <button type="button" class="ui-button ui-button--ghost ui-button--sm target-test-button">{{ t('admin_backups_target_test', locale) }}</button>
        </div>
        <p class="target-test-result" style="margin-top:8px;font-size:12px;"></p>
      </div>
    {% endfor %}
  </div>

  <div class="ng-data-card">
    <div class="ng-data-card__header">
      <div>
        <h2 class="ng-data-card__title">{{ t('admin_backups_targets_upsert_title', locale) }}</h2>
      </div>
    </div>
    <div class="ng-data-card__body">
      <form id="target-form" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:12px;">
        <input type="hidden" name="target_id" />
        <div class="form-field">
          <label class="form-label">{{ t('name', locale) }}</label>
          <input class="form-input" name="name" required>
        </div>
        <div class="form-field">
          <label class="form-label">{{ t('type', locale) }}</label>
          <select class="form-input" name="type">
            <option value="local">{{ t('admin_backups_target_local', locale) }}</option>
            <option value="webdav">{{ t('admin_backups_target_webdav', locale) }}</option>
          </select>
        </div>
        <div class="form-field">
          <label class="form-label">{{ t('admin_backups_target_local_path', locale) }}</label>
          <input class="form-input" name="base_path" placeholder="/var/backups">
        </div>
        <div class="form-field">
          <label class="form-label">{{ t('admin_backups_target_webdav_url', locale) }}</label>
          <input class="form-input" name="url" placeholder="https://cloud.example/remote.php/dav/files/user">
        </div>
        <div class="form-field">
          <label class="form-label">{{ t('admin_backups_target_remote_path', locale) }}</label>
          <input class="form-input" name="remote_path" placeholder="/gameserver">
        </div>
        <div class="form-field">
          <label class="form-label">{{ t('username', locale) }}</label>
          <input class="form-input" name="username">
        </div>
        <div class="form-field">
          <label class="form-label">{{ t('admin_backups_target_password', locale) }}</label>
          <input class="form-input" name="password" type="password" placeholder="{{ t('admin_backups_target_password_placeholder', locale) }}">
        </div>
        <div class="form-field">
          <label class="form-label" style="display:flex;align-items:center;gap:8px;">
            <input type="checkbox" name="enabled" checked>
            {{ t('enabled', locale) }}
          </label>
        </div>
        <div class="form-field">
          <label class="form-label" style="display:flex;align-items:center;gap:8px;">
            <input type="checkbox" name="verify_tls" checked>
            {{ t('admin_backups_target_verify_tls', locale) }}
          </label>
        </div>
        <div style="grid-column:1/-1;">
          <button class="ui-button ui-button--primary ui-button--sm" type="submit">{{ t('admin_backups_target_save', locale) }}</button>
        </div>
      </form>
    </div>
  </div>

</div>
<script>
(() => {
    const root = document.querySelector('[data-target-upsert-url]');
    if (!root) return;
    const form = document.getElementById('target-form');
    const feedback = document.getElementById('targets-feedback');
    const MSG_OK = {{ t('admin_backups_target_test_ok', page_locale())|json_encode|raw }};
    const MSG_FAIL = {{ t('admin_backups_target_test_fail', page_locale())|json_encode|raw }};
    const MSG_SAVED = {{ t('admin_backups_target_saved', page_locale())|json_encode|raw }};
    const MSG_SAVE_FAIL = {{ t('admin_backups_target_save_fail', page_locale())|json_encode|raw }};

    document.querySelectorAll('.target-test-button').forEach((button) => {
        button.addEventListener('click', async () => {
            const card = button.closest('[data-target-id]');
            if (!card) return;
            const result = card.querySelector('.target-test-result');
            button.disabled = true;
            try {
                const response = await fetch(card.dataset.targetTestUrl, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({}),
                });
                const data = await response.json().catch(() => ({}));
                const details = data.details || {};
                const status = details.http_status ? ` (${details.http_status})` : '';
                const hint = details.url_host ? ` host=${details.url_host}` : '';
                const remote = details.remote_path ? ` path=${details.remote_path}` : '';
                if (result) {
                    result.textContent = response.ok
                        ? `${data.message || MSG_OK}${status}${hint}${remote}`
                        : `${data.message || data.error || MSG_FAIL}${status}${hint}${remote}`;
                    result.style.color = response.ok ? 'var(--color-success,#059669)' : 'var(--color-danger,#dc2626)';
                }
            } finally {
                button.disabled = false;
            }
        });
    });

    form.addEventListener('submit', async (event) => {
        event.preventDefault();
        const fd = new FormData(form);
        const payload = Object.fromEntries(fd.entries());
        payload.enabled = form.querySelector('[name="enabled"]').checked;
        payload.verify_tls = form.querySelector('[name="verify_tls"]').checked;

        const response = await fetch(root.dataset.targetUpsertUrl, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
        });
        const data = await response.json().catch(() => ({}));
        feedback.textContent = response.ok ? MSG_SAVED : (data.message || data.error || MSG_SAVE_FAIL);
        feedback.style.color = response.ok ? 'var(--color-success,#059669)' : 'var(--color-danger,#dc2626)';
    });
})();
</script>
{% endblock %}
