{% extends 'admin/base.html.twig' %}
{% block title %}Backup Targets{% endblock %}
{% block body %}
<div class="space-y-4" data-target-upsert-url="{{ path('admin_backups_targets_upsert') }}">
    <div class="flex items-center justify-between">
        <h1 class="text-lg font-semibold">Backup Targets</h1>
        <a class="rounded bg-slate-800 px-3 py-2 text-xs text-white" href="{{ path('admin_backups_overview') }}">Overview</a>
    </div>
    <p id="targets-feedback" class="text-xs text-slate-600"></p>

    <div class="grid gap-4 lg:grid-cols-2">
        {% for target in targets %}
            <div class="rounded border border-slate-200 bg-white p-3" data-target-id="{{ target.id }}" data-target-test-url="{{ path('admin_backups_target_test', {id: target.id}) }}">
                <div class="flex items-start justify-between gap-2">
                    <div>
                        <div class="text-sm font-semibold">{{ target.name }}</div>
                        <div class="text-xs text-slate-500">{{ target.type }} · {{ target.enabled ? 'enabled' : 'disabled' }}</div>
                        <div class="text-xs text-slate-500">Secret: {{ target.secret_set ? 'set' : 'not set' }}</div>
                        {% if target.config.url is defined %}<div class="text-xs text-slate-500">Host: {{ target.config.url|replace({'https://':'','http://':''})|split('/')[0] }}</div>{% endif %}
                        {% if target.config.remote_path is defined %}<div class="text-xs text-slate-500">Remote path: {{ target.config.remote_path }}</div>{% endif %}
                    </div>
                    <button type="button" class="target-test-button rounded bg-slate-700 px-2 py-1 text-xs font-semibold text-white">Test</button>
                </div>
                <p class="mt-2 text-xs text-slate-500 target-test-result"></p>
            </div>
        {% endfor %}
    </div>

    <div class="rounded border border-slate-200 bg-white p-4">
        <h2 class="mb-2 text-sm font-semibold">Create / Update target</h2>
        <form id="target-form" class="grid gap-2 sm:grid-cols-2">
            <input type="hidden" name="target_id" />
            <label class="text-xs">Name <input class="w-full rounded border p-2" name="name" required></label>
            <label class="text-xs">Type
                <select class="w-full rounded border p-2" name="type">
                    <option value="local">local</option>
                    <option value="webdav">webdav</option>
                </select>
            </label>
            <label class="text-xs">Local base path <input class="w-full rounded border p-2" name="base_path" placeholder="/var/backups"></label>
            <label class="text-xs">WebDAV URL <input class="w-full rounded border p-2" name="url" placeholder="https://cloud.example/remote.php/dav/files/user"></label>
            <label class="text-xs">Remote path <input class="w-full rounded border p-2" name="remote_path" placeholder="/gameserver"></label>
            <label class="text-xs">Username <input class="w-full rounded border p-2" name="username"></label>
            <label class="text-xs">Password/Token <input class="w-full rounded border p-2" name="password" type="password" placeholder="only set to update"></label>
            <label class="text-xs">Enabled <input type="checkbox" name="enabled" checked></label>
            <label class="text-xs">Verify TLS <input type="checkbox" name="verify_tls" checked></label>
            <div class="sm:col-span-2">
                <button class="rounded bg-indigo-600 px-3 py-2 text-xs font-semibold text-white" type="submit">Save target</button>
            </div>
        </form>
    </div>
</div>
<script>
(() => {
    const root = document.querySelector('[data-target-upsert-url]');
    if (!root) return;
    const form = document.getElementById('target-form');
    const feedback = document.getElementById('targets-feedback');

    document.querySelectorAll('.target-test-button').forEach((button) => {
        button.addEventListener('click', async () => {
            const card = button.closest('[data-target-id]');
            if (!card) return;
            const result = card.querySelector('.target-test-result');
            button.disabled = true;
            try {
                const response = await fetch(card.dataset.targetTestUrl, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({}),
                });
                const data = await response.json().catch(() => ({}));
                const details = data.details || {};
                const status = details.http_status ? ` (${details.http_status})` : '';
                const hint = details.url_host ? ` host=${details.url_host}` : '';
                const remote = details.remote_path ? ` path=${details.remote_path}` : '';
                if (result) {
                    result.textContent = response.ok
                        ? `${data.message || 'Connection ok.'}${status}${hint}${remote}`
                        : `${data.message || data.error || 'Connection failed.'}${status}${hint}${remote}`;
                    result.className = `mt-2 text-xs ${response.ok ? 'text-emerald-600' : 'text-rose-600'} target-test-result`;
                }
            } finally {
                button.disabled = false;
            }
        });
    });

    form.addEventListener('submit', async (event) => {
        event.preventDefault();
        const fd = new FormData(form);
        const payload = Object.fromEntries(fd.entries());
        payload.enabled = form.querySelector('[name="enabled"]').checked;
        payload.verify_tls = form.querySelector('[name="verify_tls"]').checked;

        const response = await fetch(root.dataset.targetUpsertUrl, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
        });
        const data = await response.json().catch(() => ({}));
        feedback.textContent = response.ok ? 'Saved. Reload to see changes.' : (data.message || data.error || 'Failed.');
        feedback.className = `text-xs ${response.ok ? 'text-emerald-600' : 'text-rose-600'}`;
    });
})();
</script>
{% endblock %}
