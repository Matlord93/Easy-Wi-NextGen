{% extends 'admin/base.html.twig' %}

{% block content %}
<div class="flex flex-col gap-6" data-backup-module data-settings-url="{{ path('admin_settings_backups_update') }}" data-target-upsert-url="{{ path('admin_backups_targets_upsert') }}">
    <div>
        <h1 class="text-2xl font-semibold" style="color:var(--ng-text)">{{ t('admin_backup_module_title', page_locale()) }}</h1>
        <p class="text-sm" style="color:var(--ng-text-muted)">{{ t('admin_backup_module_description', page_locale()) }}</p>
    </div>

    <div class="ng-alert ng-alert--info">
        <h2 class="text-sm font-semibold uppercase tracking-wide">{{ t('admin_backup_module_quickstart_title', page_locale()) }}</h2>
        <ol class="mt-3 list-decimal space-y-2 pl-5 text-sm">
            <li>{{ t('admin_backup_module_quickstart_step_target', page_locale()) }}</li>
            <li>{{ t('admin_backup_module_quickstart_step_test', page_locale()) }}</li>
            <li>{{ t('admin_backup_module_quickstart_step_default', page_locale()) }}</li>
            <li>{{ t('admin_backup_module_quickstart_step_verify', page_locale()) }}</li>
        </ol>
    </div>

    <div class="grid gap-6 xl:grid-cols-3">
        <section class="xl:col-span-2 ng-data-card">
            <div class="ng-data-card__header">
                <div>
                    <h2 class="ng-data-card__title">{{ t('admin_backup_module_global_settings', page_locale()) }}</h2>
                </div>
                <div class="ng-data-card__actions">
                    <p id="settings-feedback" class="text-xs" style="color:var(--ng-text-muted)"></p>
                </div>
            </div>
            <div class="ng-data-card__body">
                <form id="settings-form" class="grid gap-4 md:grid-cols-2">
                    <div class="form-field">
                        <label class="form-label">{{ t('admin_backup_module_default_target', page_locale()) }}</label>
                        <select class="form-input" name="default_target_id">
                            <option value="">{{ t('admin_backup_module_default_target_none', page_locale()) }}</option>
                            {% for target in targets %}
                                <option value="{{ target.id }}" {{ settings.backup_default_target_id == target.id ? 'selected' : '' }}>{{ target.name }}</option>
                            {% endfor %}
                        </select>
                        <p class="mt-1 text-xs" style="color:var(--ng-text-muted)">{{ t('admin_backup_module_default_target_hint', page_locale()) }}</p>
                    </div>

                    <div class="form-field">
                        <label class="form-label">{{ t('admin_backup_module_compression', page_locale()) }}</label>
                        <select class="form-input" name="compression">
                            <option value="gzip" {{ settings.backup_default_compression == 'gzip' ? 'selected' : '' }}>gzip</option>
                            <option value="zstd" {{ settings.backup_default_compression == 'zstd' ? 'selected' : '' }}>zstd</option>
                        </select>
                    </div>

                    <div class="form-field">
                        <label class="form-label">{{ t('admin_backup_module_retention_count', page_locale()) }}</label>
                        <input class="form-input" type="number" min="0" name="retention_count" value="{{ settings.backup_default_retention_count }}">
                    </div>

                    <div class="form-field">
                        <label class="form-label">{{ t('admin_backup_module_retention_age_days', page_locale()) }}</label>
                        <input class="form-input" type="number" min="0" name="retention_age_days" value="{{ settings.backup_default_retention_age_days }}">
                    </div>

                    <div class="form-field">
                        <label class="form-label">{{ t('admin_backup_module_max_size', page_locale()) }}</label>
                        <input class="form-input" type="number" min="0" name="max_backup_size_bytes" value="{{ settings.backup_max_size_bytes ?: '' }}" placeholder="5368709120">
                        <p class="mt-1 text-xs" style="color:var(--ng-text-muted)">{{ t('admin_backup_module_max_size_hint', page_locale()) }}</p>
                    </div>

                    <div class="flex flex-col justify-center gap-3 rounded-lg p-4 text-sm" style="border:1px solid var(--ng-border);background:var(--ng-surface-soft);color:var(--ng-text)">
                        <label class="inline-flex items-center gap-2">
                            <input type="checkbox" class="rounded" style="border-color:var(--ng-border)" name="stop_before_backup" {{ settings.backup_stop_before ? 'checked' : '' }}>
                            {{ t('admin_backup_module_stop_before', page_locale()) }}
                        </label>
                        <label class="inline-flex items-center gap-2">
                            <input type="checkbox" class="rounded" style="border-color:var(--ng-border)" name="webdav_verify_tls" {{ settings.backup_webdav_verify_tls ? 'checked' : '' }}>
                            {{ t('admin_backup_module_verify_tls_default', page_locale()) }}
                        </label>
                    </div>

                    <div class="md:col-span-2">
                        <button class="ui-button ui-button--primary" type="submit">{{ t('save', page_locale()) }}</button>
                    </div>
                </form>
            </div>
        </section>

        <section class="ng-data-card">
            <div class="ng-data-card__header">
                <div>
                    <h2 class="ng-data-card__title">{{ t('admin_backup_module_help_title', page_locale()) }}</h2>
                </div>
            </div>
            <div class="ng-data-card__body">
                <ul class="space-y-3 text-sm" style="color:var(--ng-text-muted)">
                    <li>• {{ t('admin_backup_module_help_local', page_locale()) }}</li>
                    <li>• {{ t('admin_backup_module_help_webdav', page_locale()) }}</li>
                    <li>• {{ t('admin_backup_module_help_nextcloud', page_locale()) }}</li>
                    <li>• {{ t('admin_backup_module_help_security', page_locale()) }}</li>
                </ul>
            </div>
        </section>
    </div>

    <section class="ng-data-card">
        <div class="ng-data-card__header">
            <div>
                <h2 class="ng-data-card__title">{{ t('admin_backup_module_targets_title', page_locale()) }}</h2>
            </div>
            <div class="ng-data-card__actions">
                <p id="targets-feedback" class="text-xs" style="color:var(--ng-text-muted)"></p>
            </div>
        </div>
        <div class="ng-data-card__body">
            <div class="grid gap-4 lg:grid-cols-2">
                {% for target in targets %}
                    <article class="rounded-lg p-4" style="border:1px solid var(--ng-border)" data-target-card data-target-id="{{ target.id }}" data-target="{{ target|json_encode|e('html_attr') }}" data-target-test-url="{{ path('admin_backups_target_test', {id: target.id}) }}">
                        <div class="flex items-start justify-between gap-2">
                            <div>
                                <p class="text-sm font-semibold" style="color:var(--ng-text)">{{ target.name }}</p>
                                <p class="text-xs" style="color:var(--ng-text-muted)">{{ target.type|upper }} · {{ target.enabled ? t('admin_backup_module_enabled', page_locale()) : t('admin_backup_module_disabled', page_locale()) }}</p>
                                <p class="mt-1 text-xs" style="color:var(--ng-text-muted)">{{ t('admin_backup_module_secret_state', page_locale()) }}: {{ target.secret_set ? t('admin_backup_module_secret_set', page_locale()) : t('admin_backup_module_secret_not_set', page_locale()) }}</p>
                            </div>
                            <div class="flex gap-2">
                                <button type="button" class="target-edit-button ui-button ui-button--ghost ui-button--sm">{{ t('edit', page_locale()) }}</button>
                                <button type="button" class="target-test-button ui-button ui-button--primary ui-button--sm">{{ t('admin_backup_module_test', page_locale()) }}</button>
                            </div>
                        </div>
                        <p class="target-test-result mt-2 text-xs" style="color:var(--ng-text-muted)"></p>
                    </article>
                {% else %}
                    <p class="text-sm" style="color:var(--ng-text-muted)">{{ t('admin_backup_module_targets_empty', page_locale()) }}</p>
                {% endfor %}
            </div>

            <div class="mt-6 rounded-lg p-4" style="border:1px solid var(--ng-border);background:var(--ng-surface-soft)">
                <h3 class="text-sm font-semibold" style="color:var(--ng-text)">{{ t('admin_backup_module_target_form_title', page_locale()) }}</h3>
                <p class="mt-1 text-xs" style="color:var(--ng-text-muted)">{{ t('admin_backup_module_target_form_description', page_locale()) }}</p>

                <form id="target-form" class="mt-4 grid gap-4 md:grid-cols-2">
                    <input type="hidden" name="target_id">

                    <div class="form-field">
                        <label class="form-label">{{ t('name', page_locale()) }}</label>
                        <input class="form-input" name="name" required>
                    </div>

                    <div class="form-field">
                        <label class="form-label">{{ t('type', page_locale()) }}</label>
                        <select class="form-input" name="type">
                            <option value="local">Local</option>
                            <option value="webdav">WebDAV</option>
                            <option value="nextcloud">Nextcloud</option>
                        </select>
                    </div>

                    <div class="form-field" data-field-local>
                        <label class="form-label">{{ t('admin_backup_base_path_label', page_locale()) }}</label>
                        <input class="form-input" name="base_path" placeholder="/var/backups/easywi">
                        <p class="mt-1 text-xs" style="color:var(--ng-text-muted)">{{ t('admin_backup_module_local_path_hint', page_locale()) }}</p>
                    </div>

                    <div class="form-field" data-field-remote>
                        <label class="form-label">{{ t('admin_backup_url_label', page_locale()) }}</label>
                        <input class="form-input" name="url" placeholder="https://cloud.example/remote.php/dav/files/user">
                    </div>

                    <div class="form-field" data-field-remote>
                        <label class="form-label">{{ t('admin_backup_remote_path_label', page_locale()) }}</label>
                        <input class="form-input" name="remote_path" placeholder="/easywi/backups">
                    </div>

                    <div class="form-field" data-field-remote>
                        <label class="form-label">{{ t('admin_backup_username_label', page_locale()) }}</label>
                        <input class="form-input" name="username">
                    </div>

                    <div class="form-field" data-field-remote>
                        <label class="form-label">{{ t('admin_backup_password_label', page_locale()) }}</label>
                        <input class="form-input" type="password" name="password" placeholder="{{ t('admin_backup_module_password_placeholder', page_locale()) }}">
                    </div>

                    <div class="flex items-center gap-6 text-sm md:col-span-2" style="color:var(--ng-text)">
                        <label class="inline-flex items-center gap-2">
                            <input type="checkbox" class="rounded" style="border-color:var(--ng-border)" name="enabled" checked>
                            {{ t('admin_backup_module_enabled', page_locale()) }}
                        </label>
                        <label class="inline-flex items-center gap-2" data-field-remote>
                            <input type="checkbox" class="rounded" style="border-color:var(--ng-border)" name="verify_tls" checked>
                            {{ t('admin_backup_module_verify_tls', page_locale()) }}
                        </label>
                    </div>

                    <div class="flex gap-2 md:col-span-2">
                        <button type="submit" class="ui-button ui-button--primary">{{ t('save', page_locale()) }}</button>
                        <button type="button" id="target-form-reset" class="ui-button ui-button--ghost">{{ t('reset', page_locale()) }}</button>
                    </div>
                </form>
            </div>
        </div>
    </section>

    <section class="ng-data-card">
        <div class="ng-data-card__header">
            <div>
                <h2 class="ng-data-card__title">{{ t('admin_backup_module_recent_backups', page_locale()) }}</h2>
            </div>
        </div>
        <div class="ng-data-card__body ng-data-card__body--flush">
            <div class="cust-ws-table-wrap">
                <table class="cust-table">
                    <thead>
                        <tr>
                            <th>{{ t('admin_label_id', page_locale()) }}</th>
                            <th>{{ t('admin_backup_module_recent_instance', page_locale()) }}</th>
                            <th>{{ t('admin_backup_module_recent_customer', page_locale()) }}</th>
                            <th>{{ t('admin_backup_module_recent_target', page_locale()) }}</th>
                            <th>{{ t('admin_backup_module_recent_status', page_locale()) }}</th>
                            <th>{{ t('date', page_locale()) }}</th>
                            <th>{{ t('admin_backup_module_recent_error', page_locale()) }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for backup in recentBackups %}
                            <tr>
                                <td class="font-mono text-xs" style="color:var(--ng-text)">{{ backup.id }}</td>
                                <td>#{{ backup.instance_id }}</td>
                                <td>#{{ backup.customer_id }}</td>
                                <td>{{ backup.target ?: 'default' }}</td>
                                <td>{{ backup.status }}</td>
                                <td>{{ backup.created_at ? backup.created_at|date('Y-m-d H:i') : '—' }}</td>
                                <td class="text-xs" style="color:var(--ng-text-muted)">{{ backup.error ?: '—' }}</td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="7" class="cust-table__empty">{{ t('admin_backup_module_recent_backups_empty', page_locale()) }}</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </section>
</div>

<script>
(() => {
    const i18n = {
        saved: '{{ t("admin_backup_saved", page_locale())|e("js") }}',
        savedReload: '{{ t("admin_backup_saved_reload", page_locale())|e("js") }}',
        failed: '{{ t("admin_backup_failed", page_locale())|e("js") }}',
        connectionOk: '{{ t("admin_backup_connection_ok", page_locale())|e("js") }}',
        connectionFailed: '{{ t("admin_backup_connection_failed", page_locale())|e("js") }}',
    };

    const root = document.querySelector('[data-backup-module]');
    if (!root) return;

    const settingsForm = document.getElementById('settings-form');
    const settingsFeedback = document.getElementById('settings-feedback');

    settingsForm?.addEventListener('submit', async (event) => {
        event.preventDefault();
        const formData = new FormData(settingsForm);
        const payload = Object.fromEntries(formData.entries());
        payload.stop_before_backup = settingsForm.querySelector('[name="stop_before_backup"]').checked;
        payload.webdav_verify_tls = settingsForm.querySelector('[name="webdav_verify_tls"]').checked;

        const response = await fetch(root.dataset.settingsUrl, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
        });
        const data = await response.json().catch(() => ({}));
        settingsFeedback.textContent = response.ok ? i18n.saved : (data.message || data.error || i18n.failed);
        settingsFeedback.className = `text-xs ${response.ok ? 'text-emerald-600' : 'text-rose-600'}`;
    });

    const targetForm = document.getElementById('target-form');
    const targetFeedback = document.getElementById('targets-feedback');
    const resetButton = document.getElementById('target-form-reset');

    const toggleTargetFields = () => {
        const type = targetForm.querySelector('[name="type"]').value;
        const isLocal = type === 'local';
        document.querySelectorAll('[data-field-local]').forEach((field) => field.classList.toggle('hidden', !isLocal));
        document.querySelectorAll('[data-field-remote]').forEach((field) => field.classList.toggle('hidden', isLocal));
    };

    const resetTargetForm = () => {
        targetForm.reset();
        targetForm.querySelector('[name="target_id"]').value = '';
        targetForm.querySelector('[name="enabled"]').checked = true;
        targetForm.querySelector('[name="verify_tls"]').checked = true;
        targetForm.querySelector('[name="type"]').value = 'local';
        toggleTargetFields();
    };

    targetForm?.querySelector('[name="type"]')?.addEventListener('change', toggleTargetFields);
    resetButton?.addEventListener('click', resetTargetForm);
    resetTargetForm();

    document.querySelectorAll('[data-target-card]').forEach((card) => {
        const editButton = card.querySelector('.target-edit-button');
        const testButton = card.querySelector('.target-test-button');
        const resultNode = card.querySelector('.target-test-result');

        editButton?.addEventListener('click', () => {
            const target = JSON.parse(card.dataset.target || '{}');
            const config = target.config || {};

            targetForm.querySelector('[name="target_id"]').value = target.id || '';
            targetForm.querySelector('[name="name"]').value = target.name || '';
            targetForm.querySelector('[name="type"]').value = target.type || 'local';
            targetForm.querySelector('[name="base_path"]').value = config.base_path || '';
            targetForm.querySelector('[name="url"]').value = config.url || '';
            targetForm.querySelector('[name="remote_path"]').value = config.remote_path || '';
            targetForm.querySelector('[name="username"]').value = config.username || '';
            targetForm.querySelector('[name="password"]').value = '';
            targetForm.querySelector('[name="enabled"]').checked = !!target.enabled;
            targetForm.querySelector('[name="verify_tls"]').checked = config.verify_tls !== false;
            toggleTargetFields();
            window.scrollTo({ top: targetForm.getBoundingClientRect().top + window.scrollY - 120, behavior: 'smooth' });
        });

        testButton?.addEventListener('click', async () => {
            testButton.disabled = true;
            const response = await fetch(card.dataset.targetTestUrl, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({}),
            });
            const data = await response.json().catch(() => ({}));
            const details = data.details || {};
            const status = details.http_status ? ` (${details.http_status})` : '';
            resultNode.textContent = response.ok
                ? `${data.message || i18n.connectionOk}${status}`
                : `${data.message || data.error || i18n.connectionFailed}${status}`;
            resultNode.className = `target-test-result mt-2 text-xs ${response.ok ? 'text-emerald-600' : 'text-rose-600'}`;
            testButton.disabled = false;
        });
    });

    targetForm?.addEventListener('submit', async (event) => {
        event.preventDefault();
        const formData = new FormData(targetForm);
        const payload = Object.fromEntries(formData.entries());
        payload.enabled = targetForm.querySelector('[name="enabled"]').checked;
        payload.verify_tls = targetForm.querySelector('[name="verify_tls"]').checked;

        const response = await fetch(root.dataset.targetUpsertUrl, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
        });
        const data = await response.json().catch(() => ({}));
        targetFeedback.textContent = response.ok ? i18n.savedReload : (data.message || data.error || i18n.failed);
        targetFeedback.className = `text-xs ${response.ok ? 'text-emerald-600' : 'text-rose-600'}`;
    });
})();
</script>
{% endblock %}
