{% extends 'admin/base.html.twig' %}

{% set pageTitle = t('admin_billing_heading', page_locale()) %}
{% set pageSubtitle = t('admin_billing_intro', page_locale()) %}
{% set activeNav = 'billing' %}
{% set topbarActions = [
    { label: t('admin_billing_create_invoice', page_locale()), href: '/admin/billing/invoices/new', variant: 'ghost' }
] %}

{% block content %}
<div class="flex flex-col gap-6">

    {# ── KPI Row ── #}
    <div class="ng-kpi-row">
        <div class="ng-kpi-box">
            <div class="ng-kpi-box__label">{{ t('admin_billing_open_invoices', page_locale()) }}</div>
            <div class="ng-kpi-box__value ng-kpi-box__value--warning">{{ summary.open }}</div>
            <div class="ng-kpi-box__sub">{{ t('admin_billing_awaiting_payment', page_locale()) }}</div>
        </div>
        <div class="ng-kpi-box">
            <div class="ng-kpi-box__label">{{ t('admin_billing_past_due', page_locale()) }}</div>
            <div class="ng-kpi-box__value ng-kpi-box__value--danger">{{ summary.past_due }}</div>
            <div class="ng-kpi-box__sub">{{ t('admin_billing_requires_dunning', page_locale()) }}</div>
        </div>
        <div class="ng-kpi-box">
            <div class="ng-kpi-box__label">{{ t('admin_billing_paid', page_locale()) }}</div>
            <div class="ng-kpi-box__value ng-kpi-box__value--success">{{ summary.paid }}</div>
            <div class="ng-kpi-box__sub">{{ t('admin_billing_last_30_days', page_locale()) }}</div>
        </div>
    </div>

    {# ── Dunning Action ── #}
    <div class="ng-data-card">
        <div class="ng-data-card__header">
            <div>
                <h2 class="ng-data-card__title">{{ t('admin_billing_heading', page_locale()) }}</h2>
                <p class="ng-data-card__sub">{{ t('admin_billing_intro', page_locale()) }}</p>
            </div>
            <div class="ng-data-card__actions">
                <a href="/admin/billing/export?type=invoices" class="ui-button ui-button--ghost ui-button--sm">{{ t('admin_billing_export_invoices', page_locale()) }}</a>
                <a href="/admin/billing/export?type=payments" class="ui-button ui-button--ghost ui-button--sm">{{ t('admin_billing_export_payments', page_locale()) }}</a>
                <form method="post" action="/admin/billing/dunning" style="display:inline;">
                    <button type="submit" class="ui-button ui-button--primary ui-button--sm">{{ t('admin_billing_run_dunning', page_locale()) }}</button>
                </form>
            </div>
        </div>
    </div>

    {# ── Recent Invoices ── #}
    <div class="ng-data-card">
        <div class="ng-data-card__header">
            <div>
                <h2 class="ng-data-card__title">{{ t('admin_billing_recent_invoices', page_locale()) }}</h2>
                <p class="ng-data-card__sub">{{ t('admin_billing_recent_invoices_intro', page_locale()) }}</p>
            </div>
        </div>
        <div class="ng-data-card__body--flush">
            <div class="cust-ws-table-wrap">
                <table class="cust-table">
                    <thead>
                        <tr>
                            <th>{{ t('admin_billing_table_invoice', page_locale()) }}</th>
                            <th>{{ t('admin_billing_table_customer', page_locale()) }}</th>
                            <th>{{ t('admin_billing_table_due_date', page_locale()) }}</th>
                            <th>{{ t('admin_billing_table_amount_due', page_locale()) }}</th>
                            <th>{{ t('admin_billing_table_status', page_locale()) }}</th>
                            <th>{{ t('admin_billing_table_archive', page_locale()) }}</th>
                            <th>{{ t('admin_billing_table_actions', page_locale()) }}</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for invoice in invoices %}
                        <tr>
                            <td style="font-weight:600;">{{ invoice.number }}</td>
                            <td>{{ invoice.customer }}</td>
                            <td>{{ invoice.due_date|date('Y-m-d') }}</td>
                            <td>{{ invoice.amount_due / 100 }} {{ invoice.currency }}</td>
                            <td>
                                {% if invoice.status == 'paid' %}
                                    <span class="ui-badge ui-badge--success">{{ t('admin_billing_status_paid', page_locale()) }}</span>
                                {% elseif invoice.status == 'past_due' %}
                                    <span class="ui-badge ui-badge--danger">{{ t('admin_billing_status_past_due', page_locale()) }}</span>
                                {% elseif invoice.status == 'open' %}
                                    <span class="ui-badge ui-badge--info">{{ t('admin_billing_status_open', page_locale()) }}</span>
                                {% else %}
                                    <span class="ui-badge ui-badge--neutral">{{ invoice.status|replace({'_': ' '})|title }}</span>
                                {% endif %}
                            </td>
                            <td>
                                {% if invoice.is_archived %}
                                    <span class="ui-badge ui-badge--success">{{ t('admin_billing_status_archived', page_locale()) }}</span>
                                {% else %}
                                    <span class="ui-badge ui-badge--neutral">{{ t('admin_billing_status_pending', page_locale()) }}</span>
                                {% endif %}
                            </td>
                            <td>
                                <a href="/admin/billing/invoices/{{ invoice.id }}" class="ui-button ui-button--ghost ui-button--sm">{{ t('admin_billing_details', page_locale()) }}</a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="7" class="cust-table__empty">{{ t('admin_billing_no_invoices', page_locale()) }}</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    {# ── Credit Notes ── #}
    <div class="ng-data-card">
        <div class="ng-data-card__header">
            <div>
                <h2 class="ng-data-card__title">{{ t('admin_billing_credit_notes', page_locale()) }}</h2>
                <p class="ng-data-card__sub">{{ t('admin_billing_credit_notes_intro', page_locale()) }}</p>
            </div>
            <div class="ng-data-card__actions">
                <button class="ui-button ui-button--ghost ui-button--sm">{{ t('admin_billing_create_credit', page_locale()) }}</button>
            </div>
        </div>
        <div class="ng-data-card__body--flush">
            <div class="cust-ws-table-wrap">
                <table class="cust-table">
                    <thead>
                        <tr>
                            <th>{{ t('admin_billing_credit_note', page_locale()) }}</th>
                            <th>{{ t('admin_billing_credit_invoice', page_locale()) }}</th>
                            <th>{{ t('admin_billing_credit_customer', page_locale()) }}</th>
                            <th>{{ t('admin_billing_credit_issued', page_locale()) }}</th>
                            <th>{{ t('admin_billing_credit_amount', page_locale()) }}</th>
                            <th>{{ t('admin_billing_credit_status', page_locale()) }}</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for credit in credit_notes %}
                        <tr>
                            <td style="font-weight:600;">{{ credit.number }}</td>
                            <td>{{ credit.invoice_number }}</td>
                            <td>{{ credit.customer }}</td>
                            <td>{{ credit.issued_at ? credit.issued_at|date('Y-m-d') : '—' }}</td>
                            <td>{{ credit.amount / 100 }} {{ credit.currency }}</td>
                            <td>
                                {% if credit.status == 'issued' %}
                                    <span class="ui-badge ui-badge--info">{{ t('admin_billing_credit_status_issued', page_locale()) }}</span>
                                {% elseif credit.status == 'applied' %}
                                    <span class="ui-badge ui-badge--success">{{ t('admin_billing_credit_status_applied', page_locale()) }}</span>
                                {% elseif credit.status == 'voided' %}
                                    <span class="ui-badge ui-badge--danger">{{ t('admin_billing_credit_status_voided', page_locale()) }}</span>
                                {% else %}
                                    <span class="ui-badge ui-badge--neutral">{{ t('admin_billing_credit_status_draft', page_locale()) }}</span>
                                {% endif %}
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="6" class="cust-table__empty">{{ t('admin_billing_no_credit_notes', page_locale()) }}</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>
{% endblock %}
