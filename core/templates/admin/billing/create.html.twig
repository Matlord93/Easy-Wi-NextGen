{% extends 'admin/base.html.twig' %}

{% block content %}
{% set locale = page_locale() %}
<div style="display:flex;flex-direction:column;gap:20px;">

  <section class="ng-card" style="overflow:hidden;">
    <div class="tkt-hero">
      <div class="tkt-hero__inner">
        <div>
          <div class="tkt-hero__pill"><span class="tkt-hero__pill-dot"></span> {{ t('admin_billing_create_invoice', locale) }}</div>
          <h1 class="tkt-hero__title" style="margin-top:10px;">{{ t('admin_billing_create_invoice', locale) }}</h1>
          <p class="tkt-hero__sub">{{ t('admin_billing_create_invoice_intro', locale) }}</p>
        </div>
      </div>
    </div>
  </section>

  {% if form.errors is not empty %}
    <div class="ng-alert ng-alert--danger">
      <p style="font-weight:600;margin-bottom:4px;">{{ t('admin_form_fix_following', locale) }}</p>
      <ul style="list-style:disc;padding-left:18px;margin:0;">
        {% for error in form.errors %}
          <li>{{ error }}</li>
        {% endfor %}
      </ul>
    </div>
  {% endif %}

  <div class="ng-data-card">
    <div class="ng-data-card__body">
      <form method="post" action="/admin/billing/invoices" style="display:flex;flex-direction:column;gap:16px;">
        <div class="form-field">
          <label class="form-label">{{ t('admin_billing_customer', locale) }}</label>
          <select name="customer_id" class="form-input">
            {% for customer in customers %}
              <option value="{{ customer.id }}" {{ customer.id == form.customer_id ? 'selected' : '' }}>{{ customer.email }}</option>
            {% else %}
              <option value="">{{ t('admin_billing_no_customers', locale) }}</option>
            {% endfor %}
          </select>
        </div>
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:12px;">
          <div class="form-field">
            <label class="form-label">{{ t('admin_billing_invoice_number', locale) }}</label>
            <input name="number" value="{{ form.number }}" class="form-input">
          </div>
          <div class="form-field">
            <label class="form-label">{{ t('admin_billing_invoice_due_date', locale) }}</label>
            <input name="due_date" type="date" value="{{ form.due_date_raw ?? form.due_date }}" class="form-input">
          </div>
        </div>
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:12px;">
          <div class="form-field">
            <label class="form-label">{{ t('admin_billing_amount_total', locale) }}</label>
            <input name="amount" value="{{ form.amount }}" placeholder="99.00" class="form-input">
          </div>
          <div class="form-field">
            <label class="form-label">{{ t('admin_billing_currency', locale) }}</label>
            <input name="currency" value="{{ form.currency }}" class="form-input">
          </div>
        </div>
        <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
          <button type="submit" class="ui-button ui-button--primary ui-button--sm">{{ t('admin_billing_create_invoice_submit', locale) }}</button>
          <a href="/admin/billing" class="ui-button ui-button--ghost ui-button--sm">{{ t('cancel', locale) }}</a>
        </div>
      </form>
    </div>
  </div>

</div>
{% endblock %}
