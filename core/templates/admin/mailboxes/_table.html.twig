<div class="ng-data-card__header">
    <div>
        <h2 class="ng-data-card__title">{{ t('admin_mailboxes_inventory_title', page_locale()) }}</h2>
        <p class="ng-data-card__sub">{{ t('admin_mailboxes_inventory_intro', page_locale()) }}</p>
    </div>
    <div class="ng-data-card__actions">
        <button
            class="ui-button ui-button--ghost ui-button--sm"
            hx-get="/admin/mailboxes/table"
            hx-target="#mailboxes-table"
            hx-swap="outerHTML"
        >{{ t('refresh', page_locale()) }}</button>
    </div>
</div>
<div class="cust-ws-table-wrap">
    <table class="cust-table">
        <thead>
        <tr>
            <th>{{ t('admin_mailboxes_table_mailbox', page_locale()) }}</th>
            <th>{{ t('admin_mailboxes_table_customer', page_locale()) }}</th>
            <th>{{ t('admin_mailboxes_table_quota', page_locale()) }}</th>
            <th>{{ t('status', page_locale()) }}</th>
            <th>{{ t('updated', page_locale()) }}</th>
            <th>{{ t('actions', page_locale()) }}</th>
        </tr>
        </thead>
        <tbody>
        {% for mailbox in mailboxes %}
            <tr>
                <td>
                    <div class="font-semibold" style="color:var(--ng-text);">{{ mailbox.address }}</div>
                    <div style="font-size:11px;color:var(--ng-text-muted);">{{ mailbox.domain.name }}</div>
                </td>
                <td>
                    <div class="font-semibold" style="color:var(--ng-text);">{{ mailbox.customer.email }}</div>
                    <div style="font-size:11px;color:var(--ng-text-muted);">{{ t('admin_label_id', page_locale()) }} {{ mailbox.customer.id }}</div>
                </td>
                <td style="color:var(--ng-text-muted);">{{ mailbox.quota }}</td>
                <td>
                    {% if mailbox.enabled %}
                        <span class="ui-badge ui-badge--success">{{ t('admin_status_enabled', page_locale()) }}</span>
                    {% else %}
                        <span class="ui-badge ui-badge--neutral">{{ t('admin_status_disabled', page_locale()) }}</span>
                    {% endif %}
                </td>
                <td style="font-size:11px;color:var(--ng-text-muted);">{{ mailbox.updatedAt|date('Y-m-d H:i') }}</td>
                <td>
                    <div class="flex items-center gap-2">
                        <button
                            class="ui-button ui-button--ghost ui-button--sm"
                            hx-get="/admin/mailboxes/{{ mailbox.id }}/edit"
                            hx-target="#mailbox-form"
                            hx-swap="outerHTML"
                        >{{ t('edit', page_locale()) }}</button>
                        {% if mailbox.enabled %}
                            <button
                                class="ui-button ui-button--danger ui-button--sm"
                                hx-post="/admin/mailboxes/{{ mailbox.id }}/disable"
                                hx-target="#mailboxes-table"
                                hx-swap="outerHTML"
                            >{{ t('disable', page_locale()) }}</button>
                        {% else %}
                            <button
                                class="ui-button ui-button--ghost ui-button--sm"
                                hx-post="/admin/mailboxes/{{ mailbox.id }}/enable"
                                hx-target="#mailboxes-table"
                                hx-swap="outerHTML"
                            >{{ t('enable', page_locale()) }}</button>
                        {% endif %}
                    </div>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="6" class="cust-table__empty">{{ t('admin_mailboxes_empty', page_locale()) }}</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
</div>
