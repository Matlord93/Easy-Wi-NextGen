{% extends 'admin/base.html.twig' %}

{% set pageTitle = t('admin_mailboxes_title', page_locale()) %}
{% set pageSubtitle = t('admin_mailboxes_intro', page_locale()) %}
{% set activeNav = 'mailboxes' %}
{% set locale = page_locale() %}
{% set topbarActions %}
    <button
        class="ui-button ui-button--ghost ui-button--sm"
        hx-get="/admin/mailboxes/table"
        hx-target="#mailboxes-table"
        hx-swap="outerHTML"
    >{{ t('refresh', locale) }}</button>
    <button
        class="ui-button ui-button--primary ui-button--sm"
        hx-get="/admin/mailboxes/form"
        hx-target="#mailbox-form"
        hx-swap="outerHTML"
    >{{ t('admin_mailboxes_new', locale) }}</button>
{% endset %}

{% block content %}
<div style="display:flex;flex-direction:column;gap:20px;">

    {# ── Hero with KPI ── #}
    <section class="ng-card" style="overflow:hidden;">
        <div class="tkt-hero">
            <div class="tkt-hero__inner">
                <div style="display:flex;flex-direction:column;gap:16px;">
                    <div>
                        <div class="tkt-hero__pill">
                            <span class="tkt-hero__pill-dot"></span>
                            {{ t('admin_mailboxes_hero_label', locale) }}
                        </div>
                        <h1 class="tkt-hero__title" style="margin-top:10px;">{{ t('admin_mailboxes_title', locale) }}</h1>
                        <p class="tkt-hero__sub">{{ t('admin_mailboxes_hero_intro', locale) }}</p>
                    </div>
                    <div style="display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:10px;">
                        <div class="tkt-kpi">
                            <div class="tkt-kpi__label">{{ t('admin_mailboxes_total', locale) }}</div>
                            <div class="tkt-kpi__value">{{ summary.total }}</div>
                        </div>
                        <div class="tkt-kpi tkt-kpi--resolved">
                            <div class="tkt-kpi__label">{{ t('admin_status_enabled', locale) }}</div>
                            <div class="tkt-kpi__value">{{ summary.enabled }}</div>
                        </div>
                        <div class="tkt-kpi" style="border-color:rgba(239,68,68,.25);background:rgba(239,68,68,.07);">
                            <div class="tkt-kpi__label" style="color:rgba(252,165,165,.7);">{{ t('admin_status_disabled', locale) }}</div>
                            <div class="tkt-kpi__value" style="color:#fca5a5;">{{ summary.disabled }}</div>
                        </div>
                        <div class="tkt-kpi tkt-kpi--open">
                            <div class="tkt-kpi__label">{{ t('admin_mailboxes_quota_total', locale) }}</div>
                            <div class="tkt-kpi__value">{{ summary.quotaTotal }}</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <div class="ng-layout-2col">
        <div id="mailbox-form" class="ng-data-card">
            <div class="ng-data-card__body">
                {% include 'admin/mailboxes/_form.html.twig' with { domains: domains, form: form } %}
            </div>
        </div>

        <div id="mailboxes-table" class="ng-data-card"
             hx-get="/admin/mailboxes/table"
             hx-trigger="mailboxes-changed from:body"
             hx-swap="outerHTML">
            <div class="ng-data-card__body--flush">
                {% include 'admin/mailboxes/_table.html.twig' with { mailboxes: mailboxes } %}
            </div>
        </div>
    </div>

</div>
{% endblock %}
