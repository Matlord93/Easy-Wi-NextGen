<div class="ng-data-card__header">
    <div>
        <h2 class="ng-data-card__title">{{ form.action == 'create' ? t('admin_mailboxes_create_title', page_locale()) : t('admin_mailboxes_edit_title', page_locale()) }}</h2>
        <p class="ng-data-card__sub">{{ t('admin_mailboxes_form_intro', page_locale()) }}</p>
    </div>
</div>
<div class="ng-data-card__body">
    {% if form.errors is not empty %}
        <div class="ng-alert ng-alert--danger mb-4">
            <p class="font-semibold">{{ t('admin_form_fix_following', page_locale()) }}</p>
            <ul class="list-disc pl-5 mt-2">
                {% for error in form.errors %}
                    <li>{{ error }}</li>
                {% endfor %}
            </ul>
        </div>
    {% endif %}
    <form
        class="flex flex-col gap-4"
        hx-post="{{ form.action_url }}"
        hx-target="#mailbox-form"
        hx-swap="outerHTML"
    >
        {% if form.action == 'create' %}
            <div class="form-field">
                <label class="form-label">{{ t('admin_mailboxes_domain', page_locale()) }}</label>
                <select name="domain_id" class="form-input">
                    {% for domain in domains %}
                        <option value="{{ domain.id }}" {{ domain.id == form.domain_id ? 'selected' : '' }}>{{ domain.name }}</option>
                    {% else %}
                        <option value="">{{ t('admin_mailboxes_no_domains', page_locale()) }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="form-field">
                <label class="form-label">{{ t('admin_mailboxes_name', page_locale()) }}</label>
                <div class="form-input flex items-center gap-1">
                    <input name="local_part" value="{{ form.local_part }}" placeholder="{{ t('admin_mailboxes_name_placeholder', page_locale()) }}" class="flex-1 bg-transparent focus:outline-none">
                    <span style="color:var(--ng-text-muted);">@</span>
                    <span style="color:var(--ng-text-muted);">{{ form.domain_name ?? t('admin_mailboxes_domain_placeholder', page_locale()) }}</span>
                </div>
            </div>
        {% else %}
            <div class="form-field">
                <label class="form-label">{{ t('admin_mailboxes_address_label', page_locale()) }}</label>
                <div class="form-input" style="color:var(--ng-text);">{{ form.address }}</div>
            </div>
        {% endif %}
        <div class="form-field">
            <label class="form-label">{{ t('admin_mailboxes_password', page_locale()) }}</label>
            <input name="password" type="password" placeholder="{{ form.action == 'create' ? t('admin_mailboxes_password_required', page_locale()) : t('admin_mailboxes_password_optional', page_locale()) }}" class="form-input">
            <p class="form-hint">{{ t('admin_mailboxes_password_hint', page_locale()) }}</p>
        </div>
        <div class="grid grid-cols-2 gap-4">
            <div class="form-field">
                <label class="form-label">{{ t('admin_mailboxes_quota', page_locale()) }}</label>
                <input name="quota" type="number" min="0" value="{{ form.quota }}" class="form-input">
            </div>
            <div class="form-field">
                <label class="form-label">{{ t('status', page_locale()) }}</label>
                <label class="inline-flex items-center gap-2 text-sm" style="color:var(--ng-text-muted);">
                    <input type="hidden" name="enabled" value="0">
                    <input id="mailbox-enabled" name="enabled" type="checkbox" value="1" {{ form.enabled ? 'checked' : '' }}>
                    {{ t('admin_mailboxes_enabled_delivery', page_locale()) }}
                </label>
            </div>
        </div>
        <div class="flex items-center gap-3">
            <button type="submit" class="ui-button ui-button--primary">{{ form.submit_label }}</button>
            <button
                type="button"
                class="ui-button ui-button--ghost"
                hx-get="/admin/mailboxes/form"
                hx-target="#mailbox-form"
                hx-swap="outerHTML"
            >{{ t('reset', page_locale()) }}</button>
        </div>
    </form>
</div>
