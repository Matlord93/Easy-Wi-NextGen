{% extends 'admin/base.html.twig' %}


{% block content %}
<div class="flex flex-col gap-6">
    <div>
        <h1 class="text-2xl font-semibold">{{ t('admin_security_title', page_locale()) }}</h1>
        <p class="text-sm text-slate-700">{{ t('admin_security_intro', page_locale()) }}</p>
    </div>

    {% if errors is not empty %}
        <div class="rounded-xl border border-rose-200 bg-rose-50 px-5 py-4 text-sm text-rose-700">
            <ul class="list-disc space-y-1 pl-4">
                {% for error in errors %}
                    <li>{{ error }}</li>
                {% endfor %}
            </ul>
        </div>
    {% endif %}

    {% if ddosUpdated %}
        <div class="rounded-xl border border-emerald-200 bg-emerald-50 px-5 py-4 text-sm text-emerald-700">
            {{ t('admin_security_ddos_updated', page_locale()) }}
        </div>
    {% endif %}
    {% if fail2banUpdated %}
        <div class="rounded-xl border border-emerald-200 bg-emerald-50 px-5 py-4 text-sm text-emerald-700">
            {{ t('admin_security_fail2ban_updated', page_locale()) }}
        </div>
    {% endif %}
    {% if previewEnabled %}
        <div class="rounded-xl border border-amber-200 bg-amber-50 px-5 py-4 text-sm text-amber-700">
            {{ t('admin_security_preview_notice', page_locale()) }}
        </div>
    {% endif %}

    <div class="grid gap-6 lg:grid-cols-2">
        <div class="rounded-xl border border-slate-200 bg-white shadow-sm">
            <div class="border-b border-slate-200 px-5 py-4">
                <h2 id="ddos-provider" class="text-lg font-semibold">{{ t('admin_security_ddos_provider_title', page_locale()) }}</h2>
                <p class="text-sm text-slate-700">{{ t('admin_security_ddos_provider_intro', page_locale()) }}</p>
            </div>
            <div class="px-5 py-5">
                <form method="post" action="/admin/security/ddos" class="space-y-4">
                    <div>
                        <label class="block text-xs font-semibold uppercase text-slate-700">{{ t('admin_security_provider_label', page_locale()) }}</label>
                        <input
                            name="provider"
                            placeholder="{{ t('admin_security_provider_placeholder', page_locale()) }}"
                            class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-200"
                        >
                    </div>
                    <div>
                        <label class="block text-xs font-semibold uppercase text-slate-700">{{ t('admin_security_api_key_label', page_locale()) }}</label>
                        <input
                            type="password"
                            name="api_key"
                            placeholder="{{ t('admin_security_api_key_placeholder', page_locale()) }}"
                            class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-200"
                        >
                    </div>
                    <button type="submit" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white">{{ t('admin_security_save_credentials', page_locale()) }}</button>
                </form>
                <div class="mt-6 space-y-2">
                    <p class="text-xs font-semibold uppercase text-slate-700">{{ t('admin_security_configured_providers', page_locale()) }}</p>
                    {% if credentials is empty %}
                        <p class="text-sm text-slate-700">{{ t('admin_security_no_providers', page_locale()) }}</p>
                    {% else %}
                        <ul class="space-y-2">
                            {% for credential in credentials %}
                                <li class="flex items-center justify-between rounded-lg border border-slate-200 px-3 py-2 text-sm text-slate-600">
                                    <span class="font-medium text-slate-900">{{ credential.provider|title }}</span>
                                    <span class="text-xs text-slate-600">{{ t('admin_security_updated_at', page_locale())|replace({'%time%': credential.updatedAt|date('Y-m-d H:i')}) }}</span>
                                </li>
                            {% endfor %}
                        </ul>
                    {% endif %}
                </div>
            </div>
        </div>

        <div class="rounded-xl border border-slate-200 bg-white shadow-sm">
            <div class="border-b border-slate-200 px-5 py-4">
                <h2 id="firewall" class="text-lg font-semibold">{{ t('admin_security_firewall_title', page_locale()) }}</h2>
                <p class="text-sm text-slate-700">{{ t('admin_security_firewall_intro', page_locale()) }}</p>
            </div>
            <div class="divide-y divide-slate-200">
                {% if firewallNodes is empty %}
                    <div class="px-5 py-5 text-sm text-slate-700">{{ t('admin_security_no_nodes', page_locale()) }}</div>
                {% else %}
                    {% for node in firewallNodes %}
                        <div class="px-5 py-5">
                            <div class="flex flex-wrap items-center justify-between gap-3">
                                <div>
                                    <p class="text-sm font-semibold text-slate-900">{{ node.name }}</p>
                                    <p class="text-xs text-slate-700">{{ t('admin_security_node_last_update', page_locale())|replace({'%id%': node.id, '%time%': node.updatedAt|date('Y-m-d H:i')}) }}</p>
                                </div>
                                <span class="rounded-full border px-3 py-1 text-xs font-semibold {{ node.status == 'online' ? 'border-emerald-200 bg-emerald-50 text-emerald-700' : (node.status == 'degraded' ? 'border-amber-200 bg-amber-50 text-amber-700' : 'border-rose-200 bg-rose-50 text-rose-700') }}">
                                    {{ node.status|title }}
                                </span>
                            </div>
                            <div class="mt-4 flex flex-wrap gap-2">
                                {% if node.rules is empty %}
                                    {% if node.ports is empty %}
                                        <span class="rounded-full bg-slate-100 px-3 py-1 text-xs text-slate-700">{{ t('admin_security_no_firewall_rules', page_locale()) }}</span>
                                    {% else %}
                                        {% for port in node.ports %}
                                            <span class="rounded-full border border-slate-200 bg-slate-50 px-3 py-1 text-xs text-slate-600">{{ port }}</span>
                                        {% endfor %}
                                    {% endif %}
                                {% else %}
                                    {% for rule in node.rules %}
                                        <span class="rounded-full border px-3 py-1 text-xs font-semibold {{ rule.status == 'open' ? 'border-emerald-200 bg-emerald-50 text-emerald-700' : 'border-rose-200 bg-rose-50 text-rose-700' }}">
                                            {{ rule.port }}/{{ rule.protocol|upper }} · {{ rule.status|title }}
                                        </span>
                                    {% endfor %}
                                {% endif %}
                            </div>
                            {% if node.job %}
                                <div class="mt-4 rounded-lg border border-slate-200 bg-slate-50 px-3 py-2 text-xs text-slate-600">
                                    <div class="flex flex-wrap items-center justify-between gap-2">
                                        <span class="font-semibold text-slate-700">{{ t('admin_security_last_firewall_job', page_locale()) }}</span>
                                        <span class="text-slate-500">{{ node.job.type }} · {{ node.job.status|title }}</span>
                                    </div>
                                    {% if node.job.resultStatus %}
                                        <div class="mt-2 text-slate-600">
                                            {{ t('admin_security_job_result', page_locale()) }} <span class="font-semibold">{{ node.job.resultStatus|title }}</span>
                                            {% if node.job.resultMessage %}
                                                · {{ node.job.resultMessage }}
                                            {% endif %}
                                        </div>
                                    {% endif %}
                                </div>
                            {% endif %}
                            <form method="post" action="/admin/security/firewall/{{ node.id }}" class="mt-4 flex flex-col gap-3">
                                <label class="text-xs font-semibold uppercase text-slate-700">{{ t('admin_security_desired_ports', page_locale()) }}</label>
                                <input
                                    name="ports"
                                    value="{{ node.ports|join(', ') }}"
                                    placeholder="{{ t('admin_security_ports_placeholder', page_locale()) }}"
                                    class="w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-200"
                                >
                                <label class="inline-flex items-center gap-2 text-xs font-semibold uppercase text-slate-700">
                                    <input type="checkbox" name="dry_run" value="1" class="rounded border-slate-300">
                                    {{ t('admin_security_preview_mode', page_locale()) }}
                                </label>
                                <div class="flex items-center gap-3">
                                    <button type="submit" class="rounded-lg border border-slate-200 px-3 py-2 text-xs font-semibold text-slate-600">{{ t('admin_security_update_firewall', page_locale()) }}</button>
                                    {% if firewallUpdated == node.id %}
                                        <span class="text-xs text-emerald-600">{{ t('admin_security_saved', page_locale()) }}</span>
                                    {% endif %}
                                </div>
                            </form>
                        </div>
                    {% endfor %}
                {% endif %}
            </div>
        </div>
    </div>

    <div class="grid gap-6 lg:grid-cols-2">
        <div class="rounded-xl border border-slate-200 bg-white shadow-sm">
            <div class="border-b border-slate-200 px-5 py-4">
                <h2 id="fail2ban" class="text-lg font-semibold">{{ t('admin_security_fail2ban_title', page_locale()) }}</h2>
                <p class="text-sm text-slate-700">{{ t('admin_security_fail2ban_intro', page_locale()) }}</p>
            </div>
            <div class="divide-y divide-slate-200">
                {% if fail2banNodes is empty %}
                    <div class="px-5 py-5 text-sm text-slate-700">{{ t('admin_security_no_nodes', page_locale()) }}</div>
                {% else %}
                    {% for node in fail2banNodes %}
                        {% set payload = node.policy ? node.policy.payload : {} %}
                        <div class="px-5 py-5">
                            <div class="flex flex-wrap items-center justify-between gap-3">
                                <div>
                                    <p class="text-sm font-semibold text-slate-900">{{ node.name }}</p>
                                    <p class="text-xs text-slate-700">{{ t('admin_security_node_last_update', page_locale())|replace({'%id%': node.id, '%time%': node.updatedAt|date('Y-m-d H:i')}) }}</p>
                                </div>
                                <span class="rounded-full border px-3 py-1 text-xs font-semibold {{ node.status == 'online' ? 'border-emerald-200 bg-emerald-50 text-emerald-700' : (node.status == 'degraded' ? 'border-amber-200 bg-amber-50 text-amber-700' : 'border-rose-200 bg-rose-50 text-rose-700') }}">
                                    {{ node.status|title }}
                                </span>
                            </div>

                            {% if node.policy %}
                                <div class="mt-3 text-xs text-slate-600">
                                    {{ t('admin_security_policy_version', page_locale())|replace({'%version%': node.policy.version}) }}
                                    · {{ t('admin_security_policy_status', page_locale())|replace({'%status%': node.policy.status|title}) }}
                                    {% if node.policy.appliedAt %}
                                        · {{ t('admin_security_policy_applied_at', page_locale())|replace({'%time%': node.policy.appliedAt|date('Y-m-d H:i')}) }}
                                    {% endif %}
                                </div>
                            {% endif %}

                            <form method="post" action="/admin/security/fail2ban/{{ node.id }}" class="mt-4 flex flex-col gap-3">
                                <label class="inline-flex items-center gap-2 text-xs font-semibold uppercase text-slate-700">
                                    <input type="checkbox" name="enabled" value="1" class="rounded border-slate-300" {% if payload.enabled is not defined or payload.enabled %}checked{% endif %}>
                                    {{ t('admin_security_fail2ban_enabled', page_locale()) }}
                                </label>
                                <div class="grid gap-3 md:grid-cols-2">
                                    <div>
                                        <label class="block text-xs font-semibold uppercase text-slate-700">{{ t('admin_security_fail2ban_bantime', page_locale()) }}</label>
                                        <input name="bantime" value="{{ payload.bantime|default('10m') }}" class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-200">
                                    </div>
                                    <div>
                                        <label class="block text-xs font-semibold uppercase text-slate-700">{{ t('admin_security_fail2ban_findtime', page_locale()) }}</label>
                                        <input name="findtime" value="{{ payload.findtime|default('10m') }}" class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-200">
                                    </div>
                                    <div>
                                        <label class="block text-xs font-semibold uppercase text-slate-700">{{ t('admin_security_fail2ban_maxretry', page_locale()) }}</label>
                                        <input name="maxretry" value="{{ payload.maxretry|default(5) }}" class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-200">
                                    </div>
                                    <div>
                                        <label class="block text-xs font-semibold uppercase text-slate-700">{{ t('admin_security_fail2ban_jails', page_locale()) }}</label>
                                        <input name="jails" value="{{ payload.jails is defined ? payload.jails|join(', ') : 'sshd' }}" class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-200">
                                    </div>
                                </div>
                                <div>
                                    <label class="block text-xs font-semibold uppercase text-slate-700">{{ t('admin_security_fail2ban_ignore_ips', page_locale()) }}</label>
                                    <input name="ignore_ips" value="{{ payload.ignore_ips is defined ? payload.ignore_ips|join(', ') : '127.0.0.1/8' }}" class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-200">
                                </div>
                                <div>
                                    <label class="block text-xs font-semibold uppercase text-slate-700">{{ t('admin_security_fail2ban_advanced', page_locale()) }}</label>
                                    <textarea name="advanced_config" rows="4" class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-200">{{ payload.advanced_config|default('') }}</textarea>
                                </div>
                                <label class="inline-flex items-center gap-2 text-xs font-semibold uppercase text-slate-700">
                                    <input type="checkbox" name="dry_run" value="1" class="rounded border-slate-300">
                                    {{ t('admin_security_preview_mode', page_locale()) }}
                                </label>
                                <div class="flex flex-wrap items-center gap-3">
                                    <button type="submit" class="rounded-lg border border-slate-200 px-3 py-2 text-xs font-semibold text-slate-600">{{ t('admin_security_update_fail2ban', page_locale()) }}</button>
                                    {% if fail2banUpdated == node.id %}
                                        <span class="text-xs text-emerald-600">{{ t('admin_security_saved', page_locale()) }}</span>
                                    {% endif %}
                                </div>
                            </form>

                            <form method="post" action="/admin/security/fail2ban/{{ node.id }}/status" class="mt-3">
                                <button type="submit" class="rounded-lg border border-slate-200 px-3 py-2 text-xs font-semibold text-slate-600">{{ t('admin_security_fail2ban_check_status', page_locale()) }}</button>
                            </form>
                        </div>
                    {% endfor %}
                {% endif %}
            </div>
        </div>

        <div class="rounded-xl border border-slate-200 bg-white shadow-sm lg:col-span-2">
            <div class="border-b border-slate-200 px-5 py-4">
                <h2 id="unified-ruleset" class="text-lg font-semibold">{{ t('admin_security_unified_title', page_locale()) }}</h2>
                <p class="text-sm text-slate-700">{{ t('admin_security_unified_intro', page_locale()) }}</p>
            </div>
            <div class="px-5 py-5 space-y-4">
                {% if rulesetUpdated == 'applied' %}
                    <div class="rounded-lg border border-emerald-200 bg-emerald-50 px-3 py-2 text-xs text-emerald-700">{{ t('admin_security_unified_applied', page_locale()) }}</div>
                {% elseif rulesetUpdated == 'rollback' %}
                    <div class="rounded-lg border border-amber-200 bg-amber-50 px-3 py-2 text-xs text-amber-700">{{ t('admin_security_unified_rollback', page_locale()) }}</div>
                {% endif %}
                <form method="post" action="/admin/security/ruleset/apply" class="grid gap-3 md:grid-cols-3">
                    <select name="target_scope" class="rounded-lg border border-slate-200 px-3 py-2 text-sm">
                        <option value="global">Global</option>
                        <option value="node">Node</option>
                    </select>
                    <select name="target_node_id" class="rounded-lg border border-slate-200 px-3 py-2 text-sm">
                        <option value="">{{ t('admin_security_select_node', page_locale()) }}</option>
                        {% for node in fail2banNodes %}
                            <option value="{{ node.id }}">{{ node.name }}</option>
                        {% endfor %}
                    </select>
                    <button type="submit" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white">{{ t('admin_security_unified_apply', page_locale()) }}</button>
                    <textarea name="rules_json" rows="6" class="md:col-span-3 rounded-lg border border-slate-200 px-3 py-2 text-xs font-mono" placeholder='[{"id":"allow-ssh","type":"firewall","action":"allow","protocol":"tcp","port":22,"priority":10,"enabled":true,"reason":"admin-access","target":{"scope":"global"}}]'></textarea>
                </form>
                <div class="grid gap-2 md:grid-cols-2">
                    {% for node in fail2banNodes %}
                        <form method="post" action="/admin/security/ruleset/{{ node.id }}/rollback" class="rounded-lg border border-slate-200 px-3 py-2 flex items-center justify-between text-xs">
                            <span>{{ node.name }} · {{ node.unifiedPolicy ? ('v' ~ node.unifiedPolicy.version ~ ' ' ~ node.unifiedPolicy.status) : '-' }}</span>
                            <button type="submit" class="rounded border border-slate-300 px-2 py-1">Rollback</button>
                        </form>
                    {% endfor %}
                </div>
            </div>
        </div>

        <div class="rounded-xl border border-slate-200 bg-white shadow-sm">
            <div class="border-b border-slate-200 px-5 py-4">
                <h2 id="security-events" class="text-lg font-semibold">{{ t('admin_security_transparency_title', page_locale()) }}</h2>
                <p class="text-sm text-slate-700">{{ t('admin_security_transparency_intro', page_locale()) }}</p>
            </div>
            <div class="px-5 py-5">
                <div class="grid gap-3 md:grid-cols-2">
                    <div class="rounded-lg border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-700">
                        <div class="text-xs uppercase">{{ t('admin_security_allowed', page_locale()) }}</div>
                        <div class="text-lg font-semibold">{{ securityEventSummary.allowed }}</div>
                    </div>
                    <div class="rounded-lg border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700">
                        <div class="text-xs uppercase">{{ t('admin_security_blocked', page_locale()) }}</div>
                        <div class="text-lg font-semibold">{{ securityEventSummary.blocked }}</div>
                    </div>
                </div>

                <form method="get" action="/admin/security" class="mt-4 grid gap-3 md:grid-cols-5">
                    <input type="datetime-local" name="event_from" value="{{ securityEventFilters.from ? securityEventFilters.from|date('Y-m-d\\TH:i') : '' }}" class="rounded-lg border border-slate-200 px-3 py-2 text-sm">
                    <input type="datetime-local" name="event_to" value="{{ securityEventFilters.to ? securityEventFilters.to|date('Y-m-d\\TH:i') : '' }}" class="rounded-lg border border-slate-200 px-3 py-2 text-sm">
                    <input name="event_ip" value="{{ securityEventFilters.ip|default('') }}" placeholder="{{ t('admin_security_event_ip', page_locale()) }}" class="rounded-lg border border-slate-200 px-3 py-2 text-sm">
                    <input name="event_rule" value="{{ securityEventFilters.rule|default('') }}" placeholder="{{ t('admin_security_event_rule', page_locale()) }}" class="rounded-lg border border-slate-200 px-3 py-2 text-sm">
                    <input name="event_source" value="{{ securityEventFilters.source|default('') }}" placeholder="{{ t('admin_security_event_source', page_locale()) }}" class="rounded-lg border border-slate-200 px-3 py-2 text-sm">
                    <div class="md:col-span-5">
                        <button type="submit" class="rounded-lg border border-slate-200 px-3 py-2 text-xs font-semibold text-slate-600">{{ t('admin_security_event_filter', page_locale()) }}</button>
                    </div>
                </form>

                <div class="mt-4 overflow-x-auto">
                    <table class="min-w-full text-left text-xs text-slate-600">
                        <thead class="border-b border-slate-200 text-[11px] uppercase text-slate-500">
                            <tr>
                                <th class="py-2">{{ t('admin_security_event_time', page_locale()) }}</th>
                                <th class="py-2">{{ t('admin_security_event_source', page_locale()) }}</th>
                                <th class="py-2">{{ t('admin_security_event_direction', page_locale()) }}</th>
                                <th class="py-2">{{ t('admin_security_event_rule', page_locale()) }}</th>
                                <th class="py-2">{{ t('admin_security_event_ip', page_locale()) }}</th>
                                <th class="py-2">{{ t('admin_security_event_reason', page_locale()) }}</th>
                                <th class="py-2">{{ t('admin_security_event_count', page_locale()) }}</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-200">
                            {% if securityEvents is empty %}
                                <tr>
                                    <td colspan="7" class="py-3 text-sm text-slate-500">{{ t('admin_security_event_no_results', page_locale()) }}</td>
                                </tr>
                            {% else %}
                                {% for event in securityEvents %}
                                    <tr>
                                        <td class="py-2">{{ event.occurredAt|date('Y-m-d H:i') }}</td>
                                        <td class="py-2">{{ event.source }}</td>
                                        <td class="py-2">{{ event.direction|title }}</td>
                                        <td class="py-2">{{ event.rule ?? '-' }}</td>
                                        <td class="py-2">{{ event.ip ?? '-' }}</td>
                                        <td class="py-2">{{ event.reason ?? '-' }}</td>
                                        <td class="py-2">{{ event.count ?? 1 }}</td>
                                    </tr>
                                {% endfor %}
                            {% endif %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
