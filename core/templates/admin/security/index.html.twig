{% extends 'admin/base.html.twig' %}

{% set pageTitle = t('admin_security_title', page_locale()) %}
{% set pageSubtitle = t('admin_security_intro', page_locale()) %}
{% set activeNav = 'security' %}

{% block content %}
<div class="flex flex-col gap-6">

    {% if errors is not empty %}
        <div class="ng-alert ng-alert--danger">
            <ul class="list-disc space-y-1 pl-4">
                {% for error in errors %}
                    <li>{{ error }}</li>
                {% endfor %}
            </ul>
        </div>
    {% endif %}

    {% if ddosUpdated %}
        <div class="ng-alert ng-alert--success">{{ t('admin_security_ddos_updated', page_locale()) }}</div>
    {% endif %}
    {% if fail2banUpdated %}
        <div class="ng-alert ng-alert--success">{{ t('admin_security_fail2ban_updated', page_locale()) }}</div>
    {% endif %}
    {% if previewEnabled %}
        <div class="ng-alert ng-alert--warning">{{ t('admin_security_preview_notice', page_locale()) }}</div>
    {% endif %}

    {# ── Row 1: DDoS Provider + Firewall ── #}
    <div class="grid gap-6 lg:grid-cols-2">

        {# DDoS Provider #}
        <div class="ng-data-card">
            <div class="ng-data-card__header">
                <div>
                    <h2 class="ng-data-card__title" id="ddos-provider">{{ t('admin_security_ddos_provider_title', page_locale()) }}</h2>
                    <p class="ng-data-card__sub">{{ t('admin_security_ddos_provider_intro', page_locale()) }}</p>
                </div>
            </div>
            <div class="ng-data-card__body">
                <form method="post" action="/admin/security/ddos" class="flex flex-col gap-4">
                    <div class="form-field">
                        <label class="form-label">{{ t('admin_security_provider_label', page_locale()) }}</label>
                        <input
                            name="provider"
                            placeholder="{{ t('admin_security_provider_placeholder', page_locale()) }}"
                            class="form-input"
                        >
                    </div>
                    <div class="form-field">
                        <label class="form-label">{{ t('admin_security_api_key_label', page_locale()) }}</label>
                        <input
                            type="password"
                            name="api_key"
                            placeholder="{{ t('admin_security_api_key_placeholder', page_locale()) }}"
                            class="form-input"
                        >
                    </div>
                    <div>
                        <button type="submit" class="ui-button ui-button--primary ui-button--sm">{{ t('admin_security_save_credentials', page_locale()) }}</button>
                    </div>
                </form>

                <div class="mt-6">
                    <p class="form-label mb-2">{{ t('admin_security_configured_providers', page_locale()) }}</p>
                    {% if credentials is empty %}
                        <p class="text-sm text-slate-500">{{ t('admin_security_no_providers', page_locale()) }}</p>
                    {% else %}
                        <ul class="flex flex-col gap-2">
                            {% for credential in credentials %}
                                <li class="flex items-center justify-between rounded-lg border border-slate-200 px-3 py-2 text-sm">
                                    <span class="font-medium text-slate-900">{{ credential.provider|title }}</span>
                                    <span class="text-xs text-slate-500">{{ t('admin_security_updated_at', page_locale())|replace({'%time%': credential.updatedAt|date('Y-m-d H:i')}) }}</span>
                                </li>
                            {% endfor %}
                        </ul>
                    {% endif %}
                </div>
            </div>
        </div>

        {# Firewall #}
        <div class="ng-data-card">
            <div class="ng-data-card__header">
                <div>
                    <h2 class="ng-data-card__title" id="firewall">{{ t('admin_security_firewall_title', page_locale()) }}</h2>
                    <p class="ng-data-card__sub">{{ t('admin_security_firewall_intro', page_locale()) }}</p>
                </div>
            </div>
            <div class="ng-data-card__body--flush">
                {% if firewallNodes is empty %}
                    <div class="px-5 py-5 text-sm text-slate-500">{{ t('admin_security_no_nodes', page_locale()) }}</div>
                {% else %}
                    <div class="divide-y divide-slate-100">
                        {% for node in firewallNodes %}
                            <div class="px-5 py-5">
                                <div class="flex flex-wrap items-center justify-between gap-3">
                                    <div>
                                        <p class="text-sm font-semibold text-slate-900">{{ node.name }}</p>
                                        <p class="text-xs text-slate-500">{{ t('admin_security_node_last_update', page_locale())|replace({'%id%': node.id, '%time%': node.updatedAt|date('Y-m-d H:i')}) }}</p>
                                    </div>
                                    {% if node.status == 'online' %}
                                        <span class="ui-badge ui-badge--success">{{ node.status|title }}</span>
                                    {% elseif node.status == 'degraded' %}
                                        <span class="ui-badge ui-badge--warning">{{ node.status|title }}</span>
                                    {% else %}
                                        <span class="ui-badge ui-badge--danger">{{ node.status|title }}</span>
                                    {% endif %}
                                </div>

                                <div class="mt-4 flex flex-wrap gap-2">
                                    {% if node.rules is empty %}
                                        {% if node.ports is empty %}
                                            <span class="ui-badge ui-badge--neutral">{{ t('admin_security_no_firewall_rules', page_locale()) }}</span>
                                        {% else %}
                                            {% for port in node.ports %}
                                                <span class="ui-badge ui-badge--neutral">{{ port }}</span>
                                            {% endfor %}
                                        {% endif %}
                                    {% else %}
                                        {% for rule in node.rules %}
                                            <span class="ui-badge {{ rule.status == 'open' ? 'ui-badge--success' : 'ui-badge--danger' }}">
                                                {{ rule.port }}/{{ rule.protocol|upper }} · {{ rule.status|title }}
                                            </span>
                                        {% endfor %}
                                    {% endif %}
                                </div>

                                {% if node.job %}
                                    <div class="mt-4 rounded-lg border border-slate-200 bg-slate-50 px-3 py-2 text-xs text-slate-600">
                                        <div class="flex flex-wrap items-center justify-between gap-2">
                                            <span class="font-semibold text-slate-700">{{ t('admin_security_last_firewall_job', page_locale()) }}</span>
                                            <span class="text-slate-500">{{ node.job.type }} · {{ node.job.status|title }}</span>
                                        </div>
                                        {% if node.job.resultStatus %}
                                            <div class="mt-2 text-slate-600">
                                                {{ t('admin_security_job_result', page_locale()) }} <span class="font-semibold">{{ node.job.resultStatus|title }}</span>
                                                {% if node.job.resultMessage %} · {{ node.job.resultMessage }}{% endif %}
                                            </div>
                                        {% endif %}
                                    </div>
                                {% endif %}

                                <form method="post" action="/admin/security/firewall/{{ node.id }}" class="mt-4 flex flex-col gap-3">
                                    <div class="form-field">
                                        <label class="form-label">{{ t('admin_security_desired_ports', page_locale()) }}</label>
                                        <input
                                            name="ports"
                                            value="{{ node.ports|join(', ') }}"
                                            placeholder="{{ t('admin_security_ports_placeholder', page_locale()) }}"
                                            class="form-input"
                                        >
                                    </div>
                                    <label class="inline-flex items-center gap-2 text-xs font-semibold uppercase text-slate-700">
                                        <input type="checkbox" name="dry_run" value="1" class="rounded border-slate-300">
                                        {{ t('admin_security_preview_mode', page_locale()) }}
                                    </label>
                                    <div class="flex items-center gap-3">
                                        <button type="submit" class="ui-button ui-button--ghost ui-button--sm">{{ t('admin_security_update_firewall', page_locale()) }}</button>
                                        {% if firewallUpdated == node.id %}
                                            <span class="ui-badge ui-badge--success">{{ t('admin_security_saved', page_locale()) }}</span>
                                        {% endif %}
                                    </div>
                                </form>
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
        </div>

    </div>

    {# ── Row 2: Fail2Ban + Security Events ── #}
    <div class="grid gap-6 lg:grid-cols-2">

        {# Fail2Ban #}
        <div class="ng-data-card">
            <div class="ng-data-card__header">
                <div>
                    <h2 class="ng-data-card__title" id="fail2ban">{{ t('admin_security_fail2ban_title', page_locale()) }}</h2>
                    <p class="ng-data-card__sub">{{ t('admin_security_fail2ban_intro', page_locale()) }}</p>
                </div>
            </div>
            <div class="ng-data-card__body--flush">
                {% if fail2banNodes is empty %}
                    <div class="px-5 py-5 text-sm text-slate-500">{{ t('admin_security_no_nodes', page_locale()) }}</div>
                {% else %}
                    <div class="divide-y divide-slate-100">
                        {% for node in fail2banNodes %}
                            {% set payload = node.policy ? node.policy.payload : {} %}
                            <div class="px-5 py-5">
                                <div class="flex flex-wrap items-center justify-between gap-3">
                                    <div>
                                        <p class="text-sm font-semibold text-slate-900">{{ node.name }}</p>
                                        <p class="text-xs text-slate-500">{{ t('admin_security_node_last_update', page_locale())|replace({'%id%': node.id, '%time%': node.updatedAt|date('Y-m-d H:i')}) }}</p>
                                    </div>
                                    {% if node.status == 'online' %}
                                        <span class="ui-badge ui-badge--success">{{ node.status|title }}</span>
                                    {% elseif node.status == 'degraded' %}
                                        <span class="ui-badge ui-badge--warning">{{ node.status|title }}</span>
                                    {% else %}
                                        <span class="ui-badge ui-badge--danger">{{ node.status|title }}</span>
                                    {% endif %}
                                </div>

                                {% if node.policy %}
                                    <div class="mt-2 text-xs text-slate-500">
                                        {{ t('admin_security_policy_version', page_locale())|replace({'%version%': node.policy.version}) }}
                                        · {{ t('admin_security_policy_status', page_locale())|replace({'%status%': node.policy.status|title}) }}
                                        {% if node.policy.appliedAt %}
                                            · {{ t('admin_security_policy_applied_at', page_locale())|replace({'%time%': node.policy.appliedAt|date('Y-m-d H:i')}) }}
                                        {% endif %}
                                    </div>
                                {% endif %}

                                <form method="post" action="/admin/security/fail2ban/{{ node.id }}" class="mt-4 flex flex-col gap-3">
                                    <label class="inline-flex items-center gap-2 text-xs font-semibold uppercase text-slate-700">
                                        <input type="checkbox" name="enabled" value="1" class="rounded border-slate-300" {% if payload.enabled is not defined or payload.enabled %}checked{% endif %}>
                                        {{ t('admin_security_fail2ban_enabled', page_locale()) }}
                                    </label>
                                    <div class="grid grid-cols-2 gap-3">
                                        <div class="form-field">
                                            <label class="form-label">{{ t('admin_security_fail2ban_bantime', page_locale()) }}</label>
                                            <input name="bantime" value="{{ payload.bantime|default('10m') }}" class="form-input">
                                        </div>
                                        <div class="form-field">
                                            <label class="form-label">{{ t('admin_security_fail2ban_findtime', page_locale()) }}</label>
                                            <input name="findtime" value="{{ payload.findtime|default('10m') }}" class="form-input">
                                        </div>
                                        <div class="form-field">
                                            <label class="form-label">{{ t('admin_security_fail2ban_maxretry', page_locale()) }}</label>
                                            <input name="maxretry" value="{{ payload.maxretry|default(5) }}" class="form-input">
                                        </div>
                                        <div class="form-field">
                                            <label class="form-label">{{ t('admin_security_fail2ban_jails', page_locale()) }}</label>
                                            <input name="jails" value="{{ payload.jails is defined ? payload.jails|join(', ') : 'sshd' }}" class="form-input">
                                        </div>
                                    </div>
                                    <div class="form-field">
                                        <label class="form-label">{{ t('admin_security_fail2ban_ignore_ips', page_locale()) }}</label>
                                        <input name="ignore_ips" value="{{ payload.ignore_ips is defined ? payload.ignore_ips|join(', ') : '127.0.0.1/8' }}" class="form-input">
                                    </div>
                                    <div class="form-field">
                                        <label class="form-label">{{ t('admin_security_fail2ban_advanced', page_locale()) }}</label>
                                        <textarea name="advanced_config" rows="4" class="form-input">{{ payload.advanced_config|default('') }}</textarea>
                                    </div>
                                    <label class="inline-flex items-center gap-2 text-xs font-semibold uppercase text-slate-700">
                                        <input type="checkbox" name="dry_run" value="1" class="rounded border-slate-300">
                                        {{ t('admin_security_preview_mode', page_locale()) }}
                                    </label>
                                    <div class="flex flex-wrap items-center gap-3">
                                        <button type="submit" class="ui-button ui-button--ghost ui-button--sm">{{ t('admin_security_update_fail2ban', page_locale()) }}</button>
                                        {% if fail2banUpdated == node.id %}
                                            <span class="ui-badge ui-badge--success">{{ t('admin_security_saved', page_locale()) }}</span>
                                        {% endif %}
                                    </div>
                                </form>

                                <form method="post" action="/admin/security/fail2ban/{{ node.id }}/status" class="mt-3">
                                    <button type="submit" class="ui-button ui-button--ghost ui-button--sm">{{ t('admin_security_fail2ban_check_status', page_locale()) }}</button>
                                </form>
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
        </div>

        {# Security Events #}
        <div class="ng-data-card">
            <div class="ng-data-card__header">
                <div>
                    <h2 class="ng-data-card__title" id="security-events">{{ t('admin_security_transparency_title', page_locale()) }}</h2>
                    <p class="ng-data-card__sub">{{ t('admin_security_transparency_intro', page_locale()) }}</p>
                </div>
            </div>
            <div class="ng-data-card__body">
                <div class="ng-kpi-row">
                    <div class="ng-kpi-box">
                        <div class="ng-kpi-box__label">{{ t('admin_security_allowed', page_locale()) }}</div>
                        <div class="ng-kpi-box__value ng-kpi-box__value--success">{{ securityEventSummary.allowed }}</div>
                    </div>
                    <div class="ng-kpi-box">
                        <div class="ng-kpi-box__label">{{ t('admin_security_blocked', page_locale()) }}</div>
                        <div class="ng-kpi-box__value ng-kpi-box__value--danger">{{ securityEventSummary.blocked }}</div>
                    </div>
                </div>

                <form method="get" action="/admin/security" class="mt-4 grid grid-cols-2 gap-3 md:grid-cols-3">
                    <input type="datetime-local" name="event_from" value="{{ securityEventFilters.from ? securityEventFilters.from|date('Y-m-d\\TH:i') : '' }}" class="form-input">
                    <input type="datetime-local" name="event_to" value="{{ securityEventFilters.to ? securityEventFilters.to|date('Y-m-d\\TH:i') : '' }}" class="form-input">
                    <input name="event_ip" value="{{ securityEventFilters.ip|default('') }}" placeholder="{{ t('admin_security_event_ip', page_locale()) }}" class="form-input">
                    <input name="event_rule" value="{{ securityEventFilters.rule|default('') }}" placeholder="{{ t('admin_security_event_rule', page_locale()) }}" class="form-input">
                    <input name="event_source" value="{{ securityEventFilters.source|default('') }}" placeholder="{{ t('admin_security_event_source', page_locale()) }}" class="form-input">
                    <div>
                        <button type="submit" class="ui-button ui-button--ghost ui-button--sm">{{ t('admin_security_event_filter', page_locale()) }}</button>
                    </div>
                </form>

                <div class="cust-ws-table-wrap mt-4">
                    <table class="cust-table">
                        <thead>
                            <tr>
                                <th>{{ t('admin_security_event_time', page_locale()) }}</th>
                                <th>{{ t('admin_security_event_source', page_locale()) }}</th>
                                <th>{{ t('admin_security_event_direction', page_locale()) }}</th>
                                <th>{{ t('admin_security_event_rule', page_locale()) }}</th>
                                <th>{{ t('admin_security_event_ip', page_locale()) }}</th>
                                <th>{{ t('admin_security_event_reason', page_locale()) }}</th>
                                <th>{{ t('admin_security_event_count', page_locale()) }}</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for event in securityEvents %}
                                <tr>
                                    <td>{{ event.occurredAt|date('Y-m-d H:i') }}</td>
                                    <td>{{ event.source }}</td>
                                    <td>{{ event.direction|title }}</td>
                                    <td>{{ event.rule ?? '-' }}</td>
                                    <td>{{ event.ip ?? '-' }}</td>
                                    <td>{{ event.reason ?? '-' }}</td>
                                    <td>{{ event.count ?? 1 }}</td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="7" class="cust-table__empty">{{ t('admin_security_event_no_results', page_locale()) }}</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

    </div>

    {# ── Unified Ruleset ── #}
    <div class="ng-data-card">
        <div class="ng-data-card__header">
            <div>
                <h2 class="ng-data-card__title" id="unified-ruleset">{{ t('admin_security_unified_title', page_locale()) }}</h2>
                <p class="ng-data-card__sub">{{ t('admin_security_unified_intro', page_locale()) }}</p>
            </div>
        </div>
        <div class="ng-data-card__body">
            {% if rulesetUpdated == 'applied' %}
                <div class="ng-alert ng-alert--success mb-4">{{ t('admin_security_unified_applied', page_locale()) }}</div>
            {% elseif rulesetUpdated == 'rollback' %}
                <div class="ng-alert ng-alert--warning mb-4">{{ t('admin_security_unified_rollback', page_locale()) }}</div>
            {% endif %}

            <form method="post" action="/admin/security/ruleset/apply" class="flex flex-col gap-4">
                <div class="grid grid-cols-2 gap-3 md:grid-cols-3">
                    <select name="target_scope" class="form-input">
                        <option value="global">Global</option>
                        <option value="node">Node</option>
                    </select>
                    <select name="target_node_id" class="form-input">
                        <option value="">{{ t('admin_security_select_node', page_locale()) }}</option>
                        {% for node in fail2banNodes %}
                            <option value="{{ node.id }}">{{ node.name }}</option>
                        {% endfor %}
                    </select>
                    <div>
                        <button type="submit" class="ui-button ui-button--primary">{{ t('admin_security_unified_apply', page_locale()) }}</button>
                    </div>
                </div>
                <textarea name="rules_json" rows="6" class="form-input font-mono text-xs" placeholder='[{"id":"allow-ssh","type":"firewall","action":"allow","protocol":"tcp","port":22,"priority":10,"enabled":true,"reason":"admin-access","target":{"scope":"global"}}]'></textarea>
            </form>

            <div class="mt-4 grid gap-2 md:grid-cols-2">
                {% for node in fail2banNodes %}
                    <form method="post" action="/admin/security/ruleset/{{ node.id }}/rollback" class="flex items-center justify-between rounded-lg border border-slate-200 px-3 py-2 text-xs">
                        <span class="text-slate-700">{{ node.name }} · {{ node.unifiedPolicy ? ('v' ~ node.unifiedPolicy.version ~ ' ' ~ node.unifiedPolicy.status) : '-' }}</span>
                        <button type="submit" class="ui-button ui-button--ghost ui-button--sm">Rollback</button>
                    </form>
                {% endfor %}
            </div>
        </div>
    </div>

</div>
{% endblock %}
