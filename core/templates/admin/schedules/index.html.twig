{% extends 'admin/base.html.twig' %}

{% block title %}Geplante Aufgaben · Easy-Wi NextGen{% endblock %}

{% block content %}
<div class="mb-6 flex items-center justify-between">
    <div>
        <h1 class="text-2xl font-semibold">Geplante Aufgaben</h1>
        <p class="text-sm text-slate-700">Zentrale Übersicht für interne Schedules. Produktiv wird nur <code>app:run-schedules</code> benötigt.</p>
    </div>
</div>

<div class="grid grid-cols-1 gap-4 md:grid-cols-5 mb-6">
    <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-xs uppercase text-slate-500">Scheduler</p>
        <p class="mt-2 text-xl font-semibold {{ summary.scheduler_running ? 'text-emerald-600' : 'text-rose-600' }}">{{ summary.scheduler_running ? 'läuft' : 'läuft nicht' }}</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-xs uppercase text-slate-500">Letzter Heartbeat</p>
        <p class="mt-2 text-lg font-semibold">{{ summary.last_heartbeat ? summary.last_heartbeat|date('Y-m-d H:i:s') : '—' }}</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-xs uppercase text-slate-500">Fällige Aufgaben</p>
        <p class="mt-2 text-2xl font-semibold">{{ summary.due_tasks }}</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-xs uppercase text-slate-500">Fehler letzte 24h</p>
        <p class="mt-2 text-2xl font-semibold text-rose-600">{{ summary.failed_24h }}</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-xs uppercase text-slate-500">Jobs letzte 24h</p>
        <p class="mt-2 text-2xl font-semibold text-indigo-600">{{ summary.created_jobs_24h }}</p>
    </div>
</div>

<div class="rounded-xl border border-slate-200 bg-white mb-8 overflow-x-auto">
    <table class="min-w-full text-sm">
        <thead class="bg-slate-50 text-left text-xs uppercase text-slate-500">
        <tr>
            <th class="px-4 py-3">ID</th>
            <th class="px-4 py-3">Name</th>
            <th class="px-4 py-3">Modul</th>
            <th class="px-4 py-3">Typ</th>
            <th class="px-4 py-3">Aktiv</th>
            <th class="px-4 py-3">Cron</th>
            <th class="px-4 py-3">Nächste Ausführung</th>
            <th class="px-4 py-3">Letzte Ausführung</th>
            <th class="px-4 py-3">Status</th>
            <th class="px-4 py-3">Fehler</th>
            <th class="px-4 py-3">Letzter Job</th>
            <th class="px-4 py-3">Aktionen</th>
        </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
        {% for schedule in schedules %}
            <tr>
                <td class="px-4 py-3"><code>{{ schedule.source }}:{{ schedule.id }}</code></td>
                <td class="px-4 py-3 font-medium">{{ schedule.name }}{% if not schedule.handler_active %}<p class="mt-1 rounded bg-amber-50 px-2 py-1 text-xs text-amber-700">{{ schedule.warning ?: 'Dieser Zeitplan ist gespeichert, aber aktuell keinem aktiven Scheduler-Handler zugeordnet.' }}</p>{% endif %}</td>
                <td class="px-4 py-3">{{ schedule.module }}</td>
                <td class="px-4 py-3"><code>{{ schedule.type }}</code></td>
                <td class="px-4 py-3">{{ schedule.enabled ? 'Aktiv' : 'Inaktiv' }}</td>
                <td class="px-4 py-3"><code>{{ schedule.cron_expression }}</code></td>
                <td class="px-4 py-3">{{ schedule.next_run_at ? schedule.next_run_at|date('Y-m-d H:i') : '—' }}</td>
                <td class="px-4 py-3">{{ schedule.last_run_at ? schedule.last_run_at|date('Y-m-d H:i') : '—' }}</td>
                <td class="px-4 py-3">{{ schedule.last_status ?: '—' }}</td>
                <td class="px-4 py-3">{{ schedule.last_error ?: '—' }}</td>
                <td class="px-4 py-3">{{ schedule.last_job_id ?: '—' }}</td>
                <td class="px-4 py-3">
                    <div class="flex gap-2">
                        <form method="post" action="{{ path('admin_schedules_run_now') }}">
                            <input type="hidden" name="type" value="{{ schedule.type }}">
                            <input type="hidden" name="source" value="{{ schedule.source }}">
                            <input type="hidden" name="id" value="{{ schedule.id }}">
                            <button class="rounded bg-indigo-600 px-3 py-1 text-xs text-white" type="submit">Jetzt ausführen</button>
                        </form>
                        <form method="post" action="{{ path('admin_schedules_toggle') }}">
                            <input type="hidden" name="source" value="{{ schedule.source }}">
                            <input type="hidden" name="id" value="{{ schedule.id }}">
                            <input type="hidden" name="enabled" value="{{ schedule.enabled ? '0' : '1' }}">
                            <button class="rounded border border-slate-200 px-3 py-1 text-xs" type="submit">{{ schedule.enabled ? 'Deaktivieren' : 'Aktivieren' }}</button>
                        </form>
                        <a class="rounded border border-slate-200 px-3 py-1 text-xs" href="{{ path('admin_schedules_history', {source: schedule.source, id: schedule.id}) }}">Verlauf</a>
                        <a class="rounded border border-slate-200 px-3 py-1 text-xs" href="{{ path('admin_schedules_logs', {source: schedule.source, id: schedule.id}) }}">Logs</a>
                        <span class="rounded border border-slate-200 px-3 py-1 text-xs text-slate-400">Bearbeiten</span>
                    </div>
                </td>
            </tr>
        {% else %}
            <tr><td colspan="12" class="px-4 py-6 text-center text-slate-500">Keine geplanten Aufgaben gefunden.</td></tr>
        {% endfor %}
        </tbody>
    </table>
</div>

<div class="rounded-xl border border-slate-200 bg-white overflow-x-auto">
    <div class="border-b border-slate-200 px-4 py-3">
        <h2 class="font-semibold">Letzte Scheduler-Läufe</h2>
    </div>
    <table class="min-w-full text-sm">
        <thead class="bg-slate-50 text-left text-xs uppercase text-slate-500"><tr><th class="px-4 py-3">Zeit</th><th class="px-4 py-3">Typ</th><th class="px-4 py-3">Status</th><th class="px-4 py-3">Jobs</th><th class="px-4 py-3">Meldung</th></tr></thead>
        <tbody class="divide-y divide-slate-100">
        {% for run in runs %}
            <tr><td class="px-4 py-3">{{ run.started_at|date('Y-m-d H:i:s') }}</td><td class="px-4 py-3"><code>{{ run.type }}</code></td><td class="px-4 py-3">{{ run.status }}</td><td class="px-4 py-3">{{ run.created_job_ids|join(', ') ?: '—' }}</td><td class="px-4 py-3">{{ run.message ?: '—' }}</td></tr>
        {% else %}
            <tr><td colspan="5" class="px-4 py-6 text-center text-slate-500">Noch keine History.</td></tr>
        {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
