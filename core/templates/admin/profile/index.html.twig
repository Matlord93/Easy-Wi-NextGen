{% extends 'admin/base.html.twig' %}
{% set pageTitle = t('prof_hero_title', page_locale()) %}
{% set pageSubtitle = t('admin_prof_hero_intro', page_locale()) %}
{% set activeNav = 'profile' %}
{% set locale = page_locale() %}

{# Default to security tab when a 2FA or password action just completed #}
{% set defaultTab = (twoFactor.success is not empty or (errors is not empty and form.password is defined)) ? 'security' : 'profile' %}

{% block content %}
<div style="display:flex;flex-direction:column;gap:20px;">

    {# ── Hero / KPI card ── #}
    <div class="ng-card" style="overflow:hidden;">
        <div class="tkt-hero">
            <div class="tkt-hero__inner">
                <div style="display:flex;flex-direction:column;gap:6px;">
                    <div class="tkt-hero__pill">
                        <span class="tkt-hero__pill-dot" style="background:#6366f1;"></span>
                        {{ t('admin_prof_hero_label', locale) }}
                    </div>
                    <h1 class="tkt-hero__title">{{ t('prof_hero_title', locale) }}</h1>
                    <p class="tkt-hero__sub">{{ t('admin_prof_hero_intro', locale) }}</p>
                </div>
                <div style="display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:8px;margin-top:16px;">
                    <div class="tkt-kpi tkt-kpi--resolved">
                        <div class="tkt-kpi__label">{{ t('admin_prof_kpi_account', locale) }}</div>
                        <div class="tkt-kpi__value" style="font-size:13px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{{ form.email }}</div>
                    </div>
                    <div class="tkt-kpi {{ twoFactor.enabled ? 'tkt-kpi--resolved' : 'tkt-kpi--pending' }}">
                        <div class="tkt-kpi__label">{{ t('admin_prof_kpi_2fa', locale) }}</div>
                        <div class="tkt-kpi__value" style="font-size:13px;">{{ twoFactor.enabled ? t('two_factor_enabled_badge', locale) : t('two_factor_disabled_badge', locale) }}</div>
                    </div>
                    <div class="tkt-kpi {{ form.ssh_key_set ? 'tkt-kpi--resolved' : '' }}">
                        <div class="tkt-kpi__label">{{ t('admin_prof_kpi_ssh', locale) }}</div>
                        <div class="tkt-kpi__value" style="font-size:13px;">{{ form.ssh_key_set ? t('admin_prof_kpi_ssh_set', locale) : t('admin_prof_kpi_ssh_unset', locale) }}</div>
                    </div>
                </div>
            </div>
        </div>

        {# ── Tab navigation ── #}
        <div class="prof-tabs">
            <button type="button" class="prof-tab-btn" data-tab-btn="profile">
                <svg viewBox="0 0 16 16" fill="currentColor"><path d="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6zm2-3a2 2 0 1 1-4 0 2 2 0 0 1 4 0zm4 8c0 1-1 1-1 1H3s-1 0-1-1 1-4 6-4 6 3 6 4zm-1-.004c-.001-.246-.154-.986-.832-1.664C11.516 10.68 10.029 10 8 10c-2.029 0-3.516.68-4.168 1.332-.678.678-.83 1.418-.832 1.664h10z"/></svg>
                {{ t('admin_prof_tab_profile', locale) }}
            </button>
            <button type="button" class="prof-tab-btn" data-tab-btn="security">
                <svg viewBox="0 0 16 16" fill="currentColor"><path d="M5.338 1.59a61.44 61.44 0 0 0-2.837.856.481.481 0 0 0-.328.39c-.554 4.157.726 7.19 2.253 9.188a10.725 10.725 0 0 0 2.287 2.233c.346.244.652.42.893.533.12.057.218.095.293.118a.55.55 0 0 0 .101.025.615.615 0 0 0 .1-.025c.076-.023.174-.061.294-.118.24-.113.547-.29.893-.533a10.726 10.726 0 0 0 2.287-2.233c1.527-1.997 2.807-5.031 2.253-9.188a.48.48 0 0 0-.328-.39c-.651-.213-1.75-.56-2.837-.855C9.552 1.29 8.531 1.067 8 1.067c-.53 0-1.552.223-2.662.524z"/></svg>
                {{ t('admin_prof_tab_security', locale) }}
            </button>
        </div>
    </div>

    {# ── Alerts ── #}
    {% if errors is not empty %}
        <div class="ng-alert ng-alert--danger">
            <ul style="margin:0;padding-left:18px;">
                {% for error in errors %}<li>{{ t(error, locale) }}</li>{% endfor %}
            </ul>
        </div>
    {% elseif form.success %}
        <div class="ng-alert ng-alert--success">{{ t('admin_profile_success', locale) }}</div>
    {% endif %}

    {% if twoFactor.success %}
        <div class="ng-alert ng-alert--success">{{ t(twoFactor.success, locale) }}</div>
    {% endif %}

    {# ══════════════════════════════════════════════════
       TAB: PROFILE
       ══════════════════════════════════════════════════ #}
    <div data-tab-panel="profile" style="display:flex;flex-direction:column;gap:20px;">

        <div class="prof-section">
            <div class="prof-section__head">
                <div>
                    <div class="prof-section__title">{{ t('admin_prof_section_details', locale) }}</div>
                    <div class="prof-section__sub">{{ t('admin_prof_section_details_sub', locale) }}</div>
                </div>
                <span class="ui-badge ui-badge--neutral">{{ t('admin_profile_title', locale) }}</span>
            </div>
            <div class="prof-section__body">
                <form method="post" action="/admin/profile">
                    {# Hidden password fields so they're submitted as empty (won't change password) #}
                    <input type="hidden" name="password" value="">
                    <input type="hidden" name="password_confirm" value="">

                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
                        <div class="form-field">
                            <label class="form-label">{{ t('name', locale) }}</label>
                            <input type="text" name="name" value="{{ form.name }}" class="form-input">
                        </div>
                        <div class="form-field">
                            <label class="form-label">{{ t('email_address', locale) }}</label>
                            <input type="email" name="email" required value="{{ form.email }}" class="form-input">
                        </div>
                    </div>

                    <div class="form-field" style="margin-top:12px;">
                        <label class="form-label">{{ t('admin_profile_signature_label', locale) }}</label>
                        <textarea name="signature" rows="4" placeholder="{{ t('admin_profile_signature_placeholder', locale) }}" class="form-input">{{ form.signature }}</textarea>
                    </div>

                    <div style="display:flex;justify-content:flex-end;margin-top:16px;gap:10px;">
                        <a href="/admin" class="ui-button ui-button--ghost">{{ t('admin_profile_back_dashboard', locale) }}</a>
                        <button type="submit" class="ui-button ui-button--primary">{{ t('admin_profile_save_changes', locale) }}</button>
                    </div>
                </form>
            </div>
        </div>

        {# ── SSH Public Key ── #}
        <div class="prof-section">
            <div class="prof-section__head">
                <div>
                    <div class="prof-section__title">{{ t('admin_prof_section_ssh', locale) }}</div>
                    <div class="prof-section__sub">{{ t('admin_profile_ssh_key_label', locale) }}</div>
                </div>
                <span class="ui-badge {{ form.ssh_key_set ? 'ui-badge--success' : 'ui-badge--neutral' }}">
                    {{ form.ssh_key_set ? t('admin_prof_kpi_ssh_set', locale) : t('admin_prof_kpi_ssh_unset', locale) }}
                </span>
            </div>
            <div class="prof-section__body">
                <form method="post" action="/admin/profile">
                    {# Preserve other fields unchanged when submitting SSH key #}
                    <input type="hidden" name="name" value="{{ form.name }}">
                    <input type="hidden" name="email" value="{{ form.email }}">
                    <input type="hidden" name="signature" value="{{ form.signature }}">
                    <input type="hidden" name="password" value="">
                    <input type="hidden" name="password_confirm" value="">

                    {% if form.ssh_key_set %}
                        <div class="prof-secret-bar" style="margin-bottom:10px;">
                            <span class="prof-secret-bar__value" style="font-size:12px;opacity:0.7;">{{ form.ssh_key }}</span>
                        </div>
                        <p style="font-size:13px;color:var(--ng-text-muted);margin:0;">{{ t('admin_profile_ssh_key_help_locked', locale) }}</p>
                    {% elseif form.ssh_key_pending %}
                        <div class="prof-secret-bar" style="margin-bottom:10px;">
                            <span class="prof-secret-bar__value" style="font-size:12px;opacity:0.7;">{{ form.ssh_key_pending_value }}</span>
                        </div>
                        <p style="font-size:13px;color:var(--ng-text-muted);margin:0;">{{ t('admin_profile_ssh_key_help_pending', locale) }}</p>
                    {% elseif form.ssh_key_enabled %}
                        <div class="form-field">
                            <label class="form-label">{{ t('admin_profile_ssh_key_label', locale) }}</label>
                            <textarea name="ssh_key" rows="4" placeholder="{{ t('admin_profile_ssh_key_placeholder', locale) }}" class="form-input">{{ form.ssh_key }}</textarea>
                            <p class="form-hint">{{ t('admin_profile_ssh_key_help', locale) }}</p>
                        </div>
                        <div style="background:var(--ng-surface-soft);border:1px solid var(--ng-border);border-radius:var(--ng-radius);padding:14px;margin-top:12px;">
                            <p style="margin:0 0 6px;font-size:12px;font-weight:700;color:var(--ng-text);">{{ t('admin_profile_ssh_key_instruction_title', locale) }}</p>
                            <ul style="margin:0;padding-left:16px;font-size:12px;color:var(--ng-text-muted);display:flex;flex-direction:column;gap:4px;">
                                <li>{{ t('admin_profile_ssh_key_instruction_generate', locale) }}</li>
                                <li>{{ t('admin_profile_ssh_key_instruction_copy', locale) }}</li>
                            </ul>
                        </div>
                        <div style="display:flex;justify-content:flex-end;margin-top:16px;">
                            <button type="submit" class="ui-button ui-button--primary">{{ t('admin_profile_save_changes', locale) }}</button>
                        </div>
                    {% else %}
                        <textarea rows="3" class="form-input" readonly disabled style="opacity:0.5;cursor:not-allowed;"></textarea>
                        <p style="font-size:13px;color:var(--ng-text-muted);margin:8px 0 0;">{{ t('admin_profile_ssh_key_help_disabled', locale) }}</p>
                    {% endif %}
                </form>
            </div>
        </div>

    </div>{# /tab panel: profile #}

    {# ══════════════════════════════════════════════════
       TAB: SECURITY
       ══════════════════════════════════════════════════ #}
    <div data-tab-panel="security" style="display:none;flex-direction:column;gap:20px;">

        {# ── Password change ── #}
        <div class="prof-section">
            <div class="prof-section__head">
                <div>
                    <div class="prof-section__title">{{ t('admin_prof_section_password', locale) }}</div>
                    <div class="prof-section__sub">{{ t('admin_prof_section_password_sub', locale) }}</div>
                </div>
                <span class="ui-badge ui-badge--neutral">
                    <svg viewBox="0 0 16 16" fill="currentColor" style="width:12px;height:12px;margin-right:4px;"><path d="M8 1a2 2 0 0 1 2 2v4H6V3a2 2 0 0 1 2-2zm3 6V3a3 3 0 0 0-6 0v4a2 2 0 0 0-2 2v5a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z"/></svg>
                    {{ t('password', locale) }}
                </span>
            </div>
            <div class="prof-section__body">
                <form method="post" action="/admin/profile">
                    {# Preserve other fields when only changing password #}
                    <input type="hidden" name="name" value="{{ form.name }}">
                    <input type="hidden" name="email" value="{{ form.email }}">
                    <input type="hidden" name="signature" value="{{ form.signature }}">

                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
                        <div class="form-field">
                            <label class="form-label">{{ t('admin_profile_password_label', locale) }}</label>
                            <input type="password" name="password" placeholder="{{ t('admin_profile_password_placeholder', locale) }}" class="form-input">
                        </div>
                        <div class="form-field">
                            <label class="form-label">{{ t('admin_profile_password_confirm_label', locale) }}</label>
                            <input type="password" name="password_confirm" placeholder="{{ t('admin_profile_password_confirm_placeholder', locale) }}" class="form-input">
                        </div>
                    </div>
                    <p class="form-hint" style="margin-top:6px;">{{ t('password_minimum', locale) }}</p>

                    <div style="display:flex;justify-content:flex-end;margin-top:16px;">
                        <button type="submit" class="ui-button ui-button--primary">{{ t('admin_profile_save_changes', locale) }}</button>
                    </div>
                </form>
            </div>
        </div>

        {# ── Two-factor authentication ── #}
        <div class="prof-section">
            <div class="prof-section__head">
                <div>
                    <div class="prof-section__title">{{ t('admin_prof_section_2fa', locale) }}</div>
                    <div class="prof-section__sub">{{ t('admin_prof_section_2fa_sub', locale) }}</div>
                </div>
                {% if twoFactor.required and not twoFactor.enabled %}
                    <span class="ui-badge ui-badge--warning">{{ t('two_factor_required_badge', locale) }}</span>
                {% elseif twoFactor.enabled %}
                    <span class="ui-badge ui-badge--success">{{ t('two_factor_enabled_badge', locale) }}</span>
                {% else %}
                    <span class="ui-badge ui-badge--neutral">{{ t('two_factor_disabled_badge', locale) }}</span>
                {% endif %}
            </div>
            <div class="prof-section__body">

                {% if twoFactor.enabled %}

                    <p style="font-size:13px;color:var(--ng-text-muted);margin:0;">{{ t('two_factor_enabled_intro', locale) }}</p>

                    {# ── Regenerate recovery codes ── #}
                    <div style="background:var(--ng-surface-soft);border:1px solid var(--ng-border);border-radius:var(--ng-radius);padding:16px;">
                        <div style="font-size:12px;font-weight:700;color:var(--ng-text);margin-bottom:10px;">{{ t('two_factor_regenerate', locale) }}</div>
                        <form method="post" action="/admin/profile/2fa/recovery" style="display:flex;gap:10px;flex-wrap:wrap;align-items:flex-end;">
                            <div class="form-field" style="flex:1;min-width:160px;">
                                <label class="form-label">{{ t('two_factor_code_label', locale) }}</label>
                                <input type="text" name="otp" placeholder="123456" class="form-input" autocomplete="one-time-code">
                            </div>
                            <p style="font-size:11px;color:var(--ng-text-muted);align-self:flex-end;padding-bottom:10px;margin:0;">{{ t('two_factor_regenerate_hint', locale) }}</p>
                            <button type="submit" class="ui-button ui-button--ghost">{{ t('two_factor_regenerate', locale) }}</button>
                        </form>
                    </div>

                    {# ── Disable 2FA ── #}
                    <div style="background:rgba(239,68,68,0.05);border:1px solid rgba(239,68,68,0.18);border-radius:var(--ng-radius);padding:16px;">
                        <div style="font-size:12px;font-weight:700;color:var(--ng-text);margin-bottom:10px;">{{ t('two_factor_disable', locale) }}</div>
                        <form method="post" action="/admin/profile/2fa/disable" style="display:flex;gap:10px;flex-wrap:wrap;align-items:flex-end;">
                            <div class="form-field" style="flex:1;min-width:160px;">
                                <label class="form-label">{{ t('two_factor_code_or_recovery', locale) }}</label>
                                <input type="text" name="otp" placeholder="123456" class="form-input" autocomplete="one-time-code">
                            </div>
                            <div class="form-field" style="flex:1;min-width:160px;">
                                <label class="form-label">{{ t('two_factor_recovery_label', locale) }}</label>
                                <input type="text" name="recovery_code" placeholder="0000-0000" class="form-input">
                            </div>
                            <button type="submit" class="ui-button ui-button--danger">{{ t('two_factor_disable', locale) }}</button>
                        </form>
                    </div>

                    {# ── Recovery codes shown once ── #}
                    {% if twoFactor.recovery_codes is not empty %}
                        <div class="ng-alert ng-alert--warning">
                            <p style="margin:0 0 8px;font-weight:700;">{{ t('two_factor_recovery_show_once', locale) }}</p>
                            <div class="prof-recovery-grid">
                                {% for code in twoFactor.recovery_codes %}
                                    <div class="prof-recovery-grid__code">{{ code }}</div>
                                {% endfor %}
                            </div>
                        </div>
                    {% endif %}

                {% else %}

                    {# ── Setup 2FA ── #}
                    <p style="font-size:13px;color:var(--ng-text-muted);margin:0;">{{ t('two_factor_setup_intro', locale) }}</p>

                    <div class="prof-2fa-grid">
                        <div style="display:flex;flex-direction:column;gap:14px;">
                            <div class="form-field">
                                <label class="form-label">{{ t('two_factor_secret_label', locale) }}</label>
                                <div class="prof-secret-bar">
                                    <span class="prof-secret-bar__value">{{ twoFactor.secret }}</span>
                                    <button type="button" class="ui-button ui-button--ghost ui-button--sm" data-copy-value="{{ twoFactor.secret }}">{{ t('copy', locale) }}</button>
                                </div>
                            </div>
                            <form method="post" action="/admin/profile/2fa/enable">
                                <div class="form-field">
                                    <label class="form-label">{{ t('two_factor_code_label', locale) }}</label>
                                    <input type="text" name="otp" placeholder="123456" class="form-input" autocomplete="one-time-code">
                                </div>
                                <div style="margin-top:12px;">
                                    <button type="submit" class="ui-button ui-button--primary">{{ t('two_factor_enable', locale) }}</button>
                                </div>
                            </form>
                        </div>
                        {% if twoFactor.qr %}
                            <div class="prof-2fa-qr">
                                <img src="{{ twoFactor.qr }}" alt="QR Code" class="prof-2fa-qr__img">
                                <p class="prof-2fa-qr__hint">{{ t('two_factor_scan_qr', locale) }}</p>
                            </div>
                        {% endif %}
                    </div>

                {% endif %}

            </div>
        </div>

    </div>{# /tab panel: security #}

</div>{# /page #}

<script>
(function () {
    var defaultTab = '{{ defaultTab }}';
    var buttons = document.querySelectorAll('[data-tab-btn]');
    var panels = document.querySelectorAll('[data-tab-panel]');

    function activate(tab) {
        buttons.forEach(function (btn) {
            btn.classList.toggle('prof-tab-btn--active', btn.dataset.tabBtn === tab);
        });
        panels.forEach(function (panel) {
            var show = panel.dataset.tabPanel === tab;
            panel.style.display = show ? 'flex' : 'none';
        });
        try { history.replaceState(null, '', location.pathname + '?tab=' + tab); } catch (e) {}
    }

    buttons.forEach(function (btn) {
        btn.addEventListener('click', function () { activate(btn.dataset.tabBtn); });
    });

    var urlTab = new URLSearchParams(location.search).get('tab');
    activate(urlTab === 'security' ? 'security' : defaultTab);
})();
</script>
{% endblock %}
