{% extends 'admin/base.html.twig' %}

{% set pageTitle = t('admin_audit_logs_heading', page_locale()) %}
{% set pageSubtitle = t('admin_audit_logs_intro', page_locale()) %}
{% set activeNav = 'audit-logs' %}

{% block content %}
{% set locale = page_locale() %}

{# ─── Hero ─── #}
<section class="ng-card" style="overflow:hidden;">
    <div class="tkt-hero" style="background:linear-gradient(135deg,#07101f 0%,#1a1640 50%,#0a1220 100%);">
        <div class="tkt-hero__inner">
            <div style="display:flex;flex-direction:column;gap:16px;">
                <div>
                    <div class="tkt-hero__pill">
                        <span class="tkt-hero__pill-dot" style="background:#818cf8;"></span>
                        {{ t('admin_audit_logs_workbench_label', locale) }}
                    </div>
                    <h1 class="tkt-hero__title" style="margin-top:10px;">{{ t('admin_audit_logs_heading', locale) }}</h1>
                    <p class="tkt-hero__sub">{{ t('admin_audit_logs_intro', locale) }}</p>
                </div>
                <div style="display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:10px;">
                    <div class="tkt-kpi">
                        <div class="tkt-kpi__label">{{ t('admin_audit_logs_total_entries', locale) }}</div>
                        <div class="tkt-kpi__value">{{ summary.total }}</div>
                    </div>
                    <div class="tkt-kpi tkt-kpi--pending">
                        <div class="tkt-kpi__label">{{ t('admin_audit_logs_latest_activity', locale) }}</div>
                        <div class="tkt-kpi__value">{{ summary.latest ? summary.latest|date('d.m.Y') : '—' }}</div>
                    </div>
                    <div class="tkt-kpi tkt-kpi--resolved">
                        <div class="tkt-kpi__label">{{ t('admin_audit_logs_retention', locale) }}</div>
                        <div class="tkt-kpi__value">{{ t('admin_audit_logs_retention_value', locale) }}</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div style="display:grid;grid-template-columns:1.2fr .8fr;gap:12px;padding:16px;border-top:1px solid var(--ng-border);background:var(--ng-surface-soft);">
        <div class="tkt-oldest">
            <div class="tkt-oldest__icon">
                <svg viewBox="0 0 20 20" fill="currentColor" width="18" height="18"><path fill-rule="evenodd" d="M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16zm.75-13a.75.75 0 0 0-1.5 0v5c0 .414.336.75.75.75h4a.75.75 0 0 0 0-1.5h-3.25V5z" clip-rule="evenodd"/></svg>
            </div>
            <div>
                <div class="tkt-oldest__label">{{ t('admin_audit_logs_latest_activity', locale) }}</div>
                <div class="tkt-oldest__subject">
                    {{ summary.latest ? summary.latest|date('Y-m-d H:i') : t('admin_audit_logs_no_activity', locale) }}
                </div>
            </div>
        </div>
        <div style="display:flex;gap:8px;align-items:center;justify-content:flex-end;">
            <button
                class="tkt-qa"
                hx-get="/admin/audit-logs/table"
                hx-target="#audit-logs-table"
                hx-swap="outerHTML"
            >
                <span class="tkt-qa__icon">
                    <svg viewBox="0 0 20 20" fill="currentColor" width="16" height="16"><path fill-rule="evenodd" d="M15.312 11.424a5.5 5.5 0 0 1-9.201 2.466l-.312-.311h2.433a.75.75 0 0 0 0-1.5H3.989a.75.75 0 0 0-.75.75v4.242a.75.75 0 0 0 1.5 0v-2.43l.31.31a7 7 0 0 0 11.712-3.138.75.75 0 0 0-1.449-.389zm1.23-3.723a.75.75 0 0 0 .219-.53V2.929a.75.75 0 0 0-1.5 0v2.43l-.31-.31A7 7 0 0 0 3.239 8.188a.75.75 0 1 0 1.448.389A5.5 5.5 0 0 1 13.89 6.11l.311.31h-2.432a.75.75 0 0 0 0 1.5h4.243a.75.75 0 0 0 .53-.219z" clip-rule="evenodd"/></svg>
                </span>
                <span class="tkt-qa__title">{{ t('refresh', locale) }}</span>
            </button>
            <a href="#audit-logs-table" class="tkt-qa">
                <span class="tkt-qa__icon">
                    <svg viewBox="0 0 20 20" fill="currentColor" width="16" height="16"><path fill-rule="evenodd" d="M2 3.75A.75.75 0 0 1 2.75 3h14.5a.75.75 0 0 1 0 1.5H2.75A.75.75 0 0 1 2 3.75zm0 4.167a.75.75 0 0 1 .75-.75h14.5a.75.75 0 0 1 0 1.5H2.75a.75.75 0 0 1-.75-.75zm0 4.166a.75.75 0 0 1 .75-.75h14.5a.75.75 0 0 1 0 1.5H2.75a.75.75 0 0 1-.75-.75zm0 4.167a.75.75 0 0 1 .75-.75h14.5a.75.75 0 0 1 0 1.5H2.75a.75.75 0 0 1-.75-.75z" clip-rule="evenodd"/></svg>
                </span>
                <span class="tkt-qa__title">{{ t('admin_audit_logs_recent_entries', locale) }}</span>
            </a>
        </div>
    </div>
</section>

{# ─── Table Section ─── #}
<section class="ng-card" id="audit-logs-table" style="margin-top:20px;">
    <div class="tkt-filter-bar">
        <div class="tkt-filter-bar__top">
            <div>
                <div class="tkt-filter-bar__title">{{ t('admin_audit_logs_recent_entries', locale) }}</div>
                <div class="tkt-filter-bar__sub">{{ t('admin_audit_logs_recent_entries_intro', locale) }}</div>
            </div>
            <div>
                <button
                    class="ui-button ui-button--ghost ui-button--sm"
                    hx-get="/admin/audit-logs/table"
                    hx-target="#audit-logs-table"
                    hx-swap="outerHTML"
                >{{ t('refresh', locale) }}</button>
            </div>
        </div>
    </div>
    <div class="ng-data-card__body--flush">
        {% include 'admin/audit-logs/_table.html.twig' with { logs: logs } %}
    </div>
</section>

{% endblock %}
