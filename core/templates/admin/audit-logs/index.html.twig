{% extends 'admin/base.html.twig' %}

{% set pageTitle = t('admin_audit_logs_heading', page_locale()) %}
{% set pageSubtitle = t('admin_audit_logs_intro', page_locale()) %}
{% set activeNav = 'audit-logs' %}

{% block content %}
<div class="flex flex-col gap-6">
    <div class="ng-kpi-row">
        <div class="ng-kpi-box">
            <div class="ng-kpi-box__label">{{ t('admin_audit_logs_total_entries', page_locale()) }}</div>
            <div class="ng-kpi-box__value ng-kpi-box__value--primary">{{ summary.total }}</div>
        </div>
        <div class="ng-kpi-box">
            <div class="ng-kpi-box__label">{{ t('admin_audit_logs_latest_activity', page_locale()) }}</div>
            <div class="ng-kpi-box__value ng-kpi-box__value--info">
                {{ summary.latest ? summary.latest|date('Y-m-d H:i') : t('admin_audit_logs_no_activity', page_locale()) }}
            </div>
        </div>
        <div class="ng-kpi-box">
            <div class="ng-kpi-box__label">{{ t('admin_audit_logs_retention', page_locale()) }}</div>
            <div class="ng-kpi-box__value ng-kpi-box__value--success">{{ t('admin_audit_logs_retention_value', page_locale()) }}</div>
        </div>
    </div>

    <div class="ng-data-card" id="audit-logs-table">
        <div class="ng-data-card__header">
            <div>
                <h2 class="ng-data-card__title">{{ t('admin_audit_logs_recent_entries', page_locale()) }}</h2>
                <p class="ng-data-card__sub">{{ t('admin_audit_logs_recent_entries_intro', page_locale()) }}</p>
            </div>
            <div class="ng-data-card__actions">
                <button
                    class="ui-button ui-button--ghost ui-button--sm"
                    hx-get="/admin/audit-logs/table"
                    hx-target="#audit-logs-table"
                    hx-swap="outerHTML"
                >{{ t('refresh', page_locale()) }}</button>
            </div>
        </div>
        <div class="ng-data-card__body--flush">
            {% include 'admin/audit-logs/_table.html.twig' with { logs: logs } %}
        </div>
    </div>
</div>
{% endblock %}
