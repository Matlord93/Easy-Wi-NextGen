<div id="audit-logs-table"
    hx-get="/admin/audit-logs/table"
    hx-trigger="every 60s"
    hx-swap="outerHTML">
<div class="cust-ws-table-wrap">
    <table class="cust-table">
        <thead>
        <tr>
            <th>{{ t('admin_audit_logs_table_timestamp', page_locale()) }}</th>
            <th>{{ t('admin_audit_logs_table_actor', page_locale()) }}</th>
            <th>{{ t('admin_audit_logs_table_action', page_locale()) }}</th>
            <th>{{ t('admin_audit_logs_table_payload', page_locale()) }}</th>
            <th>{{ t('admin_audit_logs_table_hash_chain', page_locale()) }}</th>
        </tr>
        </thead>
        <tbody>
        {% for log in logs %}
            <tr>
                <td style="white-space:nowrap;font-size:12px;color:var(--color-text-muted,#64748b);">{{ log.createdAt|date('Y-m-d H:i') }}</td>
                <td>
                    <div style="font-weight:600;font-size:13px;">{{ log.actor }}</div>
                    <div style="font-size:11px;color:var(--color-text-muted,#64748b);">{{ log.actorType ?? t('admin_audit_logs_system_actor', page_locale()) }}</div>
                </td>
                <td style="font-weight:600;font-size:13px;">{{ t('audit_event_' ~ log.action|replace({'.': '_'}), page_locale()) }}</td>
                <td>
                    <details style="font-size:12px;">
                        <summary style="cursor:pointer;color:#6366f1;font-weight:600;">{{ t('admin_audit_logs_view_payload', page_locale()) }}</summary>
                        <pre style="margin-top:6px;white-space:pre-wrap;background:var(--ng-surface-soft);border:1px solid var(--ng-border);border-radius:4px;padding:8px;font-size:11px;color:var(--color-text-muted,#64748b);">{{ log.payload }}</pre>
                    </details>
                </td>
                <td style="font-family:monospace;font-size:11px;color:var(--color-text-muted,#64748b);">
                    <div>
                        <span style="color:var(--ng-text-muted);">{{ t('admin_audit_logs_hash_prev', page_locale()) }}</span>
                        {{ log.hashPrev ? log.hashPrev|slice(0, 12) ~ '…' : t('admin_audit_logs_hash_genesis', page_locale()) }}
                    </div>
                    <div style="margin-top:2px;">
                        <span style="color:var(--ng-text-muted);">{{ t('admin_audit_logs_hash_curr', page_locale()) }}</span>
                        {{ log.hashCurrent|slice(0, 12) ~ '…' }}
                    </div>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="5" class="cust-table__empty">{{ t('admin_audit_logs_empty', page_locale()) }}</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
</div>
</div>{# end #audit-logs-table #}
