{% extends 'admin/base.html.twig' %}

{% set pageTitle = t('admin_gdpr_retention_heading', page_locale()) %}
{% set pageSubtitle = t('admin_gdpr_retention_intro', page_locale()) %}
{% set activeNav = 'gdpr-retention' %}

{% block content %}
<div class="flex flex-col gap-6">

    {% if saved %}
        <div class="ng-alert ng-alert--success">{{ t('admin_gdpr_retention_saved', page_locale()) }}</div>
    {% endif %}

    <div class="ng-data-card">
        <div class="ng-data-card__header">
            <div>
                <h2 class="ng-data-card__title">{{ t('admin_gdpr_retention_windows_title', page_locale()) }}</h2>
                <p class="ng-data-card__sub">{{ t('admin_gdpr_retention_windows_intro', page_locale()) }}</p>
            </div>
            <div class="ng-data-card__actions">
                <span class="text-xs text-slate-600">{{ t('admin_gdpr_retention_last_update', page_locale()) }} {{ policy.updatedAt ? policy.updatedAt|date('Y-m-d H:i') : '—' }}</span>
            </div>
        </div>
        <div class="ng-data-card__body">
            <form method="post" action="/admin/gdpr/retention" class="flex flex-col gap-6">
                <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                    <div class="form-field">
                        <label class="form-label">{{ t('admin_gdpr_retention_tickets', page_locale()) }}</label>
                        <input type="number" min="1" name="ticket_retention_days" value="{{ policy.ticketRetentionDays }}" class="form-input">
                    </div>
                    <div class="form-field">
                        <label class="form-label">{{ t('admin_gdpr_retention_logs', page_locale()) }}</label>
                        <input type="number" min="1" name="log_retention_days" value="{{ policy.logRetentionDays }}" class="form-input">
                    </div>
                    <div class="form-field">
                        <label class="form-label">{{ t('admin_gdpr_retention_sessions', page_locale()) }}</label>
                        <input type="number" min="1" name="session_retention_days" value="{{ policy.sessionRetentionDays }}" class="form-input">
                    </div>
                </div>
                <div style="border-radius:0.5rem;background:var(--ng-surface-soft);border:1px solid var(--ng-border);padding:0.75rem 1rem;font-size:0.75rem;color:var(--ng-text-muted);">
                    {{ t('admin_gdpr_retention_command', page_locale())|raw }}
                </div>
                <div class="flex justify-end">
                    <button class="ui-button ui-button--primary">{{ t('admin_gdpr_retention_save', page_locale()) }}</button>
                </div>
            </form>
        </div>
    </div>

</div>
{% endblock %}
