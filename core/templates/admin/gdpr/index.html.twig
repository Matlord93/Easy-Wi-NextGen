{% extends 'admin/base.html.twig' %}

{% set pageTitle = t('admin_gdpr_overview_heading', page_locale()) %}
{% set pageSubtitle = t('admin_gdpr_overview_intro', page_locale()) %}
{% set activeNav = 'gdpr' %}

{% block content %}
<div class="flex flex-col gap-6">

    <div class="ng-data-card">
        <div class="ng-data-card__header">
            <div>
                <h2 class="ng-data-card__title">{{ t('admin_gdpr_inventory_title', page_locale()) }}</h2>
                <p class="ng-data-card__sub">{{ t('admin_gdpr_inventory_intro', page_locale()) }}</p>
            </div>
        </div>
        <div class="ng-data-card__body--flush">
            <div class="cust-ws-table-wrap">
                <table class="cust-table">
                    <thead>
                        <tr>
                            <th>Entity</th>
                            <th>PII</th>
                            <th>Export</th>
                            <th>Delete/Anonymize</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for item in inventory %}
                            <tr>
                                <td class="font-medium text-slate-900">{{ item.entity }}</td>
                                <td>{{ item.pii_fields|join(', ') }}</td>
                                <td>{{ item.export_scope }}</td>
                                <td>{{ item.deletion_strategy }}</td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="4" class="cust-table__empty">No inventory entries.</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="ng-layout-2col--equal" style="grid-template-columns: repeat(3, 1fr);">
        <div class="ng-data-card">
            <div class="ng-data-card__header">
                <div>
                    <h2 class="ng-data-card__title">{{ t('admin_gdpr_overview_retention_title', page_locale()) }}</h2>
                </div>
            </div>
            <div class="ng-data-card__body">
                <ul class="flex flex-col gap-2 text-sm text-slate-700">
                    <li>{{ t('admin_gdpr_overview_retention_tickets', page_locale()) }}: <strong>{{ policy.ticketRetentionDays }}d</strong></li>
                    <li>{{ t('admin_gdpr_overview_retention_logs', page_locale()) }}: <strong>{{ policy.logRetentionDays }}d</strong></li>
                    <li>{{ t('admin_gdpr_overview_retention_sessions', page_locale()) }}: <strong>{{ policy.sessionRetentionDays }}d</strong></li>
                </ul>
                <a class="ui-button ui-button--ghost ui-button--sm mt-4 inline-flex" href="/admin/gdpr/retention">{{ t('admin_gdpr_overview_retention_link', page_locale()) }}</a>
            </div>
        </div>

        <div class="ng-data-card">
            <div class="ng-data-card__header">
                <div>
                    <h2 class="ng-data-card__title">{{ t('admin_gdpr_overview_export_title', page_locale()) }}</h2>
                </div>
            </div>
            <div class="ng-data-card__body">
                <p class="text-sm text-slate-700 mb-3">{{ t('admin_gdpr_overview_export_intro', page_locale()) }}</p>
                <code class="block rounded bg-slate-100 px-3 py-2 text-xs mb-2">php bin/console app:gdpr:exports:process --limit=25</code>
                <code class="block rounded bg-slate-100 px-3 py-2 text-xs">php bin/console app:gdpr:exports:cleanup --limit=100</code>
            </div>
        </div>

        <div class="ng-data-card">
            <div class="ng-data-card__header">
                <div>
                    <h2 class="ng-data-card__title">{{ t('admin_gdpr_overview_delete_title', page_locale()) }}</h2>
                </div>
            </div>
            <div class="ng-data-card__body">
                <p class="text-sm text-slate-700 mb-3">{{ t('admin_gdpr_overview_delete_intro', page_locale()) }}</p>
                <ul class="list-disc pl-5 text-sm text-slate-700 flex flex-col gap-1">
                    <li>{{ t('admin_gdpr_overview_delete_mode_account', page_locale()) }}</li>
                    <li>{{ t('admin_gdpr_overview_delete_mode_anonymize', page_locale()) }}</li>
                </ul>
            </div>
        </div>
    </div>

    <div class="ng-data-card">
        <div class="ng-data-card__header">
            <div>
                <h2 class="ng-data-card__title">{{ t('admin_gdpr_overview_audit_title', page_locale()) }}</h2>
                <p class="ng-data-card__sub">{{ t('admin_gdpr_overview_audit_intro', page_locale()) }}</p>
            </div>
        </div>
        <div class="ng-data-card__body--flush">
            <div class="cust-ws-table-wrap">
                <table class="cust-table">
                    <thead>
                        <tr>
                            <th>Time</th>
                            <th>Action</th>
                            <th>Actor</th>
                            <th>Payload</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for entry in auditEntries %}
                            <tr>
                                <td>{{ entry.createdAt|date('Y-m-d H:i:s') }}</td>
                                <td class="font-medium text-slate-900">{{ entry.action }}</td>
                                <td>{{ entry.actor ? entry.actor.email : 'system' }}</td>
                                <td class="text-xs"><pre class="whitespace-pre-wrap">{{ entry.payload|json_encode(constant('JSON_PRETTY_PRINT')) }}</pre></td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="4" class="cust-table__empty">No GDPR audit events yet.</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>
{% endblock %}
