{% extends 'admin/base.html.twig' %}

{% block content %}
<div class="space-y-6">
    <div>
        <h1 class="text-2xl font-semibold">{{ t('admin_gdpr_overview_heading', page_locale()) }}</h1>
        <p class="text-sm text-slate-700">{{ t('admin_gdpr_overview_intro', page_locale()) }}</p>
    </div>

    <section class="rounded-xl border border-slate-200 bg-white">
        <div class="border-b border-slate-200 px-5 py-4">
            <h2 class="text-lg font-semibold">{{ t('admin_gdpr_inventory_title', page_locale()) }}</h2>
            <p class="text-sm text-slate-700">{{ t('admin_gdpr_inventory_intro', page_locale()) }}</p>
        </div>
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-slate-200 text-sm">
                <thead class="bg-slate-50 text-xs uppercase tracking-wide text-slate-600">
                <tr>
                    <th class="px-4 py-3 text-left">Entity</th>
                    <th class="px-4 py-3 text-left">PII</th>
                    <th class="px-4 py-3 text-left">Export</th>
                    <th class="px-4 py-3 text-left">Delete/Anonymize</th>
                </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                {% for item in inventory %}
                    <tr>
                        <td class="px-4 py-3 font-medium text-slate-900">{{ item.entity }}</td>
                        <td class="px-4 py-3 text-slate-700">{{ item.pii_fields|join(', ') }}</td>
                        <td class="px-4 py-3 text-slate-700">{{ item.export_scope }}</td>
                        <td class="px-4 py-3 text-slate-700">{{ item.deletion_strategy }}</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </section>

    <section class="grid grid-cols-1 gap-4 lg:grid-cols-3">
        <article class="rounded-xl border border-slate-200 bg-white px-5 py-4">
            <h3 class="text-base font-semibold">{{ t('admin_gdpr_overview_retention_title', page_locale()) }}</h3>
            <ul class="mt-3 space-y-2 text-sm text-slate-700">
                <li>{{ t('admin_gdpr_overview_retention_tickets', page_locale()) }}: <strong>{{ policy.ticketRetentionDays }}d</strong></li>
                <li>{{ t('admin_gdpr_overview_retention_logs', page_locale()) }}: <strong>{{ policy.logRetentionDays }}d</strong></li>
                <li>{{ t('admin_gdpr_overview_retention_sessions', page_locale()) }}: <strong>{{ policy.sessionRetentionDays }}d</strong></li>
            </ul>
            <a class="mt-3 inline-flex text-xs font-semibold text-indigo-600" href="/admin/gdpr/retention">{{ t('admin_gdpr_overview_retention_link', page_locale()) }}</a>
        </article>

        <article class="rounded-xl border border-slate-200 bg-white px-5 py-4">
            <h3 class="text-base font-semibold">{{ t('admin_gdpr_overview_export_title', page_locale()) }}</h3>
            <p class="mt-2 text-sm text-slate-700">{{ t('admin_gdpr_overview_export_intro', page_locale()) }}</p>
            <code class="mt-3 block rounded bg-slate-100 px-3 py-2 text-xs">php bin/console app:gdpr:exports:process --limit=25</code>
            <code class="mt-2 block rounded bg-slate-100 px-3 py-2 text-xs">php bin/console app:gdpr:exports:cleanup --limit=100</code>
        </article>

        <article class="rounded-xl border border-slate-200 bg-white px-5 py-4">
            <h3 class="text-base font-semibold">{{ t('admin_gdpr_overview_delete_title', page_locale()) }}</h3>
            <p class="mt-2 text-sm text-slate-700">{{ t('admin_gdpr_overview_delete_intro', page_locale()) }}</p>
            <ul class="mt-3 list-disc pl-5 text-sm text-slate-700">
                <li>{{ t('admin_gdpr_overview_delete_mode_account', page_locale()) }}</li>
                <li>{{ t('admin_gdpr_overview_delete_mode_anonymize', page_locale()) }}</li>
            </ul>
        </article>
    </section>

    <section class="rounded-xl border border-slate-200 bg-white">
        <div class="border-b border-slate-200 px-5 py-4">
            <h2 class="text-lg font-semibold">{{ t('admin_gdpr_overview_audit_title', page_locale()) }}</h2>
            <p class="text-sm text-slate-700">{{ t('admin_gdpr_overview_audit_intro', page_locale()) }}</p>
        </div>
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-slate-200 text-sm">
                <thead class="bg-slate-50 text-xs uppercase tracking-wide text-slate-600">
                <tr>
                    <th class="px-4 py-3 text-left">Time</th>
                    <th class="px-4 py-3 text-left">Action</th>
                    <th class="px-4 py-3 text-left">Actor</th>
                    <th class="px-4 py-3 text-left">Payload</th>
                </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                {% for entry in auditEntries %}
                    <tr>
                        <td class="px-4 py-3 text-slate-700">{{ entry.createdAt|date('Y-m-d H:i:s') }}</td>
                        <td class="px-4 py-3 text-slate-900 font-medium">{{ entry.action }}</td>
                        <td class="px-4 py-3 text-slate-700">{{ entry.actor ? entry.actor.email : 'system' }}</td>
                        <td class="px-4 py-3 text-xs text-slate-600"><pre class="whitespace-pre-wrap">{{ entry.payload|json_encode(constant('JSON_PRETTY_PRINT')) }}</pre></td>
                    </tr>
                {% else %}
                    <tr><td class="px-4 py-5 text-slate-600" colspan="4">No GDPR audit events yet.</td></tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </section>
</div>
{% endblock %}
