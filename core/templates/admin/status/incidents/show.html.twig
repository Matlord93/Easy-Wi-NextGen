{% extends 'admin/base.html.twig' %}

{% set pageTitle = incident.title %}
{% set activeNav = 'status' %}

{% block content %}
{% set locale = page_locale() %}
{% set statusBadgeMap = {
    'investigating': 'ui-badge--warning',
    'identified': 'ui-badge--info',
    'monitoring': 'ui-badge--info',
    'resolved': 'ui-badge--success'
} %}
<div style="display:flex;flex-direction:column;gap:20px;">

  {% include 'admin/status/_nav.html.twig' %}

  <section class="ng-card" style="overflow:hidden;">
    <div class="tkt-hero">
      <div class="tkt-hero__inner">
        <div>
          <div class="tkt-hero__pill"><span class="tkt-hero__pill-dot"></span> Status</div>
          <h1 class="tkt-hero__title" style="margin-top:10px;">{{ incident.title }}</h1>
          {% if incident.message %}
            <p class="tkt-hero__sub">{{ incident.message }}</p>
          {% endif %}
        </div>
        <div style="display:flex;align-items:center;gap:8px;flex-shrink:0;">
          <span class="ui-badge {{ statusBadgeMap[incident.status]|default('ui-badge--neutral') }}">
            {{ incident.status|capitalize }}
          </span>
          <span class="ui-badge {{ incident.visible_public ? 'ui-badge--info' : 'ui-badge--neutral' }}">
            {{ incident.visible_public ? 'Public' : 'Hidden' }}
          </span>
        </div>
      </div>
    </div>
    <div style="padding:14px 16px;border-top:1px solid var(--ng-border);background:var(--ng-surface-soft);">
      <a href="/admin/status/incidents" class="ui-button ui-button--ghost ui-button--sm">&larr; Back to incidents</a>
    </div>
  </section>

  <div style="display:grid;grid-template-columns:2fr 1fr;gap:20px;align-items:start;">

    <div class="ng-data-card">
      <div class="ng-data-card__header">
        <div>
          <h2 class="ng-data-card__title">Timeline</h2>
        </div>
      </div>
      <div id="incident-updates" hx-trigger="incident-updates-changed from:body" hx-get="/admin/status/incidents/{{ incident.id }}/updates" hx-swap="innerHTML">
        {% include 'admin/status/incidents/_updates.html.twig' with { updates: updates } %}
      </div>
    </div>

    <div class="ng-data-card" id="incident-update-form">
      {% include 'admin/status/incidents/_update_form.html.twig' with { updateForm: updateForm, statuses: statuses } %}
    </div>

  </div>

</div>
{% endblock %}
