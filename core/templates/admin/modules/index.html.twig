{% extends 'admin/base.html.twig' %}

{% set pageTitle = t('admin_modules_heading', page_locale()) %}
{% set pageSubtitle = t('admin_modules_intro', page_locale()) %}
{% set activeNav = 'modules' %}

{% block content %}
<div class="flex flex-col gap-6">

    <div class="ng-data-card">
        <div class="ng-data-card__header">
            <div>
                <h2 class="ng-data-card__title">{{ t('admin_modules_heading', page_locale()) }}</h2>
                <p class="ng-data-card__sub">{{ t('admin_modules_intro', page_locale()) }}</p>
            </div>
        </div>
        <div class="ng-data-card__body--flush">
            <div class="cust-ws-table-wrap">
                <table class="cust-table">
                    <thead>
                        <tr>
                            <th>{{ t('admin_modules_table_module', page_locale()) }}</th>
                            <th>{{ t('admin_modules_table_version', page_locale()) }}</th>
                            <th>{{ t('admin_modules_table_status', page_locale()) }}</th>
                            <th>{{ t('admin_modules_table_last_updated', page_locale()) }}</th>
                            <th>{{ t('admin_modules_table_action', page_locale()) }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for module in modules %}
                            <tr>
                                <td>
                                    <div class="font-medium text-slate-900">{{ module.label }}</div>
                                    <div class="text-xs text-slate-500">{{ module.description }}</div>
                                </td>
                                <td>{{ module.version }}</td>
                                <td>
                                    {% if module.enabled %}
                                        <span class="ui-badge ui-badge--success">{{ t('admin_modules_enabled', page_locale()) }}</span>
                                    {% else %}
                                        <span class="ui-badge ui-badge--neutral">{{ t('admin_modules_disabled', page_locale()) }}</span>
                                    {% endif %}
                                </td>
                                <td>{{ module.updatedAt ? module.updatedAt|date('Y-m-d H:i') : '—' }}</td>
                                <td>
                                    <form method="post" action="/admin/modules/{{ module.key }}/toggle">
                                        <input type="hidden" name="enabled" value="{{ module.enabled ? 'false' : 'true' }}">
                                        <input type="hidden" name="_token" value="{{ csrf_token('module_toggle_' ~ module.key) }}">
                                        {% if module.enabled %}
                                            <button class="ui-button ui-button--danger ui-button--sm">{{ t('disable', page_locale()) }}</button>
                                        {% else %}
                                            <button class="ui-button ui-button--primary ui-button--sm">{{ t('enable', page_locale()) }}</button>
                                        {% endif %}
                                    </form>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="5" class="cust-table__empty">{{ t('admin_modules_no_modules', page_locale()) }}</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>
{% endblock %}
