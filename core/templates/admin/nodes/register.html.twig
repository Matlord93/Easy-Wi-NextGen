{% extends 'admin/base.html.twig' %}

{% set pageTitle = t('admin_nodes_register_title', page_locale()) %}
{% set activeNav = 'nodes' %}

{% block content %}
{% set locale = page_locale() %}
<div style="display:flex;flex-direction:column;gap:20px;">

  <section class="ng-card" style="overflow:hidden;">
    <div class="tkt-hero">
      <div class="tkt-hero__inner">
        <div>
          <div class="tkt-hero__pill"><span class="tkt-hero__pill-dot"></span> Nodes</div>
          <h1 class="tkt-hero__title" style="margin-top:10px;">{{ t('admin_nodes_register_title', locale) }}</h1>
          <p class="tkt-hero__sub">{{ t('admin_nodes_register_intro', locale) }}</p>
        </div>
      </div>
    </div>
    <div style="padding:14px 16px;border-top:1px solid var(--ng-border);background:var(--ng-surface-soft);">
      <a class="ui-button ui-button--ghost ui-button--sm" href="/admin/nodes">{{ t('admin_nodes_back', locale) }}</a>
    </div>
  </section>

  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(320px,1fr));gap:20px;">

    <div class="ng-data-card">
      <div class="ng-data-card__header">
        <div>
          <h2 class="ng-data-card__title">{{ t('admin_nodes_agent_details', locale) }}</h2>
          <p class="ng-data-card__sub">{{ t('admin_nodes_agent_details_intro', locale) }}</p>
        </div>
      </div>
      <div class="ng-data-card__body">
        {% if form.errors is not empty %}
          <div class="ng-alert ng-alert--danger" style="margin-bottom:16px;">
            <ul style="margin:0;padding-left:18px;">
              {% for error in form.errors %}
                <li>{{ error }}</li>
              {% endfor %}
            </ul>
          </div>
        {% endif %}

        <form method="post" style="display:flex;flex-direction:column;gap:16px;">
          <div class="form-field">
            <label class="form-label" for="agent_id">{{ t('admin_nodes_agent_id', locale) }}</label>
            <input
              id="agent_id"
              name="agent_id"
              type="text"
              value="{{ form.agent_id }}"
              placeholder="node-eu-01"
              class="form-input"
            >
            <p style="margin-top:4px;font-size:12px;color:var(--ng-text-muted);">{{ t('admin_nodes_agent_id_hint', locale) }}</p>
          </div>
          <div class="form-field">
            <label class="form-label" for="name">{{ t('admin_nodes_display_name', locale) }}</label>
            <input
              id="name"
              name="name"
              type="text"
              value="{{ form.name }}"
              placeholder="Web Node Frankfurt"
              class="form-input"
            >
          </div>
          <div>
            <button class="ui-button ui-button--primary" type="submit">{{ t('admin_nodes_create_agent', locale) }}</button>
          </div>
        </form>
      </div>
    </div>

    <div class="ng-data-card">
      <div class="ng-data-card__header">
        <div>
          <h2 class="ng-data-card__title">{{ t('admin_nodes_agent_config', locale) }}</h2>
          <p class="ng-data-card__sub">{{ t('admin_nodes_agent_config_intro', locale) }}</p>
        </div>
      </div>
      <div class="ng-data-card__body">
        {% if config %}
          <div class="ng-alert ng-alert--success" style="margin-bottom:16px;">
            {{ t('admin_nodes_agent_registered', locale)|replace({'%id%': config.agent_id}) }}
          </div>
          <div style="margin-bottom:16px;">
            <p style="font-size:11px;font-weight:600;text-transform:uppercase;color:var(--ng-text-muted);margin-bottom:6px;">/etc/easywi/agent.conf</p>
            <pre style="white-space:pre-wrap;border-radius:6px;border:1px solid var(--ng-border);background:#0f172a;padding:12px 16px;font-size:12px;color:#e2e8f0;">agent_id={{ config.agent_id }}
secret={{ config.secret }}
api_url={{ config.api_url }}
heartbeat_interval=60s
poll_interval=30s</pre>
          </div>
          <div>
            <p style="font-weight:600;font-size:13px;color:var(--ng-text);margin-bottom:6px;">{{ t('admin_nodes_start_agent', locale) }}</p>
            <pre style="white-space:pre-wrap;border-radius:6px;border:1px solid var(--ng-border);background:var(--ng-surface-soft);padding:12px 16px;font-size:12px;color:var(--ng-text-muted);">./easywi-agent -config /etc/easywi/agent.conf</pre>
          </div>
        {% else %}
          <div class="ng-alert ng-alert--warning">
            {{ t('admin_nodes_config_pending', locale) }}
          </div>
        {% endif %}
      </div>
    </div>

  </div>

</div>
{% endblock %}
