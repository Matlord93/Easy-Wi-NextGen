{% extends 'admin/base.html.twig' %}

{% set pageTitle = t('admin_port_ranges_title', page_locale()) %}
{% set activeNav = 'nodes' %}

{% block content %}
{% set locale = page_locale() %}
<div style="display:flex;flex-direction:column;gap:20px;">

  <section class="ng-card" style="overflow:hidden;">
    <div class="tkt-hero">
      <div class="tkt-hero__inner">
        <div>
          <div class="tkt-hero__pill"><span class="tkt-hero__pill-dot"></span> Nodes</div>
          <h1 class="tkt-hero__title" style="margin-top:10px;">{{ t('admin_port_ranges_title', locale) }}</h1>
          <p class="tkt-hero__sub">{{ t('admin_port_ranges_intro', locale) }}</p>
          <p style="margin-top:6px;font-size:12px;color:var(--color-text-muted,#64748b);">
            {{ t('admin_port_ranges_node_label', locale)|replace({'%node%': node.name ?? node.id}) }}
          </p>
        </div>
      </div>
    </div>
    <div style="padding:14px 16px;border-top:1px solid var(--ng-border);background:var(--ng-surface-soft);">
      <a href="/admin/nodes" class="ui-button ui-button--ghost ui-button--sm">{{ t('admin_port_ranges_back', locale) }}</a>
    </div>
  </section>

  {% if noticeKey or errorKey or warning %}
    {% if noticeKey %}
      <div class="ng-alert ng-alert--success">{{ t(noticeKey, locale) }}</div>
    {% endif %}
    {% if warning %}
      <div class="ng-alert ng-alert--warning">
        {{ t(warning.key, locale)|replace({'%count%': warning.count}) }}
      </div>
    {% endif %}
    {% if errorKey %}
      <div class="ng-alert ng-alert--danger">{{ t(errorKey, locale) }}</div>
    {% endif %}
  {% endif %}

  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(320px,1fr));gap:20px;align-items:start;">

    <div class="ng-data-card">
      <div class="ng-data-card__header">
        <div>
          <h2 class="ng-data-card__title">{{ t('admin_port_ranges_list_title', locale) }}</h2>
          <p class="ng-data-card__sub">{{ t('admin_port_ranges_list_intro', locale) }}</p>
        </div>
      </div>

      {% for range in ranges %}
        <form id="port-range-{{ range.id }}" method="post" action="/admin/nodes/{{ node.id }}/port-ranges/{{ range.id }}/update"></form>
      {% endfor %}

      <div class="cust-ws-table-wrap">
        <table class="cust-table">
          <thead>
            <tr>
              <th>{{ t('admin_port_ranges_purpose', locale) }}</th>
              <th>{{ t('admin_port_ranges_protocol', locale) }}</th>
              <th>{{ t('admin_port_ranges_start_port', locale) }}</th>
              <th>{{ t('admin_port_ranges_end_port', locale) }}</th>
              <th>{{ t('admin_port_ranges_enabled', locale) }}</th>
              <th>{{ t('admin_port_ranges_actions', locale) }}</th>
            </tr>
          </thead>
          <tbody>
            {% for range in ranges %}
              <tr>
                <td>
                  <input form="port-range-{{ range.id }}" name="purpose" value="{{ range.purpose }}" class="form-input" style="padding:4px 8px;font-size:12px;" />
                </td>
                <td>
                  <select form="port-range-{{ range.id }}" name="protocol" class="form-input" style="padding:4px 8px;font-size:12px;">
                    {% for protocol in protocols %}
                      <option value="{{ protocol }}" {% if protocol == range.protocol %}selected{% endif %}>{{ protocol|upper }}</option>
                    {% endfor %}
                  </select>
                </td>
                <td>
                  <input form="port-range-{{ range.id }}" type="number" min="1" max="65535" step="1" name="start_port" value="{{ range.start_port }}" class="form-input" style="padding:4px 8px;font-size:12px;width:80px;" />
                </td>
                <td>
                  <input form="port-range-{{ range.id }}" type="number" min="1" max="65535" step="1" name="end_port" value="{{ range.end_port }}" class="form-input" style="padding:4px 8px;font-size:12px;width:80px;" />
                </td>
                <td>
                  <label style="display:inline-flex;align-items:center;gap:6px;font-size:13px;cursor:pointer;">
                    <input form="port-range-{{ range.id }}" type="checkbox" name="enabled" value="1" {% if range.enabled %}checked{% endif %} />
                    <span>{{ range.enabled ? t('admin_port_ranges_enabled_yes', locale) : t('admin_port_ranges_enabled_no', locale) }}</span>
                  </label>
                </td>
                <td style="display:flex;gap:6px;align-items:center;flex-wrap:wrap;">
                  <button form="port-range-{{ range.id }}" type="submit" class="ui-button ui-button--ghost ui-button--sm">
                    {{ t('admin_port_ranges_update_button', locale) }}
                  </button>
                  <form method="post" action="/admin/nodes/{{ node.id }}/port-ranges/{{ range.id }}/delete" style="display:inline;">
                    <button type="submit" class="ui-button ui-button--danger ui-button--sm">
                      {{ t('admin_port_ranges_delete_button', locale) }}
                    </button>
                  </form>
                </td>
              </tr>
            {% else %}
              <tr>
                <td colspan="6" class="cust-table__empty">{{ t('admin_port_ranges_empty', locale) }}</td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </div>

    <aside class="ng-data-card">
      <div class="ng-data-card__header">
        <div>
          <h2 class="ng-data-card__title">{{ t('admin_port_ranges_create_title', locale) }}</h2>
          <p class="ng-data-card__sub">{{ t('admin_port_ranges_create_intro', locale) }}</p>
        </div>
      </div>
      <div class="ng-data-card__body">
        <form method="post" action="/admin/nodes/{{ node.id }}/port-ranges" style="display:flex;flex-direction:column;gap:14px;">
          <div class="form-field">
            <label class="form-label" for="port-range-purpose">{{ t('admin_port_ranges_purpose', locale) }}</label>
            <input id="port-range-purpose" name="purpose" value="{{ form.purpose }}" class="form-input" />
          </div>
          <div class="form-field">
            <label class="form-label" for="port-range-protocol">{{ t('admin_port_ranges_protocol', locale) }}</label>
            <select id="port-range-protocol" name="protocol" class="form-input">
              {% for protocol in protocols %}
                <option value="{{ protocol }}" {% if protocol == form.protocol %}selected{% endif %}>{{ protocol|upper }}</option>
              {% endfor %}
            </select>
          </div>
          <div class="form-field">
            <label class="form-label" for="port-range-start">{{ t('admin_port_ranges_start_port', locale) }}</label>
            <input id="port-range-start" type="number" min="1" max="65535" step="1" name="start_port" value="{{ form.start_port }}" class="form-input" />
          </div>
          <div class="form-field">
            <label class="form-label" for="port-range-end">{{ t('admin_port_ranges_end_port', locale) }}</label>
            <input id="port-range-end" type="number" min="1" max="65535" step="1" name="end_port" value="{{ form.end_port }}" class="form-input" />
          </div>
          <div class="form-field">
            <label style="display:inline-flex;align-items:center;gap:8px;font-size:13px;cursor:pointer;">
              <input type="checkbox" name="enabled" value="1" {% if form.enabled %}checked{% endif %} />
              <span class="form-label" style="margin:0;">{{ t('admin_port_ranges_enabled_label', locale) }}</span>
            </label>
          </div>
          <div>
            <button type="submit" class="ui-button ui-button--primary">{{ t('admin_port_ranges_create_button', locale) }}</button>
          </div>
        </form>
      </div>
    </aside>

  </div>

</div>
{% endblock %}
