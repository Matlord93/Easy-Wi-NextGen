{% extends 'admin/base.html.twig' %}

{% set pageTitle = t('admin_nodes_title', page_locale()) %}
{% set pageSubtitle = t('admin_nodes_intro', page_locale()) %}
{% set activeNav = 'nodes' %}

{% block content %}
{% set selectedNode = selectedNode ?? nodes|first %}
{% set statusMap = {
    'online': 'success',
    'stale': 'warning',
    'offline': 'danger',
    'provisioning': 'primary',
    'maintenance': 'neutral'
} %}

{# ── Hero ── #}
<div class="ng-card" style="overflow:hidden;">
    <div class="tkt-hero">
        <div class="tkt-hero__inner">
            <div style="display:flex;flex-direction:column;gap:16px;">
                <div>
                    <div class="tkt-hero__pill">
                        <span class="tkt-hero__pill-dot"></span>
                        {{ t('admin_nodes_title', page_locale()) }}
                    </div>
                    <h1 class="tkt-hero__title" style="margin-top:10px;">{{ t('admin_nodes_title', page_locale()) }}</h1>
                    <p class="tkt-hero__sub">{{ t('admin_nodes_intro', page_locale()) }}</p>
                    <div class="tkt-hero__actions" style="margin-top:10px;">
                        {% if summary.latestVersion %}
                            <span class="ui-badge ui-badge--info">
                                {{ t('admin_nodes_channel', page_locale())|replace({'%channel%': updateChannel|upper}) }} · {{ summary.latestVersion }}
                            </span>
                            <span class="ui-badge ui-badge--warning">
                                {{ t('admin_nodes_updates_available', page_locale())|replace({'%count%': summary.updates}) }}
                            </span>
                        {% else %}
                            <span class="ui-badge ui-badge--neutral">
                                {{ t('admin_nodes_release_unavailable', page_locale()) }}
                            </span>
                        {% endif %}
                        <button
                            class="ui-button ui-button--ghost ui-button--sm"
                            hx-post="/admin/nodes/update"
                            hx-target="#nodes-table-wrap"
                            hx-swap="innerHTML"
                        >{{ t('admin_nodes_update_agents', page_locale()) }}</button>
                        <a href="/admin/nodes/register" class="ui-button ui-button--ghost ui-button--sm">{{ t('admin_nodes_register_button', page_locale()) }}</a>
                        <button
                            class="ui-button ui-button--primary ui-button--sm"
                            hx-post="/admin/nodes/provision"
                            hx-target="#nodes-table-wrap"
                            hx-swap="innerHTML"
                            hx-confirm="{{ t('admin_nodes_register', page_locale()) }}"
                        >{{ t('admin_nodes_provision', page_locale()) }}</button>
                    </div>
                    <p class="tkt-hero__sub" style="font-size: 0.75rem; margin-top: 0.5rem">
                        {{ t('admin_nodes_manual_register_hint', page_locale()) }}
                    </p>
                </div>
                <div style="display:grid;grid-template-columns:repeat(5,minmax(0,1fr));gap:10px;">
                    <div class="tkt-kpi">
                        <div class="tkt-kpi__value">{{ summary.total }}</div>
                        <div class="tkt-kpi__label">{{ t('admin_nodes_total', page_locale()) }}</div>
                    </div>
                    <div class="tkt-kpi tkt-kpi--resolved">
                        <div class="tkt-kpi__value">{{ summary.online }}</div>
                        <div class="tkt-kpi__label">{{ t('admin_nodes_online', page_locale()) }}</div>
                    </div>
                    <div class="tkt-kpi tkt-kpi--pending">
                        <div class="tkt-kpi__value">{{ summary.stale }}</div>
                        <div class="tkt-kpi__label">{{ t('admin_nodes_stale', page_locale()) }}</div>
                    </div>
                    <div class="tkt-kpi tkt-kpi--open">
                        <div class="tkt-kpi__value">{{ summary.offline }}</div>
                        <div class="tkt-kpi__label">{{ t('admin_nodes_offline', page_locale()) }}</div>
                    </div>
                    <div class="tkt-kpi" style="border-color:rgba(245,158,11,.25);background:rgba(245,158,11,.07);">
                        <div class="tkt-kpi__value" style="color:#fbbf24;">{{ summary.updates }}</div>
                        <div class="tkt-kpi__label">{{ t('admin_nodes_updates_label', page_locale()) }}</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<section class="nodes-page">

    {% if diskProtectCount is defined and diskProtectCount > 0 %}
        <div class="ng-alert ng-alert--danger">
            {{ t('admin_nodes_disk_protect_banner', page_locale())|replace({'%count%': diskProtectCount}) }}
        </div>
    {% endif %}

    <div class="nodes-layout">
        <div class="nodes-card">
            <div class="nodes-card__header">
                <div>
                    <h2 class="nodes-card__title">{{ t('admin_nodes_fleet', page_locale()) }}</h2>
                    <p class="nodes-card__subtitle">{{ t('admin_nodes_fleet_intro', page_locale()) }}</p>
                </div>
                <button
                    class="ui-button ui-button--ghost ui-button--sm"
                    hx-get="/admin/nodes/table"
                    hx-target="#nodes-table-wrap"
                    hx-swap="innerHTML"
                >{{ t('refresh', page_locale()) }}</button>
            </div>
            <div id="nodes-feedback" class="nodes-feedback"></div>
            <div id="nodes-table-wrap">
                {% include 'admin/nodes/_table.html.twig' with { nodes: nodes, updateChannel: updateChannel } %}
            </div>
        </div>

        <aside class="nodes-card">
            <div class="nodes-detail">
                {% if selectedNode %}
                    <form class="nodes-detail-card" method="get" action="/admin/nodes">
                        <div class="nodes-detail-card__header">
                            <div class="nodes-detail-card__title">{{ t('admin_nodes_select_agent', page_locale()) }}</div>
                        </div>
                        <div class="nodes-form-grid">
                            <div class="form-field">
                                <label class="form-label" for="node-select">{{ t('admin_nodes_select_node_label', page_locale()) }}</label>
                                <select id="node-select" name="node" class="form-input">
                                    {% for node in nodes %}
                                        <option value="{{ node.id }}" {% if node.id == selectedNode.id %}selected{% endif %}>
                                            {{ node.name ?? t('admin_nodes_unnamed', page_locale()) }} ({{ node.id }})
                                        </option>
                                    {% endfor %}
                                </select>
                            </div>
                            <div class="form-field">
                                <button class="ui-button ui-button--ghost" type="submit">{{ t('admin_nodes_load_button', page_locale()) }}</button>
                            </div>
                        </div>
                    </form>

                    {% set statusClass = statusMap[selectedNode.status] ?? 'badge--neutral' %}
                    <div class="nodes-detail__header">
                        <h3 class="nodes-detail__title">{{ selectedNode.name ?? t('admin_nodes_unnamed', page_locale()) }}</h3>
                        <div class="nodes-detail__subline">
                            {{ selectedNode.lastHeartbeatIp ?? '—' }}
                        </div>
                        <div class="nodes-detail__badges">
                            <span class="ui-badge ui-badge--{{ statusClass }}">{{ selectedNode.status|title }}</span>
                            {% if selectedNode.updateAvailable is same as(true) %}
                                <span class="ui-badge ui-badge--warning">{{ t('admin_nodes_update_available', page_locale()) }}</span>
                            {% elseif selectedNode.updateAvailable is same as(false) and selectedNode.lastHeartbeatVersion %}
                                <span class="ui-badge ui-badge--success">{{ t('admin_nodes_up_to_date', page_locale()) }}</span>
                            {% endif %}
                            {% if selectedNode.serverUpdate is not null and selectedNode.serverUpdate.updatesAvailable is same as(true) %}
                                <span class="ui-badge ui-badge--warning">{{ t('admin_nodes_server_updates_available', page_locale()) }}</span>
                            {% elseif selectedNode.serverUpdate is not null and selectedNode.serverUpdate.updatesAvailable is same as(false) %}
                                <span class="ui-badge ui-badge--success">{{ t('admin_nodes_server_updates_current', page_locale()) }}</span>
                            {% endif %}
                        </div>
                    </div>

                    <div class="nodes-detail-grid">
                        <div class="nodes-detail-card">
                            <div class="nodes-detail-card__header">
                                <div class="nodes-detail-card__title">{{ t('status', page_locale()) }}</div>
                                {% if selectedNode.rebootRequired is same as(true) %}
                                    <span class="ui-badge ui-badge--warning">{{ t('admin_nodes_reboot_required', page_locale()) }}</span>
                                {% endif %}
                            </div>
                            <div class="nodes-metadata">
                            <div>
                                <div class="nodes-meta__label">{{ t('admin_nodes_table_last_seen', page_locale()) }}</div>
                                <div class="nodes-meta__value">{{ selectedNode.lastSeenAt ? selectedNode.lastSeenAt|date('Y-m-d H:i') : '—' }}</div>
                            </div>
                            <div>
                                <div class="nodes-meta__label">{{ t('admin_nodes_table_version', page_locale()) }}</div>
                                <div class="nodes-meta__value">{{ selectedNode.lastHeartbeatVersion ?? '—' }}</div>
                            </div>
                            <div>
                                <div class="nodes-meta__label">{{ t('admin_nodes_health', page_locale()) }}</div>
                                <div class="nodes-meta__value">{{ selectedNode.health|title }}</div>
                            </div>
                            <div>
                                <div class="nodes-meta__label">{{ t('admin_nodes_os_provider', page_locale()) }}</div>
                                <div class="nodes-meta__value">{{ selectedNode.osProvider ?? '—' }}</div>
                            </div>
                            <div>
                                <div class="nodes-meta__label">{{ t('admin_nodes_server_update_status', page_locale()) }}</div>
                                {% if selectedNode.serverUpdate %}
                                    <div class="nodes-meta__value">
                                        {{ selectedNode.serverUpdate.status|title }}
                                        {% if selectedNode.serverUpdate.resultMessage %}
                                            · {{ selectedNode.serverUpdate.resultMessage }}
                                        {% endif %}
                                    </div>
                                {% else %}
                                    <div class="nodes-meta__value">—</div>
                                {% endif %}
                            </div>
                            </div>
                            <div class="nodes-inline-actions">
                                <button
                                    class="ui-button ui-button--ghost ui-button--sm"
                                    hx-post="/admin/nodes/{{ selectedNode.id }}/reboot-check"
                                    hx-target="#nodes-table-wrap"
                                    hx-swap="innerHTML"
                                >{{ t('admin_nodes_reboot_check', page_locale()) }}</button>
                                <button
                                    class="ui-button ui-button--ghost ui-button--sm"
                                    hx-post="/admin/nodes/{{ selectedNode.id }}/update-check"
                                    hx-target="#nodes-table-wrap"
                                    hx-swap="innerHTML"
                                >{{ t('admin_nodes_update_check', page_locale()) }}</button>
                                <a class="ui-button ui-button--ghost ui-button--sm" href="/admin/nodes/{{ selectedNode.id }}/port-ranges">
                                    {{ t('admin_nodes_port_ranges', page_locale()) }}
                                </a>
                            </div>
                        </div>

                        <div class="nodes-detail-card">
                            <div class="nodes-detail-card__header">
                                <div class="nodes-detail-card__title">{{ t('admin_nodes_services', page_locale()) }}</div>
                            </div>
                            <div class="role-toggle-group">
                                {% if selectedNode.services is empty %}
                                    <span style="font-size:11px;color:var(--ng-text-muted);">{{ t('admin_nodes_services_empty', page_locale()) }}</span>
                                {% else %}
                                    {% for service, state in selectedNode.services %}
                                        <span class="role-chip {{ state == 'active' ? 'role-chip--active' : '' }}">{{ service }} · {{ state }}</span>
                                    {% endfor %}
                                {% endif %}
                            </div>
                        </div>

                        <div class="nodes-detail-card">
                            <div class="nodes-detail-card__header">
                                <div class="nodes-detail-card__title">{{ t('admin_nodes_roles_active', page_locale()) }}</div>
                                <a class="ui-button ui-button--ghost" href="/admin/nodes/{{ selectedNode.id }}/roles">
                                    {{ t('admin_nodes_manage_roles', page_locale()) }}
                                </a>
                            </div>
                            <div class="role-toggle-group">
                                {% if selectedNode.roles is empty %}
                                    <span style="font-size:11px;color:var(--ng-text-muted);">{{ t('admin_nodes_roles_empty', page_locale()) }}</span>
                                {% else %}
                                    {% for role in selectedNode.roles %}
                                        <span class="role-chip role-chip--active">{{ role }}</span>
                                    {% endfor %}
                                {% endif %}
                            </div>
                            <p style="margin-top:12px;font-size:11px;color:var(--ng-text-muted);">{{ t('admin_nodes_roles_manage_hint', page_locale()) }}</p>
                        </div>

                        <form
                            class="nodes-detail-card"
                            hx-post="/admin/nodes/{{ selectedNode.id }}/agent-settings"
                            hx-target="#nodes-table-wrap"
                            hx-swap="innerHTML"
                        >
                            <div class="nodes-detail-card__header">
                                <div class="nodes-detail-card__title">{{ t('admin_nodes_agent_ts_section_title', page_locale()) }}</div>
                                <div class="nodes-inline-actions">
                                    <button class="ui-button ui-button--ghost" type="submit">{{ t('admin_nodes_save', page_locale()) }}</button>
                                    <button
                                        class="ui-button ui-button--ghost ui-button--sm"
                                        type="button"
                                        hx-post="/admin/nodes/{{ selectedNode.id }}/rotate-secret"
                                        hx-target="#nodes-table-wrap"
                                        hx-swap="innerHTML"
                                        hx-confirm="{{ t('admin_nodes_rotate_secret_confirm', page_locale()) }}"
                                    >{{ t('admin_nodes_rotate_secret', page_locale()) }}</button>
                                </div>
                            </div>
                            <div class="nodes-form-grid">
                                <div class="form-field">
                                    <label class="form-label" for="agent-base-url">{{ t('admin_nodes_agent_base_url_label', page_locale()) }}</label>
                                    <input
                                        id="agent-base-url"
                                        name="agent_base_url"
                                        type="text"
                                        value="{{ selectedNode.agent.base_url ?? '' }}"
                                        placeholder="https://agent.example.com"
                                        class="form-input"
                                    >
                                </div>
                                <div class="form-field">
                                    <label class="form-label" for="agent-api-token">{{ t('admin_nodes_agent_api_token_label', page_locale()) }}</label>
                                    <input
                                        id="agent-api-token"
                                        name="agent_api_token"
                                        type="password"
                                        placeholder="{{ selectedNode.agent.token_configured ? '••••••••' : '' }}"
                                        class="form-input"
                                    >
                                    <p style="font-size:11px;color:var(--ng-text-muted);margin-top:4px;">{{ t('admin_nodes_agent_token_hint', page_locale()) }}</p>
                                </div>
                                <div class="form-field">
                                    <label class="form-label" for="agent-job-concurrency">{{ t('admin_nodes_job_concurrency_label', page_locale()) }}</label>
                                    <input
                                        id="agent-job-concurrency"
                                        name="job_concurrency"
                                        type="number"
                                        min="1"
                                        value="{{ selectedNode.agent.job_concurrency ?? 50 }}"
                                        class="form-input"
                                    >
                                    <p style="font-size:11px;color:var(--ng-text-muted);margin-top:4px;">{{ t('admin_nodes_job_concurrency_hint', page_locale()) }}</p>
                                </div>
                                <div class="form-field">
                                    <label class="form-label" for="instance-base-dirs">{{ t('admin_nodes_instance_base_dirs_label', page_locale()) }}</label>
                                    <textarea
                                        id="instance-base-dirs"
                                        name="instance_base_dirs"
                                        rows="3"
                                        class="form-input"
                                        placeholder="/home&#10;/mnt/storage"
                                    >{{ selectedNode.agent.instance_base_dirs|default([])|join("\n") }}</textarea>
                                    <p style="font-size:11px;color:var(--ng-text-muted);margin-top:4px;">{{ t('admin_nodes_instance_base_dirs_hint', page_locale()) }}</p>
                                </div>
                                <label class="role-toggle">
                                    <input type="checkbox" name="clear_agent_token" value="1">
                                    <span>{{ t('admin_nodes_clear_agent_token', page_locale()) }}</span>
                                </label>
                            </div>
                        </form>

                        <form
                            id="node-settings-form"
                            class="nodes-detail-card"
                            hx-post="/admin/nodes/{{ selectedNode.id }}/disk-settings"
                            hx-target="#nodes-table-wrap"
                            hx-swap="innerHTML"
                        >
                            <div class="nodes-detail-card__header">
                                <div class="nodes-detail-card__title">{{ t('admin_nodes_settings_section', page_locale()) }}</div>
                            </div>
                            <div class="nodes-form-grid">
                            <div class="form-field">
                                <label class="form-label" for="disk_scan_interval_seconds">{{ t('admin_nodes_disk_scan_interval', page_locale()) }}</label>
                                <input
                                    id="disk_scan_interval_seconds"
                                    name="disk_scan_interval_seconds"
                                    type="number"
                                    min="60"
                                    value="{{ selectedNode.disk.scan_interval }}"
                                    class="form-input"
                                >
                            </div>
                            <div class="form-field">
                                <label class="form-label" for="disk_warning_percent">{{ t('admin_nodes_disk_warning_percent', page_locale()) }}</label>
                                <input
                                    id="disk_warning_percent"
                                    name="disk_warning_percent"
                                    type="number"
                                    min="1"
                                    max="99"
                                    value="{{ selectedNode.disk.warning_percent }}"
                                    class="form-input"
                                >
                            </div>
                            <div class="form-field">
                                <label class="form-label" for="disk_hard_block_percent">{{ t('admin_nodes_disk_hard_block_percent', page_locale()) }}</label>
                                <input
                                    id="disk_hard_block_percent"
                                    name="disk_hard_block_percent"
                                    type="number"
                                    min="100"
                                    value="{{ selectedNode.disk.hard_block_percent }}"
                                    class="form-input"
                                >
                            </div>
                            <div class="form-field">
                                <label class="form-label" for="node_disk_protection_threshold_percent">{{ t('admin_nodes_disk_protect_threshold', page_locale()) }}</label>
                                <input
                                    id="node_disk_protection_threshold_percent"
                                    name="node_disk_protection_threshold_percent"
                                    type="number"
                                    min="1"
                                    max="20"
                                    value="{{ selectedNode.disk.protect_threshold }}"
                                    class="form-input"
                                >
                            </div>
                            </div>
                            <button class="ui-button ui-button--ghost" type="submit">{{ t('admin_nodes_disk_save', page_locale()) }}</button>
                        </form>

                        <form
                            id="node-mail-settings-form"
                            class="nodes-detail-card"
                            hx-post="/admin/nodes/{{ selectedNode.id }}/mail-settings"
                            hx-target="#nodes-table-wrap"
                            hx-swap="innerHTML"
                        >
                            <div class="nodes-detail-card__header">
                                <div class="nodes-detail-card__title">{{ t('admin_nodes_mail_settings_title', page_locale()) }}</div>
                            </div>
                            <div class="nodes-form-grid">
                                <div class="form-field">
                                    <label class="form-label" for="mail_host">{{ t('admin_nodes_mail_host_label', page_locale()) }}</label>
                                    <input
                                        id="mail_host"
                                        name="mail_host"
                                        type="text"
                                        value="{{ selectedNode.mail.host ?? '' }}"
                                        placeholder="mail.example.com"
                                        class="form-input"
                                    >
                                    <p style="font-size:11px;color:var(--ng-text-muted);margin-top:4px;">{{ t('admin_nodes_mail_host_hint', page_locale()) }}</p>
                                </div>
                                <div class="form-field">
                                    <label class="form-label" for="mail_imap_host">{{ t('admin_nodes_mail_imap_host_label', page_locale()) }}</label>
                                    <input
                                        id="mail_imap_host"
                                        name="mail_imap_host"
                                        type="text"
                                        value="{{ selectedNode.mail.imap_host ?? '' }}"
                                        placeholder="imap.example.com"
                                        class="form-input"
                                    >
                                </div>
                                <div class="form-field">
                                    <label class="form-label" for="mail_smtp_host">{{ t('admin_nodes_mail_smtp_host_label', page_locale()) }}</label>
                                    <input
                                        id="mail_smtp_host"
                                        name="mail_smtp_host"
                                        type="text"
                                        value="{{ selectedNode.mail.smtp_host ?? '' }}"
                                        placeholder="smtp.example.com"
                                        class="form-input"
                                    >
                                </div>
                                <div class="form-field">
                                    <label class="form-label" for="mail_imap_port">{{ t('admin_nodes_mail_imap_port_label', page_locale()) }}</label>
                                    <input
                                        id="mail_imap_port"
                                        name="mail_imap_port"
                                        type="number"
                                        min="1"
                                        max="65535"
                                        value="{{ selectedNode.mail.imap_port ?? '' }}"
                                        class="form-input"
                                    >
                                </div>
                                <div class="form-field">
                                    <label class="form-label" for="mail_smtp_port">{{ t('admin_nodes_mail_smtp_port_label', page_locale()) }}</label>
                                    <input
                                        id="mail_smtp_port"
                                        name="mail_smtp_port"
                                        type="number"
                                        min="1"
                                        max="65535"
                                        value="{{ selectedNode.mail.smtp_port ?? '' }}"
                                        class="form-input"
                                    >
                                </div>
                                <div class="form-field">
                                    <label class="form-label" for="mail_imap_encryption">{{ t('admin_nodes_mail_imap_encryption_label', page_locale()) }}</label>
                                    <select id="mail_imap_encryption" name="mail_imap_encryption" class="form-input">
                                        <option value="">{{ t('admin_nodes_mail_encryption_placeholder', page_locale()) }}</option>
                                        <option value="ssl_tls" {% if selectedNode.mail.imap_encryption == 'ssl_tls' %}selected{% endif %}>SSL/TLS</option>
                                        <option value="starttls" {% if selectedNode.mail.imap_encryption == 'starttls' %}selected{% endif %}>STARTTLS</option>
                                        <option value="none" {% if selectedNode.mail.imap_encryption == 'none' %}selected{% endif %}>None</option>
                                    </select>
                                </div>
                                <div class="form-field">
                                    <label class="form-label" for="mail_smtp_encryption">{{ t('admin_nodes_mail_smtp_encryption_label', page_locale()) }}</label>
                                    <select id="mail_smtp_encryption" name="mail_smtp_encryption" class="form-input">
                                        <option value="">{{ t('admin_nodes_mail_encryption_placeholder', page_locale()) }}</option>
                                        <option value="ssl_tls" {% if selectedNode.mail.smtp_encryption == 'ssl_tls' %}selected{% endif %}>SSL/TLS</option>
                                        <option value="starttls" {% if selectedNode.mail.smtp_encryption == 'starttls' %}selected{% endif %}>STARTTLS</option>
                                        <option value="none" {% if selectedNode.mail.smtp_encryption == 'none' %}selected{% endif %}>None</option>
                                    </select>
                                </div>
                            </div>
                            <button class="ui-button ui-button--ghost" type="submit">{{ t('admin_nodes_mail_save', page_locale()) }}</button>
                        </form>

                        <form
                            id="node-override-form"
                            class="nodes-detail-card"
                            hx-post="/admin/nodes/{{ selectedNode.id }}/disk-protection-override"
                            hx-target="#nodes-table-wrap"
                            hx-swap="innerHTML"
                        >
                            <div class="nodes-detail-card__header">
                                <div class="nodes-detail-card__title">{{ t('admin_nodes_override_section', page_locale()) }}</div>
                                <button class="ui-button ui-button--ghost ui-button--sm" type="submit">{{ t('admin_nodes_disk_override_apply', page_locale()) }}</button>
                            </div>
                            <div class="nodes-form-grid nodes-form-grid--single">
                                <div class="form-field">
                                    <label class="form-label" for="override_minutes">{{ t('admin_nodes_disk_override_minutes', page_locale()) }}</label>
                                    <input
                                        id="override_minutes"
                                        name="override_minutes"
                                        type="number"
                                        min="0"
                                        class="form-input"
                                        placeholder="0"
                                    >
                                </div>
                            </div>
                        </form>

                        <div class="nodes-detail-card">
                            <div class="nodes-detail-card__header">
                                <div class="nodes-detail-card__title">{{ t('admin_nodes_logs_title', page_locale()) }}</div>
                                <a class="ui-button ui-button--ghost" href="/admin/jobs">{{ t('admin_nodes_logs_view_all', page_locale()) }}</a>
                            </div>
                            {% if selectedNode.logs is defined and selectedNode.logs is not empty %}
                                <div style="display:flex;flex-direction:column;">
                                    {% for log in selectedNode.logs %}
                                        <div style="padding:10px 0;border-top:1px solid var(--ng-border);">
                                            <div style="display:flex;flex-wrap:wrap;align-items:center;gap:8px;">
                                                <span class="ui-badge ui-badge--neutral">{{ log.status|title }}</span>
                                                <span style="font-size:14px;font-weight:500;color:var(--ng-text);">{{ log.type }}</span>
                                                <span style="font-size:11px;color:var(--ng-text-muted);">{{ log.createdAt|date('Y-m-d H:i') }}</span>
                                            </div>
                                            {% if log.errorText %}
                                                <div style="font-size:11px;color:var(--ng-danger);white-space:pre-line;margin-top:8px;">{{ log.errorText }}</div>
                                            {% elseif log.logText %}
                                                <div style="font-size:11px;color:var(--ng-text-muted);white-space:pre-line;margin-top:8px;">{{ log.logText }}</div>
                                            {% endif %}
                                        </div>
                                    {% endfor %}
                                </div>
                            {% else %}
                                <p style="font-size:11px;color:var(--ng-text-muted);">{{ t('admin_nodes_logs_empty', page_locale()) }}</p>
                            {% endif %}
                        </div>

                        <form
                            class="nodes-detail-card"
                            hx-post="/admin/nodes/{{ selectedNode.id }}/delete"
                            hx-target="#nodes-table-wrap"
                            hx-swap="innerHTML"
                        >
                            <div class="nodes-detail-card__header">
                                <div class="nodes-detail-card__title">{{ t('admin_nodes_delete_title', page_locale()) }}</div>
                                <button
                                    class="ui-button ui-button--danger"
                                    type="submit"
                                    {% if selectedNode.delete is defined and selectedNode.delete.allowed is same as(false) %}
                                        disabled
                                        title="{{ selectedNode.delete.message }}"
                                    {% endif %}
                                >{{ t('admin_nodes_delete', page_locale()) }}</button>
                            </div>
                            <p style="font-size:11px;color:var(--ng-text-muted);">{{ t('admin_nodes_delete_hint', page_locale()) }}</p>
                            {% if selectedNode.delete is defined and selectedNode.delete.allowed is same as(false) %}
                                <p style="font-size:11px;color:var(--ng-danger);white-space:pre-line;margin-top:8px;">{{ selectedNode.delete.message }}</p>
                            {% endif %}
                            <div class="nodes-form-grid nodes-form-grid--single">
                                <div class="form-field">
                                    <label class="form-label" for="confirm-id">{{ t('admin_nodes_delete_confirm_label', page_locale()) }}</label>
                                    <input
                                        id="confirm-id"
                                        name="confirm_id"
                                        type="text"
                                        class="form-input"
                                        placeholder="{{ selectedNode.id }}"
                                        {% if selectedNode.delete is defined and selectedNode.delete.allowed is same as(false) %}disabled{% endif %}
                                    >
                                </div>
                            </div>
                        </form>
                    </div>

                    <div class="nodes-actions-row">
                        <button
                            class="ui-button ui-button--primary"
                            hx-post="/admin/nodes/{{ selectedNode.id }}/update"
                            hx-target="#nodes-table-wrap"
                            hx-swap="innerHTML"
                        >{{ t('admin_nodes_update_agent', page_locale()) }}</button>
                        <button
                            class="ui-button ui-button--ghost"
                            hx-post="/admin/nodes/{{ selectedNode.id }}/update-run"
                            hx-target="#nodes-table-wrap"
                            hx-swap="innerHTML"
                        >{{ t('admin_nodes_server_update_run', page_locale()) }}</button>
                        <button
                            class="ui-button ui-button--danger"
                            hx-post="/admin/nodes/{{ selectedNode.id }}/reboot"
                            hx-target="#nodes-table-wrap"
                            hx-swap="innerHTML"
                            hx-confirm="{{ t('admin_nodes_reboot_confirm', page_locale()) }}"
                        >{{ t('admin_nodes_reboot', page_locale()) }}</button>
                    </div>
                {% else %}
                    <div class="nodes-detail__header">
                        <h3 class="nodes-detail__title">{{ t('admin_nodes_empty', page_locale()) }}</h3>
                        <div class="nodes-detail__subline">{{ t('admin_nodes_release_unavailable', page_locale()) }}</div>
                    </div>
                {% endif %}
            </div>
        </aside>
    </div>
</section>
<script>
    const pageLocale = '{{ page_locale() }}';
    const formatRelativeTime = (date) => {
        const diffMs = date.getTime() - Date.now();
        const diffSeconds = Math.round(diffMs / 1000);
        const absSeconds = Math.abs(diffSeconds);
        const rtf = new Intl.RelativeTimeFormat(pageLocale, { numeric: 'auto' });
        if (absSeconds < 60) {
            return rtf.format(Math.round(diffSeconds), 'second');
        }
        const diffMinutes = Math.round(diffSeconds / 60);
        if (Math.abs(diffMinutes) < 60) {
            return rtf.format(diffMinutes, 'minute');
        }
        const diffHours = Math.round(diffMinutes / 60);
        if (Math.abs(diffHours) < 24) {
            return rtf.format(diffHours, 'hour');
        }
        const diffDays = Math.round(diffHours / 24);
        return rtf.format(diffDays, 'day');
    };

    const updateRelativeTimes = (root = document) => {
        root.querySelectorAll('[data-relative-time]').forEach((el) => {
            const datetime = el.getAttribute('datetime');
            if (!datetime) {
                return;
            }
            const parsed = new Date(datetime);
            if (Number.isNaN(parsed.getTime())) {
                return;
            }
            el.textContent = formatRelativeTime(parsed);
        });
    };

    const bindRoleToggles = (root = document) => {
        root.querySelectorAll('[data-role-toggle]').forEach((button) => {
            if (button.dataset.roleToggleBound) {
                return;
            }
            button.dataset.roleToggleBound = 'true';
            button.addEventListener('click', () => {
                const list = button.nextElementSibling;
                if (list && list.hasAttribute('data-role-list')) {
                    list.hidden = !list.hidden;
                }
            });
        });
    };

    updateRelativeTimes();
    bindRoleToggles();

    document.body.addEventListener('htmx:afterSwap', (event) => {
        updateRelativeTimes(event.target);
        bindRoleToggles(event.target);
    });
</script>
{% endblock %}
