{% extends 'admin/base.html.twig' %}

{% set pageTitle = t('admin_nodes_title', page_locale()) %}
{% set pageSubtitle = t('admin_nodes_intro', page_locale()) %}
{% set activeNav = 'nodes' %}

{% block content %}
{% set selectedNode = selectedNode ?? nodes|first %}
{% set statusMap = {
    'online': 'success',
    'stale': 'warning',
    'offline': 'danger',
    'provisioning': 'primary',
    'maintenance': 'neutral'
} %}

<div style="display:flex;flex-direction:column;gap:20px;">

    {% if diskProtectCount is defined and diskProtectCount > 0 %}
        <div class="ng-alert ng-alert--danger">
            {{ t('admin_nodes_disk_protect_banner', page_locale())|replace({'%count%': diskProtectCount}) }}
        </div>
    {% endif %}

    {# ── Hero ── #}
    <section class="ng-card" style="overflow:hidden;">
        <div class="tkt-hero">
            <div class="tkt-hero__inner">
                <div style="display:flex;flex-direction:column;gap:16px;">
                    <div>
                        <div class="tkt-hero__pill">
                            <span class="tkt-hero__pill-dot"></span>
                            {{ t('admin_nodes_title', page_locale()) }}
                        </div>
                        <h1 class="tkt-hero__title" style="margin-top:10px;">{{ t('admin_nodes_title', page_locale()) }}</h1>
                        <p class="tkt-hero__sub">{{ t('admin_nodes_intro', page_locale()) }}</p>
                    </div>
                    <div style="display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:10px;">
                        <div class="tkt-kpi">
                            <div class="tkt-kpi__label">{{ t('admin_nodes_total', page_locale()) }}</div>
                            <div class="tkt-kpi__value">{{ summary.total }}</div>
                        </div>
                        <div class="tkt-kpi tkt-kpi--resolved">
                            <div class="tkt-kpi__label">{{ t('admin_nodes_online', page_locale()) }}</div>
                            <div class="tkt-kpi__value">{{ summary.online }}</div>
                        </div>
                        <div class="tkt-kpi tkt-kpi--open">
                            <div class="tkt-kpi__label">{{ t('admin_nodes_offline', page_locale()) }}</div>
                            <div class="tkt-kpi__value">{{ summary.offline }}</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div style="display:flex;gap:12px;padding:14px 20px;border-top:1px solid var(--ng-border);background:var(--ng-surface-soft);align-items:center;justify-content:space-between;">
            <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;">
                {% if summary.latestVersion %}
                    <span class="ui-badge ui-badge--info">
                        {{ t('admin_nodes_channel', page_locale())|replace({'%channel%': updateChannel|upper}) }} · {{ summary.latestVersion }}
                    </span>
                {% endif %}
                <span style="font-size:11px;color:var(--ng-text-muted);">{{ t('admin_nodes_manual_register_hint', page_locale()) }}</span>
            </div>
            <div style="display:flex;gap:8px;align-items:center;">
                <a href="/admin/nodes/register" class="ui-button ui-button--ghost ui-button--sm">{{ t('admin_nodes_register_button', page_locale()) }}</a>
            </div>
        </div>
    </section>

    <div id="nodes-feedback" class="nodes-feedback"></div>
    <div id="nodes-table-wrap" style="display:none;"></div>

    {# ── Agent detail — 3-column layout ── #}
    {% if selectedNode %}
    <div style="display:grid;grid-template-columns:220px minmax(0,1fr) 260px;gap:20px;align-items:start;">

        {# ── Left sidebar: node selector + navigation ── #}
        <aside style="position:sticky;top:20px;display:flex;flex-direction:column;gap:10px;">
            <div class="ng-card" style="overflow:hidden;padding:16px;">

                <div style="background:var(--ng-surface-soft);border:1px solid var(--ng-border);border-radius:var(--ng-radius-sm);padding:12px;margin-bottom:12px;">
                    <div style="font-size:10px;font-weight:700;font-family:monospace;letter-spacing:.06em;color:var(--ng-text-muted);margin-bottom:4px;">{{ t('admin_nodes_select_agent', page_locale()) }}</div>
                    <h2 style="margin:0 0 8px;font-size:13px;font-weight:700;color:var(--ng-text);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{{ selectedNode.name ?? t('admin_nodes_unnamed', page_locale()) }}</h2>
                    <div style="display:flex;gap:5px;flex-wrap:wrap;">
                        {% set statusClass = statusMap[selectedNode.status] ?? 'neutral' %}
                        <span class="ui-badge ui-badge--{{ statusClass }}" style="font-size:10px;">{{ selectedNode.status|title }}</span>
                        {% if selectedNode.updateAvailable is same as(true) %}
                            <span class="ui-badge ui-badge--warning" style="font-size:10px;">{{ t('admin_nodes_update_available', page_locale()) }}</span>
                        {% elseif selectedNode.updateAvailable is same as(false) and selectedNode.lastHeartbeatVersion %}
                            <span class="ui-badge ui-badge--success" style="font-size:10px;">{{ t('admin_nodes_up_to_date', page_locale()) }}</span>
                        {% endif %}
                    </div>
                </div>

                <form method="get" action="/admin/nodes" style="margin-bottom:14px;">
                    <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--ng-text-muted);margin-bottom:6px;">{{ t('admin_nodes_select_node_label', page_locale()) }}</label>
                    <select name="node" class="form-input" style="font-size:12px;padding:6px 10px;margin-bottom:8px;">
                        {% for node in nodes %}
                            <option value="{{ node.id }}" {% if node.id == selectedNode.id %}selected{% endif %}>
                                {{ node.name ?? t('admin_nodes_unnamed', page_locale()) }} ({{ node.id }})
                            </option>
                        {% endfor %}
                    </select>
                    <button class="tkt-sidebar-btn" style="width:100%;" type="submit">{{ t('admin_nodes_load_button', page_locale()) }}</button>
                </form>

                <nav style="display:flex;flex-direction:column;gap:2px;">
                    <a href="#section-status" class="sb-nav-link sb-nav-link--active">
                        <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path stroke-linecap="round" d="M12 8v4l3 3"/></svg>
                        {{ t('status', page_locale()) }}
                    </a>
                    <a href="#section-services" class="sb-nav-link">
                        <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M5 12h14M12 5l7 7-7 7"/></svg>
                        {{ t('admin_nodes_services', page_locale()) }}
                    </a>
                    <a href="#section-roles" class="sb-nav-link">
                        <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/></svg>
                        {{ t('admin_nodes_roles_active', page_locale()) }}
                    </a>
                    <a href="#section-agent-settings" class="sb-nav-link">
                        <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><circle cx="12" cy="12" r="3"/></svg>
                        {{ t('admin_nodes_agent_ts_section_title', page_locale()) }}
                    </a>
                    <a href="#section-disk" class="sb-nav-link">
                        <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M3 12a9 9 0 1018 0 9 9 0 00-18 0"/><path stroke-linecap="round" d="M9 12h6M12 9v6"/></svg>
                        {{ t('admin_nodes_settings_section', page_locale()) }}
                    </a>
                    <a href="#section-mail" class="sb-nav-link">
                        <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                        {{ t('admin_nodes_mail_settings_title', page_locale()) }}
                    </a>
                    <a href="#section-logs" class="sb-nav-link">
                        <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
                        {{ t('admin_nodes_logs_title', page_locale()) }}
                    </a>
                    <a href="#section-delete" class="sb-nav-link">
                        <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                        {{ t('admin_nodes_delete_title', page_locale()) }}
                    </a>
                </nav>
            </div>
        </aside>

        {# ── Center: node detail sections ── #}
        <main style="display:flex;flex-direction:column;gap:16px;min-width:0;">

            {# Node header #}
            <div class="ng-card" style="overflow:hidden;">
                <div class="tkt-hero" style="padding-bottom:0;">
                    <div class="tkt-hero__inner" style="padding-bottom:16px;">
                        <div>
                            <div class="tkt-hero__breadcrumb">
                                <span>{{ t('admin_nodes_fleet', page_locale()) }}</span>
                                <span>/</span>
                                <span>{{ selectedNode.name ?? t('admin_nodes_unnamed', page_locale()) }}</span>
                            </div>
                            <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;margin-top:10px;">
                                <div class="tkt-hero__pill">
                                    <span class="tkt-hero__pill-dot"></span>
                                    Nodes
                                </div>
                                {% set statusClass = statusMap[selectedNode.status] ?? 'neutral' %}
                                <span class="ui-badge ui-badge--{{ statusClass }}" style="font-size:11px;">{{ selectedNode.status|title }}</span>
                                {% if selectedNode.updateAvailable is same as(true) %}
                                    <span class="ui-badge ui-badge--warning" style="font-size:11px;">{{ t('admin_nodes_update_available', page_locale()) }}</span>
                                {% elseif selectedNode.updateAvailable is same as(false) and selectedNode.lastHeartbeatVersion %}
                                    <span class="ui-badge ui-badge--success" style="font-size:11px;">{{ t('admin_nodes_up_to_date', page_locale()) }}</span>
                                {% endif %}
                                {% if selectedNode.serverUpdate is not null and selectedNode.serverUpdate.updatesAvailable is same as(true) %}
                                    <span class="ui-badge ui-badge--warning" style="font-size:11px;">{{ t('admin_nodes_server_updates_available', page_locale()) }}</span>
                                {% elseif selectedNode.serverUpdate is not null and selectedNode.serverUpdate.updatesAvailable is same as(false) %}
                                    <span class="ui-badge ui-badge--success" style="font-size:11px;">{{ t('admin_nodes_server_updates_current', page_locale()) }}</span>
                                {% endif %}
                            </div>
                            <h1 class="tkt-hero__title" style="margin-top:10px;">{{ selectedNode.name ?? t('admin_nodes_unnamed', page_locale()) }}</h1>
                            <p class="tkt-hero__sub">{{ selectedNode.lastHeartbeatIp ?? '—' }}</p>
                        </div>
                    </div>
                </div>
            </div>

            {# ── Status ── #}
            <div id="section-status" class="ng-data-card">
                <div class="ng-data-card__header">
                    <div style="display:flex;align-items:center;gap:10px;">
                        <span style="display:flex;align-items:center;justify-content:center;width:32px;height:32px;border-radius:8px;background:rgba(100,115,255,.12);flex-shrink:0;">
                            <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="#6473ff" stroke-width="2"><circle cx="12" cy="12" r="10"/><path stroke-linecap="round" d="M12 8v4l3 3"/></svg>
                        </span>
                        <div>
                            <h2 class="ng-data-card__title">{{ t('status', page_locale()) }}</h2>
                            <p class="ng-data-card__sub">{{ t('admin_nodes_table_last_seen', page_locale()) }}: {{ selectedNode.lastSeenAt ? selectedNode.lastSeenAt|date('Y-m-d H:i') : '—' }}</p>
                        </div>
                    </div>
                    <div class="ng-data-card__actions">
                        {% if selectedNode.rebootRequired is same as(true) %}
                            <span class="ui-badge ui-badge--warning">{{ t('admin_nodes_reboot_required', page_locale()) }}</span>
                        {% endif %}
                    </div>
                </div>
                <div class="ng-data-card__body">
                    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(190px,1fr));gap:10px;margin-bottom:16px;">
                        <div style="background:var(--ng-surface-soft);border:1px solid var(--ng-border);border-radius:8px;padding:12px;">
                            <div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--ng-text-muted);margin-bottom:4px;">{{ t('admin_nodes_table_version', page_locale()) }}</div>
                            <div style="font-size:14px;font-weight:600;color:var(--ng-text);font-family:monospace;">{{ selectedNode.lastHeartbeatVersion ?? '—' }}</div>
                        </div>
                        <div style="background:var(--ng-surface-soft);border:1px solid var(--ng-border);border-radius:8px;padding:12px;">
                            <div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--ng-text-muted);margin-bottom:4px;">{{ t('admin_nodes_health', page_locale()) }}</div>
                            <div style="font-size:14px;font-weight:600;color:var(--ng-text);">{{ selectedNode.health|title }}</div>
                        </div>
                        <div style="background:var(--ng-surface-soft);border:1px solid var(--ng-border);border-radius:8px;padding:12px;">
                            <div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--ng-text-muted);margin-bottom:4px;">{{ t('admin_nodes_os_provider', page_locale()) }}</div>
                            <div style="font-size:14px;font-weight:600;color:var(--ng-text);">{{ selectedNode.osProvider ?? '—' }}</div>
                        </div>
                        {% if selectedNode.serverUpdate %}
                        <div style="background:var(--ng-surface-soft);border:1px solid var(--ng-border);border-radius:8px;padding:12px;">
                            <div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--ng-text-muted);margin-bottom:4px;">{{ t('admin_nodes_server_update_status', page_locale()) }}</div>
                            <div style="font-size:13px;font-weight:600;color:var(--ng-text);">
                                {{ selectedNode.serverUpdate.status|title }}
                                {% if selectedNode.serverUpdate.resultMessage %}
                                    <span style="font-size:11px;color:var(--ng-text-muted);">· {{ selectedNode.serverUpdate.resultMessage }}</span>
                                {% endif %}
                            </div>
                        </div>
                        {% endif %}
                    </div>
                    <div style="display:flex;flex-wrap:wrap;gap:8px;padding-top:14px;border-top:1px solid var(--ng-border);">
                        <button
                            class="ui-button ui-button--ghost ui-button--sm"
                            hx-post="/admin/nodes/{{ selectedNode.id }}/reboot-check"
                            hx-target="#nodes-table-wrap"
                            hx-swap="innerHTML"
                        >{{ t('admin_nodes_reboot_check', page_locale()) }}</button>
                        <button
                            class="ui-button ui-button--ghost ui-button--sm"
                            hx-post="/admin/nodes/{{ selectedNode.id }}/update-check"
                            hx-target="#nodes-table-wrap"
                            hx-swap="innerHTML"
                        >{{ t('admin_nodes_update_check', page_locale()) }}</button>
                        <a class="ui-button ui-button--ghost ui-button--sm" href="/admin/nodes/{{ selectedNode.id }}/port-ranges">
                            {{ t('admin_nodes_port_ranges', page_locale()) }}
                        </a>
                    </div>
                </div>
            </div>

            {# ── Services ── #}
            <details id="section-services" class="ng-data-card">
                <summary style="padding:16px 20px;cursor:pointer;display:flex;justify-content:space-between;align-items:center;list-style:none;user-select:none;">
                    <div style="display:flex;align-items:center;gap:10px;">
                        <span style="display:flex;align-items:center;justify-content:center;width:32px;height:32px;border-radius:8px;background:rgba(34,197,94,.10);flex-shrink:0;">
                            <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="#22c55e" stroke-width="2"><path stroke-linecap="round" d="M5 12h14M12 5l7 7-7 7"/></svg>
                        </span>
                        <div>
                            <h2 class="ng-data-card__title" style="margin:0;">{{ t('admin_nodes_services', page_locale()) }}</h2>
                            <p class="ng-data-card__sub" style="margin:2px 0 0;">{{ selectedNode.services|length }} {{ t('admin_nodes_services', page_locale())|lower }}</p>
                        </div>
                    </div>
                    <svg width="15" height="15" fill="none" viewBox="0 0 24 24" style="flex-shrink:0;transition:transform .2s;color:var(--ng-text-muted);" class="details-chevron"><path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </summary>
                <div class="ng-data-card__body" style="border-top:1px solid var(--ng-border);">
                    <div class="role-toggle-group">
                        {% if selectedNode.services is empty %}
                            <span style="font-size:11px;color:var(--ng-text-muted);">{{ t('admin_nodes_services_empty', page_locale()) }}</span>
                        {% else %}
                            {% for service, state in selectedNode.services %}
                                <span class="role-chip {{ state == 'active' ? 'role-chip--active' : '' }}">{{ service }} · {{ state }}</span>
                            {% endfor %}
                        {% endif %}
                    </div>
                </div>
            </details>

            {# ── Roles ── #}
            <div id="section-roles" class="ng-data-card">
                <div class="ng-data-card__header">
                    <div style="display:flex;align-items:center;gap:10px;">
                        <span style="display:flex;align-items:center;justify-content:center;width:32px;height:32px;border-radius:8px;background:rgba(99,102,241,.12);flex-shrink:0;">
                            <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="#6366f1" stroke-width="2"><path stroke-linecap="round" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/></svg>
                        </span>
                        <div>
                            <h2 class="ng-data-card__title">{{ t('admin_nodes_roles_active', page_locale()) }}</h2>
                            <p class="ng-data-card__sub">{{ t('admin_nodes_roles_manage_hint', page_locale()) }}</p>
                        </div>
                    </div>
                    <div class="ng-data-card__actions">
                        <a class="ui-button ui-button--ghost ui-button--sm" href="/admin/nodes/{{ selectedNode.id }}/roles">
                            {{ t('admin_nodes_manage_roles', page_locale()) }}
                        </a>
                    </div>
                </div>
                <div class="ng-data-card__body">
                    <div class="role-toggle-group">
                        {% if selectedNode.roles is empty %}
                            <span style="font-size:11px;color:var(--ng-text-muted);">{{ t('admin_nodes_roles_empty', page_locale()) }}</span>
                        {% else %}
                            {% for role in selectedNode.roles %}
                                <span class="role-chip role-chip--active">{{ role }}</span>
                            {% endfor %}
                        {% endif %}
                    </div>
                </div>
            </div>

            {# ── Agent Settings ── #}
            <details id="section-agent-settings" class="ng-data-card">
                <summary style="padding:16px 20px;cursor:pointer;display:flex;justify-content:space-between;align-items:center;list-style:none;user-select:none;">
                    <div style="display:flex;align-items:center;gap:10px;">
                        <span style="display:flex;align-items:center;justify-content:center;width:32px;height:32px;border-radius:8px;background:rgba(100,116,139,.10);flex-shrink:0;">
                            <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><circle cx="12" cy="12" r="3"/></svg>
                        </span>
                        <div>
                            <h2 class="ng-data-card__title" style="margin:0;">{{ t('admin_nodes_agent_ts_section_title', page_locale()) }}</h2>
                            <p class="ng-data-card__sub" style="margin:2px 0 0;">{{ t('admin_nodes_agent_base_url_label', page_locale()) }}: {{ selectedNode.agent.base_url ?? '—' }}</p>
                        </div>
                    </div>
