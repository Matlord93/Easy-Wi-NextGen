                    >{{ t('admin_nodes_reboot_check', page_locale()) }}</button>
                    <button
                        class="tkt-sidebar-btn"
                        style="width:100%;"
                        hx-post="/admin/nodes/{{ selectedNode.id }}/update-check"
                        hx-target="#nodes-table-wrap"
                        hx-swap="innerHTML"
                    >{{ t('admin_nodes_update_check', page_locale()) }}</button>
                    <div style="height:1px;background:var(--ng-border);margin:4px 0;"></div>
                    <button
                        class="tkt-sidebar-btn tkt-sidebar-btn--warning"
                        style="width:100%;"
                        hx-post="/admin/nodes/{{ selectedNode.id }}/reboot"
                        hx-target="#nodes-table-wrap"
                        hx-swap="innerHTML"
                        hx-confirm="{{ t('admin_nodes_reboot_confirm', page_locale()) }}"
                    >{{ t('admin_nodes_reboot', page_locale()) }}</button>
                </div>
            </div>

            {# Node info #}
            <div class="ng-card" style="overflow:hidden;">
                <div style="padding:13px 18px;border-bottom:1px solid var(--ng-border);">
                    <h3 style="margin:0;font-size:13px;font-weight:700;color:var(--ng-text);">Info</h3>
                </div>
                <div style="padding:14px 18px;">
                    <dl class="tkt-dl">
                        <div>
                            <dt>{{ t('admin_nodes_last_ip', page_locale())|replace({'%ip%': ''}) }}</dt>
                            <dd style="font-family:monospace;font-size:12px;">{{ selectedNode.lastHeartbeatIp ?? '—' }}</dd>
                        </div>
                        <div>
                            <dt>{{ t('admin_nodes_table_version', page_locale()) }}</dt>
                            <dd style="font-family:monospace;font-size:12px;">{{ selectedNode.lastHeartbeatVersion ?? '—' }}</dd>
                        </div>
                        <div>
                            <dt>{{ t('admin_nodes_health', page_locale()) }}</dt>
                            <dd>{{ selectedNode.health|title }}</dd>
                        </div>
                        {% if selectedNode.serviceMapping is defined %}
                        <div>
                            <dt>Node ↔ Agent</dt>
                            <dd style="font-size:11px;font-family:monospace;word-break:break-all;">{{ selectedNode.serviceMapping.node }} ↔ {{ selectedNode.serviceMapping.agent_id }}</dd>
                        </div>
                        <div>
                            <dt>Services</dt>
                            <dd style="font-size:11px;">GS {{ selectedNode.serviceMapping.services.instances }}, Web {{ selectedNode.serviceMapping.services.webspaces }}, TS3 {{ selectedNode.serviceMapping.services.ts3_instances }}, TS6 {{ selectedNode.serviceMapping.services.ts6_instances }}</dd>
                        </div>
                        {% endif %}
                        {% if updateChannel is defined %}
                        <div>
                            <dt>{{ t('admin_nodes_channel', page_locale())|replace({'%channel%': ''}) }}</dt>
                            <dd>{{ updateChannel|upper }}</dd>
                        </div>
                        {% endif %}
                    </dl>
                </div>
            </div>

            {# Disk Protection Override quick form #}
            <div class="ng-card" style="overflow:hidden;">
                <div style="padding:13px 18px;border-bottom:1px solid var(--ng-border);">
                    <h3 style="margin:0;font-size:13px;font-weight:700;color:var(--ng-text);">{{ t('admin_nodes_override_section', page_locale()) }}</h3>
                </div>
                <div style="padding:14px 18px;">
                    <form
                        hx-post="/admin/nodes/{{ selectedNode.id }}/disk-protection-override"
                        hx-target="#nodes-table-wrap"
                        hx-swap="innerHTML"
                    >
                        <div class="form-field" style="margin-bottom:10px;">
                            <label class="form-label" style="font-size:10px;" for="override_minutes_sidebar">{{ t('admin_nodes_disk_override_minutes', page_locale()) }}</label>
                            <input id="override_minutes_sidebar" name="override_minutes" type="number" min="0" class="form-input" placeholder="0" style="font-size:13px;padding:7px 10px;">
                        </div>
                        <button class="tkt-sidebar-btn" style="width:100%;" type="submit">{{ t('admin_nodes_disk_override_apply', page_locale()) }}</button>
                    </form>
                </div>
            </div>

            {# Port ranges link #}
            <div class="ng-card" style="overflow:hidden;">
                <div style="padding:13px 18px;">
                    <a class="tkt-sidebar-btn" style="width:100%;display:block;text-align:center;text-decoration:none;" href="/admin/nodes/{{ selectedNode.id }}/port-ranges">
                        {{ t('admin_nodes_port_ranges', page_locale()) }}
                    </a>
                </div>
            </div>

        </aside>

    </div>
    {% else %}
    <div class="ng-data-card">
        <div class="ng-data-card__body" style="padding:60px 20px;text-align:center;">
            <svg width="48" height="48" fill="none" viewBox="0 0 24 24" style="display:block;margin:0 auto 16px;opacity:.25;color:var(--ng-text-muted);"><rect x="2" y="3" width="20" height="14" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M8 21h8M12 17v4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            <p style="margin:0;font-size:14px;font-weight:600;color:var(--ng-text);">{{ t('admin_nodes_empty', page_locale()) }}</p>
            <p style="margin:8px 0 0;font-size:13px;color:var(--ng-text-muted);">{{ t('admin_nodes_release_unavailable', page_locale()) }}</p>
        </div>
    </div>
    {% endif %}

</div>

<style>
.sb-nav-link {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 7px 10px;
    border-radius: var(--ng-radius-sm);
    font-size: 12px;
    font-weight: 600;
    color: var(--ng-text-muted);
    text-decoration: none;
    transition: background .15s, color .15s;
}
.sb-nav-link:hover,
.sb-nav-link--active {
    background: var(--ng-primary-soft);
    color: var(--ng-primary);
}
</style>

<script>
    const pageLocale = '{{ page_locale() }}';
    const formatRelativeTime = (date) => {
        const diffMs = date.getTime() - Date.now();
        const diffSeconds = Math.round(diffMs / 1000);
        const absSeconds = Math.abs(diffSeconds);
        const rtf = new Intl.RelativeTimeFormat(pageLocale, { numeric: 'auto' });
        if (absSeconds < 60) {
            return rtf.format(Math.round(diffSeconds), 'second');
        }
        const diffMinutes = Math.round(diffSeconds / 60);
        if (Math.abs(diffMinutes) < 60) {
            return rtf.format(diffMinutes, 'minute');
        }
        const diffHours = Math.round(diffMinutes / 60);
        if (Math.abs(diffHours) < 24) {
            return rtf.format(diffHours, 'hour');
        }
        const diffDays = Math.round(diffHours / 24);
        return rtf.format(diffDays, 'day');
    };

    const updateRelativeTimes = (root = document) => {
        root.querySelectorAll('[data-relative-time]').forEach((el) => {
            const datetime = el.getAttribute('datetime');
            if (!datetime) return;
            const parsed = new Date(datetime);
            if (Number.isNaN(parsed.getTime())) return;
            el.textContent = formatRelativeTime(parsed);
        });
    };

    const bindRoleToggles = (root = document) => {
        root.querySelectorAll('[data-role-toggle]').forEach((button) => {
            if (button.dataset.roleToggleBound) return;
            button.dataset.roleToggleBound = 'true';
            button.addEventListener('click', () => {
                const list = button.nextElementSibling;
                if (list && list.hasAttribute('data-role-list')) {
                    list.hidden = !list.hidden;
                }
            });
        });
    };

    document.querySelectorAll('details').forEach(d => {
        d.addEventListener('toggle', () => {
            const chevron = d.querySelector('.details-chevron');
            if (chevron) chevron.style.transform = d.open ? 'rotate(180deg)' : '';
        });
    });

    updateRelativeTimes();
    bindRoleToggles();

    document.body.addEventListener('htmx:afterSwap', (event) => {
        updateRelativeTimes(event.target);
        bindRoleToggles(event.target);
    });
</script>
{% endblock %}
