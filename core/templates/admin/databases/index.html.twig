{% extends 'admin/base.html.twig' %}

{% set pageTitle = t('admin_databases_title', page_locale()) %}
{% set pageSubtitle = t('admin_databases_intro', page_locale()) %}
{% set activeNav = 'databases' %}
{% set locale = page_locale() %}

{% block content %}
<div style="display:flex;flex-direction:column;gap:20px;">

    {# ── Hero ── #}
    <section class="ng-card" style="overflow:hidden;">
        <div class="tkt-hero">
            <div class="tkt-hero__inner">
                <div style="display:flex;flex-direction:column;gap:8px;">
                    <div class="tkt-hero__pill">
                        <span class="tkt-hero__pill-dot"></span>
                        {{ t('admin_databases_hero_label', locale) }}
                    </div>
                    <h1 class="tkt-hero__title">{{ t('admin_databases_title', locale) }}</h1>
                    <p class="tkt-hero__sub">{{ t('admin_databases_hero_intro', locale) }}</p>
                </div>
            </div>
        </div>
    </section>

    {% if errors is defined and errors is not empty %}
        <div class="ng-alert ng-alert--danger">
            <ul class="list-disc space-y-1 pl-5">
                {% for error in errors %}
                    <li>{{ error }}</li>
                {% endfor %}
            </ul>
        </div>
    {% endif %}

    {# Databases list + create form #}
    <div class="ng-layout-2col">
        <div class="ng-data-card">
            <div class="ng-data-card__header">
                <div>
                    <h2 class="ng-data-card__title">{{ t('admin_databases_list', page_locale()) }}</h2>
                    <p class="ng-data-card__sub">{{ t('admin_databases_list_intro', page_locale()) }}</p>
                </div>
            </div>
            <div class="ng-data-card__body ng-data-card__body--flush">
                <div class="cust-ws-table-wrap">
                    <table class="cust-table">
                        <thead>
                            <tr>
                                <th>{{ t('admin_databases_table_name', page_locale()) }}</th>
                                <th>{{ t('admin_databases_table_engine', page_locale()) }}</th>
                                <th>{{ t('admin_databases_table_host', page_locale()) }}</th>
                                <th>{{ t('admin_databases_table_node', page_locale()) }}</th>
                                <th>{{ t('admin_databases_table_user', page_locale()) }}</th>
                                <th>{{ t('admin_databases_table_customer', page_locale()) }}</th>
                                <th>{{ t('admin_databases_table_updated', page_locale()) }}</th>
                                <th>{{ t('admin_databases_table_actions', page_locale()) }}</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for database in databases %}
                                <tr>
                                    <td>
                                        <div class="font-semibold" style="color:var(--ng-text);">{{ database.name }}</div>
                                        <div style="font-size:11px;color:var(--ng-text-muted);">ID {{ database.id }}</div>
                                    </td>
                                    <td>{{ database.engine }}</td>
                                    <td>{{ database.host }}:{{ database.port }}</td>
                                    <td>
                                        {% if database.node is defined and database.node %}
                                            <div class="font-semibold" style="color:var(--ng-text);">{{ database.node.name }}</div>
                                            <div style="font-size:11px;color:var(--ng-text-muted);">ID {{ database.node.id }}</div>
                                        {% else %}
                                            <span class="ui-badge ui-badge--neutral">{{ t('admin_databases_node_unassigned', page_locale()) }}</span>
                                        {% endif %}
                                    </td>
                                    <td>{{ database.username }}</td>
                                    <td>{{ database.customer.email }}</td>
                                    <td>{{ database.updatedAt|date('Y-m-d H:i') }}</td>
                                    <td>
                                        <form method="post" action="/admin/databases/{{ database.id }}/password" class="flex flex-col gap-2">
                                            <div class="form-field">
                                                <input
                                                    type="password"
                                                    name="password"
                                                    class="form-input"
                                                    placeholder="{{ t('admin_databases_password_reset', page_locale()) }}"
                                                    minlength="8"
                                                    required
                                                >
                                            </div>
                                            <button class="ui-button ui-button--primary ui-button--sm">
                                                {{ t('admin_databases_reset', page_locale()) }}
                                            </button>
                                        </form>
                                        <form method="post" action="/admin/databases/{{ database.id }}/delete" class="mt-2">
                                            <button class="ui-button ui-button--danger ui-button--sm w-full">
                                                {{ t('admin_databases_delete', page_locale()) }}
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="8" class="cust-table__empty">{{ t('admin_databases_empty', page_locale()) }}</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="ng-data-card">
            <div class="ng-data-card__header">
                <div>
                    <h2 class="ng-data-card__title">{{ t('admin_databases_create', page_locale()) }}</h2>
                    <p class="ng-data-card__sub">{{ t('admin_databases_create_intro', page_locale()) }}</p>
                </div>
            </div>
            <div class="ng-data-card__body">
                <form method="post" action="/admin/databases" class="flex flex-col gap-4">
                    <div class="form-field">
                        <label class="form-label">{{ t('admin_databases_customer', page_locale()) }}</label>
                        <select name="customer_id" class="form-input" required>
                            <option value="">{{ t('admin_databases_customer_placeholder', page_locale()) }}</option>
                            {% for customer in customers %}
                                <option value="{{ customer.id }}">{{ customer.email }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="form-field">
                        <label class="form-label">{{ t('admin_databases_node', page_locale()) }}</label>
                        <select name="node_id" class="form-input" required>
                            <option value="">{{ t('admin_databases_node_placeholder', page_locale()) }}</option>
                            {% for node in nodeCandidates %}
                                <option value="{{ node.id }}">{{ node.name }} ({{ node.engine|upper }} · {{ node.host }}:{{ node.port }})</option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="form-field">
                        <label class="form-label">{{ t('admin_databases_name', page_locale()) }}</label>
                        <input name="name" type="text" class="form-input" required>
                    </div>
                    <div class="form-field">
                        <label class="form-label">{{ t('admin_databases_username', page_locale()) }}</label>
                        <input name="username" type="text" class="form-input" required>
                    </div>
                    <div class="form-field">
                        <label class="form-label">{{ t('admin_databases_password', page_locale()) }}</label>
                        <input name="password" type="password" minlength="8" class="form-input" required>
                    </div>
                    <button class="ui-button ui-button--primary">
                        {{ t('admin_databases_submit', page_locale()) }}
                    </button>
                </form>
            </div>
        </div>
    </div>

    {# Customer database limits #}
    <div class="ng-data-card">
        <div class="ng-data-card__header">
            <div>
                <h2 class="ng-data-card__title">{{ t('admin_databases_customer_limits_title', page_locale()) }}</h2>
                <p class="ng-data-card__sub">{{ t('admin_databases_customer_limits_intro', page_locale()) }}</p>
            </div>
        </div>
        <div class="ng-data-card__body">
            <div class="grid grid-cols-2 gap-3 xl:grid-cols-3">
                {% for customer in customers %}
                    <form method="post" action="{{ path('admin_database_customer_limit', {id: customer.id}) }}" class="flex items-center gap-3" style="border:1px solid var(--ng-border);border-radius:0.5rem;padding:0.75rem;">
                        <div class="min-w-0 flex-1">
                            <div class="truncate text-sm font-semibold" style="color:var(--ng-text);">{{ customer.email }}</div>
                            <div style="font-size:11px;color:var(--ng-text-muted);">{{ t('admin_databases_customer_id_label', page_locale()) }} {{ customer.id }}</div>
                        </div>
                        <input name="database_limit" type="number" min="0" value="{{ customer.databaseLimit }}" class="form-input w-24">
                        <button class="ui-button ui-button--primary ui-button--sm">{{ t('save', page_locale()) }}</button>
                    </form>
                {% else %}
                    <div class="cust-empty">{{ t('admin_databases_no_customers', page_locale()) }}</div>
                {% endfor %}
            </div>
        </div>
    </div>

    {# Database nodes list + create form #}
    <div class="ng-layout-2col">
        <div class="ng-data-card">
            <div class="ng-data-card__header">
                <div>
                    <h2 class="ng-data-card__title">{{ t('admin_database_nodes_title', page_locale()) }}</h2>
                    <p class="ng-data-card__sub">{{ t('admin_database_nodes_intro', page_locale()) }}</p>
                </div>
            </div>
            <div class="ng-data-card__body ng-data-card__body--flush">
                <div class="cust-ws-table-wrap">
                    <table class="cust-table">
                        <thead>
                            <tr>
                                <th>{{ t('admin_database_nodes_table_name', page_locale()) }}</th>
                                <th>{{ t('admin_database_nodes_table_engine', page_locale()) }}</th>
                                <th>{{ t('admin_database_nodes_table_host', page_locale()) }}</th>
                                <th>{{ t('admin_database_nodes_table_agent', page_locale()) }}</th>
                                <th>{{ t('admin_database_nodes_table_health', page_locale()) }}</th>
                                <th>{{ t('admin_database_nodes_table_actions', page_locale()) }}</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for node in databaseNodes %}
                                <tr>
                                    <td>
                                        <div class="font-semibold" style="color:var(--ng-text);">{{ node.name }}</div>
                                        <div style="font-size:11px;color:var(--ng-text-muted);">ID {{ node.id }}</div>
                                        {% if not node.isActive %}
                                            <span class="ui-badge ui-badge--danger mt-1">{{ t('admin_database_nodes_inactive', page_locale()) }}</span>
                                        {% endif %}
                                    </td>
                                    <td>{{ node.engine }}</td>
                                    <td>{{ node.host }}:{{ node.port }}</td>
                                    <td>
                                        <div class="font-semibold" style="color:var(--ng-text);">{{ node.agent.id }}</div>
                                        <div style="font-size:11px;color:var(--ng-text-muted);">{{ node.agent.name ?: t('admin_database_nodes_agent_placeholder', page_locale()) }}</div>
                                    </td>
                                    <td>
                                        <div class="font-semibold" style="color:var(--ng-text);">{{ node.healthStatus }}</div>
                                        <div style="font-size:11px;color:var(--ng-text-muted);">
                                            {{ node.lastCheckedAt ? node.lastCheckedAt|date('Y-m-d H:i') : t('admin_database_nodes_never_checked', page_locale()) }}
                                        </div>
                                        {% if node.healthMessage %}
                                            <div style="margin-top:4px;font-size:11px;color:var(--ng-text-muted);">{{ node.healthMessage }}</div>
                                        {% endif %}
                                    </td>
                                    <td>
                                        <div class="flex flex-col gap-2">
                                            <form method="post" action="/admin/databases/nodes/{{ node.id }}/health">
                                                <button class="ui-button ui-button--primary ui-button--sm w-full">
                                                    {{ t('admin_database_nodes_check', page_locale()) }}
                                                </button>
                                            </form>
                                            <form method="post" action="/admin/databases/nodes/{{ node.id }}/toggle">
                                                <button class="ui-button ui-button--ghost ui-button--sm w-full">
                                                    {{ node.isActive ? t('admin_database_nodes_deactivate', page_locale()) : t('admin_database_nodes_activate', page_locale()) }}
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="6" class="cust-table__empty">{{ t('admin_database_nodes_empty', page_locale()) }}</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="ng-data-card">
            <div class="ng-data-card__header">
                <div>
                    <h2 class="ng-data-card__title">{{ t('admin_database_nodes_create', page_locale()) }}</h2>
                    <p class="ng-data-card__sub">{{ t('admin_database_nodes_create_intro', page_locale()) }}</p>
                </div>
            </div>
            <div class="ng-data-card__body">
                <form method="post" action="/admin/databases/nodes" class="flex flex-col gap-4">
                    <div class="form-field">
                        <label class="form-label">{{ t('admin_database_nodes_name', page_locale()) }}</label>
                        <input name="name" type="text" class="form-input" required>
                    </div>
                    <div class="form-field">
                        <label class="form-label">{{ t('admin_database_nodes_engine', page_locale()) }}</label>
                        <select name="engine" class="form-input" required>
                            {% for engine in engines %}
                                <option value="{{ engine }}">{{ engine|upper }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="grid grid-cols-2 gap-3">
                        <div class="form-field">
                            <label class="form-label">{{ t('admin_database_nodes_host', page_locale()) }}</label>
                            <input name="host" type="text" class="form-input" required>
                        </div>
                        <div class="form-field">
                            <label class="form-label">{{ t('admin_database_nodes_port', page_locale()) }}</label>
                            <input name="port" type="number" min="1" max="65535" class="form-input" required>
                        </div>
                    </div>
                    <div class="form-field">
                        <label class="form-label">{{ t('admin_databases_tls_mode', page_locale()) }}</label>
                        <select name="tls_mode" class="form-input">
                            <option value="off">off</option>
                            <option value="required">required</option>
                            <option value="verify_ca">verify_ca</option>
                            <option value="verify_full">verify_full</option>
                        </select>
                    </div>
                    <div class="grid grid-cols-2 gap-3">
                        <div class="form-field">
                            <label class="form-label">{{ t('admin_databases_admin_user', page_locale()) }}</label>
                            <input name="admin_user" type="text" class="form-input">
                        </div>
                        <div class="form-field">
                            <label class="form-label">{{ t('admin_databases_admin_secret', page_locale()) }}</label>
                            <input name="admin_secret" type="password" class="form-input">
                        </div>
                    </div>
                    <div class="form-field">
                        <label class="form-label">{{ t('admin_databases_ca_cert', page_locale()) }}</label>
                        <textarea name="ca_cert" class="form-input"></textarea>
                    </div>
                    <div class="form-field">
                        <label class="form-label">{{ t('admin_databases_tags', page_locale()) }}</label>
                        <input name="tags" type="text" class="form-input">
                    </div>
                    <div class="form-field">
                        <label class="form-label">{{ t('admin_database_nodes_agent', page_locale()) }}</label>
                        <select name="agent_id" class="form-input" required>
                            <option value="">{{ t('admin_database_nodes_agent_placeholder', page_locale()) }}</option>
                            {% for agent in agents %}
                                <option value="{{ agent.id }}">{{ agent.name ?: agent.id }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <button class="ui-button ui-button--primary">
                        {{ t('admin_database_nodes_submit', page_locale()) }}
                    </button>
                </form>
            </div>
        </div>
    </div>

</div>
{% endblock %}
