{% extends 'admin/base.html.twig' %}


{% block content %}
<div class="flex flex-col gap-6">
    <div class="rounded-2xl border border-slate-200 bg-white px-6 py-6 shadow-sm">
        <div class="flex flex-wrap items-center justify-between gap-4">
            <div>
                <h1 class="text-2xl font-semibold text-slate-900">{{ t('admin_databases_title', page_locale()) }}</h1>
                <p class="text-sm text-slate-700">{{ t('admin_databases_intro', page_locale()) }}</p>
            </div>
        </div>
        {% if errors is defined and errors is not empty %}
            <div class="mt-4 rounded-lg border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700">
                <ul class="list-disc space-y-1 pl-5">
                    {% for error in errors %}
                        <li>{{ error }}</li>
                    {% endfor %}
                </ul>
            </div>
        {% endif %}
    </div>

    <div class="grid gap-6 lg:grid-cols-[minmax(0,1.2fr)_minmax(0,0.8fr)]">
        <div class="rounded-2xl border border-slate-200 bg-white shadow-sm">
            <div class="border-b border-slate-200 px-6 py-4">
                <h2 class="text-lg font-semibold text-slate-900">{{ t('admin_databases_list', page_locale()) }}</h2>
                <p class="text-sm text-slate-700">{{ t('admin_databases_list_intro', page_locale()) }}</p>
            </div>
            {% if databases is empty %}
                <div class="px-6 py-6 text-sm text-slate-600">{{ t('admin_databases_empty', page_locale()) }}</div>
            {% else %}
                <div class="overflow-x-auto">
                    <table class="min-w-full text-left text-sm">
                        <thead class="border-b border-slate-200 text-xs uppercase text-slate-600">
                            <tr>
                                <th class="px-6 py-3">{{ t('admin_databases_table_name', page_locale()) }}</th>
                                <th class="px-6 py-3">{{ t('admin_databases_table_engine', page_locale()) }}</th>
                                <th class="px-6 py-3">{{ t('admin_databases_table_host', page_locale()) }}</th>
                                <th class="px-6 py-3">{{ t('admin_databases_table_node', page_locale()) }}</th>
                                <th class="px-6 py-3">{{ t('admin_databases_table_user', page_locale()) }}</th>
                                <th class="px-6 py-3">{{ t('admin_databases_table_customer', page_locale()) }}</th>
                                <th class="px-6 py-3">{{ t('admin_databases_table_updated', page_locale()) }}</th>
                                <th class="px-6 py-3">{{ t('admin_databases_table_actions', page_locale()) }}</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-200">
                            {% for database in databases %}
                                <tr>
                                    <td class="px-6 py-4">
                                        <div class="font-semibold text-slate-900">{{ database.name }}</div>
                                        <div class="text-xs text-slate-500">ID {{ database.id }}</div>
                                    </td>
                                    <td class="px-6 py-4 text-slate-600">{{ database.engine }}</td>
                                    <td class="px-6 py-4 text-slate-600">{{ database.host }}:{{ database.port }}</td>
                                    <td class="px-6 py-4 text-slate-600">
                                        {% if database.node is defined and database.node %}
                                            <div class="font-semibold text-slate-900">{{ database.node.name }}</div>
                                            <div class="text-xs text-slate-500">ID {{ database.node.id }}</div>
                                        {% else %}
                                            <span class="text-xs text-slate-400">{{ t('admin_databases_node_unassigned', page_locale()) }}</span>
                                        {% endif %}
                                    </td>
                                    <td class="px-6 py-4 text-slate-600">{{ database.username }}</td>
                                    <td class="px-6 py-4 text-slate-600">{{ database.customer.email }}</td>
                                    <td class="px-6 py-4 text-slate-600">{{ database.updatedAt|date('Y-m-d H:i') }}</td>
                                    <td class="px-6 py-4">
                                        <form method="post" action="/admin/databases/{{ database.id }}/password" class="flex flex-col gap-2">
                                            <input
                                                type="password"
                                                name="password"
                                                class="w-full rounded-lg border border-slate-200 px-3 py-2 text-xs"
                                                placeholder="{{ t('admin_databases_password_reset', page_locale()) }}"
                                                minlength="8"
                                                required
                                            >
                                            <button class="rounded-lg bg-slate-900 px-3 py-2 text-xs font-semibold text-white hover:bg-slate-800">
                                                {{ t('admin_databases_reset', page_locale()) }}
                                            </button>
                                        </form>
                                        <form method="post" action="/admin/databases/{{ database.id }}/delete" class="mt-3">
                                            <button class="w-full rounded-lg border border-rose-200 px-3 py-2 text-xs font-semibold text-rose-700 hover:bg-rose-50">
                                                {{ t('admin_databases_delete', page_locale()) }}
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </div>

        <div class="rounded-2xl border border-slate-200 bg-white shadow-sm">
            <div class="border-b border-slate-200 px-6 py-4">
                <h2 class="text-lg font-semibold text-slate-900">{{ t('admin_databases_create', page_locale()) }}</h2>
                <p class="text-sm text-slate-700">{{ t('admin_databases_create_intro', page_locale()) }}</p>
            </div>
            <form method="post" action="/admin/databases" class="space-y-4 px-6 py-6">
                <div>
                    <label class="text-sm font-medium text-slate-700">{{ t('admin_databases_customer', page_locale()) }}</label>
                    <select name="customer_id" class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm" required>
                        <option value="">{{ t('admin_databases_customer_placeholder', page_locale()) }}</option>
                        {% for customer in customers %}
                            <option value="{{ customer.id }}">{{ customer.email }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div>
                    <label class="text-sm font-medium text-slate-700">{{ t('admin_databases_node', page_locale()) }}</label>
                    <select name="node_id" class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm" required>
                        <option value="">{{ t('admin_databases_node_placeholder', page_locale()) }}</option>
                        {% for node in nodeCandidates %}
                            <option value="{{ node.id }}">{{ node.name }} ({{ node.engine|upper }} · {{ node.host }}:{{ node.port }})</option>
                        {% endfor %}
                    </select>
                </div>
                <div>
                    <label class="text-sm font-medium text-slate-700">{{ t('admin_databases_name', page_locale()) }}</label>
                    <input name="name" type="text" class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm" required>
                </div>
                <div>
                    <label class="text-sm font-medium text-slate-700">{{ t('admin_databases_username', page_locale()) }}</label>
                    <input name="username" type="text" class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm" required>
                </div>
                <div>
                    <label class="text-sm font-medium text-slate-700">{{ t('admin_databases_password', page_locale()) }}</label>
                    <input name="password" type="password" minlength="8" class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm" required>
                </div>
                <button class="w-full rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-500">
                    {{ t('admin_databases_submit', page_locale()) }}
                </button>
            </form>
        </div>
    </div>

    <div class="grid gap-6 lg:grid-cols-[minmax(0,1.1fr)_minmax(0,0.9fr)]">
        <div class="rounded-2xl border border-slate-200 bg-white shadow-sm">
            <div class="border-b border-slate-200 px-6 py-4">
                <h2 class="text-lg font-semibold text-slate-900">{{ t('admin_database_nodes_title', page_locale()) }}</h2>
                <p class="text-sm text-slate-700">{{ t('admin_database_nodes_intro', page_locale()) }}</p>
            </div>
            {% if databaseNodes is empty %}
                <div class="px-6 py-6 text-sm text-slate-600">{{ t('admin_database_nodes_empty', page_locale()) }}</div>
            {% else %}
                <div class="overflow-x-auto">
                    <table class="min-w-full text-left text-sm">
                        <thead class="border-b border-slate-200 text-xs uppercase text-slate-600">
                            <tr>
                                <th class="px-6 py-3">{{ t('admin_database_nodes_table_name', page_locale()) }}</th>
                                <th class="px-6 py-3">{{ t('admin_database_nodes_table_engine', page_locale()) }}</th>
                                <th class="px-6 py-3">{{ t('admin_database_nodes_table_host', page_locale()) }}</th>
                                <th class="px-6 py-3">{{ t('admin_database_nodes_table_agent', page_locale()) }}</th>
                                <th class="px-6 py-3">{{ t('admin_database_nodes_table_health', page_locale()) }}</th>
                                <th class="px-6 py-3">{{ t('admin_database_nodes_table_actions', page_locale()) }}</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-200">
                            {% for node in databaseNodes %}
                                <tr>
                                    <td class="px-6 py-4">
                                        <div class="font-semibold text-slate-900">{{ node.name }}</div>
                                        <div class="text-xs text-slate-500">ID {{ node.id }}</div>
                                        {% if not node.isActive %}
                                            <div class="mt-1 text-xs text-rose-600">{{ t('admin_database_nodes_inactive', page_locale()) }}</div>
                                        {% endif %}
                                    </td>
                                    <td class="px-6 py-4 text-slate-600">{{ node.engine }}</td>
                                    <td class="px-6 py-4 text-slate-600">{{ node.host }}:{{ node.port }}</td>
                                    <td class="px-6 py-4 text-slate-600">
                                        <div class="font-semibold text-slate-900">{{ node.agent.id }}</div>
                                        <div class="text-xs text-slate-500">{{ node.agent.name ?: t('admin_database_nodes_agent_placeholder', page_locale()) }}</div>
                                    </td>
                                    <td class="px-6 py-4 text-slate-600">
                                        <div class="font-semibold text-slate-900">{{ node.healthStatus }}</div>
                                        <div class="text-xs text-slate-500">
                                            {{ node.lastCheckedAt ? node.lastCheckedAt|date('Y-m-d H:i') : t('admin_database_nodes_never_checked', page_locale()) }}
                                        </div>
                                        {% if node.healthMessage %}
                                            <div class="mt-1 text-xs text-slate-500">{{ node.healthMessage }}</div>
                                        {% endif %}
                                    </td>
                                    <td class="px-6 py-4">
                                        <form method="post" action="/admin/databases/nodes/{{ node.id }}/health" class="mb-2">
                                            <button class="w-full rounded-lg bg-slate-900 px-3 py-2 text-xs font-semibold text-white hover:bg-slate-800">
                                                {{ t('admin_database_nodes_check', page_locale()) }}
                                            </button>
                                        </form>
                                        <form method="post" action="/admin/databases/nodes/{{ node.id }}/toggle">
                                            <button class="w-full rounded-lg border border-slate-200 px-3 py-2 text-xs font-semibold text-slate-700 hover:bg-slate-50">
                                                {{ node.isActive ? t('admin_database_nodes_deactivate', page_locale()) : t('admin_database_nodes_activate', page_locale()) }}
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </div>

        <div class="rounded-2xl border border-slate-200 bg-white shadow-sm">
            <div class="border-b border-slate-200 px-6 py-4">
                <h2 class="text-lg font-semibold text-slate-900">{{ t('admin_database_nodes_create', page_locale()) }}</h2>
                <p class="text-sm text-slate-700">{{ t('admin_database_nodes_create_intro', page_locale()) }}</p>
            </div>
            <form method="post" action="/admin/databases/nodes" class="space-y-4 px-6 py-6">
                <div>
                    <label class="text-sm font-medium text-slate-700">{{ t('admin_database_nodes_name', page_locale()) }}</label>
                    <input name="name" type="text" class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm" required>
                </div>
                <div>
                    <label class="text-sm font-medium text-slate-700">{{ t('admin_database_nodes_engine', page_locale()) }}</label>
                    <select name="engine" class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm" required>
                        {% for engine in engines %}
                            <option value="{{ engine }}">{{ engine|upper }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div>
                    <label class="text-sm font-medium text-slate-700">{{ t('admin_database_nodes_host', page_locale()) }}</label>
                    <input name="host" type="text" class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm" required>
                </div>
                <div>
                    <label class="text-sm font-medium text-slate-700">{{ t('admin_database_nodes_port', page_locale()) }}</label>
                    <input name="port" type="number" min="1" max="65535" class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm" required>
                </div>

                <div>
                    <label class="text-sm font-medium text-slate-700">TLS mode</label>
                    <select name="tls_mode" class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm">
                        <option value="off">off</option>
                        <option value="required">required</option>
                        <option value="verify_ca">verify_ca</option>
                        <option value="verify_full">verify_full</option>
                    </select>
                </div>
                <div>
                    <label class="text-sm font-medium text-slate-700">Admin user</label>
                    <input name="admin_user" type="text" class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm">
                </div>
                <div>
                    <label class="text-sm font-medium text-slate-700">Admin secret</label>
                    <input name="admin_secret" type="password" class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm">
                </div>
                <div>
                    <label class="text-sm font-medium text-slate-700">CA cert (optional)</label>
                    <textarea name="ca_cert" class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm"></textarea>
                </div>
                <div>
                    <label class="text-sm font-medium text-slate-700">Tags (comma-separated)</label>
                    <input name="tags" type="text" class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm">
                </div>
                <div>
                    <label class="text-sm font-medium text-slate-700">{{ t('admin_database_nodes_agent', page_locale()) }}</label>
                    <select name="agent_id" class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm" required>
                        <option value="">{{ t('admin_database_nodes_agent_placeholder', page_locale()) }}</option>
                        {% for agent in agents %}
                            <option value="{{ agent.id }}">{{ agent.name ?: agent.id }}</option>
                        {% endfor %}
                    </select>
                </div>
                <button class="w-full rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-500">
                    {{ t('admin_database_nodes_submit', page_locale()) }}
                </button>
            </form>
        </div>
    </div>
</div>
{% endblock %}
