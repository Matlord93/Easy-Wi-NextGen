{% extends 'admin/base.html.twig' %}

{% set pageTitle = t('admin_webspaces_title', page_locale()) %}
{% set pageSubtitle = t('admin_webspaces_intro', page_locale()) %}
{% set activeNav = 'webspaces' %}

{% block content %}
<div class="flex flex-col gap-6">

    {% if notice %}
        <div class="ng-alert ng-alert--success">{{ notice }}</div>
    {% endif %}
    {% if error %}
        <div class="ng-alert ng-alert--danger">{{ error }}</div>
    {% endif %}

    {# Create form + help text #}
    <div class="ng-layout-2col--equal">
        <div class="ng-data-card">
            <div class="ng-data-card__header">
                <div>
                    <h2 class="ng-data-card__title">{{ t('admin_webspaces_create_title', page_locale()) }}</h2>
                </div>
            </div>
            <div class="ng-data-card__body">
                <form class="flex flex-col gap-4" method="post" action="{{ path('admin_webspaces_create') }}">
                    <div class="form-field">
                        <label class="form-label">{{ t('admin_webspaces_customer_label', page_locale()) }}</label>
                        <select name="customer_id" class="form-input">
                            <option value="">{{ t('admin_webspaces_customer_placeholder', page_locale()) }}</option>
                            {% for customer in customers %}
                                <option value="{{ customer.id }}">{{ customer.email }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="form-field">
                        <label class="form-label">{{ t('admin_webspaces_node_label', page_locale()) }}</label>
                        <select name="node_id" id="ws-node-select" class="form-input">
                            <option value="">{{ t('admin_webspaces_node_placeholder', page_locale()) }}</option>
                            {% for node in nodes %}
                                <option value="{{ node.id }}" data-panel-host="{{ panelHostNodeIds[node.id] is defined ? '1' : '0' }}">
                                    {{ node.name ?? node.id }}{% if panelHostNodeIds[node.id] is defined %} ★ Panel{% endif %}
                                </option>
                            {% endfor %}
                        </select>
                        <div id="ws-panel-host-warning" class="mt-2 hidden ng-alert ng-alert--warning">
                            Dieser Server hostet das Panel. Der Panel-Vhost wird beim Deployment automatisch geschützt und nicht überschrieben.
                        </div>
                    </div>
                    <script>
                    (function () {
                        var sel = document.getElementById('ws-node-select');
                        var warn = document.getElementById('ws-panel-host-warning');
                        if (!sel || !warn) return;
                        function update() {
                            var opt = sel.options[sel.selectedIndex];
                            warn.classList.toggle('hidden', !opt || opt.dataset.panelHost !== '1');
                        }
                        sel.addEventListener('change', update);
                        update();
                    }());
                    </script>
                    <div class="form-field">
                        <label class="form-label">{{ t('admin_webspaces_path_label', page_locale()) }}</label>
                        <input type="text" name="path" placeholder="/var/www/example.com" class="form-input" disabled>
                        <p class="mt-1 text-xs text-slate-600">{{ t('admin_webspaces_path_auto_hint', page_locale()) }}</p>
                    </div>
                    <div class="form-field">
                        <label class="form-label">{{ t('admin_webspaces_docroot_label', page_locale()) }}</label>
                        <input type="text" name="docroot" placeholder="/var/www/example.com/public" class="form-input" disabled>
                        <p class="mt-1 text-xs text-slate-600">{{ t('admin_webspaces_docroot_auto_hint', page_locale()) }}</p>
                    </div>
                    <div class="form-field">
                        <label class="form-label">{{ t('admin_webspaces_domain_label', page_locale()) }}</label>
                        <input type="text" name="domain" placeholder="{{ t('admin_webspaces_domain_placeholder', page_locale()) }}" class="form-input">
                    </div>
                    <div class="grid grid-cols-2 gap-3">
                        <div class="form-field">
                            <label class="form-label">{{ t('admin_webspaces_php_label', page_locale()) }}</label>
                            <select name="php_version" class="form-input">
                                {% for version in phpVersions %}
                                    {% set isDefault = version == defaultPhpVersion %}
                                    <option value="{{ version }}" {% if isDefault or (loop.first and defaultPhpVersion not in phpVersions) %}selected{% endif %}>{{ version }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="form-field">
                            <label class="form-label">{{ t('admin_webspaces_quota_label', page_locale()) }}</label>
                            <input type="number" min="0" name="quota" value="0" class="form-input">
                        </div>
                    </div>
                    <div class="grid grid-cols-2 gap-3">
                        <div class="form-field">
                            <label class="form-label">{{ t('admin_webspaces_disk_limit_label', page_locale()) }}</label>
                            <input type="number" min="0" name="disk_limit_bytes" value="0" class="form-input">
                        </div>
                        <div class="flex items-center gap-4 pt-6">
                            <label class="flex items-center gap-2 text-xs font-semibold uppercase text-slate-700 cursor-pointer">
                                <input type="checkbox" name="ftp_enabled" class="rounded border-slate-300 text-slate-900">
                                {{ t('admin_webspaces_ftp_label', page_locale()) }}
                            </label>
                            <label class="flex items-center gap-2 text-xs font-semibold uppercase text-slate-700 cursor-pointer">
                                <input type="checkbox" name="sftp_enabled" class="rounded border-slate-300 text-slate-900">
                                {{ t('admin_webspaces_sftp_label', page_locale()) }}
                            </label>
                        </div>
                    </div>
                    <button type="submit" class="ui-button ui-button--primary">
                        {{ t('admin_webspaces_create_action', page_locale()) }}
                    </button>
                </form>
            </div>
        </div>

        <div class="ng-data-card">
            <div class="ng-data-card__header">
                <div>
                    <h2 class="ng-data-card__title">{{ t('admin_webspaces_help_title', page_locale()) }}</h2>
                </div>
            </div>
            <div class="ng-data-card__body">
                <ul class="flex flex-col gap-2 text-sm text-slate-600 list-disc pl-5">
                    <li>{{ t('admin_webspaces_help_paths', page_locale()) }}</li>
                    <li>{{ t('admin_webspaces_help_agent', page_locale()) }}</li>
                    <li>{{ t('admin_webspaces_help_security', page_locale()) }}</li>
                </ul>
            </div>
        </div>
    </div>

    {% set statusClasses = {
        'active': 'success',
        'suspended': 'warning',
        'deleted': 'danger'
    } %}

    {# Webspaces list #}
    <div class="ng-data-card">
        <div class="ng-data-card__header">
            <div>
                <h2 class="ng-data-card__title">{{ t('admin_webspaces_list_title', page_locale()) }}</h2>
                <p class="ng-data-card__sub">{{ t('admin_webspaces_list_intro', page_locale()) }}</p>
            </div>
            <div class="ng-data-card__actions">
                <span class="ui-badge ui-badge--neutral">{{ webspaces|length }}</span>
            </div>
        </div>
        <div class="ng-data-card__body ng-data-card__body--flush">
            <div class="cust-ws-table-wrap">
                <table class="cust-table">
                    <thead>
                        <tr>
                            <th>{{ t('admin_label_id', page_locale()) }}</th>
                            <th>{{ t('admin_webspaces_customer_label', page_locale()) }}</th>
                            <th>{{ t('admin_webspaces_node_label', page_locale()) }}</th>
                            <th>{{ t('admin_webspaces_path_label', page_locale()) }}</th>
                            <th>{{ t('admin_webspaces_domain_label', page_locale()) }}</th>
                            <th>{{ t('admin_webspaces_port_label', page_locale()) }}</th>
                            <th>{{ t('admin_webspaces_ddos_label', page_locale()) }}</th>
                            <th>{{ t('admin_webspaces_php_label', page_locale()) }}</th>
                            <th>{{ t('admin_webspaces_status_label', page_locale()) }}</th>
                            <th>Apply</th>
                            <th>{{ t('admin_actions', page_locale()) }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for webspace in webspaces %}
                            <tr>
                                <td class="font-mono text-xs text-slate-700">{{ webspace.id }}</td>
                                <td>
                                    <div class="font-semibold text-slate-900">{{ webspace.customer.email }}</div>
                                    <div class="text-xs text-slate-600">ID {{ webspace.customer.id }}</div>
                                </td>
                                <td>
                                    <div class="font-semibold text-slate-900">{{ webspace.node.name ?? webspace.node.id }}</div>
                                    <div class="text-xs text-slate-600">{{ webspace.node.id }}</div>
                                </td>
                                <td>
                                    <div class="font-semibold text-slate-900">{{ webspace.path }}</div>
                                    <div class="text-xs text-slate-600">{{ webspace.docroot }}</div>
                                </td>
                                <td class="text-xs text-slate-600">{{ webspace.domain }}</td>
                                <td class="text-xs text-slate-600">{{ webspace.assigned_port ?? '-' }}</td>
                                <td>
                                    {% if webspace.ddos_protection_enabled %}
                                        <span class="ui-badge ui-badge--success">{{ t('admin_webspaces_ddos_enabled', page_locale()) }}</span>
                                    {% else %}
                                        <span class="ui-badge ui-badge--neutral">{{ t('admin_webspaces_ddos_disabled', page_locale()) }}</span>
                                    {% endif %}
                                </td>
                                <td class="text-xs text-slate-600">{{ webspace.php_version }}</td>
                                <td>
                                    {% set badgeVariant = statusClasses[webspace.status] ?? 'neutral' %}
                                    <span class="ui-badge ui-badge--{{ badgeVariant }}">{{ webspace.status|title }}</span>
                                </td>
                                <td class="text-xs text-slate-600">
                                    <div>{{ webspace.apply_status|default('unknown')|replace({'_':' '})|title }}</div>
                                    <div>{% if webspace.apply_required %}required{% else %}clean{% endif %}</div>
                                    {% if webspace.last_apply_error_code %}
                                        <div class="text-rose-600">{{ webspace.last_apply_error_code }}</div>
                                    {% endif %}
                                </td>
                                <td>
                                    <div class="flex flex-wrap gap-2">
                                        {% if webspace.status != 'deleted' %}
                                            {% if webspace.status == 'active' %}
                                                <form method="post" action="{{ path('admin_webspaces_suspend', {id: webspace.id}) }}">
                                                    <button class="ui-button ui-button--warning ui-button--sm">
                                                        {{ t('admin_webspaces_suspend_action', page_locale()) }}
                                                    </button>
                                                </form>
                                            {% elseif webspace.status == 'suspended' %}
                                                <form method="post" action="{{ path('admin_webspaces_resume', {id: webspace.id}) }}">
                                                    <button class="ui-button ui-button--primary ui-button--sm">
                                                        {{ t('admin_webspaces_resume_action', page_locale()) }}
                                                    </button>
                                                </form>
                                            {% endif %}
                                            <form method="post" action="{{ path('admin_webspaces_delete', {id: webspace.id}) }}" onsubmit="return confirm('{{ t('admin_webspaces_delete_confirm', page_locale()) }}');">
                                                <button class="ui-button ui-button--danger ui-button--sm">
                                                    {{ t('admin_webspaces_delete_action', page_locale()) }}
                                                </button>
                                            </form>
                                        {% else %}
                                            <span class="text-xs text-slate-500">{{ t('admin_webspaces_deleted_label', page_locale()) }}</span>
                                        {% endif %}
                                    </div>
                                </td>
                            </tr>
                            <tr class="bg-slate-50/60">
                                <td colspan="11" class="px-6 py-5">
                                    <details class="group rounded-xl border border-slate-200 bg-white">
                                        <summary class="cursor-pointer px-4 py-3 text-sm font-semibold text-slate-800 group-open:border-b group-open:border-slate-200">
                                            Domains, SSL, Subdomains und E-Mail-Adressen verwalten
                                        </summary>
                                        <div class="grid gap-5 p-4 xl:grid-cols-3">
                                            <form method="post" action="{{ path('admin_webspaces_domain_add', {id: webspace.id}) }}" class="flex flex-col gap-3 rounded-lg border border-slate-200 p-4">
                                                <h3 class="text-xs font-semibold uppercase text-slate-700">Domain/Subdomain hinzufügen</h3>
                                                <input name="fqdn" placeholder="example.com oder app.example.com" class="form-input" required>
                                                <select name="type" class="form-input">
                                                    <option value="domain">Domain</option>
                                                    <option value="subdomain">Subdomain</option>
                                                </select>
                                                <input name="target_path" placeholder="Zielpfad, z. B. public/shop" class="form-input">
                                                <input name="server_aliases" placeholder="Aliase: www.example.com, m.example.com" class="form-input">
                                                <label class="flex items-center gap-2 text-xs text-slate-700 cursor-pointer"><input type="checkbox" name="redirect_https" value="1"> HTTPS-Redirect</label>
                                                <label class="flex items-center gap-2 text-xs text-slate-700 cursor-pointer"><input type="checkbox" name="redirect_www" value="1"> WWW-Redirect</label>
                                                <label class="flex items-center gap-2 text-xs text-slate-700 cursor-pointer"><input type="checkbox" name="request_tls" value="1"> SSL-Zertifikat direkt anfordern</label>
                                                <input name="ssl_email" type="email" placeholder="admin@example.com (optional)" class="form-input">
                                                <button class="ui-button ui-button--primary ui-button--sm">Hinzufügen</button>
                                            </form>

                                            <div class="flex flex-col gap-3 xl:col-span-2">
                                                <h3 class="text-xs font-semibold uppercase text-slate-700">Zugewiesene Domains</h3>
                                                {% for domain in webspace.domains %}
                                                    <div class="rounded-lg border border-slate-200 bg-white p-4">
                                                        <div class="flex flex-wrap items-center justify-between gap-2">
                                                            <div>
                                                                <div class="font-semibold text-slate-900">{{ domain.name }}</div>
                                                                <div class="text-xs text-slate-500">{{ domain.type }} · {{ domain.status }} · Apply: {{ domain.apply_status }}{% if domain.ssl_expires_at %} · SSL bis {{ domain.ssl_expires_at|date('Y-m-d') }}{% endif %}</div>
                                                            </div>
                                                            <form method="post" action="{{ path('admin_webspaces_domain_delete', {id: webspace.id, domainId: domain.id}) }}" onsubmit="return confirm('Domain entfernen?');">
                                                                <button class="ui-button ui-button--danger ui-button--sm">Entfernen</button>
                                                            </form>
                                                        </div>
                                                        <form method="post" action="{{ path('admin_webspaces_domain_update', {id: webspace.id, domainId: domain.id}) }}" class="mt-3 grid gap-2 md:grid-cols-4">
                                                            <input name="target_path" value="{{ domain.target_path }}" placeholder="Zielpfad" class="form-input md:col-span-1">
                                                            <input name="server_aliases" value="{{ domain.server_aliases }}" placeholder="Subdomains/Aliase" class="form-input md:col-span-2">
                                                            <div class="flex items-center gap-3 text-xs text-slate-700">
                                                                <label class="cursor-pointer"><input type="checkbox" name="redirect_https" value="1" {% if domain.redirect_https %}checked{% endif %}> HTTPS</label>
                                                                <label class="cursor-pointer"><input type="checkbox" name="redirect_www" value="1" {% if domain.redirect_www %}checked{% endif %}> WWW</label>
                                                            </div>
                                                            <button class="ui-button ui-button--ghost ui-button--sm md:col-span-4">Speichern & anwenden</button>
                                                        </form>
                                                        <div class="mt-3 flex flex-wrap gap-2">
                                                            <form method="post" action="{{ path('admin_webspaces_domain_ssl', {id: webspace.id, domainId: domain.id, action: 'issue'}) }}" class="flex gap-2">
                                                                <input name="ssl_email" type="email" placeholder="admin@{{ domain.name }}" class="form-input">
                                                                <button class="ui-button ui-button--primary ui-button--sm">SSL ausstellen</button>
                                                            </form>
                                                            <form method="post" action="{{ path('admin_webspaces_domain_ssl', {id: webspace.id, domainId: domain.id, action: 'renew'}) }}">
                                                                <button class="ui-button ui-button--primary ui-button--sm">SSL erneuern</button>
                                                            </form>
                                                            <form method="post" action="{{ path('admin_webspaces_domain_ssl', {id: webspace.id, domainId: domain.id, action: 'disable'}) }}">
                                                                <button class="ui-button ui-button--ghost ui-button--sm">SSL deaktivieren</button>
                                                            </form>
                                                        </div>
                                                        <form method="post" action="{{ path('admin_webspaces_mailbox_create', {id: webspace.id}) }}" class="mt-3 grid gap-2 border-t border-slate-100 pt-3 md:grid-cols-5">
                                                            <input type="hidden" name="domain_id" value="{{ domain.id }}">
                                                            <input name="local_part" placeholder="info" class="form-input" required>
                                                            <input value="@{{ domain.name }}" disabled class="form-input bg-slate-50">
                                                            <input name="password" type="password" placeholder="Passwort" class="form-input" required>
                                                            <input name="quota" type="number" min="1" value="1024" class="form-input" required>
                                                            <button class="ui-button ui-button--primary ui-button--sm">E-Mail anlegen</button>
                                                        </form>
                                                    </div>
                                                {% else %}
                                                    <div class="cust-empty">Noch keine Domains zugewiesen.</div>
                                                {% endfor %}
                                            </div>
                                        </div>
                                    </details>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="11" class="cust-table__empty">{{ t('admin_webspaces_empty', page_locale()) }}</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            {% set total_pages = (total / per_page)|round(0, 'ceil') %}
            <div class="border-t border-slate-200 px-6 py-3 text-xs text-slate-600">
                Page {{ page }} / {{ total_pages > 0 ? total_pages : 1 }} · {{ total }} items
            </div>
        </div>
    </div>

</div>
{% endblock %}
