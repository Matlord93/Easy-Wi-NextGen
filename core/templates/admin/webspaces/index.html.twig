{% extends 'admin/base.html.twig' %}


{% block content %}
    <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
        <div>
            <h1 class="text-2xl font-semibold">{{ t('admin_webspaces_title', page_locale()) }}</h1>
            <p class="text-sm text-slate-700">{{ t('admin_webspaces_intro', page_locale()) }}</p>
        </div>
    </div>

    {% if notice %}
        <div class="mt-4 rounded-lg border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-700">{{ notice }}</div>
    {% endif %}
    {% if error %}
        <div class="mt-4 rounded-lg border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700">{{ error }}</div>
    {% endif %}

    <div class="mt-6 grid gap-6 lg:grid-cols-2">
        <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
            <h2 class="text-sm font-semibold uppercase text-slate-700">{{ t('admin_webspaces_create_title', page_locale()) }}</h2>
            <form class="mt-4 space-y-4" method="post" action="{{ path('admin_webspaces_create') }}">
                <div>
                    <label class="text-xs font-semibold uppercase text-slate-700">{{ t('admin_webspaces_customer_label', page_locale()) }}</label>
                    <select name="customer_id" class="mt-2 w-full rounded-lg border border-slate-200 bg-slate-50 px-3 py-2 text-sm">
                        <option value="">{{ t('admin_webspaces_customer_placeholder', page_locale()) }}</option>
                        {% for customer in customers %}
                            <option value="{{ customer.id }}">{{ customer.email }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div>
                    <label class="text-xs font-semibold uppercase text-slate-700">{{ t('admin_webspaces_node_label', page_locale()) }}</label>
                    <select name="node_id" id="ws-node-select" class="mt-2 w-full rounded-lg border border-slate-200 bg-slate-50 px-3 py-2 text-sm">
                        <option value="">{{ t('admin_webspaces_node_placeholder', page_locale()) }}</option>
                        {% for node in nodes %}
                            <option value="{{ node.id }}" data-panel-host="{{ panelHostNodeIds[node.id] is defined ? '1' : '0' }}">
                                {{ node.name ?? node.id }}{% if panelHostNodeIds[node.id] is defined %} ★ Panel{% endif %}
                            </option>
                        {% endfor %}
                    </select>
                    <div id="ws-panel-host-warning" class="mt-2 hidden rounded-lg border border-amber-200 bg-amber-50 px-3 py-2 text-xs text-amber-800">
                        Dieser Server hostet das Panel. Der Panel-Vhost wird beim Deployment automatisch geschützt und nicht überschrieben.
                    </div>
                </div>
                <script>
                (function () {
                    var sel = document.getElementById('ws-node-select');
                    var warn = document.getElementById('ws-panel-host-warning');
                    if (!sel || !warn) return;
                    function update() {
                        var opt = sel.options[sel.selectedIndex];
                        warn.classList.toggle('hidden', !opt || opt.dataset.panelHost !== '1');
                    }
                    sel.addEventListener('change', update);
                    update();
                }());
                </script>
                <div>
                    <label class="text-xs font-semibold uppercase text-slate-700">{{ t('admin_webspaces_path_label', page_locale()) }}</label>
                    <input type="text" name="path" placeholder="/var/www/example.com" class="mt-2 w-full rounded-lg border border-slate-200 bg-slate-50 px-3 py-2 text-sm" disabled>
                    <p class="mt-1 text-xs text-slate-600">{{ t('admin_webspaces_path_auto_hint', page_locale()) }}</p>
                </div>
                <div>
                    <label class="text-xs font-semibold uppercase text-slate-700">{{ t('admin_webspaces_docroot_label', page_locale()) }}</label>
                    <input type="text" name="docroot" placeholder="/var/www/example.com/public" class="mt-2 w-full rounded-lg border border-slate-200 bg-slate-50 px-3 py-2 text-sm" disabled>
                    <p class="mt-1 text-xs text-slate-600">{{ t('admin_webspaces_docroot_auto_hint', page_locale()) }}</p>
                </div>
                <div>
                    <label class="text-xs font-semibold uppercase text-slate-700">{{ t('admin_webspaces_domain_label', page_locale()) }}</label>
                    <input type="text" name="domain" placeholder="{{ t('admin_webspaces_domain_placeholder', page_locale()) }}" class="mt-2 w-full rounded-lg border border-slate-200 bg-slate-50 px-3 py-2 text-sm">
                </div>
                <div class="grid gap-2 sm:grid-cols-2">
                    <div>
                        <label class="text-xs font-semibold uppercase text-slate-700">{{ t('admin_webspaces_php_label', page_locale()) }}</label>
                        <select name="php_version" class="mt-2 w-full rounded-lg border border-slate-200 bg-slate-50 px-3 py-2 text-sm">
                            {% for version in phpVersions %}
                                {% set isDefault = version == defaultPhpVersion %}
                                <option value="{{ version }}" {% if isDefault or (loop.first and defaultPhpVersion not in phpVersions) %}selected{% endif %}>{{ version }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <div>
                        <label class="text-xs font-semibold uppercase text-slate-700">{{ t('admin_webspaces_quota_label', page_locale()) }}</label>
                        <input type="number" min="0" name="quota" value="0" class="mt-2 w-full rounded-lg border border-slate-200 bg-slate-50 px-3 py-2 text-sm">
                    </div>
                </div>
                <div class="grid gap-2 sm:grid-cols-2">
                    <div>
                        <label class="text-xs font-semibold uppercase text-slate-700">{{ t('admin_webspaces_disk_limit_label', page_locale()) }}</label>
                        <input type="number" min="0" name="disk_limit_bytes" value="0" class="mt-2 w-full rounded-lg border border-slate-200 bg-slate-50 px-3 py-2 text-sm">
                    </div>
                    <div class="flex items-center gap-4 pt-6">
                        <label class="flex items-center gap-2 text-xs font-semibold uppercase text-slate-700">
                            <input type="checkbox" name="ftp_enabled" class="rounded border-slate-300 text-slate-900">
                            {{ t('admin_webspaces_ftp_label', page_locale()) }}
                        </label>
                        <label class="flex items-center gap-2 text-xs font-semibold uppercase text-slate-700">
                            <input type="checkbox" name="sftp_enabled" class="rounded border-slate-300 text-slate-900">
                            {{ t('admin_webspaces_sftp_label', page_locale()) }}
                        </label>
                    </div>
                </div>
                <button type="submit" class="rounded-lg bg-slate-900 px-4 py-2 text-xs font-semibold text-white transition hover:bg-slate-800">
                    {{ t('admin_webspaces_create_action', page_locale()) }}
                </button>
            </form>
        </div>

        <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
            <h2 class="text-sm font-semibold uppercase text-slate-700">{{ t('admin_webspaces_help_title', page_locale()) }}</h2>
            <ul class="mt-3 space-y-2 text-sm text-slate-600">
                <li>{{ t('admin_webspaces_help_paths', page_locale()) }}</li>
                <li>{{ t('admin_webspaces_help_agent', page_locale()) }}</li>
                <li>{{ t('admin_webspaces_help_security', page_locale()) }}</li>
            </ul>
        </div>
    </div>

    {% set statusClasses = {
        'active': 'bg-emerald-100 text-emerald-700',
        'suspended': 'bg-amber-100 text-amber-700',
        'deleted': 'bg-rose-100 text-rose-700'
    } %}

    <div class="mt-8 rounded-xl border border-slate-200 bg-white shadow-sm">
        <div class="flex items-center justify-between border-b border-slate-200 px-6 py-4">
            <div>
                <h2 class="text-sm font-semibold uppercase text-slate-700">{{ t('admin_webspaces_list_title', page_locale()) }}</h2>
                <p class="text-xs text-slate-600">{{ t('admin_webspaces_list_intro', page_locale()) }}</p>
            </div>
            <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-600">{{ webspaces|length }}</span>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-left text-sm">
                <thead class="bg-slate-50 text-xs uppercase text-slate-500">
                    <tr>
                        <th class="px-6 py-3">{{ t('admin_label_id', page_locale()) }}</th>
                        <th class="px-6 py-3">{{ t('admin_webspaces_customer_label', page_locale()) }}</th>
                        <th class="px-6 py-3">{{ t('admin_webspaces_node_label', page_locale()) }}</th>
                        <th class="px-6 py-3">{{ t('admin_webspaces_path_label', page_locale()) }}</th>
                        <th class="px-6 py-3">{{ t('admin_webspaces_domain_label', page_locale()) }}</th>
                        <th class="px-6 py-3">{{ t('admin_webspaces_port_label', page_locale()) }}</th>
                        <th class="px-6 py-3">{{ t('admin_webspaces_ddos_label', page_locale()) }}</th>
                        <th class="px-6 py-3">{{ t('admin_webspaces_php_label', page_locale()) }}</th>
                        <th class="px-6 py-3">{{ t('admin_webspaces_status_label', page_locale()) }}</th>
                        <th class="px-6 py-3">Apply</th>
                        <th class="px-6 py-3">{{ t('admin_actions', page_locale()) }}</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-200">
                    {% for webspace in webspaces %}
                        <tr>
                            <td class="px-6 py-3 font-mono text-xs text-slate-700">{{ webspace.id }}</td>
                            <td class="px-6 py-3">
                                <div class="text-sm font-semibold text-slate-900">{{ webspace.customer.email }}</div>
                                <div class="text-xs text-slate-600">ID {{ webspace.customer.id }}</div>
                            </td>
                            <td class="px-6 py-3">
                                <div class="text-sm font-semibold text-slate-900">{{ webspace.node.name ?? webspace.node.id }}</div>
                                <div class="text-xs text-slate-600">{{ webspace.node.id }}</div>
                            </td>
                            <td class="px-6 py-3">
                                <div class="text-sm font-semibold text-slate-900">{{ webspace.path }}</div>
                                <div class="text-xs text-slate-600">{{ webspace.docroot }}</div>
                            </td>
                            <td class="px-6 py-3 text-xs text-slate-600">{{ webspace.domain }}</td>
                            <td class="px-6 py-3 text-xs text-slate-600">{{ webspace.assigned_port ?? '-' }}</td>
                            <td class="px-6 py-3 text-xs text-slate-600">
                                {{ webspace.ddos_protection_enabled ? t('admin_webspaces_ddos_enabled', page_locale()) : t('admin_webspaces_ddos_disabled', page_locale()) }}
                            </td>
                            <td class="px-6 py-3 text-xs text-slate-600">{{ webspace.php_version }}</td>
                            <td class="px-6 py-3">
                                {% set statusClass = statusClasses[webspace.status] ?? 'bg-slate-100 text-slate-700' %}
                                <span class="rounded-full px-3 py-1 text-xs font-semibold {{ statusClass }}">{{ webspace.status|title }}</span>
                            </td>
                            <td class="px-6 py-3 text-xs text-slate-600">
                                <div>{{ webspace.apply_status|default('unknown')|replace({'_':' '})|title }}</div>
                                <div>{% if webspace.apply_required %}required{% else %}clean{% endif %}</div>
                                {% if webspace.last_apply_error_code %}<div class="text-rose-600">{{ webspace.last_apply_error_code }}</div>{% endif %}
                            </td>
                            <td class="px-6 py-3">
                                <div class="flex flex-wrap gap-2">
                                    {% if webspace.status != 'deleted' %}
                                        {% if webspace.status == 'active' %}
                                            <form method="post" action="{{ path('admin_webspaces_suspend', {id: webspace.id}) }}">
                                                <button class="rounded-lg border border-amber-200 bg-amber-50 px-3 py-1 text-xs font-semibold text-amber-700">
                                                    {{ t('admin_webspaces_suspend_action', page_locale()) }}
                                                </button>
                                            </form>
                                        {% elseif webspace.status == 'suspended' %}
                                            <form method="post" action="{{ path('admin_webspaces_resume', {id: webspace.id}) }}">
                                                <button class="rounded-lg border border-emerald-200 bg-emerald-50 px-3 py-1 text-xs font-semibold text-emerald-700">
                                                    {{ t('admin_webspaces_resume_action', page_locale()) }}
                                                </button>
                                            </form>
                                        {% endif %}
                                        <form method="post" action="{{ path('admin_webspaces_delete', {id: webspace.id}) }}" onsubmit="return confirm('{{ t('admin_webspaces_delete_confirm', page_locale()) }}');">
                                            <button class="rounded-lg border border-rose-200 bg-rose-50 px-3 py-1 text-xs font-semibold text-rose-700">
                                                {{ t('admin_webspaces_delete_action', page_locale()) }}
                                            </button>
                                        </form>
                                    {% else %}
                                        <span class="text-xs text-slate-500">{{ t('admin_webspaces_deleted_label', page_locale()) }}</span>
                                    {% endif %}
                                </div>
                            </td>
                        </tr>
                        <tr class="bg-slate-50/60">
                            <td colspan="11" class="px-6 py-5">
                                <details class="group rounded-xl border border-slate-200 bg-white">
                                    <summary class="cursor-pointer px-4 py-3 text-sm font-semibold text-slate-800 group-open:border-b group-open:border-slate-200">
                                        Domains, SSL, Subdomains und E-Mail-Adressen verwalten
                                    </summary>
                                    <div class="grid gap-5 p-4 xl:grid-cols-3">
                                        <form method="post" action="{{ path('admin_webspaces_domain_add', {id: webspace.id}) }}" class="space-y-3 rounded-lg border border-slate-200 p-4">
                                            <h3 class="text-xs font-semibold uppercase text-slate-700">Domain/Subdomain hinzufügen</h3>
                                            <input name="fqdn" placeholder="example.com oder app.example.com" class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm" required>
                                            <select name="type" class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm">
                                                <option value="domain">Domain</option>
                                                <option value="subdomain">Subdomain</option>
                                            </select>
                                            <input name="target_path" placeholder="Zielpfad, z. B. public/shop" class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm">
                                            <input name="server_aliases" placeholder="Aliase: www.example.com, m.example.com" class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm">
                                            <label class="flex items-center gap-2 text-xs text-slate-700"><input type="checkbox" name="redirect_https" value="1"> HTTPS-Redirect</label>
                                            <label class="flex items-center gap-2 text-xs text-slate-700"><input type="checkbox" name="redirect_www" value="1"> WWW-Redirect</label>
                                            <label class="flex items-center gap-2 text-xs text-slate-700"><input type="checkbox" name="request_tls" value="1"> SSL-Zertifikat direkt anfordern</label>
                                            <input name="ssl_email" type="email" placeholder="admin@example.com (optional)" class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm">
                                            <button class="rounded-lg bg-slate-900 px-3 py-2 text-xs font-semibold text-white">Hinzufügen</button>
                                        </form>

                                        <div class="space-y-3 xl:col-span-2">
                                            <h3 class="text-xs font-semibold uppercase text-slate-700">Zugewiesene Domains</h3>
                                            {% for domain in webspace.domains %}
                                                <div class="rounded-lg border border-slate-200 bg-white p-4">
                                                    <div class="flex flex-wrap items-center justify-between gap-2">
                                                        <div>
                                                            <div class="font-semibold text-slate-900">{{ domain.name }}</div>
                                                            <div class="text-xs text-slate-500">{{ domain.type }} · {{ domain.status }} · Apply: {{ domain.apply_status }}{% if domain.ssl_expires_at %} · SSL bis {{ domain.ssl_expires_at|date('Y-m-d') }}{% endif %}</div>
                                                        </div>
                                                        <form method="post" action="{{ path('admin_webspaces_domain_delete', {id: webspace.id, domainId: domain.id}) }}" onsubmit="return confirm('Domain entfernen?');">
                                                            <button class="rounded-lg border border-rose-200 bg-rose-50 px-3 py-1 text-xs font-semibold text-rose-700">Entfernen</button>
                                                        </form>
                                                    </div>
                                                    <form method="post" action="{{ path('admin_webspaces_domain_update', {id: webspace.id, domainId: domain.id}) }}" class="mt-3 grid gap-2 md:grid-cols-4">
                                                        <input name="target_path" value="{{ domain.target_path }}" placeholder="Zielpfad" class="rounded-lg border border-slate-200 px-3 py-2 text-xs md:col-span-1">
                                                        <input name="server_aliases" value="{{ domain.server_aliases }}" placeholder="Subdomains/Aliase" class="rounded-lg border border-slate-200 px-3 py-2 text-xs md:col-span-2">
                                                        <div class="flex items-center gap-3 text-xs text-slate-700">
                                                            <label><input type="checkbox" name="redirect_https" value="1" {% if domain.redirect_https %}checked{% endif %}> HTTPS</label>
                                                            <label><input type="checkbox" name="redirect_www" value="1" {% if domain.redirect_www %}checked{% endif %}> WWW</label>
                                                        </div>
                                                        <button class="rounded-lg border border-slate-200 px-3 py-2 text-xs font-semibold text-slate-700 md:col-span-4">Speichern & anwenden</button>
                                                    </form>
                                                    <div class="mt-3 flex flex-wrap gap-2">
                                                        <form method="post" action="{{ path('admin_webspaces_domain_ssl', {id: webspace.id, domainId: domain.id, action: 'issue'}) }}" class="flex gap-2">
                                                            <input name="ssl_email" type="email" placeholder="admin@{{ domain.name }}" class="rounded-lg border border-slate-200 px-3 py-1 text-xs">
                                                            <button class="rounded-lg bg-indigo-600 px-3 py-1 text-xs font-semibold text-white">SSL ausstellen</button>
                                                        </form>
                                                        <form method="post" action="{{ path('admin_webspaces_domain_ssl', {id: webspace.id, domainId: domain.id, action: 'renew'}) }}">
                                                            <button class="rounded-lg bg-emerald-600 px-3 py-1 text-xs font-semibold text-white">SSL erneuern</button>
                                                        </form>
                                                        <form method="post" action="{{ path('admin_webspaces_domain_ssl', {id: webspace.id, domainId: domain.id, action: 'disable'}) }}">
                                                            <button class="rounded-lg bg-slate-700 px-3 py-1 text-xs font-semibold text-white">SSL deaktivieren</button>
                                                        </form>
                                                    </div>
                                                    <form method="post" action="{{ path('admin_webspaces_mailbox_create', {id: webspace.id}) }}" class="mt-3 grid gap-2 border-t border-slate-100 pt-3 md:grid-cols-5">
                                                        <input type="hidden" name="domain_id" value="{{ domain.id }}">
                                                        <input name="local_part" placeholder="info" class="rounded-lg border border-slate-200 px-3 py-2 text-xs" required>
                                                        <input value="@{{ domain.name }}" disabled class="rounded-lg border border-slate-200 bg-slate-50 px-3 py-2 text-xs">
                                                        <input name="password" type="password" placeholder="Passwort" class="rounded-lg border border-slate-200 px-3 py-2 text-xs" required>
                                                        <input name="quota" type="number" min="1" value="1024" class="rounded-lg border border-slate-200 px-3 py-2 text-xs" required>
                                                        <button class="rounded-lg bg-slate-900 px-3 py-2 text-xs font-semibold text-white">E-Mail anlegen</button>
                                                    </form>
                                                </div>
                                            {% else %}
                                                <div class="rounded-lg border border-dashed border-slate-300 p-4 text-sm text-slate-600">Noch keine Domains zugewiesen.</div>
                                            {% endfor %}
                                        </div>
                                    </div>
                                </details>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="11" class="px-6 py-6 text-center text-sm text-slate-600">{{ t('admin_webspaces_empty', page_locale()) }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
        {% set total_pages = (total / per_page)|round(0, 'ceil') %}
        <div class="border-t border-slate-200 px-6 py-3 text-xs text-slate-600">
            Page {{ page }} / {{ total_pages > 0 ? total_pages : 1 }} · {{ total }} items
        </div>
    </div>
{% endblock %}
