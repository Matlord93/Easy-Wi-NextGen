{% extends 'admin/base.html.twig' %}

{% block title %}{{ t('admin_sinusbot_node_add_title', page_locale()) }} · Easy-Wi NextGen{% endblock %}

{% block content %}
{% set locale = page_locale() %}

<div style="display:flex;flex-direction:column;gap:20px;">

    {# ── Hero ── #}
    <section class="ng-card" style="overflow:hidden;">
        <div class="tkt-hero">
            <div class="tkt-hero__inner">
                <div>
                    <div class="tkt-hero__pill">
                        <span class="tkt-hero__pill-dot" style="background:#f97316;"></span>
                        SinusBot
                    </div>
                    <h1 class="tkt-hero__title" style="margin-top:10px;">{{ t('admin_sinusbot_node_add_title', locale) }}</h1>
                    <p class="tkt-hero__sub">{{ t('admin_sinusbot_node_add_desc', locale) }}</p>
                </div>
                <div>
                    <a class="ui-button ui-button--ghost ui-button--sm" href="/admin/sinusbot/nodes">{{ t('admin_sinusbot_back_to_overview', locale) }}</a>
                </div>
            </div>
        </div>
    </section>

    {% for message in app.flashes('error') %}
        <div class="ng-alert ng-alert--danger">{{ t(message, locale) }}</div>
    {% endfor %}

    {{ form_start(form, {'attr': {'id': 'sinusbot-node-form'}}) }}

    {# ── Mode selection ── #}
    <div class="ng-data-card">
        <div class="ng-data-card__header">
            <div style="display:flex;align-items:center;gap:10px;">
                <span style="display:flex;align-items:center;justify-content:center;width:34px;height:34px;border-radius:8px;background:rgba(249,115,22,.12);flex-shrink:0;">
                    <svg width="17" height="17" fill="none" viewBox="0 0 24 24" stroke="#f97316" stroke-width="2"><circle cx="12" cy="12" r="10"/><path stroke-linecap="round" d="M12 8v4l3 3"/></svg>
                </span>
                <div>
                    <h2 class="ng-data-card__title">{{ t('admin_sinusbot_node_mode_title', locale) }}</h2>
                    <p class="ng-data-card__sub">{{ t('admin_sinusbot_node_mode_desc', locale) }}</p>
                </div>
            </div>
        </div>
        <div class="ng-data-card__body">
            <div id="mode-selector" style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
                <label id="mode-solo-card" class="sinusbot-mode-card" style="cursor:pointer;border:2px solid var(--ng-border);border-radius:12px;padding:20px;display:flex;flex-direction:column;gap:12px;background:var(--ng-surface);transition:border-color .15s,box-shadow .15s;">
                    <input type="radio" name="sinusbot_node[instanceMode]" value="solo" style="display:none;">
                    <div style="display:flex;align-items:center;gap:14px;">
                        <div style="width:44px;height:44px;border-radius:12px;background:linear-gradient(135deg,#6366f1,#818cf8);display:flex;align-items:center;justify-content:center;flex-shrink:0;box-shadow:0 4px 12px rgba(99,102,241,.3);">
                            <svg width="22" height="22" fill="none" viewBox="0 0 24 24"><circle cx="12" cy="8" r="4" stroke="#fff" stroke-width="2"/><path d="M4 20c0-4 3.582-7 8-7s8 3 8 7" stroke="#fff" stroke-width="2" stroke-linecap="round"/></svg>
                        </div>
                        <div>
                            <div style="font-weight:700;font-size:15px;color:var(--ng-text);">{{ t('admin_sinusbot_solo_title', locale) }}</div>
                            <div style="font-size:12px;color:var(--ng-text-muted);margin-top:2px;">{{ t('admin_sinusbot_solo_subtitle', locale) }}</div>
                        </div>
                    </div>
                    <p style="font-size:13px;color:var(--ng-text-muted);margin:0;line-height:1.6;padding-top:4px;border-top:1px solid var(--ng-border);">{{ t('admin_sinusbot_solo_desc', locale) }}</p>
                </label>

                <label id="mode-multi-card" class="sinusbot-mode-card" style="cursor:pointer;border:2px solid var(--ng-primary,#6366f1);border-radius:12px;padding:20px;display:flex;flex-direction:column;gap:12px;background:var(--ng-surface);transition:border-color .15s,box-shadow .15s;box-shadow:0 0 0 3px rgba(99,102,241,.12);">
                    <input type="radio" name="sinusbot_node[instanceMode]" value="multi" checked style="display:none;">
                    <div style="display:flex;align-items:center;gap:14px;">
                        <div style="width:44px;height:44px;border-radius:12px;background:linear-gradient(135deg,#10b981,#34d399);display:flex;align-items:center;justify-content:center;flex-shrink:0;box-shadow:0 4px 12px rgba(16,185,129,.3);">
                            <svg width="22" height="22" fill="none" viewBox="0 0 24 24"><circle cx="7" cy="9" r="3" stroke="#fff" stroke-width="2"/><circle cx="17" cy="9" r="3" stroke="#fff" stroke-width="2"/><path d="M1 19c0-3 2.686-5 6-5M17 14c3.314 0 6 2 6 5" stroke="#fff" stroke-width="2" stroke-linecap="round"/><path d="M9 19c0-3.314 1.343-5 3-5s3 1.686 3 5" stroke="#fff" stroke-width="2" stroke-linecap="round"/></svg>
                        </div>
                        <div>
                            <div style="font-weight:700;font-size:15px;color:var(--ng-text);">{{ t('admin_sinusbot_multi_title', locale) }}</div>
                            <div style="font-size:12px;color:var(--ng-text-muted);margin-top:2px;">{{ t('admin_sinusbot_multi_subtitle', locale) }}</div>
                        </div>
                    </div>
                    <p style="font-size:13px;color:var(--ng-text-muted);margin:0;line-height:1.6;padding-top:4px;border-top:1px solid var(--ng-border);">{{ t('admin_sinusbot_multi_desc', locale) }}</p>
                </label>
            </div>
            <div style="display:none;">{{ form_widget(form.instanceMode) }}</div>
        </div>
    </div>

    {# ── Basic configuration ── #}
    <div class="ng-data-card">
        <div class="ng-data-card__header">
            <div style="display:flex;align-items:center;gap:10px;">
                <span style="display:flex;align-items:center;justify-content:center;width:34px;height:34px;border-radius:8px;background:rgba(249,115,22,.12);flex-shrink:0;">
                    <svg width="17" height="17" fill="none" viewBox="0 0 24 24" stroke="#f97316" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="3"/><path stroke-linecap="round" d="M9 9h6M9 12h6M9 15h4"/></svg>
                </span>
                <div>
                    <h2 class="ng-data-card__title">{{ t('admin_sinusbot_basic_config_title', locale) }}</h2>
                    <p class="ng-data-card__sub">{{ t('admin_sinusbot_basic_config_desc', locale) }}</p>
                </div>
            </div>
        </div>
        <div class="ng-data-card__body">
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
                <div>
                    {{ form_row(form.name, { label: t('admin_sinusbot_node_form_name', locale) }) }}
                </div>
                <div>
                    {{ form_row(form.customerId, { label: t('admin_sinusbot_customer_label', locale) }) }}
                </div>
                <div style="grid-column:span 2;">
                    {{ form_row(form.downloadUrl, { label: t('admin_sinusbot_node_form_download_url', locale) }) }}
                    <p style="margin:-8px 0 0;padding:8px 12px;border-radius:0 0 6px 6px;background:rgba(249,115,22,.06);border:1px solid rgba(249,115,22,.2);border-top:none;color:var(--ng-text-muted);font-size:12px;display:flex;align-items:center;gap:6px;">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;color:#f97316;"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                        {{ t('admin_sinusbot_node_form_download_url', locale) }}
                    </p>
                </div>
            </div>
        </div>
    </div>

    {# ── Paths & Network ── #}
    <div class="ng-data-card">
        <div class="ng-data-card__header">
            <div style="display:flex;align-items:center;gap:10px;">
                <span style="display:flex;align-items:center;justify-content:center;width:34px;height:34px;border-radius:8px;background:rgba(249,115,22,.12);flex-shrink:0;">
                    <svg width="17" height="17" fill="none" viewBox="0 0 24 24" stroke="#f97316" stroke-width="2"><path stroke-linecap="round" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/></svg>
                </span>
                <div>
                    <h2 class="ng-data-card__title">{{ t('admin_sinusbot_paths_title', locale) }}</h2>
                    <p class="ng-data-card__sub">{{ t('admin_sinusbot_paths_desc', locale) }}</p>
                </div>
            </div>
        </div>
        <div class="ng-data-card__body">
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
                <div>
                    {{ form_row(form.installPath, { label: t('admin_sinusbot_install_path_label', locale) }) }}
                </div>
                <div id="instance-root-row">
                    {{ form_row(form.instanceRoot, { label: t('admin_sinusbot_instance_root_form_label', locale) }) }}
                </div>
                <div>
                    {{ form_row(form.webBindIp, { label: t('admin_sinusbot_web_bind_label', locale) }) }}
                </div>
                <div>
                    {{ form_row(form.webPortBase, { label: t('admin_sinusbot_node_form_web_port_base', locale) }) }}
                </div>
            </div>
        </div>
    </div>

    {# ── Actions ── #}
    <div style="display:flex;justify-content:flex-end;gap:12px;padding-bottom:4px;">
        <a class="ui-button ui-button--ghost" href="/admin/sinusbot/nodes">{{ t('admin_sinusbot_back_to_overview', locale) }}</a>
        <button class="ui-button ui-button--primary" type="submit">{{ t('admin_sinusbot_node_save', locale) }}</button>
    </div>

    {{ form_end(form) }}

</div>

<style>
.sinusbot-mode-card:hover {
    border-color: var(--ng-primary, #6366f1) !important;
    box-shadow: 0 0 0 3px rgba(99,102,241,.08) !important;
}
</style>

<script>
(function () {
    const soloCard  = document.getElementById('mode-solo-card');
    const multiCard = document.getElementById('mode-multi-card');
    const soloRadio  = soloCard.querySelector('input[type=radio]');
    const multiRadio = multiCard.querySelector('input[type=radio]');
    const instanceRootRow = document.getElementById('instance-root-row');

    function updateMode(mode) {
        const isMulti = mode === 'multi';
        soloCard.style.borderColor  = isMulti ? 'var(--ng-border)' : 'var(--ng-primary,#6366f1)';
        soloCard.style.boxShadow    = isMulti ? 'none' : '0 0 0 3px rgba(99,102,241,.12)';
        multiCard.style.borderColor = isMulti ? 'var(--ng-primary,#6366f1)' : 'var(--ng-border)';
        multiCard.style.boxShadow   = isMulti ? '0 0 0 3px rgba(99,102,241,.12)' : 'none';
        instanceRootRow.style.display = isMulti ? '' : 'none';
        soloRadio.checked  = !isMulti;
        multiRadio.checked = isMulti;
        const sel = document.querySelector('select[name="sinusbot_node[instanceMode]"]');
        if (sel) sel.value = mode;
    }

    updateMode('multi');
    soloCard.addEventListener('click', () => updateMode('solo'));
    multiCard.addEventListener('click', () => updateMode('multi'));
})();
</script>

{% endblock %}
