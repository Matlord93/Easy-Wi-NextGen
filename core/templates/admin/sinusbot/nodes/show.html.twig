{% extends 'admin/base.html.twig' %}


{% block content %}
{% set locale = page_locale() %}
    <div class="sinusbot-page">
        <div class="sinusbot-header">
            <div>
                <h1>{{ node.name }}</h1>
                <p>{{ t('admin_sinusbot_intro', locale) }}</p>
            </div>
            <div class="sinusbot-actions">
                <a class="sinusbot-link" href="/admin/sinusbot/nodes">{{ t('admin_sinusbot_back_to_overview', locale) }}</a>
                <form method="post" action="/admin/sinusbot/nodes/{{ node.id }}/delete" onsubmit="return confirm('{{ t('admin_sinusbot_delete_confirm', locale) }}');">
                    <input type="hidden" name="_token" value="{{ csrf.delete }}">
                    <button class="sinusbot-button" type="submit">{{ t('admin_sinusbot_delete', locale) }}</button>
                </form>
            </div>
        </div>

        {% for message in app.flashes('success') %}
            <div class="sinusbot-alert sinusbot-alert-success">{{ t(message, page_locale()) }}</div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="sinusbot-alert sinusbot-alert-error">{{ t(message, page_locale()) }}</div>
        {% endfor %}

        {% set runtimeLabel = node.running ? 'Online' : 'Offline' %}
        {% set runtimeClass = node.running ? 'sinusbot-pill--success' : 'sinusbot-pill--danger' %}

        <div class="sinusbot-grid">
            <div class="sinusbot-card">
                <div class="sinusbot-card-header">
                    <div>
                        <h2>{{ t('admin_sinusbot_installation_title', locale) }}</h2>
                        <p class="sinusbot-muted">{{ t('admin_sinusbot_service_desc', locale) }}</p>
                    </div>
                    <div class="sinusbot-status-group">
                        <span class="sinusbot-pill">{{ node.installStatus }}</span>
                        <span class="sinusbot-pill {{ runtimeClass }}">{{ runtimeLabel }}</span>
                    </div>
                </div>
                <div class="sinusbot-meta">
                    <div><strong>{{ t('admin_sinusbot_status_label', locale) }}</strong> {{ node.installStatus }}</div>
                    <div><strong>{{ t('admin_sinusbot_runtime', locale) }}:</strong> {{ node.running ? t('admin_sinusbot_start_instance', locale) : t('admin_sinusbot_stop_instance', locale) }}</div>
                    <div><strong>{{ t('admin_sinusbot_version_label', locale) }}</strong> {{ node.installedVersion ?? '–' }}</div>
                    <div><strong>{{ t('admin_sinusbot_last_error_label', locale) }}</strong> {{ node.lastError ?? '–' }}</div>
                </div>
                <div class="sinusbot-actions">
                    <form method="post" action="/admin/sinusbot/nodes/{{ node.id }}/install">
                        <input type="hidden" name="_token" value="{{ csrf.install }}">
                        <button class="sinusbot-button" type="submit" data-loading-text="Installiere…">{{ t('admin_sinusbot_install_repair', locale) }}</button>
                    </form>
                    <form method="post" action="/admin/sinusbot/nodes/{{ node.id }}/refresh">
                        <input type="hidden" name="_token" value="{{ csrf.refresh }}">
                        <button class="sinusbot-button" type="submit" data-loading-text="Aktualisiere…">{{ t('admin_sinusbot_refresh_status', locale) }}</button>
                    </form>
                </div>
                <div class="sinusbot-actions">
                    <form method="post" action="/admin/sinusbot/nodes/{{ node.id }}/start">
                        <input type="hidden" name="_token" value="{{ csrf.start }}">
                        <button class="sinusbot-button" type="submit" data-loading-text="Starte…">{{ t('admin_sinusbot_start', locale) }}</button>
                    </form>
                    <form method="post" action="/admin/sinusbot/nodes/{{ node.id }}/stop">
                        <input type="hidden" name="_token" value="{{ csrf.stop }}">
                        <button class="sinusbot-button" type="submit" data-loading-text="Stoppe…">{{ t('admin_sinusbot_stop', locale) }}</button>
                    </form>
                    <form method="post" action="/admin/sinusbot/nodes/{{ node.id }}/restart">
                        <input type="hidden" name="_token" value="{{ csrf.restart }}">
                        <button class="sinusbot-button" type="submit" data-loading-text="Starte neu…">{{ t('admin_sinusbot_restart', locale) }}</button>
                    </form>
                </div>
            </div>

            <div class="sinusbot-card">
                <div class="sinusbot-card-header">
                    <div>
                        <h2>{{ t('admin_sinusbot_customer_instances_title', locale) }}</h2>
                        <p class="sinusbot-muted">{{ t('admin_sinusbot_customer_instances_desc', locale) }}</p>
                    </div>
                </div>
                <form class="sinusbot-form" method="post" action="/admin/sinusbot/instances/create">
                    <input type="hidden" name="_token" value="{{ csrf.instance_create }}">
                    <input type="hidden" name="node_id" value="{{ node.id }}">
                    <div class="sinusbot-grid">
                        <div>
                            <label for="customer_id">{{ t('admin_sinusbot_customer_label', locale) }}</label>
                            <select id="customer_id" name="customer_id" required>
                                <option value="">{{ t('admin_sinusbot_select_customer', locale) }}</option>
                                {% for customer in customers %}
                                    <option value="{{ customer.id }}">{{ customer.email }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div>
                            <label for="quota">{{ t('admin_sinusbot_quota_label', locale) }}</label>
                            <input id="quota" name="quota" type="number" min="{{ quota_min }}" max="{{ quota_max }}" value="{{ quota_min }}" required>
                        </div>
                        <div>
                            <label for="username">{{ t('admin_sinusbot_username_optional', locale) }}</label>
                            <input id="username" name="username" type="text" placeholder="auto">
                        </div>
                    </div>
                    <button class="sinusbot-button" type="submit">{{ t('admin_sinusbot_create_instance', locale) }}</button>
                </form>

                {% if instances is not empty %}
                    <div class="sinusbot-instance-list">
                        {% for instance in instances %}
                            {% set instanceStatusLabel = instance.status == 'running' ? t('admin_sinusbot_instance_online', locale) : (instance.status == 'stopped' ? t('admin_sinusbot_instance_offline', locale) : t('customer_ts_unknown', locale)) %}
                            {% set instanceStatusClass = instance.status == 'running' ? 'sinusbot-pill--success' : (instance.status == 'stopped' ? 'sinusbot-pill--danger' : 'sinusbot-pill--warning') %}
                            {% set instancePassword = instance_passwords[instance.id] ?? null %}
                            {% set botId = instance.botId ?? instance.instanceId %}
                            <div class="sinusbot-instance-card">
                                <div class="sinusbot-card-header">
                                    <div>
                                        <h3>{{ instance.customer ? instance.customer.email : t('admin_sinusbot_unknown_customer', locale) }}</h3>
                                        <p class="sinusbot-muted">{{ t('admin_sinusbot_instance_id_label', locale) }} {{ instance.instanceId }}</p>
                                    </div>
                                    <span class="sinusbot-pill {{ instanceStatusClass }}">{{ instanceStatusLabel }}</span>
                                </div>
                                <div class="sinusbot-instance-grid">
                                    <div class="sinusbot-field">
                                        <span class="sinusbot-field__label">{{ t('admin_sinusbot_status', locale) }}</span>
                                        <span class="sinusbot-field__value">{{ instance.status }}</span>
                                    </div>
                                    <div class="sinusbot-field">
                                        <span class="sinusbot-field__label">{{ t('admin_sinusbot_last_check', locale) }}</span>
                                        <span class="sinusbot-field__value">
                                            {{ instance.lastSeenAt ? instance.lastSeenAt|date('Y-m-d H:i') : '—' }}
                                        </span>
                                    </div>
                                    <div class="sinusbot-field">
                                        <span class="sinusbot-field__label">{{ t('admin_sinusbot_bot_id', locale) }}</span>
                                        {% if botId %}
                                            <span class="sinusbot-field__value">{{ botId }}</span>
                                        {% else %}
                                            <span class="sinusbot-field__value">—</span>
                                            <span class="sinusbot-hint">{{ t('admin_sinusbot_no_bot_id', locale) }}</span>
                                        {% endif %}
                                    </div>
                                    <div class="sinusbot-field">
                                        <span class="sinusbot-field__label">{{ t('admin_sinusbot_manage_url', locale) }}</span>
                                        {% if instance.manageUrl %}
                                            <div class="sinusbot-field__value">
                                                <a class="sinusbot-link" href="{{ instance.manageUrl }}" target="_blank" rel="noopener noreferrer">{{ instance.manageUrl }}</a>
                                                <button class="sinusbot-copy" type="button" data-sinusbot-copy="{{ instance.manageUrl }}">{{ t('admin_sinusbot_copy', locale) }}</button>
                                            </div>
                                        {% else %}
                                            <span class="sinusbot-field__value">—</span>
                                            <span class="sinusbot-hint">{{ t('admin_sinusbot_manage_url_missing', locale) }}</span>
                                        {% endif %}
                                    </div>
                                    <div class="sinusbot-field">
                                        <span class="sinusbot-field__label">{{ t('admin_sinusbot_username_field', locale) }}</span>
                                        {% if instance.sinusbotUsername %}
                                            <div class="sinusbot-field__value">
                                                <span>{{ instance.sinusbotUsername }}</span>
                                                <button class="sinusbot-copy" type="button" data-sinusbot-copy="{{ instance.sinusbotUsername }}">{{ t('admin_sinusbot_copy', locale) }}</button>
                                            </div>
                                        {% else %}
                                            <span class="sinusbot-field__value">—</span>
                                            <span class="sinusbot-hint">{{ t('admin_sinusbot_no_username', locale) }}</span>
                                        {% endif %}
                                    </div>
                                    <div class="sinusbot-field">
                                        <span class="sinusbot-field__label">{{ t('admin_sinusbot_password', locale) }}</span>
                                        {% if instancePassword %}
                                            <div class="sinusbot-field__value sinusbot-secret-row">
                                                <span class="sinusbot-secret" data-sinusbot-secret="{{ instancePassword }}" data-label-reveal="{{ t('admin_sinusbot_password_reveal', locale) }}" data-label-hide="{{ t('admin_sinusbot_password_hide', locale) }}">••••••••</span>
                                                <button class="sinusbot-button sinusbot-button--ghost" type="button" data-sinusbot-reveal>{{ t('admin_sinusbot_password_reveal', locale) }}</button>
                                            </div>
                                        {% else %}
                                            <span class="sinusbot-field__value">—</span>
                                            <span class="sinusbot-hint">{{ t('admin_sinusbot_password_missing', locale) }}</span>
                                        {% endif %}
                                    </div>
                                    <div class="sinusbot-field">
                                        <span class="sinusbot-field__label">{{ t('admin_sinusbot_quota', locale) }}</span>
                                        <span class="sinusbot-field__value">{{ instance.botQuota }}</span>
                                    </div>
                                </div>
                                <div class="sinusbot-actions">
                                    <form method="post" action="/admin/sinusbot/instances/{{ instance.id }}/start">
                                        <input type="hidden" name="_token" value="{{ instance_csrf[instance.id].start }}">
                                        <button class="sinusbot-button" type="submit" data-loading-text="Starte…">{{ t('admin_sinusbot_start_instance', locale) }}</button>
                                    </form>
                                    <form method="post" action="/admin/sinusbot/instances/{{ instance.id }}/stop">
                                        <input type="hidden" name="_token" value="{{ instance_csrf[instance.id].stop }}">
                                        <button class="sinusbot-button" type="submit" data-loading-text="Stoppe…">{{ t('admin_sinusbot_stop_instance', locale) }}</button>
                                    </form>
                                    <form method="post" action="/admin/sinusbot/instances/{{ instance.id }}/restart">
                                        <input type="hidden" name="_token" value="{{ instance_csrf[instance.id].restart }}">
                                        <button class="sinusbot-button" type="submit" data-loading-text="Starte neu…">{{ t('admin_sinusbot_restart_instance', locale) }}</button>
                                    </form>
                                    <form method="post" action="/admin/sinusbot/instances/{{ instance.id }}/reset-password">
                                        <input type="hidden" name="_token" value="{{ instance_csrf[instance.id].reset }}">
                                        <button class="sinusbot-button" type="submit" data-loading-text="{{ t('admin_sinusbot_reset_loading', page_locale()) }}">{{ t('admin_sinusbot_password_reset_btn', locale) }}</button>
                                    </form>
                                </div>
                                <form class="sinusbot-form sinusbot-form-inline" method="post" action="/admin/sinusbot/instances/{{ instance.id }}/quota">
                                    <input type="hidden" name="_token" value="{{ instance_csrf[instance.id].quota }}">
                                    <label for="quota_{{ instance.id }}">{{ t('admin_sinusbot_quota_label', locale) }}</label>
                                    <input id="quota_{{ instance.id }}" name="quota" type="number" min="{{ quota_min }}" max="{{ quota_max }}" value="{{ instance.botQuota }}" required>
                                    <button class="sinusbot-button" type="submit">{{ t('admin_sinusbot_quota_update', locale) }}</button>
                                </form>
                                <form class="sinusbot-form" method="post" action="/admin/sinusbot/instances/{{ instance.id }}/delete" onsubmit="return confirm('{{ t('admin_sinusbot_instance_delete_confirm', locale) }}');">
                                    <input type="hidden" name="_token" value="{{ instance_csrf[instance.id].delete }}">
                                    <div class="sinusbot-actions">
                                        <label>
                                            <input type="radio" name="mode" value="delete" checked>
                                            {{ t('admin_sinusbot_delete_with_agent', locale) }}
                                        </label>
                                        <label>
                                            <input type="radio" name="mode" value="detach">
                                            {{ t('admin_sinusbot_detach_only', locale) }}
                                        </label>
                                        <button class="sinusbot-button" type="submit">{{ t('admin_sinusbot_delete_instance', locale) }}</button>
                                    </div>
                                </form>
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <p class="sinusbot-muted">{{ t('admin_sinusbot_no_instances', locale) }}</p>
                {% endif %}
            </div>

            <div class="sinusbot-card">
                <div class="sinusbot-card-header">
                    <div>
                        <h2>{{ t('admin_sinusbot_recent_jobs', locale) }}</h2>
                        <p class="sinusbot-muted">{{ t('admin_sinusbot_jobs_desc', locale) }}</p>
                    </div>
                </div>
                {% if agent_jobs is not empty %}
                    {% for job in agent_jobs %}
                        <div class="sinusbot-meta">
                            <div><strong>{{ t('admin_sinusbot_job_type', locale) }}</strong> {{ job.type }}</div>
                            <div><strong>{{ t('admin_sinusbot_job_status', locale) }}</strong> {{ job.status.value }}</div>
                            <div><strong>{{ t('admin_sinusbot_job_started', locale) }}</strong> {{ job.startedAt ? job.startedAt|date('Y-m-d H:i') : '—' }}</div>
                            <div><strong>{{ t('admin_sinusbot_job_finished', locale) }}</strong> {{ job.finishedAt ? job.finishedAt|date('Y-m-d H:i') : '—' }}</div>
                            <div><strong>{{ t('admin_sinusbot_job_error', locale) }}</strong> {{ job.errorText ?? '—' }}</div>
                        </div>
                        {% if job.logText %}
                            <div class="sinusbot-code"><pre>{{ job.logText }}</pre></div>
                        {% endif %}
                        {% if job.resultPayload %}
                            <div class="sinusbot-code"><pre>{{ job.resultPayload|json_encode(constant('JSON_PRETTY_PRINT')) }}</pre></div>
                        {% endif %}
                        {% if not loop.last %}
                            <p class="sinusbot-muted">—</p>
                        {% endif %}
                    {% endfor %}
                {% else %}
                    <p class="sinusbot-muted">{{ t('admin_sinusbot_no_jobs', locale) }}</p>
                {% endif %}
            </div>

            <div class="sinusbot-card">
                <div class="sinusbot-card-header">
                    <div>
                        <h2>{{ t('admin_sinusbot_service_title', locale) }}</h2>
                        <p class="sinusbot-muted">{{ t('admin_sinusbot_service_desc', locale) }}</p>
                    </div>
                </div>
                <div class="sinusbot-meta">
                    <div><strong>{{ t('admin_sinusbot_assigned_customer', locale) }}</strong> {{ node.customer ? node.customer.email : '–' }}</div>
                    <div><strong>{{ t('admin_sinusbot_install_path_label', locale) }}</strong> {{ node.installPath }}</div>
                    <div><strong>{{ t('admin_sinusbot_web_bind_label', locale) }}</strong> {{ node.webBindIp }}:{{ node.webPortBase }}</div>
                    <div><strong>{{ t('admin_sinusbot_ts3_client', locale) }}</strong> {{ node.ts3ClientInstalled ? t('admin_sinusbot_ts3_installed', locale) : t('admin_sinusbot_ts3_not_installed', locale) }}</div>
                    <div><strong>{{ t('admin_sinusbot_ts3_version', locale) }}</strong> {{ node.ts3ClientVersion ?? '–' }}</div>
                    <div><strong>{{ t('admin_sinusbot_ts3_path', locale) }}</strong> {{ node.ts3ClientPath ?? '–' }}</div>
                    <div>
                        <strong>{{ t('admin_sinusbot_manage_url_field', locale) }}</strong>
                        {% if management_url %}
                            <a class="sinusbot-link" href="{{ management_url }}" target="_blank" rel="noopener noreferrer">{{ management_url }}</a>
                        {% else %}
                            –
                        {% endif %}
                    </div>
                </div>
            </div>

            <div class="sinusbot-card">
                <h2>{{ t('admin_sinusbot_login_title', locale) }}</h2>
                <p class="sinusbot-muted">{{ t('admin_sinusbot_login_desc', locale) }}</p>
                {% if admin_password %}
                    <div class="sinusbot-credentials">
                        <div><strong>{{ t('admin_sinusbot_username_label', locale) }}</strong> {{ node.adminUsername ?? '–' }}</div>
                        <div class="sinusbot-secret">{{ admin_password }}</div>
                    </div>
                    <button class="sinusbot-button" type="button" data-sinusbot-copy="{{ admin_password }}">{{ t('admin_sinusbot_copy', locale) }}</button>
                {% else %}
                    <div class="sinusbot-credentials">
                        <div><strong>{{ t('admin_sinusbot_username_label', locale) }}</strong> {{ node.adminUsername ?? '–' }}</div>
                        <div class="sinusbot-secret">••••••••</div>
                    </div>
                    <form method="post" action="/admin/sinusbot/nodes/{{ node.id }}/reveal-credentials">
                        <input type="hidden" name="_token" value="{{ csrf.reveal }}">
                        <button class="sinusbot-button" type="submit">{{ t('admin_sinusbot_reveal', locale) }}</button>
                    </form>
                {% endif %}
            </div>

            <div class="sinusbot-card">
                <h2>{{ t('admin_sinusbot_user_management_title', locale) }}</h2>
                <p class="sinusbot-muted">{{ t('admin_sinusbot_user_management_description', locale) }}</p>
                <div class="sinusbot-code">
                    <pre>{{ t('admin_sinusbot_user_management_example', locale) }}</pre>
                </div>
                <a class="sinusbot-link" href="https://sinusbot.github.io/api-docs/" target="_blank" rel="noopener noreferrer">
                    {{ t('admin_sinusbot_user_management_link', locale) }}
                </a>
            </div>
        </div>
    </div>

    <script>
        const bindSinusbotActions = (root = document) => {
            root.querySelectorAll('[data-sinusbot-copy]').forEach((button) => {
                if (button.dataset.sinusbotCopyBound) {
                    return;
                }
                button.dataset.sinusbotCopyBound = 'true';
                button.addEventListener('click', () => {
                    navigator.clipboard?.writeText(button.dataset.sinusbotCopy || '');
                });
            });

            root.querySelectorAll('[data-sinusbot-reveal]').forEach((button) => {
                if (button.dataset.sinusbotRevealBound) {
                    return;
                }
                button.dataset.sinusbotRevealBound = 'true';
                button.addEventListener('click', () => {
                    const container = button.closest('.sinusbot-field');
                    const secret = container?.querySelector('[data-sinusbot-secret]');
                    if (!secret) {
                        return;
                    }
                    const value = secret.dataset.sinusbotSecret || '';
                    const revealed = secret.dataset.revealed === 'true';
                    if (revealed) {
                        secret.textContent = '••••••••';
                        secret.dataset.revealed = 'false';
                        button.textContent = secret.dataset.labelReveal || 'Show Password';
                        return;
                    }
                    secret.textContent = value;
                    secret.dataset.revealed = 'true';
                    button.textContent = secret.dataset.labelHide || 'Hide Password';
                });
            });

            root.querySelectorAll('form').forEach((form) => {
                if (form.dataset.sinusbotLoadingBound) {
                    return;
                }
                form.dataset.sinusbotLoadingBound = 'true';
                form.addEventListener('submit', () => {
                    const button = form.querySelector('button[data-loading-text]');
                    if (!button) {
                        return;
                    }
                    button.dataset.originalText = button.textContent || '';
                    button.textContent = button.dataset.loadingText || button.textContent;
                    button.classList.add('is-loading');
                });
            });
        };

        bindSinusbotActions();
    </script>
{% endblock %}
