{% extends 'admin/base.html.twig' %}

{% block content %}
{% set locale = page_locale() %}
{% set runningInstances = instances|filter(i => i.status == 'running')|length %}
{% set totalInstances   = instances|length %}
{% set isMulti          = node.instanceMode == 'multi' %}
{% set isOnline         = node.running %}
{% set runtimeBadge     = isOnline ? 'success' : 'danger' %}
{% set runtimeLabel     = isOnline ? t('admin_sinusbot_kpi_online', locale) : t('admin_sinusbot_kpi_offline', locale) %}

<div style="display:grid;grid-template-columns:220px minmax(0,1fr) 300px;gap:20px;align-items:start;">

{# ─────────── Left sidebar ─────────── #}
<aside style="position:sticky;top:20px;display:flex;flex-direction:column;gap:10px;">
    <div class="ng-card" style="overflow:hidden;padding:16px;">
        <a href="/admin/sinusbot/nodes" style="display:inline-flex;align-items:center;gap:6px;font-size:12px;font-weight:700;color:var(--ng-text-muted);text-decoration:none;margin-bottom:14px;">
            <svg style="width:13px;height:13px;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
            {{ t('admin_sinusbot_back_to_overview', locale) }}
        </a>

        <div style="background:var(--ng-surface-soft);border:1px solid var(--ng-border);border-radius:var(--ng-radius-sm);padding:12px;margin-bottom:12px;">
            <div style="font-size:10px;font-weight:700;font-family:monospace;letter-spacing:.06em;color:var(--ng-text-muted);margin-bottom:4px;">SinusBot Node</div>
            <h2 style="margin:0 0 8px;font-size:13px;font-weight:700;color:var(--ng-text);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{{ node.name }}</h2>
            <div style="display:flex;gap:5px;flex-wrap:wrap;">
                <span class="ui-badge ui-badge--{{ isMulti ? 'primary' : 'neutral' }}" style="font-size:10px;">{{ isMulti ? t('admin_sinusbot_mode_multi_label', locale) : t('admin_sinusbot_mode_solo_label', locale) }}</span>
                <span class="ui-badge ui-badge--{{ runtimeBadge }}" style="font-size:10px;">{{ runtimeLabel }}</span>
            </div>
        </div>

        <nav style="display:flex;flex-direction:column;gap:2px;">
            <a href="#section-installation" class="sb-nav-link sb-nav-link--active">
                <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2V9M9 21H5a2 2 0 01-2-2V9m0 0h18"/></svg>
                {{ t('admin_sinusbot_installation_title', locale) }}
            </a>
            {% if isMulti %}
            <a href="#section-instances" class="sb-nav-link">
                <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="7" cy="9" r="3"/><circle cx="17" cy="9" r="3"/><path stroke-linecap="round" d="M1 19c0-3 2.686-5 6-5M17 14c3.314 0 6 2 6 5"/></svg>
                {{ t('admin_sinusbot_customer_instances_title', locale) }}
            </a>
            {% endif %}
            <a href="#section-login" class="sb-nav-link">
                <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path stroke-linecap="round" d="M7 11V7a5 5 0 0110 0v4"/></svg>
                {{ t('admin_sinusbot_login_title', locale) }}
            </a>
            <a href="#section-jobs" class="sb-nav-link">
                <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
                {{ t('admin_sinusbot_recent_jobs', locale) }}
            </a>
        </nav>
    </div>
</aside>

{# ─────────── Main content ─────────── #}
<main style="display:flex;flex-direction:column;gap:20px;min-width:0;">

    {# Hero #}
    <section class="ng-card" style="overflow:hidden;">
        <div class="tkt-hero">
            <div class="tkt-hero__inner">
                <div>
                    <div class="tkt-hero__breadcrumb">
                        <a href="/admin/sinusbot/nodes">{{ t('admin_sinusbot_nodes_page_title', locale) }}</a>
                        <span>/</span>
                        <span>{{ node.name }}</span>
                    </div>
                    <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;margin-top:10px;">
                        <div class="tkt-hero__pill">
                            <span class="tkt-hero__pill-dot" style="background:#f97316;"></span>
                            SinusBot
                        </div>
                        <span class="ui-badge ui-badge--{{ isMulti ? 'primary' : 'neutral' }}" style="font-size:11px;">{{ isMulti ? t('admin_sinusbot_mode_multi_label', locale) : t('admin_sinusbot_mode_solo_label', locale) }}</span>
                        <span class="ui-badge ui-badge--{{ runtimeBadge }}" style="font-size:11px;">{{ runtimeLabel }}</span>
                    </div>
                    <h1 class="tkt-hero__title" style="margin-top:10px;">{{ node.name }}</h1>
                    <p class="tkt-hero__sub">{{ t('admin_sinusbot_intro', locale) }}</p>
                </div>
                {% if isMulti %}
                <div style="display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:10px;margin-top:16px;">
                    <div class="tkt-kpi">
                        <div class="tkt-kpi__label">{{ t('admin_sinusbot_kpi_instances', locale) }}</div>
                        <div class="tkt-kpi__value">{{ totalInstances }}</div>
                    </div>
                    <div class="tkt-kpi tkt-kpi--open">
                        <div class="tkt-kpi__label">{{ t('admin_sinusbot_kpi_online', locale) }}</div>
                        <div class="tkt-kpi__value">{{ runningInstances }}</div>
                    </div>
                    <div class="tkt-kpi tkt-kpi--pending">
                        <div class="tkt-kpi__label">{{ t('admin_sinusbot_kpi_offline', locale) }}</div>
                        <div class="tkt-kpi__value">{{ totalInstances - runningInstances }}</div>
                    </div>
                </div>
                {% endif %}
            </div>
        </div>
        <div style="padding:10px 16px;border-top:1px solid var(--ng-border);background:var(--ng-surface-soft);display:flex;justify-content:flex-end;">
            <form method="post" action="/admin/sinusbot/nodes/{{ node.id }}/delete" onsubmit="return confirm('{{ t('admin_sinusbot_delete_confirm', locale) }}');">
                <input type="hidden" name="_token" value="{{ csrf.delete }}">
                <button class="ui-button ui-button--danger ui-button--sm" type="submit">{{ t('admin_sinusbot_delete', locale) }}</button>
            </form>
        </div>
    </section>

    {# Flash messages #}
    {% for message in app.flashes('success') %}
        <div class="ng-alert ng-alert--success">{{ t(message, locale) }}</div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="ng-alert ng-alert--danger">{{ t(message, locale) }}</div>
    {% endfor %}

    {# ── Installation ── #}
    <div id="section-installation" class="ng-data-card">
        <div class="ng-data-card__header">
            <div style="display:flex;align-items:center;gap:10px;">
                <span style="display:flex;align-items:center;justify-content:center;width:32px;height:32px;border-radius:8px;background:rgba(249,115,22,.12);flex-shrink:0;">
                    <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="#f97316" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><path stroke-linecap="round" d="M8 21h8M12 17v4"/></svg>
                </span>
                <div>
                    <h2 class="ng-data-card__title">{{ t('admin_sinusbot_installation_title', locale) }}</h2>
                    <p class="ng-data-card__sub">{{ t('admin_sinusbot_service_desc', locale) }}</p>
                </div>
            </div>
            <div class="ng-data-card__actions">
                <span class="ui-badge ui-badge--neutral" style="font-family:monospace;font-size:11px;">{{ node.installStatus }}</span>
                <span class="ui-badge ui-badge--{{ runtimeBadge }}">{{ runtimeLabel }}</span>
            </div>
        </div>
        <div class="ng-data-card__body">
            <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(190px,1fr));gap:10px;">
                <div style="background:var(--ng-surface-soft);border:1px solid var(--ng-border);border-radius:8px;padding:12px;">
                    <div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--ng-text-muted);margin-bottom:4px;">{{ t('admin_sinusbot_status_label', locale) }}</div>
                    <div style="font-size:14px;font-weight:600;color:var(--ng-text);">{{ node.installStatus }}</div>
                </div>
                <div style="background:var(--ng-surface-soft);border:1px solid var(--ng-border);border-radius:8px;padding:12px;">
                    <div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--ng-text-muted);margin-bottom:4px;">{{ t('admin_sinusbot_version_label', locale) }}</div>
                    <div style="font-size:14px;font-weight:600;color:var(--ng-text);font-family:monospace;">{{ node.installedVersion ?? '–' }}</div>
                </div>
                <div style="background:var(--ng-surface-soft);border:1px solid var(--ng-border);border-radius:8px;padding:12px;">
                    <div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--ng-text-muted);margin-bottom:4px;">{{ t('admin_sinusbot_install_path_label', locale) }}</div>
                    <div style="font-size:12px;font-weight:500;color:var(--ng-text);font-family:monospace;word-break:break-all;">{{ node.installPath }}</div>
                </div>
                <div style="background:var(--ng-surface-soft);border:1px solid var(--ng-border);border-radius:8px;padding:12px;">
                    <div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--ng-text-muted);margin-bottom:4px;">{{ t('admin_sinusbot_web_bind_label', locale) }}</div>
                    <div style="font-size:13px;font-weight:600;color:var(--ng-text);font-family:monospace;">{{ node.webBindIp }}:{{ node.webPortBase }}</div>
                </div>
                {% if node.lastError %}
                <div style="background:rgba(239,68,68,.07);border:1px solid rgba(239,68,68,.25);border-radius:8px;padding:12px;grid-column:1/-1;">
                    <div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:rgba(252,165,165,.8);margin-bottom:4px;">{{ t('admin_sinusbot_last_error_label', locale) }}</div>
                    <div style="font-size:13px;color:#fca5a5;font-family:monospace;word-break:break-all;">{{ node.lastError }}</div>
                </div>
                {% endif %}
            </div>
        </div>
    </div>

    {# ── Customer instances (multi only) ── #}
    {% if isMulti %}
    <div id="section-instances" class="ng-data-card">
        <div class="ng-data-card__header">
            <div style="display:flex;align-items:center;gap:10px;">
                <span style="display:flex;align-items:center;justify-content:center;width:32px;height:32px;border-radius:8px;background:rgba(99,102,241,.12);flex-shrink:0;">
                    <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="#6366f1" stroke-width="2"><circle cx="7" cy="9" r="3"/><circle cx="17" cy="9" r="3"/><path stroke-linecap="round" d="M1 19c0-3 2.686-5 6-5M17 14c3.314 0 6 2 6 5"/></svg>
                </span>
                <div>
                    <h2 class="ng-data-card__title">{{ t('admin_sinusbot_customer_instances_title', locale) }}</h2>
                    <p class="ng-data-card__sub">{{ t('admin_sinusbot_customer_instances_desc', locale) }}</p>
                </div>
            </div>
        </div>
        <div class="ng-data-card__body">

            {# Create instance form #}
            <form method="post" action="/admin/sinusbot/instances/create" style="display:grid;grid-template-columns:1fr 1fr 1fr auto;gap:12px;align-items:flex-end;margin-bottom:24px;padding:16px;background:var(--ng-surface-soft);border-radius:10px;border:1px solid var(--ng-border);">
                <input type="hidden" name="_token" value="{{ csrf.instance_create }}">
                <input type="hidden" name="node_id" value="{{ node.id }}">
                <div class="form-field">
                    <label class="form-label" for="customer_id">{{ t('admin_sinusbot_customer_label', locale) }}</label>
                    <select id="customer_id" name="customer_id" class="form-input" required>
                        <option value="">{{ t('admin_sinusbot_select_customer', locale) }}</option>
                        {% for customer in customers %}
                            <option value="{{ customer.id }}">{{ customer.email }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="form-field">
                    <label class="form-label" for="quota">{{ t('admin_sinusbot_quota_label', locale) }}</label>
                    <input id="quota" name="quota" type="number" class="form-input" min="{{ quota_min }}" max="{{ quota_max }}" value="{{ quota_min }}" required>
                </div>
                <div class="form-field">
                    <label class="form-label" for="username">{{ t('admin_sinusbot_username_optional', locale) }}</label>
                    <input id="username" name="username" type="text" class="form-input" placeholder="auto">
                </div>
                <div>
                    <button class="ui-button ui-button--primary" type="submit">{{ t('admin_sinusbot_create_instance', locale) }}</button>
                </div>
            </form>

            {% if instances is not empty %}
                <div style="display:flex;flex-direction:column;gap:12px;">
                    {% for instance in instances %}
                        {% set instanceStatusLabel = instance.status == 'running' ? t('admin_sinusbot_instance_online', locale) : (instance.status == 'stopped' ? t('admin_sinusbot_instance_offline', locale) : t('customer_ts_unknown', locale)) %}
                        {% set instanceStatusBadge = instance.status == 'running' ? 'success' : (instance.status == 'stopped' ? 'danger' : 'warning') %}
                        {% set instancePassword = instance_passwords[instance.id] ?? null %}
                        <div style="border:1px solid var(--ng-border);border-radius:var(--ng-radius);overflow:hidden;">
                            {# Instance header #}
                            <div style="display:flex;align-items:center;justify-content:space-between;gap:12px;padding:12px 16px;background:var(--ng-surface-soft);border-bottom:1px solid var(--ng-border);">
                                <div style="min-width:0;flex:1;">
                                    <div style="display:flex;align-items:center;gap:8px;">
                                        <div style="width:8px;height:8px;border-radius:50%;background:{{ instance.status == 'running' ? '#22c55e' : '#f59e0b' }};flex-shrink:0;"></div>
                                        <span style="font-size:13px;font-weight:700;color:var(--ng-text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">{{ instance.customer ? instance.customer.email : t('admin_sinusbot_unknown_customer', locale) }}</span>
                                    </div>
                                    <div style="font-size:11px;font-family:monospace;color:var(--ng-text-muted);margin-top:2px;padding-left:16px;">{{ instance.instanceId }}</div>
                                </div>
                                <span class="ui-badge ui-badge--{{ instanceStatusBadge }}">{{ instanceStatusLabel }}</span>
                            </div>
                            {# Instance body #}
                            <div style="padding:14px 16px;">
                                <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:8px;margin-bottom:12px;">
                                    <div style="background:var(--ng-surface-soft);border:1px solid var(--ng-border);border-radius:6px;padding:9px 11px;">
                                        <div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--ng-text-muted);margin-bottom:2px;">{{ t('admin_sinusbot_last_check', locale) }}</div>
                                        <div style="font-size:12px;color:var(--ng-text);">{{ instance.lastSeenAt ? instance.lastSeenAt|date('d.m.Y H:i') : '—' }}</div>
                                    </div>
                                    <div style="background:var(--ng-surface-soft);border:1px solid var(--ng-border);border-radius:6px;padding:9px 11px;">
                                        <div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--ng-text-muted);margin-bottom:2px;">{{ t('admin_sinusbot_quota', locale) }}</div>
                                        <div style="font-size:12px;font-weight:600;color:var(--ng-text);">{{ instance.botQuota }}</div>
                                    </div>
                                    <div style="background:var(--ng-surface-soft);border:1px solid var(--ng-border);border-radius:6px;padding:9px 11px;">
                                        <div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--ng-text-muted);margin-bottom:2px;">{{ t('admin_sinusbot_username_field', locale) }}</div>
                                        <div style="font-size:12px;color:var(--ng-text);display:flex;align-items:center;gap:6px;">
                                            {% if instance.sinusbotUsername %}
                                                <code style="font-family:monospace;">{{ instance.sinusbotUsername }}</code>
                                                <button class="ui-button ui-button--ghost ui-button--sm" type="button" data-sinusbot-copy="{{ instance.sinusbotUsername }}" style="padding:2px 6px;font-size:10px;">{{ t('admin_sinusbot_copy', locale) }}</button>
                                            {% else %}—{% endif %}
                                        </div>
                                    </div>
                                    <div style="background:var(--ng-surface-soft);border:1px solid var(--ng-border);border-radius:6px;padding:9px 11px;">
                                        <div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--ng-text-muted);margin-bottom:2px;">{{ t('admin_sinusbot_password', locale) }}</div>
                                        <div style="font-size:12px;color:var(--ng-text);display:flex;align-items:center;gap:6px;">
                                            {% if instancePassword %}
                                                <code data-sinusbot-secret="{{ instancePassword }}" data-label-reveal="{{ t('admin_sinusbot_password_reveal', locale) }}" data-label-hide="{{ t('admin_sinusbot_password_hide', locale) }}" style="font-family:monospace;font-size:11px;background:var(--ng-surface);padding:1px 6px;border-radius:4px;border:1px solid var(--ng-border);">••••••••</code>
                                                <button class="ui-button ui-button--ghost ui-button--sm" type="button" data-sinusbot-reveal style="padding:2px 6px;font-size:10px;">{{ t('admin_sinusbot_password_reveal', locale) }}</button>
                                            {% else %}—{% endif %}
                                        </div>
                                    </div>
                                    {% if instance.manageUrl %}
                                    <div style="background:var(--ng-surface-soft);border:1px solid var(--ng-border);border-radius:6px;padding:9px 11px;grid-column:1/-1;">
                                        <div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--ng-text-muted);margin-bottom:2px;">{{ t('admin_sinusbot_manage_url', locale) }}</div>
                                        <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;">
                                            <a href="{{ instance.manageUrl }}" target="_blank" rel="noopener noreferrer" style="color:var(--ng-primary);font-size:12px;word-break:break-all;">{{ instance.manageUrl }}</a>
                                            <button class="ui-button ui-button--ghost ui-button--sm" type="button" data-sinusbot-copy="{{ instance.manageUrl }}" style="padding:2px 6px;font-size:10px;flex-shrink:0;">{{ t('admin_sinusbot_copy', locale) }}</button>
                                        </div>
                                    </div>
                                    {% endif %}
                                </div>
                                {# Instance actions #}
                                <div style="display:flex;flex-wrap:wrap;gap:6px;padding-top:10px;border-top:1px solid var(--ng-border);align-items:center;">
                                    <form method="post" action="/admin/sinusbot/instances/{{ instance.id }}/start">
                                        <input type="hidden" name="_token" value="{{ instance_csrf[instance.id].start }}">
                                        <button class="ui-button ui-button--ghost ui-button--sm" type="submit" data-loading-text="…">{{ t('admin_sinusbot_start_instance', locale) }}</button>
                                    </form>
                                    <form method="post" action="/admin/sinusbot/instances/{{ instance.id }}/stop">
                                        <input type="hidden" name="_token" value="{{ instance_csrf[instance.id].stop }}">
                                        <button class="ui-button ui-button--ghost ui-button--sm" type="submit" data-loading-text="…">{{ t('admin_sinusbot_stop_instance', locale) }}</button>
                                    </form>
                                    <form method="post" action="/admin/sinusbot/instances/{{ instance.id }}/restart">
                                        <input type="hidden" name="_token" value="{{ instance_csrf[instance.id].restart }}">
                                        <button class="ui-button ui-button--ghost ui-button--sm" type="submit" data-loading-text="…">{{ t('admin_sinusbot_restart_instance', locale) }}</button>
                                    </form>
                                    <form method="post" action="/admin/sinusbot/instances/{{ instance.id }}/reset-password">
                                        <input type="hidden" name="_token" value="{{ instance_csrf[instance.id].reset }}">
                                        <button class="ui-button ui-button--ghost ui-button--sm" type="submit" data-loading-text="{{ t('admin_sinusbot_reset_loading', locale) }}">{{ t('admin_sinusbot_password_reset_btn', locale) }}</button>
                                    </form>
                                    <form method="post" action="/admin/sinusbot/instances/{{ instance.id }}/quota" style="display:flex;align-items:center;gap:5px;">
                                        <input type="hidden" name="_token" value="{{ instance_csrf[instance.id].quota }}">
                                        <input name="quota" type="number" class="form-input" style="width:64px;padding:4px 8px;font-size:12px;" min="{{ quota_min }}" max="{{ quota_max }}" value="{{ instance.botQuota }}" required>
                                        <button class="ui-button ui-button--ghost ui-button--sm" type="submit">{{ t('admin_sinusbot_quota_update', locale) }}</button>
                                    </form>
                                    <form method="post" action="/admin/sinusbot/instances/{{ instance.id }}/delete" onsubmit="return confirm('{{ t('admin_sinusbot_instance_delete_confirm', locale) }}');" style="margin-left:auto;display:flex;align-items:center;gap:8px;">
                                        <input type="hidden" name="_token" value="{{ instance_csrf[instance.id].delete }}">
                                        <label style="display:flex;align-items:center;gap:4px;font-size:11px;cursor:pointer;color:var(--ng-text-muted);">
                                            <input type="radio" name="mode" value="delete" checked>{{ t('admin_sinusbot_delete_with_agent', locale) }}
                                        </label>
                                        <label style="display:flex;align-items:center;gap:4px;font-size:11px;cursor:pointer;color:var(--ng-text-muted);">
                                            <input type="radio" name="mode" value="detach">{{ t('admin_sinusbot_detach_only', locale) }}
                                        </label>
                                        <button class="ui-button ui-button--danger ui-button--sm" type="submit">{{ t('admin_sinusbot_delete_instance', locale) }}</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% else %}
                <div style="text-align:center;padding:40px 20px;background:var(--ng-surface-soft);border-radius:8px;border:1px dashed var(--ng-border);">
                    <svg width="36" height="36" fill="none" viewBox="0 0 24 24" style="display:block;margin:0 auto 10px;opacity:.25;color:var(--ng-text-muted);"><circle cx="12" cy="8" r="4" stroke="currentColor" stroke-width="2"/><path d="M4 20c0-4 3.582-7 8-7s8 3 8 7" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                    <p style="margin:0;font-size:13px;color:var(--ng-text-muted);">{{ t('admin_sinusbot_no_instances', locale) }}</p>
                </div>
            {% endif %}
        </div>
    </div>
    {% endif %}

    {# ── Recent jobs ── #}
    <details id="section-jobs" class="ng-data-card">
        <summary style="padding:16px 20px;cursor:pointer;display:flex;justify-content:space-between;align-items:center;list-style:none;user-select:none;">
            <div style="display:flex;align-items:center;gap:10px;">
                <span style="display:flex;align-items:center;justify-content:center;width:32px;height:32px;border-radius:8px;background:rgba(100,116,139,.1);flex-shrink:0;">
                    <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
                </span>
                <div>
                    <h2 class="ng-data-card__title" style="margin:0;">{{ t('admin_sinusbot_recent_jobs', locale) }}</h2>
                    <p class="ng-data-card__sub" style="margin:2px 0 0;">{{ t('admin_sinusbot_jobs_desc', locale) }}</p>
                </div>
            </div>
            <svg width="15" height="15" fill="none" viewBox="0 0 24 24" style="flex-shrink:0;transition:transform .2s;color:var(--ng-text-muted);" class="details-chevron"><path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </summary>
        <div class="ng-data-card__body" style="border-top:1px solid var(--ng-border);">
            {% if agent_jobs is not empty %}
                <div style="display:flex;flex-direction:column;gap:12px;">
                {% for job in agent_jobs %}
                    <div style="background:var(--ng-surface-soft);border:1px solid var(--ng-border);border-radius:8px;padding:12px 14px;">
                        <div style="display:flex;gap:16px;flex-wrap:wrap;font-size:12px;margin-bottom:8px;align-items:center;">
                            <span style="font-family:monospace;background:var(--ng-surface);padding:2px 8px;border-radius:4px;border:1px solid var(--ng-border);font-size:11px;">{{ job.type }}</span>
                            <span class="ui-badge ui-badge--{{ job.status.value == 'success' ? 'success' : (job.status.value == 'error' ? 'danger' : 'neutral') }}" style="font-size:10px;">{{ job.status.value }}</span>
                            <span style="color:var(--ng-text-muted);">{{ job.startedAt ? job.startedAt|date('d.m.Y H:i') : '—' }}</span>
                            {% if job.finishedAt %}
                                <span style="color:var(--ng-text-muted);">→ {{ job.finishedAt|date('H:i') }}</span>
                            {% endif %}
                        </div>
                        {% if job.errorText %}
                            <div style="color:#fca5a5;font-size:12px;margin-bottom:6px;font-family:monospace;">{{ job.errorText }}</div>
                        {% endif %}
                        {% if job.logText %}
                            <pre style="background:#0f172a;color:#94a3b8;padding:10px 12px;border-radius:6px;overflow-x:auto;font-size:11px;margin:0 0 6px;line-height:1.5;">{{ job.logText }}</pre>
                        {% endif %}
                        {% if job.resultPayload %}
                            <pre style="background:#0f172a;color:#94a3b8;padding:10px 12px;border-radius:6px;overflow-x:auto;font-size:11px;margin:0;line-height:1.5;">{{ job.resultPayload|json_encode(constant('JSON_PRETTY_PRINT')) }}</pre>
                        {% endif %}
                    </div>
                    {% if not loop.last %}<div style="height:1px;"></div>{% endif %}
                {% endfor %}
                </div>
            {% else %}
                <p style="color:var(--ng-text-muted);margin:0;font-size:13px;">{{ t('admin_sinusbot_no_jobs', locale) }}</p>
            {% endif %}
        </div>
    </details>

    {# ── User management ── #}
    <details class="ng-data-card">
        <summary style="padding:16px 20px;cursor:pointer;display:flex;justify-content:space-between;align-items:center;list-style:none;user-select:none;">
            <div style="display:flex;align-items:center;gap:10px;">
                <span style="display:flex;align-items:center;justify-content:center;width:32px;height:32px;border-radius:8px;background:rgba(100,116,139,.1);flex-shrink:0;">
                    <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"/><path stroke-linecap="round" d="M4 20c0-4 3.582-7 8-7s8 3 8 7"/></svg>
                </span>
                <div>
                    <h2 class="ng-data-card__title" style="margin:0;">{{ t('admin_sinusbot_user_management_title', locale) }}</h2>
                    <p class="ng-data-card__sub" style="margin:2px 0 0;">{{ t('admin_sinusbot_user_management_description', locale) }}</p>
                </div>
            </div>
            <svg width="15" height="15" fill="none" viewBox="0 0 24 24" style="flex-shrink:0;transition:transform .2s;color:var(--ng-text-muted);" class="details-chevron"><path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </summary>
        <div class="ng-data-card__body" style="border-top:1px solid var(--ng-border);">
            <pre style="background:#0f172a;color:#94a3b8;padding:12px;border-radius:6px;overflow-x:auto;font-size:12px;margin-bottom:12px;line-height:1.5;">{{ t('admin_sinusbot_user_management_example', locale) }}</pre>
            <a class="ui-button ui-button--ghost ui-button--sm" href="https://sinusbot.github.io/api-docs/" target="_blank" rel="noopener noreferrer">{{ t('admin_sinusbot_user_management_link', locale) }}</a>
        </div>
    </details>

</main>

{# ─────────── Right sidebar ─────────── #}
<aside style="position:sticky;top:20px;display:flex;flex-direction:column;gap:12px;">

    {# Quick actions #}
    <div class="ng-card" style="overflow:hidden;">
        <div style="padding:13px 18px;border-bottom:1px solid var(--ng-border);display:flex;align-items:center;gap:8px;">
            <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="color:var(--ng-text-muted);"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
            <h3 style="margin:0;font-size:13px;font-weight:700;color:var(--ng-text);">{{ t('admin_sinusbot_quick_actions', locale) }}</h3>
        </div>
        <div style="padding:14px 18px;display:flex;flex-direction:column;gap:6px;">
            <form method="post" action="/admin/sinusbot/nodes/{{ node.id }}/install">
                <input type="hidden" name="_token" value="{{ csrf.install }}">
                <button class="tkt-sidebar-btn tkt-sidebar-btn--primary" style="width:100%;" type="submit" data-loading-text="…">{{ t('admin_sinusbot_install_repair', locale) }}</button>
            </form>
            <form method="post" action="/admin/sinusbot/nodes/{{ node.id }}/refresh">
                <input type="hidden" name="_token" value="{{ csrf.refresh }}">
                <button class="tkt-sidebar-btn" style="width:100%;" type="submit" data-loading-text="…">{{ t('admin_sinusbot_refresh_status', locale) }}</button>
            </form>
            <div style="height:1px;background:var(--ng-border);margin:4px 0;"></div>
            <form method="post" action="/admin/sinusbot/nodes/{{ node.id }}/start">
                <input type="hidden" name="_token" value="{{ csrf.start }}">
                <button class="tkt-sidebar-btn tkt-sidebar-btn--success" style="width:100%;" type="submit" data-loading-text="…">{{ t('admin_sinusbot_start', locale) }}</button>
            </form>
            <form method="post" action="/admin/sinusbot/nodes/{{ node.id }}/stop">
                <input type="hidden" name="_token" value="{{ csrf.stop }}">
                <button class="tkt-sidebar-btn" style="width:100%;" type="submit" data-loading-text="…">{{ t('admin_sinusbot_stop', locale) }}</button>
            </form>
            <form method="post" action="/admin/sinusbot/nodes/{{ node.id }}/restart">
                <input type="hidden" name="_token" value="{{ csrf.restart }}">
                <button class="tkt-sidebar-btn" style="width:100%;" type="submit" data-loading-text="…">{{ t('admin_sinusbot_restart', locale) }}</button>
            </form>
        </div>
    </div>

    {# Login credentials #}
    <div id="section-login" class="ng-card" style="overflow:hidden;">
        <div style="padding:13px 18px;border-bottom:1px solid var(--ng-border);">
            <h3 style="margin:0;font-size:13px;font-weight:700;color:var(--ng-text);">{{ t('admin_sinusbot_login_title', locale) }}</h3>
            <p style="margin:2px 0 0;font-size:11px;color:var(--ng-text-muted);">{{ t('admin_sinusbot_login_desc', locale) }}</p>
        </div>
        <div style="padding:14px 18px;">
            <dl class="tkt-dl">
                <div>
                    <dt>{{ t('admin_sinusbot_username_label', locale) }}</dt>
                    <dd><code style="background:var(--ng-surface-soft);padding:2px 8px;border-radius:4px;font-size:12px;border:1px solid var(--ng-border);">{{ node.adminUsername ?? '–' }}</code></dd>
                </div>
                <div>
                    <dt>{{ t('admin_sinusbot_password', locale) }}</dt>
                    <dd>
                        {% if admin_password %}
                            <div style="display:flex;align-items:center;gap:6px;flex-wrap:wrap;">
                                <code style="background:var(--ng-surface-soft);padding:2px 8px;border-radius:4px;font-size:12px;border:1px solid var(--ng-border);word-break:break-all;">{{ admin_password }}</code>
                                <button class="ui-button ui-button--ghost ui-button--sm" type="button" data-sinusbot-copy="{{ admin_password }}" style="padding:2px 7px;font-size:11px;">{{ t('admin_sinusbot_copy', locale) }}</button>
                            </div>
                        {% else %}
                            <code style="background:var(--ng-surface-soft);padding:2px 8px;border-radius:4px;font-size:12px;letter-spacing:3px;border:1px solid var(--ng-border);">••••••••</code>
                        {% endif %}
                    </dd>
                </div>
                {% if management_url %}
                <div>
                    <dt>{{ t('admin_sinusbot_url_label', locale) }}</dt>
                    <dd><a href="{{ management_url }}" target="_blank" rel="noopener noreferrer" style="color:var(--ng-primary);font-size:12px;word-break:break-all;">{{ management_url }}</a></dd>
                </div>
                {% endif %}
            </dl>
            {% if not admin_password %}
            <form method="post" action="/admin/sinusbot/nodes/{{ node.id }}/reveal-credentials" style="margin-top:10px;">
                <input type="hidden" name="_token" value="{{ csrf.reveal }}">
                <button class="tkt-sidebar-btn" style="width:100%;" type="submit">{{ t('admin_sinusbot_reveal', locale) }}</button>
            </form>
            {% endif %}
        </div>
    </div>

    {# Service info #}
    <div id="section-service" class="ng-card" style="overflow:hidden;">
        <div style="padding:13px 18px;border-bottom:1px solid var(--ng-border);">
            <h3 style="margin:0;font-size:13px;font-weight:700;color:var(--ng-text);">{{ t('admin_sinusbot_service_title', locale) }}</h3>
        </div>
        <div style="padding:14px 18px;">
            <dl class="tkt-dl">
                <div>
                    <dt>{{ t('admin_sinusbot_assigned_customer', locale) }}</dt>
                    <dd style="{{ not node.customer ? 'color:var(--ng-text-muted);font-weight:400;' : '' }}">{{ node.customer ? node.customer.email : '–' }}</dd>
                </div>
                <div>
                    <dt>{{ t('admin_sinusbot_ts3_client', locale) }}</dt>
                    <dd>
                        {% if node.ts3ClientInstalled %}
                            <span class="ui-badge ui-badge--success" style="font-size:10px;">{{ t('admin_sinusbot_ts3_installed', locale) }}</span>
                            {% if node.ts3ClientVersion %}<span style="font-size:11px;color:var(--ng-text-muted);margin-left:4px;">{{ node.ts3ClientVersion }}</span>{% endif %}
                        {% else %}
                            <span class="ui-badge ui-badge--neutral" style="font-size:10px;">{{ t('admin_sinusbot_ts3_not_installed', locale) }}</span>
                        {% endif %}
                    </dd>
                </div>
                {% if node.ts3ClientPath %}
                <div>
                    <dt>{{ t('admin_sinusbot_ts3_path', locale) }}</dt>
                    <dd style="font-family:monospace;font-size:11px;word-break:break-all;">{{ node.ts3ClientPath }}</dd>
                </div>
                {% endif %}
                <div>
                    <dt>{{ t('admin_sinusbot_install_path_label', locale) }}</dt>
                    <dd style="font-family:monospace;font-size:11px;word-break:break-all;">{{ node.installPath }}</dd>
                </div>
            </dl>
        </div>
    </div>

</aside>

</div>

<style>
.sb-nav-link {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 7px 10px;
    border-radius: var(--ng-radius-sm);
    font-size: 12px;
    font-weight: 600;
    color: var(--ng-text-muted);
    text-decoration: none;
    transition: background .15s, color .15s;
}
.sb-nav-link:hover,
.sb-nav-link--active {
    background: var(--ng-primary-soft);
    color: var(--ng-primary);
}
</style>

<script>
document.querySelectorAll('details').forEach(d => {
    d.addEventListener('toggle', () => {
        const chevron = d.querySelector('.details-chevron');
        if (chevron) chevron.style.transform = d.open ? 'rotate(180deg)' : '';
    });
});

const bindSinusbotActions = (root = document) => {
    root.querySelectorAll('[data-sinusbot-copy]').forEach(button => {
        if (button.dataset.bound) return;
        button.dataset.bound = '1';
        button.addEventListener('click', () => navigator.clipboard?.writeText(button.dataset.sinusbotCopy || ''));
    });

    root.querySelectorAll('[data-sinusbot-reveal]').forEach(button => {
        if (button.dataset.bound) return;
        button.dataset.bound = '1';
        button.addEventListener('click', () => {
            const card = button.closest('[style*="border"]') ?? button.closest('.ng-card');
            const secret = card?.querySelector('[data-sinusbot-secret]');
            if (!secret) return;
            const revealed = secret.dataset.revealed === 'true';
            secret.textContent = revealed ? '••••••••' : secret.dataset.sinusbotSecret;
            secret.dataset.revealed = revealed ? 'false' : 'true';
            button.textContent = revealed ? (secret.dataset.labelReveal || 'Anzeigen') : (secret.dataset.labelHide || 'Verbergen');
        });
    });

    root.querySelectorAll('form').forEach(form => {
        if (form.dataset.lb) return;
        form.dataset.lb = '1';
        form.addEventListener('submit', () => {
            const btn = form.querySelector('button[data-loading-text]');
            if (!btn) return;
            btn.textContent = btn.dataset.loadingText || btn.textContent;
            btn.disabled = true;
        });
    });
};

bindSinusbotActions();
</script>
{% endblock %}
