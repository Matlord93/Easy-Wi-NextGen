{% extends 'admin/base.html.twig' %}


{% block content %}
    <div class="sinusbot-page">
        <div class="sinusbot-header">
            <div>
                <h1>{{ node.name }}</h1>
                <p>{{ t('admin_sinusbot_intro', page_locale()) }}</p>
            </div>
            <div class="sinusbot-actions">
                <a class="sinusbot-link" href="/admin/sinusbot/nodes">{{ t('admin_sinusbot_back_to_overview', page_locale()) }}</a>
                <form method="post" action="/admin/sinusbot/nodes/{{ node.id }}/delete" onsubmit="return confirm('SinusBot Node wirklich löschen?');">
                    <input type="hidden" name="_token" value="{{ csrf.delete }}">
                    <button class="sinusbot-button" type="submit">Löschen</button>
                </form>
            </div>
        </div>

        {% for message in app.flashes('success') %}
            <div class="sinusbot-alert sinusbot-alert-success">{{ message }}</div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="sinusbot-alert sinusbot-alert-error">{{ message }}</div>
        {% endfor %}

        {% set runtimeLabel = node.running ? 'Online' : 'Offline' %}
        {% set runtimeClass = node.running ? 'sinusbot-pill--success' : 'sinusbot-pill--danger' %}

        <div class="sinusbot-grid">
            <div class="sinusbot-card">
                <div class="sinusbot-card-header">
                    <div>
                        <h2>{{ t('admin_sinusbot_installation_title', page_locale()) }}</h2>
                        <p class="sinusbot-muted">Status und Steuerung für die Node.</p>
                    </div>
                    <div class="sinusbot-status-group">
                        <span class="sinusbot-pill">{{ node.installStatus }}</span>
                        <span class="sinusbot-pill {{ runtimeClass }}">{{ runtimeLabel }}</span>
                    </div>
                </div>
                <div class="sinusbot-meta">
                    <div><strong>{{ t('admin_sinusbot_status_label', page_locale()) }}</strong> {{ node.installStatus }}</div>
                    <div><strong>Runtime:</strong> {{ node.running ? 'running' : 'stopped' }}</div>
                    <div><strong>{{ t('admin_sinusbot_version_label', page_locale()) }}</strong> {{ node.installedVersion ?? '–' }}</div>
                    <div><strong>{{ t('admin_sinusbot_last_error_label', page_locale()) }}</strong> {{ node.lastError ?? '–' }}</div>
                </div>
                <div class="sinusbot-actions">
                    <form method="post" action="/admin/sinusbot/nodes/{{ node.id }}/install">
                        <input type="hidden" name="_token" value="{{ csrf.install }}">
                        <button class="sinusbot-button" type="submit" data-loading-text="Installiere…">{{ t('admin_sinusbot_install_repair', page_locale()) }}</button>
                    </form>
                    <form method="post" action="/admin/sinusbot/nodes/{{ node.id }}/refresh">
                        <input type="hidden" name="_token" value="{{ csrf.refresh }}">
                        <button class="sinusbot-button" type="submit" data-loading-text="Aktualisiere…">{{ t('admin_sinusbot_refresh_status', page_locale()) }}</button>
                    </form>
                </div>
                <div class="sinusbot-actions">
                    <form method="post" action="/admin/sinusbot/nodes/{{ node.id }}/start">
                        <input type="hidden" name="_token" value="{{ csrf.start }}">
                        <button class="sinusbot-button" type="submit" data-loading-text="Starte…">{{ t('admin_sinusbot_start', page_locale()) }}</button>
                    </form>
                    <form method="post" action="/admin/sinusbot/nodes/{{ node.id }}/stop">
                        <input type="hidden" name="_token" value="{{ csrf.stop }}">
                        <button class="sinusbot-button" type="submit" data-loading-text="Stoppe…">{{ t('admin_sinusbot_stop', page_locale()) }}</button>
                    </form>
                    <form method="post" action="/admin/sinusbot/nodes/{{ node.id }}/restart">
                        <input type="hidden" name="_token" value="{{ csrf.restart }}">
                        <button class="sinusbot-button" type="submit" data-loading-text="Starte neu…">{{ t('admin_sinusbot_restart', page_locale()) }}</button>
                    </form>
                </div>
            </div>

            <div class="sinusbot-card">
                <div class="sinusbot-card-header">
                    <div>
                        <h2>Kunden-Instanzen</h2>
                        <p class="sinusbot-muted">Pro Kunde wird eine eigene SinusBot-Instanz mit Bot-Quota verwaltet.</p>
                    </div>
                </div>
                <form class="sinusbot-form" method="post" action="/admin/sinusbot/instances/create">
                    <input type="hidden" name="_token" value="{{ csrf.instance_create }}">
                    <input type="hidden" name="node_id" value="{{ node.id }}">
                    <div class="sinusbot-grid">
                        <div>
                            <label for="customer_id">Kunde</label>
                            <select id="customer_id" name="customer_id" required>
                                <option value="">Bitte wählen</option>
                                {% for customer in customers %}
                                    <option value="{{ customer.id }}">{{ customer.email }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div>
                            <label for="quota">Bot-Quota</label>
                            <input id="quota" name="quota" type="number" min="{{ quota_min }}" max="{{ quota_max }}" value="{{ quota_min }}" required>
                        </div>
                        <div>
                            <label for="username">Username (optional)</label>
                            <input id="username" name="username" type="text" placeholder="auto">
                        </div>
                    </div>
                    <button class="sinusbot-button" type="submit">Instanz erstellen</button>
                </form>

                {% if instances is not empty %}
                    <div class="sinusbot-instance-list">
                        {% for instance in instances %}
                            {% set instanceStatusLabel = instance.status == 'running' ? 'Online' : (instance.status == 'stopped' ? 'Offline' : 'Unbekannt') %}
                            {% set instanceStatusClass = instance.status == 'running' ? 'sinusbot-pill--success' : (instance.status == 'stopped' ? 'sinusbot-pill--danger' : 'sinusbot-pill--warning') %}
                            {% set instancePassword = instance_passwords[instance.id] ?? null %}
                            {% set botId = instance.botId ?? instance.instanceId %}
                            <div class="sinusbot-instance-card">
                                <div class="sinusbot-card-header">
                                    <div>
                                        <h3>{{ instance.customer ? instance.customer.email : 'Unbekannter Kunde' }}</h3>
                                        <p class="sinusbot-muted">Instanz-ID {{ instance.instanceId }}</p>
                                    </div>
                                    <span class="sinusbot-pill {{ instanceStatusClass }}">{{ instanceStatusLabel }}</span>
                                </div>
                                <div class="sinusbot-instance-grid">
                                    <div class="sinusbot-field">
                                        <span class="sinusbot-field__label">Status</span>
                                        <span class="sinusbot-field__value">{{ instance.status }}</span>
                                    </div>
                                    <div class="sinusbot-field">
                                        <span class="sinusbot-field__label">Letzter Check</span>
                                        <span class="sinusbot-field__value">
                                            {{ instance.lastSeenAt ? instance.lastSeenAt|date('Y-m-d H:i') : '—' }}
                                        </span>
                                    </div>
                                    <div class="sinusbot-field">
                                        <span class="sinusbot-field__label">Bot-ID</span>
                                        {% if botId %}
                                            <span class="sinusbot-field__value">{{ botId }}</span>
                                        {% else %}
                                            <span class="sinusbot-field__value">—</span>
                                            <span class="sinusbot-hint">Noch keine Bot-ID gemeldet (Status-Refresh ausführen).</span>
                                        {% endif %}
                                    </div>
                                    <div class="sinusbot-field">
                                        <span class="sinusbot-field__label">Verwaltungs-URL</span>
                                        {% if instance.manageUrl %}
                                            <div class="sinusbot-field__value">
                                                <a class="sinusbot-link" href="{{ instance.manageUrl }}" target="_blank" rel="noopener noreferrer">{{ instance.manageUrl }}</a>
                                                <button class="sinusbot-copy" type="button" data-sinusbot-copy="{{ instance.manageUrl }}">Kopieren</button>
                                            </div>
                                        {% else %}
                                            <span class="sinusbot-field__value">—</span>
                                            <span class="sinusbot-hint">URL fehlt: WebBind-IP/Port wurde vom Agenten noch nicht gemeldet.</span>
                                        {% endif %}
                                    </div>
                                    <div class="sinusbot-field">
                                        <span class="sinusbot-field__label">Benutzername</span>
                                        {% if instance.sinusbotUsername %}
                                            <div class="sinusbot-field__value">
                                                <span>{{ instance.sinusbotUsername }}</span>
                                                <button class="sinusbot-copy" type="button" data-sinusbot-copy="{{ instance.sinusbotUsername }}">Kopieren</button>
                                            </div>
                                        {% else %}
                                            <span class="sinusbot-field__value">—</span>
                                            <span class="sinusbot-hint">Noch kein Username gemeldet (Provisioning läuft oder Status-Refresh).</span>
                                        {% endif %}
                                    </div>
                                    <div class="sinusbot-field">
                                        <span class="sinusbot-field__label">Passwort</span>
                                        {% if instancePassword %}
                                            <div class="sinusbot-field__value sinusbot-secret-row">
                                                <span class="sinusbot-secret" data-sinusbot-secret="{{ instancePassword }}">••••••••</span>
                                                <button class="sinusbot-button sinusbot-button--ghost" type="button" data-sinusbot-reveal>Passwort anzeigen</button>
                                            </div>
                                        {% else %}
                                            <span class="sinusbot-field__value">—</span>
                                            <span class="sinusbot-hint">Passwort noch nicht gespeichert (Provisioning-Result fehlt).</span>
                                        {% endif %}
                                    </div>
                                    <div class="sinusbot-field">
                                        <span class="sinusbot-field__label">Quota</span>
                                        <span class="sinusbot-field__value">{{ instance.botQuota }}</span>
                                    </div>
                                </div>
                                <div class="sinusbot-actions">
                                    <form method="post" action="/admin/sinusbot/instances/{{ instance.id }}/start">
                                        <input type="hidden" name="_token" value="{{ instance_csrf[instance.id].start }}">
                                        <button class="sinusbot-button" type="submit" data-loading-text="Starte…">Starten</button>
                                    </form>
                                    <form method="post" action="/admin/sinusbot/instances/{{ instance.id }}/stop">
                                        <input type="hidden" name="_token" value="{{ instance_csrf[instance.id].stop }}">
                                        <button class="sinusbot-button" type="submit" data-loading-text="Stoppe…">Stoppen</button>
                                    </form>
                                    <form method="post" action="/admin/sinusbot/instances/{{ instance.id }}/restart">
                                        <input type="hidden" name="_token" value="{{ instance_csrf[instance.id].restart }}">
                                        <button class="sinusbot-button" type="submit" data-loading-text="Starte neu…">Restart</button>
                                    </form>
                                    <form method="post" action="/admin/sinusbot/instances/{{ instance.id }}/reset-password">
                                        <input type="hidden" name="_token" value="{{ instance_csrf[instance.id].reset }}">
                                        <button class="sinusbot-button" type="submit" data-loading-text="Setze zurück…">Passwort reset</button>
                                    </form>
                                </div>
                                <form class="sinusbot-form sinusbot-form-inline" method="post" action="/admin/sinusbot/instances/{{ instance.id }}/quota">
                                    <input type="hidden" name="_token" value="{{ instance_csrf[instance.id].quota }}">
                                    <label for="quota_{{ instance.id }}">Bot-Quota</label>
                                    <input id="quota_{{ instance.id }}" name="quota" type="number" min="{{ quota_min }}" max="{{ quota_max }}" value="{{ instance.botQuota }}" required>
                                    <button class="sinusbot-button" type="submit">Quota aktualisieren</button>
                                </form>
                                <form class="sinusbot-form" method="post" action="/admin/sinusbot/instances/{{ instance.id }}/delete" onsubmit="return confirm('SinusBot-Instanz wirklich löschen?');">
                                    <input type="hidden" name="_token" value="{{ instance_csrf[instance.id].delete }}">
                                    <div class="sinusbot-actions">
                                        <label>
                                            <input type="radio" name="mode" value="delete" checked>
                                            Löschen inkl. Agent
                                        </label>
                                        <label>
                                            <input type="radio" name="mode" value="detach">
                                            Nur Zuordnung entfernen
                                        </label>
                                        <button class="sinusbot-button" type="submit">Instanz löschen</button>
                                    </div>
                                </form>
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <p class="sinusbot-muted">Keine Kunden-Instanzen vorhanden.</p>
                {% endif %}
            </div>

            <div class="sinusbot-card">
                <div class="sinusbot-card-header">
                    <div>
                        <h2>Letzte Jobs</h2>
                        <p class="sinusbot-muted">Agent-Protokolle zur Fehlersuche.</p>
                    </div>
                </div>
                {% if agent_jobs is not empty %}
                    {% for job in agent_jobs %}
                        <div class="sinusbot-meta">
                            <div><strong>Typ:</strong> {{ job.type }}</div>
                            <div><strong>Status:</strong> {{ job.status.value }}</div>
                            <div><strong>Gestartet:</strong> {{ job.startedAt ? job.startedAt|date('Y-m-d H:i') : '—' }}</div>
                            <div><strong>Beendet:</strong> {{ job.finishedAt ? job.finishedAt|date('Y-m-d H:i') : '—' }}</div>
                            <div><strong>Fehler:</strong> {{ job.errorText ?? '—' }}</div>
                        </div>
                        {% if job.logText %}
                            <div class="sinusbot-code"><pre>{{ job.logText }}</pre></div>
                        {% endif %}
                        {% if job.resultPayload %}
                            <div class="sinusbot-code"><pre>{{ job.resultPayload|json_encode(constant('JSON_PRETTY_PRINT')) }}</pre></div>
                        {% endif %}
                        {% if not loop.last %}
                            <p class="sinusbot-muted">—</p>
                        {% endif %}
                    {% endfor %}
                {% else %}
                    <p class="sinusbot-muted">Keine Jobs vorhanden.</p>
                {% endif %}
            </div>

            <div class="sinusbot-card">
                <div class="sinusbot-card-header">
                    <div>
                        <h2>Sinusbot-Service</h2>
                        <p class="sinusbot-muted">Management-Zugriff und Service-Konfiguration der Node.</p>
                    </div>
                </div>
                <div class="sinusbot-meta">
                    <div><strong>Zugewiesener Kunde:</strong> {{ node.customer ? node.customer.email : '–' }}</div>
                    <div><strong>{{ t('admin_sinusbot_install_path_label', page_locale()) }}</strong> {{ node.installPath }}</div>
                    <div><strong>{{ t('admin_sinusbot_web_bind_label', page_locale()) }}</strong> {{ node.webBindIp }}:{{ node.webPortBase }}</div>
                    <div><strong>TS3-Client:</strong> {{ node.ts3ClientInstalled ? 'Installiert (Installed)' : 'Nicht installiert (Not installed)' }}</div>
                    <div><strong>TS3-Client Version:</strong> {{ node.ts3ClientVersion ?? '–' }}</div>
                    <div><strong>TS3-Client Pfad:</strong> {{ node.ts3ClientPath ?? '–' }}</div>
                    <div>
                        <strong>Verwaltungs-URL:</strong>
                        {% if management_url %}
                            <a class="sinusbot-link" href="{{ management_url }}" target="_blank" rel="noopener noreferrer">{{ management_url }}</a>
                        {% else %}
                            –
                        {% endif %}
                    </div>
                </div>
            </div>

            <div class="sinusbot-card">
                <h2>Login-Daten (Admin)</h2>
                <p class="sinusbot-muted">Zugangsdaten für den globalen SinusBot-Admin auf dieser Node.</p>
                {% if admin_password %}
                    <div class="sinusbot-credentials">
                        <div><strong>{{ t('admin_sinusbot_username_label', page_locale()) }}</strong> {{ node.adminUsername ?? '–' }}</div>
                        <div class="sinusbot-secret">{{ admin_password }}</div>
                    </div>
                    <button class="sinusbot-button" type="button" data-sinusbot-copy="{{ admin_password }}">{{ t('admin_sinusbot_copy', page_locale()) }}</button>
                {% else %}
                    <div class="sinusbot-credentials">
                        <div><strong>{{ t('admin_sinusbot_username_label', page_locale()) }}</strong> {{ node.adminUsername ?? '–' }}</div>
                        <div class="sinusbot-secret">••••••••</div>
                    </div>
                    <form method="post" action="/admin/sinusbot/nodes/{{ node.id }}/reveal-credentials">
                        <input type="hidden" name="_token" value="{{ csrf.reveal }}">
                        <button class="sinusbot-button" type="submit">{{ t('admin_sinusbot_reveal', page_locale()) }}</button>
                    </form>
                {% endif %}
            </div>

            <div class="sinusbot-card">
                <h2>{{ t('admin_sinusbot_user_management_title', page_locale()) }}</h2>
                <p class="sinusbot-muted">{{ t('admin_sinusbot_user_management_description', page_locale()) }}</p>
                <div class="sinusbot-code">
                    <pre>{{ t('admin_sinusbot_user_management_example', page_locale()) }}</pre>
                </div>
                <a class="sinusbot-link" href="https://sinusbot.github.io/api-docs/" target="_blank" rel="noopener noreferrer">
                    {{ t('admin_sinusbot_user_management_link', page_locale()) }}
                </a>
            </div>
        </div>
    </div>

    <script>
        const bindSinusbotActions = (root = document) => {
            root.querySelectorAll('[data-sinusbot-copy]').forEach((button) => {
                if (button.dataset.sinusbotCopyBound) {
                    return;
                }
                button.dataset.sinusbotCopyBound = 'true';
                button.addEventListener('click', () => {
                    navigator.clipboard?.writeText(button.dataset.sinusbotCopy || '');
                });
            });

            root.querySelectorAll('[data-sinusbot-reveal]').forEach((button) => {
                if (button.dataset.sinusbotRevealBound) {
                    return;
                }
                button.dataset.sinusbotRevealBound = 'true';
                button.addEventListener('click', () => {
                    const container = button.closest('.sinusbot-field');
                    const secret = container?.querySelector('[data-sinusbot-secret]');
                    if (!secret) {
                        return;
                    }
                    const value = secret.dataset.sinusbotSecret || '';
                    const revealed = secret.dataset.revealed === 'true';
                    if (revealed) {
                        secret.textContent = '••••••••';
                        secret.dataset.revealed = 'false';
                        button.textContent = 'Passwort anzeigen';
                        return;
                    }
                    secret.textContent = value;
                    secret.dataset.revealed = 'true';
                    button.textContent = 'Passwort verbergen';
                });
            });

            root.querySelectorAll('form').forEach((form) => {
                if (form.dataset.sinusbotLoadingBound) {
                    return;
                }
                form.dataset.sinusbotLoadingBound = 'true';
                form.addEventListener('submit', () => {
                    const button = form.querySelector('button[data-loading-text]');
                    if (!button) {
                        return;
                    }
                    button.dataset.originalText = button.textContent || '';
                    button.textContent = button.dataset.loadingText || button.textContent;
                    button.classList.add('is-loading');
                });
            });
        };

        bindSinusbotActions();
    </script>
{% endblock %}
