{% extends 'admin/base.html.twig' %}

{% block content %}
{% set locale = page_locale() %}

    <section class="ng-card" style="overflow:hidden;">
        <div class="tkt-hero">
            <div class="tkt-hero__inner">
                <div>
                    <div class="tkt-hero__pill"><span class="tkt-hero__pill-dot"></span> SinusBot</div>
                    <h1 class="tkt-hero__title" style="margin-top:10px;">{{ node.name }}</h1>
                    <p class="tkt-hero__sub">{{ t('admin_sinusbot_intro', locale) }}</p>
                </div>
                <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
                    <a class="ui-button ui-button--ghost ui-button--sm" href="/admin/sinusbot/nodes">{{ t('admin_sinusbot_back_to_overview', locale) }}</a>
                    <form method="post" action="/admin/sinusbot/nodes/{{ node.id }}/delete" onsubmit="return confirm('{{ t('admin_sinusbot_delete_confirm', locale) }}');">
                        <input type="hidden" name="_token" value="{{ csrf.delete }}">
                        <button class="ui-button ui-button--danger ui-button--sm" type="submit">{{ t('admin_sinusbot_delete', locale) }}</button>
                    </form>
                </div>
            </div>
        </div>
    </section>

    {% for message in app.flashes('success') %}
        <div class="ng-alert ng-alert--success" style="margin-top:16px;">{{ t(message, page_locale()) }}</div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="ng-alert ng-alert--danger" style="margin-top:16px;">{{ t(message, page_locale()) }}</div>
    {% endfor %}

    {% set runtimeLabel = node.running ? 'Online' : 'Offline' %}
    {% set runtimeBadge = node.running ? 'success' : 'danger' %}

    <div style="display:flex;flex-direction:column;gap:20px;margin-top:20px;">

        <div class="ng-data-card">
            <div class="ng-data-card__header">
                <div>
                    <h2 class="ng-data-card__title">{{ t('admin_sinusbot_installation_title', locale) }}</h2>
                    <p class="ng-data-card__sub">{{ t('admin_sinusbot_service_desc', locale) }}</p>
                </div>
                <div class="ng-data-card__actions">
                    <span class="ui-badge ui-badge--neutral">{{ node.installStatus }}</span>
                    <span class="ui-badge ui-badge--{{ runtimeBadge }}">{{ runtimeLabel }}</span>
                </div>
            </div>
            <div class="ng-data-card__body">
                <div style="display:flex;flex-direction:column;gap:8px;margin-bottom:16px;">
                    <div><strong>{{ t('admin_sinusbot_status_label', locale) }}</strong> {{ node.installStatus }}</div>
                    <div><strong>{{ t('admin_sinusbot_runtime', locale) }}:</strong> {{ node.running ? t('admin_sinusbot_start_instance', locale) : t('admin_sinusbot_stop_instance', locale) }}</div>
                    <div><strong>{{ t('admin_sinusbot_version_label', locale) }}</strong> {{ node.installedVersion ?? '–' }}</div>
                    <div><strong>{{ t('admin_sinusbot_last_error_label', locale) }}</strong> {{ node.lastError ?? '–' }}</div>
                </div>
                <div style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:8px;">
                    <form method="post" action="/admin/sinusbot/nodes/{{ node.id }}/install">
                        <input type="hidden" name="_token" value="{{ csrf.install }}">
                        <button class="ui-button ui-button--ghost ui-button--sm" type="submit" data-loading-text="Installiere…">{{ t('admin_sinusbot_install_repair', locale) }}</button>
                    </form>
                    <form method="post" action="/admin/sinusbot/nodes/{{ node.id }}/refresh">
                        <input type="hidden" name="_token" value="{{ csrf.refresh }}">
                        <button class="ui-button ui-button--ghost ui-button--sm" type="submit" data-loading-text="Aktualisiere…">{{ t('admin_sinusbot_refresh_status', locale) }}</button>
                    </form>
                </div>
                <div style="display:flex;flex-wrap:wrap;gap:8px;">
                    <form method="post" action="/admin/sinusbot/nodes/{{ node.id }}/start">
                        <input type="hidden" name="_token" value="{{ csrf.start }}">
                        <button class="ui-button ui-button--ghost ui-button--sm" type="submit" data-loading-text="Starte…">{{ t('admin_sinusbot_start', locale) }}</button>
                    </form>
                    <form method="post" action="/admin/sinusbot/nodes/{{ node.id }}/stop">
                        <input type="hidden" name="_token" value="{{ csrf.stop }}">
                        <button class="ui-button ui-button--ghost ui-button--sm" type="submit" data-loading-text="Stoppe…">{{ t('admin_sinusbot_stop', locale) }}</button>
                    </form>
                    <form method="post" action="/admin/sinusbot/nodes/{{ node.id }}/restart">
                        <input type="hidden" name="_token" value="{{ csrf.restart }}">
                        <button class="ui-button ui-button--ghost ui-button--sm" type="submit" data-loading-text="Starte neu…">{{ t('admin_sinusbot_restart', locale) }}</button>
                    </form>
                </div>
            </div>
        </div>

        <div class="ng-data-card">
            <div class="ng-data-card__header">
                <div>
                    <h2 class="ng-data-card__title">{{ t('admin_sinusbot_customer_instances_title', locale) }}</h2>
                    <p class="ng-data-card__sub">{{ t('admin_sinusbot_customer_instances_desc', locale) }}</p>
                </div>
            </div>
            <div class="ng-data-card__body">
                <form method="post" action="/admin/sinusbot/instances/create" style="display:flex;flex-wrap:wrap;gap:16px;align-items:flex-end;margin-bottom:24px;">
                    <input type="hidden" name="_token" value="{{ csrf.instance_create }}">
                    <input type="hidden" name="node_id" value="{{ node.id }}">
                    <div class="form-field" style="flex:1;min-width:160px;">
                        <label class="form-label" for="customer_id">{{ t('admin_sinusbot_customer_label', locale) }}</label>
                        <select id="customer_id" name="customer_id" class="form-input" required>
                            <option value="">{{ t('admin_sinusbot_select_customer', locale) }}</option>
                            {% for customer in customers %}
                                <option value="{{ customer.id }}">{{ customer.email }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="form-field" style="flex:1;min-width:120px;">
                        <label class="form-label" for="quota">{{ t('admin_sinusbot_quota_label', locale) }}</label>
                        <input id="quota" name="quota" type="number" class="form-input" min="{{ quota_min }}" max="{{ quota_max }}" value="{{ quota_min }}" required>
                    </div>
                    <div class="form-field" style="flex:1;min-width:160px;">
                        <label class="form-label" for="username">{{ t('admin_sinusbot_username_optional', locale) }}</label>
                        <input id="username" name="username" type="text" class="form-input" placeholder="auto">
                    </div>
                    <div>
                        <button class="ui-button ui-button--primary" type="submit">{{ t('admin_sinusbot_create_instance', locale) }}</button>
                    </div>
                </form>

                {% if instances is not empty %}
                    <div style="display:flex;flex-direction:column;gap:20px;">
                        {% for instance in instances %}
                            {% set instanceStatusLabel = instance.status == 'running' ? t('admin_sinusbot_instance_online', locale) : (instance.status == 'stopped' ? t('admin_sinusbot_instance_offline', locale) : t('customer_ts_unknown', locale)) %}
                            {% set instanceStatusBadge = instance.status == 'running' ? 'success' : (instance.status == 'stopped' ? 'danger' : 'warning') %}
                            {% set instancePassword = instance_passwords[instance.id] ?? null %}
                            {% set botId = instance.botId ?? instance.instanceId %}
                            <div class="ng-data-card" style="border:1px solid #e2e8f0;">
                                <div class="ng-data-card__header">
                                    <div>
                                        <h3 class="ng-data-card__title">{{ instance.customer ? instance.customer.email : t('admin_sinusbot_unknown_customer', locale) }}</h3>
                                        <p class="ng-data-card__sub">{{ t('admin_sinusbot_instance_id_label', locale) }} {{ instance.instanceId }}</p>
                                    </div>
                                    <div class="ng-data-card__actions">
                                        <span class="ui-badge ui-badge--{{ instanceStatusBadge }}">{{ instanceStatusLabel }}</span>
                                    </div>
                                </div>
                                <div class="ng-data-card__body">
                                    <div style="display:flex;flex-direction:column;gap:8px;margin-bottom:16px;">
                                        <div>
                                            <span style="font-weight:500;color:#64748b;font-size:13px;">{{ t('admin_sinusbot_status', locale) }}</span>
                                            <span style="margin-left:8px;">{{ instance.status }}</span>
                                        </div>
                                        <div>
                                            <span style="font-weight:500;color:#64748b;font-size:13px;">{{ t('admin_sinusbot_last_check', locale) }}</span>
                                            <span style="margin-left:8px;">{{ instance.lastSeenAt ? instance.lastSeenAt|date('Y-m-d H:i') : '—' }}</span>
                                        </div>
                                        <div>
                                            <span style="font-weight:500;color:#64748b;font-size:13px;">{{ t('admin_sinusbot_bot_id', locale) }}</span>
                                            <span style="margin-left:8px;">
                                                {% if botId %}{{ botId }}{% else %}—{% endif %}
                                            </span>
                                        </div>
                                        <div>
                                            <span style="font-weight:500;color:#64748b;font-size:13px;">{{ t('admin_sinusbot_manage_url', locale) }}</span>
                                            <span style="margin-left:8px;">
                                                {% if instance.manageUrl %}
                                                    <a href="{{ instance.manageUrl }}" target="_blank" rel="noopener noreferrer" style="color:#6366f1;">{{ instance.manageUrl }}</a>
                                                    <button class="ui-button ui-button--ghost ui-button--sm" type="button" data-sinusbot-copy="{{ instance.manageUrl }}" style="margin-left:8px;">{{ t('admin_sinusbot_copy', locale) }}</button>
                                                {% else %}
                                                    —
                                                {% endif %}
                                            </span>
                                        </div>
                                        <div>
                                            <span style="font-weight:500;color:#64748b;font-size:13px;">{{ t('admin_sinusbot_username_field', locale) }}</span>
                                            <span style="margin-left:8px;">
                                                {% if instance.sinusbotUsername %}
                                                    {{ instance.sinusbotUsername }}
                                                    <button class="ui-button ui-button--ghost ui-button--sm" type="button" data-sinusbot-copy="{{ instance.sinusbotUsername }}" style="margin-left:8px;">{{ t('admin_sinusbot_copy', locale) }}</button>
                                                {% else %}
                                                    —
                                                {% endif %}
                                            </span>
                                        </div>
                                        <div style="display:flex;align-items:center;gap:8px;">
                                            <span style="font-weight:500;color:#64748b;font-size:13px;">{{ t('admin_sinusbot_password', locale) }}</span>
                                            {% if instancePassword %}
                                                <span data-sinusbot-secret="{{ instancePassword }}" data-label-reveal="{{ t('admin_sinusbot_password_reveal', locale) }}" data-label-hide="{{ t('admin_sinusbot_password_hide', locale) }}" style="font-family:monospace;background:#f1f5f9;padding:4px 8px;border-radius:4px;">••••••••</span>
                                                <button class="ui-button ui-button--ghost ui-button--sm" type="button" data-sinusbot-reveal>{{ t('admin_sinusbot_password_reveal', locale) }}</button>
                                            {% else %}
                                                <span style="margin-left:8px;">—</span>
                                            {% endif %}
                                        </div>
                                        <div>
                                            <span style="font-weight:500;color:#64748b;font-size:13px;">{{ t('admin_sinusbot_quota', locale) }}</span>
                                            <span style="margin-left:8px;">{{ instance.botQuota }}</span>
                                        </div>
                                    </div>

                                    <div style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:12px;">
                                        <form method="post" action="/admin/sinusbot/instances/{{ instance.id }}/start">
                                            <input type="hidden" name="_token" value="{{ instance_csrf[instance.id].start }}">
                                            <button class="ui-button ui-button--ghost ui-button--sm" type="submit" data-loading-text="Starte…">{{ t('admin_sinusbot_start_instance', locale) }}</button>
                                        </form>
                                        <form method="post" action="/admin/sinusbot/instances/{{ instance.id }}/stop">
                                            <input type="hidden" name="_token" value="{{ instance_csrf[instance.id].stop }}">
                                            <button class="ui-button ui-button--ghost ui-button--sm" type="submit" data-loading-text="Stoppe…">{{ t('admin_sinusbot_stop_instance', locale) }}</button>
                                        </form>
                                        <form method="post" action="/admin/sinusbot/instances/{{ instance.id }}/restart">
                                            <input type="hidden" name="_token" value="{{ instance_csrf[instance.id].restart }}">
                                            <button class="ui-button ui-button--ghost ui-button--sm" type="submit" data-loading-text="Starte neu…">{{ t('admin_sinusbot_restart_instance', locale) }}</button>
                                        </form>
                                        <form method="post" action="/admin/sinusbot/instances/{{ instance.id }}/reset-password">
                                            <input type="hidden" name="_token" value="{{ instance_csrf[instance.id].reset }}">
                                            <button class="ui-button ui-button--ghost ui-button--sm" type="submit" data-loading-text="{{ t('admin_sinusbot_reset_loading', page_locale()) }}">{{ t('admin_sinusbot_password_reset_btn', locale) }}</button>
                                        </form>
                                    </div>

                                    <form method="post" action="/admin/sinusbot/instances/{{ instance.id }}/quota" style="display:flex;align-items:center;gap:8px;margin-bottom:12px;">
                                        <input type="hidden" name="_token" value="{{ instance_csrf[instance.id].quota }}">
                                        <label class="form-label" for="quota_{{ instance.id }}" style="margin:0;">{{ t('admin_sinusbot_quota_label', locale) }}</label>
                                        <input id="quota_{{ instance.id }}" name="quota" type="number" class="form-input" style="width:100px;" min="{{ quota_min }}" max="{{ quota_max }}" value="{{ instance.botQuota }}" required>
                                        <button class="ui-button ui-button--ghost ui-button--sm" type="submit">{{ t('admin_sinusbot_quota_update', locale) }}</button>
                                    </form>

                                    <form method="post" action="/admin/sinusbot/instances/{{ instance.id }}/delete" onsubmit="return confirm('{{ t('admin_sinusbot_instance_delete_confirm', locale) }}');">
                                        <input type="hidden" name="_token" value="{{ instance_csrf[instance.id].delete }}">
                                        <div style="display:flex;flex-wrap:wrap;align-items:center;gap:12px;">
                                            <label style="display:flex;align-items:center;gap:6px;font-size:14px;">
                                                <input type="radio" name="mode" value="delete" checked>
                                                {{ t('admin_sinusbot_delete_with_agent', locale) }}
                                            </label>
                                            <label style="display:flex;align-items:center;gap:6px;font-size:14px;">
                                                <input type="radio" name="mode" value="detach">
                                                {{ t('admin_sinusbot_detach_only', locale) }}
                                            </label>
                                            <button class="ui-button ui-button--danger ui-button--sm" type="submit">{{ t('admin_sinusbot_delete_instance', locale) }}</button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <p style="color:#64748b;">{{ t('admin_sinusbot_no_instances', locale) }}</p>
                {% endif %}
            </div>
        </div>

        <div class="ng-data-card">
            <div class="ng-data-card__header">
                <div>
                    <h2 class="ng-data-card__title">{{ t('admin_sinusbot_recent_jobs', locale) }}</h2>
                    <p class="ng-data-card__sub">{{ t('admin_sinusbot_jobs_desc', locale) }}</p>
                </div>
            </div>
            <div class="ng-data-card__body">
                {% if agent_jobs is not empty %}
                    {% for job in agent_jobs %}
                        <div style="display:flex;flex-direction:column;gap:6px;margin-bottom:12px;">
                            <div><strong>{{ t('admin_sinusbot_job_type', locale) }}</strong> {{ job.type }}</div>
                            <div><strong>{{ t('admin_sinusbot_job_status', locale) }}</strong> {{ job.status.value }}</div>
                            <div><strong>{{ t('admin_sinusbot_job_started', locale) }}</strong> {{ job.startedAt ? job.startedAt|date('Y-m-d H:i') : '—' }}</div>
                            <div><strong>{{ t('admin_sinusbot_job_finished', locale) }}</strong> {{ job.finishedAt ? job.finishedAt|date('Y-m-d H:i') : '—' }}</div>
                            <div><strong>{{ t('admin_sinusbot_job_error', locale) }}</strong> {{ job.errorText ?? '—' }}</div>
                        </div>
                        {% if job.logText %}
                            <pre style="background:#0f172a;color:#e2e8f0;padding:12px;border-radius:6px;overflow-x:auto;font-size:12px;margin-bottom:12px;">{{ job.logText }}</pre>
                        {% endif %}
                        {% if job.resultPayload %}
                            <pre style="background:#0f172a;color:#e2e8f0;padding:12px;border-radius:6px;overflow-x:auto;font-size:12px;margin-bottom:12px;">{{ job.resultPayload|json_encode(constant('JSON_PRETTY_PRINT')) }}</pre>
                        {% endif %}
                        {% if not loop.last %}
                            <hr style="border:none;border-top:1px solid #e2e8f0;margin:12px 0;">
                        {% endif %}
                    {% endfor %}
                {% else %}
                    <p style="color:#64748b;">{{ t('admin_sinusbot_no_jobs', locale) }}</p>
                {% endif %}
            </div>
        </div>

        <div class="ng-data-card">
            <div class="ng-data-card__header">
                <div>
                    <h2 class="ng-data-card__title">{{ t('admin_sinusbot_service_title', locale) }}</h2>
                    <p class="ng-data-card__sub">{{ t('admin_sinusbot_service_desc', locale) }}</p>
                </div>
            </div>
            <div class="ng-data-card__body">
                <div style="display:flex;flex-direction:column;gap:8px;">
                    <div><strong>{{ t('admin_sinusbot_assigned_customer', locale) }}</strong> {{ node.customer ? node.customer.email : '–' }}</div>
                    <div><strong>{{ t('admin_sinusbot_install_path_label', locale) }}</strong> {{ node.installPath }}</div>
                    <div><strong>{{ t('admin_sinusbot_web_bind_label', locale) }}</strong> {{ node.webBindIp }}:{{ node.webPortBase }}</div>
                    <div><strong>{{ t('admin_sinusbot_ts3_client', locale) }}</strong> {{ node.ts3ClientInstalled ? t('admin_sinusbot_ts3_installed', locale) : t('admin_sinusbot_ts3_not_installed', locale) }}</div>
                    <div><strong>{{ t('admin_sinusbot_ts3_version', locale) }}</strong> {{ node.ts3ClientVersion ?? '–' }}</div>
                    <div><strong>{{ t('admin_sinusbot_ts3_path', locale) }}</strong> {{ node.ts3ClientPath ?? '–' }}</div>
                    <div>
                        <strong>{{ t('admin_sinusbot_manage_url_field', locale) }}</strong>
                        {% if management_url %}
                            <a href="{{ management_url }}" target="_blank" rel="noopener noreferrer" style="color:#6366f1;">{{ management_url }}</a>
                        {% else %}
                            –
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>

        <div class="ng-data-card">
            <div class="ng-data-card__header">
                <div>
                    <h2 class="ng-data-card__title">{{ t('admin_sinusbot_login_title', locale) }}</h2>
                    <p class="ng-data-card__sub">{{ t('admin_sinusbot_login_desc', locale) }}</p>
                </div>
            </div>
            <div class="ng-data-card__body">
                {% if admin_password %}
                    <div style="display:flex;flex-direction:column;gap:6px;margin-bottom:12px;">
                        <div><strong>{{ t('admin_sinusbot_username_label', locale) }}</strong> {{ node.adminUsername ?? '–' }}</div>
                        <div style="font-family:monospace;background:#f1f5f9;padding:8px 12px;border-radius:6px;">{{ admin_password }}</div>
                    </div>
                    <button class="ui-button ui-button--ghost ui-button--sm" type="button" data-sinusbot-copy="{{ admin_password }}">{{ t('admin_sinusbot_copy', locale) }}</button>
                {% else %}
                    <div style="display:flex;flex-direction:column;gap:6px;margin-bottom:12px;">
                        <div><strong>{{ t('admin_sinusbot_username_label', locale) }}</strong> {{ node.adminUsername ?? '–' }}</div>
                        <div style="font-family:monospace;background:#f1f5f9;padding:8px 12px;border-radius:6px;letter-spacing:2px;">••••••••</div>
                    </div>
                    <form method="post" action="/admin/sinusbot/nodes/{{ node.id }}/reveal-credentials" style="margin-top:12px;">
                        <input type="hidden" name="_token" value="{{ csrf.reveal }}">
                        <button class="ui-button ui-button--ghost ui-button--sm" type="submit">{{ t('admin_sinusbot_reveal', locale) }}</button>
                    </form>
                {% endif %}
            </div>
        </div>

        <div class="ng-data-card">
            <div class="ng-data-card__header">
                <div>
                    <h2 class="ng-data-card__title">{{ t('admin_sinusbot_user_management_title', locale) }}</h2>
                    <p class="ng-data-card__sub">{{ t('admin_sinusbot_user_management_description', locale) }}</p>
                </div>
            </div>
            <div class="ng-data-card__body">
                <pre style="background:#0f172a;color:#e2e8f0;padding:12px;border-radius:6px;overflow-x:auto;font-size:12px;margin-bottom:12px;">{{ t('admin_sinusbot_user_management_example', locale) }}</pre>
                <a class="ui-button ui-button--ghost ui-button--sm" href="https://sinusbot.github.io/api-docs/" target="_blank" rel="noopener noreferrer">
                    {{ t('admin_sinusbot_user_management_link', locale) }}
                </a>
            </div>
        </div>

    </div>

    <script>
        const bindSinusbotActions = (root = document) => {
            root.querySelectorAll('[data-sinusbot-copy]').forEach((button) => {
                if (button.dataset.sinusbotCopyBound) {
                    return;
                }
                button.dataset.sinusbotCopyBound = 'true';
                button.addEventListener('click', () => {
                    navigator.clipboard?.writeText(button.dataset.sinusbotCopy || '');
                });
            });

            root.querySelectorAll('[data-sinusbot-reveal]').forEach((button) => {
                if (button.dataset.sinusbotRevealBound) {
                    return;
                }
                button.dataset.sinusbotRevealBound = 'true';
                button.addEventListener('click', () => {
                    const container = button.closest('.ng-data-card__body');
                    const secret = container?.querySelector('[data-sinusbot-secret]');
                    if (!secret) {
                        return;
                    }
                    const value = secret.dataset.sinusbotSecret || '';
                    const revealed = secret.dataset.revealed === 'true';
                    if (revealed) {
                        secret.textContent = '••••••••';
                        secret.dataset.revealed = 'false';
                        button.textContent = secret.dataset.labelReveal || 'Show Password';
                        return;
                    }
                    secret.textContent = value;
                    secret.dataset.revealed = 'true';
                    button.textContent = secret.dataset.labelHide || 'Hide Password';
                });
            });

            root.querySelectorAll('form').forEach((form) => {
                if (form.dataset.sinusbotLoadingBound) {
                    return;
                }
                form.dataset.sinusbotLoadingBound = 'true';
                form.addEventListener('submit', () => {
                    const button = form.querySelector('button[data-loading-text]');
                    if (!button) {
                        return;
                    }
                    button.dataset.originalText = button.textContent || '';
                    button.textContent = button.dataset.loadingText || button.textContent;
                    button.classList.add('is-loading');
                });
            });
        };

        bindSinusbotActions();
    </script>
{% endblock %}
