{% extends 'admin/base.html.twig' %}

{% block title %}{{ t('admin_sinusbot_nodes_page_title', page_locale()) }} · Easy-Wi NextGen{% endblock %}

{% block content %}
{% set locale = page_locale() %}
    <div class="sinusbot-page">
        <div class="sinusbot-header">
            <div>
                <h1>{{ t('admin_sinusbot_nodes_page_title', locale) }}</h1>
                <p>{{ t('admin_sinusbot_nodes_page_desc', locale) }}</p>
            </div>
            <div class="sinusbot-actions">
                <a class="sinusbot-button" href="/admin/sinusbot/nodes/new">{{ t('admin_sinusbot_nodes_add', locale) }}</a>
            </div>
        </div>

        {% for message in app.flashes('success') %}
            <div class="sinusbot-alert sinusbot-alert-success">{{ t(message, page_locale()) }}</div>
        {% endfor %}

        <div class="sinusbot-card">
            <table class="sinusbot-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>{{ t('admin_sinusbot_nodes_status', locale) }}</th>
                        <th>Version</th>
                        <th>{{ t('admin_sinusbot_nodes_actions', locale) }}</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    {% for node in nodes %}
                        <tr>
                            <td>
                                <div>{{ node.name }}</div>
                            </td>
                            {% set sinusStatusLabel = node.installStatus %}
                            {% if node.installStatus == 'installed' %}
                                {% set sinusStatusLabel = node.running ? 'running' : 'stopped' %}
                            {% endif %}
                            <td><span class="sinusbot-pill">{{ sinusStatusLabel }}</span></td>
                            <td>{{ node.installedVersion ?? '–' }}</td>
                            <td>{{ node.updatedAt|date('Y-m-d H:i') }}</td>
                            <td class="sinusbot-align-right">
                                <a class="sinusbot-link" href="/admin/sinusbot/nodes/{{ node.id }}">{{ t('admin_sinusbot_nodes_details', locale) }}</a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="5" class="sinusbot-empty">{{ t('admin_sinusbot_nodes_none', locale) }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
