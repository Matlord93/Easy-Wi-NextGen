{% extends 'admin/base.html.twig' %}

{% set pageTitle = t('admin_sinusbot_nodes_page_title', page_locale()) %}
{% set pageSubtitle = t('admin_sinusbot_nodes_page_desc', page_locale()) %}
{% set activeNav = 'sinusbot-nodes' %}

{% block content %}
{% set locale = page_locale() %}
<div style="display:flex;flex-direction:column;gap:20px;">

    <section class="ng-card" style="overflow:hidden;">
        <div class="tkt-hero">
            <div class="tkt-hero__inner">
                <div>
                    <div class="tkt-hero__pill"><span class="tkt-hero__pill-dot"></span> SinusBot</div>
                    <h1 class="tkt-hero__title" style="margin-top:10px;">{{ t('admin_sinusbot_nodes_page_title', locale) }}</h1>
                    <p class="tkt-hero__sub">{{ t('admin_sinusbot_nodes_page_desc', locale) }}</p>
                </div>
                <div style="display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:10px;margin-top:16px;">
                    <div class="tkt-kpi">
                        <div class="tkt-kpi__label">{{ t('total', locale) }}</div>
                        <div class="tkt-kpi__value">{{ nodes|length }}</div>
                    </div>
                    <div class="tkt-kpi tkt-kpi--open">
                        <div class="tkt-kpi__label">Running</div>
                        <div class="tkt-kpi__value">{{ nodes|filter(n => n.running)|length }}</div>
                    </div>
                    <div class="tkt-kpi tkt-kpi--pending">
                        <div class="tkt-kpi__label">Stopped</div>
                        <div class="tkt-kpi__value">{{ nodes|filter(n => not n.running)|length }}</div>
                    </div>
                </div>
            </div>
        </div>
        <div style="padding:14px 16px;border-top:1px solid var(--ng-border);background:var(--ng-surface-soft);">
            <a class="ui-button ui-button--primary ui-button--sm" href="/admin/sinusbot/nodes/new">{{ t('admin_sinusbot_nodes_add', locale) }}</a>
        </div>
    </section>

    {% for message in app.flashes('success') %}
        <div class="ng-alert ng-alert--success">{{ t(message, locale) }}</div>
    {% endfor %}

    <div class="ng-data-card">
        <div class="ng-data-card__header">
            <div>
                <h2 class="ng-data-card__title">{{ t('admin_sinusbot_nodes_page_title', locale) }}</h2>
                <p class="ng-data-card__sub">{{ t('admin_sinusbot_nodes_page_desc', locale) }}</p>
            </div>
        </div>
        <div class="ng-data-card__body ng-data-card__body--flush">
            <div class="cust-ws-table-wrap">
                <table class="cust-table">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>{{ t('admin_sinusbot_nodes_status', locale) }}</th>
                            <th>Version</th>
                            <th>{{ t('admin_sinusbot_nodes_actions', locale) }}</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for node in nodes %}
                            <tr>
                                <td>
                                    <div>{{ node.name }}</div>
                                </td>
                                <td>
                                    {% set sinusStatusLabel = node.installStatus %}
                                    {% if node.installStatus == 'installed' %}
                                        {% set sinusStatusLabel = node.running ? 'running' : 'stopped' %}
                                    {% endif %}
                                    {% set statusBadge = sinusStatusLabel == 'running' ? 'success' : (sinusStatusLabel == 'stopped' ? 'warning' : 'neutral') %}
                                    <span class="ui-badge ui-badge--{{ statusBadge }}">{{ t('admin_node_status_' ~ sinusStatusLabel, locale) }}</span>
                                </td>
                                <td>{{ node.installedVersion ?? '–' }}</td>
                                <td>{{ node.updatedAt|date('Y-m-d H:i') }}</td>
                                <td style="text-align:right;">
                                    <a class="ui-button ui-button--ghost ui-button--sm" href="/admin/sinusbot/nodes/{{ node.id }}">{{ t('admin_sinusbot_nodes_details', locale) }}</a>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="5" class="cust-table__empty">{{ t('admin_sinusbot_nodes_none', locale) }}</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>
{% endblock %}
