<div id="agent-update-card" class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
    <div class="flex flex-col gap-2">
        <h3 class="text-lg font-semibold text-slate-900">{{ t('admin_updates_agents_title', page_locale()) }}</h3>
        <p class="text-sm text-slate-700">{{ t('admin_updates_agents_intro', page_locale()) }}</p>
    </div>

    {# ── Release channel selector ── #}
    <div class="mt-4 rounded-xl border border-slate-200 bg-slate-50/40 px-4 py-3">
        <p class="text-xs font-semibold uppercase text-slate-500 mb-2">Release-Kanal (Agenten)</p>
        <form method="post" hx-post="/admin/updates/agents/channel" hx-target="#agent-update-card" hx-swap="outerHTML" class="flex flex-wrap items-center gap-3">
            <input type="hidden" name="csrf_token" value="{{ agentUpdate.csrf.agents_channel }}">
            {% for value, label in agentUpdate.channels %}
                <label class="flex cursor-pointer items-center gap-2 text-sm">
                    <input
                        type="radio" name="channel" value="{{ value }}"
                        {% if agentUpdate.channel == value %}checked{% endif %}
                        onchange="this.form.requestSubmit()"
                        class="accent-indigo-600"
                    >
                    <span class="font-medium text-slate-700">{{ label }}</span>
                    {% if value == 'stable' %}
                        <span class="rounded-full bg-emerald-100 px-2 py-0.5 text-[10px] font-semibold uppercase text-emerald-700">Empfohlen</span>
                    {% elseif value == 'beta' %}
                        <span class="rounded-full bg-amber-100 px-2 py-0.5 text-[10px] font-semibold uppercase text-amber-700">Vorschau</span>
                    {% elseif value == 'alpha' %}
                        <span class="rounded-full bg-rose-100 px-2 py-0.5 text-[10px] font-semibold uppercase text-rose-700">Experimentell</span>
                    {% endif %}
                </label>
            {% endfor %}
        </form>
        <p class="mt-2 text-xs text-slate-500">
            Aktueller Kanal:
            <span class="font-semibold text-slate-700">{{ agentUpdate.channels[agentUpdate.channel] ?? agentUpdate.channel }}</span>.
            {% if agentUpdate.channel == 'alpha' %}
                Alpha-Agenten können instabil sein.
            {% elseif agentUpdate.channel == 'beta' %}
                Beta-Agenten sind Vorabversionen.
            {% else %}
                Stabile Agenten-Releases für Produktion.
            {% endif %}
        </p>
    </div>

    {% if agentUpdate.notice %}
        <div class="mt-4 rounded-lg border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-700">
            {{ t('admin_updates_agents_notice', page_locale()) }}
        </div>
    {% endif %}

    <div class="mt-5 grid gap-4 sm:grid-cols-3">
        <div class="rounded-lg border border-slate-200 bg-slate-50 px-4 py-3">
            <p class="text-xs font-semibold uppercase text-slate-500">{{ t('admin_nodes_total', page_locale()) }}</p>
            <p class="mt-2 text-xl font-semibold text-slate-900">{{ agentUpdate.total }}</p>
        </div>
        <div class="rounded-lg border border-slate-200 bg-slate-50 px-4 py-3">
            <p class="text-xs font-semibold uppercase text-slate-500">{{ t('admin_nodes_updates_label', page_locale()) }}</p>
            <p class="mt-2 text-xl font-semibold text-slate-900">{{ agentUpdate.updates }}</p>
        </div>
        <div class="rounded-lg border border-slate-200 bg-slate-50 px-4 py-3">
            <p class="text-xs font-semibold uppercase text-slate-500">{{ t('admin_updates_agents_latest', page_locale()) }}</p>
            <p class="mt-2 text-xl font-semibold text-slate-900">{{ agentUpdate.latestVersion ?? '—' }}</p>
        </div>
    </div>

    <div class="mt-5 flex flex-wrap gap-3">
        <button
            class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white"
            hx-post="/admin/updates/agents/update"
            hx-target="#agent-update-card"
            hx-swap="outerHTML"
        >{{ t('admin_updates_agents_action', page_locale()) }}</button>
        <a
            href="/admin/nodes"
            class="rounded-lg border border-slate-200 px-4 py-2 text-sm font-semibold text-slate-600"
        >{{ t('admin_updates_agents_manage', page_locale()) }}</a>
    </div>
</div>
