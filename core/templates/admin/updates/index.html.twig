{% extends 'admin/base.html.twig' %}

{% set pageTitle = t('admin_updates_title', page_locale()) %}
{% set pageSubtitle = t('admin_updates_intro', page_locale()) %}
{% set activeNav = 'updates' %}

{% block content %}
<div class="flex flex-col gap-6">
    <div class="ng-layout-2col--equal">
        <div class="ng-data-card">
            <div class="ng-data-card__header">
                <div>
                    <h2 class="ng-data-card__title">{{ t('admin_updates_web_title', page_locale()) }}</h2>
                </div>
            </div>
            <div class="ng-data-card__body">
                {% include 'admin/dashboard/_web_update_card.html.twig' with { coreUpdate: coreUpdate } %}
            </div>
        </div>

        <div id="agent-update-card" class="ng-data-card">
            <div class="ng-data-card__body">
                {% include 'admin/updates/_agent_update_card.html.twig' with { agentUpdate: agentUpdate } %}
            </div>
        </div>
    </div>
</div>
{% endblock %}
