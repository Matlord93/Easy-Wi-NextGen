{% extends 'admin/base.html.twig' %}

{% set pageTitle = t('admin_easywi_migration_page_title', page_locale()) %}
{% set pageSubtitle = t('admin_easywi_migration_page_desc', page_locale()) %}
{% set activeNav = 'easywi-migration' %}

{% block content %}
{% set locale = page_locale() %}
<div class="flex flex-col gap-6">

    {# ── Database Connection ── #}
    <div class="ng-data-card">
        <div class="ng-data-card__header">
            <div>
                <h2 class="ng-data-card__title">{{ t('admin_easywi_db_connection_title', locale) }}</h2>
                <p class="ng-data-card__sub">{{ t('admin_easywi_migration_page_desc', locale) }}</p>
            </div>
        </div>
        <div class="ng-data-card__body">
            <div class="grid grid-cols-2 gap-4">
                <div class="form-field">
                    <label class="form-label">{{ t('host', locale) }}</label>
                    <input id="mig-host" type="text" value="127.0.0.1" class="form-input">
                </div>
                <div class="form-field">
                    <label class="form-label">{{ t('port', locale) }}</label>
                    <input id="mig-port" type="number" value="3306" class="form-input">
                </div>
                <div class="form-field">
                    <label class="form-label">{{ t('admin_easywi_db_name', locale) }}</label>
                    <input id="mig-dbname" type="text" placeholder="easywi" class="form-input">
                </div>
                <div class="form-field">
                    <label class="form-label">{{ t('admin_easywi_table_prefix', locale) }}</label>
                    <input id="mig-prefix" type="text" value="easywi_" class="form-input">
                </div>
                <div class="form-field">
                    <label class="form-label">{{ t('username', locale) }}</label>
                    <input id="mig-user" type="text" value="root" class="form-input">
                </div>
                <div class="form-field">
                    <label class="form-label">{{ t('admin_easywi_password', locale) }}</label>
                    <input id="mig-password" type="password" class="form-input">
                </div>
            </div>
            <div class="mt-4 flex items-center gap-3">
                <button id="btn-probe" class="ui-button ui-button--ghost">
                    {{ t('admin_easywi_probe_button', locale) }}
                </button>
            </div>
            <div id="probe-result" class="mt-3 hidden"></div>
        </div>
    </div>

    {# ── Entity Selection ── #}
    <div class="ng-data-card">
        <div class="ng-data-card__header">
            <div>
                <h2 class="ng-data-card__title">{{ t('admin_easywi_entities_title', locale) }}</h2>
            </div>
        </div>
        <div class="ng-data-card__body">
            <div class="flex flex-wrap gap-3">
                {% for entity in entities %}
                    <label class="flex cursor-pointer items-center gap-2 rounded-lg border border-slate-200 bg-slate-50 px-3 py-2 text-sm text-slate-700 hover:bg-indigo-50 hover:border-indigo-300 transition has-[:checked]:border-indigo-500 has-[:checked]:bg-indigo-50">
                        <input type="checkbox" name="entity" value="{{ entity }}" checked class="accent-indigo-600">
                        {{ entity|capitalize }}
                    </label>
                {% endfor %}
            </div>
        </div>
    </div>

    {# ── Actions ── #}
    <div class="ng-data-card">
        <div class="ng-data-card__body">
            <div class="flex flex-wrap gap-3">
                <button id="btn-dryrun" class="ui-button ui-button--warning">
                    {{ t('admin_easywi_dry_run_button', locale) }}
                </button>
                <button id="btn-run" class="ui-button ui-button--primary">
                    {{ t('admin_easywi_migration_start', locale) }}
                </button>
            </div>
        </div>
    </div>

    {# ── Results ── #}
    <div id="run-result" class="ng-data-card hidden">
        <div class="ng-data-card__header">
            <div>
                <h2 class="ng-data-card__title">{{ t('admin_easywi_result_title', locale) }}</h2>
            </div>
        </div>
        <div class="ng-data-card__body">
            <div id="run-result-content"></div>
        </div>
    </div>

</div>

<script>
const MSG_MIGRATION_RUNNING = {{ t('admin_easywi_migration_running', locale)|json_encode|raw }};
const MSG_MIGRATION_DONE = {{ t('admin_easywi_migration_done', locale)|json_encode|raw }};
const MSG_MIGRATION_ERROR = {{ t('admin_easywi_migration_error', locale)|json_encode|raw }};
const MSG_ERROR_PREFIX = {{ t('customer_ts_action_error_prefix', locale)|json_encode|raw }};
const MSG_COL_ENTITY = {{ t('admin_easywi_col_entity', locale)|json_encode|raw }};
const MSG_COL_IMPORTED = {{ t('admin_easywi_col_imported', locale)|json_encode|raw }};
const MSG_COL_SKIPPED = {{ t('admin_easywi_col_skipped', locale)|json_encode|raw }};
const MSG_COL_FAILED = {{ t('admin_easywi_col_failed', locale)|json_encode|raw }};
const MSG_COL_TOTAL = {{ t('admin_easywi_col_total', locale)|json_encode|raw }};
const MSG_EXECUTED = {{ t('common_executed', locale)|json_encode|raw }};
(function () {
    function buildPayload(dryRun) {
        return {
            host: document.getElementById('mig-host').value,
            port: parseInt(document.getElementById('mig-port').value, 10) || 3306,
            dbname: document.getElementById('mig-dbname').value,
            prefix: document.getElementById('mig-prefix').value,
            user: document.getElementById('mig-user').value,
            password: document.getElementById('mig-password').value,
            entities: [...document.querySelectorAll('input[name=entity]:checked')].map(el => el.value),
            dry_run: dryRun,
        };
    }

    document.getElementById('btn-probe').addEventListener('click', async () => {
        const btn = document.getElementById('btn-probe');
        const result = document.getElementById('probe-result');
        btn.disabled = true;
        result.innerHTML = `<p class="text-sm text-slate-500">${MSG_MIGRATION_RUNNING}</p>`;
        result.classList.remove('hidden');
        try {
            const resp = await fetch('/admin/easywi-migration/probe', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify(buildPayload(true)),
            });
            const data = await resp.json();
            if (data.error) {
                result.innerHTML = `<p class="text-sm text-red-600">${MSG_ERROR_PREFIX}: ${data.error}</p>`;
            } else {
                const rows = Object.entries(data.counts || {}).map(([t, c]) =>
                    `<tr><td class="pr-4 py-0.5 text-sm text-slate-700">${t}</td><td class="text-sm font-mono text-slate-900">${c.toLocaleString()}</td></tr>`
                ).join('');
                result.innerHTML = `<table class="mt-1">${rows}</table>`;
            }
        } catch (e) {
            result.innerHTML = `<p class="text-sm text-red-600">${e.message}</p>`;
        }
        btn.disabled = false;
    });

    async function runMigration(dryRun) {
        const resultBox = document.getElementById('run-result');
        const content = document.getElementById('run-result-content');
        resultBox.classList.remove('hidden');
        content.innerHTML = `<p class="text-sm text-slate-500">${MSG_MIGRATION_RUNNING}</p>`;
        try {
            const resp = await fetch('/admin/easywi-migration/run', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify(buildPayload(dryRun)),
            });
            const data = await resp.json();
            if (data.error) {
                content.innerHTML = `<p class="text-sm text-red-600">${MSG_ERROR_PREFIX}: ${data.error}</p>`;
                return;
            }
            const rows = (data.results || []).map(r => {
                const errs = r.errors && r.errors.length ? `<ul class="mt-1 ml-4 list-disc text-xs text-red-600">${r.errors.map(e => `<li>${e}</li>`).join('')}</ul>` : '';
                return `<tr class="border-t border-slate-100">
                    <td class="py-1.5 pr-4 text-sm font-medium text-slate-800">${r.entity}</td>
                    <td class="py-1.5 pr-4 text-sm text-emerald-700">${r.imported}</td>
                    <td class="py-1.5 pr-4 text-sm text-slate-500">${r.skipped}</td>
                    <td class="py-1.5 pr-4 text-sm text-red-600">${r.failed}</td>
                    <td class="py-1.5 text-sm text-slate-700">${r.total}</td>
                </tr>${errs ? `<tr><td colspan="5">${errs}</td></tr>` : ''}`;
            }).join('');
            const badge = dryRun
                ? '<span class="ui-badge ui-badge--warning ml-2">DRY-RUN</span>'
                : `<span class="ui-badge ui-badge--success ml-2">${MSG_EXECUTED}</span>`;
            content.innerHTML = `
                <div class="flex items-center gap-2 mb-3 text-sm font-semibold text-slate-800">${MSG_MIGRATION_DONE}${badge}</div>
                <table class="w-full">
                    <thead><tr class="text-xs font-semibold uppercase text-slate-500">
                        <th class="pb-1 pr-4 text-left">${MSG_COL_ENTITY}</th>
                        <th class="pb-1 pr-4 text-left text-emerald-700">${MSG_COL_IMPORTED}</th>
                        <th class="pb-1 pr-4 text-left">${MSG_COL_SKIPPED}</th>
                        <th class="pb-1 pr-4 text-left text-red-600">${MSG_COL_FAILED}</th>
                        <th class="pb-1 text-left">${MSG_COL_TOTAL}</th>
                    </tr></thead>
                    <tbody>${rows}</tbody>
                </table>`;
        } catch (e) {
            content.innerHTML = `<p class="text-sm text-red-600">${e.message}</p>`;
        }
    }

    document.getElementById('btn-dryrun').addEventListener('click', () => runMigration(true));
    document.getElementById('btn-run').addEventListener('click', () => runMigration(false));
})();
</script>
{% endblock %}
