<div class="ng-data-card__body">
    <div class="mb-4">
        <h2 class="ng-data-card__title">{{ form.action == 'create' ? t('admin_servers_add_title', page_locale()) : t('admin_servers_edit_title', page_locale()) }}</h2>
        <p class="ng-data-card__sub">{{ t('admin_servers_form_intro', page_locale()) }}</p>
    </div>

    {% if form.errors is not empty %}
        <div class="ng-alert ng-alert--danger mb-4">
            <p class="font-semibold">{{ t('please_fix_following', page_locale()) }}</p>
            <ul class="list-disc pl-5 mt-2">
                {% for error in form.errors %}
                    <li>{{ error }}</li>
                {% endfor %}
            </ul>
        </div>
    {% endif %}

    <form
        class="flex flex-col gap-4"
        hx-post="{{ form.action_url }}"
        hx-target="#public-server-form"
        hx-swap="outerHTML"
    >
        <div class="grid gap-4 sm:grid-cols-2">
            <div class="form-field">
                <label class="form-label">{{ t('admin_servers_form_name', page_locale()) }}</label>
                <input type="text" name="name" value="{{ form.name }}" class="form-input" placeholder="EU #1">
            </div>
            <div class="form-field">
                <label class="form-label">{{ t('admin_servers_form_category', page_locale()) }}</label>
                <input type="text" name="category" value="{{ form.category }}" class="form-input" placeholder="community">
            </div>
        </div>
        <div class="grid gap-4 sm:grid-cols-2">
            <div class="form-field">
                <label class="form-label">{{ t('admin_servers_form_game_key', page_locale()) }}</label>
                <input type="text" name="game_key" value="{{ form.game_key }}" class="form-input" placeholder="valheim">
            </div>
            <div class="form-field">
                <label class="form-label">{{ t('admin_servers_form_query_type', page_locale()) }}</label>
                <input type="text" name="query_type" value="{{ form.query_type }}" class="form-input" placeholder="steam_a2s">
            </div>
        </div>
        <div class="grid gap-4 sm:grid-cols-3">
            <div class="form-field">
                <label class="form-label">{{ t('admin_servers_form_ip', page_locale()) }}</label>
                <input type="text" name="ip" value="{{ form.ip }}" class="form-input" placeholder="8.8.8.8">
            </div>
            <div class="form-field">
                <label class="form-label">{{ t('admin_servers_form_port', page_locale()) }}</label>
                <input type="number" name="port" value="{{ form.port }}" class="form-input" min="1" max="65535">
            </div>
            <div class="form-field">
                <label class="form-label">{{ t('admin_servers_form_query_port', page_locale()) }}</label>
                <input type="number" name="query_port" value="{{ form.query_port }}" class="form-input" min="1" max="65535">
            </div>
        </div>
        <div class="grid gap-4 sm:grid-cols-3">
            <div class="form-field">
                <label class="form-label">{{ t('admin_servers_form_check_interval', page_locale()) }}</label>
                <input type="number" name="check_interval_seconds" value="{{ form.check_interval_seconds }}" class="form-input" min="10" step="1">
            </div>
            <div class="form-field">
                <label class="form-label">{{ t('admin_servers_form_sort_order', page_locale()) }}</label>
                <input type="number" name="sort_order" value="{{ form.sort_order }}" class="form-input" step="1">
            </div>
        </div>
        <div class="grid gap-3 sm:grid-cols-2">
            <label class="inline-flex items-center gap-2 text-sm" style="color:var(--ng-text-muted)">
                <input type="checkbox" name="visible_public" {% if form.visible_public %}checked{% endif %}>
                {{ t('admin_servers_form_visible_public', page_locale()) }}
            </label>
            <label class="inline-flex items-center gap-2 text-sm" style="color:var(--ng-text-muted)">
                <input type="checkbox" name="visible_logged_in" {% if form.visible_logged_in %}checked{% endif %}>
                {{ t('admin_servers_form_visible_logged_in', page_locale()) }}
            </label>
        </div>
        <div class="form-field">
            <label class="form-label">{{ t('admin_servers_form_internal_notes', page_locale()) }}</label>
            <textarea name="notes_internal" rows="3" class="form-input" placeholder="{{ t('admin_servers_form_internal_notes_placeholder', page_locale()) }}">{{ form.notes_internal }}</textarea>
        </div>
        <button type="submit" class="ui-button ui-button--primary w-full">{{ form.submit_label }}</button>
    </form>
</div>
