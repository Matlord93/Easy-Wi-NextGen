<div class="cust-ws-table-wrap">
    <table class="cust-table">
        <thead>
            <tr>
                <th>{{ t('admin_servers_table_name', page_locale()) }}</th>
                <th>{{ t('admin_servers_table_game', page_locale()) }}</th>
                <th>{{ t('admin_servers_table_address', page_locale()) }}</th>
                <th>{{ t('admin_servers_table_status', page_locale()) }}</th>
                <th>{{ t('admin_servers_table_visibility', page_locale()) }}</th>
                <th>{{ t('admin_servers_table_interval', page_locale()) }}</th>
                <th>{{ t('admin_servers_table_last_check', page_locale()) }}</th>
                <th class="text-right">{{ t('admin_servers_table_actions', page_locale()) }}</th>
            </tr>
        </thead>
        <tbody>
            {% for server in servers %}
                <tr>
                    <td class="font-medium" style="color:var(--ng-text)">{{ server.name }}</td>
                    <td>{{ server.game_key }}</td>
                    <td>{{ server.address }}</td>
                    <td>
                        {% if server.status == 'online' %}
                            <span class="ui-badge ui-badge--success">{{ t('admin_servers_status_online', page_locale()) }}</span>
                        {% elseif server.status == 'offline' %}
                            <span class="ui-badge ui-badge--neutral">{{ t('admin_servers_status_offline', page_locale()) }}</span>
                        {% elseif server.status == 'error' %}
                            <span class="ui-badge ui-badge--danger">{{ t('admin_servers_status_error', page_locale()) }}</span>
                        {% else %}
                            <span class="ui-badge ui-badge--warning">{{ server.status|default('unknown')|capitalize }}</span>
                        {% endif %}
                    </td>
                    <td>
                        {% if server.visible_public %}
                            <span class="ui-badge ui-badge--info">{{ t('admin_servers_status_public', page_locale()) }}</span>
                        {% else %}
                            <span class="ui-badge ui-badge--neutral">{{ t('admin_servers_status_hidden', page_locale()) }}</span>
                        {% endif %}
                    </td>
                    <td>{{ server.check_interval_seconds }}s</td>
                    <td>{{ server.last_checked_at ? server.last_checked_at|date('Y-m-d H:i') : '—' }}</td>
                    <td class="text-right">
                        <div class="inline-flex items-center gap-2">
                            <button
                                class="ui-button ui-button--ghost ui-button--sm"
                                hx-get="/admin/servers/{{ server.id }}/edit"
                                hx-target="#public-server-form"
                                hx-swap="outerHTML"
                            >
                                {{ t('edit', page_locale()) }}
                            </button>
                            <button
                                class="ui-button ui-button--danger ui-button--sm"
                                hx-post="/admin/servers/{{ server.id }}/delete"
                                hx-confirm="{{ t('admin_servers_delete_confirm', page_locale())|replace({'%name%': server.name}) }}"
                            >
                                {{ t('delete', page_locale()) }}
                            </button>
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="8" class="cust-table__empty">{{ t('admin_servers_empty', page_locale()) }}</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
