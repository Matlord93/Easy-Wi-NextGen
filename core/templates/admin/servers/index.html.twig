{% extends 'admin/base.html.twig' %}

{% set pageTitle = t('admin_servers_heading', page_locale()) %}
{% set pageSubtitle = t('admin_servers_intro', page_locale()) %}
{% set activeNav = 'servers' %}

{% block content %}
{% set locale = page_locale() %}
<div class="flex flex-col gap-6">

    <section class="ng-card" style="overflow:hidden;">
        <div class="tkt-hero">
            <div class="tkt-hero__inner">
                <div style="display:flex;flex-direction:column;gap:16px;">
                    <div>
                        <div class="tkt-hero__pill">
                            <span class="tkt-hero__pill-dot" style="background:#fb923c;"></span>
                            {{ t('admin_servers_hero_label', locale) }}
                        </div>
                        <h1 class="tkt-hero__title" style="margin-top:10px;">{{ t('admin_servers_heading', locale) }}</h1>
                        <p class="tkt-hero__sub">{{ t('admin_servers_intro', locale) }}</p>
                    </div>
                    <div style="display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:10px;">
                        <div class="tkt-kpi">
                            <div class="tkt-kpi__label">{{ t('admin_servers_total_label', locale) }}</div>
                            <div class="tkt-kpi__value">{{ summary.total }}</div>
                        </div>
                        <div class="tkt-kpi tkt-kpi--resolved">
                            <div class="tkt-kpi__label">{{ t('admin_servers_public_label', locale) }}</div>
                            <div class="tkt-kpi__value">{{ summary.public }}</div>
                        </div>
                        <div class="tkt-kpi tkt-kpi--open">
                            <div class="tkt-kpi__label">{{ t('admin_servers_hidden_label', locale) }}</div>
                            <div class="tkt-kpi__value">{{ summary.hidden }}</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <div class="ng-layout-2col">
        <div class="ng-data-card" id="public-servers-table" hx-trigger="public-servers-changed from:body" hx-get="/admin/servers/table" hx-swap="outerHTML">
            {% include 'admin/servers/_table.html.twig' with { servers: servers } %}
        </div>
        <div class="ng-data-card" id="public-server-form" hx-trigger="public-servers-changed from:body" hx-get="/admin/servers/form" hx-swap="outerHTML">
            {% include 'admin/servers/_form.html.twig' with { form: form } %}
        </div>
    </div>
</div>
{% endblock %}
