{% extends 'admin/base.html.twig' %}

{% set pageTitle = t('admin_servers_heading', page_locale()) %}
{% set pageSubtitle = t('admin_servers_intro', page_locale()) %}
{% set activeNav = 'servers' %}

{% block content %}
<div class="flex flex-col gap-6">
    <div class="ng-kpi-row">
        <div class="ng-kpi-box">
            <div class="ng-kpi-box__label">{{ t('admin_servers_total_label', page_locale()) }}</div>
            <div class="ng-kpi-box__value ng-kpi-box__value--primary">{{ summary.total }}</div>
        </div>
        <div class="ng-kpi-box">
            <div class="ng-kpi-box__label">{{ t('admin_servers_public_label', page_locale()) }}</div>
            <div class="ng-kpi-box__value ng-kpi-box__value--success">{{ summary.public }}</div>
        </div>
        <div class="ng-kpi-box">
            <div class="ng-kpi-box__label">{{ t('admin_servers_hidden_label', page_locale()) }}</div>
            <div class="ng-kpi-box__value ng-kpi-box__value--warning">{{ summary.hidden }}</div>
        </div>
    </div>

    <div class="ng-layout-2col">
        <div class="ng-data-card" id="public-servers-table" hx-trigger="public-servers-changed from:body" hx-get="/admin/servers/table" hx-swap="outerHTML">
            {% include 'admin/servers/_table.html.twig' with { servers: servers } %}
        </div>
        <div class="ng-data-card" id="public-server-form" hx-trigger="public-servers-changed from:body" hx-get="/admin/servers/form" hx-swap="outerHTML">
            {% include 'admin/servers/_form.html.twig' with { form: form } %}
        </div>
    </div>
</div>
{% endblock %}
