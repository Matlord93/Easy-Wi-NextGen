{% extends 'admin/base.html.twig' %}

{% block content %}
{% set locale = page_locale() %}
<div style="display:flex;flex-direction:column;gap:20px;">

  <section class="ng-card" style="overflow:hidden;">
    <div class="tkt-hero">
      <div class="tkt-hero__inner">
        <div>
          <div class="tkt-hero__pill"><span class="tkt-hero__pill-dot"></span> {{ t('admin_jobs_create_title', locale) }}</div>
          <h1 class="tkt-hero__title" style="margin-top:10px;">{{ t('admin_jobs_create_title', locale) }}</h1>
          <p class="tkt-hero__sub">{{ t('admin_jobs_create_intro', locale) }}</p>
        </div>
      </div>
    </div>
  </section>

  {% if form.errors is not empty %}
    <div class="ng-alert ng-alert--danger">
      <p style="font-weight:600;margin-bottom:4px;">{{ t('admin_form_fix_following', locale) }}</p>
      <ul style="list-style:disc;padding-left:18px;margin:0;">
        {% for error in form.errors %}
          <li>{{ error }}</li>
        {% endfor %}
      </ul>
    </div>
  {% endif %}

  <div class="ng-data-card">
    <div class="ng-data-card__body">
      <form method="post" action="/admin/jobs" style="display:flex;flex-direction:column;gap:16px;">
        <div class="form-field">
          <label class="form-label">{{ t('type', locale) }}</label>
          <input name="type" value="{{ form.type }}" placeholder="agent.update" class="form-input">
        </div>
        <div class="form-field">
          <label class="form-label">{{ t('admin_jobs_payload_title', locale) }}</label>
          <textarea name="payload" rows="6" placeholder='{"node_id":"123"}' class="form-input" style="font-family:monospace;font-size:12px;">{{ form.payload_raw }}</textarea>
          <p style="margin-top:6px;font-size:12px;color:var(--ng-text-muted);">{{ t('admin_jobs_payload_hint', locale) }}</p>
        </div>
        <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
          <button type="submit" class="ui-button ui-button--primary ui-button--sm">{{ t('admin_jobs_create_submit', locale) }}</button>
          <a href="/admin/jobs" class="ui-button ui-button--ghost ui-button--sm">{{ t('cancel', locale) }}</a>
        </div>
      </form>
    </div>
  </div>

</div>
{% endblock %}
