<div id="jobs-table"
    hx-get="/admin/jobs/table"
    hx-trigger="every 15s"
    hx-swap="outerHTML">

<div class="cust-ws-table-wrap">
    <table class="cust-table">
        <thead>
        <tr>
            <th>{{ t('admin_jobs_table_id', page_locale()) }}</th>
            <th>{{ t('type', page_locale()) }}</th>
            <th>{{ t('status', page_locale()) }}</th>
            <th>{{ t('admin_jobs_table_locked_by', page_locale()) }}</th>
            <th>{{ t('created', page_locale()) }}</th>
            <th style="text-align:right;">{{ t('actions', page_locale()) }}</th>
        </tr>
        </thead>
        <tbody>
        {% for job in jobs %}
            <tr>
                <td>
                    <span style="font-family:monospace;font-size:11px;color:var(--color-text-muted,#64748b);">{{ job.id }}</span>
                </td>
                <td style="font-weight:600;">{{ t('job_type_' ~ job.type|replace({'.': '_'}), page_locale()) }}</td>
                <td>
                    {% if job.status == 'succeeded' %}
                        {% set jobBadge = 'success' %}
                    {% elseif job.status == 'failed' %}
                        {% set jobBadge = 'danger' %}
                    {% elseif job.status == 'running' %}
                        {% set jobBadge = 'info' %}
                    {% elseif job.status == 'queued' %}
                        {% set jobBadge = 'warning' %}
                    {% else %}
                        {% set jobBadge = 'neutral' %}
                    {% endif %}
                    <span class="ui-badge ui-badge--{{ jobBadge }}">{{ job.status|title }}</span>
                </td>
                <td>
                    {% if job.lockedBy %}
                        <div style="font-size:13px;font-weight:600;">{{ job.lockedBy }}</div>
                        <div style="font-size:11px;color:var(--color-text-muted,#64748b);">{{ job.lockedAt ? job.lockedAt|date('Y-m-d H:i') : '' }}</div>
                    {% else %}
                        <span style="font-size:12px;color:var(--color-text-muted,#64748b);">{{ t('admin_jobs_unassigned', page_locale()) }}</span>
                    {% endif %}
                </td>
                <td style="font-size:12px;color:var(--color-text-muted,#64748b);">{{ job.createdAt|date('Y-m-d H:i') }}</td>
                <td style="text-align:right;">
                    <a class="ui-button ui-button--ghost ui-button--sm" href="/admin/jobs/{{ job.id }}">{{ t('view', page_locale()) }}</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="6" class="cust-table__empty">{{ t('admin_jobs_empty', page_locale()) }}</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
</div>

{% if pagination is defined and pagination.totalPages > 1 %}
    <div style="display:flex;align-items:center;justify-content:space-between;border-top:1px solid var(--ng-border);padding:10px 16px;">
        <div style="font-size:12px;color:var(--color-text-muted,#64748b);">
            {{ t('admin_jobs_pagination_label', page_locale())|replace({'%page%': pagination.page, '%total%': pagination.totalPages}) }}
        </div>
        <div style="display:flex;gap:8px;">
            <a
                href="/admin/jobs?page={{ pagination.previousPage }}"
                hx-get="/admin/jobs/table?page={{ pagination.previousPage }}"
                hx-target="#jobs-table"
                hx-swap="outerHTML"
                class="ui-button ui-button--ghost ui-button--sm{{ not pagination.hasPrevious ? ' ui-button--disabled' : '' }}"
            >{{ t('admin_jobs_pagination_previous', page_locale()) }}</a>
            <a
                href="/admin/jobs?page={{ pagination.nextPage }}"
                hx-get="/admin/jobs/table?page={{ pagination.nextPage }}"
                hx-target="#jobs-table"
                hx-swap="outerHTML"
                class="ui-button ui-button--ghost ui-button--sm{{ not pagination.hasNext ? ' ui-button--disabled' : '' }}"
            >{{ t('admin_jobs_pagination_next', page_locale()) }}</a>
        </div>
    </div>
{% endif %}

</div>{# end #jobs-table #}
