{% extends 'admin/base.html.twig' %}

{% set locale = page_locale() %}
{% set pageTitle = t('admin_cms_xenal_landing_title', locale) %}
{% set activeNav = 'cms-xenal' %}

{% block content %}
<div class="max-w-4xl space-y-6">
    <div class="ng-data-card">
        <div class="ng-data-card__body">
            <h1 class="text-2xl font-semibold" style="color:var(--ng-text)">{{ t('admin_cms_xenal_landing_title', locale) }}</h1>
            <p class="mt-2 text-sm" style="color:var(--ng-text-muted)">
                {{ t('admin_cms_xenal_landing_intro', locale) }}
            </p>
            <div class="mt-4 flex flex-wrap gap-2">
                <a href="/admin/cms/pages/{{ page.id }}"
                   class="ui-button ui-button--primary ui-button--sm">
                    {{ t('admin_cms_xenal_open_page', locale) }}
                </a>
                <a href="/admin/cms/pages"
                   class="ui-button ui-button--ghost ui-button--sm">
                    {{ t('admin_cms_xenal_all_pages', locale) }}
                </a>
            </div>
        </div>
    </div>

    <div class="ng-data-card">
        <div class="ng-data-card__body">
            <h2 class="text-lg font-semibold" style="color:var(--ng-text)">{{ t('admin_cms_xenal_recommended_order_title', locale) }}</h2>
            <ul class="mt-3 list-disc space-y-2 pl-5 text-sm" style="color:var(--ng-text)">
                <li><span class="font-semibold">hero</span> → {{ t('admin_cms_xenal_block_hero_desc', locale) }}</li>
                <li><span class="font-semibold">server_list</span> {{ t('or', locale) }} <span class="font-semibold">server_featured</span> → {{ t('admin_cms_xenal_block_server_desc', locale) }}</li>
                <li><span class="font-semibold">cards</span> (1. {{ t('admin_cms_xenal_module', locale) }}) → {{ t('admin_cms_xenal_block_cards1_desc', locale) }}</li>
                <li><span class="font-semibold">cards</span> (2. {{ t('admin_cms_xenal_module', locale) }}) → {{ t('admin_cms_xenal_block_cards2_desc', locale) }}</li>
                <li><span class="font-semibold">cards</span> (3. {{ t('admin_cms_xenal_module', locale) }}) → {{ t('admin_cms_xenal_block_cards3_desc', locale) }}</li>
                <li><span class="font-semibold">rich_text</span> (1. {{ t('admin_cms_xenal_module', locale) }}) {{ t('or', locale) }} <span class="font-semibold">xn_cta</span> → {{ t('admin_cms_xenal_block_cta_desc', locale) }}</li>
            </ul>
            <p class="mt-4 text-xs text-slate-500">
                {{ t('admin_cms_xenal_legacy_blocks_note', locale) }}
            </p>
        </div>
    </div>
</div>
{% endblock %}
