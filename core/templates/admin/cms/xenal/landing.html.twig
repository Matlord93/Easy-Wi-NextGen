{% extends 'admin/base.html.twig' %}

{% block content %}

{# ── Page header ────────────────────────────────────────────────────── #}
<div class="mb-6 flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
    <div>
        <h1 class="text-2xl font-semibold">Xenal Landing-Page</h1>
        <p class="text-sm text-slate-600">
            Pixel-perfect editor für alle Abschnitte der Startseite
            (<span class="font-mono font-semibold text-slate-700">/{{ page.slug }}</span>).
        </p>
    </div>
    <div class="flex gap-2">
        <a href="/" target="_blank"
           class="inline-flex items-center gap-1.5 rounded-lg border border-slate-200 px-3 py-2 text-xs font-semibold text-slate-600 hover:bg-slate-50">
            <svg class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor"><path d="M10 12a2 2 0 1 0 0-4 2 2 0 0 0 0 4Z"/><path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10ZM14 10a4 4 0 1 1-8 0 4 4 0 0 1 8 0Z" clip-rule="evenodd"/></svg>
            Vorschau
        </a>
        <a href="/admin/cms/pages"
           class="inline-flex items-center gap-1.5 rounded-lg border border-slate-200 px-3 py-2 text-xs font-semibold text-slate-600 hover:bg-slate-50">
            Alle Seiten
        </a>
    </div>
</div>

{# ── Flash / save confirmation ───────────────────────────────────────── #}
{% if saved is not null %}
    {% set sectionNames = {
        hero: 'Hero-Abschnitt',
        servers: 'Gameserver',
        stats: 'Clan-Statistiken',
        teams: 'Teams',
        events: 'Events & Turniere',
        cta: 'CTA-Banner'
    } %}
    <div class="mb-5 rounded-lg border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm font-medium text-emerald-700">
        ✓ {{ sectionNames[saved]|default('Abschnitt') }} wurde gespeichert.
    </div>
{% endif %}

{# ── SECTION CARD macro ──────────────────────────────────────────────── #}

{# Helper: returns block payload or {} #}
{% macro payload(block) %}{% endmacro %}

{# ════════════════════════════════════════════════════════════════════════
   1 · HERO
   ════════════════════════════════════════════════════════════════════════ #}
{% set hero = blocks['hero'] %}
{% set hp   = hero ? hero.payloadJson : {} %}

<section class="xn-admin-card" id="section-hero">
    <div class="xn-admin-card__head">
        <div class="xn-admin-card__label">
            <span class="xn-admin-badge">1</span>
            <span>Hero-Abschnitt</span>
        </div>
        <span class="xn-admin-status {{ hero ? 'xn-admin-status--ok' : 'xn-admin-status--empty' }}">
            {{ hero ? 'Gespeichert' : 'Noch leer' }}
        </span>
    </div>
    <form method="post" action="/admin/cms/xenal/landing/hero" class="xn-admin-form">
        <div class="xn-admin-grid">
            <label class="xn-admin-field xn-admin-field--full">
                <span>Headline (HTML erlaubt, z. B. <code>DOMINATE&lt;br&gt;THE GAME.</code>)</span>
                <input type="text" name="headline" class="xn-admin-input" value="{{ hp.headline|default('DOMINATE<br>THE GAME.') }}">
            </label>
            <label class="xn-admin-field">
                <span>Subheadline</span>
                <input type="text" name="subheadline" class="xn-admin-input" value="{{ hp.subheadline|default('') }}">
            </label>
            <label class="xn-admin-field">
                <span>Meta-Tags <small class="text-slate-500">(kommagetrennt)</small></span>
                <input type="text" name="meta" class="xn-admin-input"
                       value="{{ hp.meta is defined and hp.meta is not empty ? hp.meta|join(',') : 'Community,Competition,Performance' }}">
            </label>
            <label class="xn-admin-field">
                <span>Button 1 Text</span>
                <input type="text" name="ctaText" class="xn-admin-input" value="{{ hp.ctaText|default('Join the Clan') }}">
            </label>
            <label class="xn-admin-field">
                <span>Button 1 URL</span>
                <input type="text" name="ctaUrl" class="xn-admin-input" value="{{ hp.ctaUrl|default('/login') }}">
            </label>
            <label class="xn-admin-field">
                <span>Button 2 Text</span>
                <input type="text" name="cta2Text" class="xn-admin-input" value="{{ hp.cta2Text|default('Unsere Server') }}">
            </label>
            <label class="xn-admin-field">
                <span>Button 2 URL</span>
                <input type="text" name="cta2Url" class="xn-admin-input" value="{{ hp.cta2Url|default('#gameserver') }}">
            </label>
            <label class="xn-admin-field">
                <span>Hintergrundbild-Pfad (optional)</span>
                <input type="text" name="backgroundImage" class="xn-admin-input" value="{{ hp.backgroundImage|default('') }}" placeholder="/assets/img/hero-bg.jpg">
            </label>
            <label class="xn-admin-field">
                <span>Rechtes Bild-Pfad (optional)</span>
                <input type="text" name="rightImage" class="xn-admin-input" value="{{ hp.rightImage|default('') }}" placeholder="/assets/img/soldier.png">
            </label>
            <label class="xn-admin-field">
                <span>Logo-Buchstabe</span>
                <input type="text" name="logoLetter" class="xn-admin-input" maxlength="1" value="{{ hp.logoLetter|default('X') }}">
            </label>
            <label class="xn-admin-field">
                <span>Brand-Name</span>
                <input type="text" name="brandName" class="xn-admin-input" value="{{ hp.brandName|default('XENAL GAMING') }}">
            </label>
        </div>
        <div class="xn-admin-actions">
            <button type="submit" class="xn-admin-save">Speichern</button>
        </div>
    </form>
</section>

{# ════════════════════════════════════════════════════════════════════════
   2 · GAMESERVER
   ════════════════════════════════════════════════════════════════════════ #}
{% set srvBlock = blocks['xn_servers'] %}
{% set sp       = srvBlock ? srvBlock.payloadJson : {} %}
{% set servers  = sp.servers|default([]) %}

<section class="xn-admin-card" id="section-servers">
    <div class="xn-admin-card__head">
        <div class="xn-admin-card__label">
            <span class="xn-admin-badge">2</span>
            <span>Gameserver</span>
        </div>
        <span class="xn-admin-status {{ srvBlock ? 'xn-admin-status--ok' : 'xn-admin-status--empty' }}">
            {{ srvBlock ? servers|length ~ ' Server' : 'Noch leer' }}
        </span>
    </div>
    <form method="post" action="/admin/cms/xenal/landing/servers" class="xn-admin-form">
        <div class="xn-admin-grid xn-admin-grid--3col">
            <label class="xn-admin-field">
                <span>Abschnitts-Titel</span>
                <input type="text" name="sectionTitle" class="xn-admin-input" value="{{ sp.sectionTitle|default('Unsere Gameserver') }}">
            </label>
            <label class="xn-admin-field">
                <span>Mehr-Button Text</span>
                <input type="text" name="moreText" class="xn-admin-input" value="{{ sp.moreText|default('Zur Serverübersicht') }}">
            </label>
            <label class="xn-admin-field">
                <span>Mehr-Button URL</span>
                <input type="text" name="moreLink" class="xn-admin-input" value="{{ sp.moreLink|default('/servers') }}">
            </label>
            <label class="xn-admin-field">
                <span>Max. Server auf Startseite</span>
                <input type="number" min="1" max="12" name="maxItems" class="xn-admin-input" value="{{ sp.maxItems|default(4) }}">
            </label>
        </div>

        <h3 class="xn-admin-subheading">Server-Karten</h3>

        {# Render existing servers + 2 empty slots for adding new ones #}
        {% set srvRows = servers %}
        {% for _i in range(servers|length, servers|length + 1) %}
            {% set srvRows = srvRows|merge([{}]) %}
        {% endfor %}

        <div class="xn-admin-server-list" id="server-list">
            {% for srv in srvRows %}
            <div class="xn-admin-server-row">
                <div class="xn-admin-server-row__head">
                    <span class="xn-admin-row-num">{{ loop.index }}</span>
                    <span class="xn-admin-row-hint">{{ srv.name|default('Neuer Server') }}</span>
                </div>
                <div class="xn-admin-grid xn-admin-grid--4col">
                    <label class="xn-admin-field">
                        <span>Server-Name</span>
                        <input type="text" name="srv_name[]" class="xn-admin-input" value="{{ srv.name|default('') }}" placeholder="CS2 Competitive">
                    </label>
                    <label class="xn-admin-field">
                        <span>Spiel <small class="text-slate-400">(cs2 / ark / rust / valorant)</small></span>
                        <input type="text" name="srv_game[]" class="xn-admin-input" value="{{ srv.game|default('cs2') }}" list="game-types">
                    </label>
                    <label class="xn-admin-field">
                        <span>Status</span>
                        <select name="srv_status[]" class="xn-admin-input">
                            <option value="online"  {{ srv.status|default('online') == 'online'  ? 'selected' }}>Online</option>
                            <option value="offline" {{ srv.status|default('online') == 'offline' ? 'selected' }}>Offline</option>
                        </select>
                    </label>
                    <label class="xn-admin-field">
                        <span>Spieler (z. B. 45/70)</span>
                        <input type="text" name="srv_players[]" class="xn-admin-input" value="{{ srv.players|default('') }}" placeholder="45/70">
                    </label>
                    <label class="xn-admin-field">
                        <span>Spieler-Suffix</span>
                        <input type="text" name="srv_player_suffix[]" class="xn-admin-input" value="{{ srv.playerSuffix|default('Spieler') }}">
                    </label>
                    <label class="xn-admin-field">
                        <span>Registrierte Spieler (z. B. 12.116 Spielers)</span>
                        <input type="text" name="srv_registered[]" class="xn-admin-input" value="{{ srv.registered|default('') }}" placeholder="12.116 Spielers">
                    </label>
                    <label class="xn-admin-field">
                        <span>Karte (z. B. in Mirage)</span>
                        <input type="text" name="srv_map[]" class="xn-admin-input" value="{{ srv.map|default('') }}" placeholder="in Mirage">
                    </label>
                    <label class="xn-admin-field">
                        <span>Info / Beschreibung</span>
                        <input type="text" name="srv_info[]" class="xn-admin-input" value="{{ srv.info|default('') }}">
                    </label>
                    <label class="xn-admin-field">
                        <span>Aktueller Spieler</span>
                        <input type="text" name="srv_current_player[]" class="xn-admin-input" value="{{ srv.currentPlayer|default('') }}" placeholder="Current Player">
                    </label>
                    <label class="xn-admin-field">
                        <span>Link-URL</span>
                        <input type="text" name="srv_link[]" class="xn-admin-input" value="{{ srv.link|default('') }}" placeholder="/server/1">
                    </label>
                    <label class="xn-admin-field">
                        <span>Link-Text</span>
                        <input type="text" name="srv_link_text[]" class="xn-admin-input" value="{{ srv.linkText|default('Server anzeigen') }}">
                    </label>
                </div>
            </div>
            {% endfor %}
        </div>

        <datalist id="game-types">
            <option value="cs2"><option value="ark"><option value="rust"><option value="valorant"><option value="casual">
        </datalist>

        <div class="xn-admin-actions">
            <button type="submit" class="xn-admin-save">Speichern</button>
            <p class="text-xs text-slate-500 mt-1">Leere Einträge werden automatisch ignoriert. Für mehr Server weitere Zeilen einfach befüllen.</p>
        </div>
    </form>
</section>

{# ════════════════════════════════════════════════════════════════════════
   3 · CLAN STATS
   ════════════════════════════════════════════════════════════════════════ #}
{% set stBlock = blocks['xn_stats'] %}
{% set stp     = stBlock ? stBlock.payloadJson : {} %}
{% set stats   = stp.stats|default([]) %}

<section class="xn-admin-card" id="section-stats">
    <div class="xn-admin-card__head">
        <div class="xn-admin-card__label">
            <span class="xn-admin-badge">3</span>
            <span>Clan-Statistiken</span>
        </div>
        <span class="xn-admin-status {{ stBlock ? 'xn-admin-status--ok' : 'xn-admin-status--empty' }}">
            {{ stBlock ? stats|length ~ ' Einträge' : 'Noch leer' }}
        </span>
    </div>
    <form method="post" action="/admin/cms/xenal/landing/stats" class="xn-admin-form">
        <label class="xn-admin-field" style="max-width:320px">
            <span>Abschnitts-Titel</span>
            <input type="text" name="sectionTitle" class="xn-admin-input" value="{{ stp.sectionTitle|default('CLAN STATS') }}">
        </label>

        <label class="xn-admin-field" style="max-width:320px">
            <span>Aktive Member (manuell pflegen)</span>
            <input type="number" min="0" name="memberCount" class="xn-admin-input" value="{{ stp.memberCount|default(0) }}">
        </label>

        <p class="text-xs text-slate-500">Teams, Events/Monat und aktive Turniere werden automatisch aus dem CMS berechnet.</p>

        <h3 class="xn-admin-subheading">Statistik-Kacheln</h3>

        {% set statRows = stats %}
        {% for _i in range(stats|length, stats|length + 3) %}
            {% set statRows = statRows|merge([{}]) %}
        {% endfor %}

        <div class="xn-admin-grid xn-admin-grid--4col">
            {% for st in statRows %}
            <div class="xn-admin-stat-box">
                <label class="xn-admin-field">
                    <span>Wert (z. B. 25+)</span>
                    <input type="text" name="stat_value[]" class="xn-admin-input xn-admin-input--center xn-admin-input--lg"
                           value="{{ st.value|default('') }}" placeholder="25+">
                </label>
                <label class="xn-admin-field">
                    <span>Beschriftung</span>
                    <input type="text" name="stat_label[]" class="xn-admin-input xn-admin-input--center"
                           value="{{ st.label|default('') }}" placeholder="AKTIVE MEMBER">
                </label>
            </div>
            {% endfor %}
        </div>

        <div class="xn-admin-actions">
            <button type="submit" class="xn-admin-save">Speichern</button>
        </div>
    </form>
</section>

{# ════════════════════════════════════════════════════════════════════════
   4 · TEAMS
   ════════════════════════════════════════════════════════════════════════ #}
{% set teamBlock = blocks['xn_teams'] %}
{% set tp        = teamBlock ? teamBlock.payloadJson : {} %}
{% set teams     = tp.teams|default([]) %}

<section class="xn-admin-card" id="section-teams">
    <div class="xn-admin-card__head">
        <div class="xn-admin-card__label">
            <span class="xn-admin-badge">4</span>
            <span>Teams</span>
        </div>
        <span class="xn-admin-status {{ teamBlock ? 'xn-admin-status--ok' : 'xn-admin-status--empty' }}">
            {{ teamBlock ? teams|length ~ ' Teams' : 'Noch leer' }}
        </span>
    </div>
    <form method="post" action="/admin/cms/xenal/landing/teams" class="xn-admin-form">
        <div class="xn-admin-grid xn-admin-grid--3col">
            <label class="xn-admin-field">
                <span>Abschnitts-Titel</span>
                <input type="text" name="sectionTitle" class="xn-admin-input" value="{{ tp.sectionTitle|default('UNSERE TEAMS') }}">
            </label>
            <label class="xn-admin-field">
                <span>Mehr-Button Text</span>
                <input type="text" name="moreText" class="xn-admin-input" value="{{ tp.moreText|default('Alle Teams anzeigen') }}">
            </label>
            <label class="xn-admin-field">
                <span>Mehr-Button URL</span>
                <input type="text" name="moreLink" class="xn-admin-input" value="{{ tp.moreLink|default('/teams') }}">
            </label>
            <label class="xn-admin-field">
                <span>Übersicht-Button Text</span>
                <input type="text" name="overviewText" class="xn-admin-input" value="{{ tp.overviewText|default('') }}">
            </label>
            <label class="xn-admin-field">
                <span>Übersicht-Button URL</span>
                <input type="text" name="overviewLink" class="xn-admin-input" value="{{ tp.overviewLink|default('') }}">
            </label>
        </div>

        <h3 class="xn-admin-subheading">Team-Karten</h3>

        {% set teamRows = teams %}
        {% for _i in range(teams|length, teams|length + 1) %}
            {% set teamRows = teamRows|merge([{}]) %}
        {% endfor %}

        {% for team in teamRows %}
        <div class="xn-admin-team-row">
            <div class="xn-admin-server-row__head">
                <span class="xn-admin-row-num">{{ loop.index }}</span>
                <span class="xn-admin-row-hint">{{ team.name|default('Neues Team') }}</span>
            </div>
            <div class="xn-admin-grid xn-admin-grid--3col">
                <label class="xn-admin-field">
                    <span>Team-Name</span>
                    <input type="text" name="team_name[]" class="xn-admin-input" value="{{ team.name|default('') }}" placeholder="Valorant Team">
                </label>
                <label class="xn-admin-field">
                    <span>Spiel <small class="text-slate-400">(cs2 / ark / rust / valorant / casual)</small></span>
                    <input type="text" name="team_game[]" class="xn-admin-input" value="{{ team.game|default('casual') }}" list="game-types">
                </label>
                <label class="xn-admin-field">
                    <span>Division / Liga</span>
                    <input type="text" name="team_division[]" class="xn-admin-input" value="{{ team.division|default('') }}" placeholder="Division 2">
                </label>
                <label class="xn-admin-field">
                    <span>Bild-URL (optional)</span>
                    <input type="text" name="team_image[]" class="xn-admin-input" value="{{ team.image|default('') }}" placeholder="/assets/img/team.jpg">
                </label>
                <label class="xn-admin-field">
                    <span>Akzentfarbe (RGBA)</span>
                    <input type="text" name="team_color[]" class="xn-admin-input" value="{{ team.color|default('') }}" placeholder="rgba(180,20,20,0.45)">
                </label>
                <label class="xn-admin-field">
                    <span>Info-Zeile 1</span>
                    <input type="text" name="team_info1[]" class="xn-admin-input" value="{{ team.info1|default('') }}" placeholder="745 Aktive Raider · Fr/Sa">
                </label>
                <label class="xn-admin-field">
                    <span>Info-Zeile 2</span>
                    <input type="text" name="team_info2[]" class="xn-admin-input" value="{{ team.info2|default('') }}">
                </label>
                <label class="xn-admin-field">
                    <span>Button Text</span>
                    <input type="text" name="team_link_label[]" class="xn-admin-input"
                           value="{{ team.links is defined and team.links is not empty ? team.links[0].label|default('Mehr Infos') : 'Mehr Infos' }}">
                </label>
                <label class="xn-admin-field">
                    <span>Button URL</span>
                    <input type="text" name="team_link_url[]" class="xn-admin-input"
                           value="{{ team.links is defined and team.links is not empty ? team.links[0].url|default('') : '' }}" placeholder="/teams/valorant">
                </label>
            </div>
        </div>
        {% endfor %}

        <div class="xn-admin-actions">
            <button type="submit" class="xn-admin-save">Speichern</button>
        </div>
    </form>
</section>

{# ════════════════════════════════════════════════════════════════════════
   5 · EVENTS & TURNIERE
   ════════════════════════════════════════════════════════════════════════ #}
{% set evBlock  = blocks['xn_events'] %}
{% set ep       = evBlock ? evBlock.payloadJson : {} %}
{% set upcoming = ep.upcoming|default([]) %}
{% set tourn    = ep.tournament|default({}) %}
{% set tournList = ep.tournaments|default([]) %}
{% set cd       = tourn.countdown|default({}) %}

<section class="xn-admin-card" id="section-events">
    <div class="xn-admin-card__head">
        <div class="xn-admin-card__label">
            <span class="xn-admin-badge">5</span>
            <span>Events &amp; Turniere</span>
        </div>
        <span class="xn-admin-status {{ evBlock ? 'xn-admin-status--ok' : 'xn-admin-status--empty' }}">
            {{ evBlock ? upcoming|length ~ ' Events' : 'Noch leer' }}
        </span>
    </div>
    <form method="post" action="/admin/cms/xenal/landing/events" class="xn-admin-form">
        <div class="xn-admin-grid xn-admin-grid--3col">
            <label class="xn-admin-field">
                <span>Abschnitts-Titel</span>
                <input type="text" name="sectionTitle" class="xn-admin-input" value="{{ ep.sectionTitle|default('EVENTS & TURNIERE') }}">
            </label>
            <label class="xn-admin-field">
                <span>Events-Überschrift</span>
                <input type="text" name="upcomingTitle" class="xn-admin-input" value="{{ ep.upcomingTitle|default('Kommende Events') }}">
            </label>
        </div>

        <h3 class="xn-admin-subheading">Kommende Events</h3>
        <div class="space-y-2">
            {% set evRows = upcoming %}
            {% for _i in range(upcoming|length, upcoming|length + 2) %}
                {% set evRows = evRows|merge([{}]) %}
            {% endfor %}
            {% for ev in evRows %}
            <div class="flex gap-3">
                <label class="xn-admin-field" style="max-width:100px">
                    <span>Datum</span>
                    <input type="text" name="ev_date[]" class="xn-admin-input" value="{{ ev.date|default('') }}" placeholder="18.02">
                </label>
                <label class="xn-admin-field xn-admin-field--grow">
                    <span>Event-Name</span>
                    <input type="text" name="ev_name[]" class="xn-admin-input" value="{{ ev.name|default('') }}" placeholder="Clan Scrim">
                </label>
            </div>
            {% endfor %}
        </div>

        <h3 class="xn-admin-subheading" style="margin-top:24px">Turniere (Liste)</h3>
        {% set tourRows = tournList %}
        {% for _i in range(tournList|length, tournList|length + 2) %}
            {% set tourRows = tourRows|merge([{}]) %}
        {% endfor %}
        <div class="space-y-2">
            {% for tour in tourRows %}
            <div class="xn-admin-grid xn-admin-grid--4col">
                <label class="xn-admin-field">
                    <span>Turnier-Name</span>
                    <input type="text" name="tour_title[]" class="xn-admin-input" value="{{ tour.title|default('') }}" placeholder="Xenal Spring Cup">
                </label>
                <label class="xn-admin-field">
                    <span>Spiel / Kategorie</span>
                    <input type="text" name="tour_game[]" class="xn-admin-input" value="{{ tour.game|default('') }}" placeholder="CS2">
                </label>
                <label class="xn-admin-field">
                    <span>Details</span>
                    <input type="text" name="tour_details[]" class="xn-admin-input" value="{{ tour.details|default('') }}" placeholder="Qualifier Runde 1">
                </label>
                <label class="xn-admin-field">
                    <span>Link</span>
                    <input type="text" name="tour_link[]" class="xn-admin-input" value="{{ tour.link|default('') }}" placeholder="/events/xenal-spring-cup">
                </label>
            </div>
            {% endfor %}
        </div>

        <h3 class="xn-admin-subheading" style="margin-top:24px">Aktuelles Turnier (Countdown)</h3>
        <div class="xn-admin-grid xn-admin-grid--3col">
            <label class="xn-admin-field">
                <span>Badge-Text (z. B. ESL)</span>
                <input type="text" name="t_badge" class="xn-admin-input" value="{{ tourn.badge|default('ESL') }}">
            </label>
            <label class="xn-admin-field">
                <span>Turnier-Titel</span>
                <input type="text" name="t_title" class="xn-admin-input" value="{{ tourn.title|default('Aktuelles Turnier') }}">
            </label>
            <label class="xn-admin-field">
                <span>Spiel / Kategorie</span>
                <input type="text" name="t_game" class="xn-admin-input" value="{{ tourn.game|default('') }}" placeholder="CS2 Open · All · 004">
            </label>
            <label class="xn-admin-field">
                <span>Details-Zeile</span>
                <input type="text" name="t_details" class="xn-admin-input" value="{{ tourn.details|default('') }}">
            </label>
            <label class="xn-admin-field">
                <span>Link-Text</span>
                <input type="text" name="t_link_text" class="xn-admin-input" value="{{ tourn.linkText|default('Details anzeigen') }}">
            </label>
            <label class="xn-admin-field">
                <span>Link-URL</span>
                <input type="text" name="t_link" class="xn-admin-input" value="{{ tourn.link|default('') }}" placeholder="/turnier/esl">
            </label>
        </div>

        <h4 class="text-xs font-semibold uppercase tracking-wider text-slate-500 mt-4 mb-2">Countdown (statisch — Werte)</h4>
        <div class="flex gap-3 flex-wrap">
            <label class="xn-admin-field" style="max-width:90px">
                <span>Tage</span>
                <input type="text" name="t_cd_days" class="xn-admin-input xn-admin-input--center" value="{{ cd.days|default('00') }}" maxlength="3">
            </label>
            <label class="xn-admin-field" style="max-width:90px">
                <span>Stunden</span>
                <input type="text" name="t_cd_hours" class="xn-admin-input xn-admin-input--center" value="{{ cd.hours|default('00') }}" maxlength="3">
            </label>
            <label class="xn-admin-field" style="max-width:90px">
                <span>Minuten</span>
                <input type="text" name="t_cd_minutes" class="xn-admin-input xn-admin-input--center" value="{{ cd.minutes|default('00') }}" maxlength="3">
            </label>
            <label class="xn-admin-field" style="max-width:90px">
                <span>Sekunden</span>
                <input type="text" name="t_cd_seconds" class="xn-admin-input xn-admin-input--center" value="{{ cd.seconds|default('00') }}" maxlength="3">
            </label>
        </div>

        <div class="xn-admin-grid xn-admin-grid--4col" style="margin-top:8px">
            <label class="xn-admin-field">
                <span>Label Tage</span>
                <input type="text" name="t_label_days" class="xn-admin-input" value="{{ tourn.labelDays|default('Tage') }}">
            </label>
            <label class="xn-admin-field">
                <span>Label Stunden</span>
                <input type="text" name="t_label_hours" class="xn-admin-input" value="{{ tourn.labelHours|default('Std') }}">
            </label>
            <label class="xn-admin-field">
                <span>Label Minuten</span>
                <input type="text" name="t_label_minutes" class="xn-admin-input" value="{{ tourn.labelMinutes|default('Min') }}">
            </label>
            <label class="xn-admin-field">
                <span>Label Sekunden</span>
                <input type="text" name="t_label_seconds" class="xn-admin-input" value="{{ tourn.labelSeconds|default('Sek') }}">
            </label>
        </div>

        <div class="xn-admin-actions">
            <button type="submit" class="xn-admin-save">Speichern</button>
        </div>
    </form>
</section>

{# ════════════════════════════════════════════════════════════════════════
   6 · CTA-BANNER + SOCIAL LINKS
   ════════════════════════════════════════════════════════════════════════ #}
{% set ctaBlock = blocks['xn_cta'] %}
{% set cp       = ctaBlock ? ctaBlock.payloadJson : {} %}
{% set socials  = cp.socials|default([]) %}

<section class="xn-admin-card" id="section-cta">
    <div class="xn-admin-card__head">
        <div class="xn-admin-card__label">
            <span class="xn-admin-badge">6</span>
            <span>CTA-Banner &amp; Social Links</span>
        </div>
        <span class="xn-admin-status {{ ctaBlock ? 'xn-admin-status--ok' : 'xn-admin-status--empty' }}">
            {{ ctaBlock ? 'Gespeichert' : 'Noch leer' }}
        </span>
    </div>
    <form method="post" action="/admin/cms/xenal/landing/cta" class="xn-admin-form">
        <label class="xn-admin-field">
            <span>CTA-Text (Seitenabschluss)</span>
            <input type="text" name="title" class="xn-admin-input"
                   value="{{ cp.title|default('BEREIT EIN TEIL VON XENAL ZU WERDEN?') }}"
                   placeholder="BEREIT EIN TEIL VON XENAL ZU WERDEN?">
        </label>

        <h3 class="xn-admin-subheading">Social-Links (Mitte der Seite)</h3>

        {% set socialRows = socials %}
        {% for _i in range(socials|length, socials|length + 2) %}
            {% set socialRows = socialRows|merge([{}]) %}
        {% endfor %}

        {% for soc in socialRows %}
        <div class="flex gap-3 items-end">
            <label class="xn-admin-field" style="max-width:100px">
                <span>Label <small class="text-slate-400">(X / YT / DC)</small></span>
                <input type="text" name="cta_social_label[]" class="xn-admin-input" value="{{ soc.label|default('') }}" placeholder="X">
            </label>
            <label class="xn-admin-field xn-admin-field--grow">
                <span>URL</span>
                <input type="text" name="cta_social_url[]" class="xn-admin-input" value="{{ soc.url|default('') }}" placeholder="https://x.com/…">
            </label>
        </div>
        {% endfor %}

        <div class="xn-admin-actions">
            <button type="submit" class="xn-admin-save">Speichern</button>
        </div>
    </form>
</section>

{# ── Admin-specific CSS (scoped, no Tailwind needed) ─────────────────── #}
<style>
.xn-admin-card {
  background: #fff;
  border: 1px solid #e2e8f0;
  border-radius: 14px;
  margin-bottom: 20px;
  overflow: hidden;
}
.xn-admin-card__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 18px;
  border-bottom: 1px solid #f1f5f9;
  background: #f8fafc;
}
.xn-admin-card__label {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 15px;
  font-weight: 700;
  color: #1e293b;
}
.xn-admin-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 24px;
  height: 24px;
  border-radius: 6px;
  background: #1e293b;
  color: #fff;
  font-size: 12px;
  font-weight: 800;
  flex-shrink: 0;
}
.xn-admin-status {
  font-size: 11px;
  font-weight: 700;
  padding: 3px 10px;
  border-radius: 999px;
  text-transform: uppercase;
  letter-spacing: .4px;
}
.xn-admin-status--ok    { background: #dcfce7; color: #15803d; border: 1px solid #bbf7d0; }
.xn-admin-status--empty { background: #f1f5f9; color: #64748b; border: 1px solid #e2e8f0; }

.xn-admin-form { padding: 18px; }

.xn-admin-grid {
  display: grid;
  gap: 12px;
  grid-template-columns: repeat(2, 1fr);
}
.xn-admin-grid--3col { grid-template-columns: repeat(3, 1fr); }
.xn-admin-grid--4col { grid-template-columns: repeat(4, 1fr); }

@media (max-width: 900px) {
  .xn-admin-grid--3col,
  .xn-admin-grid--4col { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 600px) {
  .xn-admin-grid,
  .xn-admin-grid--3col,
  .xn-admin-grid--4col { grid-template-columns: 1fr; }
}

.xn-admin-field {
  display: flex;
  flex-direction: column;
  gap: 4px;
  font-size: 12px;
  font-weight: 600;
  color: #475569;
}
.xn-admin-field--full  { grid-column: 1 / -1; }
.xn-admin-field--grow  { flex: 1; }

.xn-admin-input {
  width: 100%;
  border: 1px solid #cbd5e1;
  border-radius: 8px;
  padding: 7px 10px;
  font-size: 13px;
  color: #1e293b;
  background: #fff;
  outline: none;
  transition: border-color .15s, box-shadow .15s;
}
.xn-admin-input:focus {
  border-color: #6366f1;
  box-shadow: 0 0 0 3px rgba(99,102,241,.12);
}
.xn-admin-input--center { text-align: center; }
.xn-admin-input--lg     { font-size: 18px; font-weight: 800; }

.xn-admin-subheading {
  font-size: 12px;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: .5px;
  color: #64748b;
  margin: 18px 0 10px;
  padding-bottom: 6px;
  border-bottom: 1px solid #f1f5f9;
}

.xn-admin-server-row,
.xn-admin-team-row {
  border: 1px solid #e2e8f0;
  border-radius: 10px;
  padding: 14px;
  margin-bottom: 12px;
  background: #fafafa;
}
.xn-admin-server-row__head {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 10px;
}
.xn-admin-row-num {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 20px;
  height: 20px;
  border-radius: 50%;
  background: #e2e8f0;
  font-size: 11px;
  font-weight: 800;
  color: #64748b;
}
.xn-admin-row-hint {
  font-size: 12px;
  font-weight: 700;
  color: #94a3b8;
}

.xn-admin-stat-box {
  border: 1px solid #e2e8f0;
  border-radius: 10px;
  padding: 12px;
  background: #fafafa;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.xn-admin-actions {
  margin-top: 18px;
  padding-top: 14px;
  border-top: 1px solid #f1f5f9;
}
.xn-admin-save {
  padding: 9px 22px;
  border-radius: 9px;
  background: #1e293b;
  color: #fff;
  font-size: 13px;
  font-weight: 700;
  cursor: pointer;
  border: none;
  transition: background .15s;
}
.xn-admin-save:hover { background: #0f172a; }

.xn-admin-server-list { display: flex; flex-direction: column; gap: 10px; }
</style>

{% endblock %}
