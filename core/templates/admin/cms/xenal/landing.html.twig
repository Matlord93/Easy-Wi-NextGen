{% extends 'admin/base.html.twig' %}

{% block content %}
<div class="max-w-4xl space-y-6">
    <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <h1 class="text-2xl font-semibold text-slate-900">Xenal Landing-Page</h1>
        <p class="mt-2 text-sm text-slate-600">
            Die Xenal-Startseite nutzt jetzt ausschließlich das bestehende CMS-Blocksystem.
            Pflege die Inhalte direkt über die normale Seitenverwaltung, damit alle Theme-Bereiche mit Modulen verwaltet werden.
        </p>
        <div class="mt-4 flex flex-wrap gap-2">
            <a href="/admin/cms/pages/{{ page.id }}"
               class="inline-flex items-center gap-1.5 rounded-lg bg-indigo-600 px-4 py-2 text-xs font-semibold text-white hover:bg-indigo-700">
                Seite & Module öffnen
            </a>
            <a href="/admin/cms/pages"
               class="inline-flex items-center gap-1.5 rounded-lg border border-slate-200 px-4 py-2 text-xs font-semibold text-slate-700 hover:bg-slate-50">
                Alle CMS-Seiten
            </a>
        </div>
    </div>

    <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <h2 class="text-lg font-semibold text-slate-900">Empfohlene Modul-Reihenfolge für Xenal</h2>
        <ul class="mt-3 list-disc space-y-2 pl-5 text-sm text-slate-700">
            <li><span class="font-semibold">hero</span> → Hero-Bereich.</li>
            <li><span class="font-semibold">server_list</span> oder <span class="font-semibold">server_featured</span> → Gameserver-Bereich.</li>
            <li><span class="font-semibold">cards</span> (1. Modul) → Clan-Stats.</li>
            <li><span class="font-semibold">cards</span> (2. Modul) → Teams.</li>
            <li><span class="font-semibold">cards</span> (3. Modul) → Events.</li>
            <li><span class="font-semibold">rich_text</span> (1. Modul) oder <span class="font-semibold">xn_cta</span> → CTA-Zeile.</li>
        </ul>
        <p class="mt-4 text-xs text-slate-500">
            Bereits vorhandene Legacy-Blöcke (<code>xn_*</code>) werden weiterhin unterstützt, damit bestehende Inhalte nicht verloren gehen.
        </p>
    </div>
</div>
{% endblock %}
