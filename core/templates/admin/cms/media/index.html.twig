{% extends 'admin/base.html.twig' %}

{% set pageTitle = t('admin_cms_media_title', page_locale()) %}
{% set activeNav = 'cms-media' %}

{% set locale = page_locale() %}

{% block content %}
<div class="flex flex-col gap-6">
    <div class="ng-data-card">
        <div class="ng-data-card__header">
            <div>
                <h2 class="ng-data-card__title">{{ t('admin_cms_media_upload', locale) }}</h2>
            </div>
        </div>
        <div class="ng-data-card__body">
            <form method="post" action="/admin/cms/media" enctype="multipart/form-data" style="display: grid; gap: 0.75rem; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));">
                <div class="form-field" style="grid-column: span 2;">
                    <label class="form-label">File</label>
                    <input type="file" name="file" class="form-input" required />
                </div>
                <div class="form-field">
                    <label class="form-label">Title</label>
                    <input name="title" placeholder="Title" class="form-input" />
                </div>
                <div class="form-field">
                    <label class="form-label">Alt</label>
                    <input name="alt" placeholder="Alt" class="form-input" />
                </div>
                <div>
                    <button type="submit" class="ui-button ui-button--primary ui-button--sm">{{ t('admin_cms_media_upload', locale) }}</button>
                </div>
            </form>
        </div>
    </div>

    <div class="ng-data-card">
        <div class="ng-data-card__header">
            <div>
                <h2 class="ng-data-card__title">{{ t('admin_cms_media_title', locale) }}</h2>
            </div>
        </div>
        <div class="ng-data-card__body--flush">
            <div class="cust-ws-table-wrap">
                <table class="cust-table">
                    <thead>
                        <tr>
                            <th>{{ t('admin_cms_media_title_alt', locale) }}</th>
                            <th>{{ t('admin_cms_media_path', locale) }}</th>
                            <th>{{ t('admin_cms_media_title_col', locale) }}</th>
                            <th>{{ t('admin_cms_media_actions', locale) }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for asset in assets %}
                            <tr>
                                <td>
                                    {% if asset.path %}
                                        <img src="{{ asset.path }}" alt="" style="height: 3rem; width: 3rem; border-radius: 0.375rem; object-fit: cover;" />
                                    {% endif %}
                                </td>
                                <td><code style="font-size: 0.75rem;">{{ asset.path }}</code></td>
                                <td>{{ asset.title ?: '-' }} / {{ asset.alt ?: '-' }}</td>
                                <td>
                                    <form method="post" action="/admin/cms/media/{{ asset.id }}/delete">
                                        <button class="ui-button ui-button--danger ui-button--sm">{{ t('admin_cms_media_delete', locale) }}</button>
                                    </form>
                                </td>
                            </tr>
                        {% else %}
                            <tr><td colspan="4" class="cust-table__empty">{{ t('admin_cms_media_empty', locale) }}</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{% endblock %}
