{% extends 'admin/base.html.twig' %}

{% set pageTitle = t('admin_cms_settings_title', page_locale()) %}
{% set pageSubtitle = t('admin_cms_settings_intro', page_locale()) %}
{% set activeNav = 'cms-settings' %}

{% block content %}
{% set locale = page_locale() %}
<div style="display:flex;flex-direction:column;gap:20px;">

    {% if saved %}
        <div class="ng-alert ng-alert--success">{{ t('admin_cms_settings_saved', locale) }}</div>
    {% endif %}

    <section class="ng-card" style="overflow:hidden;">
        <div class="tkt-hero">
            <div class="tkt-hero__inner">
                <div style="display:flex;flex-direction:column;gap:16px;">
                    <div>
                        <div class="tkt-hero__pill">
                            <span class="tkt-hero__pill-dot"></span>
                            CMS
                        </div>
                        <h1 class="tkt-hero__title" style="margin-top:10px;">{{ t('admin_cms_settings_title', locale) }}</h1>
                        <p class="tkt-hero__sub">{{ t('admin_cms_settings_intro', locale) }}</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <form method="post" action="/admin/cms/settings" style="display:flex;flex-direction:column;gap:20px;">

        <div class="ng-data-card">
            <div class="ng-data-card__header">
                <div>
                    <h2 class="ng-data-card__title">{{ t('admin_cms_settings_theme_title', locale) }}</h2>
                    <p class="ng-data-card__sub">{{ t('admin_cms_settings_theme_hint', locale) }}</p>
                </div>
            </div>
            <div class="ng-data-card__body">
                <div class="form-field">
                    <label class="form-label" for="active_theme">{{ t('admin_cms_settings_theme_active', locale) }}</label>
                    <select id="active_theme" name="active_theme" class="form-input">
                        {% for key in ['esports', 'minimal', 'fantasy', 'nexus-gaming', 'xenal'] %}
                            <option value="{{ key }}" {% if current_theme == key %}selected{% endif %}>{{ key }}</option>
                        {% endfor %}
                    </select>
                </div>
            </div>
        </div>

        <div class="ng-data-card">
            <div class="ng-data-card__header">
                <div>
                    <h2 class="ng-data-card__title">{{ t('admin_cms_settings_branding_title', locale) }}</h2>
                </div>
            </div>
            <div class="ng-data-card__body">
                <div class="ng-layout-2col--equal">
                    <div class="form-field">
                        <label class="form-label">{{ t('admin_cms_settings_logo_path', locale) }}</label>
                        <input type="text" name="logo_path" value="{{ branding.logo_path }}" class="form-input">
                    </div>
                    <div class="form-field">
                        <label class="form-label">{{ t('admin_cms_settings_primary_color', locale) }}</label>
                        <input type="text" name="primary_color" value="{{ branding.primary_color }}" placeholder="#4f46e5" class="form-input">
                    </div>
                    <div class="form-field">
                        <label class="form-label">{{ t('admin_cms_settings_website', locale) }}</label>
                        <input type="text" name="social_website" value="{{ branding.socials.website|default('') }}" class="form-input">
                    </div>
                    <div class="form-field">
                        <label class="form-label">{{ t('admin_cms_settings_discord', locale) }}</label>
                        <input type="text" name="social_discord" value="{{ branding.socials.discord|default('') }}" class="form-input">
                    </div>
                    <div class="form-field">
                        <label class="form-label">{{ t('admin_cms_settings_twitter', locale) }}</label>
                        <input type="text" name="social_twitter" value="{{ branding.socials.twitter|default('') }}" class="form-input">
                    </div>
                    <div class="form-field">
                        <label class="form-label">{{ t('admin_cms_settings_youtube', locale) }}</label>
                        <input type="text" name="social_youtube" value="{{ branding.socials.youtube|default('') }}" class="form-input">
                    </div>
                </div>
            </div>
        </div>

        <div class="ng-data-card">
            <div class="ng-data-card__header">
                <div>
                    <h2 class="ng-data-card__title">{{ t('admin_cms_settings_modules_title', locale) }}</h2>
                    <p class="ng-data-card__sub">{{ t('admin_cms_settings_modules_hint', locale) }}</p>
                </div>
            </div>
            <div class="ng-data-card__body">
                <div class="ng-layout-2col--equal">
                    {% for key, enabled in module_toggles %}
                        <label style="display:inline-flex;align-items:center;gap:8px;font-size:0.875rem;cursor:pointer;border:1px solid var(--ng-border);border-radius:0.5rem;padding:0.5rem 0.75rem;">
                            <input type="checkbox" name="toggle_{{ key }}" value="1" {% if enabled %}checked{% endif %}>
                            <span>{{ key|capitalize }}</span>
                        </label>
                    {% endfor %}
                </div>
            </div>
        </div>

        <div class="ng-data-card">
            <div class="ng-data-card__header">
                <div>
                    <h2 class="ng-data-card__title">{{ t('admin_cms_settings_legal_title', locale) }}</h2>
                    <p class="ng-data-card__sub">{{ t('admin_cms_settings_legal_hint', locale) }}</p>
                </div>
            </div>
            <div class="ng-data-card__body" style="display:flex;flex-direction:column;gap:1rem;">
                <div class="form-field">
                    <label class="form-label">{{ t('admin_cms_settings_impressum', locale) }}</label>
                    <textarea name="impressum_content" rows="10" class="form-input font-mono">{{ impressum_content|default('') }}</textarea>
                </div>
                <div class="form-field">
                    <label class="form-label">{{ t('admin_cms_settings_datenschutz', locale) }}</label>
                    <textarea name="datenschutz_content" rows="10" class="form-input font-mono">{{ datenschutz_content|default('') }}</textarea>
                </div>
            </div>
        </div>

        <div class="ng-data-card">
            <div class="ng-data-card__header">
                <div>
                    <h2 class="ng-data-card__title">{{ t('admin_cms_settings_maintenance_title', locale) }}</h2>
                </div>
            </div>
            <div class="ng-data-card__body" style="display:flex;flex-direction:column;gap:1rem;">
                <label style="display:inline-flex;align-items:center;gap:8px;font-size:0.875rem;cursor:pointer;border:1px solid var(--ng-border);border-radius:0.5rem;padding:0.5rem 0.75rem;width:fit-content;">
                    <input type="checkbox" name="maintenance_enabled" value="1" {% if maintenance.enabled %}checked{% endif %}>
                    <span>{{ t('admin_cms_settings_maintenance_enable', locale) }}</span>
                </label>
                <div class="ng-layout-2col--equal">
                    <div class="form-field">
                        <label class="form-label">{{ t('admin_cms_settings_maintenance_start', locale) }}</label>
                        <input type="datetime-local" name="maintenance_starts_at" value="{{ maintenance.starts_at|default('') }}" class="form-input">
                    </div>
                    <div class="form-field">
                        <label class="form-label">{{ t('admin_cms_settings_maintenance_end', locale) }}</label>
                        <input type="datetime-local" name="maintenance_ends_at" value="{{ maintenance.ends_at|default('') }}" class="form-input">
                    </div>
                </div>
                <div class="form-field">
                    <label class="form-label">{{ t('admin_cms_settings_maintenance_text', locale) }}</label>
                    <textarea name="maintenance_message" rows="3" class="form-input">{{ maintenance.message|default('') }}</textarea>
                    <p class="form-hint">{{ t('admin_cms_settings_maintenance_text_hint', locale) }}</p>
                </div>
                <div class="form-field">
                    <label class="form-label">{{ t('admin_cms_settings_maintenance_graphic', locale) }}</label>
                    <input type="text" name="maintenance_graphic_path" value="{{ maintenance.graphic_path|default('') }}" class="form-input">
                </div>
                <div class="form-field">
                    <label class="form-label">{{ t('admin_cms_settings_maintenance_allowlist', locale) }}</label>
                    <textarea name="maintenance_allowlist" rows="3" class="form-input">{{ maintenance.allowlist|default('') }}</textarea>
                </div>
            </div>
        </div>

        <div class="ng-data-card">
            <div class="ng-data-card__header">
                <div>
                    <h2 class="ng-data-card__title">{{ t('admin_cms_settings_nav_title', locale) }}</h2>
                    <p class="ng-data-card__sub">{{ t('admin_cms_settings_nav_hint', locale) }}</p>
                </div>
            </div>
            <div class="ng-data-card__body" style="display:flex;flex-direction:column;gap:1rem;">
                <div class="form-field">
                    <label class="form-label">{{ t('admin_cms_settings_header_links', locale) }}</label>
                    <textarea name="header_links_json" rows="8" class="form-input font-mono text-xs">{{ header_links_json }}</textarea>
                </div>
                <div class="form-field">
                    <label class="form-label">{{ t('admin_cms_settings_footer_links', locale) }}</label>
                    <textarea name="footer_links_json" rows="8" class="form-input font-mono text-xs">{{ footer_links_json }}</textarea>
                </div>
            </div>
        </div>

        <div>
            <button type="submit" class="ui-button ui-button--primary">{{ t('admin_cms_settings_save', locale) }}</button>
        </div>

    </form>

</div>
{% endblock %}
