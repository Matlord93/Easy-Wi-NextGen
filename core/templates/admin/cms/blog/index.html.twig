{% extends 'admin/base.html.twig' %}

{% set pageTitle = t('cms_blog_title', page_locale()) %}
{% set pageSubtitle = t('cms_blog_description', page_locale()) %}
{% set activeNav = 'cms-blog' %}
{% set topbarActions %}
    <a href="/admin/cms/blog/new" class="ui-button ui-button--primary ui-button--sm">{{ t('cms_blog_new', page_locale()) }}</a>
{% endset %}

{% block content %}
{% set locale = page_locale() %}
<div class="flex flex-col gap-6">

    <div class="ng-layout-2col--equal">
        <div class="ng-data-card">
            <div class="ng-data-card__header">
                <div>
                    <h2 class="ng-data-card__title">{{ t('admin_cms_blog_categories_title', locale) }}</h2>
                </div>
            </div>
            <div class="ng-data-card__body">
                <form method="post" action="/admin/cms/blog/categories" class="grid gap-2 sm:grid-cols-3 mb-4">
                    <div class="form-field">
                        <input name="name" placeholder="Name" class="form-input">
                    </div>
                    <div class="form-field">
                        <input name="slug" placeholder="slug" class="form-input">
                    </div>
                    <button class="ui-button ui-button--primary ui-button--sm">{{ t('admin_cms_blog_create_category', locale) }}</button>
                </form>
                <div class="flex flex-col gap-2 text-sm">
                    {% for category in categories %}
                        <div class="flex items-center justify-between rounded-lg border border-slate-100 px-3 py-2">
                            <span>{{ category.name }} <span class="text-xs text-slate-500">({{ category.slug }})</span></span>
                            <form method="post" action="/admin/cms/blog/categories/{{ category.id }}/delete">
                                <button class="ui-button ui-button--danger ui-button--sm">{{ t('admin_cms_blog_delete', locale) }}</button>
                            </form>
                        </div>
                    {% else %}
                        <p class="text-xs text-slate-500">{{ t('admin_cms_blog_no_categories', locale) }}</p>
                    {% endfor %}
                </div>
            </div>
        </div>

        <div class="ng-data-card">
            <div class="ng-data-card__header">
                <div>
                    <h2 class="ng-data-card__title">{{ t('admin_cms_blog_tags_title', locale) }}</h2>
                </div>
            </div>
            <div class="ng-data-card__body">
                <form method="post" action="/admin/cms/blog/tags" class="grid gap-2 sm:grid-cols-3 mb-4">
                    <div class="form-field">
                        <input name="name" placeholder="Name" class="form-input">
                    </div>
                    <div class="form-field">
                        <input name="slug" placeholder="slug" class="form-input">
                    </div>
                    <button class="ui-button ui-button--primary ui-button--sm">{{ t('admin_cms_blog_create_category', locale) }}</button>
                </form>
                <div class="flex flex-col gap-2 text-sm">
                    {% for tag in tags %}
                        <div class="flex items-center justify-between rounded-lg border border-slate-100 px-3 py-2">
                            <span>{{ tag.name }} <span class="text-xs text-slate-500">({{ tag.slug }})</span></span>
                            <form method="post" action="/admin/cms/blog/tags/{{ tag.id }}/delete">
                                <button class="ui-button ui-button--danger ui-button--sm">{{ t('admin_cms_blog_delete', locale) }}</button>
                            </form>
                        </div>
                    {% else %}
                        <p class="text-xs text-slate-500">{{ t('admin_cms_blog_no_tags', locale) }}</p>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>

    <div class="ng-data-card">
        <div class="ng-data-card__header">
            <div>
                <h2 class="ng-data-card__title">{{ t('cms_blog_title', locale) }}</h2>
            </div>
        </div>
        <div class="ng-data-card__body--flush">
            <div class="cust-ws-table-wrap">
                <table class="cust-table">
                    <thead>
                        <tr>
                            <th>{{ t('title', locale) }}</th>
                            <th>{{ t('admin_cms_blog_category_col', locale) }}</th>
                            <th>{{ t('admin_cms_blog_tags_col', locale) }}</th>
                            <th>{{ t('status', locale) }}</th>
                            <th>{{ t('actions', locale) }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for post in posts %}
                            <tr>
                                <td>
                                    <div class="font-semibold text-slate-900">{{ post.title }}</div>
                                    <div class="mt-1 text-xs text-slate-500">/{{ post.slug }}</div>
                                </td>
                                <td>{{ post.category ?: '-' }}</td>
                                <td>{{ post.tags|join(', ') ?: '-' }}</td>
                                <td>
                                    {% if post.is_published %}
                                        <span class="ui-badge ui-badge--success">{{ t('published', locale) }}</span>
                                    {% else %}
                                        <span class="ui-badge ui-badge--neutral">{{ t('admin_cms_blog_draft_badge', locale) }}</span>
                                    {% endif %}
                                </td>
                                <td>
                                    <div class="inline-flex items-center gap-2">
                                        <a href="/admin/cms/blog/{{ post.id }}/edit" class="ui-button ui-button--ghost ui-button--sm">{{ t('edit', locale) }}</a>
                                        <form method="post" action="/admin/cms/blog/{{ post.id }}/delete" onsubmit="return confirm('{{ t('cms_blog_delete_confirm', locale) }}');">
                                            <button class="ui-button ui-button--danger ui-button--sm" type="submit">{{ t('delete', locale) }}</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="5" class="cust-table__empty">{{ t('cms_blog_empty', locale) }}</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>
{% endblock %}
