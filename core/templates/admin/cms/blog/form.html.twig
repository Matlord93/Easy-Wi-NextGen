{% extends 'admin/base.html.twig' %}

{% set pageTitle = form.action == 'create' ? t('cms_blog_new', page_locale()) : t('cms_blog_edit', page_locale()) %}

{% block content %}
{% set locale = page_locale() %}
<div class="mx-auto max-w-4xl flex flex-col gap-6">
    <div class="ng-data-card">
        <div class="ng-data-card__header">
            <div>
                <h1 class="ng-data-card__title">{{ pageTitle }}</h1>
                <p class="ng-data-card__subtitle">{{ t('cms_blog_form_description', locale) }}</p>
            </div>
        </div>
        <div class="ng-data-card__body">

            {% if form.errors is not empty %}
                <div class="ng-alert ng-alert--danger">
                    <ul class="list-disc pl-5">
                        {% for error in form.errors %}<li>{{ error }}</li>{% endfor %}
                    </ul>
                </div>
            {% endif %}

            <form method="post" action="{{ form.action_url }}" class="flex flex-col gap-5">
                <div class="grid gap-4 md:grid-cols-2">
                    <div class="form-field">
                        <label class="form-label">{{ t('title', locale) }}</label>
                        <input name="title" value="{{ form.title }}" class="form-input" />
                    </div>
                    <div class="form-field">
                        <label class="form-label">{{ t('slug', locale) }}</label>
                        <input name="slug" value="{{ form.slug }}" class="form-input" />
                    </div>
                </div>

                <div class="form-field">
                    <label class="form-label">{{ t('cms_blog_excerpt', locale) }}</label>
                    <textarea name="excerpt" rows="3" class="form-input">{{ form.excerpt }}</textarea>
                </div>

                <div class="form-field">
                    <label class="form-label">{{ t('admin_cms_blog_content_label', locale) }}</label>
                    <textarea name="content" rows="10" class="form-input">{{ form.content }}</textarea>
                </div>

                <div class="grid gap-4 md:grid-cols-2">
                    <div class="form-field">
                        <label class="form-label">{{ t('admin_cms_blog_seo_title_label', locale) }}</label>
                        <input name="seo_title" value="{{ form.seo_title }}" class="form-input" />
                    </div>
                    <div class="form-field">
                        <label class="form-label">{{ t('admin_cms_blog_featured_image', locale) }}</label>
                        <input name="featured_image_path" value="{{ form.featured_image_path }}" class="form-input" />
                    </div>
                </div>

                <div class="form-field">
                    <label class="form-label">{{ t('admin_cms_blog_seo_desc_label', locale) }}</label>
                    <textarea name="seo_description" rows="2" class="form-input">{{ form.seo_description }}</textarea>
                </div>

                <div class="grid gap-4 md:grid-cols-2">
                    <div class="form-field">
                        <label class="form-label">{{ t('admin_cms_blog_category_select', locale) }}</label>
                        <select name="category_id" class="form-input">
                            <option value="">-</option>
                            {% for category in form.categories %}
                                <option value="{{ category.id }}" {% if form.category_id == category.id %}selected{% endif %}>{{ category.name }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="form-field">
                        <label class="form-label">{{ t('admin_cms_blog_tags_select', locale) }}</label>
                        <select name="tag_ids[]" multiple class="form-input" style="height:8rem">
                            {% for tag in form.available_tags %}
                                <option value="{{ tag.id }}" {% if tag.id in form.tag_ids %}selected{% endif %}>{{ tag.name }}</option>
                            {% endfor %}
                        </select>
                    </div>
                </div>

                <label class="inline-flex items-center gap-2 text-sm">
                    <input type="checkbox" name="is_published" {% if form.is_published %}checked{% endif %} />
                    <span>{{ t('cms_blog_publish', locale) }}</span>
                </label>

                <div class="flex items-center gap-3">
                    <button class="ui-button ui-button--primary" type="submit">{{ t(form.submit_label, locale) }}</button>
                    <a href="/admin/cms/blog" class="ui-button ui-button--ghost">{{ t('cancel', locale) }}</a>
                </div>
            </form>

        </div>
    </div>
</div>
{% endblock %}
