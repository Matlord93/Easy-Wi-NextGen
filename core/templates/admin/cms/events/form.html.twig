{% extends 'admin/base.html.twig' %}
{% set event = form.event %}
{% set locale = page_locale() %}
{% block content %}
<div class="mx-auto max-w-3xl" style="display:flex;flex-direction:column;gap:20px;">
    <div class="ng-data-card">
        <div class="ng-data-card__header">
            <div>
                <h1 class="ng-data-card__title">{{ event ? t('admin_cms_events_form_edit_title', locale) : t('admin_cms_events_form_new_title', locale) }}</h1>
            </div>
        </div>
        <div class="ng-data-card__body">
            <form method="post" action="{{ form.action_url }}" style="display:flex;flex-direction:column;gap:1.25rem;">

                <div class="form-field">
                    <label class="form-label">{{ t('admin_cms_events_form_title_placeholder', locale) }}</label>
                    <input name="title" value="{{ event ? event.title : '' }}" placeholder="{{ t('admin_cms_events_form_title_placeholder', locale) }}" class="form-input" />
                </div>

                <div class="form-field">
                    <label class="form-label">{{ t('admin_cms_events_form_slug_placeholder', locale) }}</label>
                    <input name="slug" value="{{ event ? event.slug : '' }}" placeholder="{{ t('admin_cms_events_form_slug_placeholder', locale) }}" class="form-input" />
                </div>

                <div class="form-field">
                    <label class="form-label">{{ t('admin_cms_events_form_desc_placeholder', locale) }}</label>
                    <textarea name="description" rows="6" placeholder="{{ t('admin_cms_events_form_desc_placeholder', locale) }}" class="form-input">{{ event ? event.description : '' }}</textarea>
                </div>

                <div style="display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:1rem;">
                    <div class="form-field">
                        <label class="form-label">{{ t('admin_cms_events_table_start', locale) }}</label>
                        <input type="datetime-local" name="start_at" value="{{ event and event.startAt ? event.startAt|date('Y-m-d\\TH:i') : '' }}" class="form-input" />
                    </div>
                    <div class="form-field">
                        <label class="form-label">{{ t('admin_cms_events_form_end_at', locale) }}</label>
                        <input type="datetime-local" name="end_at" value="{{ event and event.endAt ? event.endAt|date('Y-m-d\\TH:i') : '' }}" class="form-input" />
                    </div>
                </div>

                <div class="form-field">
                    <label class="form-label">{{ t('admin_cms_events_form_location', locale) }}</label>
                    <input name="location" value="{{ event ? event.location : '' }}" placeholder="{{ t('admin_cms_events_form_location', locale) }}" class="form-input" />
                </div>

                <div class="form-field">
                    <label class="form-label">{{ t('admin_cms_events_table_status', locale) }}</label>
                    <select name="status" class="form-input">
                        {% set value = event ? event.status : 'planned' %}
                        <option value="planned" {% if value == 'planned' %}selected{% endif %}>{{ t('admin_cms_events_status_planned', locale) }}</option>
                        <option value="canceled" {% if value == 'canceled' %}selected{% endif %}>{{ t('admin_cms_events_status_canceled', locale) }}</option>
                        <option value="past" {% if value == 'past' %}selected{% endif %}>{{ t('admin_cms_events_status_past', locale) }}</option>
                    </select>
                </div>

                <div class="form-field">
                    <label class="form-label">{{ t('admin_cms_events_form_cover', locale) }}</label>
                    <input name="cover_image_path" value="{{ event ? event.coverImagePath : '' }}" placeholder="{{ t('admin_cms_events_form_cover', locale) }}" class="form-input" />
                </div>

                <label style="display:inline-flex;align-items:center;gap:8px;font-size:0.875rem;">
                    <input type="checkbox" name="is_published" {% if event and event.isPublished %}checked{% endif %} />
                    <span>{{ t('admin_cms_events_form_published', locale) }}</span>
                </label>

                <div style="display:flex;align-items:center;gap:12px;">
                    <button class="ui-button ui-button--primary" type="submit">{{ t('admin_cms_events_form_save', locale) }}</button>
                    <a href="/admin/cms/events" class="ui-button ui-button--ghost">{{ t('cancel', locale) }}</a>
                </div>

            </form>
        </div>
    </div>
</div>
{% endblock %}
