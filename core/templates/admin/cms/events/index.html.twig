{% extends 'admin/base.html.twig' %}

{% set pageTitle = t('admin_cms_events_title', page_locale()) %}
{% set activeNav = 'cms-events' %}
{% set topbarActions %}
    <a href="/admin/cms/events/new" class="ui-button ui-button--primary ui-button--sm">{{ t('admin_cms_events_new', page_locale()) }}</a>
{% endset %}

{% set locale = page_locale() %}

{% block content %}
<div style="display:flex;flex-direction:column;gap:20px;">

    <section class="ng-card" style="overflow:hidden;">
        <div class="tkt-hero">
            <div class="tkt-hero__inner">
                <div style="display:flex;flex-direction:column;gap:16px;">
                    <div>
                        <div class="tkt-hero__pill">
                            <span class="tkt-hero__pill-dot"></span>
                            CMS
                        </div>
                        <h1 class="tkt-hero__title" style="margin-top:10px;">{{ t('admin_cms_events_title', locale) }}</h1>
                        <p class="tkt-hero__sub">{{ t('admin_cms_events_intro', locale) }}</p>
                    </div>
                    <div style="display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:10px;">
                        <div class="tkt-kpi">
                            <div class="tkt-kpi__label">{{ t('admin_cms_events_total_kpi', locale) }}</div>
                            <div class="tkt-kpi__value">{{ events|length }}</div>
                        </div>
                        <div class="tkt-kpi tkt-kpi--resolved">
                            <div class="tkt-kpi__label">{{ t('admin_cms_events_status_planned', locale) }}</div>
                            <div class="tkt-kpi__value">{{ events|filter(e => e.status == 'planned')|length }}</div>
                        </div>
                        <div class="tkt-kpi tkt-kpi--pending">
                            <div class="tkt-kpi__label">{{ t('admin_cms_events_status_past', locale) }}</div>
                            <div class="tkt-kpi__value">{{ events|filter(e => e.status == 'past')|length }}</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <div class="ng-data-card">
        <div class="ng-data-card__header">
            <div>
                <h2 class="ng-data-card__title">{{ t('admin_cms_events_title', locale) }}</h2>
            </div>
            <div class="ng-data-card__actions">
                <a href="/admin/cms/events/new" class="ui-button ui-button--primary ui-button--sm">{{ t('admin_cms_events_new', locale) }}</a>
            </div>
        </div>
        <div class="ng-data-card__body--flush">
            <div class="cust-ws-table-wrap">
                <table class="cust-table">
                    <thead>
                        <tr>
                            <th>{{ t('admin_cms_events_table_title', locale) }}</th>
                            <th>{{ t('admin_cms_events_table_start', locale) }}</th>
                            <th>{{ t('admin_cms_events_table_status', locale) }}</th>
                            <th>{{ t('admin_cms_events_table_actions', locale) }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for event in events %}
                            <tr>
                                <td>
                                    {{ event.title }}
                                    <span class="ui-badge ui-badge--neutral">/{{ event.slug }}</span>
                                </td>
                                <td>{{ event.startAt|date('Y-m-d H:i') }}</td>
                                <td>
                                    {% if event.status == 'planned' %}
                                        <span class="ui-badge ui-badge--success">{{ t('admin_cms_events_status_planned', locale) }}</span>
                                    {% elseif event.status == 'canceled' %}
                                        <span class="ui-badge ui-badge--danger">{{ t('admin_cms_events_status_canceled', locale) }}</span>
                                    {% elseif event.status == 'past' %}
                                        <span class="ui-badge ui-badge--neutral">{{ t('admin_cms_events_status_past', locale) }}</span>
                                    {% else %}
                                        <span class="ui-badge ui-badge--warning">{{ event.status }}</span>
                                    {% endif %}
                                </td>
                                <td>
                                    <div style="display:inline-flex;align-items:center;gap:8px;">
                                        <a class="ui-button ui-button--ghost ui-button--sm" href="/admin/cms/events/{{ event.id }}/edit">{{ t('admin_cms_events_edit', locale) }}</a>
                                        <form method="post" action="/admin/cms/events/{{ event.id }}/delete" class="inline">
                                            <button class="ui-button ui-button--danger ui-button--sm">{{ t('admin_cms_events_delete', locale) }}</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        {% else %}
                            <tr><td colspan="4" class="cust-table__empty">{{ t('admin_cms_events_empty', locale) }}</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{% endblock %}
