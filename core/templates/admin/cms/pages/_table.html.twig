<div id="cms-pages-table" class="cust-ws-table-wrap">
    <table class="cust-table">
        <thead>
            <tr>
                <th>{{ t('page', page_locale()) }}</th>
                <th>{{ t('slug', page_locale()) }}</th>
                <th>{{ t('status', page_locale()) }}</th>
                <th>{{ t('blocks', page_locale()) }}</th>
                <th>{{ t('updated', page_locale()) }}</th>
                <th class="text-right">{{ t('actions', page_locale()) }}</th>
            </tr>
        </thead>
        <tbody>
            {% for page in pages %}
                <tr>
                    <td>
                        <div class="font-semibold" style="color:var(--ng-text)">{{ page.title }}</div>
                        <div class="text-xs" style="color:var(--ng-text-muted)">ID #{{ page.id }}</div>
                    </td>
                    <td>/{{ page.slug }}</td>
                    <td>
                        {% if page.is_published %}
                            <span class="ui-badge ui-badge--success">{{ t('published', page_locale()) }}</span>
                        {% else %}
                            <span class="ui-badge ui-badge--neutral">{{ t('draft', page_locale()) }}</span>
                        {% endif %}
                    </td>
                    <td>{{ page.block_count }}</td>
                    <td>{{ page.updated_at|date('Y-m-d H:i') }}</td>
                    <td class="text-right">
                        <div class="inline-flex items-center gap-2">
                            <button
                                class="ui-button ui-button--ghost ui-button--sm"
                                hx-get="/admin/cms/pages/{{ page.id }}/edit"
                                hx-target="#cms-page-form"
                                hx-swap="outerHTML"
                            >
                                {{ t('edit', page_locale()) }}
                            </button>
                            <a href="/admin/cms/pages/{{ page.id }}" class="ui-button ui-button--ghost ui-button--sm">{{ t('manage_blocks', page_locale()) }}</a>
                            <button
                                class="ui-button ui-button--danger ui-button--sm"
                                hx-post="/admin/cms/pages/{{ page.id }}/delete"
                                hx-confirm="{{ t('delete_page_confirm', page_locale()) }}"
                            >
                                {{ t('delete', page_locale()) }}
                            </button>
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="6" class="cust-table__empty">{{ t('no_cms_pages', page_locale()) }}</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
