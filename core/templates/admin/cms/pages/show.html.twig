{% extends 'admin/base.html.twig' %}

{% block content %}
{% set locale = page_locale() %}

<div style="display:flex;flex-direction:column;gap:20px;">

    <section class="ng-card" style="overflow:hidden;">
        <div class="tkt-hero">
            <div class="tkt-hero__inner">
                <div style="display:flex;flex-direction:column;gap:12px;">
                    <div style="display:flex;align-items:flex-start;justify-content:space-between;flex-wrap:wrap;gap:12px;">
                        <div>
                            <div class="tkt-hero__pill">
                                <span class="tkt-hero__pill-dot" style="background:#a78bfa;"></span>
                                {{ t('cms_pages_title', locale) }}
                            </div>
                            <h1 class="tkt-hero__title" style="margin-top:10px;">{{ page.title }}</h1>
                            <p class="tkt-hero__sub">{{ t('cms_page_manage_blocks_description', locale) }} <span style="font-weight:600;color:var(--ng-text)">/{{ page.slug }}</span>.</p>
                        </div>
                        <div style="display:flex;align-items:center;gap:8px;padding-top:4px;">
                            {% if page.is_published %}
                                <span class="ui-badge ui-badge--success">{{ t('published', locale) }}</span>
                            {% else %}
                                <span class="ui-badge ui-badge--neutral">{{ t('draft', locale) }}</span>
                            {% endif %}
                            <a href="/admin/cms/pages" class="ui-button ui-button--ghost ui-button--sm">{{ t('back_to_pages', locale) }}</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <div class="ng-layout-2col">
        <div class="ng-data-card">
            <div class="ng-data-card__header">
                <div>
                    <h2 class="ng-data-card__title">{{ t('content_blocks', locale) }}</h2>
                    <p class="ng-data-card__sub">{{ t('content_blocks_description', locale) }}</p>
                </div>
                <div class="ng-data-card__actions">
                    <button
                        class="ui-button ui-button--ghost ui-button--sm"
                        hx-get="/admin/cms/pages/{{ page.id }}/blocks/table"
                        hx-target="#cms-blocks-table"
                        hx-swap="outerHTML"
                    >{{ t('refresh', locale) }}</button>
                </div>
            </div>
            <div id="cms-blocks-table" class="ng-data-card__body--flush" hx-trigger="cms-blocks-changed from:body" hx-get="/admin/cms/pages/{{ page.id }}/blocks/table" hx-swap="outerHTML">
                {% include 'admin/cms/pages/_blocks_table.html.twig' with { blocks: blocks, page: page } %}
            </div>
        </div>

        <div class="ng-data-card" id="cms-block-form" hx-trigger="cms-blocks-changed from:body" hx-get="/admin/cms/pages/{{ page.id }}/blocks/form" hx-swap="outerHTML">
            <div class="ng-data-card__body">
                {% include 'admin/cms/pages/_block_form.html.twig' with { blockForm: blockForm, page: page } %}
            </div>
        </div>
    </div>

</div>
{% endblock %}
