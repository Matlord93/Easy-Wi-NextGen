<div class="cust-ws-table-wrap">
    <table class="cust-table">
        <thead>
            <tr>
                <th>{{ t('order', page_locale()) }}</th>
                <th>{{ t('type', page_locale()) }}</th>
                <th>{{ t('preview', page_locale()) }}</th>
                <th>{{ t('updated', page_locale()) }}</th>
                <th class="text-right">{{ t('actions', page_locale()) }}</th>
            </tr>
        </thead>
        <tbody>
            {% for block in blocks %}
                <tr>
                    <td>{{ block.sort_order }}</td>
                    <td>
                        <span class="ui-badge ui-badge--info">{{ block.type }}</span>
                        <span class="ui-badge ui-badge--neutral">v{{ block.version }}</span>
                    </td>
                    <td>
                        <span class="line-clamp-2">{{ block.preview|slice(0, 120) }}{% if block.preview|length > 120 %}…{% endif %}</span>
                    </td>
                    <td>{{ block.updated_at|date('Y-m-d H:i') }}</td>
                    <td class="text-right">
                        <div class="inline-flex items-center gap-2">
                            <button
                                class="ui-button ui-button--ghost ui-button--sm"
                                hx-post="/admin/cms/pages/{{ page.id }}/blocks/{{ block.id }}/move-up"
                            >↑</button>
                            <button
                                class="ui-button ui-button--ghost ui-button--sm"
                                hx-post="/admin/cms/pages/{{ page.id }}/blocks/{{ block.id }}/move-down"
                            >↓</button>
                            <button
                                class="ui-button ui-button--ghost ui-button--sm"
                                hx-get="/admin/cms/pages/{{ page.id }}/blocks/{{ block.id }}/edit"
                                hx-target="#cms-block-form"
                                hx-swap="outerHTML"
                            >
                                {{ t('edit', page_locale()) }}
                            </button>
                            <button
                                class="ui-button ui-button--danger ui-button--sm"
                                hx-post="/admin/cms/pages/{{ page.id }}/blocks/{{ block.id }}/delete"
                                hx-confirm="{{ t('delete_block_confirm', page_locale()) }}"
                            >
                                {{ t('delete', page_locale()) }}
                            </button>
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="5" class="cust-table__empty">{{ t('no_blocks_yet', page_locale()) }}</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
