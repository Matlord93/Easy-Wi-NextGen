<details class="group" {{ (maintenanceForm.errors is not empty or maintenanceForm.success) ? 'open' : '' }}>
    <summary class="flex cursor-pointer items-center justify-between rounded-xl border border-slate-200 bg-white px-5 py-4 text-left">
        <div>
            <h2 class="text-lg font-semibold">{{ t('cms_maintenance_title', page_locale()) }}</h2>
            <p class="text-sm text-slate-700">{{ t('cms_maintenance_description', page_locale()) }}</p>
        </div>
        <span class="text-xs font-semibold uppercase text-slate-500">{{ t('configure', page_locale()) }}</span>
    </summary>

    <div class="rounded-b-xl border-x border-b border-slate-200 bg-white px-5 py-6">
        {% if maintenanceForm.success %}
            <div class="mb-4 rounded-lg border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-700">
                {{ t('cms_maintenance_saved', page_locale()) }}
            </div>
        {% endif %}

        {% if maintenanceForm.errors is not empty %}
            <div class="mb-4 rounded-lg border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700">
                <ul class="list-disc space-y-1 pl-4">
                    {% for error in maintenanceForm.errors %}
                        <li>{{ error }}</li>
                    {% endfor %}
                </ul>
            </div>
        {% endif %}

        <form class="space-y-4" hx-post="/admin/cms/pages/maintenance" hx-target="#cms-maintenance-form" hx-swap="outerHTML">
            <label class="inline-flex items-center gap-2 text-sm text-slate-700">
                <input type="checkbox" name="maintenance_enabled" class="rounded border-slate-300" {{ maintenanceForm.enabled ? 'checked' : '' }}>
                {{ t('cms_maintenance_enabled_label', page_locale()) }}
            </label>

            <div class="grid gap-4 lg:grid-cols-2">
                <div>
                    <label class="block text-xs font-semibold uppercase text-slate-700">{{ t('cms_maintenance_start_label', page_locale()) }}</label>
                    <input type="datetime-local" name="maintenance_starts_at" value="{{ maintenanceForm.starts_at }}" class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm">
                </div>
                <div>
                    <label class="block text-xs font-semibold uppercase text-slate-700">{{ t('cms_maintenance_end_label', page_locale()) }}</label>
                    <input type="datetime-local" name="maintenance_ends_at" value="{{ maintenanceForm.ends_at }}" class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm">
                </div>
            </div>

            <div>
                <label class="block text-xs font-semibold uppercase text-slate-700">{{ t('cms_maintenance_message_label', page_locale()) }}</label>
                <textarea name="maintenance_message" rows="3" class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm">{{ maintenanceForm.message }}</textarea>
                <p class="mt-2 text-xs text-slate-600">{{ t('cms_maintenance_message_hint', page_locale()) }}</p>
            </div>

            <div>
                <label class="block text-xs font-semibold uppercase text-slate-700">{{ t('cms_maintenance_allowlist_label', page_locale()) }}</label>
                <textarea name="maintenance_allowlist" rows="3" class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm" placeholder="203.0.113.10&#10;198.51.100.0/24">{{ maintenanceForm.allowlist }}</textarea>
                <p class="mt-2 text-xs text-slate-600">{{ t('cms_maintenance_allowlist_hint', page_locale()) }}</p>
            </div>

            <div class="flex items-center gap-3">
                <button type="submit" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-700">
                    {{ t('save', page_locale()) }}
                </button>
                <span class="text-xs text-slate-500">{{ t('cms_maintenance_scope_site', page_locale()) }}</span>
            </div>
        </form>
    </div>
</details>
