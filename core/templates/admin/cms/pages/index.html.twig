{% extends 'admin/base.html.twig' %}

{% set pageTitle = t('cms_pages_title', page_locale()) %}
{% set pageSubtitle = t('cms_pages_description', page_locale()) %}
{% set activeNav = 'cms-pages' %}
{% set topbarActions %}
    <button
        class="ui-button ui-button--ghost ui-button--sm"
        hx-get="/admin/cms/pages/table"
        hx-target="#cms-pages-table"
        hx-swap="outerHTML"
    >{{ t('refresh', page_locale()) }}</button>
{% endset %}

{% block content %}
{% set locale = page_locale() %}
<div class="flex flex-col gap-6">

    <section class="ng-card" style="overflow:hidden;">
        <div class="tkt-hero">
            <div class="tkt-hero__inner">
                <div style="display:flex;flex-direction:column;gap:16px;">
                    <div>
                        <div class="tkt-hero__pill">
                            <span class="tkt-hero__pill-dot" style="background:#a78bfa;"></span>
                            {{ t('cms_pages_title', locale) }}
                        </div>
                        <h1 class="tkt-hero__title" style="margin-top:10px;">{{ t('cms_pages_title', locale) }}</h1>
                        <p class="tkt-hero__sub">{{ t('cms_pages_description', locale) }}</p>
                    </div>
                    <div style="display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:10px;">
                        <div class="tkt-kpi">
                            <div class="tkt-kpi__label">{{ t('total_pages', locale) }}</div>
                            <div class="tkt-kpi__value">{{ summary.total }}</div>
                        </div>
                        <div class="tkt-kpi tkt-kpi--resolved">
                            <div class="tkt-kpi__label">{{ t('published', locale) }}</div>
                            <div class="tkt-kpi__value">{{ summary.published }}</div>
                        </div>
                        <div class="tkt-kpi tkt-kpi--pending">
                            <div class="tkt-kpi__label">{{ t('blocks', locale) }}</div>
                            <div class="tkt-kpi__value">{{ summary.blocks }}</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <div class="ng-layout-2col">
        <div class="ng-data-card">
            <div class="ng-data-card__header">
                <div>
                    <h2 class="ng-data-card__title">{{ t('pages_overview', locale) }}</h2>
                    <p class="ng-data-card__sub">{{ t('pages_overview_description', locale) }}</p>
                </div>
                <div class="ng-data-card__actions">
                    <button
                        class="ui-button ui-button--ghost ui-button--sm"
                        hx-get="/admin/cms/pages/table"
                        hx-target="#cms-pages-table"
                        hx-swap="outerHTML"
                    >{{ t('refresh', locale) }}</button>
                </div>
            </div>
            <div class="ng-data-card__body--flush">
                {% include 'admin/cms/pages/_table.html.twig' with { pages: pages } %}
            </div>
        </div>

        <div id="cms-page-form" class="ng-data-card" hx-trigger="cms-pages-changed from:body" hx-get="/admin/cms/pages/form" hx-swap="outerHTML">
            <div class="ng-data-card__body">
                {% include 'admin/cms/pages/_form.html.twig' with { form: form } %}
            </div>
        </div>
    </div>

</div>
{% endblock %}
