{% extends 'admin/base.html.twig' %}

{% set pageTitle = t('admin_cms_contact_title', page_locale()) %}
{% set activeNav = 'cms-contact' %}

{% block content %}
{% set locale = page_locale() %}
<div class="flex flex-col gap-6">

    {% if new_count > 0 %}
        <div class="ng-alert ng-alert--info">
            {{ new_count != 1 ? t('admin_cms_contact_new_count_plural', locale)|replace({'%count%': new_count}) : t('admin_cms_contact_new_count', locale)|replace({'%count%': new_count}) }}
        </div>
    {% endif %}

    <div class="ng-data-card">
        <div class="ng-data-card__header">
            <div>
                <h2 class="ng-data-card__title">{{ t('admin_cms_contact_title', locale) }}</h2>
                <p class="ng-data-card__sub">{{ t('admin_cms_contact_all_read', locale) }}</p>
            </div>
        </div>
        <div class="ng-data-card__body--flush">
            <div class="cust-ws-table-wrap">
                <table class="cust-table">
                    <thead>
                        <tr>
                            <th>{{ t('admin_cms_contact_col_status', locale) }}</th>
                            <th>{{ t('admin_cms_contact_col_name', locale) }}</th>
                            <th>{{ t('admin_cms_contact_col_email', locale) }}</th>
                            <th>{{ t('admin_cms_contact_col_subject', locale) }}</th>
                            <th>{{ t('admin_cms_contact_col_date', locale) }}</th>
                            <th>{{ t('admin_cms_contact_col_actions', locale) }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for msg in messages %}
                            <tr>
                                <td>
                                    {% if msg.status == 'new' %}
                                        <span class="ui-badge ui-badge--info">{{ t('admin_cms_contact_status_new', locale) }}</span>
                                    {% elseif msg.status == 'replied' %}
                                        <span class="ui-badge ui-badge--success">{{ t('admin_cms_contact_status_replied', locale) }}</span>
                                    {% else %}
                                        <span class="ui-badge ui-badge--neutral">{{ t('admin_cms_contact_status_read', locale) }}</span>
                                    {% endif %}
                                </td>
                                <td class="font-medium text-slate-800">{{ msg.name }}</td>
                                <td>{{ msg.email }}</td>
                                <td>{{ msg.subject|slice(0, 60) }}{% if msg.subject|length > 60 %}…{% endif %}</td>
                                <td class="whitespace-nowrap">{{ msg.createdAt|date('d.m.Y H:i') }}</td>
                                <td>
                                    <div class="inline-flex items-center gap-2">
                                        <a href="/admin/cms/contact/{{ msg.id }}" class="ui-button ui-button--ghost ui-button--sm">{{ t('admin_cms_contact_open', locale) }}</a>
                                        <form method="post" action="/admin/cms/contact/{{ msg.id }}/delete" class="inline" onsubmit="return confirm('{{ t('admin_cms_contact_delete_confirm', locale) }}')">
                                            <button type="submit" class="ui-button ui-button--danger ui-button--sm">{{ t('admin_cms_contact_delete', locale) }}</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="6" class="cust-table__empty">{{ t('admin_cms_contact_empty', locale) }}</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    {% if total_pages > 1 %}
    <div class="flex items-center justify-between text-sm text-slate-500">
        <span>{{ t('admin_cms_contact_total', locale)|replace({'%count%': total}) }}</span>
        <div class="flex gap-2">
            {% if page > 1 %}
                <a href="?page={{ page - 1 }}" class="ui-button ui-button--ghost ui-button--sm">← Zurück</a>
            {% endif %}
            <span class="px-3 py-1">Seite {{ page }} / {{ total_pages }}</span>
            {% if page < total_pages %}
                <a href="?page={{ page + 1 }}" class="ui-button ui-button--ghost ui-button--sm">Weiter →</a>
            {% endif %}
        </div>
    </div>
    {% endif %}

</div>
{% endblock %}
