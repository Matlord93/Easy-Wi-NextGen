{% extends 'admin/base.html.twig' %}
{% block content %}
{% set locale = page_locale() %}
<div class="max-w-3xl space-y-6">

    <div class="flex items-center gap-3">
        <a href="/admin/cms/contact" class="text-sm text-slate-500 hover:text-slate-700">{{ t('admin_cms_contact_back', locale) }}</a>
    </div>

    {% if replied %}
        <div class="ng-alert ng-alert--success">
            {{ t('admin_cms_contact_reply_saved', locale) }}
        </div>
    {% endif %}

    <div class="ng-data-card">
        <div class="ng-data-card__header">
            <div>
                <h1 class="ng-data-card__title">{{ message.subject }}</h1>
                <p class="ng-data-card__sub">
                    {{ t('admin_cms_contact_from', locale) }} <strong>{{ message.name }}</strong>
                    &lt;<a href="mailto:{{ message.email }}" class="text-indigo-600">{{ message.email }}</a>&gt;
                    · {{ message.createdAt|date('d.m.Y H:i') }}{% set timeSuffix = t('admin_cms_contact_time_suffix', locale) %}{% if timeSuffix %} {{ timeSuffix }}{% endif %}
                </p>
            </div>
            <div>
                {% if message.status == 'new' %}
                    <span class="ui-badge ui-badge--info">{{ t('admin_cms_contact_status_new', locale) }}</span>
                {% elseif message.status == 'replied' %}
                    <span class="ui-badge ui-badge--success">{{ t('admin_cms_contact_status_replied', locale) }}</span>
                {% else %}
                    <span class="ui-badge ui-badge--neutral">{{ t('admin_cms_contact_status_read', locale) }}</span>
                {% endif %}
            </div>
        </div>
        <div class="ng-data-card__body">
            <p class="text-sm whitespace-pre-wrap" style="color:var(--ng-text)">{{ message.message }}</p>
        </div>
        {% if message.adminReply is not null %}
            <div class="px-6 py-4 border-t border-slate-100 bg-emerald-50/40">
                <p class="text-xs font-medium text-emerald-700 uppercase tracking-wide mb-2">{{ t('admin_cms_contact_reply_saved', locale) }} ({{ message.repliedAt|date('d.m.Y H:i') }})</p>
                <p class="text-sm whitespace-pre-wrap" style="color:var(--ng-text)">{{ message.adminReply }}</p>
            </div>
        {% endif %}
    </div>

    <div class="ng-data-card">
        <div class="ng-data-card__body">
            <h2 class="text-base font-semibold mb-4" style="color:var(--ng-text)">
                {% if message.adminReply is not null %}{{ t('admin_cms_contact_reply_update_title', locale) }}{% else %}{{ t('admin_cms_contact_reply_title', locale) }}{% endif %}
            </h2>
            <form method="post" action="/admin/cms/contact/{{ message.id }}/reply" class="space-y-4">
                <div class="form-field">
                    <label class="form-label">{{ t('admin_cms_contact_reply_text', locale) }}</label>
                    <textarea name="reply_text" rows="6" required class="form-input font-mono resize-y">{{ message.adminReply|default('') }}</textarea>
                </div>
                <p class="text-xs text-slate-400">{{ t('admin_cms_contact_reply_hint', locale) }}</p>
                <div class="flex items-center gap-3">
                    <button type="submit" class="ui-button ui-button--primary">
                        {{ t('admin_cms_contact_reply_save', locale) }}
                    </button>
                    <form method="post" action="/admin/cms/contact/{{ message.id }}/delete" onsubmit="return confirm('{{ t('admin_cms_contact_delete_confirm', locale) }}')">
                        <button type="submit" class="ui-button ui-button--danger">
                            {{ t('admin_cms_contact_delete_msg', locale) }}
                        </button>
                    </form>
                </div>
            </form>
        </div>
    </div>

</div>
{% endblock %}
