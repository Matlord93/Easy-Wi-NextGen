{% extends 'admin/base.html.twig' %}

{% set pageTitle = t('admin_cms_team_title', page_locale()) %}
{% set activeNav = 'cms-team' %}
{% set topbarActions %}
    <a href="/admin/cms/team/new" class="ui-button ui-button--primary ui-button--sm">{{ t('admin_cms_team_new', page_locale()) }}</a>
{% endset %}

{% block content %}
{% set locale = page_locale() %}
<div class="flex flex-col gap-6">

    <div class="ng-data-card">
        <div class="ng-data-card__header">
            <div>
                <h2 class="ng-data-card__title">{{ t('admin_cms_team_groups_title', locale) }}</h2>
            </div>
        </div>
        <div class="ng-data-card__body">
            <form method="post" action="/admin/cms/team/groups" class="grid grid-cols-5 gap-2 mb-4">
                <div class="form-field">
                    <input name="name" placeholder="{{ t('admin_cms_team_groups_name', locale) }}" class="form-input" required>
                </div>
                <div class="form-field">
                    <input name="game" placeholder="{{ t('admin_cms_team_groups_game', locale) }}" class="form-input" required>
                </div>
                <div class="form-field">
                    <input name="slug" placeholder="{{ t('admin_cms_team_groups_slug', locale) }}" class="form-input">
                </div>
                <div class="form-field">
                    <input name="image_path" placeholder="{{ t('admin_cms_team_groups_image', locale) }}" class="form-input">
                </div>
                <div class="flex gap-2">
                    <input type="number" name="sort_order" value="0" class="form-input w-24">
                    <button class="ui-button ui-button--primary ui-button--sm">{{ t('admin_cms_team_groups_create', locale) }}</button>
                </div>
            </form>

            <div class="flex flex-col gap-3">
                {% for group in teamGroups %}
                    <div class="rounded-lg border border-slate-200 px-3 py-3 flex flex-col gap-2">
                        <form method="post" action="/admin/cms/team/groups/{{ group.id }}" class="grid grid-cols-5 gap-2 items-center">
                            <div class="form-field">
                                <input name="name" value="{{ group.name }}" class="form-input" required>
                            </div>
                            <div class="form-field">
                                <input name="game" value="{{ group.game }}" class="form-input" required>
                            </div>
                            <div class="form-field">
                                <input name="slug" value="{{ group.slug }}" class="form-input">
                            </div>
                            <div class="form-field">
                                <input name="image_path" value="{{ group.imagePath }}" class="form-input">
                            </div>
                            <div class="flex gap-2">
                                <input type="number" name="sort_order" value="{{ group.sortOrder }}" class="form-input w-24">
                                <button class="ui-button ui-button--primary ui-button--sm">{{ t('admin_cms_team_groups_save', locale) }}</button>
                            </div>
                        </form>
                        <form method="post" action="/admin/cms/team/groups/{{ group.id }}/delete">
                            <button class="ui-button ui-button--danger ui-button--sm">{{ t('admin_cms_blog_delete', locale) }}</button>
                        </form>
                    </div>
                {% else %}
                    <div class="cust-empty">{{ t('admin_cms_team_groups_empty', locale) }}</div>
                {% endfor %}
            </div>
        </div>
    </div>

    <div class="ng-data-card">
        <div class="ng-data-card__header">
            <div>
                <h2 class="ng-data-card__title">{{ t('admin_cms_team_title', locale) }}</h2>
            </div>
        </div>
        <div class="ng-data-card__body--flush">
            <div class="cust-ws-table-wrap">
                <table class="cust-table">
                    <thead>
                        <tr>
                            <th>{{ t('admin_cms_team_table_team', locale) }}</th>
                            <th>{{ t('admin_cms_team_table_name', locale) }}</th>
                            <th>{{ t('admin_cms_team_table_role', locale) }}</th>
                            <th>{{ t('admin_cms_team_table_order', locale) }}</th>
                            <th>{{ t('admin_cms_team_table_actions', locale) }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for member in members %}
                            <tr>
                                <td>{{ member.teamName ?: t('admin_cms_team_table_general', locale) }}</td>
                                <td>{{ member.name }}</td>
                                <td>{{ member.roleTitle }}</td>
                                <td>{{ member.sortOrder }}</td>
                                <td>
                                    <a class="ui-button ui-button--ghost ui-button--sm" href="/admin/cms/team/{{ member.id }}/edit">{{ t('admin_cms_team_table_edit', locale) }}</a>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="5" class="cust-table__empty">{{ t('admin_cms_team_table_empty', locale) }}</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>
{% endblock %}
