{% extends 'admin/base.html.twig' %}
{% set member = form.member %}
{% block content %}
<form method="post" action="{{ form.action_url }}" class="mx-auto max-w-3xl space-y-3 rounded-2xl border bg-white p-6">
    <h1 class="text-xl font-semibold">{{ member ? 'Edit Team Member' : 'New Team Member' }}</h1>
    <input name="name" value="{{ member ? member.name : '' }}" placeholder="Name" class="w-full rounded border px-3 py-2" />
    <input name="role_title" value="{{ member ? member.roleTitle : '' }}" placeholder="Role title" class="w-full rounded border px-3 py-2" />
    <textarea name="bio" rows="5" placeholder="Bio" class="w-full rounded border px-3 py-2">{{ member ? member.bio : '' }}</textarea>
    <input name="avatar_path" value="{{ member ? member.avatarPath : '' }}" placeholder="Avatar path" class="w-full rounded border px-3 py-2" />
    <textarea name="socials_json" rows="3" placeholder='{"x":"https://x.com/..."}' class="w-full rounded border px-3 py-2">{{ member and member.socialsJson ? member.socialsJson|json_encode : '' }}</textarea>
    <input type="number" name="sort_order" value="{{ member ? member.sortOrder : 0 }}" class="w-full rounded border px-3 py-2" />
    <label><input type="checkbox" name="is_active" value="1" {% if member is null or member.isActive %}checked{% endif %}/> Active</label>
    <div><button class="rounded bg-indigo-600 px-4 py-2 text-white">Save</button></div>
</form>
{% endblock %}
