{% extends 'admin/base.html.twig' %}

{% set pageTitle = t('admin_marketplace_title', page_locale()) %}
{% set pageSubtitle = t('admin_marketplace_intro', page_locale()) %}
{% set activeNav = 'marketplace' %}

{% block content %}
<div class="flex flex-col gap-6">
    <div class="ng-layout-2col--equal">
        <div class="ng-data-card">
            <div class="ng-data-card__header">
                <div>
                    <h2 class="ng-data-card__title">{{ t('admin_marketplace_storefront_title', page_locale()) }}</h2>
                    <p class="ng-data-card__sub">{{ t('admin_marketplace_storefront_intro', page_locale()) }}</p>
                </div>
                <div class="ng-data-card__actions">
                    <span class="ui-badge ui-badge--info">{{ t('admin_marketplace_coming_soon', page_locale()) }}</span>
                </div>
            </div>
            <div class="ng-data-card__body">
                <ul style="display: flex; flex-direction: column; gap: 0.5rem; font-size: 0.875rem;">
                    <li style="display: flex; align-items: center; gap: 0.5rem;">
                        <span style="height: 0.5rem; width: 0.5rem; border-radius: 9999px; background: var(--color-primary); display: inline-block;"></span>
                        {{ t('admin_marketplace_storefront_feature_partners', page_locale()) }}
                    </li>
                    <li style="display: flex; align-items: center; gap: 0.5rem;">
                        <span style="height: 0.5rem; width: 0.5rem; border-radius: 9999px; background: var(--color-primary); display: inline-block;"></span>
                        {{ t('admin_marketplace_storefront_feature_updates', page_locale()) }}
                    </li>
                    <li style="display: flex; align-items: center; gap: 0.5rem;">
                        <span style="height: 0.5rem; width: 0.5rem; border-radius: 9999px; background: var(--color-primary); display: inline-block;"></span>
                        {{ t('admin_marketplace_storefront_feature_roles', page_locale()) }}
                    </li>
                </ul>
            </div>
        </div>

        <div class="ng-data-card">
            <div class="ng-data-card__header">
                <div>
                    <h2 class="ng-data-card__title">{{ t('admin_marketplace_dev_portal_title', page_locale()) }}</h2>
                    <p class="ng-data-card__sub">{{ t('admin_marketplace_dev_portal_intro', page_locale()) }}</p>
                </div>
            </div>
            <div class="ng-data-card__body">
                <div class="cust-empty">{{ t('admin_marketplace_tooling_note', page_locale()) }}</div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
