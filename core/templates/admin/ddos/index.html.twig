{% extends 'admin/base.html.twig' %}

{% set pageTitle = t('admin_ddos_title', page_locale()) %}
{% set pageSubtitle = t('admin_ddos_intro', page_locale()) %}
{% set activeNav = 'ddos' %}

{% block content %}
<div class="flex flex-col gap-6">

    {% if errors is not empty %}
        <div class="ng-alert ng-alert--danger">
            <ul class="list-disc space-y-1 pl-4">
                {% for error in errors %}
                    <li>{{ error }}</li>
                {% endfor %}
            </ul>
        </div>
    {% endif %}

    {% if ddosApplied %}
        <div class="ng-alert ng-alert--success">
            {{ t('admin_ddos_jobs_queued', page_locale()) }}
        </div>
    {% endif %}

    {# Current node status #}
    <div class="ng-data-card">
        <div class="ng-data-card__header">
            <div>
                <h2 class="ng-data-card__title">{{ t('admin_ddos_current_status_title', page_locale()) }}</h2>
                <p class="ng-data-card__sub">{{ t('admin_ddos_current_status_intro', page_locale()) }}</p>
            </div>
        </div>
        <div class="ng-data-card__body">
            {% if statusPanels is empty %}
                <div class="cust-empty">{{ t('admin_ddos_no_nodes_available', page_locale()) }}</div>
            {% else %}
                <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
                    {% for panel in statusPanels %}
                        <div class="rounded-lg border border-slate-200 p-4">
                            <div class="flex items-start justify-between gap-3">
                                <div>
                                    <p class="text-sm font-semibold text-slate-900">{{ panel.name }}</p>
                                    <p class="text-xs text-slate-600">{{ t('admin_ddos_node_label', page_locale())|replace({'%id%': panel.id}) }}</p>
                                </div>
                                {% if panel.attackActive %}
                                    <span class="ui-badge ui-badge--danger">{{ t('admin_nodes_ddos_attack_active', page_locale()) }}</span>
                                {% else %}
                                    <span class="ui-badge ui-badge--success">{{ t('admin_nodes_ddos_idle', page_locale()) }}</span>
                                {% endif %}
                            </div>

                            {# Port telemetry #}
                            <div class="mt-3">
                                <p class="text-xs font-semibold uppercase" style="color:var(--ng-text-muted);">Port-Telemetrie</p>
                                <div class="mt-2 flex flex-col gap-1">
                                    {% if panel.portStats is empty %}
                                        <span class="ui-badge ui-badge--neutral">Keine Port-Details gemeldet</span>
                                    {% else %}
                                        {% for stat in panel.portStats %}
                                            <div class="flex items-center justify-between rounded-lg border px-3 py-2 text-xs" style="border-color:{{ stat.attack_active ? 'rgba(239,68,68,.4)' : 'var(--ng-border)' }};background:{{ stat.attack_active ? 'rgba(239,68,68,.08)' : 'var(--ng-surface-soft)' }};color:{{ stat.attack_active ? '#fca5a5' : 'var(--ng-text)' }};">
                                                <span>Port {{ stat.port }}</span>
                                                <span>{{ stat.syn_recv }} SYN-RECV{{ stat.attack_active ? ' · Angriff aktiv' : '' }}</span>
                                            </div>
                                        {% endfor %}
                                    {% endif %}
                                </div>
                            </div>

                            {# Protocols #}
                            <div class="mt-3">
                                <p class="text-xs font-semibold uppercase" style="color:var(--ng-text-muted);">{{ t('admin_ddos_protocols', page_locale()) }}</p>
                                <div class="mt-2 flex flex-wrap gap-2">
                                    {% if panel.protocols is empty %}
                                        <span class="ui-badge ui-badge--neutral">{{ t('admin_ddos_no_protocols_reported', page_locale()) }}</span>
                                    {% else %}
                                        {% for protocol in panel.protocols %}
                                            <span class="ui-badge ui-badge--info">{{ protocol|upper }}</span>
                                        {% endfor %}
                                    {% endif %}
                                </div>
                            </div>

                            {# Policy #}
                            <div class="mt-3" style="border-top:1px solid var(--ng-border);padding-top:12px;">
                                <div class="flex items-center justify-between text-xs">
                                    <span class="font-semibold uppercase" style="color:var(--ng-text-muted);">{{ t('admin_ddos_policy', page_locale()) }}</span>
                                    <span style="color:var(--ng-text);">
                                        {% if panel.policyEnabled is same as(false) %}
                                            {{ t('admin_ddos_policy_disabled', page_locale()) }}
                                        {% else %}
                                            {{ panel.policyMode ?? '—' }}
                                        {% endif %}
                                    </span>
                                </div>
                                <div class="mt-2 flex flex-col gap-1 text-xs" style="color:var(--ng-text-muted);">

                                <div class="flex items-center justify-between">
                                    <span>{{ t('admin_ddos_packets_per_second', page_locale()) }}</span>
                                    <span class="font-medium">{{ panel.pps ?? '—' }}</span>
                                </div>
                                <div class="flex items-center justify-between">
                                    <span>{{ t('admin_ddos_connections', page_locale()) }}</span>
                                    <span class="font-medium">{{ panel.connCount ?? '—' }}</span>
                                </div>
                                <div class="flex items-center justify-between">
                                    <span>{{ t('admin_ddos_mode', page_locale()) }}</span>
                                    <span class="font-medium">{{ panel.mode ?? '—' }}</span>
                                </div>
                                <div class="flex items-center justify-between">
                                    <span>{{ t('admin_ddos_reported', page_locale()) }}</span>
                                    <span class="font-medium">{{ panel.reportedAt ? panel.reportedAt|date('Y-m-d H:i') : '—' }}</span>
                                </div>
                            </div>
                            <div class="mt-4">
                                <p class="text-xs font-semibold uppercase text-slate-600">{{ t('admin_ddos_protected_ports', page_locale()) }}</p>
                                <div class="mt-2 flex flex-wrap gap-2">
                                    {% if panel.ports is empty %}
                                        <span class="ui-badge ui-badge--neutral">{{ t('admin_ddos_no_ports_reported', page_locale()) }}</span>
                                    {% else %}
                                        {% for port in panel.ports %}
                                            <span class="ui-badge ui-badge--info">{{ port }}</span>
                                        {% endfor %}
                                    {% endif %}
                                </div>
                            </div>
                            <div class="mt-3">
                                <p class="text-xs font-semibold uppercase text-slate-600">{{ t('admin_ddos_protocols', page_locale()) }}</p>
                                <div class="mt-2 flex flex-wrap gap-2">
                                    {% if panel.protocols is empty %}
                                        <span class="ui-badge ui-badge--neutral">{{ t('admin_ddos_no_protocols_reported', page_locale()) }}</span>
                                    {% else %}
                                        {% for protocol in panel.protocols %}
                                            <span class="ui-badge ui-badge--info">{{ protocol|upper }}</span>
                                        {% endfor %}
                                    {% endif %}
                                </div>
                            </div>
                            <div class="mt-4 border-t border-slate-100 pt-4">
                                <div class="flex items-center justify-between text-xs">
                                    <span class="font-semibold uppercase text-slate-600">{{ t('admin_ddos_policy', page_locale()) }}</span>
                                    <span class="font-medium text-slate-700">
                                        {% if panel.policyEnabled is same as(false) %}
                                            {{ t('admin_ddos_policy_disabled', page_locale()) }}
                                        {% else %}
                                            {{ panel.policyMode ?? '—' }}
                                        {% endif %}
                                    </span>
                                </div>
                                <div class="mt-2 space-y-2 text-xs text-slate-700">
                                    <div class="flex items-center justify-between">
                                        <span>{{ t('admin_ddos_applied', page_locale()) }}</span>
                                        <span class="font-medium">{{ panel.policyAppliedAt ? panel.policyAppliedAt|date('Y-m-d H:i') : '—' }}</span>
                                    </div>
                                    <div class="flex items-center justify-between">
                                        <span>{{ t('admin_ddos_last_update', page_locale()) }}</span>
                                        <span class="font-medium">{{ panel.policyUpdatedAt ? panel.policyUpdatedAt|date('Y-m-d H:i') : '—' }}</span>
                                    </div>
                                </div>
                                <div class="mt-3">
                                    <p class="text-xs font-semibold uppercase text-slate-600">{{ t('admin_ddos_policy_ports', page_locale()) }}</p>
                                    <div class="mt-2 flex flex-wrap gap-2">
                                        {% if panel.policyPorts is empty %}
                                            <span class="ui-badge ui-badge--neutral">{{ t('admin_ddos_no_policy_ports', page_locale()) }}</span>
                                        {% else %}
                                            {% for port in panel.policyPorts %}
                                                <span class="ui-badge ui-badge--info">{{ port }}</span>
                                            {% endfor %}
                                        {% endif %}
                                    </div>
                                </div>
                                <div class="mt-3">
                                    <p class="text-xs font-semibold uppercase text-slate-600">{{ t('admin_ddos_policy_protocols', page_locale()) }}</p>
                                    <div class="mt-2 flex flex-wrap gap-2">
                                        {% if panel.policyProtocols is empty %}
                                            <span class="ui-badge ui-badge--neutral">{{ t('admin_ddos_no_policy_protocols', page_locale()) }}</span>
                                        {% else %}
                                            {% for protocol in panel.policyProtocols %}
                                                <span class="ui-badge ui-badge--info">{{ protocol|upper }}</span>
                                            {% endfor %}
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}
        </div>
    </div>

    {# Apply policy form #}
    <div class="ng-data-card">
        <div class="ng-data-card__header">
            <div>
                <h2 class="ng-data-card__title">{{ t('admin_ddos_apply_policy_title', page_locale()) }}</h2>
                <p class="ng-data-card__sub">{{ t('admin_ddos_apply_policy_intro', page_locale()) }}</p>
            </div>
        </div>
        <div class="ng-data-card__body">
            <form method="post" action="/admin/ddos/apply" class="flex flex-col gap-6">
                <div>
                    <p class="text-xs font-semibold uppercase text-slate-700">{{ t('admin_ddos_target_nodes', page_locale()) }}</p>
                    <div class="mt-3 grid gap-3 md:grid-cols-2 xl:grid-cols-3">
                        {% for node in nodes %}
                            <label class="flex items-center gap-2 rounded-lg border border-slate-200 px-3 py-2 text-sm text-slate-700 cursor-pointer">
                                <input
                                    type="checkbox"
                                    name="nodes[]"
                                    value="{{ node.id }}"
                                    class="rounded border-slate-300 text-indigo-600 focus:ring-indigo-500"
                                    {{ node.id in formData.nodes ? 'checked' : '' }}
                                >
                                <span>{{ node.name ?? t('admin_ddos_unnamed_node', page_locale()) }} <span class="text-xs text-slate-500">#{{ node.id }}</span></span>
                            </label>
                        {% else %}
                            <p class="text-sm text-slate-700">{{ t('admin_ddos_no_nodes_available', page_locale()) }}</p>
                        {% endfor %}
                    </div>
                </div>

                <div class="grid gap-6 lg:grid-cols-2">
                    <div class="flex flex-col gap-3">
                        <div class="form-field">
                            <label class="form-label">{{ t('admin_ddos_protected_ports', page_locale()) }}</label>
                            <select
                                name="ports[]"
                                multiple
                                size="7"
                                class="form-input"
                            >
                                {% for port in portOptions %}
                                    <option value="{{ port }}" {{ port in formData.ports ? 'selected' : '' }}>{{ port }}</option>
                                {% endfor %}
                            </select>
                            <p class="mt-1 text-xs text-slate-500">{{ t('admin_ddos_ports_hint', page_locale()) }}</p>
                        </div>
                        <div class="form-field">
                            <label class="form-label">{{ t('admin_ddos_custom_ports_label', page_locale()) }}</label>
                            <input
                                name="custom_ports"
                                value="{{ formData.custom_ports }}"
                                placeholder="{{ t('admin_ddos_custom_ports_placeholder', page_locale()) }}"
                                class="form-input"
                            >
                        </div>
                    </div>

                    <div class="flex flex-col gap-5">
                        <div>
                            <p class="text-xs font-semibold uppercase text-slate-700">{{ t('admin_ddos_protocols', page_locale()) }}</p>
                            <div class="mt-3 flex flex-wrap gap-3">
                                {% for protocol in protocolOptions %}
                                    <label class="flex items-center gap-2 rounded-lg border border-slate-200 px-3 py-2 text-sm text-slate-700 cursor-pointer">
                                        <input
                                            type="checkbox"
                                            name="protocols[]"
                                            value="{{ protocol }}"
                                            class="rounded border-slate-300 text-indigo-600 focus:ring-indigo-500"
                                            {{ protocol in formData.protocols ? 'checked' : '' }}
                                        >
                                        <span>{{ protocol|upper }}</span>
                                    </label>
                                {% endfor %}
                            </div>
                        </div>
                        <div class="form-field">
                            <label class="form-label">{{ t('admin_ddos_mode', page_locale()) }}</label>
                            <select name="mode" class="form-input">
                                {% for mode in modeOptions %}
                                    <option value="{{ mode }}" {{ mode == formData.mode ? 'selected' : '' }}>{{ mode|title }}</option>
                                {% endfor %}
                            </select>
                        </div>
                    </div>
                </div>

                <div>
                    <button type="submit" class="ui-button ui-button--primary">{{ t('admin_ddos_apply_policy', page_locale()) }}</button>
                </div>
            </form>
        </div>
    </div>

</div>
{% endblock %}
