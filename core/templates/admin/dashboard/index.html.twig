{% extends 'admin/base.html.twig' %}

{% set pageTitle = t('admin_dashboard_title', page_locale()) %}
{% set pageSubtitle = t('admin_dashboard_subtitle', page_locale()) %}
{% set topbarActions = [
    { label: t('admin_dashboard_action_job', page_locale()),      href: '/admin/jobs/new', variant: 'primary' },
    { label: t('admin_dashboard_action_operator', page_locale()), href: '/admin/users',    variant: 'ghost' },
    { label: t('admin_dashboard_action_security', page_locale()), href: '/admin/security', variant: 'ghost' }
] %}

{% block content %}
{% set locale = page_locale() %}
{% set primaryNode = nodes|first %}
{% set cpuValue = primaryNode and primaryNode.cpu ? primaryNode.cpu : '—' %}
{% set ramValue = primaryNode and primaryNode.memory ? primaryNode.memory : '—' %}
{% set ticketsTotal = overview.tickets_total|default(overview.tickets_open) %}
{% set ticketsInProgress = ticketsTotal > overview.tickets_open ? (ticketsTotal - overview.tickets_open) : 0 %}

{% set kpiItems = [
    {
        label: t('admin_dashboard_kpi_online', page_locale()),
        value: agentSummary.online,
        icon: '<svg viewBox="0 0 20 20" fill="currentColor"><path d="M10 2a8 8 0 1 0 0 16A8 8 0 0 0 10 2zm3.53 5.47a.75.75 0 0 1 0 1.06l-4 4a.75.75 0 0 1-1.06 0l-2-2a.75.75 0 0 1 1.06-1.06l1.47 1.47 3.47-3.47a.75.75 0 0 1 1.06 0z"/></svg>',
        tone: 'success'
    },
    {
        label: t('admin_dashboard_kpi_warnings', page_locale()),
        value: agentSummary.degraded,
        icon: '<svg viewBox="0 0 20 20" fill="currentColor"><path d="M8.257 3.099c.765-1.36 2.72-1.36 3.485 0l5.604 9.966c.75 1.334-.213 2.985-1.742 2.985H4.395c-1.53 0-2.492-1.651-1.742-2.985L8.257 3.1Zm1.743 9.651a.75.75 0 0 0 .75-.75v-3.5a.75.75 0 0 0-1.5 0v3.5c0 .414.336.75.75.75Zm0 2.5a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Z"/></svg>',
        tone: 'warning'
    },
    {
        label: t('admin_dashboard_kpi_critical', page_locale()),
        value: agentSummary.offline,
        icon: '<svg viewBox="0 0 20 20" fill="currentColor"><path d="M10 2a8 8 0 1 0 0 16A8 8 0 0 0 10 2zm0 4.5a.75.75 0 0 1 .75.75v3.5a.75.75 0 0 1-1.5 0v-3.5A.75.75 0 0 1 10 6.5Zm0 8a.75.75 0 1 1 0-1.5.75.75 0 0 1 0 1.5Z"/></svg>',
        tone: 'danger'
    },
    {
        label: t('admin_dashboard_kpi_maintenance', page_locale()),
        value: jobSummary.queued,
        icon: '<svg viewBox="0 0 20 20" fill="currentColor"><path d="M4.75 3A1.75 1.75 0 0 0 3 4.75v10.5C3 16.216 3.784 17 4.75 17h10.5A1.75 1.75 0 0 0 17 15.25V4.75A1.75 1.75 0 0 0 15.25 3H4.75Zm3 3.25a.75.75 0 0 1 .75-.75h3a.75.75 0 0 1 0 1.5h-3a.75.75 0 0 1-.75-.75Zm0 4a.75.75 0 0 1 .75-.75h5a.75.75 0 0 1 0 1.5h-5a.75.75 0 0 1-.75-.75Zm0 4a.75.75 0 0 1 .75-.75h2a.75.75 0 0 1 0 1.5h-2a.75.75 0 0 1-.75-.75Z"/></svg>',
        tone: 'info'
    },
    {
        label: t('admin_dashboard_kpi_customers', page_locale()),
        value: overview.customers,
        icon: '<svg viewBox="0 0 20 20" fill="currentColor"><path d="M10 10a3 3 0 1 0-3-3 3 3 0 0 0 3 3Zm-6 7a6 6 0 0 1 12 0v.25a.75.75 0 0 1-.75.75h-10.5A.75.75 0 0 1 4 17.25Z"/></svg>',
        tone: 'primary'
    }
] %}

{# ─── Hero ─── #}
<section class="ng-card" style="overflow:hidden;">
    <div class="tkt-hero" style="background:linear-gradient(135deg,#07101f 0%,#0d1f38 50%,#0a1220 100%);">
        <div class="tkt-hero__inner">
            <div style="display:flex;flex-direction:column;gap:16px;">
                <div>
                    <div class="tkt-hero__pill">
                        <span class="tkt-hero__pill-dot" style="background:#4ade80;"></span>
                        {{ t('admin_dashboard_workbench_label', locale) }}
                    </div>
                    <h1 class="tkt-hero__title" style="margin-top:10px;">{{ t('admin_dashboard_title', locale) }}</h1>
                    <p class="tkt-hero__sub">{{ t('admin_dashboard_subtitle', locale) }}</p>
                </div>
                <div style="display:grid;grid-template-columns:repeat(5,minmax(0,1fr));gap:10px;">
                    <div class="tkt-kpi tkt-kpi--resolved">
                        <div class="tkt-kpi__label">{{ t('admin_dashboard_kpi_online', locale) }}</div>
                        <div class="tkt-kpi__value">{{ agentSummary.online }}</div>
                    </div>
                    <div class="tkt-kpi tkt-kpi--open">
                        <div class="tkt-kpi__label">{{ t('admin_dashboard_kpi_warnings', locale) }}</div>
                        <div class="tkt-kpi__value">{{ agentSummary.degraded }}</div>
                    </div>
                    <div class="tkt-kpi" style="border-color:rgba(239,68,68,.25);background:rgba(239,68,68,.07);color:#fca5a5;">
                        <div class="tkt-kpi__label">{{ t('admin_dashboard_kpi_critical', locale) }}</div>
                        <div class="tkt-kpi__value">{{ agentSummary.offline }}</div>
                    </div>
                    <div class="tkt-kpi" style="border-color:rgba(96,165,250,.25);background:rgba(96,165,250,.08);color:#93c5fd;">
                        <div class="tkt-kpi__label">{{ t('admin_dashboard_kpi_customers', locale) }}</div>
                        <div class="tkt-kpi__value">{{ overview.customers }}</div>
                    </div>
                    <div class="tkt-kpi tkt-kpi--pending">
                        <div class="tkt-kpi__label">{{ t('admin_dashboard_kpi_maintenance', locale) }}</div>
                        <div class="tkt-kpi__value">{{ jobSummary.queued }}</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div style="display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:8px;padding:16px;border-top:1px solid var(--ng-border);background:var(--ng-surface-soft);">
        <a href="/admin/jobs/new" class="tkt-qa">
            <span class="tkt-qa__icon">
                <svg viewBox="0 0 20 20" fill="currentColor" width="16" height="16"><path d="M10.75 4.75a.75.75 0 0 0-1.5 0v4.5h-4.5a.75.75 0 0 0 0 1.5h4.5v4.5a.75.75 0 0 0 1.5 0v-4.5h4.5a.75.75 0 0 0 0-1.5h-4.5v-4.5z"/></svg>
            </span>
            <span class="tkt-qa__title">{{ t('admin_dashboard_action_job', locale) }}</span>
        </a>
        <a href="/admin/users" class="tkt-qa">
            <span class="tkt-qa__icon">
                <svg viewBox="0 0 20 20" fill="currentColor" width="16" height="16"><path d="M10 10a3 3 0 1 0-3-3 3 3 0 0 0 3 3Zm-6 7a6 6 0 0 1 12 0v.25a.75.75 0 0 1-.75.75h-10.5A.75.75 0 0 1 4 17.25Z"/></svg>
            </span>
            <span class="tkt-qa__title">{{ t('admin_dashboard_action_operator', locale) }}</span>
        </a>
        <a href="/admin/security" class="tkt-qa">
            <span class="tkt-qa__icon">
                <svg viewBox="0 0 20 20" fill="currentColor" width="16" height="16"><path fill-rule="evenodd" d="M9.661 2.237a.531.531 0 0 1 .678 0 11.947 11.947 0 0 0 7.078 2.749.5.5 0 0 1 .479.425c.069.52.104 1.05.104 1.589 0 5.162-3.26 9.563-7.834 11.256a.48.48 0 0 1-.332 0C5.26 16.563 2 12.162 2 7c0-.538.035-1.069.104-1.589a.5.5 0 0 1 .48-.425 11.947 11.947 0 0 0 7.077-2.749z" clip-rule="evenodd"/></svg>
            </span>
            <span class="tkt-qa__title">{{ t('admin_dashboard_action_security', locale) }}</span>
        </a>
    </div>
</section>

<div style="display:flex;flex-direction:column;gap:20px;margin-top:20px;">

{# ─── KPI Row ─── #}
<div class="grid grid-cols-1 gap-3 md:grid-cols-2 xl:grid-cols-5">
    {% for item in kpiItems %}
        {% include 'components/ui/_kpi_card.html.twig' with item %}
    {% endfor %}
</div>

{# ─── Metrics Row ─── #}
<div class="grid grid-cols-1 gap-4 xl:grid-cols-3">
    {% embed 'components/ui/_card.html.twig' with {
        title: t('admin_dashboard_cpu_title', page_locale()),
        subtitle: t('admin_dashboard_cpu_subtitle', page_locale())
    } %}
        {% block content %}
            <div class="flex items-center justify-between">
                <div class="text-3xl font-semibold" style="color: var(--ng-success);">{{ cpuValue }}</div>
                <div class="text-xs" style="color: var(--ng-text-muted);">{{ t('admin_dashboard_cpu_trend', page_locale()) }}</div>
            </div>
            <div class="mt-4">
                {% include 'components/ui/_sparkline.html.twig' with {
                    data: cpuSeries,
                    tone: 'success',
                    empty: t('admin_metrics_no_data', page_locale())
                } %}
            </div>
        {% endblock %}
    {% endembed %}

    {% embed 'components/ui/_card.html.twig' with {
        title: t('admin_dashboard_ram_title', page_locale()),
        subtitle: t('admin_dashboard_ram_subtitle', page_locale())
    } %}
        {% block content %}
            <div class="flex items-center justify-between">
                <div class="text-3xl font-semibold" style="color: var(--ng-danger);">{{ ramValue }}</div>
                <div class="text-xs" style="color: var(--ng-text-muted);">{{ t('admin_dashboard_ram_trend', page_locale()) }}</div>
            </div>
            <div class="mt-4">
                {% include 'components/ui/_sparkline.html.twig' with {
                    data: memorySeries,
                    tone: 'danger',
                    empty: t('admin_metrics_no_data', page_locale())
                } %}
            </div>
        {% endblock %}
    {% endembed %}

    {% embed 'components/ui/_card.html.twig' with {
        title: t('admin_dashboard_bandwidth_title', page_locale()),
        subtitle: t('admin_dashboard_bandwidth_subtitle', page_locale())
    } %}
        {% block content %}
            <div class="flex items-center justify-between">
                <div class="text-3xl font-semibold" style="color: var(--ng-info);">{{ bandwidthValue ?? '—' }}</div>
                <div class="text-xs" style="color: var(--ng-text-muted);">{{ t('admin_dashboard_bandwidth_trend', page_locale()) }}</div>
            </div>
            <div class="mt-4">
                {% include 'components/ui/_sparkline.html.twig' with {
                    data: bandwidthSeries,
                    tone: 'info',
                    empty: t('admin_metrics_no_data', page_locale())
                } %}
            </div>
        {% endblock %}
    {% endembed %}
</div>

{# ─── Module Summary ─── #}
<div class="grid grid-cols-1 gap-3 md:grid-cols-2 xl:grid-cols-5">
    {% set moduleCards = [
        { label: t('admin_dashboard_module_webspaces', page_locale()),  value: moduleSummary.webspaces,    icon: '<svg viewBox="0 0 20 20" fill="currentColor" width="22" height="22"><path d="M10 12a2 2 0 1 0 0-4 2 2 0 0 0 0 4z"/><path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 1 1-8 0 4 4 0 0 1 8 0z" clip-rule="evenodd"/></svg>', tone: 'primary' },
        { label: t('admin_dashboard_module_databases', page_locale()),  value: moduleSummary.databases,    icon: '<svg viewBox="0 0 20 20" fill="currentColor" width="22" height="22"><path d="M3 12v3c0 1.657 3.134 3 7 3s7-1.343 7-3v-3c0 1.657-3.134 3-7 3s-7-1.343-7-3z"/><path d="M3 7v3c0 1.657 3.134 3 7 3s7-1.343 7-3V7c0 1.657-3.134 3-7 3S3 8.657 3 7z"/><path d="M17 5c0 1.657-3.134 3-7 3S3 6.657 3 5s3.134-3 7-3 7 1.343 7 3z"/></svg>', tone: 'info' },
        { label: t('admin_dashboard_module_games', page_locale()),      value: moduleSummary.games,        icon: '<svg viewBox="0 0 20 20" fill="currentColor" width="22" height="22"><path fill-rule="evenodd" d="M3 6a3 3 0 0 1 3-3h8a3 3 0 0 1 3 3v8a3 3 0 0 1-3 3H6a3 3 0 0 1-3-3V6zm4.5 3a.75.75 0 0 1 .75-.75h.75V7.5a.75.75 0 0 1 1.5 0v.75h.75a.75.75 0 0 1 0 1.5h-.75v.75a.75.75 0 0 1-1.5 0v-.75H7.5A.75.75 0 0 1 7.5 9zm5.25-.75a.75.75 0 0 0 0 1.5h.008a.75.75 0 0 0 0-1.5H12.75zm0 3a.75.75 0 0 0 0 1.5h.008a.75.75 0 0 0 0-1.5H12.75z" clip-rule="evenodd"/></svg>', tone: 'success' },
        { label: t('admin_dashboard_module_mail', page_locale()),       value: moduleSummary.mailboxes,    icon: '<svg viewBox="0 0 20 20" fill="currentColor" width="22" height="22"><path d="M3 4a2 2 0 0 0-2 2v1.161l8.441 4.221a1.25 1.25 0 0 0 1.118 0L19 7.162V6a2 2 0 0 0-2-2H3z"/><path d="m19 8.839-7.77 3.885a2.75 2.75 0 0 1-2.46 0L1 8.839V14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V8.839z"/></svg>', tone: 'warning' },
        { label: t('admin_dashboard_module_voice', page_locale()),      value: moduleSummary.voiceServers, icon: '<svg viewBox="0 0 20 20" fill="currentColor" width="22" height="22"><path d="M7 4a3 3 0 0 1 6 0v6a3 3 0 1 1-6 0V4z"/><path d="M5.5 9.643a.75.75 0 0 0-1.5 0V10c0 3.06 2.29 5.585 5.25 5.954V17.5h-1.5a.75.75 0 0 0 0 1.5h4.5a.75.75 0 0 0 0-1.5h-1.5v-1.546A6.001 6.001 0 0 0 16 10v-.357a.75.75 0 0 0-1.5 0V10a4.5 4.5 0 0 1-9 0v-.357z"/></svg>', tone: 'danger' }
    ] %}
    {% for card in moduleCards %}
        {% embed 'components/ui/_card.html.twig' with { variant: 'soft' } %}
            {% block content %}
                <div class="flex items-center justify-between">
                    <div>
                        <div class="text-xs font-semibold uppercase tracking-wide" style="color: var(--ng-text-muted);">{{ card.label }}</div>
                        <div class="mt-2 text-2xl font-bold" style="color: var(--ng-text);">{{ card.value }}</div>
                    </div>
                    <div class="ui-kpi__icon ui-kpi__icon--{{ card.tone }}">
                        {{ card.icon|raw }}
                    </div>
                </div>
            {% endblock %}
        {% endembed %}
    {% endfor %}
</div>

{# ─── Tickets / Messages / Queue ─── #}
<div class="grid grid-cols-1 gap-4 xl:grid-cols-3">
    {% embed 'components/ui/_card.html.twig' with {
        title: t('admin_dashboard_customers_tickets_title', page_locale()),
        subtitle: t('admin_dashboard_customers_tickets_subtitle', page_locale())
    } %}
        {% block content %}
            <div class="grid grid-cols-3 gap-4">
                <div>
                    <div class="text-xs font-semibold uppercase tracking-wide" style="color: var(--ng-text-muted);">{{ t('admin_dashboard_customers_total', page_locale()) }}</div>
                    <div class="mt-2 text-2xl font-bold" style="color: var(--ng-text);">{{ overview.customers }}</div>
                </div>
                <div>
                    <div class="text-xs font-semibold uppercase tracking-wide" style="color: var(--ng-text-muted);">{{ t('admin_dashboard_tickets_open', page_locale()) }}</div>
                    <div class="mt-2 text-2xl font-bold" style="color: var(--ng-warning);">{{ overview.tickets_open }}</div>
                </div>
                <div>
                    <div class="text-xs font-semibold uppercase tracking-wide" style="color: var(--ng-text-muted);">{{ t('admin_dashboard_tickets_in_progress', page_locale()) }}</div>
                    <div class="mt-2 text-2xl font-bold" style="color: var(--ng-info);">{{ ticketsInProgress }}</div>
                </div>
            </div>
        {% endblock %}
    {% endembed %}

    {% embed 'components/ui/_card.html.twig' with {
        title: t('admin_dashboard_system_messages_title', page_locale()),
        subtitle: t('admin_dashboard_system_messages_subtitle', page_locale())
    } %}
        {% block content %}
            {% set messageItems = [] %}
            {% for job in jobs|slice(0, 3) %}
                {% set messageItems = messageItems|merge([{
                    title: t('job_type_' ~ job.type|replace({'.': '_'}), page_locale()),
                    description: t('admin_dashboard_system_message_job', page_locale())|replace({'%id%': job.id}),
                    time: job.createdAt ? job.createdAt|date('H:i') : t('admin_dashboard_time_unknown', page_locale()),
                    icon: '<svg viewBox="0 0 20 20" fill="currentColor"><path d="M4.75 3A1.75 1.75 0 0 0 3 4.75v10.5C3 16.216 3.784 17 4.75 17h10.5A1.75 1.75 0 0 0 17 15.25V4.75A1.75 1.75 0 0 0 15.25 3H4.75Zm2.5 3.25h5.5a.75.75 0 0 1 0 1.5H7.25a.75.75 0 0 1 0-1.5Zm0 4h8a.75.75 0 0 1 0 1.5h-8a.75.75 0 0 1 0-1.5Z"/></svg>'
                }]) %}
            {% endfor %}
            {% include 'components/ui/_system_messages.html.twig' with { messages: messageItems } %}
        {% endblock %}
    {% endembed %}

    {% embed 'components/ui/_card.html.twig' with {
        title: t('admin_dashboard_queue_title', page_locale()),
        subtitle: t('admin_dashboard_queue_subtitle', page_locale())
    } %}
        {% block content %}
            {% set activeQueueJobs = [] %}
            {% for job in jobs %}
                {% if job.status in ['queued', 'claimed', 'running'] %}
                    {% set activeQueueJobs = activeQueueJobs|merge([job]) %}
                {% endif %}
            {% endfor %}

            {% set queueRows = [] %}
            {% for job in activeQueueJobs|slice(0, 5) %}
                {% set badge = job.status == 'queued'
                    ? include('components/ui/_badge.html.twig', { label: t('admin_dashboard_status_queued', page_locale()), tone: 'warning' })
                    : include('components/ui/_badge.html.twig', { label: t('admin_dashboard_status_running', page_locale()), tone: 'info' })
                %}
                {% set queueRows = queueRows|merge([[
                    '#' ~ job.id,
                    t('job_type_' ~ job.type|replace({'.': '_'}), page_locale()),
                    badge
                ]]) %}
            {% endfor %}
            {% include 'components/ui/_table.html.twig' with {
                headers: [
                    t('admin_dashboard_table_job', page_locale()),
                    t('admin_dashboard_table_type', page_locale()),
                    t('admin_dashboard_table_status', page_locale())
                ],
                rows: queueRows,
                empty: t('admin_dashboard_queue_empty', page_locale())
            } %}
        {% endblock %}
    {% endembed %}
</div>

{# ─── Storage / Nodes / Jobs ─── #}
<div class="grid grid-cols-1 gap-4 xl:grid-cols-3">
    {% embed 'components/ui/_card.html.twig' with {
        title: t('admin_dashboard_storage_title', page_locale()),
        subtitle: t('admin_dashboard_storage_subtitle', page_locale())
    } %}
        {% block content %}
            {% for node in nodes %}
                {% set memoryValue   = node.memory ?? '—' %}
                {% set memoryPercent = node.memory ? node.memory|replace({'%': ''}) : null %}
                <div class="mb-4">
                    <div class="flex items-center justify-between text-xs" style="color: var(--ng-text-muted);">
                        <span>{{ node.name }}</span>
                        <span>{{ memoryValue }}</span>
                    </div>
                    {% if memoryPercent is not null %}
                        <div class="mt-2 ui-progress">
                            <div class="ui-progress__bar" style="width: {{ memoryPercent }}%;"></div>
                        </div>
                    {% else %}
                        <div class="mt-2 text-xs" style="color: var(--ng-text-muted);">{{ t('admin_metrics_no_data', page_locale()) }}</div>
                    {% endif %}
                </div>
            {% else %}
                <div class="text-sm" style="color: var(--ng-text-muted);">{{ t('admin_dashboard_storage_empty', page_locale()) }}</div>
            {% endfor %}
        {% endblock %}
    {% endembed %}

    {% embed 'components/ui/_card.html.twig' with {
        title: t('admin_dashboard_nodes_title', page_locale()),
        subtitle: t('admin_dashboard_nodes_subtitle', page_locale())
    } %}
        {% block content %}
            <div class="space-y-4">
                {% for node in nodes %}
                    <div class="flex items-center justify-between">
                        <div>
                            <div class="text-sm font-semibold" style="color: var(--ng-text);">{{ node.name }}</div>
                            <div class="text-xs" style="color: var(--ng-text-muted);">#{{ node.id }}</div>
                        </div>
                        {% set statusTone = node.status == 'online' ? 'success' : (node.status == 'degraded' ? 'warning' : 'danger') %}
                        {% include 'components/ui/_badge.html.twig' with { label: node.status|title, tone: statusTone } %}
                    </div>
                {% else %}
                    <div class="text-sm" style="color: var(--ng-text-muted);">{{ t('admin_dashboard_no_agents', page_locale()) }}</div>
                {% endfor %}
            </div>
        {% endblock %}
    {% endembed %}

    {% embed 'components/ui/_card.html.twig' with {
        title: t('admin_dashboard_jobs_title', page_locale()),
        subtitle: t('admin_dashboard_jobs_subtitle', page_locale())
    } %}
        {% block content %}
            <div class="space-y-4">
                <div class="flex items-center justify-between">
                    <span class="text-xs font-semibold uppercase tracking-wide" style="color: var(--ng-text-muted);">{{ t('admin_dashboard_jobs_total', page_locale()) }}</span>
                    <span class="text-lg font-semibold" style="color: var(--ng-text);">{{ jobSummary.total }}</span>
                </div>
                <div class="flex items-center justify-between">
                    <span class="text-xs font-semibold uppercase tracking-wide" style="color: var(--ng-text-muted);">{{ t('admin_dashboard_jobs_running', page_locale()) }}</span>
                    <span class="text-lg font-semibold" style="color: var(--ng-info);">{{ jobSummary.running }}</span>
                </div>
                <div class="flex items-center justify-between">
                    <span class="text-xs font-semibold uppercase tracking-wide" style="color: var(--ng-text-muted);">{{ t('admin_dashboard_jobs_failed', page_locale()) }}</span>
                    <span class="text-lg font-semibold" style="color: var(--ng-danger);">{{ jobSummary.failed }}</span>
                </div>
            </div>
        {% endblock %}
    {% endembed %}
</div>

<script>
    (function () {
        var refreshMs = 30000;
        var timer = null;

        function scheduleRefresh() {
            if (timer !== null) { clearTimeout(timer); }
            if (document.hidden) { return; }
            timer = setTimeout(function () { location.reload(); }, refreshMs);
        }

        document.addEventListener('visibilitychange', scheduleRefresh);
        window.addEventListener('focus', scheduleRefresh);
        scheduleRefresh();
    })();
</script>

</div>
{% endblock %}
