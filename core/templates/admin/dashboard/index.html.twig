{% extends 'admin/base.html.twig' %}

{% block content %}
{% set primaryNode = nodes|first %}
{% set cpuValue = primaryNode and primaryNode.cpu ? primaryNode.cpu : '—' %}
{% set ramValue = primaryNode and primaryNode.memory ? primaryNode.memory : '—' %}
{% set ticketsTotal = overview.tickets_total|default(overview.tickets_open) %}
{% set ticketsInProgress = ticketsTotal > overview.tickets_open ? (ticketsTotal - overview.tickets_open) : 0 %}

{% set kpiItems = [
    {
        label: t('admin_dashboard_kpi_online', page_locale()),
        value: agentSummary.online,
        icon: '<svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M10 2a8 8 0 1 0 8 8 8 8 0 0 0-8-8Zm3.53 6.47a.75.75 0 0 1 0 1.06l-4 4a.75.75 0 0 1-1.06 0l-2-2a.75.75 0 0 1 1.06-1.06l1.47 1.47 3.47-3.47a.75.75 0 0 1 1.06 0Z"/></svg>',
        tone: 'success'
    },
    {
        label: t('admin_dashboard_kpi_warnings', page_locale()),
        value: agentSummary.degraded,
        icon: '<svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M8.257 3.099c.765-1.36 2.72-1.36 3.485 0l5.604 9.966c.75 1.334-.213 2.985-1.742 2.985H4.395c-1.53 0-2.492-1.651-1.742-2.985L8.257 3.1Zm1.743 9.651a.75.75 0 0 0 .75-.75v-3.5a.75.75 0 0 0-1.5 0v3.5c0 .414.336.75.75.75Zm0 2.5a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Z"/></svg>',
        tone: 'warning'
    },
    {
        label: t('admin_dashboard_kpi_critical', page_locale()),
        value: agentSummary.offline,
        icon: '<svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M10 2a8 8 0 1 0 8 8 8 8 0 0 0-8-8Zm0 4.5a.75.75 0 0 1 .75.75v3.5a.75.75 0 0 1-1.5 0v-3.5A.75.75 0 0 1 10 6.5Zm0 8a.75.75 0 1 1 0-1.5.75.75 0 0 1 0 1.5Z"/></svg>',
        tone: 'danger'
    },
    {
        label: t('admin_dashboard_kpi_maintenance', page_locale()),
        value: jobSummary.queued,
        icon: '<svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M4.75 3A1.75 1.75 0 0 0 3 4.75v10.5C3 16.216 3.784 17 4.75 17h10.5A1.75 1.75 0 0 0 17 15.25V4.75A1.75 1.75 0 0 0 15.25 3H4.75Zm3 3.25a.75.75 0 0 1 .75-.75h3a.75.75 0 0 1 0 1.5h-3a.75.75 0 0 1-.75-.75Zm0 4a.75.75 0 0 1 .75-.75h5a.75.75 0 0 1 0 1.5h-5a.75.75 0 0 1-.75-.75Zm0 4a.75.75 0 0 1 .75-.75h2a.75.75 0 0 1 0 1.5h-2a.75.75 0 0 1-.75-.75Z"/></svg>',
        tone: 'info'
    },
    {
        label: t('admin_dashboard_kpi_customers', page_locale()),
        value: overview.customers,
        icon: '<svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M10 10a3 3 0 1 0-3-3 3 3 0 0 0 3 3Zm-6 7a6 6 0 0 1 12 0v.25a.75.75 0 0 1-.75.75h-10.5A.75.75 0 0 1 4 17.25Z"/></svg>',
        tone: 'primary'
    }
] %}

<div class="flex flex-col gap-6">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
        <div>
            <h1 class="text-2xl font-semibold text-slate-100">{{ t('admin_dashboard_title', page_locale()) }}</h1>
            <p class="text-sm text-slate-400">{{ t('admin_dashboard_subtitle', page_locale()) }}</p>
        </div>
        <div class="flex flex-wrap items-center gap-2">
            {% include 'components/ui/_button.html.twig' with {
                label: t('admin_dashboard_action_job', page_locale()),
                href: '/admin/jobs/new',
                variant: 'primary'
            } %}
            {% include 'components/ui/_button.html.twig' with {
                label: t('admin_dashboard_action_operator', page_locale()),
                href: '/admin/users',
                variant: 'ghost'
            } %}
            {% include 'components/ui/_button.html.twig' with {
                label: t('admin_dashboard_action_security', page_locale()),
                href: '/admin/security',
                variant: 'ghost'
            } %}
        </div>
    </div>

    <div class="grid grid-cols-1 gap-3 md:grid-cols-2 xl:grid-cols-5">
        {% for item in kpiItems %}
            {% include 'components/ui/_kpi_card.html.twig' with item %}
        {% endfor %}
    </div>

    <div class="grid grid-cols-1 gap-4 xl:grid-cols-3">
        {% embed 'components/ui/_card.html.twig' with {
            title: t('admin_dashboard_cpu_title', page_locale()),
            subtitle: t('admin_dashboard_cpu_subtitle', page_locale())
        } %}
            {% block content %}
                <div class="flex items-center justify-between">
                    <div class="text-3xl font-semibold text-emerald-300">{{ cpuValue }}</div>
                    <div class="text-xs text-slate-400">{{ t('admin_dashboard_cpu_trend', page_locale()) }}</div>
                </div>
                <div class="mt-4">
                    {% include 'components/ui/_sparkline.html.twig' with {
                        data: cpuSeries,
                        tone: 'success',
                        empty: t('admin_metrics_no_data', page_locale())
                    } %}
                </div>
            {% endblock %}
        {% endembed %}

        {% embed 'components/ui/_card.html.twig' with {
            title: t('admin_dashboard_ram_title', page_locale()),
            subtitle: t('admin_dashboard_ram_subtitle', page_locale())
        } %}
            {% block content %}
                <div class="flex items-center justify-between">
                    <div class="text-3xl font-semibold text-rose-300">{{ ramValue }}</div>
                    <div class="text-xs text-slate-400">{{ t('admin_dashboard_ram_trend', page_locale()) }}</div>
                </div>
                <div class="mt-4">
                    {% include 'components/ui/_sparkline.html.twig' with {
                        data: memorySeries,
                        tone: 'danger',
                        empty: t('admin_metrics_no_data', page_locale())
                    } %}
                </div>
            {% endblock %}
        {% endembed %}

        {% embed 'components/ui/_card.html.twig' with {
            title: t('admin_dashboard_bandwidth_title', page_locale()),
            subtitle: t('admin_dashboard_bandwidth_subtitle', page_locale())
        } %}
            {% block content %}
                <div class="flex items-center justify-between">
                    <div class="text-3xl font-semibold text-sky-300">{{ bandwidthValue ?? '—' }}</div>
                    <div class="text-xs text-slate-400">{{ t('admin_dashboard_bandwidth_trend', page_locale()) }}</div>
                </div>
                <div class="mt-4">
                    {% include 'components/ui/_sparkline.html.twig' with {
                        data: bandwidthSeries,
                        tone: 'info',
                        empty: t('admin_metrics_no_data', page_locale())
                    } %}
                </div>
            {% endblock %}
        {% endembed %}
    </div>

    <div class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-5">
        {% set moduleCards = [
            { label: t('admin_dashboard_module_webspaces', page_locale()), value: moduleSummary.webspaces, icon: '🗂️' },
            { label: t('admin_dashboard_module_databases', page_locale()), value: moduleSummary.databases, icon: '🗄️' },
            { label: t('admin_dashboard_module_games', page_locale()), value: moduleSummary.games, icon: '🎮' },
            { label: t('admin_dashboard_module_mail', page_locale()), value: moduleSummary.mailboxes, icon: '✉️' },
            { label: t('admin_dashboard_module_voice', page_locale()), value: moduleSummary.voiceServers, icon: '🎧' }
        ] %}
        {% for card in moduleCards %}
            {% embed 'components/ui/_card.html.twig' with { variant: 'soft' } %}
                {% block content %}
                    <div class="flex items-center justify-between">
                        <div>
                            <div class="text-xs uppercase tracking-wide text-slate-400">{{ card.label }}</div>
                            <div class="mt-2 text-2xl font-semibold text-slate-100">{{ card.value }}</div>
                        </div>
                        <div class="text-2xl">{{ card.icon }}</div>
                    </div>
                {% endblock %}
            {% endembed %}
        {% endfor %}
    </div>

    <div class="grid grid-cols-1 gap-4 xl:grid-cols-3">
        {% embed 'components/ui/_card.html.twig' with {
            title: t('admin_dashboard_customers_tickets_title', page_locale()),
            subtitle: t('admin_dashboard_customers_tickets_subtitle', page_locale())
        } %}
            {% block content %}
                <div class="grid grid-cols-3 gap-4">
                    <div>
                        <div class="text-xs uppercase tracking-wide text-slate-400">{{ t('admin_dashboard_customers_total', page_locale()) }}</div>
                        <div class="mt-2 text-2xl font-semibold text-slate-100">{{ overview.customers }}</div>
                    </div>
                    <div>
                        <div class="text-xs uppercase tracking-wide text-slate-400">{{ t('admin_dashboard_tickets_open', page_locale()) }}</div>
                        <div class="mt-2 text-2xl font-semibold text-slate-100">{{ overview.tickets_open }}</div>
                    </div>
                    <div>
                        <div class="text-xs uppercase tracking-wide text-slate-400">{{ t('admin_dashboard_tickets_in_progress', page_locale()) }}</div>
                        <div class="mt-2 text-2xl font-semibold text-slate-100">{{ ticketsInProgress }}</div>
                    </div>
                </div>
            {% endblock %}
        {% endembed %}

        {% embed 'components/ui/_card.html.twig' with {
            title: t('admin_dashboard_system_messages_title', page_locale()),
            subtitle: t('admin_dashboard_system_messages_subtitle', page_locale())
        } %}
            {% block content %}
                {% set messageItems = [] %}
                {% for job in jobs|slice(0, 3) %}
                    {% set messageItems = messageItems|merge([
                        {
                            title: t('admin_dashboard_system_message_job', page_locale())|replace({'%id%': job.id}),
                            description: job.type,
                            time: job.createdAt ? job.createdAt|date('H:i') : t('admin_dashboard_time_unknown', page_locale()),
                            icon: '<svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M4.75 3A1.75 1.75 0 0 0 3 4.75v10.5C3 16.216 3.784 17 4.75 17h10.5A1.75 1.75 0 0 0 17 15.25V4.75A1.75 1.75 0 0 0 15.25 3H4.75Zm2.5 3.25h5.5a.75.75 0 0 1 0 1.5H7.25a.75.75 0 0 1 0-1.5Zm0 4h8a.75.75 0 0 1 0 1.5h-8a.75.75 0 0 1 0-1.5Z"/></svg>'
                        }
                    ]) %}
                {% endfor %}
                {% include 'components/ui/_system_messages.html.twig' with { messages: messageItems } %}
            {% endblock %}
        {% endembed %}

        {% embed 'components/ui/_card.html.twig' with {
            title: t('admin_dashboard_queue_title', page_locale()),
            subtitle: t('admin_dashboard_queue_subtitle', page_locale())
        } %}
            {% block content %}
                {% set activeQueueJobs = [] %}
                {% for job in jobs %}
                    {% if job.status in ['queued', 'claimed', 'running'] %}
                        {% set activeQueueJobs = activeQueueJobs|merge([job]) %}
                    {% endif %}
                {% endfor %}

                {% set queueRows = [] %}
                {% for job in activeQueueJobs|slice(0, 4) %}
                    {% set badge = job.status == 'queued'
                        ? include('components/ui/_badge.html.twig', { label: t('admin_dashboard_status_queued', page_locale()), tone: 'warning' })
                        : include('components/ui/_badge.html.twig', { label: t('admin_dashboard_status_running', page_locale()), tone: 'info' })
                    %}
                    {% set queueRows = queueRows|merge([
                        [
                            '#' ~ job.id,
                            job.type,
                            badge
                        ]
                    ]) %}
                {% endfor %}
                {% include 'components/ui/_table.html.twig' with {
                    headers: [t('admin_dashboard_table_job', page_locale()), t('admin_dashboard_table_type', page_locale()), t('admin_dashboard_table_status', page_locale())],
                    rows: queueRows,
                    empty: t('admin_dashboard_queue_empty', page_locale())
                } %}
            {% endblock %}
        {% endembed %}
    </div>

    <div class="grid grid-cols-1 gap-4 xl:grid-cols-3">
        {% embed 'components/ui/_card.html.twig' with {
            title: t('admin_dashboard_storage_title', page_locale()),
            subtitle: t('admin_dashboard_storage_subtitle', page_locale())
        } %}
            {% block content %}
                {% for node in nodes %}
                    {% set memoryValue = node.memory ?? '—' %}
                    {% set memoryPercent = node.memory ? node.memory|replace({'%': ''}) : null %}
                    <div class="mb-4">
                        <div class="flex items-center justify-between text-xs text-slate-400">
                            <span>{{ node.name }}</span>
                            <span>{{ memoryValue }}</span>
                        </div>
                        {% if memoryPercent is not null %}
                            <div class="mt-2 ui-progress">
                                <div class="ui-progress__bar" style="width: {{ memoryPercent }}%;"></div>
                            </div>
                        {% else %}
                            <div class="mt-2 text-xs text-slate-500">{{ t('admin_metrics_no_data', page_locale()) }}</div>
                        {% endif %}
                    </div>
                {% else %}
                    <div class="text-sm text-slate-400">{{ t('admin_dashboard_storage_empty', page_locale()) }}</div>
                {% endfor %}
            {% endblock %}
        {% endembed %}

        {% embed 'components/ui/_card.html.twig' with {
            title: t('admin_dashboard_nodes_title', page_locale()),
            subtitle: t('admin_dashboard_nodes_subtitle', page_locale())
        } %}
            {% block content %}
                <div class="space-y-4">
                    {% for node in nodes %}
                        <div class="flex items-center justify-between">
                            <div>
                                <div class="text-sm font-semibold text-slate-100">{{ node.name }}</div>
                                <div class="text-xs text-slate-400">#{{ node.id }}</div>
                            </div>
                            {% set statusTone = node.status == 'online' ? 'success' : (node.status == 'degraded' ? 'warning' : 'danger') %}
                            {% include 'components/ui/_badge.html.twig' with { label: node.status|title, tone: statusTone } %}
                        </div>
                    {% else %}
                        <div class="text-sm text-slate-400">{{ t('admin_dashboard_no_agents', page_locale()) }}</div>
                    {% endfor %}
                </div>
            {% endblock %}
        {% endembed %}

        {% embed 'components/ui/_card.html.twig' with {
            title: t('admin_dashboard_jobs_title', page_locale()),
            subtitle: t('admin_dashboard_jobs_subtitle', page_locale())
        } %}
            {% block content %}
                <div class="space-y-4">
                    <div class="flex items-center justify-between">
                        <span class="text-xs uppercase tracking-wide text-slate-400">{{ t('admin_dashboard_jobs_total', page_locale()) }}</span>
                        <span class="text-lg font-semibold text-slate-100">{{ jobSummary.total }}</span>
                    </div>
                    <div class="flex items-center justify-between">
                        <span class="text-xs uppercase tracking-wide text-slate-400">{{ t('admin_dashboard_jobs_running', page_locale()) }}</span>
                        <span class="text-lg font-semibold text-slate-100">{{ jobSummary.running }}</span>
                    </div>
                    <div class="flex items-center justify-between">
                        <span class="text-xs uppercase tracking-wide text-slate-400">{{ t('admin_dashboard_jobs_failed', page_locale()) }}</span>
                        <span class="text-lg font-semibold text-rose-300">{{ jobSummary.failed }}</span>
                    </div>
                </div>
            {% endblock %}
        {% endembed %}
    </div>
</div>

<script>
    (() => {
        const refreshIntervalMs = 30000;
        let refreshTimer = null;

        const scheduleRefresh = () => {
            if (refreshTimer !== null) {
                window.clearTimeout(refreshTimer);
            }

            if (document.hidden) {
                return;
            }

            refreshTimer = window.setTimeout(() => {
                window.location.reload();
            }, refreshIntervalMs);
        };

        document.addEventListener('visibilitychange', scheduleRefresh);
        window.addEventListener('focus', scheduleRefresh);
        scheduleRefresh();
    })();
</script>
{% endblock %}
