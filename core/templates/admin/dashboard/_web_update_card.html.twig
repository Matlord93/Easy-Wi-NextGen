<div id="core-update-card" class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
        <div>
            <h2 class="text-lg font-semibold">{{ t('admin_dashboard_core_updates_title', page_locale()) }}</h2>
            <p class="text-sm text-slate-700">{{ t('admin_dashboard_core_updates_intro', page_locale()) }}</p>
        </div>
        <div class="flex flex-col gap-2 sm:flex-row sm:items-center">
            <form method="post" hx-post="/admin/updates/job" hx-target="#core-update-card" hx-swap="outerHTML">
                <input type="hidden" name="type" value="update">
                <input type="hidden" name="csrf_token" value="{{ coreUpdate.csrf.update }}">
                <button
                    class="btn rounded-lg bg-indigo-600 px-4 py-2 text-sm font-medium text-white shadow-sm"
                    {% if coreUpdate.latestVersion is empty or coreUpdate.updateAvailable is same as(false) %}
                        disabled
                    {% endif %}
                >
                    {{ t('admin_dashboard_core_updates_action', page_locale()) }}
                </button>
            </form>
            <form method="post" hx-post="/admin/updates/job" hx-target="#core-update-card" hx-swap="outerHTML">
                <input type="hidden" name="type" value="migrate">
                <input type="hidden" name="csrf_token" value="{{ coreUpdate.csrf.migrate }}">
                <button class="btn rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 shadow-sm">
                    {{ t('admin_dashboard_core_updates_migrate_action', page_locale()) }}
                </button>
            </form>
            <form method="post" hx-post="/admin/updates/job" hx-target="#core-update-card" hx-swap="outerHTML">
                <input type="hidden" name="type" value="both">
                <input type="hidden" name="csrf_token" value="{{ coreUpdate.csrf.both }}">
                <button class="btn rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 shadow-sm">
                    {{ t('admin_dashboard_core_updates_both_action', page_locale()) }}
                </button>
            </form>
        </div>
    </div>

    <div class="mt-4 grid grid-cols-1 gap-4 sm:grid-cols-3">
        <div class="rounded-xl border border-slate-200 bg-slate-50/40 p-4">
            <p class="text-xs font-semibold uppercase text-slate-500">{{ t('admin_dashboard_core_current_version', page_locale()) }}</p>
            <p class="mt-2 text-lg font-semibold text-slate-900">{{ coreUpdate.currentVersion ?? '—' }}</p>
        </div>
        <div class="rounded-xl border border-slate-200 bg-slate-50/40 p-4">
            <p class="text-xs font-semibold uppercase text-slate-500">{{ t('admin_dashboard_core_latest_version', page_locale()) }}</p>
            <p class="mt-2 text-lg font-semibold text-slate-900">{{ coreUpdate.latestVersion ?? '—' }}</p>
        </div>
        <div class="rounded-xl border border-slate-200 bg-slate-50/40 p-4">
            <p class="text-xs font-semibold uppercase text-slate-500">{{ t('admin_dashboard_core_update_status', page_locale()) }}</p>
            <p class="mt-2 text-lg font-semibold text-slate-900">
                {% if coreUpdate.updateAvailable is same as(true) %}
                    {{ t('admin_dashboard_core_update_available', page_locale()) }}
                {% elseif coreUpdate.updateAvailable is same as(false) %}
                    {{ t('admin_dashboard_core_update_up_to_date', page_locale()) }}
                {% else %}
                    {{ t('admin_dashboard_core_update_unknown', page_locale()) }}
                {% endif %}
            </p>
        </div>
    </div>

    <div class="mt-4 grid grid-cols-1 gap-4 sm:grid-cols-2">
        <div class="rounded-xl border border-slate-200 bg-slate-50/40 px-4 py-3 text-sm text-slate-700">
            <p class="text-xs font-semibold uppercase text-slate-500">{{ t('admin_dashboard_core_current_commit', page_locale()) }}</p>
            <p class="mt-2 font-semibold">{{ coreUpdate.currentCommit ?? '—' }}</p>
        </div>
        <div class="rounded-xl border border-slate-200 bg-slate-50/40 px-4 py-3 text-sm text-slate-700">
            <p class="text-xs font-semibold uppercase text-slate-500">{{ t('admin_dashboard_core_current_build', page_locale()) }}</p>
            <p class="mt-2 font-semibold">{{ coreUpdate.currentBuild ?? '—' }}</p>
        </div>
    </div>

    <div class="mt-4 rounded-xl border border-slate-200 bg-slate-50/40 px-4 py-3 text-sm text-slate-700">
        <p class="text-xs font-semibold uppercase text-slate-500">{{ t('admin_dashboard_core_migration_dry_run', page_locale()) }}</p>
        {% if coreUpdate.migrationStatus.error %}
            <p class="mt-2 text-rose-700">{{ t('admin_dashboard_core_migration_error', page_locale()) }}</p>
        {% else %}
            <p class="mt-2">{{ t('admin_dashboard_core_migration_pending', page_locale())|replace({'%count%': coreUpdate.migrationStatus.pending}) }}</p>
        {% endif %}
    </div>

    {% if coreUpdate.autoEnabled and coreUpdate.notesList is not empty %}
        <div class="mt-4 rounded-xl border border-slate-200 bg-slate-50/40 px-4 py-3 text-sm text-slate-700">
            <p class="text-xs font-semibold uppercase text-slate-500">{{ t('admin_dashboard_core_update_changes', page_locale()) }}</p>
            <ul class="mt-2 list-disc space-y-1 pl-5">
                {% for item in coreUpdate.notesList %}
                    <li>{{ item }}</li>
                {% endfor %}
            </ul>
        </div>
    {% elseif coreUpdate.notes %}
        <div class="mt-4 rounded-xl border border-slate-200 bg-slate-50/40 px-4 py-3 text-sm text-slate-700">
            <p class="text-xs font-semibold uppercase text-slate-500">{{ t('admin_dashboard_core_update_notes', page_locale()) }}</p>
            <p class="mt-2 whitespace-pre-line">{{ coreUpdate.notes }}</p>
        </div>
    {% endif %}

    {% if coreUpdate.manifestError %}
        <div class="mt-4 rounded-xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700">
            {{ coreUpdate.manifestError }}
        </div>
    {% endif %}

    {% if coreUpdate.notice or coreUpdate.error %}
        <div class="mt-4 rounded-xl border px-4 py-3 text-sm {{ coreUpdate.error ? 'border-rose-200 bg-rose-50 text-rose-700' : 'border-emerald-200 bg-emerald-50 text-emerald-700' }}">
            {{ coreUpdate.error ?? coreUpdate.notice }}
        </div>
    {% endif %}

    <div class="mt-4 rounded-xl border border-slate-200 bg-slate-50/40 px-4 py-3 text-sm text-slate-700">
        <p class="text-xs font-semibold uppercase text-slate-500">{{ t('admin_dashboard_core_last_job', page_locale()) }}</p>
        {% if coreUpdate.latestJob %}
            <div class="mt-2 grid grid-cols-1 gap-2 text-xs sm:grid-cols-2">
                <div><span class="font-semibold text-slate-600">ID</span> {{ coreUpdate.latestJob.id }}</div>
                <div><span class="font-semibold text-slate-600">Status</span> {{ coreUpdate.latestJob.status }}</div>
                <div><span class="font-semibold text-slate-600">Typ</span> {{ coreUpdate.latestJob.type }}</div>
                <div><span class="font-semibold text-slate-600">Exit</span> {{ coreUpdate.latestJob.exitCode ?? '—' }}</div>
            </div>
        {% else %}
            <p class="mt-2 text-xs text-slate-600">{{ t('admin_dashboard_core_no_jobs', page_locale()) }}</p>
        {% endif %}
    </div>

    <div class="mt-4 rounded-xl border border-slate-200 bg-slate-50/40 px-4 py-3 text-sm text-slate-700">
        <p class="text-xs font-semibold uppercase text-slate-500">{{ t('admin_dashboard_core_update_logs', page_locale()) }}</p>
        <pre class="mt-2 max-h-64 overflow-auto rounded-lg border border-slate-200 bg-white p-3 text-xs text-slate-700">{{ coreUpdate.logLines|join("\n") }}</pre>
    </div>

    {% if coreUpdate.backups is not empty %}
        <div class="mt-4 rounded-xl border border-slate-200 bg-slate-50/40 px-4 py-3 text-sm text-slate-700">
            <p class="text-xs font-semibold uppercase text-slate-500">{{ t('admin_dashboard_core_rollback', page_locale()) }}</p>
            <form method="post" hx-post="/admin/updates/job" hx-target="#core-update-card" hx-swap="outerHTML" class="mt-2 flex flex-col gap-2 sm:flex-row sm:items-center">
                <input type="hidden" name="type" value="rollback">
                <input type="hidden" name="csrf_token" value="{{ coreUpdate.csrf.rollback }}">
                <select name="backup_path" class="rounded-lg border border-slate-200 bg-white px-3 py-2 text-xs text-slate-700">
                    {% for backup in coreUpdate.backups %}
                        <option value="{{ backup.path }}">{{ backup.path }}</option>
                    {% endfor %}
                </select>
                <button class="btn rounded-lg border border-slate-200 bg-white px-3 py-2 text-xs font-semibold text-slate-700 shadow-sm">
                    {{ t('admin_dashboard_core_rollback_action', page_locale()) }}
                </button>
            </form>
        </div>
    {% endif %}
</div>
