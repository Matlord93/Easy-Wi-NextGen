<div id="notification-{{ notification.id }}" style="padding:14px 18px;border-bottom:1px solid var(--ng-border);display:flex;flex-wrap:wrap;align-items:center;justify-content:space-between;gap:12px;">
    <div style="flex:1;min-width:0;">
        <p style="margin:0;font-size:13px;font-weight:600;color:var(--ng-text);">{{ notification.title }}</p>
        <p style="margin:2px 0 0;font-size:12px;color:var(--ng-text-muted);">{{ notification.body }}</p>
        <p style="margin:4px 0 0;font-size:11px;color:var(--ng-text-muted);">{{ notification.created_at|date('Y-m-d H:i') }}</p>
    </div>
    <div style="display:flex;align-items:center;gap:8px;flex-shrink:0;">
        <span class="ui-badge ui-badge--{{ notification.read_at ? 'neutral' : 'info' }}">
            {{ notification.read_at ? t('read', page_locale()) : t('unread', page_locale()) }}
        </span>
        {% if notification.action_url %}
            <a href="{{ notification.action_url }}" class="ui-button ui-button--ghost ui-button--sm">{{ t('admin_notifications_open', page_locale()) }}</a>
        {% endif %}
        {% if not notification.read_at %}
            <button
                class="ui-button ui-button--ghost ui-button--sm"
                hx-post="{{ path('admin_notifications_read', { id: notification.id }) }}"
                hx-target="#notification-{{ notification.id }}"
                hx-swap="outerHTML"
            >{{ t('mark_read', page_locale()) }}</button>
        {% endif %}
    </div>
</div>
