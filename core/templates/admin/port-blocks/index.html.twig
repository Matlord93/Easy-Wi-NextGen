{% extends 'admin/base.html.twig' %}

{% set pageTitle = t('admin_port_blocks_title', page_locale()) %}
{% set pageSubtitle = t('admin_port_blocks_intro', page_locale()) %}
{% set activeNav = 'port-blocks' %}

{% block content %}
<div class="flex flex-col gap-6">

    {% if notice %}
        <div class="ng-alert ng-alert--success">{{ notice }}</div>
    {% endif %}
    {% if error %}
        <div class="ng-alert ng-alert--danger">{{ error }}</div>
    {% endif %}

    <div class="ng-layout-2col--equal">
        <div class="ng-data-card">
            <div class="ng-data-card__header">
                <div>
                    <h2 class="ng-data-card__title">{{ t('admin_port_blocks_create_title', page_locale()) }}</h2>
                </div>
            </div>
            <div class="ng-data-card__body">
                <form class="flex flex-col gap-4" method="post" action="/admin/port-blocks">
                    <div class="form-field">
                        <label class="form-label">{{ t('admin_port_blocks_pool_label', page_locale()) }}</label>
                        <select name="pool_id" class="form-input">
                            <option value="">{{ t('admin_port_blocks_pool_placeholder', page_locale()) }}</option>
                            {% for pool in portPools %}
                                <option value="{{ pool.id }}">{{ pool.name }} · {{ pool.node.name ?? pool.node.id }} ({{ pool.startPort }}-{{ pool.endPort }})</option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="form-field">
                        <label class="form-label">{{ t('admin_port_blocks_customer_label', page_locale()) }}</label>
                        <select name="customer_id" class="form-input">
                            <option value="">{{ t('admin_port_blocks_customer_placeholder', page_locale()) }}</option>
                            {% for customer in customers %}
                                <option value="{{ customer.id }}">{{ customer.email }} ({{ customer.id }})</option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="form-field">
                        <label class="form-label">{{ t('admin_port_blocks_size_label', page_locale()) }}</label>
                        <input type="number" min="1" name="size" value="5" class="form-input">
                        <p class="mt-1 text-xs text-slate-500">{{ t('admin_port_blocks_size_hint', page_locale()) }}</p>
                    </div>
                    <div class="form-field">
                        <label class="form-label">{{ t('admin_port_blocks_range_input_label', page_locale()) }}</label>
                        <div class="grid gap-2 sm:grid-cols-2">
                            <input type="number" min="1" name="start_port" placeholder="{{ t('admin_port_blocks_range_start_placeholder', page_locale()) }}" class="form-input">
                            <input type="number" min="1" name="end_port" placeholder="{{ t('admin_port_blocks_range_end_placeholder', page_locale()) }}" class="form-input">
                        </div>
                        <p class="mt-1 text-xs text-slate-500">{{ t('admin_port_blocks_range_hint', page_locale()) }}</p>
                    </div>
                    <div>
                        <button type="submit" class="ui-button ui-button--primary">{{ t('admin_port_blocks_create_action', page_locale()) }}</button>
                    </div>
                </form>
            </div>
        </div>

        <div class="ng-data-card">
            <div class="ng-data-card__header">
                <div>
                    <h2 class="ng-data-card__title">{{ t('admin_port_blocks_help_title', page_locale()) }}</h2>
                </div>
            </div>
            <div class="ng-data-card__body">
                <ul class="flex flex-col gap-2 text-sm text-slate-600">
                    <li>{{ t('admin_port_blocks_help_assignment', page_locale()) }}</li>
                    <li>{{ t('admin_port_blocks_help_order', page_locale()) }}</li>
                    <li>{{ t('admin_port_blocks_help_instance', page_locale()) }}</li>
                </ul>
            </div>
        </div>
    </div>

    <div class="ng-data-card">
        <div class="ng-data-card__header">
            <div>
                <h2 class="ng-data-card__title">{{ t('admin_port_blocks_list_title', page_locale()) }}</h2>
                <p class="ng-data-card__sub">{{ t('admin_port_blocks_list_intro', page_locale()) }}</p>
            </div>
            <div class="ng-data-card__actions">
                <span class="ui-badge ui-badge--neutral">{{ portBlocks|length }}</span>
            </div>
        </div>
        <div class="ng-data-card__body--flush">
            <div class="cust-ws-table-wrap">
                <table class="cust-table">
                    <thead>
                        <tr>
                            <th>{{ t('admin_label_id', page_locale()) }}</th>
                            <th>{{ t('admin_port_blocks_pool_label', page_locale()) }}</th>
                            <th>{{ t('admin_port_blocks_customer_label', page_locale()) }}</th>
                            <th>{{ t('admin_port_blocks_range_label', page_locale()) }}</th>
                            <th>{{ t('admin_port_blocks_instance_label', page_locale()) }}</th>
                            <th>{{ t('admin_port_blocks_assigned_label', page_locale()) }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for block in portBlocks %}
                            <tr>
                                <td class="font-mono text-xs text-slate-700">{{ block.id }}</td>
                                <td>
                                    <div class="font-semibold text-slate-900">{{ block.pool.name }}</div>
                                    <div class="text-xs text-slate-500">{{ block.pool.node }}</div>
                                </td>
                                <td>
                                    <div class="font-semibold text-slate-900">{{ block.customer.email }}</div>
                                    <div class="text-xs text-slate-500">#{{ block.customer.id }}</div>
                                </td>
                                <td>
                                    <span class="ui-badge ui-badge--neutral">{{ block.start_port }}-{{ block.end_port }}</span>
                                </td>
                                <td>{{ block.instance_id ?? '—' }}</td>
                                <td>{{ block.assigned_at ? block.assigned_at|date('Y-m-d H:i') : '—' }}</td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="6" class="cust-table__empty">{{ t('admin_port_blocks_empty', page_locale()) }}</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>
{% endblock %}
