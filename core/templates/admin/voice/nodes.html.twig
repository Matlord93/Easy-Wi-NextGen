{% extends 'admin/base.html.twig' %}

{% block content %}
{% set locale = page_locale() %}
<div class="space-y-6" id="voice-admin-root">
    <div>
        <h1 class="text-2xl font-semibold text-slate-900">{{ t('admin_voice_nodes_title', locale) }}</h1>
        <p class="text-sm text-slate-700">{{ t('admin_voice_nodes_subtitle', locale) }}</p>
    </div>

    <form method="get" action="{{ path('admin_voice_nodes') }}" class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm grid gap-3 md:grid-cols-4">
        <select name="provider" class="rounded border border-slate-300 px-3 py-2">
            <option value="">{{ t('admin_voice_nodes_filter_provider_all', locale) }}</option>
            <option value="ts3" {{ filter_provider == 'ts3' ? 'selected' : '' }}>TS3</option>
            <option value="ts6" {{ filter_provider == 'ts6' ? 'selected' : '' }}>TS6</option>
        </select>
        <select name="enabled" class="rounded border border-slate-300 px-3 py-2">
            <option value="" {{ filter_enabled == '' ? 'selected' : '' }}>{{ t('admin_voice_nodes_filter_status_all', locale) }}</option>
            <option value="1" {{ filter_enabled == '1' ? 'selected' : '' }}>{{ t('admin_voice_nodes_status_enabled', locale) }}</option>
            <option value="0" {{ filter_enabled == '0' ? 'selected' : '' }}>{{ t('admin_voice_nodes_status_disabled', locale) }}</option>
        </select>
        <input name="per_page" value="{{ per_page }}" type="number" min="1" max="200" class="rounded border border-slate-300 px-3 py-2" placeholder="{{ t('admin_voice_nodes_per_page_placeholder', locale) }}">
        <button class="rounded bg-slate-900 text-white px-3 py-2">{{ t('admin_voice_nodes_filter_btn', locale) }}</button>
    </form>

    <form method="post" action="{{ path('admin_voice_nodes_create') }}" class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm grid gap-3 md:grid-cols-5">
        <input name="name" placeholder="{{ t('admin_voice_nodes_name_placeholder', locale) }}" class="rounded border border-slate-300 px-3 py-2" required>
        <select name="provider_type" class="rounded border border-slate-300 px-3 py-2" required>
            <option value="ts3">TS3</option>
            <option value="ts6">TS6</option>
        </select>
        <input name="host" placeholder="{{ t('admin_voice_nodes_host_placeholder', locale) }}" class="rounded border border-slate-300 px-3 py-2" required>
        <input name="query_port" placeholder="{{ t('admin_voice_nodes_query_port_placeholder', locale) }}" type="number" class="rounded border border-slate-300 px-3 py-2" required>
        <button class="rounded bg-indigo-600 text-white px-3 py-2">{{ t('admin_create_btn', locale) }}</button>
        <input name="query_user" placeholder="{{ t('admin_voice_nodes_query_user_placeholder', locale) }}" class="rounded border border-slate-300 px-3 py-2 md:col-span-2">
        <input name="query_secret" placeholder="{{ t('admin_voice_nodes_query_secret_placeholder', locale) }}" type="password" class="rounded border border-slate-300 px-3 py-2 md:col-span-2">
    </form>

    <div class="rounded-xl border border-slate-200 bg-white shadow-sm overflow-x-auto">
        <table class="min-w-full text-sm divide-y divide-slate-200">
            <thead class="bg-slate-50"><tr><th class="px-4 py-3 text-left">{{ t('admin_voice_nodes_col_name', locale) }}</th><th class="px-4 py-3 text-left">{{ t('admin_voice_nodes_col_provider', locale) }}</th><th class="px-4 py-3 text-left">{{ t('admin_voice_nodes_col_host', locale) }}</th><th class="px-4 py-3 text-left">{{ t('admin_voice_nodes_col_enabled', locale) }}</th><th class="px-4 py-3 text-left">{{ t('admin_voice_nodes_col_query', locale) }}</th><th class="px-4 py-3 text-left">{{ t('admin_voice_nodes_col_rate', locale) }}</th><th class="px-4 py-3 text-left">{{ t('admin_voice_nodes_col_last_probe', locale) }}</th><th class="px-4 py-3 text-left">{{ t('admin_voice_nodes_col_last_error', locale) }}</th><th class="px-4 py-3 text-left">{{ t('admin_voice_nodes_col_action', locale) }}</th></tr></thead>
            <tbody class="divide-y divide-slate-200">
                {% for row in rows %}
                    {% set n = row.node %}
                    {% set state = row.state %}
                    {% set latest = row.latest %}
                    <tr>
                        <td class="px-4 py-3">{{ n.name }}</td>
                        <td class="px-4 py-3">{{ n.providerType|upper }}</td>
                        <td class="px-4 py-3">{{ n.host }}:{{ n.queryPort }}</td>
                        <td class="px-4 py-3">{{ n.enabled ? t('admin_voice_nodes_yes', locale) : t('admin_voice_nodes_no', locale) }}</td>
                        <td class="px-4 py-3">{{ n.credentialsEncrypted is not empty ? t('admin_voice_nodes_query_configured', locale) : t('admin_voice_nodes_query_missing', locale) }}</td>
                        <td class="px-4 py-3">
                            {% if state %}
                                <div>tokens: {{ state.tokens|number_format(2, '.', ',') }}</div>
                                <div>locked_until: {{ state.lockedUntil ? state.lockedUntil|date('Y-m-d H:i:s') : '-' }}</div>
                                <div>circuit_until: {{ state.circuitOpenUntil ? state.circuitOpenUntil|date('Y-m-d H:i:s') : '-' }}</div>
                            {% else %}
                                -
                            {% endif %}
                        </td>
                        <td class="px-4 py-3">{{ latest and latest.checkedAt ? latest.checkedAt|date('Y-m-d H:i:s') : '-' }}</td>
                        <td class="px-4 py-3">{{ latest and latest.errorCode ? latest.errorCode ~ ' · ' ~ (latest.reason ?? '') : '-' }}</td>
                        <td class="px-4 py-3 flex gap-2 flex-wrap">
                            <form method="post" action="{{ path('admin_voice_nodes_toggle', {id: n.id}) }}"><button class="rounded border px-3 py-1">{{ t('admin_voice_nodes_toggle', locale) }}</button></form>
                            <button type="button" data-probe-node="{{ n.id }}" class="rounded border border-indigo-300 px-3 py-1 text-indigo-700">{{ t('admin_voice_nodes_probe_now', locale) }}</button>
                            <span data-probe-status="{{ n.id }}" class="text-xs text-slate-600"></span>
                        </td>
                    </tr>
                {% else %}
                    <tr><td colspan="9" class="px-4 py-6 text-center text-slate-600">{{ t('admin_voice_nodes_none', locale) }}</td></tr>
                {% endfor %}
            </tbody>
        </table>
        {% set total_pages = (total / per_page)|round(0, 'ceil') %}
        <div class="border-t border-slate-200 px-4 py-2 text-xs text-slate-600">{{ t('admin_voice_nodes_page', locale) }} {{ page }} / {{ total_pages > 0 ? total_pages : 1 }} · {{ total }} {{ t('admin_voice_nodes_rows', locale) }}</div>
    </div>
</div>

<script>
(() => {
    const root = document.getElementById('voice-admin-root');
    if (!root) {
        return;
    }

    root.addEventListener('click', async (event) => {
        const button = event.target.closest('[data-probe-node]');
        if (!button) {
            return;
        }

        const nodeId = button.getAttribute('data-probe-node');
        const status = root.querySelector(`[data-probe-status="${nodeId}"]`);
        button.disabled = true;
        status.textContent = 'queue...';

        try {
            const probeUrlTemplate = '{{ path('admin_voice_nodes_probe_v1', {id: 0}) }}';
            const response = await fetch(probeUrlTemplate.replace('/0/probe', `/${nodeId}/probe`), {method: 'POST', headers: {'Accept': 'application/json'}});
            const payload = await response.json();
            const retry = payload.retry_after ? ` (retry ${payload.retry_after}s)` : '';
            status.textContent = `${payload.message || 'done'}${retry}`;
        } catch (e) {
            status.textContent = 'request failed';
        } finally {
            button.disabled = false;
        }
    });
})();
</script>
{% endblock %}
