{% extends 'admin/base.html.twig' %}

{% set pageTitle = t('admin_voice_nodes_title', page_locale()) %}
{% set activeNav = 'voice-nodes' %}

{% block content %}
{% set locale = page_locale() %}
<div style="display:flex;flex-direction:column;gap:20px;" id="voice-admin-root">

  <section class="ng-card" style="overflow:hidden;">
    <div class="tkt-hero">
      <div class="tkt-hero__inner">
        <div>
          <div class="tkt-hero__pill"><span class="tkt-hero__pill-dot"></span> Voice</div>
          <h1 class="tkt-hero__title" style="margin-top:10px;">{{ t('admin_voice_nodes_title', locale) }}</h1>
          <p class="tkt-hero__sub">{{ t('admin_voice_nodes_subtitle', locale) }}</p>
        </div>
      </div>
    </div>
  </section>

  <div class="ng-data-card">
    <div class="ng-data-card__header">
      <div>
        <h2 class="ng-data-card__title">{{ t('admin_voice_nodes_title', locale) }}</h2>
      </div>
    </div>
    <div class="ng-data-card__body">
      <form method="get" action="{{ path('admin_voice_nodes') }}" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:10px;">
        <select name="provider" class="form-input">
          <option value="">{{ t('admin_voice_nodes_filter_provider_all', locale) }}</option>
          <option value="ts3" {{ filter_provider == 'ts3' ? 'selected' : '' }}>TS3</option>
          <option value="ts6" {{ filter_provider == 'ts6' ? 'selected' : '' }}>TS6</option>
        </select>
        <select name="enabled" class="form-input">
          <option value="" {{ filter_enabled == '' ? 'selected' : '' }}>{{ t('admin_voice_nodes_filter_status_all', locale) }}</option>
          <option value="1" {{ filter_enabled == '1' ? 'selected' : '' }}>{{ t('admin_voice_nodes_status_enabled', locale) }}</option>
          <option value="0" {{ filter_enabled == '0' ? 'selected' : '' }}>{{ t('admin_voice_nodes_status_disabled', locale) }}</option>
        </select>
        <input name="per_page" value="{{ per_page }}" type="number" min="1" max="200" class="form-input" placeholder="{{ t('admin_voice_nodes_per_page_placeholder', locale) }}">
        <button class="ui-button ui-button--primary" type="submit">{{ t('admin_voice_nodes_filter_btn', locale) }}</button>
      </form>
    </div>
  </div>

  <div class="ng-data-card">
    <div class="ng-data-card__header">
      <div>
        <h2 class="ng-data-card__title">{{ t('admin_voice_nodes_title', locale) }}</h2>
      </div>
    </div>
    <div class="ng-data-card__body">
      <form method="post" action="{{ path('admin_voice_nodes_create') }}" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:10px;">
        <input name="name" placeholder="{{ t('admin_voice_nodes_name_placeholder', locale) }}" class="form-input" required>
        <select name="provider_type" class="form-input" required>
          <option value="ts3">TS3</option>
          <option value="ts6">TS6</option>
        </select>
        <input name="host" placeholder="{{ t('admin_voice_nodes_host_placeholder', locale) }}" class="form-input" required>
        <input name="query_port" placeholder="{{ t('admin_voice_nodes_query_port_placeholder', locale) }}" type="number" class="form-input" required>
        <input name="query_user" placeholder="{{ t('admin_voice_nodes_query_user_placeholder', locale) }}" class="form-input" style="grid-column:span 2;">
        <input name="query_secret" placeholder="{{ t('admin_voice_nodes_query_secret_placeholder', locale) }}" type="password" class="form-input" style="grid-column:span 2;">
        <div>
          <button class="ui-button ui-button--primary" type="submit">{{ t('admin_create_btn', locale) }}</button>
        </div>
      </form>
    </div>
  </div>

  <div class="ng-data-card">
    <div class="cust-ws-table-wrap">
      <table class="cust-table">
        <thead>
          <tr>
            <th>{{ t('admin_voice_nodes_col_name', locale) }}</th>
            <th>{{ t('admin_voice_nodes_col_provider', locale) }}</th>
            <th>{{ t('admin_voice_nodes_col_host', locale) }}</th>
            <th>{{ t('admin_voice_nodes_col_enabled', locale) }}</th>
            <th>{{ t('admin_voice_nodes_col_query', locale) }}</th>
            <th>{{ t('admin_voice_nodes_col_rate', locale) }}</th>
            <th>{{ t('admin_voice_nodes_col_last_probe', locale) }}</th>
            <th>{{ t('admin_voice_nodes_col_last_error', locale) }}</th>
            <th>{{ t('admin_voice_nodes_col_action', locale) }}</th>
          </tr>
        </thead>
        <tbody>
          {% for row in rows %}
            {% set n = row.node %}
            {% set state = row.state %}
            {% set latest = row.latest %}
            <tr>
              <td>{{ n.name }}</td>
              <td>{{ n.providerType|upper }}</td>
              <td>{{ n.host }}:{{ n.queryPort }}</td>
              <td>
                {% if n.enabled %}
                  <span class="ui-badge ui-badge--success">{{ t('admin_voice_nodes_yes', locale) }}</span>
                {% else %}
                  <span class="ui-badge ui-badge--neutral">{{ t('admin_voice_nodes_no', locale) }}</span>
                {% endif %}
              </td>
              <td>
                {% if n.credentialsEncrypted is not empty %}
                  <span class="ui-badge ui-badge--success">{{ t('admin_voice_nodes_query_configured', locale) }}</span>
                {% else %}
                  <span class="ui-badge ui-badge--warning">{{ t('admin_voice_nodes_query_missing', locale) }}</span>
                {% endif %}
              </td>
              <td>
                {% if state %}
                  <div style="font-size:12px;color:var(--ng-text-muted);">tokens: {{ state.tokens|number_format(2, '.', ',') }}</div>
                  <div style="font-size:12px;color:var(--ng-text-muted);">locked_until: {{ state.lockedUntil ? state.lockedUntil|date('Y-m-d H:i:s') : '-' }}</div>
                  <div style="font-size:12px;color:var(--ng-text-muted);">circuit_until: {{ state.circuitOpenUntil ? state.circuitOpenUntil|date('Y-m-d H:i:s') : '-' }}</div>
                {% else %}
                  -
                {% endif %}
              </td>
              <td>{{ latest and latest.checkedAt ? latest.checkedAt|date('Y-m-d H:i:s') : '-' }}</td>
              <td>{{ latest and latest.errorCode ? latest.errorCode ~ ' · ' ~ (latest.reason ?? '') : '-' }}</td>
              <td style="display:flex;gap:6px;flex-wrap:wrap;align-items:center;">
                <form method="post" action="{{ path('admin_voice_nodes_toggle', {id: n.id}) }}">
                  <button class="ui-button ui-button--ghost ui-button--sm" type="submit">{{ t('admin_voice_nodes_toggle', locale) }}</button>
                </form>
                <button type="button" data-probe-node="{{ n.id }}" class="ui-button ui-button--ghost ui-button--sm">{{ t('admin_voice_nodes_probe_now', locale) }}</button>
                <span data-probe-status="{{ n.id }}" style="font-size:11px;color:var(--ng-text-muted);"></span>
              </td>
            </tr>
          {% else %}
            <tr>
              <td colspan="9" class="cust-table__empty">{{ t('admin_voice_nodes_none', locale) }}</td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
    {% set total_pages = (total / per_page)|round(0, 'ceil') %}
    <div style="border-top:1px solid var(--ng-border);padding:8px 16px;font-size:12px;color:var(--ng-text-muted);">
      {{ t('admin_voice_nodes_page', locale) }} {{ page }} / {{ total_pages > 0 ? total_pages : 1 }} · {{ total }} {{ t('admin_voice_nodes_rows', locale) }}
    </div>
  </div>

</div>

<script>
(() => {
    const root = document.getElementById('voice-admin-root');
    if (!root) {
        return;
    }

    root.addEventListener('click', async (event) => {
        const button = event.target.closest('[data-probe-node]');
        if (!button) {
            return;
        }

        const nodeId = button.getAttribute('data-probe-node');
        const status = root.querySelector(`[data-probe-status="${nodeId}"]`);
        button.disabled = true;
        status.textContent = 'queue...';

        try {
            const probeUrlTemplate = '{{ path('admin_voice_nodes_probe_v1', {id: 0}) }}';
            const response = await fetch(probeUrlTemplate.replace('/0/probe', `/${nodeId}/probe`), {method: 'POST', headers: {'Accept': 'application/json'}});
            const payload = await response.json();
            const retry = payload.retry_after ? ` (retry ${payload.retry_after}s)` : '';
            status.textContent = `${payload.message || 'done'}${retry}`;
        } catch (e) {
            status.textContent = 'request failed';
        } finally {
            button.disabled = false;
        }
    });
})();
</script>
{% endblock %}
