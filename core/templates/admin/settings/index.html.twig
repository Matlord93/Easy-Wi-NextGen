                        <a href="{{ path('admin_settings', {tab: 'mail_templates', lang: 'en'}) }}" style="border-radius:999px;padding:0.375rem 1rem;font-size:0.75rem;font-weight:600;text-decoration:none;{% if activeLang == 'en' %}background:var(--ng-primary-soft);color:var(--ng-primary);border:1px solid var(--ng-primary);{% else %}background:var(--ng-surface-soft);color:var(--ng-text-muted);border:1px solid var(--ng-border);{% endif %}">🇬🇧 English</a>
