                            <div style="border-top:1px solid var(--ng-border);padding:1rem;">
                                <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
                                    <label style="display:inline-flex;align-items:center;gap:0.5rem;font-size:0.875rem;color:var(--ng-text);cursor:pointer;"><input type="checkbox" name="anti_abuse_enable_pow_contact" value="1" {{ settings.anti_abuse_enable_pow_contact ? 'checked' : '' }}> {{ t('admin_webinterface_security_pow_contact', page_locale()) }}</label>
                                    <label style="display:inline-flex;align-items:center;gap:0.5rem;font-size:0.875rem;color:var(--ng-text);cursor:pointer;"><input type="checkbox" name="anti_abuse_enable_pow_registration" value="1" {{ settings.anti_abuse_enable_pow_registration ? 'checked' : '' }}> {{ t('admin_webinterface_security_pow_registration', page_locale()) }}</label>
                                    <label style="display:inline-flex;align-items:center;gap:0.5rem;font-size:0.875rem;color:var(--ng-text);cursor:pointer;"><input type="checkbox" name="anti_abuse_enable_captcha_registration" value="1" {{ settings.anti_abuse_enable_captcha_registration ? 'checked' : '' }}> {{ t('admin_webinterface_security_captcha_registration', page_locale()) }}</label>
                                    <label style="display:inline-flex;align-items:center;gap:0.5rem;font-size:0.875rem;color:var(--ng-text);cursor:pointer;"><input type="checkbox" name="anti_abuse_enable_captcha_contact" value="1" {{ settings.anti_abuse_enable_captcha_contact ? 'checked' : '' }}> {{ t('admin_webinterface_security_captcha_contact', page_locale()) }}</label>
                                    <div style="display:flex;flex-direction:column;gap:0.375rem;">
                                        <label style="font-size:0.8125rem;font-weight:500;color:var(--ng-text);">{{ t('admin_webinterface_security_min_submit_seconds', page_locale()) }}</label>
