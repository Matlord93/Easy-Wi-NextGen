                                    <details>
                                        <summary style="cursor:pointer;font-size:0.8125rem;font-weight:500;color:var(--ng-primary);list-style:none;display:inline-flex;align-items:center;gap:0.375rem;">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16"><path d="M12.854.146a.5.5 0 0 0-.707 0L10.5 1.793 14.207 5.5l1.647-1.646a.5.5 0 0 0 0-.708l-3-3zm.646 6.061L9.793 2.5 3.293 9H3.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.207l6.5-6.5zm-7.468 7.468A.5.5 0 0 1 6 13.5V13h-.5a.5.5 0 0 1-.5-.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.5-.5V10h-.5a.499.499 0 0 1-.175-.032l-.179.178a.5.5 0 0 0-.11.168l-2 5a.5.5 0 0 0 .65.65l5-2a.5.5 0 0 0 .168-.11l.178-.178z"/></svg>
                                            {{ t('admin_settings_mail_tpl_edit', page_locale()) }}
                                        </summary>
                                        <div style="margin-top:0.75rem;">
                                            <form method="post" action="/admin/settings/mail-templates/{{ activeLang }}/{{ tplKey }}">
                                                <input type="hidden" name="_token" value="{{ csrf_token('mail_template_' ~ tplKey) }}">
                                                <textarea name="content" rows="8" placeholder="HTML-Inhalt der Vorlage…" style="width:100%;border:1px solid var(--ng-border);border-radius:var(--ng-radius);padding:0.5rem 0.75rem;font-size:0.8125rem;font-family:monospace;background:var(--ng-surface-soft);color:var(--ng-text);box-sizing:border-box;resize:vertical;"></textarea>
                                                <p style="font-size:0.72rem;color:var(--ng-text-muted);margin:0.375rem 0 0.75rem;">{{ t('admin_settings_mail_tpl_backend_hint', page_locale()) }}</p>
                                                <button type="submit" class="ui-button ui-button--primary" style="font-size:0.8125rem;padding:0.375rem 0.875rem;">{{ t('admin_settings_mail_tpl_save', page_locale()) }}</button>
                                            </form>
                                        </div>
                                    </details>
                                </div>
                            </div>
                        {% endfor %}
                    </div>

                    {# New template section #}
                    <div style="border:1px solid var(--ng-border);border-radius:var(--ng-radius);background:var(--ng-surface);overflow:hidden;">
                        <div style="padding:1rem;border-bottom:1px solid var(--ng-border);background:var(--ng-surface-soft);">
                            <h3 style="margin:0 0 0.25rem;font-size:0.9375rem;font-weight:600;color:var(--ng-text);">{{ t('admin_settings_mail_tpl_new_title', page_locale()) }}</h3>
                            <p style="margin:0;font-size:0.8125rem;color:var(--ng-text-muted);">{{ t('admin_settings_mail_tpl_new_intro', page_locale()) }}</p>
                        </div>
                        <div style="padding:1.25rem;">
                            <form method="post" action="/admin/settings/mail-templates/create" style="display:flex;flex-direction:column;gap:1rem;">
                                <input type="hidden" name="_token" value="{{ csrf_token('mail_template_create') }}">
                                <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
                                    <div style="display:flex;flex-direction:column;gap:0.375rem;">
                                        <label style="font-size:0.8125rem;font-weight:500;color:var(--ng-text);">Template-Key (Slug)</label>
                                        <input type="text" name="key" placeholder="invoice_reminder" pattern="[a-z0-9_]+" style="width:100%;border:1px solid var(--ng-border);border-radius:var(--ng-radius);padding:0.5rem 0.75rem;font-size:0.875rem;background:var(--ng-surface);color:var(--ng-text);box-sizing:border-box;">
                                    </div>
                                    <div style="display:flex;flex-direction:column;gap:0.375rem;">
                                        <label style="font-size:0.8125rem;font-weight:500;color:var(--ng-text);">{{ t('admin_settings_mail_tpl_language', page_locale()) }}</label>
                                        <select name="locale" style="width:100%;border:1px solid var(--ng-border);border-radius:var(--ng-radius);padding:0.5rem 0.75rem;font-size:0.875rem;background:var(--ng-surface);color:var(--ng-text);box-sizing:border-box;">
                                            <option value="de">DE – Deutsch</option>
                                            <option value="en">EN – English</option>
                                        </select>
                                    </div>
                                </div>
                                <div style="display:flex;flex-direction:column;gap:0.375rem;">
                                    <label style="font-size:0.8125rem;font-weight:500;color:var(--ng-text);">HTML-Inhalt</label>
                                    <textarea name="content" rows="10" placeholder="<!DOCTYPE html>…" style="width:100%;border:1px solid var(--ng-border);border-radius:var(--ng-radius);padding:0.5rem 0.75rem;font-size:0.8125rem;font-family:monospace;background:var(--ng-surface);color:var(--ng-text);box-sizing:border-box;resize:vertical;"></textarea>
                                </div>
                                <div>
                                    <button type="submit" class="ui-button ui-button--primary">Vorlage erstellen</button>
                                </div>
                            </form>
                        </div>
                    </div>

                {% endif %}

                {% if activeTab != 'mail_templates' %}
                    <div style="margin-top:1.5rem;display:flex;flex-wrap:wrap;align-items:center;gap:0.75rem;">
                        <button type="submit" class="ui-button ui-button--primary">{{ t('admin_settings_save', page_locale()) }}</button>
                        <a href="/admin" class="ui-button ui-button--ghost">{{ t('admin_settings_back', page_locale()) }}</a>
                    </div>
                {% endif %}
            </form>

        </div>
    </div>

</div>
{% endblock %}
