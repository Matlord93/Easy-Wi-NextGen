                        <div>
                            <button type="submit" formaction="{{ path('admin_settings_agent_token_rotate') }}" formmethod="post" class="ui-button ui-button--warning">{{ t('admin_settings_agent_token_rotate', page_locale()) }}</button>
                        </div>
                        <p style="margin:0;font-size:0.75rem;color:var(--ng-text-muted);">{{ t('admin_settings_agent_token_rotate_hint', page_locale()) }}</p>
