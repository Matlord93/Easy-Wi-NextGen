                        'gameserver_ready': { label: t('admin_mail_tpl_gameserver_ready_label', page_locale()), desc: t('admin_mail_tpl_gameserver_ready_desc', page_locale()) },
                        'invoice_paid': { label: t('admin_mail_tpl_invoice_paid_label', page_locale()), desc: t('admin_mail_tpl_invoice_paid_desc', page_locale()) },
                        'password_reset': { label: t('admin_mail_tpl_password_reset_label', page_locale()), desc: t('admin_mail_tpl_password_reset_desc', page_locale()) },
                        'server_created': { label: t('admin_mail_tpl_server_created_label', page_locale()), desc: t('admin_mail_tpl_server_created_desc', page_locale()) },
                        'voiceserver_ready': { label: t('admin_mail_tpl_voiceserver_ready_label', page_locale()), desc: t('admin_mail_tpl_voiceserver_ready_desc', page_locale()) },
                        'webspace_ready': { label: t('admin_mail_tpl_webspace_ready_label', page_locale()), desc: t('admin_mail_tpl_webspace_ready_desc', page_locale()) }
