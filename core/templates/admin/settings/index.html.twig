                                    <label style="display:inline-flex;align-items:center;gap:0.5rem;cursor:pointer;">
                                        <input type="checkbox" name="security_2fa_required_reseller" value="1" {{ settings.security_2fa_required_reseller ? 'checked' : '' }}>
                                        {{ t('admin_webinterface_security_2fa_reseller', page_locale()) }}
                                    </label>
