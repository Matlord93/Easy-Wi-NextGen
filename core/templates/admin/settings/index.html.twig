                                            <th style="padding:0.625rem 1rem;text-align:left;font-size:0.75rem;font-weight:600;color:var(--ng-text-muted);border-bottom:1px solid var(--ng-border);">{{ t('admin_webinterface_security_2fa_status', page_locale()) }}</th>
                                        </tr>
