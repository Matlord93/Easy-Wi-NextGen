                            <div style="display:flex;flex-direction:column;gap:0.375rem;">
                                <label style="font-size:0.8125rem;font-weight:500;color:var(--ng-text);">Routine-Log-Retention (Tage)</label>
                                <input type="number" min="1" name="database_logging_routine_retention_days" value="{{ settings.database_logging_routine_retention_days }}" style="width:100%;border:1px solid var(--ng-border);border-radius:var(--ng-radius);padding:0.5rem 0.75rem;font-size:0.875rem;background:var(--ng-surface);color:var(--ng-text);box-sizing:border-box;">
                            </div>
                            <div style="display:flex;flex-direction:column;gap:0.375rem;">
                                <label style="font-size:0.8125rem;font-weight:500;color:var(--ng-text);">Fehler-/Security-Log-Retention (Tage)</label>
