                            <textarea name="cms_maintenance_allowlist" rows="3" style="width:100%;border:1px solid var(--ng-border);border-radius:var(--ng-radius);padding:0.5rem 0.75rem;font-size:0.875rem;background:var(--ng-surface);color:var(--ng-text);box-sizing:border-box;resize:vertical;font-family:monospace;" placeholder="203.0.113.10&#10;198.51.100.0/24">{{ settings.cms_maintenance_allowlist }}</textarea>
                            <p style="margin:0.25rem 0 0;font-size:0.75rem;color:var(--ng-text-muted);">{{ t('admin_webinterface_maintenance_hint', page_locale()) }}</p>
                        </div>
                    </div>


                {# ── Logging ── #}
                {% elseif activeTab == 'logging' %}
