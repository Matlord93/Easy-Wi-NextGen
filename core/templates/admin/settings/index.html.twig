{% extends 'admin/base.html.twig' %}

{% set pageTitle = t('admin_settings_title', page_locale()) %}
{% set pageSubtitle = t('admin_settings_description', page_locale()) %}
{% set activeNav = 'settings' %}

{% block content %}
<div style="display:flex;flex-direction:column;gap:1.5rem;">

    {# Alerts #}
    {% if errors is not empty %}
        <div style="background:#fef2f2;border:1px solid #fecaca;border-radius:var(--ng-radius);padding:1rem;color:#b91c1c;">
            <ul style="margin:0;padding-left:1.25rem;">
                {% for error in errors %}
                    <li>{{ error }}</li>
                {% endfor %}
            </ul>
        </div>
    {% elseif tokenRotated %}
        <div style="background:#f0fdf4;border:1px solid #bbf7d0;border-radius:var(--ng-radius);padding:1rem;color:#15803d;">
            {{ t('admin_settings_token_rotated', page_locale()) }}
        </div>
    {% elseif saved %}
        <div style="background:#f0fdf4;border:1px solid #bbf7d0;border-radius:var(--ng-radius);padding:1rem;color:#15803d;">
            {{ t('admin_settings_saved', page_locale()) }}
        </div>
    {% endif %}

    <div class="ng-card" style="border:1px solid var(--ng-border);border-radius:var(--ng-radius);background:var(--ng-surface);">
        <div style="padding:1.5rem;border-bottom:1px solid var(--ng-border);">
            <h2 style="font-size:1.125rem;font-weight:700;color:var(--ng-text);margin:0 0 0.25rem;">{{ t('admin_settings_title', page_locale()) }}</h2>
            <p style="color:var(--ng-text-muted);margin:0;font-size:0.875rem;">{{ t('admin_settings_description', page_locale()) }}</p>
        </div>
        <div style="padding:1.5rem;">

            {# Tab navigation #}
            {% set tabs = [
                { key: 'general', label: t('admin_webinterface_tab_general', page_locale()) },
                { key: 'email', label: t('admin_webinterface_tab_email', page_locale()) },
                { key: 'gameserver', label: t('admin_webinterface_tab_gameserver', page_locale()) },
                { key: 'customer', label: t('admin_webinterface_tab_customer', page_locale()) },
                { key: 'security', label: t('admin_webinterface_tab_security', page_locale()) },
                { key: 'maintenance', label: t('admin_webinterface_tab_maintenance', page_locale()) },
                { key: 'logging', label: 'Logging' },
                { key: 'agent', label: t('admin_webinterface_tab_agent', page_locale()) },
                { key: 'mail_templates', label: t('admin_settings_mail_templates_tab', page_locale()) }
            ] %}
            <div style="display:flex;flex-wrap:wrap;gap:0.5rem;margin-bottom:1.5rem;padding-bottom:1rem;border-bottom:1px solid var(--ng-border);">
                {% for tab in tabs %}
                    <a
                        href="{{ path('admin_settings', {tab: tab.key}) }}"
                        style="border-radius:999px;padding:0.375rem 1rem;font-size:0.75rem;font-weight:600;text-decoration:none;transition:background 0.15s;{% if activeTab == tab.key %}background:var(--ng-primary-soft);color:var(--ng-primary);border:1px solid var(--ng-primary);{% else %}background:var(--ng-surface-soft);color:var(--ng-text-muted);border:1px solid var(--ng-border);{% endif %}"
                    >
                        {{ tab.label }}
                    </a>
                {% endfor %}
            </div>

            <form method="post" action="{{ path('admin_settings_update') }}">
                <input type="hidden" name="tab" value="{{ activeTab }}">

                {# ── General ── #}
                {% if activeTab == 'general' %}
                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
                        <div style="display:flex;flex-direction:column;gap:0.375rem;">
                            <label style="font-size:0.8125rem;font-weight:500;color:var(--ng-text);">{{ t('admin_webinterface_site_title', page_locale()) }}</label>
                            <input type="text" name="site_title" value="{{ settings.site_title }}" style="width:100%;border:1px solid var(--ng-border);border-radius:var(--ng-radius);padding:0.5rem 0.75rem;font-size:0.875rem;background:var(--ng-surface);color:var(--ng-text);box-sizing:border-box;">
                        </div>
                        <div style="display:flex;flex-direction:column;gap:0.375rem;">
                            <label style="font-size:0.8125rem;font-weight:500;color:var(--ng-text);">{{ t('admin_webinterface_branding_name', page_locale()) }}</label>
                            <input type="text" name="branding_name" value="{{ settings.branding_name }}" style="width:100%;border:1px solid var(--ng-border);border-radius:var(--ng-radius);padding:0.5rem 0.75rem;font-size:0.875rem;background:var(--ng-surface);color:var(--ng-text);box-sizing:border-box;">
                        </div>
                        <div style="display:flex;flex-direction:column;gap:0.375rem;grid-column:span 2;">
                            <label style="font-size:0.8125rem;font-weight:500;color:var(--ng-text);">{{ t('admin_webinterface_branding_logo', page_locale()) }}</label>
                            <input type="text" name="branding_logo_url" value="{{ settings.branding_logo_url }}" placeholder="/assets/logo.svg" style="width:100%;border:1px solid var(--ng-border);border-radius:var(--ng-radius);padding:0.5rem 0.75rem;font-size:0.875rem;background:var(--ng-surface);color:var(--ng-text);box-sizing:border-box;">
                            <p style="margin:0.25rem 0 0;font-size:0.75rem;color:var(--ng-text-muted);">{{ t('admin_webinterface_branding_logo_hint', page_locale()) }}</p>
                        </div>
                        <div style="display:flex;flex-direction:column;gap:0.375rem;">
                            <label style="font-size:0.8125rem;font-weight:500;color:var(--ng-text);">{{ t('admin_webinterface_support_email', page_locale()) }}</label>
                            <input type="email" name="support_email" value="{{ settings.support_email }}" placeholder="support@example.com" style="width:100%;border:1px solid var(--ng-border);border-radius:var(--ng-radius);padding:0.5rem 0.75rem;font-size:0.875rem;background:var(--ng-surface);color:var(--ng-text);box-sizing:border-box;">
                        </div>
                    </div>

                {# ── Email ── #}
                {% elseif activeTab == 'email' %}
                    <div style="display:flex;flex-direction:column;gap:1.5rem;">
                        {# Basic mail fields #}
                        <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
                            <div style="display:flex;flex-direction:column;gap:0.375rem;">
                                <label style="font-size:0.8125rem;font-weight:500;color:var(--ng-text);">{{ t('admin_webinterface_mail_from_name', page_locale()) }}</label>
                                <input type="text" name="mail_from_name" value="{{ settings.mail_from_name }}" style="width:100%;border:1px solid var(--ng-border);border-radius:var(--ng-radius);padding:0.5rem 0.75rem;font-size:0.875rem;background:var(--ng-surface);color:var(--ng-text);box-sizing:border-box;">
                            </div>
                            <div style="display:flex;flex-direction:column;gap:0.375rem;">
                                <label style="font-size:0.8125rem;font-weight:500;color:var(--ng-text);">{{ t('admin_webinterface_mail_from_address', page_locale()) }}</label>
                                <input type="email" name="mail_from_address" value="{{ settings.mail_from_address }}" style="width:100%;border:1px solid var(--ng-border);border-radius:var(--ng-radius);padding:0.5rem 0.75rem;font-size:0.875rem;background:var(--ng-surface);color:var(--ng-text);box-sizing:border-box;">
                            </div>
                            <div style="display:flex;flex-direction:column;gap:0.375rem;">
                                <label style="font-size:0.8125rem;font-weight:500;color:var(--ng-text);">{{ t('admin_webinterface_mail_reply_to', page_locale()) }}</label>
                                <input type="email" name="mail_reply_to" value="{{ settings.mail_reply_to }}" style="width:100%;border:1px solid var(--ng-border);border-radius:var(--ng-radius);padding:0.5rem 0.75rem;font-size:0.875rem;background:var(--ng-surface);color:var(--ng-text);box-sizing:border-box;">
                            </div>
                            <div style="display:flex;flex-direction:column;gap:0.375rem;">
                                <label style="font-size:0.8125rem;font-weight:500;color:var(--ng-text);">{{ t('admin_webinterface_mail_default_locale', page_locale()) }}</label>
                                <select name="mail_default_locale" style="width:100%;border:1px solid var(--ng-border);border-radius:var(--ng-radius);padding:0.5rem 0.75rem;font-size:0.875rem;background:var(--ng-surface);color:var(--ng-text);box-sizing:border-box;">
                                    <option value="de" {{ settings.mail_default_locale == 'de' ? 'selected' : '' }}>DE</option>
                                    <option value="en" {{ settings.mail_default_locale == 'en' ? 'selected' : '' }}>EN</option>
                                </select>
                            </div>
                        </div>

                        {# SMTP Konfiguration #}
                        <div style="border:1px solid var(--ng-border);border-radius:var(--ng-radius);overflow:hidden;">
                            <div style="padding:0.75rem 1rem;background:var(--ng-surface-soft);border-bottom:1px solid var(--ng-border);">
                                <h3 style="margin:0;font-size:0.875rem;font-weight:600;color:var(--ng-text);">{{ t('admin_settings_smtp_section', page_locale()) }}</h3>
                            </div>
                            <div style="padding:1rem;display:flex;flex-direction:column;gap:1rem;">
                                {# Backend selection #}
                                <div style="display:flex;flex-direction:column;gap:0.5rem;">
                                    <label style="font-size:0.8125rem;font-weight:500;color:var(--ng-text);">{{ t('admin_settings_mail_backend_label', page_locale()) }}</label>
                                    <div style="display:flex;flex-wrap:wrap;gap:0.75rem;">
                                        {% for optKey, optLabel in mail_backend_options %}
                                            <label style="display:inline-flex;align-items:center;gap:0.375rem;font-size:0.875rem;color:var(--ng-text);cursor:pointer;">
                                                <input type="radio" name="smtp_backend" value="{{ optKey }}" {% if settings.smtp_backend is defined and settings.smtp_backend == optKey %}checked{% elseif optKey == 'none' and settings.smtp_backend is not defined %}checked{% endif %}>
                                                {{ optLabel }}
                                            </label>
                                        {% endfor %}
                                    </div>
                                </div>

                                {# External SMTP fields #}
                                <div id="smtp-external-fields" style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
                                    <div style="display:flex;flex-direction:column;gap:0.375rem;">
                                        <label style="font-size:0.8125rem;font-weight:500;color:var(--ng-text);">{{ t('admin_settings_smtp_host', page_locale()) }}</label>
                                        <input type="text" name="smtp_host" value="{{ settings.smtp_host is defined ? settings.smtp_host : '' }}" placeholder="mail.example.com" style="width:100%;border:1px solid var(--ng-border);border-radius:var(--ng-radius);padding:0.5rem 0.75rem;font-size:0.875rem;background:var(--ng-surface);color:var(--ng-text);box-sizing:border-box;">
                                    </div>
                                    <div style="display:flex;flex-direction:column;gap:0.375rem;">
                                        <label style="font-size:0.8125rem;font-weight:500;color:var(--ng-text);">{{ t('admin_settings_smtp_port', page_locale()) }}</label>
                                        <input type="number" name="smtp_port" value="{{ settings.smtp_port is defined ? settings.smtp_port : '587' }}" placeholder="587" style="width:100%;border:1px solid var(--ng-border);border-radius:var(--ng-radius);padding:0.5rem 0.75rem;font-size:0.875rem;background:var(--ng-surface);color:var(--ng-text);box-sizing:border-box;">
                                    </div>
                                    <div style="display:flex;flex-direction:column;gap:0.375rem;">
                                        <label style="font-size:0.8125rem;font-weight:500;color:var(--ng-text);">{{ t('admin_settings_smtp_user', page_locale()) }}</label>
                                        <input type="text" name="smtp_user" value="{{ settings.smtp_user is defined ? settings.smtp_user : '' }}" style="width:100%;border:1px solid var(--ng-border);border-radius:var(--ng-radius);padding:0.5rem 0.75rem;font-size:0.875rem;background:var(--ng-surface);color:var(--ng-text);box-sizing:border-box;">
                                    </div>
                                    <div style="display:flex;flex-direction:column;gap:0.375rem;">
                                        <label style="font-size:0.8125rem;font-weight:500;color:var(--ng-text);">{{ t('admin_settings_smtp_password', page_locale()) }}</label>
                                        <input type="password" name="smtp_password" placeholder="●●●●●●●●" style="width:100%;border:1px solid var(--ng-border);border-radius:var(--ng-radius);padding:0.5rem 0.75rem;font-size:0.875rem;background:var(--ng-surface);color:var(--ng-text);box-sizing:border-box;">
                                    </div>
                                    <div style="grid-column:span 2;">
                                        <label style="display:inline-flex;align-items:center;gap:0.5rem;font-size:0.875rem;color:var(--ng-text);cursor:pointer;">
                                            <input type="checkbox" name="mailer_verify_tls" value="1" {{ (settings.mailer_verify_tls is defined and settings.mailer_verify_tls) ? 'checked' : '' }}>
                                            {{ t('admin_settings_smtp_tls_verify', page_locale()) }}
                                        </label>
                                    </div>
                                </div>

                                {# DSN Info #}
                                <div style="background:var(--ng-surface-soft);border:1px solid var(--ng-border);border-radius:var(--ng-radius);padding:0.75rem;font-size:0.8125rem;color:var(--ng-text-muted);">
                                    {{ t('admin_settings_mailer_dsn_label', page_locale()) }}: <code style="font-family:monospace;background:var(--ng-border);padding:0.1rem 0.4rem;border-radius:4px;">{{ settings.mailer_dsn is defined ? settings.mailer_dsn : '—' }}</code>
                                </div>

                                {# Mail enabled toggle #}
                                <div>
                                    <label style="display:inline-flex;align-items:center;gap:0.5rem;font-size:0.875rem;color:var(--ng-text);cursor:pointer;">
                                        <input type="checkbox" name="mail_enabled" value="1" {{ (settings.mail_enabled is defined and settings.mail_enabled) ? 'checked' : '' }}>
                                        Mail-Versand aktiviert
                                    </label>
                                </div>
                            </div>
                        </div>
                    </div>

                {# ── Gameserver ── #}
                {% elseif activeTab == 'gameserver' %}
                    <div style="display:flex;flex-direction:column;gap:1.5rem;">
                        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;">
                            <div style="display:flex;flex-direction:column;gap:0.375rem;">
                                <label style="font-size:0.8125rem;font-weight:500;color:var(--ng-text);">{{ t('admin_webinterface_gameserver_default_slots', page_locale()) }}</label>
                                <input type="number" min="1" name="gameserver_default_slots" value="{{ settings.gameserver_default_slots }}" style="width:100%;border:1px solid var(--ng-border);border-radius:var(--ng-radius);padding:0.5rem 0.75rem;font-size:0.875rem;background:var(--ng-surface);color:var(--ng-text);box-sizing:border-box;">
                            </div>
                            <div style="display:flex;flex-direction:column;gap:0.375rem;">
                                <label style="font-size:0.8125rem;font-weight:500;color:var(--ng-text);">{{ t('admin_webinterface_gameserver_min_slots', page_locale()) }}</label>
                                <input type="number" min="1" name="gameserver_min_slots" value="{{ settings.gameserver_min_slots }}" style="width:100%;border:1px solid var(--ng-border);border-radius:var(--ng-radius);padding:0.5rem 0.75rem;font-size:0.875rem;background:var(--ng-surface);color:var(--ng-text);box-sizing:border-box;">
                            </div>
                            <div style="display:flex;flex-direction:column;gap:0.375rem;">
                                <label style="font-size:0.8125rem;font-weight:500;color:var(--ng-text);">{{ t('admin_webinterface_gameserver_max_slots', page_locale()) }}</label>
                                <input type="number" min="1" name="gameserver_max_slots" value="{{ settings.gameserver_max_slots }}" style="width:100%;border:1px solid var(--ng-border);border-radius:var(--ng-radius);padding:0.5rem 0.75rem;font-size:0.875rem;background:var(--ng-surface);color:var(--ng-text);box-sizing:border-box;">
                            </div>
                            <div style="grid-column:span 3;display:flex;flex-wrap:wrap;gap:1.5rem;">
                                <label style="display:inline-flex;align-items:center;gap:0.5rem;font-size:0.875rem;color:var(--ng-text);cursor:pointer;">
                                    <input type="checkbox" name="gameserver_show_port_range" value="1" {{ settings.gameserver_show_port_range ? 'checked' : '' }}>
                                    {{ t('admin_webinterface_gameserver_show_port_range', page_locale()) }}
                                </label>
                                <label style="display:inline-flex;align-items:center;gap:0.5rem;font-size:0.875rem;color:var(--ng-text);cursor:pointer;">
                                    <input type="checkbox" name="gameserver_allow_start_stop" value="1" {{ settings.gameserver_allow_start_stop ? 'checked' : '' }}>
                                    {{ t('admin_webinterface_gameserver_allow_start_stop', page_locale()) }}
                                </label>
                            </div>
                        </div>

                        <details style="border:1px solid var(--ng-border);border-radius:var(--ng-radius);">
                            <summary style="cursor:pointer;padding:0.75rem 1rem;font-size:0.875rem;font-weight:600;color:var(--ng-text);">{{ t('admin_settings_core_section', page_locale()) }}</summary>
                            <div style="border-top:1px solid var(--ng-border);padding:1rem;">
                                <div style="display:flex;flex-direction:column;gap:0.375rem;">
                                    <label style="font-size:0.8125rem;font-weight:500;color:var(--ng-text);">{{ t('admin_settings_instance_base_dir', page_locale()) }}</label>
                                    <input type="text" name="instance_base_dir" value="{{ settings.instance_base_dir }}" placeholder="/home" style="width:100%;border:1px solid var(--ng-border);border-radius:var(--ng-radius);padding:0.5rem 0.75rem;font-size:0.875rem;background:var(--ng-surface);color:var(--ng-text);box-sizing:border-box;">
                                    <p style="margin:0.25rem 0 0;font-size:0.75rem;color:var(--ng-text-muted);">{{ t('admin_settings_instance_base_dir_hint', page_locale()) }}</p>
                                </div>
                            </div>
                        </details>

                        <details style="border:1px solid var(--ng-border);border-radius:var(--ng-radius);">
                            <summary style="cursor:pointer;padding:0.75rem 1rem;font-size:0.875rem;font-weight:600;color:var(--ng-text);">{{ t('admin_settings_sftp_section', page_locale()) }}</summary>
                            <div style="border-top:1px solid var(--ng-border);padding:1rem;">
                                <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
                                    <div style="display:flex;flex-direction:column;gap:0.375rem;">
                                        <label style="font-size:0.8125rem;font-weight:500;color:var(--ng-text);">{{ t('admin_settings_sftp_host', page_locale()) }}</label>
                                        <input type="text" name="sftp_host" value="{{ settings.sftp_host }}" placeholder="node.example.com" style="width:100%;border:1px solid var(--ng-border);border-radius:var(--ng-radius);padding:0.5rem 0.75rem;font-size:0.875rem;background:var(--ng-surface);color:var(--ng-text);box-sizing:border-box;">
                                    </div>
                                    <div style="display:flex;flex-direction:column;gap:0.375rem;">
                                        <label style="font-size:0.8125rem;font-weight:500;color:var(--ng-text);">{{ t('admin_settings_sftp_port', page_locale()) }}</label>
                                        <input type="text" name="sftp_port" value="{{ settings.sftp_port }}" placeholder="22" style="width:100%;border:1px solid var(--ng-border);border-radius:var(--ng-radius);padding:0.5rem 0.75rem;font-size:0.875rem;background:var(--ng-surface);color:var(--ng-text);box-sizing:border-box;">
                                    </div>
                                    <div style="display:flex;flex-direction:column;gap:0.375rem;">
                                        <label style="font-size:0.8125rem;font-weight:500;color:var(--ng-text);">{{ t('admin_settings_sftp_username', page_locale()) }}</label>
                                        <input type="text" name="sftp_username" value="{{ settings.sftp_username }}" placeholder="easywi" style="width:100%;border:1px solid var(--ng-border);border-radius:var(--ng-radius);padding:0.5rem 0.75rem;font-size:0.875rem;background:var(--ng-surface);color:var(--ng-text);box-sizing:border-box;">
                                    </div>
                                    <div style="display:flex;flex-direction:column;gap:0.375rem;">
                                        <label style="font-size:0.8125rem;font-weight:500;color:var(--ng-text);">{{ t('admin_settings_sftp_password', page_locale()) }}</label>
                                        <input type="password" name="sftp_password" placeholder="{{ t('admin_settings_secret_placeholder', page_locale()) }}" style="width:100%;border:1px solid var(--ng-border);border-radius:var(--ng-radius);padding:0.5rem 0.75rem;font-size:0.875rem;background:var(--ng-surface);color:var(--ng-text);box-sizing:border-box;">
                                    </div>
                                    <div style="display:flex;flex-direction:column;gap:0.375rem;grid-column:span 2;">
                                        <label style="font-size:0.8125rem;font-weight:500;color:var(--ng-text);">{{ t('admin_settings_sftp_private_key', page_locale()) }}</label>
                                        <textarea name="sftp_private_key" rows="4" placeholder="{{ t('admin_settings_secret_placeholder', page_locale()) }}" style="width:100%;border:1px solid var(--ng-border);border-radius:var(--ng-radius);padding:0.5rem 0.75rem;font-size:0.875rem;background:var(--ng-surface);color:var(--ng-text);box-sizing:border-box;font-family:monospace;resize:vertical;"></textarea>
                                    </div>
                                    <div style="display:flex;flex-direction:column;gap:0.375rem;">
                                        <label style="font-size:0.8125rem;font-weight:500;color:var(--ng-text);">{{ t('admin_settings_sftp_private_key_path', page_locale()) }}</label>
                                        <input type="text" name="sftp_private_key_path" value="{{ settings.sftp_private_key_path }}" placeholder="/home/easywi/.ssh/id_ed25519" style="width:100%;border:1px solid var(--ng-border);border-radius:var(--ng-radius);padding:0.5rem 0.75rem;font-size:0.875rem;background:var(--ng-surface);color:var(--ng-text);box-sizing:border-box;">
                                    </div>
                                    <div style="display:flex;flex-direction:column;gap:0.375rem;">
                                        <label style="font-size:0.8125rem;font-weight:500;color:var(--ng-text);">{{ t('admin_settings_sftp_private_key_passphrase', page_locale()) }}</label>
                                        <input type="password" name="sftp_private_key_passphrase" placeholder="{{ t('admin_settings_secret_placeholder', page_locale()) }}" style="width:100%;border:1px solid var(--ng-border);border-radius:var(--ng-radius);padding:0.5rem 0.75rem;font-size:0.875rem;background:var(--ng-surface);color:var(--ng-text);box-sizing:border-box;">
                                    </div>
                                </div>
                                <p style="margin:0.75rem 0 0;font-size:0.75rem;color:var(--ng-text-muted);">{{ t('admin_settings_secret_hint', page_locale()) }}</p>
                            </div>
                        </details>
                    </div>

                {# ── Customer ── #}
                {% elseif activeTab == 'customer' %}
                    <div style="display:flex;flex-direction:column;gap:1.25rem;">
                        <div style="display:flex;flex-wrap:wrap;gap:1.5rem;">
                            <label style="display:inline-flex;align-items:center;gap:0.5rem;font-size:0.875rem;color:var(--ng-text);cursor:pointer;">
                                <input type="checkbox" name="customer_data_manager_enabled" value="1" {{ settings.customer_data_manager_enabled ? 'checked' : '' }}>
                                {{ t('admin_webinterface_customer_data_manager', page_locale()) }}
                            </label>
                            <label style="display:inline-flex;align-items:center;gap:0.5rem;font-size:0.875rem;color:var(--ng-text);cursor:pointer;">
                                <input type="checkbox" name="customer_file_push_enabled" value="1" {{ settings.customer_file_push_enabled ? 'checked' : '' }}>
                                {{ t('admin_webinterface_customer_file_push', page_locale()) }}
                            </label>
                        </div>
                        <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
