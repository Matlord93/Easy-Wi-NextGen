                                    </div>
                                </div>
                            </div>
                        </details>

                        <div class="ng-card" style="border:1px solid var(--ng-border);border-radius:var(--ng-radius);">
                            <div style="padding:1rem;border-bottom:1px solid var(--ng-border);display:flex;align-items:center;justify-content:space-between;">
                                <div>
                                    <h2 style="font-size:0.9375rem;font-weight:600;color:var(--ng-text);margin:0 0 0.25rem;">{{ t('admin_webinterface_security_2fa_overview', page_locale()) }}</h2>
