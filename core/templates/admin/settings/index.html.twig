                                    <div style="display:flex;flex-direction:column;gap:0.375rem;">
                                        <label style="font-size:0.8125rem;font-weight:500;color:var(--ng-text);">{{ t('admin_webinterface_security_pow_difficulty', page_locale()) }}</label>
                                        <input type="number" min="0" max="6" name="anti_abuse_pow_difficulty" value="{{ settings.anti_abuse_pow_difficulty }}" style="width:100%;border:1px solid var(--ng-border);border-radius:var(--ng-radius);padding:0.5rem 0.75rem;font-size:0.875rem;background:var(--ng-surface);color:var(--ng-text);box-sizing:border-box;">
