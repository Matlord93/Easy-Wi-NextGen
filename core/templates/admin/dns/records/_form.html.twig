<div class="ng-data-card__header">
    <div>
        <h2 class="ng-data-card__title">{{ form.action == 'create' ? t('admin_dns_create_title', page_locale()) : t('admin_dns_edit_title', page_locale()) }}</h2>
        <p class="ng-data-card__sub">{{ t('admin_dns_form_intro', page_locale()) }}</p>
    </div>
</div>
<div class="ng-data-card__body">
    {% if form.errors is not empty %}
        <div class="ng-alert ng-alert--danger mb-4">
            <p class="font-semibold">{{ t('admin_form_fix_following', page_locale()) }}</p>
            <ul class="list-disc pl-5 mt-2">
                {% for error in form.errors %}
                    <li>{{ error }}</li>
                {% endfor %}
            </ul>
        </div>
    {% endif %}
    <form
        class="flex flex-col gap-4"
        hx-post="{{ form.action_url }}"
        hx-target="#dns-record-form"
        hx-swap="outerHTML"
    >
        <div class="form-field">
            <label class="form-label">{{ t('admin_dns_domain_label', page_locale()) }}</label>
            <select name="domain_id" class="form-input">
                {% for domain in domains %}
                    <option value="{{ domain.id }}" {{ domain.id == form.domain_id ? 'selected' : '' }}>{{ domain.name }}</option>
                {% else %}
                    <option value="">{{ t('admin_dns_no_domains', page_locale()) }}</option>
                {% endfor %}
            </select>
        </div>
        <div class="grid grid-cols-2 gap-4">
            <div class="form-field">
                <label class="form-label">{{ t('admin_dns_name_label', page_locale()) }}</label>
                <input name="name" value="{{ form.name }}" placeholder="@" class="form-input">
            </div>
            <div class="form-field">
                <label class="form-label">{{ t('admin_dns_type_label', page_locale()) }}</label>
                <select name="type" class="form-input">
                    {% for type in recordTypes %}
                        <option value="{{ type }}" {{ type == form.type ? 'selected' : '' }}>{{ type }}</option>
                    {% endfor %}
                </select>
            </div>
        </div>
        <div class="form-field">
            <label class="form-label">{{ t('admin_dns_content_label', page_locale()) }}</label>
            <input name="content" value="{{ form.content }}" placeholder="192.0.2.10" class="form-input">
        </div>
        <div class="grid grid-cols-2 gap-4">
            <div class="form-field">
                <label class="form-label">{{ t('admin_dns_ttl_label', page_locale()) }}</label>
                <input name="ttl" type="number" value="{{ form.ttl }}" min="60" max="86400" class="form-input">
            </div>
            <div class="form-field">
                <label class="form-label">{{ t('admin_dns_priority_label', page_locale()) }}</label>
                <input name="priority" type="number" value="{{ form.priority }}" placeholder="10" class="form-input">
            </div>
        </div>
        <div class="flex items-center gap-3">
            <button type="submit" class="ui-button ui-button--primary">{{ form.submit_label }}</button>
            <button
                type="button"
                class="ui-button ui-button--ghost"
                hx-get="/admin/dns/records/form"
                hx-target="#dns-record-form"
                hx-swap="outerHTML"
            >{{ t('reset', page_locale()) }}</button>
        </div>
    </form>
</div>
