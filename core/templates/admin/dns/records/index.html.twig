{% extends 'admin/base.html.twig' %}

{% set pageTitle = t('admin_dns_heading', page_locale()) %}
{% set pageSubtitle = t('admin_dns_intro', page_locale()) %}
{% set activeNav = 'dns-records' %}
{% set topbarActions %}
    <button
        class="ui-button ui-button--ghost ui-button--sm"
        hx-get="/admin/dns/records/table"
        hx-target="#dns-records-table"
        hx-swap="outerHTML"
    >{{ t('refresh', page_locale()) }}</button>
    <button
        class="ui-button ui-button--primary ui-button--sm"
        hx-get="/admin/dns/records/form"
        hx-target="#dns-record-form"
        hx-swap="outerHTML"
    >{{ t('admin_dns_new_record', page_locale()) }}</button>
{% endset %}

{% block content %}
<div class="flex flex-col gap-6">

    <div class="ng-kpi-row">
        <div class="ng-kpi-box">
            <div class="ng-kpi-box__label">{{ t('admin_dns_total_records', page_locale()) }}</div>
            <div class="ng-kpi-box__value">{{ summary.total }}</div>
        </div>
        <div class="ng-kpi-box">
            <div class="ng-kpi-box__label">{{ t('admin_dns_a_records', page_locale()) }}</div>
            <div class="ng-kpi-box__value ng-kpi-box__value--primary">{{ summary.byType.A ?? 0 }}</div>
        </div>
        <div class="ng-kpi-box">
            <div class="ng-kpi-box__label">{{ t('admin_dns_cname_records', page_locale()) }}</div>
            <div class="ng-kpi-box__value ng-kpi-box__value--success">{{ summary.byType.CNAME ?? 0 }}</div>
        </div>
        <div class="ng-kpi-box">
            <div class="ng-kpi-box__label">{{ t('admin_dns_mx_records', page_locale()) }}</div>
            <div class="ng-kpi-box__value ng-kpi-box__value--warning">{{ summary.byType.MX ?? 0 }}</div>
        </div>
    </div>

    <div class="ng-layout-2col">
        <div id="dns-record-form" class="ng-data-card">
            <div class="ng-data-card__body">
                {% include 'admin/dns/records/_form.html.twig' with { domains: domains, recordTypes: recordTypes, form: form } %}
            </div>
        </div>

        <div id="dns-records-table" class="ng-data-card"
             hx-get="/admin/dns/records/table"
             hx-trigger="dns-records-changed from:body"
             hx-swap="outerHTML">
            <div class="ng-data-card__body--flush">
                {% include 'admin/dns/records/_table.html.twig' with { records: records } %}
            </div>
        </div>
    </div>

</div>
{% endblock %}
