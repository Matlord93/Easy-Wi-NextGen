<div class="ng-data-card__header">
    <div>
        <h2 class="ng-data-card__title">{{ t('admin_dns_inventory_title', page_locale()) }}</h2>
        <p class="ng-data-card__sub">{{ t('admin_dns_inventory_intro', page_locale()) }}</p>
    </div>
    <div class="ng-data-card__actions">
        <button
            class="ui-button ui-button--ghost ui-button--sm"
            hx-get="/admin/dns/records/table"
            hx-target="#dns-records-table"
            hx-swap="outerHTML"
        >{{ t('refresh', page_locale()) }}</button>
    </div>
</div>
<div class="cust-ws-table-wrap">
    <table class="cust-table">
        <thead>
        <tr>
            <th>{{ t('admin_dns_table_domain', page_locale()) }}</th>
            <th>{{ t('admin_dns_table_name', page_locale()) }}</th>
            <th>{{ t('admin_dns_table_type', page_locale()) }}</th>
            <th>{{ t('admin_dns_table_content', page_locale()) }}</th>
            <th>{{ t('admin_dns_table_ttl', page_locale()) }}</th>
            <th>{{ t('admin_dns_table_priority', page_locale()) }}</th>
            <th>{{ t('admin_dns_table_updated', page_locale()) }}</th>
            <th>{{ t('admin_dns_table_actions', page_locale()) }}</th>
        </tr>
        </thead>
        <tbody>
        {% for record in records %}
            <tr>
                <td>
                    <div class="font-semibold" style="color:var(--ng-text);">{{ record.domain.name }}</div>
                    <div style="font-size:11px;color:var(--ng-text-muted);">{{ t('admin_label_id', page_locale()) }} {{ record.domain.id }}</div>
                </td>
                <td class="font-semibold" style="color:var(--ng-text);">{{ record.name }}</td>
                <td>
                    <span class="ui-badge ui-badge--info">{{ record.type }}</span>
                </td>
                <td style="color:var(--ng-text-muted);">{{ record.content }}</td>
                <td style="color:var(--ng-text-muted);">{{ record.ttl }}</td>
                <td style="color:var(--ng-text-muted);">{{ record.priority ?? '—' }}</td>
                <td style="font-size:11px;color:var(--ng-text-muted);">{{ record.updatedAt|date('Y-m-d H:i') }}</td>
                <td>
                    <div class="flex items-center gap-2">
                        <button
                            class="ui-button ui-button--ghost ui-button--sm"
                            hx-get="/admin/dns/records/{{ record.id }}/edit"
                            hx-target="#dns-record-form"
                            hx-swap="outerHTML"
                        >{{ t('edit', page_locale()) }}</button>
                        <button
                            class="ui-button ui-button--danger ui-button--sm"
                            hx-post="/admin/dns/records/{{ record.id }}/delete"
                            hx-confirm="{{ t('admin_dns_delete_confirm', page_locale()) }}"
                        >{{ t('delete', page_locale()) }}</button>
                    </div>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="8" class="cust-table__empty">{{ t('admin_dns_empty', page_locale()) }}</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
</div>
