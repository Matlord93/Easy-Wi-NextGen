{% extends 'admin/base.html.twig' %}
{% block title %}{{ t('admin_mail_matrix_title', page_locale()) }}{% endblock %}
{% block content %}
<section class="space-y-4" data-mail-matrix data-health-endpoint="{{ healthEndpoint }}" data-metrics-endpoint="{{ metricsEndpoint }}" data-repair-endpoint-base="{{ repairEndpointBase }}">
  <header class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold">{{ t('admin_mail_matrix_title', page_locale()) }}</h1>
      <p class="text-sm text-slate-600">{{ t('admin_mail_matrix_subtitle', page_locale()) }}</p>
    </div>
    <div class="flex gap-2">
      <button data-action="reload" class="rounded-md border px-3 py-2 text-sm">{{ t('admin_mail_health_action_refresh', page_locale()) }}</button>
      <a href="/admin/mail/health" class="rounded-md border px-3 py-2 text-sm">{{ t('admin_mail_matrix_action_health', page_locale()) }}</a>
      <span class="text-xs text-slate-600">{{ t('admin_mail_repair_running', page_locale()) }}</span>
    </div>
  </header>
  <div class="flex gap-3 items-center text-sm">
    <input data-filter="search" placeholder="{{ t('admin_mail_matrix_filter_search', page_locale()) }}" class="rounded border px-2 py-1" />
    <label><input type="checkbox" data-filter="errors"> {{ t('admin_mail_matrix_filter_errors', page_locale()) }}</label>
    <label><input type="checkbox" data-filter="online"> {{ t('admin_mail_matrix_filter_online', page_locale()) }}</label>
    <label><input type="checkbox" data-filter="queue"> {{ t('admin_mail_matrix_filter_queue', page_locale()) }}</label>
  </div>
  <div data-state="error" class="hidden rounded border border-rose-200 bg-rose-50 p-3 text-rose-700 text-sm"></div>
  <div class="overflow-x-auto rounded border bg-white">
    <table class="min-w-full text-xs">
      <thead class="bg-slate-50"><tr>
        <th>Node</th><th>Agent-ID</th><th>Online</th><th>Status</th><th>Postfix</th><th>Dovecot</th><th>Queue</th><th>Deferred</th><th>Hold</th><th>Mailboxen</th><th>Domains</th><th>Aliase</th><th>Maildir Disk</th><th>Ports</th><th>Critical</th><th>Warnings</th><th>Last Seen</th><th>Actions</th>
      </tr></thead>
      <tbody data-table-body></tbody>
    </table>
  </div>
</section>
<script>
(()=>{const root=document.querySelector('[data-mail-matrix]');if(!root)return;
const e=document.querySelector('[data-state="error"]'),tb=root.querySelector('[data-table-body]');
const f={s:root.querySelector('[data-filter="search"]'),er:root.querySelector('[data-filter="errors"]'),on:root.querySelector('[data-filter="online"]'),q:root.querySelector('[data-filter="queue"]')};
let rows=[];const b=(v,g='emerald')=>`<span class="px-1 rounded bg-${g}-100 text-${g}-800">${v}</span>`;
const esc=(v)=>String(v??'').replace(/[&<>"']/g,m=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[m]));
const ports=(p)=>['25','465','587','110','143','993','995'].map(k=>`<span class="${p?.[k]?'text-emerald-700':'text-slate-400'}">${k}</span>`).join(' ');
function render(){const q=(f.s.value||'').toLowerCase();tb.innerHTML=rows.filter(r=>{if(q&&!(`${r.name} ${r.agent_id}`.toLowerCase().includes(q)))return false;if(f.er.checked&&r.critical===0&&r.warn===0)return false;if(f.on.checked&&!r.online)return false;if(f.q.checked&&r.queue===0)return false;return true;}).map(r=>`<tr class="border-t"><td>${esc(r.name)}</td><td>${esc(r.agent_id)}</td><td>${r.online?b('online'):b('offline','rose')}</td><td>${r.ok?b('OK'):b('Error','rose')}</td><td>${r.postfix?b('up'):b('down','rose')}</td><td>${r.dovecot?b('up'):b('down','rose')}</td><td>${r.queue>0?b(r.queue,'amber'):r.queue}</td><td>${r.def>0?b(r.def,'amber'):r.def}</td><td>${r.hold}</td><td>${r.mb}</td><td>${r.dom}</td><td>${r.al}</td><td>${r.disk}</td><td>${ports(r.ports)}</td><td>${r.critical>0?b(r.critical,'rose'):r.critical}</td><td>${r.warn>0?b(r.warn,'amber'):r.warn}</td><td>${esc(r.last_seen_at||'—')}</td><td><button class="border rounded px-1" data-details='${esc(JSON.stringify(r.details))}'>{{ t('admin_mail_health_action_details', page_locale()) }}</button> <button class="border rounded px-1" data-repair="${esc(String(r.id||''))}" ${r.agent_id ? '' : 'disabled'}>{{ t('admin_mail_repair_action', page_locale()) }}</button></td></tr><tr class="hidden" data-detail-row><td colspan="18" class="bg-slate-50 text-xs p-2"></td></tr>`).join('');}
async function load(){try{e.classList.add('hidden');const [h,m]=await Promise.all([fetch(root.dataset.healthEndpoint),fetch(root.dataset.metricsEndpoint)]);if(!h.ok||!m.ok)throw new Error('http');const hp=await h.json(),mp=await m.json();const hm=new Map((hp.nodes||[]).map(n=>[String(n.agent_id??n.id),n]));const repairBase=root.dataset.repairEndpointBase;rows=(mp.nodes||[]).map(n=>{const h=hm.get(String(n.agent_id??n.id))||{};const mt=n.metrics||{};return {id:n.id,name:n.name,agent_id:n.agent_id,online:!!n.online,ok:!!h.overall_ok,postfix:!!mt.postfix_active,dovecot:!!mt.dovecot_active,queue:+(mt.queue_total||0),def:+(mt.queue_deferred||0),hold:+(mt.queue_hold||0),mb:+(mt.mailbox_count||0),dom:+(mt.domain_count||0),al:+(mt.alias_count||0),disk:+(mt.maildir_disk_bytes||0),ports:mt.ports||{},critical:(h.critical_failures||[]).length,warn:(n.warnings||[]).length,last_seen_at:n.last_seen_at,details:{critical:h.critical_failures||[],warnings:n.warnings||[],checks:h.checks||{}}};});render();}catch(_){e.textContent='Matrix data could not be loaded.';e.classList.remove('hidden');}}
root.addEventListener('change',render);root.addEventListener('input',render);root.addEventListener('click',(ev)=>{const t=ev.target;if(!(t instanceof HTMLElement))return;if(t.dataset.action==='reload')load();if(t.dataset.repair){const id=t.dataset.repair;if(confirm('{{ t('admin_mail_repair_confirm', page_locale()) }}')){fetch(`${root.dataset.repairEndpointBase}/${id}/repair`,{method:'POST',headers:{'Accept':'application/json','X-Admin-Request':'1'}}).then(r=>r.json().then(p=>({ok:r.ok,p}))).then(({ok,p})=>{if(!ok)throw new Error(p.error||'failed');alert(`{{ t('admin_mail_repair_success', page_locale()) }} #${p.job_id}`);load();}).catch(err=>alert(`{{ t('admin_mail_repair_failed', page_locale()) }}: ${err.message}`));}}
if(t.dataset.action==='roundcube-install'||t.dataset.action==='roundcube-deploy'){const id=t.dataset.nodeId||t.dataset.repair; const action=t.dataset.action==='roundcube-install'?'install':'deploy'; if(id&&confirm('{{ t('admin_roundcube_confirm', page_locale()) }}')){fetch(`/api/v1/admin/mail/nodes/${id}/roundcube/${action}`,{method:'POST',headers:{'Accept':'application/json','X-Admin-Request':'1'}}).then(r=>r.json().then(p=>({ok:r.ok,p}))).then(({ok,p})=>{if(!ok)throw new Error(p.error||'failed'); alert(`{{ t('admin_roundcube_success', page_locale()) }} #${p.job_id}`); loadHealth?loadHealth():load();}).catch(err=>alert(`{{ t('admin_roundcube_failed', page_locale()) }}: ${err.message}`));}}
if(t.dataset.details){const tr=t.closest('tr')?.nextElementSibling;if(tr){tr.classList.toggle('hidden');tr.firstElementChild.textContent=t.dataset.details;}}});load();})();
</script>
{% endblock %}
