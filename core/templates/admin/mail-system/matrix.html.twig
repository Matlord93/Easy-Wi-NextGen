{% extends 'admin/base.html.twig' %}
{% set pageTitle = t('admin_mail_matrix_title', page_locale()) %}
{% set activeNav = 'mail-matrix' %}
{% block content %}
{% set locale = page_locale() %}
<div style="display:flex;flex-direction:column;gap:20px;" data-mail-matrix data-health-endpoint="{{ healthEndpoint }}" data-metrics-endpoint="{{ metricsEndpoint }}" data-repair-endpoint-base="{{ repairEndpointBase }}">

  <section class="ng-card" style="overflow:hidden;">
    <div class="tkt-hero">
      <div class="tkt-hero__inner">
        <div>
          <div class="tkt-hero__pill"><span class="tkt-hero__pill-dot"></span> Mail System</div>
          <h1 class="tkt-hero__title" style="margin-top:10px;">{{ t('admin_mail_matrix_title', locale) }}</h1>
          <p class="tkt-hero__sub">{{ t('admin_mail_matrix_subtitle', locale) }}</p>
        </div>
      </div>
    </div>
    <div style="padding:14px 16px;border-top:1px solid var(--ng-border);background:var(--ng-surface-soft);display:flex;align-items:center;gap:8px;flex-wrap:wrap;">
      <button data-action="reload" class="ui-button ui-button--ghost ui-button--sm">{{ t('admin_mail_health_action_refresh', locale) }}</button>
      <a href="/admin/mail/health" class="ui-button ui-button--ghost ui-button--sm">{{ t('admin_mail_matrix_action_health', locale) }}</a>
      <span style="font-size:12px;color:var(--ng-text-muted);">{{ t('admin_mail_repair_running', locale) }}</span>
    </div>
  </section>

  <div class="ng-data-card">
    <div class="ng-data-card__header">
      <div>
        <h2 class="ng-data-card__title">{{ t('admin_mail_matrix_title', locale) }}</h2>
      </div>
    </div>
    <div class="ng-data-card__body" style="padding-bottom:0;">
      <div style="display:flex;gap:12px;align-items:center;flex-wrap:wrap;margin-bottom:12px;">
        <input data-filter="search" placeholder="{{ t('admin_mail_matrix_filter_search', locale) }}" class="form-input" style="max-width:200px;" />
        <label style="display:flex;align-items:center;gap:6px;font-size:13px;"><input type="checkbox" data-filter="errors"> {{ t('admin_mail_matrix_filter_errors', locale) }}</label>
        <label style="display:flex;align-items:center;gap:6px;font-size:13px;"><input type="checkbox" data-filter="online"> {{ t('admin_mail_matrix_filter_online', locale) }}</label>
        <label style="display:flex;align-items:center;gap:6px;font-size:13px;"><input type="checkbox" data-filter="queue"> {{ t('admin_mail_matrix_filter_queue', locale) }}</label>
      </div>
      <div data-state="error" style="display:none;" class="ng-alert ng-alert--danger"></div>
    </div>
    <div class="cust-ws-table-wrap">
      <table class="cust-table">
        <thead><tr>
          <th>Node</th><th>Agent-ID</th><th>{{ t('admin_mail_col_online', locale) }}</th><th>{{ t('status', locale) }}</th><th>Postfix</th><th>Dovecot</th><th>{{ t('admin_mail_col_queue', locale) }}</th><th>{{ t('admin_mail_col_deferred', locale) }}</th><th>{{ t('admin_mail_col_hold', locale) }}</th><th>{{ t('admin_mail_col_mailboxes', locale) }}</th><th>{{ t('admin_mail_col_domains', locale) }}</th><th>{{ t('admin_mail_col_aliases', locale) }}</th><th>{{ t('admin_mail_col_disk', locale) }}</th><th>{{ t('admin_mail_col_ports', locale) }}</th><th>{{ t('admin_mail_col_critical', locale) }}</th><th>{{ t('admin_mail_col_warnings', locale) }}</th><th>{{ t('admin_mail_col_last_seen', locale) }}</th><th>{{ t('actions', locale) }}</th>
        </tr></thead>
        <tbody data-table-body></tbody>
      </table>
    </div>
  </div>

</div>
<script>
(()=>{const root=document.querySelector('[data-mail-matrix]');if(!root)return;
const e=document.querySelector('[data-state="error"]'),tb=root.querySelector('[data-table-body]');
const f={s:root.querySelector('[data-filter="search"]'),er:root.querySelector('[data-filter="errors"]'),on:root.querySelector('[data-filter="online"]'),q:root.querySelector('[data-filter="queue"]')};
let rows=[];
const badgeClass=(v,type)=>{const m={ok:'ui-badge--success',warn:'ui-badge--warning',err:'ui-badge--danger',neutral:'ui-badge--neutral'};return `<span class="ui-badge ${m[type]||'ui-badge--neutral'}">${v}</span>`;};
const esc=(v)=>String(v??'').replace(/[&<>"']/g,m=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[m]));
const ports=(p)=>['25','465','587','110','143','993','995'].map(k=>`<span style="color:${p?.[k]?'var(--color-success,#16a34a)':'var(--ng-text-muted)'}">${k}</span>`).join(' ');
function render(){const q=(f.s.value||'').toLowerCase();tb.innerHTML=rows.filter(r=>{if(q&&!(`${r.name} ${r.agent_id}`.toLowerCase().includes(q)))return false;if(f.er.checked&&r.critical===0&&r.warn===0)return false;if(f.on.checked&&!r.online)return false;if(f.q.checked&&r.queue===0)return false;return true;}).map(r=>`<tr><td>${esc(r.name)}</td><td>${esc(r.agent_id)}</td><td>${r.online?badgeClass('online','ok'):badgeClass('offline','err')}</td><td>${r.ok?badgeClass('OK','ok'):badgeClass('Error','err')}</td><td>${r.postfix?badgeClass('up','ok'):badgeClass('down','err')}</td><td>${r.dovecot?badgeClass('up','ok'):badgeClass('down','err')}</td><td>${r.queue>0?badgeClass(r.queue,'warn'):r.queue}</td><td>${r.def>0?badgeClass(r.def,'warn'):r.def}</td><td>${r.hold}</td><td>${r.mb}</td><td>${r.dom}</td><td>${r.al}</td><td>${r.disk}</td><td>${ports(r.ports)}</td><td>${r.critical>0?badgeClass(r.critical,'err'):r.critical}</td><td>${r.warn>0?badgeClass(r.warn,'warn'):r.warn}</td><td>${esc(r.last_seen_at||'—')}</td><td style="display:flex;gap:4px;flex-wrap:wrap;"><button class="ui-button ui-button--ghost ui-button--sm" data-details='${esc(JSON.stringify(r.details))}'>{{ t('admin_mail_health_action_details', locale) }}</button> <button class="ui-button ui-button--ghost ui-button--sm" data-repair="${esc(String(r.id||''))}" ${r.agent_id ? '' : 'disabled'}>{{ t('admin_mail_repair_action', locale) }}</button></td></tr><tr class="hidden" data-detail-row><td colspan="18" style="background:var(--ng-surface-soft);font-size:12px;padding:8px;"></td></tr>`).join('')||'<tr><td colspan="18" class="cust-table__empty">{{ t('admin_mail_health_no_mail_nodes', locale)|e('js') }}</td></tr>';}
const MSG_LOAD_FAIL={{ t('admin_mail_matrix_load_error', locale)|json_encode|raw }};
async function load(){try{e.style.display='none';const [h,m]=await Promise.all([fetch(root.dataset.healthEndpoint),fetch(root.dataset.metricsEndpoint)]);if(!h.ok||!m.ok)throw new Error('http');const hp=await h.json(),mp=await m.json();const hm=new Map((hp.nodes||[]).map(n=>[String(n.agent_id??n.id),n]));const repairBase=root.dataset.repairEndpointBase;rows=(mp.nodes||[]).map(n=>{const h=hm.get(String(n.agent_id??n.id))||{};const mt=n.metrics||{};return {id:n.id,name:n.name,agent_id:n.agent_id,online:!!n.online,ok:!!h.overall_ok,postfix:!!mt.postfix_active,dovecot:!!mt.dovecot_active,queue:+(mt.queue_total||0),def:+(mt.queue_deferred||0),hold:+(mt.queue_hold||0),mb:+(mt.mailbox_count||0),dom:+(mt.domain_count||0),al:+(mt.alias_count||0),disk:+(mt.maildir_disk_bytes||0),ports:mt.ports||{},critical:(h.critical_failures||[]).length,warn:(n.warnings||[]).length,last_seen_at:n.last_seen_at,details:{critical:h.critical_failures||[],warnings:n.warnings||[],checks:h.checks||{}}};});render();}catch(_){e.textContent=MSG_LOAD_FAIL;e.style.display='';}}
root.addEventListener('change',render);root.addEventListener('input',render);root.addEventListener('click',(ev)=>{const t=ev.target;if(!(t instanceof HTMLElement))return;if(t.dataset.action==='reload')load();if(t.dataset.repair){const id=t.dataset.repair;if(confirm('{{ t('admin_mail_repair_confirm', locale) }}')){fetch(`${root.dataset.repairEndpointBase}/${id}/repair`,{method:'POST',headers:{'Accept':'application/json','X-Admin-Request':'1'}}).then(r=>r.json().then(p=>({ok:r.ok,p}))).then(({ok,p})=>{if(!ok)throw new Error(p.error||'failed');alert(`{{ t('admin_mail_repair_success', locale) }} #${p.job_id}`);load();}).catch(err=>alert(`{{ t('admin_mail_repair_failed', locale) }}: ${err.message}`));}}
if(t.dataset.action==='roundcube-install'||t.dataset.action==='roundcube-deploy'){const id=t.dataset.nodeId||t.dataset.repair; const action=t.dataset.action==='roundcube-install'?'install':'deploy'; if(id&&confirm('{{ t('admin_roundcube_confirm', locale) }}')){fetch(`/api/v1/admin/mail/nodes/${id}/roundcube/${action}`,{method:'POST',headers:{'Accept':'application/json','X-Admin-Request':'1'}}).then(r=>r.json().then(p=>({ok:r.ok,p}))).then(({ok,p})=>{if(!ok)throw new Error(p.error||'failed'); alert(`{{ t('admin_roundcube_success', locale) }} #${p.job_id}`); loadHealth?loadHealth():load();}).catch(err=>alert(`{{ t('admin_roundcube_failed', locale) }}: ${err.message}`));}}
if(t.dataset.details){const tr=t.closest('tr')?.nextElementSibling;if(tr){tr.classList.toggle('hidden');tr.firstElementChild.textContent=t.dataset.details;}}});load();})();
</script>
{% endblock %}
