{% extends 'admin/base.html.twig' %}

{% set pageTitle = t('admin_mail_system_title', page_locale()) %}
{% set pageSubtitle = t('admin_mail_system_intro', page_locale()) %}
{% set activeNav = 'mail-system' %}

{% block title %}{{ t('admin_mail_system_title', page_locale()) }} · Easy-Wi NextGen{% endblock %}

{% block content %}
{% set locale = page_locale() %}
<div class="flex flex-col gap-6">

    {# Header actions #}
    <div class="flex items-center justify-end gap-3">
        <a href="{{ path('admin_mailboxes') }}" class="ui-button ui-button--ghost ui-button--sm">{{ t('admin_nav_mailboxes', locale) }}</a>
        <a href="{{ path('admin_mail_aliases') }}" class="ui-button ui-button--primary ui-button--sm">{{ t('admin_nav_mail_aliases', locale) }}</a>
    </div>

    {# KPI summary #}
    <div class="ng-kpi-row">
        <div class="ng-kpi-box">
            <div class="ng-kpi-box__label">Nodes</div>
            <div class="ng-kpi-box__value">{{ summary.nodes }}</div>
        </div>
        <div class="ng-kpi-box">
            <div class="ng-kpi-box__label">Policies</div>
            <div class="ng-kpi-box__value">{{ summary.policies }}</div>
        </div>
        <div class="ng-kpi-box">
            <div class="ng-kpi-box__label">Domains</div>
            <div class="ng-kpi-box__value">{{ summary.domains }}</div>
        </div>
        <div class="ng-kpi-box">
            <div class="ng-kpi-box__label">Mailboxes</div>
            <div class="ng-kpi-box__value">{{ summary.mailboxes }}</div>
        </div>
        <div class="ng-kpi-box">
            <div class="ng-kpi-box__label">Aliases</div>
            <div class="ng-kpi-box__value">{{ summary.aliases }}</div>
        </div>
    </div>

    {# Mail server status #}
    <div class="ng-data-card">
        <div class="ng-data-card__header">
            <div>
                <h2 class="ng-data-card__title">Mail Server Status</h2>
                <p class="ng-data-card__sub">Letzte {{ status.window_hours }} Stunden (Postfix/Dovecot/OpenDKIM/Agent Logs)</p>
            </div>
            <div class="ng-data-card__actions">
                <a href="/api/v1/admin/mail/logs?limit=100" class="ui-button ui-button--ghost ui-button--sm">JSON Logs öffnen</a>
            </div>
        </div>
        <div class="ng-data-card__body">
            {# Log level KPIs #}
            <div class="ng-kpi-row mb-4">
                <div class="ng-kpi-box">
                    <div class="ng-kpi-box__label">Info</div>
                    <div class="ng-kpi-box__value ng-kpi-box__value--neutral">{{ status.levels.info|default(0) }}</div>
                </div>
                <div class="ng-kpi-box">
                    <div class="ng-kpi-box__label">Warnings</div>
                    <div class="ng-kpi-box__value ng-kpi-box__value--warning">{{ status.levels.warning|default(0) }}</div>
                </div>
                <div class="ng-kpi-box">
                    <div class="ng-kpi-box__label">Errors</div>
                    <div class="ng-kpi-box__value ng-kpi-box__value--danger">{{ status.levels.error|default(0) }}</div>
                </div>
                <div class="ng-kpi-box">
                    <div class="ng-kpi-box__label">Critical</div>
                    <div class="ng-kpi-box__value ng-kpi-box__value--danger">{{ status.levels.critical|default(0) }}</div>
                </div>
            </div>

            {# Sources #}
            <div class="mb-4">
                <h3 class="text-sm font-semibold text-slate-900 mb-2">Quellen</h3>
                {% if status.sources is empty %}
                    <p class="text-sm text-slate-600">{{ t('admin_mail_no_log_data', locale) }}</p>
                {% else %}
                    <div class="flex flex-wrap gap-2">
                        {% for source, total in status.sources %}
                            <span class="ui-badge ui-badge--neutral">{{ source }}: {{ total }}</span>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
        </div>

        {# Log entries table #}
        <div class="ng-data-card__body ng-data-card__body--flush">
            <div class="cust-ws-table-wrap">
                <table class="cust-table">
                    <thead>
                        <tr>
                            <th>Zeit</th>
                            <th>Domain</th>
                            <th>Source</th>
                            <th>Level</th>
                            <th>Event</th>
                            <th>Message</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% if status.recent is empty %}
                            <tr>
                                <td colspan="7" class="cust-table__empty">{{ t('admin_mail_no_entries', locale) }}</td>
                            </tr>
                        {% else %}
                            {% for row in status.recent %}
                                <tr>
                                    <td>{{ row.created_at|date('Y-m-d H:i:s') }}</td>
                                    <td>{{ row.domain }}</td>
                                    <td>{{ row.source }}</td>
                                    <td>{{ row.level }}</td>
                                    <td>{{ row.event_type }}</td>
                                    <td>{{ row.message|length > 140 ? row.message|slice(0, 140) ~ '…' : row.message }}</td>
                                    <td>
                                        <form method="post" action="{{ path('admin_mail_security_contain_domain') }}" onsubmit="return confirm('{{ t('admin_mail_security_contain_confirm', page_locale())|e('js') }}');" class="inline-flex">
                                            <input type="hidden" name="_token" value="{{ csrf.contain_domain }}">
                                            <input type="hidden" name="domain_id" value="{{ row.domain_id }}">
                                            <button type="submit" class="ui-button ui-button--danger ui-button--sm">Contain Domain</button>
                                        </form>
                                    </td>
                                </tr>
                            {% endfor %}
                        {% endif %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    {# Mail gateway security #}
    <div class="ng-data-card">
        <div class="ng-data-card__header">
            <div>
                <h2 class="ng-data-card__title">Mail Gateway Security</h2>
                <p class="ng-data-card__sub">Anti-Abuse, Anti-Phishing, Malware/Spam Sichtbarkeit wie bei einem Mail Gateway.</p>
            </div>
        </div>
        <div class="ng-data-card__body">
            <div class="ng-kpi-row mb-4">
                <div class="ng-kpi-box">
                    <div class="ng-kpi-box__label">Policies</div>
                    <div class="ng-kpi-box__value">{{ security.policy_posture.total|default(0) }}</div>
                </div>
                <div class="ng-kpi-box">
                    <div class="ng-kpi-box__label">TLS required</div>
                    <div class="ng-kpi-box__value ng-kpi-box__value--success">{{ security.policy_posture.strict_tls|default(0) }}</div>
                </div>
                <div class="ng-kpi-box">
                    <div class="ng-kpi-box__label">External forwarding ON</div>
                    <div class="ng-kpi-box__value ng-kpi-box__value--danger">{{ security.policy_posture.external_forwarding_enabled|default(0) }}</div>
                </div>
                <div class="ng-kpi-box">
                    <div class="ng-kpi-box__label">Spam protection high</div>
                    <div class="ng-kpi-box__value ng-kpi-box__value--info">{{ security.policy_posture.high_spam_protection|default(0) }}</div>
                </div>
                <div class="ng-kpi-box">
                    <div class="ng-kpi-box__label">Suspicious events</div>
                    <div class="ng-kpi-box__value ng-kpi-box__value--warning">{{ security.suspicious_count|default(0) }}</div>
                </div>
            </div>
        </div>
        <div class="ng-data-card__body ng-data-card__body--flush">
            <div class="cust-ws-table-wrap">
                <table class="cust-table">
                    <thead>
                        <tr>
                            <th>Zeit</th>
                            <th>Domain</th>
                            <th>Source</th>
                            <th>Level</th>
                            <th>Event</th>
                            <th>Threat/Message</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% if security.suspicious is empty %}
                            <tr>
                                <td colspan="7" class="cust-table__empty">Keine auffälligen Events erkannt.</td>
                            </tr>
                        {% else %}
                            {% for row in security.suspicious %}
                                <tr>
                                    <td>{{ row.created_at|date('Y-m-d H:i:s') }}</td>
                                    <td>{{ row.domain }}</td>
                                    <td>{{ row.source }}</td>
                                    <td>{{ row.level }}</td>
                                    <td>{{ row.event_type }}</td>
                                    <td>{{ row.message|length > 140 ? row.message|slice(0, 140) ~ '…' : row.message }}</td>
                                    <td>
                                        <form method="post" action="{{ path('admin_mail_security_contain_domain') }}" onsubmit="return confirm('{{ t('admin_mail_security_contain_confirm', page_locale())|e('js') }}');" class="inline-flex">
                                            <input type="hidden" name="_token" value="{{ csrf.contain_domain }}">
                                            <input type="hidden" name="domain_id" value="{{ row.domain_id }}">
                                            <button type="submit" class="ui-button ui-button--danger ui-button--sm">Contain Domain</button>
                                        </form>
                                    </td>
                                </tr>
                            {% endfor %}
                        {% endif %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    {# Bindings table #}
    <div class="ng-data-card">
        <div class="ng-data-card__header">
            <div>
                <h2 class="ng-data-card__title">{{ t('admin_mail_system_bindings', page_locale()) }}</h2>
            </div>
        </div>
        <div class="ng-data-card__body ng-data-card__body--flush">
            <div class="cust-ws-table-wrap">
                <table class="cust-table">
                    <thead>
                        <tr>
                            <th>Domain</th>
                            <th>Customer</th>
                            <th>Node</th>
                            <th>Policy</th>
                            <th>DNS</th>
                            <th>Updated</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for binding in bindings %}
                            <tr>
                                <td class="font-semibold text-slate-900">{{ binding.domain }}</td>
                                <td>{{ binding.customer }}</td>
                                <td>{{ binding.node }}</td>
                                <td>{{ binding.policy }}</td>
                                <td class="text-xs">DKIM: {{ binding.dkim }} · SPF: {{ binding.spf }} · DMARC: {{ binding.dmarc }} · MX: {{ binding.mx }} · TLS: {{ binding.tls }}</td>
                                <td>{{ binding.updated_at|date('Y-m-d H:i') }}</td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="6" class="cust-table__empty">{{ t('admin_mail_system_empty', page_locale()) }}</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>
{% endblock %}
