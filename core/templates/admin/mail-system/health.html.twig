{% extends 'admin/base.html.twig' %}

{% block title %}{{ t('admin_mail_health_title', page_locale()) }}{% endblock %}

{% block content %}
<section class="space-y-6" data-mail-health data-endpoint="{{ healthEndpoint }}" data-repair-endpoint-base="{{ repairEndpointBase }}">
    <header class="flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-bold text-slate-900">{{ t('admin_mail_health_title', page_locale()) }}</h1>
            <p class="text-sm text-slate-600">{{ t('admin_mail_health_subtitle', page_locale()) }}</p>
        </div>
        <div class="flex gap-2">
            <button type="button" data-action="refresh" class="rounded-md border px-3 py-2 text-sm">{{ t('admin_mail_health_action_refresh', page_locale()) }}</button>
            <div data-repair-status class="text-xs text-slate-600"></div>
        </div>
    </header>

    <div data-state="loading" class="rounded-lg border bg-white p-4 text-sm text-slate-600">{{ t('common_loading', page_locale()) }}</div>
    <div data-state="error" class="hidden rounded-lg border border-red-200 bg-red-50 p-4 text-sm text-red-800"></div>
    <div data-state="list" class="hidden space-y-4"></div>
</section>

<script>
(() => {
    const root = document.querySelector('[data-mail-health]');
    if (!root) return;
    const endpoint = root.dataset.endpoint;
    const repairEndpointBase = root.dataset.repairEndpointBase;
    const stateLoading = root.querySelector('[data-state="loading"]');
    const stateError = root.querySelector('[data-state="error"]');
    const stateList = root.querySelector('[data-state="list"]');
    const refreshButton = root.querySelector('[data-action="refresh"]');

    const groups = {
        installation: ['postfix_installed', 'dovecot_installed', 'postmap_available'],
        services: ['postfix_active', 'dovecot_active'],
        files: ['postfix_virtual_mailboxes_file', 'postfix_virtual_domains_file', 'postfix_virtual_aliases_file', 'dovecot_users_file'],
        storage: ['maildir_writable'],
        ports: ['port_25_listening', 'port_465_listening', 'port_587_listening', 'port_110_listening', 'port_143_listening', 'port_993_listening', 'port_995_listening']
    };

    const warningChecks = new Set(['port_465_listening', 'port_110_listening', 'port_143_listening', 'port_995_listening']);

    function escapeHtml(value) {
        return String(value ?? '').replace(/[&<>"]/g, (char) => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[char]));
    }

    function checkBadge(key, check) {
        const ok = !!check?.ok;
        const message = check?.message ?? '{{ t('admin_mail_health_missing_agent_check', page_locale())|e('js') }}';
        if (ok) return `<span class="inline-flex rounded bg-emerald-100 px-2 py-0.5 text-xs text-emerald-800">OK</span>`;
        if (warningChecks.has(key)) return `<span class="inline-flex rounded bg-amber-100 px-2 py-0.5 text-xs text-amber-800">{{ t('common_warning', page_locale()) }}</span>`;
        return `<span class="inline-flex rounded bg-rose-100 px-2 py-0.5 text-xs text-rose-800">{{ t('common_failed', page_locale()) }}</span>`;
    }

    function renderNode(node) {
        const criticalCount = Array.isArray(node.critical_failures) ? node.critical_failures.length : 0;
        const warningCount = Array.isArray(node.warnings) ? node.warnings.length : 0;
        const overall = node.overall_ok ? 'OK' : (criticalCount > 0 ? '{{ t('common_error', page_locale())|e('js') }}' : '{{ t('common_warning', page_locale())|e('js') }}');
        const overallClass = node.overall_ok ? 'bg-emerald-100 text-emerald-800' : (criticalCount > 0 ? 'bg-rose-100 text-rose-800' : 'bg-amber-100 text-amber-800');
        const offlineNotice = node.online ? '' : `<p class="mt-2 text-sm text-rose-700">{{ t('admin_mail_health_offline_hint', page_locale()) }}</p>`;

        const sections = Object.entries(groups).map(([label, keys]) => {
            const rows = keys.map((key) => {
                const check = node.checks?.[key] ?? {ok: false, message: '{{ t('admin_mail_health_missing_agent_check', page_locale())|e('js') }}'};
                return `<tr class="border-t"><td class="px-3 py-2 text-xs font-mono">${escapeHtml(key)}</td><td class="px-3 py-2">${checkBadge(key, check)}</td><td class="px-3 py-2 text-xs text-slate-600">${escapeHtml(check.message ?? '')}</td></tr>`;
            }).join('');
            return `<details class="rounded border bg-slate-50" open><summary class="cursor-pointer px-3 py-2 text-sm font-semibold text-slate-800">${escapeHtml(label)}</summary><table class="w-full text-sm"><tbody>${rows}</tbody></table></details>`;
        }).join('');

        const r = node.mail_report || {};
        const generated = r.generated_at ? new Date(r.generated_at) : null;
        const oldHint = generated && (Date.now() - generated.getTime() > 15 * 60 * 1000) ? '<p class="text-xs text-amber-700">{{ t('admin_mail_health_old_hint', page_locale())|e('js') }}</p>' : '';
        const cMap = {dovecot:'Dovecot',postfix:'Postfix',tls:'{{ t('admin_mail_health_category_tls', page_locale())|e('js') }}',auth:'{{ t('admin_mail_health_category_auth', page_locale())|e('js') }}',delivery:'{{ t('admin_mail_health_category_delivery', page_locale())|e('js') }}',dns:'DNS',ports:'Ports',security:'{{ t('admin_mail_health_category_security', page_locale())|e('js') }}',relay:'Relay/Outbound'};
        const byCat = {};
        (Array.isArray(r.checks) ? r.checks : []).forEach((c)=>{const k=c.category||'other';(byCat[k]=byCat[k]||[]).push(c);});
        const badge = (s)=> s==='ok' ? 'bg-emerald-100 text-emerald-800' : s==='warning' ? 'bg-amber-100 text-amber-800' : s==='error' ? 'bg-rose-100 text-rose-800' : 'bg-slate-100 text-slate-700';
        const mSections = Object.entries(byCat).map(([cat, items]) => `<details class="rounded border bg-white" open><summary class="cursor-pointer px-3 py-2 text-sm font-semibold">${escapeHtml(cMap[cat]||cat)}</summary>${items.map(c=>`<div class="border-t px-3 py-2 text-xs"><div class="flex items-center gap-2"><span class="inline-flex rounded px-2 py-0.5 ${badge(c.status)}">${escapeHtml((c.status||'skipped').toUpperCase())}</span><strong>${escapeHtml(c.title||c.key)}</strong></div><div class="text-slate-600">${escapeHtml(c.message||'')}</div>${c.recommendation?`<div class="text-amber-800">${escapeHtml(c.recommendation)}</div>`:''}${c.probe?`<code class="block mt-1 rounded bg-slate-100 px-1 py-0.5">${escapeHtml(c.probe)}</code>`:''}</div>`).join('')}</details>`).join('');
        return `<article class="rounded-lg border bg-white p-4 shadow-sm"><div class="flex items-start justify-between gap-4"><div><h2 class="text-lg font-semibold text-slate-900">${escapeHtml(node.name ?? 'Node')}</h2><p class="text-xs text-slate-600">Agent: ${escapeHtml(node.agent_id ?? '—')} · {{ t('admin_mail_health_last_seen', page_locale()) }}: ${escapeHtml(node.last_seen_at ?? '—')}</p></div><div class="text-right"><span class="inline-flex rounded px-2 py-1 text-xs font-semibold ${overallClass}">${overall}</span><p class="mt-1 text-xs text-slate-600">{{ t('admin_mail_health_critical', page_locale()) }}: ${criticalCount} · {{ t('admin_mail_health_warnings', page_locale()) }}: ${warningCount}</p></div></div>${offlineNotice}<div class="mt-3 flex gap-2"><button type="button" data-action="refresh" class="rounded border px-2 py-1 text-xs">{{ t('admin_mail_health_action_refresh', page_locale()) }}</button><button type="button" data-action="refresh-mail-report" data-node-id="${escapeHtml(node.id ?? '')}" class="rounded border px-2 py-1 text-xs">{{ t('admin_mail_health_refresh_mail_report', page_locale()) }}</button><button type="button" data-action="repair" data-node-id="${escapeHtml(node.id ?? '')}" ${node.agent_id ? '' : 'disabled'} class="rounded border px-2 py-1 text-xs">{{ t('admin_mail_repair_action', page_locale()) }}</button></div><div class="mt-2 rounded border bg-slate-50 p-2 text-xs"><p><strong>{{ t('admin_mail_health_mailserver_label', page_locale()) }}:</strong> ${escapeHtml((r.overall||'unknown').toUpperCase())} · ${escapeHtml(r.generated_at||'n/a')}</p>${oldHint}${mSections || '<p class="text-slate-600">{{ t('admin_mail_health_load_failed', page_locale())|e('js') }}</p>'}</div><div class="mt-3 space-y-2">${sections}</div></article>`;
    }

    async function loadHealth() {
        stateLoading.classList.remove('hidden');
        stateError.classList.add('hidden');
        stateList.classList.add('hidden');
        try {
            const response = await fetch(endpoint, {headers: {'Accept': 'application/json'}});
            if (!response.ok) throw new Error('HTTP ' + response.status);
            const payload = await response.json();
            const nodes = Array.isArray(payload.nodes) ? payload.nodes : [];
            stateList.innerHTML = nodes.map(renderNode).join('') || '<div class="rounded border bg-white p-4 text-sm text-slate-600">{{ t('admin_mail_health_no_mail_nodes', page_locale())|e('js') }}</div>';
            stateList.classList.remove('hidden');
        } catch (error) {
            stateError.textContent = '{{ t('admin_mail_health_data_load_failed', page_locale())|e('js') }}';
            stateError.classList.remove('hidden');
        } finally {
            stateLoading.classList.add('hidden');
        }
    }

    root.addEventListener('click', (event) => {
        const target = event.target;
        if (!(target instanceof HTMLElement)) return;
        if (target.dataset.action === 'refresh') {
            loadHealth();
        }
        if (target.dataset.action === 'repair') {
            const nodeId = target.dataset.nodeId;
            if (!nodeId) return;
            if (!confirm('{{ t('admin_mail_repair_confirm', page_locale()) }}')) return;
            target.setAttribute('disabled', 'disabled');
            fetch(`${repairEndpointBase}/${nodeId}/repair`, {method: 'POST', headers: {'Accept': 'application/json', 'X-Admin-Request': '1'}})
                .then(async (response) => ({ok: response.ok, payload: await response.json().catch(() => ({}))}))
                .then(({ok, payload}) => {
                    if (!ok) throw new Error(payload.error || 'failed');
                    alert(`{{ t('admin_mail_repair_success', page_locale()) }} #${payload.job_id}`);
                    loadHealth();
                })
                .catch((error) => {
                    alert(`{{ t('admin_mail_repair_failed', page_locale()) }}: ${error.message}`);
                })
                .finally(() => target.removeAttribute('disabled'));
        }
        if (target.dataset.action === 'refresh-mail-report') {
            const nodeId = target.dataset.nodeId; if (!nodeId) return;
            target.setAttribute('disabled', 'disabled');
            fetch(`${repairEndpointBase}/${nodeId}/health-report?refresh=1`, {headers:{'Accept':'application/json'}})
            .then(()=>loadHealth()).finally(()=>target.removeAttribute('disabled'));
        }
    });

    refreshButton?.addEventListener('click', loadHealth);
    loadHealth();
})();
</script>
{% endblock %}
