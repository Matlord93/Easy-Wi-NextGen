{% extends 'admin/base.html.twig' %}

{% set pageTitle = t('admin_mail_health_title', page_locale()) %}
{% set activeNav = 'mail-health' %}

{% block content %}
{% set locale = page_locale() %}
<div style="display:flex;flex-direction:column;gap:20px;" data-mail-health data-endpoint="{{ healthEndpoint }}" data-repair-endpoint-base="{{ repairEndpointBase }}">

  <section class="ng-card" style="overflow:hidden;">
    <div class="tkt-hero">
      <div class="tkt-hero__inner">
        <div>
          <div class="tkt-hero__pill"><span class="tkt-hero__pill-dot"></span> Mail System</div>
          <h1 class="tkt-hero__title" style="margin-top:10px;">{{ t('admin_mail_health_title', locale) }}</h1>
          <p class="tkt-hero__sub">{{ t('admin_mail_health_subtitle', locale) }}</p>
        </div>
      </div>
    </div>
    <div style="padding:14px 16px;border-top:1px solid var(--ng-border);background:var(--ng-surface-soft);display:flex;align-items:center;gap:8px;">
      <button type="button" data-action="refresh" class="ui-button ui-button--ghost ui-button--sm">{{ t('admin_mail_health_action_refresh', locale) }}</button>
      <div data-repair-status style="font-size:12px;color:var(--ng-text-muted);"></div>
    </div>
  </section>

  <div data-state="loading" class="ng-alert ng-alert--warning">{{ t('common_loading', locale) }}</div>
  <div data-state="error" style="display:none;"></div>
  <div data-state="list" style="display:none;flex-direction:column;gap:16px;"></div>

</div>

<script>
(() => {
    const root = document.querySelector('[data-mail-health]');
    if (!root) return;
    const endpoint = root.dataset.endpoint;
    const repairEndpointBase = root.dataset.repairEndpointBase;
    const stateLoading = root.querySelector('[data-state="loading"]');
    const stateError = root.querySelector('[data-state="error"]');
    const stateList = root.querySelector('[data-state="list"]');
    const refreshButton = root.querySelector('[data-action="refresh"]');

    const groups = {
        installation: ['postfix_installed', 'dovecot_installed', 'postmap_available'],
        services: ['postfix_active', 'dovecot_active'],
        files: ['postfix_virtual_mailboxes_file', 'postfix_virtual_domains_file', 'postfix_virtual_aliases_file', 'dovecot_users_file'],
        storage: ['maildir_writable'],
        ports: ['port_25_listening', 'port_465_listening', 'port_587_listening', 'port_110_listening', 'port_143_listening', 'port_993_listening', 'port_995_listening']
    };

    const warningChecks = new Set(['port_465_listening', 'port_110_listening', 'port_143_listening', 'port_995_listening']);

    function escapeHtml(value) {
        return String(value ?? '').replace(/[&<>"]/g, (char) => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[char]));
    }

    function checkBadge(key, check) {
        const ok = !!check?.ok;
        const message = check?.message ?? '{{ t('admin_mail_health_missing_agent_check', locale)|e('js') }}';
        if (ok) return `<span class="ui-badge ui-badge--success">OK</span>`;
        if (warningChecks.has(key)) return `<span class="ui-badge ui-badge--warning">{{ t('common_warning', locale) }}</span>`;
        return `<span class="ui-badge ui-badge--danger">{{ t('common_failed', locale) }}</span>`;
    }

    function renderNode(node) {
        const criticalCount = Array.isArray(node.critical_failures) ? node.critical_failures.length : 0;
        const warningCount = Array.isArray(node.warnings) ? node.warnings.length : 0;
        const overall = node.overall_ok ? 'OK' : (criticalCount > 0 ? '{{ t('common_error', locale)|e('js') }}' : '{{ t('common_warning', locale)|e('js') }}');
        const overallBadge = node.overall_ok ? 'ui-badge--success' : (criticalCount > 0 ? 'ui-badge--danger' : 'ui-badge--warning');
        const offlineNotice = node.online ? '' : `<p class="ng-alert ng-alert--danger" style="margin-top:8px;">{{ t('admin_mail_health_offline_hint', locale) }}</p>`;

        const sections = Object.entries(groups).map(([label, keys]) => {
            const rows = keys.map((key) => {
                const check = node.checks?.[key] ?? {ok: false, message: '{{ t('admin_mail_health_missing_agent_check', locale)|e('js') }}'};
                return `<tr><td style="padding:6px 10px;font-size:11px;font-family:monospace;border-top:1px solid var(--ng-border);">${escapeHtml(key)}</td><td style="padding:6px 10px;border-top:1px solid var(--ng-border);">${checkBadge(key, check)}</td><td style="padding:6px 10px;font-size:11px;color:var(--ng-text-muted);border-top:1px solid var(--ng-border);">${escapeHtml(check.message ?? '')}</td></tr>`;
            }).join('');
            return `<details style="border:1px solid var(--ng-border);border-radius:6px;background:var(--ng-surface-soft);" open><summary style="cursor:pointer;padding:8px 12px;font-size:13px;font-weight:600;color:var(--ng-text);">${escapeHtml(label)}</summary><table style="width:100%;font-size:13px;"><tbody>${rows}</tbody></table></details>`;
        }).join('');

        const r = node.mail_report || {};
        const generated = r.generated_at ? new Date(r.generated_at) : null;
        const oldHint = generated && (Date.now() - generated.getTime() > 15 * 60 * 1000) ? '<p class="ng-alert ng-alert--warning" style="margin-top:6px;">{{ t('admin_mail_health_old_hint', locale)|e('js') }}</p>' : '';
        const cMap = {dovecot:'Dovecot',postfix:'Postfix',tls:'{{ t('admin_mail_health_category_tls', locale)|e('js') }}',auth:'{{ t('admin_mail_health_category_auth', locale)|e('js') }}',delivery:'{{ t('admin_mail_health_category_delivery', locale)|e('js') }}',dns:'DNS',ports:'Ports',security:'{{ t('admin_mail_health_category_security', locale)|e('js') }}',relay:'Relay/Outbound'};
        const byCat = {};
        (Array.isArray(r.checks) ? r.checks : []).forEach((c)=>{const k=c.category||'other';(byCat[k]=byCat[k]||[]).push(c);});
        const badge = (s)=> s==='ok' ? 'ui-badge--success' : s==='warning' ? 'ui-badge--warning' : s==='error' ? 'ui-badge--danger' : 'ui-badge--neutral';
        const mSections = Object.entries(byCat).map(([cat, items]) => `<details style="border:1px solid var(--ng-border);border-radius:6px;background:#fff;" open><summary style="cursor:pointer;padding:8px 12px;font-size:13px;font-weight:600;">${escapeHtml(cMap[cat]||cat)}</summary>${items.map(c=>`<div style="border-top:1px solid var(--ng-border);padding:8px 12px;font-size:12px;"><div style="display:flex;align-items:center;gap:8px;"><span class="ui-badge ${badge(c.status)}">${escapeHtml((c.status||'skipped').toUpperCase())}</span><strong>${escapeHtml(c.title||c.key)}</strong></div><div style="color:var(--ng-text-muted);">${escapeHtml(c.message||'')}</div>${c.recommendation?`<div style="color:#92400e;">${escapeHtml(c.recommendation)}</div>`:''} ${c.probe?`<code style="display:block;margin-top:4px;border-radius:4px;background:var(--ng-surface-soft);padding:2px 6px;">${escapeHtml(c.probe)}</code>`:''}</div>`).join('')}</details>`).join('');
        return `<article class="ng-data-card"><div class="ng-data-card__header"><div><h2 class="ng-data-card__title">${escapeHtml(node.name ?? 'Node')}</h2><p class="ng-data-card__sub">Agent: ${escapeHtml(node.agent_id ?? '—')} · {{ t('admin_mail_health_last_seen', locale) }}: ${escapeHtml(node.last_seen_at ?? '—')}</p></div><div style="text-align:right;"><span class="ui-badge ${overallBadge}">${overall}</span><p style="margin-top:4px;font-size:11px;color:var(--ng-text-muted);">{{ t('admin_mail_health_critical', locale) }}: ${criticalCount} · {{ t('admin_mail_health_warnings', locale) }}: ${warningCount}</p></div></div>${offlineNotice}<div class="ng-data-card__body"><div style="display:flex;gap:8px;margin-bottom:12px;"><button type="button" data-action="refresh" class="ui-button ui-button--ghost ui-button--sm">{{ t('admin_mail_health_action_refresh', locale) }}</button><button type="button" data-action="refresh-mail-report" data-node-id="${escapeHtml(node.id ?? '')}" class="ui-button ui-button--ghost ui-button--sm">{{ t('admin_mail_health_refresh_mail_report', locale) }}</button><button type="button" data-action="repair" data-node-id="${escapeHtml(node.id ?? '')}" ${node.agent_id ? '' : 'disabled'} class="ui-button ui-button--ghost ui-button--sm">{{ t('admin_mail_repair_action', locale) }}</button></div><div style="border:1px solid var(--ng-border);border-radius:6px;background:var(--ng-surface-soft);padding:10px;font-size:12px;margin-bottom:12px;"><p><strong>{{ t('admin_mail_health_mailserver_label', locale) }}:</strong> ${escapeHtml((r.overall||'unknown').toUpperCase())} · ${escapeHtml(r.generated_at||'n/a')}</p>${oldHint}${mSections || '<p style="color:var(--ng-text-muted);">{{ t('admin_mail_health_load_failed', locale)|e('js') }}</p>'}</div><div style="display:flex;flex-direction:column;gap:8px;">${sections}</div></div></article>`;
    }

    async function loadHealth() {
        stateLoading.style.display = '';
        stateError.style.display = 'none';
        stateList.style.display = 'none';
        try {
            const response = await fetch(endpoint, {headers: {'Accept': 'application/json'}});
            if (!response.ok) throw new Error('HTTP ' + response.status);
            const payload = await response.json();
            const nodes = Array.isArray(payload.nodes) ? payload.nodes : [];
            stateList.innerHTML = nodes.map(renderNode).join('') || '<div class="ng-alert ng-alert--warning">{{ t('admin_mail_health_no_mail_nodes', locale)|e('js') }}</div>';
            stateList.style.display = 'flex';
        } catch (error) {
            stateError.className = 'ng-alert ng-alert--danger';
            stateError.textContent = '{{ t('admin_mail_health_data_load_failed', locale)|e('js') }}';
            stateError.style.display = '';
        } finally {
            stateLoading.style.display = 'none';
        }
    }

    root.addEventListener('click', (event) => {
        const target = event.target;
        if (!(target instanceof HTMLElement)) return;
        if (target.dataset.action === 'refresh') {
            loadHealth();
        }
        if (target.dataset.action === 'repair') {
            const nodeId = target.dataset.nodeId;
            if (!nodeId) return;
            if (!confirm('{{ t('admin_mail_repair_confirm', locale) }}')) return;
            target.setAttribute('disabled', 'disabled');
            fetch(`${repairEndpointBase}/${nodeId}/repair`, {method: 'POST', headers: {'Accept': 'application/json', 'X-Admin-Request': '1'}})
                .then(async (response) => ({ok: response.ok, payload: await response.json().catch(() => ({}))}))
                .then(({ok, payload}) => {
                    if (!ok) throw new Error(payload.error || 'failed');
                    alert(`{{ t('admin_mail_repair_success', locale) }} #${payload.job_id}`);
                    loadHealth();
                })
                .catch((error) => {
                    alert(`{{ t('admin_mail_repair_failed', locale) }}: ${error.message}`);
                })
                .finally(() => target.removeAttribute('disabled'));
        }
        if (target.dataset.action === 'refresh-mail-report') {
            const nodeId = target.dataset.nodeId; if (!nodeId) return;
            target.setAttribute('disabled', 'disabled');
            fetch(`${repairEndpointBase}/${nodeId}/health-report?refresh=1`, {headers:{'Accept':'application/json'}})
            .then(()=>loadHealth()).finally(()=>target.removeAttribute('disabled'));
        }
    });

    refreshButton?.addEventListener('click', loadHealth);
    loadHealth();
})();
</script>
{% endblock %}
