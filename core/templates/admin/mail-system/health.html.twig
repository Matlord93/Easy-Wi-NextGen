{% extends 'layouts/admin.html.twig' %}

{% block title %}{{ t('admin_mail_health_title', page_locale()) }}{% endblock %}

{% block body %}
<section class="space-y-6" data-mail-health data-endpoint="{{ healthEndpoint }}" data-repair-endpoint-base="{{ repairEndpointBase }}">
    <header class="flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-bold text-slate-900">{{ t('admin_mail_health_title', page_locale()) }}</h1>
            <p class="text-sm text-slate-600">{{ t('admin_mail_health_subtitle', page_locale()) }}</p>
        </div>
        <div class="flex gap-2">
            <button type="button" data-action="refresh" class="rounded-md border px-3 py-2 text-sm">{{ t('admin_mail_health_action_refresh', page_locale()) }}</button>
            <div data-repair-status class="text-xs text-slate-600"></div>
        </div>
    </header>

    <div data-state="loading" class="rounded-lg border bg-white p-4 text-sm text-slate-600">Loading...</div>
    <div data-state="error" class="hidden rounded-lg border border-red-200 bg-red-50 p-4 text-sm text-red-800"></div>
    <div data-state="list" class="hidden space-y-4"></div>
</section>

<script>
(() => {
    const root = document.querySelector('[data-mail-health]');
    if (!root) return;
    const endpoint = root.dataset.endpoint;
    const repairEndpointBase = root.dataset.repairEndpointBase;
    const stateLoading = root.querySelector('[data-state="loading"]');
    const stateError = root.querySelector('[data-state="error"]');
    const stateList = root.querySelector('[data-state="list"]');
    const refreshButton = root.querySelector('[data-action="refresh"]');

    const groups = {
        installation: ['postfix_installed', 'dovecot_installed', 'postmap_available'],
        services: ['postfix_active', 'dovecot_active'],
        files: ['postfix_virtual_mailboxes_file', 'postfix_virtual_domains_file', 'postfix_virtual_aliases_file', 'dovecot_users_file'],
        storage: ['maildir_writable'],
        ports: ['port_25_listening', 'port_465_listening', 'port_587_listening', 'port_110_listening', 'port_143_listening', 'port_993_listening', 'port_995_listening']
    };

    const warningChecks = new Set(['port_465_listening', 'port_110_listening', 'port_143_listening', 'port_995_listening']);

    function escapeHtml(value) {
        return String(value ?? '').replace(/[&<>"]/g, (char) => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[char]));
    }

    function checkBadge(key, check) {
        const ok = !!check?.ok;
        const message = check?.message ?? 'missing check from agent';
        if (ok) return `<span class="inline-flex rounded bg-emerald-100 px-2 py-0.5 text-xs text-emerald-800">OK</span>`;
        if (warningChecks.has(key)) return `<span class="inline-flex rounded bg-amber-100 px-2 py-0.5 text-xs text-amber-800">Warning</span>`;
        return `<span class="inline-flex rounded bg-rose-100 px-2 py-0.5 text-xs text-rose-800">Failed</span>`;
    }

    function renderNode(node) {
        const criticalCount = Array.isArray(node.critical_failures) ? node.critical_failures.length : 0;
        const warningCount = Array.isArray(node.warnings) ? node.warnings.length : 0;
        const overall = node.overall_ok ? 'OK' : (criticalCount > 0 ? 'Error' : 'Warning');
        const overallClass = node.overall_ok ? 'bg-emerald-100 text-emerald-800' : (criticalCount > 0 ? 'bg-rose-100 text-rose-800' : 'bg-amber-100 text-amber-800');
        const offlineNotice = node.online ? '' : `<p class="mt-2 text-sm text-rose-700">{{ t('admin_mail_health_offline_hint', page_locale()) }}</p>`;

        const sections = Object.entries(groups).map(([label, keys]) => {
            const rows = keys.map((key) => {
                const check = node.checks?.[key] ?? {ok: false, message: 'missing check from agent'};
                return `<tr class="border-t"><td class="px-3 py-2 text-xs font-mono">${escapeHtml(key)}</td><td class="px-3 py-2">${checkBadge(key, check)}</td><td class="px-3 py-2 text-xs text-slate-600">${escapeHtml(check.message ?? '')}</td></tr>`;
            }).join('');
            return `<details class="rounded border bg-slate-50" open><summary class="cursor-pointer px-3 py-2 text-sm font-semibold text-slate-800">${escapeHtml(label)}</summary><table class="w-full text-sm"><tbody>${rows}</tbody></table></details>`;
        }).join('');

        return `<article class="rounded-lg border bg-white p-4 shadow-sm"><div class="flex items-start justify-between gap-4"><div><h2 class="text-lg font-semibold text-slate-900">${escapeHtml(node.name ?? 'Node')}</h2><p class="text-xs text-slate-600">Agent: ${escapeHtml(node.agent_id ?? '—')} · Last Seen: ${escapeHtml(node.last_seen_at ?? '—')}</p></div><div class="text-right"><span class="inline-flex rounded px-2 py-1 text-xs font-semibold ${overallClass}">${overall}</span><p class="mt-1 text-xs text-slate-600">Critical: ${criticalCount} · Warnings: ${warningCount}</p></div></div>${offlineNotice}<div class="mt-3 flex gap-2"><button type="button" data-action="refresh" class="rounded border px-2 py-1 text-xs">{{ t('admin_mail_health_action_refresh', page_locale()) }}</button><button type="button" data-action="repair" data-node-id="${escapeHtml(node.id ?? '')}" ${node.agent_id ? '' : 'disabled'} class="rounded border px-2 py-1 text-xs">{{ t('admin_mail_repair_action', page_locale()) }}</button><button type="button" data-action="roundcube-install" data-node-id="${escapeHtml(node.id ?? '')}" class="rounded border px-2 py-1 text-xs">{{ t('admin_roundcube_install', page_locale()) }}</button><button type="button" data-action="roundcube-deploy" data-node-id="${escapeHtml(node.id ?? '')}" class="rounded border px-2 py-1 text-xs">{{ t('admin_roundcube_deploy', page_locale()) }}</button><button type="button" class="rounded border px-2 py-1 text-xs">{{ t('admin_mail_health_action_details', page_locale()) }}</button></div><p class="mt-2 text-xs text-slate-500">{{ t('admin_mail_repair_last_job', page_locale()) }}: ${escapeHtml(node.last_repair_job?.status ?? '—')}</p><div class="mt-3 space-y-2">${sections}</div></article>`;
    }

    async function loadHealth() {
        stateLoading.classList.remove('hidden');
        stateError.classList.add('hidden');
        stateList.classList.add('hidden');
        try {
            const response = await fetch(endpoint, {headers: {'Accept': 'application/json'}});
            if (!response.ok) throw new Error('HTTP ' + response.status);
            const payload = await response.json();
            const nodes = Array.isArray(payload.nodes) ? payload.nodes : [];
            stateList.innerHTML = nodes.map(renderNode).join('') || '<div class="rounded border bg-white p-4 text-sm text-slate-600">No mail nodes available.</div>';
            stateList.classList.remove('hidden');
        } catch (error) {
            stateError.textContent = 'Health data could not be loaded.';
            stateError.classList.remove('hidden');
        } finally {
            stateLoading.classList.add('hidden');
        }
    }

    root.addEventListener('click', (event) => {
        const target = event.target;
        if (!(target instanceof HTMLElement)) return;
        if (target.dataset.action === 'refresh') {
            loadHealth();
        }
        if (target.dataset.action === 'repair') {
            const nodeId = target.dataset.nodeId;
            if (!nodeId) return;
            if (!confirm('{{ t('admin_mail_repair_confirm', page_locale()) }}')) return;
            target.setAttribute('disabled', 'disabled');
            fetch(`${repairEndpointBase}/${nodeId}/repair`, {method: 'POST', headers: {'Accept': 'application/json'}})
                .then(async (response) => ({ok: response.ok, payload: await response.json().catch(() => ({}))}))
                .then(({ok, payload}) => {
                    if (!ok) throw new Error(payload.error || 'failed');
                    alert(`{{ t('admin_mail_repair_success', page_locale()) }} #${payload.job_id}`);
                    loadHealth();
                })
                .catch((error) => {
                    alert(`{{ t('admin_mail_repair_failed', page_locale()) }}: ${error.message}`);
                })
                .finally(() => target.removeAttribute('disabled'));
        }
    });

    refreshButton?.addEventListener('click', loadHealth);
    loadHealth();
})();
</script>
{% endblock %}
