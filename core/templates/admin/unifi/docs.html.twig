{% extends 'admin/base.html.twig' %}

{% set pageTitle = t('admin_unifi_docs_title', page_locale()) %}
{% set pageSubtitle = t('admin_unifi_docs_subtitle', page_locale()) %}

{% block content %}
<div class="space-y-6">
    {% include 'admin/unifi/_nav.html.twig' with { unifiNav: 'docs' } %}

    <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm space-y-4">
        <h2 class="text-lg font-semibold text-slate-900">{{ t('admin_unifi_docs_conn_title', page_locale()) }}</h2>
        <p class="text-sm text-slate-700">{{ t('admin_unifi_docs_conn_body', page_locale()) }}</p>

        <h2 class="text-lg font-semibold text-slate-900">{{ t('admin_unifi_docs_site_title', page_locale()) }}</h2>
        <p class="text-sm text-slate-700">{{ t('admin_unifi_docs_site_body', page_locale()) }}</p>

        <h2 class="text-lg font-semibold text-slate-900">{{ t('admin_unifi_docs_sync_title', page_locale()) }}</h2>
        <ul class="list-disc space-y-2 pl-5 text-sm text-slate-700">
            <li>{{ t('admin_unifi_docs_sync_1', page_locale()) }}</li>
            <li>{{ t('admin_unifi_docs_sync_2', page_locale()) }}</li>
            <li>{{ t('admin_unifi_docs_sync_3', page_locale()) }}</li>
            <li>{{ t('admin_unifi_docs_sync_4', page_locale()) }}</li>
        </ul>

        <h2 class="text-lg font-semibold text-slate-900">{{ t('admin_unifi_nav_audit', page_locale()) }}</h2>
        <p class="text-sm text-slate-700">{{ t('admin_unifi_docs_audit_body', page_locale()) }}</p>
    </div>
</div>
{% endblock %}
