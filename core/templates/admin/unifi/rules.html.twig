{% extends 'admin/base.html.twig' %}

{% set pageTitle = 'UniFi Manuelle Regeln' %}
{% set pageSubtitle = 'Port Forward CRUD' %}

{% block content %}
<div class="space-y-6">
    {% include 'admin/unifi/_nav.html.twig' with { unifiNav: 'rules' } %}

    {% if notice %}
        <div class="rounded-lg border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-800">
            {% if notice == 'created' %}Regel erstellt.{% elseif notice == 'updated' %}Regel aktualisiert.{% elseif notice == 'deleted' %}Regel gelöscht.{% endif %}
        </div>
    {% endif %}

    {% if errors is not empty %}
        <div class="rounded-lg border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-800">
            <ul class="list-disc pl-5">
                {% for error in errors %}
                    <li>{{ error }}</li>
                {% endfor %}
            </ul>
        </div>
    {% endif %}

    <div class="grid gap-6 lg:grid-cols-3">
        <form method="post" action="{{ editRule ? '/admin/unifi/rules/' ~ editRule.id : '/admin/unifi/rules' }}" class="space-y-4 rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
            <h3 class="text-lg font-semibold text-slate-900">{{ editRule ? 'Regel bearbeiten' : 'Neue Regel' }}</h3>
            <label class="block text-sm font-semibold text-slate-700">
                Name
                <input type="text" name="name" value="{{ form.name }}" class="mt-2 w-full rounded-lg border border-slate-200 px-3 py-2 text-sm" />
            </label>
            <label class="block text-sm font-semibold text-slate-700">
                Protokoll
                <select name="protocol" class="mt-2 w-full rounded-lg border border-slate-200 px-3 py-2 text-sm">
                    <option value="tcp" {{ form.protocol == 'tcp' ? 'selected' : '' }}>TCP</option>
                    <option value="udp" {{ form.protocol == 'udp' ? 'selected' : '' }}>UDP</option>
                </select>
            </label>
            <label class="block text-sm font-semibold text-slate-700">
                Externer Port
                <input type="text" name="port" value="{{ form.port }}" class="mt-2 w-full rounded-lg border border-slate-200 px-3 py-2 text-sm" />
            </label>
            <label class="block text-sm font-semibold text-slate-700">
                Ziel-IP
                <input type="text" name="target_ip" value="{{ form.target_ip }}" class="mt-2 w-full rounded-lg border border-slate-200 px-3 py-2 text-sm" placeholder="10.0.0.10" />
            </label>
            <label class="block text-sm font-semibold text-slate-700">
                Ziel-Port
                <input type="text" name="target_port" value="{{ form.target_port }}" class="mt-2 w-full rounded-lg border border-slate-200 px-3 py-2 text-sm" />
            </label>
            <label class="block text-sm font-semibold text-slate-700">
                Beschreibung
                <textarea name="description" class="mt-2 w-full rounded-lg border border-slate-200 px-3 py-2 text-sm" rows="2">{{ form.description }}</textarea>
            </label>
            <label class="flex items-center gap-2 text-sm text-slate-700">
                <input type="checkbox" name="enabled" value="1" {{ form.enabled ? 'checked' : '' }} />
                Aktiviert
            </label>
            <div class="flex gap-2">
                <button class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white" type="submit">Speichern</button>
                {% if editRule %}
                    <a href="/admin/unifi/rules" class="rounded-lg border border-slate-200 px-4 py-2 text-sm font-semibold text-slate-700">Abbrechen</a>
                {% endif %}
            </div>
        </form>

        <div class="lg:col-span-2 rounded-xl border border-slate-200 bg-white shadow-sm">
            <div class="border-b border-slate-200 px-5 py-3 text-sm font-semibold text-slate-700">Manuelle Regeln</div>
            <div class="overflow-x-auto">
                <table class="min-w-full text-left text-sm">
                    <thead class="bg-slate-50 text-xs uppercase text-slate-500">
                        <tr>
                            <th class="px-4 py-3">Name</th>
                            <th class="px-4 py-3">Port</th>
                            <th class="px-4 py-3">Target</th>
                            <th class="px-4 py-3">Status</th>
                            <th class="px-4 py-3"></th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for rule in rules %}
                            <tr class="border-t border-slate-200">
                                <td class="px-4 py-3">
                                    <p class="font-semibold text-slate-900">{{ rule.name }}</p>
                                    <p class="text-xs text-slate-500">{{ rule.description ?? '—' }}</p>
                                </td>
                                <td class="px-4 py-3">{{ rule.port }}/{{ rule.protocol|upper }}</td>
                                <td class="px-4 py-3">{{ rule.targetIp }}:{{ rule.targetPort }}</td>
                                <td class="px-4 py-3">
                                    <span class="rounded-full px-2 py-1 text-xs {{ rule.enabled ? 'bg-emerald-100 text-emerald-700' : 'bg-slate-100 text-slate-600' }}">{{ rule.enabled ? 'aktiv' : 'inaktiv' }}</span>
                                </td>
                                <td class="px-4 py-3 text-right">
                                    <a href="/admin/unifi/rules/{{ rule.id }}/edit" class="text-xs font-semibold text-indigo-600 hover:text-indigo-500">Edit</a>
                                    <form method="post" action="/admin/unifi/rules/{{ rule.id }}/delete" class="inline">
                                        <button type="submit" class="ml-3 text-xs font-semibold text-rose-600 hover:text-rose-500">Delete</button>
                                    </form>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="5" class="px-4 py-6 text-center text-sm text-slate-500">Keine Regeln vorhanden.</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{% endblock %}
