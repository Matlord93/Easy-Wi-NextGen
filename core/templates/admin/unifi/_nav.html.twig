{% set items = [
    { label: t('admin_unifi_nav_dashboard', page_locale()),   href: '/admin/unifi',             key: 'dashboard' },
    { label: t('admin_unifi_nav_connection', page_locale()),  href: '/admin/unifi/connection',   key: 'connection' },
    { label: t('admin_unifi_nav_policy', page_locale()),      href: '/admin/unifi/policy',       key: 'policy' },
    { label: t('admin_unifi_nav_rules', page_locale()),       href: '/admin/unifi/rules',        key: 'rules' },
    { label: t('admin_unifi_nav_auto_preview', page_locale()), href: '/admin/unifi/auto-preview', key: 'auto-preview' },
    { label: t('admin_unifi_nav_audit', page_locale()),       href: '/admin/unifi/audit',        key: 'audit' },
    { label: t('admin_unifi_nav_docs', page_locale()),        href: '/admin/unifi/docs',         key: 'docs' }
] %}

<div class="flex flex-wrap gap-2">
    {% for item in items %}
        <a href="{{ item.href }}" class="rounded-lg px-4 py-2 text-sm font-semibold {{ unifiNav == item.key ? 'bg-slate-900 text-white' : 'border border-slate-200 text-slate-600 hover:bg-slate-50' }}">
            {{ item.label }}
        </a>
    {% endfor %}
</div>
