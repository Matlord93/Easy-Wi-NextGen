{% extends 'admin/base.html.twig' %}

{% set pageTitle = t('admin_unifi_dashboard_title', page_locale()) %}
{% set pageSubtitle = t('admin_unifi_dashboard_subtitle', page_locale()) %}

{% block content %}
<div class="space-y-6">
    {% include 'admin/unifi/_nav.html.twig' with { unifiNav: 'dashboard' } %}

    <div class="grid gap-6 lg:grid-cols-3">
        <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
            <p class="text-xs uppercase text-slate-500">{{ t('admin_unifi_module_status', page_locale()) }}</p>
            <p class="mt-2 text-lg font-semibold text-slate-900">
                {{ settings.enabled ? t('enabled', page_locale()) : t('disabled', page_locale()) }}
            </p>
            <p class="mt-2 text-sm text-slate-600">{{ t('admin_unifi_module_status_hint', page_locale()) }}</p>
        </div>
        <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
            <p class="text-xs uppercase text-slate-500">{{ t('admin_unifi_nav_policy', page_locale()) }}</p>
            <p class="mt-2 text-lg font-semibold text-slate-900">{{ policy.mode|capitalize }}</p>
            <p class="mt-2 text-sm text-slate-600">{{ t('admin_unifi_policy_hint', page_locale()) }}</p>
        </div>
        <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
            <p class="text-xs uppercase text-slate-500">{{ t('admin_unifi_last_sync', page_locale()) }}</p>
            <p class="mt-2 text-lg font-semibold text-slate-900">{{ latestAudit ? latestAudit.createdAt|date('Y-m-d H:i') : '—' }}</p>
            <p class="mt-2 text-sm text-slate-600">{{ t('admin_unifi_request_id', page_locale()) }}: {{ latestAudit ? latestAudit.requestId : '—' }}</p>
            <p class="mt-1 text-sm text-slate-600">{{ t('status', page_locale()) }}: {{ latestAudit ? latestAudit.status : '—' }}</p>
        </div>
    </div>

    <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
        <h2 class="text-lg font-semibold text-slate-900">{{ t('admin_unifi_guide_title', page_locale()) }}</h2>
        <ul class="mt-3 list-disc space-y-2 pl-5 text-sm text-slate-700">
            <li>{{ t('admin_unifi_guide_1', page_locale()) }}</li>
            <li>{{ t('admin_unifi_guide_2', page_locale()) }}</li>
            <li>{{ t('admin_unifi_guide_3', page_locale()) }}</li>
            <li>{{ t('admin_unifi_guide_4', page_locale()) }}</li>
        </ul>
        <a href="/admin/unifi/docs" class="mt-4 inline-flex items-center text-sm font-semibold text-indigo-600 hover:text-indigo-500">{{ t('admin_unifi_nav_docs', page_locale()) }} →</a>
    </div>
</div>
{% endblock %}
