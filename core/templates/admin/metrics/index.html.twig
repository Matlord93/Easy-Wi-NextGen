{% extends 'admin/base.html.twig' %}

{% set pageTitle = t('admin_metrics_heading', page_locale()) %}
{% set pageSubtitle = t('admin_metrics_intro', page_locale()) %}
{% set activeNav = 'metrics' %}

{% block content %}
{% set locale = page_locale() %}

{# ── Hero ── #}
<div class="ng-card" style="overflow:hidden;">
    <div class="tkt-hero">
        <div class="tkt-hero__inner">
            <div style="display:flex;flex-direction:column;gap:16px;">
                <div>
                    <div class="tkt-hero__pill">
                        <span class="tkt-hero__pill-dot"></span>
                        {{ t('admin_metrics_heading', locale) }}
                    </div>
                    <h1 class="tkt-hero__title" style="margin-top:10px;">{{ t('admin_metrics_heading', locale) }}</h1>
                    <p class="tkt-hero__sub">{{ t('admin_metrics_intro', locale) }}</p>
                    <div class="tkt-hero__actions" style="margin-top:10px;">
                        <span class="ui-badge ui-badge--neutral">
                            {{ t('admin_metrics_window_since', locale) }}: {{ since|date('Y-m-d H:i') }}
                        </span>
                        <span class="ui-badge ui-badge--info">
                            {{ tab == 'host' ? t('admin_metrics_tab_host', locale) : t('admin_metrics_tab_instances', locale) }}
                        </span>
                    </div>
                </div>
                <div style="display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:10px;">
                    <div class="tkt-kpi">
                        <div class="tkt-kpi__value">{{ agents|length }}</div>
                        <div class="tkt-kpi__label">{{ t('admin_metrics_filter_node', locale) }}</div>
                    </div>
                    <div class="tkt-kpi tkt-kpi--open">
                        <div class="tkt-kpi__value">{{ window }}</div>
                        <div class="tkt-kpi__label">{{ t('admin_metrics_filter_window', locale) }}</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="flex flex-col gap-6">

    {% if loadError %}
        <div class="ng-alert ng-alert--warning">{{ t('admin_metrics_load_error', locale) }}</div>
    {% endif %}

    {# ── Tab bar ── #}
    <div class="ng-data-card">
        <div class="ng-data-card__body">
            <div class="flex gap-2">
                <a
                    href="{{ path('admin_metrics', {tab: 'host', agent: selectedAgent ? selectedAgent.id : '', window: window, per_page: perPage, page: 1}) }}"
                    class="ui-button {{ tab == 'host' ? 'ui-button--primary' : 'ui-button--ghost' }} ui-button--sm"
                >{{ t('admin_metrics_tab_host', locale) }}</a>
                <a
                    href="{{ path('admin_metrics', {tab: 'instances', node: nodeFilter, customer: customerFilter, instance: selectedInstanceId, window: window, per_page: perPage, page: 1}) }}"
                    class="ui-button {{ tab == 'instances' ? 'ui-button--primary' : 'ui-button--ghost' }} ui-button--sm"
                >{{ t('admin_metrics_tab_instances', locale) }}</a>
            </div>
        </div>
    </div>

    {% if tab == 'host' %}

        {# ── Host Filters ── #}
        <div class="ng-data-card">
            <div class="ng-data-card__body">
                <form method="get" action="{{ path('admin_metrics') }}" class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
                    <input type="hidden" name="tab" value="host">
                    <div class="grid flex-1 gap-4 md:grid-cols-3">
                        <label class="form-field">
                            <span class="form-label">{{ t('admin_metrics_filter_node', locale) }}</span>
                            <select name="agent" class="form-input mt-2">
                                {% for agent in agents %}
                                    <option value="{{ agent.id }}" {{ selectedAgent and selectedAgent.id == agent.id ? 'selected' : '' }}>
                                        {{ agent.name ?? t('admin_metrics_node_unnamed', locale) }} · {{ agent.id }}
                                    </option>
                                {% else %}
                                    <option value="">{{ t('admin_metrics_no_nodes', locale) }}</option>
                                {% endfor %}
                            </select>
                        </label>
                        <label class="form-field">
                            <span class="form-label">{{ t('admin_metrics_filter_window', locale) }}</span>
                            <select name="window" class="form-input mt-2">
                                <option value="15m" {{ window == '15m' ? 'selected' : '' }}>15m</option>
                                <option value="60m" {{ window == '60m' ? 'selected' : '' }}>60m</option>
                                <option value="6h" {{ window == '6h' ? 'selected' : '' }}>6h</option>
                                <option value="24h" {{ window == '24h' ? 'selected' : '' }}>24h</option>
                                <option value="7d" {{ window == '7d' ? 'selected' : '' }}>7d</option>
                            </select>
                        </label>
                        <label class="form-field">
                            <span class="form-label">{{ t('admin_metrics_filter_per_page', locale) }}</span>
                            <select name="per_page" class="form-input mt-2">
                                {% for size in [50, 100, 200] %}
                                    <option value="{{ size }}" {{ perPage == size ? 'selected' : '' }}>{{ size }}</option>
                                {% endfor %}
                            </select>
                        </label>
                    </div>
                    <button class="ui-button ui-button--ghost ui-button--sm">{{ t('admin_metrics_filter_apply', locale) }}</button>
                </form>
            </div>
        </div>

        {# ── Node Health Status ── #}
        <div class="ng-data-card">
            <div class="ng-data-card__body">
                <p class="form-label">{{ t('admin_metrics_node_status_label', locale) }}</p>
                <p class="mt-1 font-semibold {% if nodeHealthStatus == 'critical' %}text-red-600{% elseif nodeHealthStatus == 'warning' %}text-amber-600{% elseif nodeHealthStatus == 'offline' %}text-slate-500{% else %}text-emerald-600{% endif %}">
                    {{ nodeHealthStatus|upper }}
                </p>
                <p class="mt-1 text-xs" style="color: var(--ng-text-muted)">
                    {{ t('admin_metrics_recorded_at', locale) }}: {{ nodeLastSeenAt ? nodeLastSeenAt|date('Y-m-d H:i:s') ~ ' UTC' : '—' }}
                    · {{ heartbeatGraceSeconds }}s
                </p>
            </div>
        </div>

        {# ── KPI sparkline cards ── #}
        <div class="ng-card">
            <div class="overflow-x-auto">
                <div class="grid grid-cols-4 gap-4 p-4">
                    <div class="ng-data-card">
                        <div class="ng-data-card__body">
                            <p class="form-label">{{ t('admin_metrics_cpu_usage', locale) }}</p>
                            <p class="mt-2 text-2xl font-semibold" style="color: var(--ng-text)">{{ latestCpu is not null ? latestCpu|number_format(1, '.', '') ~ '%' : '—' }}</p>
                            <p class="text-xs" style="color: var(--ng-text-muted)">{{ t('admin_metrics_average', locale) }} {{ aggregate.cpu_avg is not null ? aggregate.cpu_avg|number_format(1, '.', '') ~ '%' : '—' }} · {{ aggregate.cpu_max is not null ? aggregate.cpu_max|number_format(1, '.', '') ~ '%' : '—' }}</p>
                            <svg viewBox="0 0 240 60" class="mt-3 h-16 w-full">
                                {% if cpuPoints %}
                                    <polyline fill="none" stroke="#6366f1" stroke-width="2" points="{{ cpuPoints }}" />
                                {% else %}
                                    <text x="10" y="30" fill="#94a3b8">{{ t('admin_metrics_no_data', locale) }}</text>
                                {% endif %}
                            </svg>
                        </div>
                    </div>
                    <div class="ng-data-card">
                        <div class="ng-data-card__body">
                            <p class="form-label">{{ t('admin_metrics_memory_usage', locale) }}</p>
                            <p class="mt-2 text-2xl font-semibold" style="color: var(--ng-text)">{{ latestMemory is not null ? latestMemory|number_format(1, '.', '') ~ '%' : '—' }}</p>
                            <p class="text-xs" style="color: var(--ng-text-muted)">{{ t('admin_metrics_average', locale) }} {{ aggregate.memory_avg is not null ? aggregate.memory_avg|number_format(1, '.', '') ~ '%' : '—' }} · {{ aggregate.memory_max is not null ? aggregate.memory_max|number_format(1, '.', '') ~ '%' : '—' }}</p>
                            <svg viewBox="0 0 240 60" class="mt-3 h-16 w-full">
                                {% if memoryPoints %}
                                    <polyline fill="none" stroke="#10b981" stroke-width="2" points="{{ memoryPoints }}" />
                                {% else %}
                                    <text x="10" y="30" fill="#94a3b8">{{ t('admin_metrics_no_data', locale) }}</text>
                                {% endif %}
                            </svg>
                        </div>
                    </div>
                    <div class="ng-data-card">
                        <div class="ng-data-card__body">
                            <p class="form-label">{{ t('admin_metrics_disk_usage', locale) }}</p>
                            <p class="mt-2 text-2xl font-semibold" style="color: var(--ng-text)">{{ latestDisk is not null ? latestDisk|number_format(1, '.', '') ~ '%' : '—' }}</p>
                            <p class="text-xs" style="color: var(--ng-text-muted)">{{ t('admin_metrics_average', locale) }} {{ aggregate.disk_avg is not null ? aggregate.disk_avg|number_format(1, '.', '') ~ '%' : '—' }} · {{ aggregate.disk_max is not null ? aggregate.disk_max|number_format(1, '.', '') ~ '%' : '—' }}</p>
                            <svg viewBox="0 0 240 60" class="mt-3 h-16 w-full">
                                {% if diskPoints %}
                                    <polyline fill="none" stroke="#f59e0b" stroke-width="2" points="{{ diskPoints }}" />
                                {% else %}
                                    <text x="10" y="30" fill="#94a3b8">{{ t('admin_metrics_no_data', locale) }}</text>
                                {% endif %}
                            </svg>
                        </div>
                    </div>
                    <div class="ng-data-card">
                        <div class="ng-data-card__body">
                            <p class="form-label">{{ t('admin_metrics_network_traffic', locale) }}</p>
                            <p class="mt-2 text-xl font-semibold" style="color: var(--ng-text)">
                                {{ latestNetRecv is not null ? latestNetRecv|number_format(2, '.', '') : '—' }} /
                                {{ latestNetSent is not null ? latestNetSent|number_format(2, '.', '') : '—' }}
                                {{ t('admin_metrics_bandwidth_unit', locale) }}
                            </p>
                            <p class="text-xs" style="color: var(--ng-text-muted)">{{ t('admin_metrics_download', locale) }} · {{ t('admin_metrics_upload', locale) }}</p>
                            <svg viewBox="0 0 240 60" class="mt-3 h-16 w-full">
                                {% if netRecvPoints %}<polyline fill="none" stroke="#06b6d4" stroke-width="2" points="{{ netRecvPoints }}" />{% endif %}
                                {% if netSentPoints %}<polyline fill="none" stroke="#8b5cf6" stroke-width="2" points="{{ netSentPoints }}" />{% endif %}
                                {% if not netRecvPoints and not netSentPoints %}<text x="10" y="30" fill="#94a3b8">{{ t('admin_metrics_no_data', locale) }}</text>{% endif %}
                            </svg>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        {# ── Recent Samples Table ── #}
        <div class="ng-data-card">
            <div class="ng-data-card__header">
                <div>
                    <h2 class="ng-data-card__title">{{ t('admin_metrics_recent_samples_host', locale) }}</h2>
                    <p class="ng-data-card__sub">{{ t('admin_metrics_page_info', locale)|replace({'%page%': page, '%total%': hostTotalPages}) }}</p>
                </div>
            </div>
            <div class="ng-data-card__body--flush">
                <div class="cust-ws-table-wrap">
                    <table class="cust-table">
                        <thead>
                            <tr>
                                <th>{{ t('admin_metrics_recorded_at', locale) }}</th>
                                <th>CPU %</th>
                                <th>RAM %</th>
                                <th>Disk %</th>
                                <th>{{ t('admin_metrics_upload', locale) }} ({{ t('admin_metrics_bandwidth_unit', locale) }})</th>
                                <th>{{ t('admin_metrics_download', locale) }} ({{ t('admin_metrics_bandwidth_unit', locale) }})</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for sample in recentSamples %}
                                <tr>
                                    <td>{{ sample.recordedAt ? sample.recordedAt|date('Y-m-d H:i:s') : '—' }}</td>
                                    <td>{{ sample.cpuPercent is not null ? sample.cpuPercent|number_format(2, '.', '') ~ '%' : '—' }}</td>
                                    <td>{{ sample.memoryPercent is not null ? sample.memoryPercent|number_format(2, '.', '') : '—' }}</td>
                                    <td>{{ sample.diskPercent is not null ? sample.diskPercent|number_format(2, '.', '') : '—' }}</td>
                                    <td>{{ sampleBandwidth[sample.id].upload is not null ? sampleBandwidth[sample.id].upload|number_format(2, '.', '') : '—' }}</td>
                                    <td>{{ sampleBandwidth[sample.id].download is not null ? sampleBandwidth[sample.id].download|number_format(2, '.', '') : '—' }}</td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="6" class="cust-table__empty">{{ t('admin_metrics_no_data', locale) }}</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
                <div class="flex items-center justify-between px-4 py-3 text-sm">
                    <a class="ui-button ui-button--ghost ui-button--sm {{ page <= 1 ? 'pointer-events-none opacity-50' : '' }}" href="{{ path('admin_metrics', {tab: 'host', agent: selectedAgent ? selectedAgent.id : '', window: window, per_page: perPage, page: page - 1}) }}">{{ t('admin_metrics_previous', locale) }}</a>
                    <a class="ui-button ui-button--ghost ui-button--sm {{ page >= hostTotalPages ? 'pointer-events-none opacity-50' : '' }}" href="{{ path('admin_metrics', {tab: 'host', agent: selectedAgent ? selectedAgent.id : '', window: window, per_page: perPage, page: page + 1}) }}">{{ t('admin_metrics_next', locale) }}</a>
                </div>
            </div>
        </div>

    {% else %}

        {# ── Instances Filters ── #}
        <div class="ng-data-card">
            <div class="ng-data-card__body">
                <form method="get" action="{{ path('admin_metrics') }}" class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
                    <input type="hidden" name="tab" value="instances">
                    <div class="grid flex-1 gap-4 md:grid-cols-5">
                        <label class="form-field">
                            <span class="form-label">{{ t('admin_metrics_filter_node', locale) }}</span>
                            <select name="node" class="form-input mt-2">
                                <option value="">{{ t('admin_metrics_all', locale) }}</option>
                                {% for agent in agents %}
                                    <option value="{{ agent.id }}" {{ nodeFilter == agent.id ? 'selected' : '' }}>{{ agent.name ?? t('admin_metrics_node_unnamed', locale) }} · {{ agent.id }}</option>
                                {% endfor %}
                            </select>
                        </label>
                        <label class="form-field">
                            <span class="form-label">{{ t('admin_metrics_filter_customer', locale) }}</span>
                            <input name="customer" type="text" value="{{ customerFilter }}" class="form-input mt-2" placeholder="{{ t('admin_metrics_customer_placeholder', locale) }}">
                        </label>
                        <label class="form-field">
                            <span class="form-label">{{ t('admin_metrics_filter_instance', locale) }}</span>
                            <select name="instance" class="form-input mt-2">
                                <option value="">{{ t('admin_metrics_all_instances', locale) }}</option>
                                {% for instance in instances %}
                                    <option value="{{ instance.id }}" {{ selectedInstanceId == instance.id ? 'selected' : '' }}>{{ t('admin_metrics_instance_label', locale)|replace({'%id%': instance.id}) }}</option>
                                {% endfor %}
                            </select>
                        </label>
                        <label class="form-field">
                            <span class="form-label">{{ t('admin_metrics_filter_window', locale) }}</span>
                            <select name="window" class="form-input mt-2">
                                <option value="15m" {{ window == '15m' ? 'selected' : '' }}>15m</option>
                                <option value="60m" {{ window == '60m' ? 'selected' : '' }}>60m</option>
                                <option value="6h" {{ window == '6h' ? 'selected' : '' }}>6h</option>
                                <option value="24h" {{ window == '24h' ? 'selected' : '' }}>24h</option>
                                <option value="7d" {{ window == '7d' ? 'selected' : '' }}>7d</option>
                            </select>
                        </label>
                        <label class="form-field">
                            <span class="form-label">{{ t('admin_metrics_filter_per_page', locale) }}</span>
                            <select name="per_page" class="form-input mt-2">
                                {% for size in [50, 100, 200] %}
                                    <option value="{{ size }}" {{ perPage == size ? 'selected' : '' }}>{{ size }}</option>
                                {% endfor %}
                            </select>
                        </label>
                    </div>
                    <button class="ui-button ui-button--ghost ui-button--sm">{{ t('admin_metrics_filter_apply', locale) }}</button>
                </form>
            </div>
        </div>

        {# ── Instance Browse Table ── #}
        <div class="ng-data-card">
            <div class="ng-data-card__header">
                <div>
                    <h2 class="ng-data-card__title">{{ t('admin_metrics_instance_metrics_paged', locale) }}</h2>
                    <p class="ng-data-card__sub">{{ t('admin_metrics_samples_count', locale)|replace({'%count%': instanceBrowseTotal}) }} · {{ t('admin_metrics_page_info', locale)|replace({'%page%': page, '%total%': instanceBrowsePages}) }}</p>
                </div>
            </div>
            <div class="ng-data-card__body--flush">
                <div class="cust-ws-table-wrap">
                    <table class="cust-table">
                        <thead>
                            <tr>
                                <th>{{ t('admin_metrics_filter_instance', locale) }}</th>
                                <th>{{ t('admin_metrics_filter_customer', locale) }}</th>
                                <th>{{ t('admin_nodes_table_node', locale) }}</th>
                                <th>CPU %</th>
                                <th>{{ t('admin_metrics_ram_used', locale) }}</th>
                                <th>{{ t('admin_metrics_booked_cpu_ram', locale) }}</th>
                                <th>{{ t('admin_metrics_recorded_at', locale) }}</th>
                                <th>{{ t('admin_metrics_reason', locale) }}</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for row in instanceBrowseRows %}
                                <tr>
                                    <td><a class="text-indigo-700 underline" href="{{ path('admin_metrics', {tab: 'instances', node: nodeFilter, customer: customerFilter, instance: row.instance_id, window: window, per_page: perPage, page: 1}) }}">#{{ row.instance_id }}</a></td>
                                    <td>{{ row.customer_email }}</td>
                                    <td>{{ row.node_name ?? row.node_id }}</td>
                                    <td>{{ row.cpu_percent is not null ? row.cpu_percent|number_format(2, '.', '') ~ '%' : '—' }}</td>
                                    <td>{{ row.mem_used_bytes is not null ? (row.mem_used_bytes / 1024 / 1024)|number_format(0, '.', '') ~ ' MiB' : '—' }}</td>
                                    <td>{{ row.booked_cpu_cores|number_format(2, '.', '') }} cores / {{ row.booked_ram_mb }} MiB</td>
                                    <td>{{ row.collected_at ? row.collected_at|date('Y-m-d H:i:s') : '—' }}</td>
                                    <td>{{ row.error_code ?: '—' }}</td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="8" class="cust-table__empty">{{ t('admin_metrics_no_data', locale) }}</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
                <div class="flex items-center justify-between px-4 py-3 text-sm">
                    <a class="ui-button ui-button--ghost ui-button--sm {{ page <= 1 ? 'pointer-events-none opacity-50' : '' }}" href="{{ path('admin_metrics', {tab: 'instances', node: nodeFilter, customer: customerFilter, instance: selectedInstanceId, window: window, per_page: perPage, page: page - 1}) }}">{{ t('admin_metrics_previous', locale) }}</a>
                    <a class="ui-button ui-button--ghost ui-button--sm {{ page >= instanceBrowsePages ? 'pointer-events-none opacity-50' : '' }}" href="{{ path('admin_metrics', {tab: 'instances', node: nodeFilter, customer: customerFilter, instance: selectedInstanceId, window: window, per_page: perPage, page: page + 1}) }}">{{ t('admin_metrics_next', locale) }}</a>
                </div>
            </div>
        </div>

        {# ── Instance Detail ── #}
        {% if selectedInstance %}
            <div class="ng-data-card">
                <div class="ng-data-card__header">
                    <div>
                        <h2 class="ng-data-card__title">{{ t('admin_metrics_instance_detail', locale) }} · #{{ selectedInstance.id }}</h2>
                        <p class="ng-data-card__sub">
                            {{ selectedInstance.customer_email }} · {{ selectedInstance.node_name ?? selectedInstance.node_id }}
                            · {{ t('customer_resource_booked_cpu', locale) }} {{ selectedInstance.booked_cpu_cores|number_format(2, '.', '') }} cores
                            · {{ t('customer_resource_booked_ram', locale) }} {{ selectedInstance.booked_ram_mb }} MiB
                        </p>
                    </div>
                    <div class="ng-data-card__actions">
                        <span class="ui-badge ui-badge--info">{{ t('admin_metrics_samples_count', locale)|replace({'%count%': instanceMetricTotal}) }}</span>
                    </div>
                </div>
                <div class="ng-data-card__body">
                    <div class="grid grid-cols-1 gap-4 md:grid-cols-2 mb-4">
                        <div class="ng-data-card">
                            <div class="ng-data-card__body">
                                <p class="form-label">{{ t('admin_metrics_cpu_sparkline', locale) }}</p>
                                <svg viewBox="0 0 240 60" class="mt-2 h-16 w-full">
                                    {% if instanceCpuPoints %}
                                        <polyline fill="none" stroke="#6366f1" stroke-width="2" points="{{ instanceCpuPoints }}" />
                                    {% else %}
                                        <text x="10" y="30" fill="#94a3b8">{{ t('admin_metrics_no_data', locale) }}</text>
                                    {% endif %}
                                </svg>
                            </div>
                        </div>
                        <div class="ng-data-card">
                            <div class="ng-data-card__body">
                                <p class="form-label">{{ t('admin_metrics_ram_sparkline', locale) }}</p>
                                <svg viewBox="0 0 240 60" class="mt-2 h-16 w-full">
                                    {% if instanceMemPoints %}
                                        <polyline fill="none" stroke="#10b981" stroke-width="2" points="{{ instanceMemPoints }}" />
                                    {% else %}
                                        <text x="10" y="30" fill="#94a3b8">{{ t('admin_metrics_no_data', locale) }}</text>
                                    {% endif %}
                                </svg>
                            </div>
                        </div>
                    </div>

                    <div class="cust-ws-table-wrap">
                        <table class="cust-table">
                            <thead>
                                <tr>
                                    <th>{{ t('admin_metrics_collected_at', locale) }}</th>
                                    <th>CPU %</th>
                                    <th>{{ t('admin_metrics_ram_used', locale) }}</th>
                                    <th>{{ t('admin_metrics_booked_cpu_ram', locale) }}</th>
                                    <th>{{ t('admin_metrics_tasks', locale) }}</th>
                                    <th>{{ t('admin_metrics_reason', locale) }}</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for sample in instanceMetricRecent %}
                                    <tr>
                                        <td>{{ sample.collectedAt ? sample.collectedAt|date('Y-m-d H:i:s') : '—' }}</td>
                                        <td>{{ sample.cpuPercent is not null ? sample.cpuPercent|number_format(2, '.', '') ~ '%' : '—' }}</td>
                                        <td>{{ sample.memUsedBytes is not null ? (sample.memUsedBytes / 1024 / 1024)|number_format(0, '.', '') ~ ' MiB' : '—' }}</td>
                                        <td>{{ selectedInstance.booked_cpu_cores|number_format(2, '.', '') }} cores / {{ selectedInstance.booked_ram_mb }} MiB</td>
                                        <td>{{ sample.tasksCurrent is not null ? sample.tasksCurrent : '—' }}</td>
                                        <td>{{ sample.errorCode ?: '—' }}</td>
                                    </tr>
                                {% else %}
                                    <tr>
                                        <td colspan="6" class="cust-table__empty">{{ t('admin_metrics_no_data', locale) }}</td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        {% endif %}

    {% endif %}

</div>
{% endblock %}
