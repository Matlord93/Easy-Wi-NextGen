{% extends 'admin/base.html.twig' %}

{% set pageTitle = t('admin_mail_aliases_title', page_locale()) %}
{% set pageSubtitle = t('admin_mail_aliases_intro', page_locale()) %}
{% set activeNav = 'mail-aliases' %}
{% set topbarActions %}
    <button
        class="ui-button ui-button--ghost ui-button--sm"
        hx-get="/admin/mail-aliases/table"
        hx-target="#mail-aliases-table"
        hx-swap="outerHTML"
    >{{ t('refresh', page_locale()) }}</button>
    <button
        class="ui-button ui-button--primary ui-button--sm"
        hx-get="/admin/mail-aliases/form"
        hx-target="#mail-alias-form"
        hx-swap="outerHTML"
    >{{ t('admin_mail_aliases_new', page_locale()) }}</button>
{% endset %}

{% block content %}
<div class="flex flex-col gap-6">

    <div class="ng-kpi-row">
        <div class="ng-kpi-box">
            <div class="ng-kpi-box__label">{{ t('admin_mail_aliases_total', page_locale()) }}</div>
            <div class="ng-kpi-box__value">{{ summary.total }}</div>
        </div>
        <div class="ng-kpi-box">
            <div class="ng-kpi-box__label">{{ t('admin_status_enabled', page_locale()) }}</div>
            <div class="ng-kpi-box__value ng-kpi-box__value--success">{{ summary.enabled }}</div>
        </div>
        <div class="ng-kpi-box">
            <div class="ng-kpi-box__label">{{ t('admin_status_disabled', page_locale()) }}</div>
            <div class="ng-kpi-box__value ng-kpi-box__value--danger">{{ summary.disabled }}</div>
        </div>
        <div class="ng-kpi-box">
            <div class="ng-kpi-box__label">{{ t('admin_mail_aliases_destinations', page_locale()) }}</div>
            <div class="ng-kpi-box__value ng-kpi-box__value--primary">{{ summary.destinations }}</div>
        </div>
    </div>

    <div class="ng-layout-2col">
        <div id="mail-alias-form" class="ng-data-card">
            <div class="ng-data-card__body">
                {% include 'admin/mail-aliases/_form.html.twig' with { domains: domains, form: form } %}
            </div>
        </div>

        <div id="mail-aliases-table" class="ng-data-card"
             hx-get="/admin/mail-aliases/table"
             hx-trigger="mail-aliases-changed from:body"
             hx-swap="outerHTML">
            <div class="ng-data-card__body--flush">
                {% include 'admin/mail-aliases/_table.html.twig' with { aliases: aliases } %}
            </div>
        </div>
    </div>

</div>
{% endblock %}
