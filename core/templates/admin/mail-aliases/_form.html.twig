<div class="ng-data-card__header">
    <div>
        <h2 class="ng-data-card__title">{{ form.action == 'create' ? t('admin_mail_aliases_create_title', page_locale()) : t('admin_mail_aliases_edit_title', page_locale()) }}</h2>
        <p class="ng-data-card__sub">{{ t('admin_mail_aliases_form_intro', page_locale()) }}</p>
    </div>
</div>
<div class="ng-data-card__body">
    {% if form.errors is not empty %}
        <div class="ng-alert ng-alert--danger mb-4">
            <p class="font-semibold">{{ t('admin_form_fix_following', page_locale()) }}</p>
            <ul class="list-disc pl-5 mt-2">
                {% for error in form.errors %}
                    <li>{{ error }}</li>
                {% endfor %}
            </ul>
        </div>
    {% endif %}

    <form
        class="flex flex-col gap-4"
        hx-post="{{ form.action_url }}"
        hx-target="#mail-alias-form"
        hx-swap="outerHTML"
    >
        <div class="form-field">
            <label class="form-label">{{ t('admin_mail_aliases_domain', page_locale()) }}</label>
            <select name="domain_id" class="form-input" {{ form.action == 'update' ? 'disabled' : '' }}>
                <option value="">{{ t('admin_mail_aliases_domain_select', page_locale()) }}</option>
                {% for domain in domains %}
                    <option value="{{ domain.id }}" {{ domain.id == form.domain_id ? 'selected' : '' }}>{{ domain.name }}</option>
                {% endfor %}
            </select>
        </div>

        <div class="form-field">
            <label class="form-label">{{ t('admin_mail_aliases_name', page_locale()) }}</label>
            <input
                type="text"
                name="local_part"
                value="{{ form.local_part }}"
                placeholder="{{ t('admin_mail_aliases_name_placeholder', page_locale()) }}"
                class="form-input"
                {{ form.action == 'update' ? 'disabled' : '' }}
            >
            {% if form.address %}
                <p class="form-hint">{{ t('admin_mail_aliases_address_label', page_locale()) }}: <strong>{{ form.address }}</strong></p>
            {% endif %}
        </div>

        <div class="form-field">
            <label class="form-label">{{ t('admin_mail_aliases_destinations', page_locale()) }}</label>
            <textarea
                name="destinations"
                rows="3"
                placeholder="{{ t('admin_mail_aliases_destinations_placeholder', page_locale()) }}"
                class="form-input"
            >{{ form.destinations }}</textarea>
            <p class="form-hint">{{ t('admin_mail_aliases_destinations_hint', page_locale()) }}</p>
        </div>

        <label class="inline-flex items-center gap-2 text-sm" style="color:var(--ng-text-muted);">
            <input id="alias-enabled" name="enabled" type="checkbox" value="1" {{ form.enabled ? 'checked' : '' }}>
            {{ t('admin_mail_aliases_enabled_forwarding', page_locale()) }}
        </label>

        <div class="flex items-center gap-3">
            <button type="submit" class="ui-button ui-button--primary">{{ form.submit_label }}</button>
            <button
                type="button"
                class="ui-button ui-button--ghost"
                hx-get="/admin/mail-aliases/form"
                hx-target="#mail-alias-form"
                hx-swap="outerHTML"
            >{{ t('reset', page_locale()) }}</button>
        </div>
    </form>
</div>
