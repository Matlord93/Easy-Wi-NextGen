<div id="mail-aliases-table"
    hx-get="/admin/mail-aliases/table"
    hx-trigger="mail-aliases-changed from:body"
    hx-swap="outerHTML">
<div class="ng-data-card__header">
    <div>
        <h2 class="ng-data-card__title">{{ t('admin_mail_aliases_inventory_title', page_locale()) }}</h2>
        <p class="ng-data-card__sub">{{ t('admin_mail_aliases_inventory_intro', page_locale()) }}</p>
    </div>
    <div class="ng-data-card__actions">
        <button
            class="ui-button ui-button--ghost ui-button--sm"
            hx-get="/admin/mail-aliases/table"
            hx-target="#mail-aliases-table"
            hx-swap="outerHTML"
        >{{ t('refresh', page_locale()) }}</button>
    </div>
</div>
<div class="cust-ws-table-wrap">
    <table class="cust-table">
        <thead>
            <tr>
                <th>{{ t('admin_mail_aliases_table_alias', page_locale()) }}</th>
                <th>{{ t('admin_mail_aliases_table_destinations', page_locale()) }}</th>
                <th>{{ t('status', page_locale()) }}</th>
                <th>{{ t('updated', page_locale()) }}</th>
                <th>{{ t('actions', page_locale()) }}</th>
            </tr>
        </thead>
        <tbody>
            {% for alias in aliases %}
                <tr>
                    <td>
                        <div style="font-weight:600;color:var(--ng-text);">{{ alias.address }}</div>
                        <div style="font-size:11px;color:var(--ng-text-muted);">{{ alias.domain.name }}</div>
                    </td>
                    <td>
                        {% if alias.destinations is not empty %}
                            <ul style="margin:0;padding:0;list-style:none;display:flex;flex-direction:column;gap:2px;">
                                {% for destination in alias.destinations %}
                                    <li style="font-size:11px;color:var(--ng-text-muted);">{{ destination }}</li>
                                {% endfor %}
                            </ul>
                        {% else %}
                            <span style="font-size:11px;color:var(--ng-text-muted);">{{ t('admin_mail_aliases_no_destinations', page_locale()) }}</span>
                        {% endif %}
                    </td>
                    <td>
                        {% if alias.enabled %}
                            <span class="ui-badge ui-badge--success">{{ t('admin_status_enabled', page_locale()) }}</span>
                        {% else %}
                            <span class="ui-badge ui-badge--neutral">{{ t('admin_status_disabled', page_locale()) }}</span>
                        {% endif %}
                    </td>
                    <td style="font-size:11px;color:var(--ng-text-muted);">{{ alias.updatedAt|date('Y-m-d H:i') }}</td>
                    <td>
                        <div style="display:flex;align-items:center;gap:6px;">
                            <button
                                class="ui-button ui-button--ghost ui-button--sm"
                                hx-get="/admin/mail-aliases/{{ alias.id }}/edit"
                                hx-target="#mail-alias-form"
                                hx-swap="outerHTML"
                            >{{ t('edit', page_locale()) }}</button>
                            {% if alias.enabled %}
                                <button
                                    class="ui-button ui-button--danger ui-button--sm"
                                    hx-post="/admin/mail-aliases/{{ alias.id }}/disable"
                                    hx-target="#mail-aliases-table"
                                    hx-swap="outerHTML"
                                >{{ t('disable', page_locale()) }}</button>
                            {% else %}
                                <button
                                    class="ui-button ui-button--ghost ui-button--sm"
                                    hx-post="/admin/mail-aliases/{{ alias.id }}/enable"
                                    hx-target="#mail-aliases-table"
                                    hx-swap="outerHTML"
                                >{{ t('enable', page_locale()) }}</button>
                            {% endif %}
                            <button
                                class="ui-button ui-button--danger ui-button--sm"
                                hx-post="/admin/mail-aliases/{{ alias.id }}/delete"
                                hx-target="#mail-aliases-table"
                                hx-swap="outerHTML"
                            >{{ t('delete', page_locale()) }}</button>
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="5" class="cust-table__empty">{{ t('admin_mail_aliases_empty', page_locale()) }}</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>

</div>{# end #mail-aliases-table #}
