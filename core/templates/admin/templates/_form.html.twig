{% if form.errors is not empty %}
    <div class="ng-alert ng-alert--danger" style="margin-bottom:16px;">
        <p style="font-weight:600;margin-bottom:4px;">{{ t('admin_form_fix_following', page_locale()) }}</p>
        <ul style="list-style:disc;padding-left:20px;margin-top:4px;">
            {% for error in form.errors %}
                <li>{{ error }}</li>
            {% endfor %}
        </ul>
    </div>
{% endif %}

<form
    id="template-form"
    hx-post="{{ form.is_edit ? '/admin/templates/' ~ form.template_id : '/admin/templates' }}"
    hx-target="#template-form"
    hx-swap="outerHTML"
    style="display:flex;flex-direction:column;gap:16px;"
>
    <div class="form-field">
        <label class="form-label">{{ t('admin_templates_game_key', page_locale()) }}</label>
        <input name="game_key" value="{{ form.game_key }}" placeholder="{{ t('admin_templates_game_key_placeholder', page_locale()) }}" class="form-input">
        <p style="margin-top:4px;font-size:12px;color:var(--text-muted);">{{ t('admin_templates_game_key_hint', page_locale()) }}</p>
    </div>

    <div class="form-field">
        <label class="form-label">{{ t('admin_templates_display_name', page_locale()) }}</label>
        <input name="display_name" value="{{ form.display_name }}" placeholder="{{ t('admin_templates_display_name_placeholder', page_locale()) }}" class="form-input">
    </div>

    <div class="form-field">
        <label class="form-label">{{ t('description', page_locale()) }}</label>
        <textarea name="description" rows="2" class="form-textarea" placeholder="{{ t('admin_templates_description_placeholder', page_locale()) }}">{{ form.description }}</textarea>
    </div>

    <div class="form-field">
        <label class="form-label">{{ t('admin_templates_steam_app_id', page_locale()) }}</label>
        <input name="steam_app_id" value="{{ form.steam_app_id }}" placeholder="{{ t('admin_templates_steam_app_id_placeholder', page_locale()) }}" class="form-input">
        <p style="margin-top:4px;font-size:12px;color:var(--text-muted);">{{ t('admin_templates_steam_app_id_hint', page_locale()) }}</p>
    </div>

    <div class="form-field">
        <label class="form-label">{{ t('admin_templates_sniper_profile', page_locale()) }}</label>
        <input name="sniper_profile" value="{{ form.sniper_profile }}" placeholder="{{ t('admin_templates_sniper_profile_placeholder', page_locale()) }}" class="form-input">
        <p style="margin-top:4px;font-size:12px;color:var(--text-muted);">{{ t('admin_templates_sniper_profile_hint', page_locale()) }}</p>
    </div>

    <div class="form-field">
        <label class="form-label">{{ t('admin_templates_required_ports', page_locale()) }}</label>
        {% set selected_ports = form.required_ports is iterable ? form.required_ports : [] %}
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:6px;">
            {% for port in ['game', 'query', 'rcon', 'tv'] %}
                <label style="display:flex;align-items:center;gap:8px;padding:8px 12px;border:1px solid var(--border);border-radius:6px;font-size:13px;cursor:pointer;">
                    <input type="checkbox" name="required_ports[]" value="{{ port }}" {% if port in selected_ports %}checked{% endif %}>
                    <span style="font-weight:500;">{{ port|upper }}</span>
                </label>
            {% endfor %}
        </div>
        <p style="margin-top:4px;font-size:12px;color:var(--text-muted);">{{ t('admin_templates_ports_hint', page_locale()) }}</p>
    </div>

    <div class="form-field">
        <label class="form-label">{{ t('admin_templates_fixed_start_params', page_locale()) }}</label>
        <textarea name="start_params" rows="2" class="form-textarea" placeholder="{{ t('admin_templates_fixed_start_params_placeholder', page_locale()) }}">{{ form.start_params }}</textarea>
        <p style="margin-top:4px;font-size:12px;color:var(--text-muted);">{{ t('admin_templates_fixed_start_params_hint', page_locale()) }}</p>
    </div>

    <div class="form-field">
        <label class="form-label">{{ t('admin_templates_env_vars', page_locale()) }}</label>
        <textarea name="env_vars" rows="3" class="form-textarea" placeholder="{{ t('admin_templates_env_vars_placeholder', page_locale()) }}">{{ form.env_vars }}</textarea>
    </div>

    <div class="form-field">
        <label class="form-label">{{ t('admin_templates_requirement_vars', page_locale()) }}</label>
        <textarea name="requirement_vars" rows="4" class="form-textarea" placeholder="{{ t('admin_templates_requirement_vars_placeholder', page_locale()) }}">{{ form.requirement_vars }}</textarea>
        <p style="margin-top:4px;font-size:12px;color:var(--text-muted);">{{ t('admin_templates_requirement_vars_hint', page_locale()) }}</p>
    </div>

    <div class="form-field">
        <label class="form-label">{{ t('admin_templates_requirement_secrets', page_locale()) }}</label>
        <textarea name="requirement_secrets" rows="4" class="form-textarea" placeholder="{{ t('admin_templates_requirement_secrets_placeholder', page_locale()) }}">{{ form.requirement_secrets }}</textarea>
        <p style="margin-top:4px;font-size:12px;color:var(--text-muted);">{{ t('admin_templates_requirement_secrets_hint', page_locale()) }}</p>
    </div>

    <div class="form-field">
        <label class="form-label">{{ t('admin_templates_shared_paths', page_locale()) }}</label>
        <textarea name="shared_paths" rows="4" class="form-textarea" placeholder='[{"source":"maps","target":"maps","mode":"symlink","readonly":true}]'>{{ form.shared_paths }}</textarea>
        <p style="margin-top:4px;font-size:12px;color:var(--text-muted);">{{ t('admin_templates_shared_paths_hint', page_locale()) }}</p>
    </div>

    <div class="form-field">
        <label class="form-label">{{ t('admin_templates_config_files', page_locale()) }}</label>
        <textarea name="config_files" rows="3" class="form-textarea" placeholder="{{ t('admin_templates_config_files_placeholder', page_locale()) }}">{{ form.config_files }}</textarea>
    </div>

    <div class="form-field">
        <label class="form-label">{{ t('admin_templates_plugin_paths', page_locale()) }}</label>
        <textarea name="plugin_paths" rows="2" class="form-textarea" placeholder="{{ t('admin_templates_plugin_paths_placeholder', page_locale()) }}">{{ form.plugin_paths }}</textarea>
    </div>

    <div style="border:1px solid var(--border);border-radius:8px;padding:16px;">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;">
            <span style="font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:0.05em;">{{ t('admin_templates_fastdl_settings', page_locale()) }}</span>
            <label style="display:flex;align-items:center;gap:8px;font-size:12px;font-weight:500;cursor:pointer;">
                <input type="checkbox" name="fastdl_enabled" value="1" {% if form.fastdl_enabled %}checked{% endif %}>
                {{ t('admin_status_enabled', page_locale()) }}
            </label>
        </div>
        <div style="display:flex;flex-direction:column;gap:8px;">
            <input name="fastdl_base_url" value="{{ form.fastdl_base_url }}" placeholder="{{ t('admin_templates_fastdl_base_url_placeholder', page_locale()) }}" class="form-input">
            <input name="fastdl_root_path" value="{{ form.fastdl_root_path }}" placeholder="{{ t('admin_templates_fastdl_root_placeholder', page_locale()) }}" class="form-input">
        </div>
    </div>

    <div class="form-field">
        <label class="form-label">{{ t('admin_templates_install_command', page_locale()) }}</label>
        <textarea name="install_command" rows="2" class="form-textarea" placeholder="{{ t('admin_templates_install_command_placeholder', page_locale()) }}">{{ form.install_command }}</textarea>
    </div>

    <div class="form-field">
        <label class="form-label">{{ t('admin_templates_update_command', page_locale()) }}</label>
        <textarea name="update_command" rows="2" class="form-textarea" placeholder="{{ t('admin_templates_update_command_placeholder', page_locale()) }}">{{ form.update_command }}</textarea>
    </div>

    <div class="form-field">
        <label class="form-label">{{ t('admin_templates_install_resolver', page_locale()) }}</label>
        <textarea name="install_resolver" rows="2" class="form-textarea" placeholder='{"type":"minecraft_vanilla"}'>{{ form.install_resolver }}</textarea>
        <p style="margin-top:4px;font-size:12px;color:var(--text-muted);">{{ t('admin_templates_install_resolver_hint', page_locale()) }}</p>
    </div>

    <div class="form-field">
        <label class="form-label">{{ t('admin_templates_switch_flags', page_locale()) }}</label>
        <input name="allowed_switch_flags" value="{{ form.allowed_switch_flags }}" placeholder="{{ t('admin_templates_switch_flags_placeholder', page_locale()) }}" class="form-input">
    </div>

    <div style="display:flex;flex-wrap:wrap;align-items:center;gap:12px;">
        <button type="submit" class="ui-button ui-button--primary">
            {{ form.is_edit ? t('admin_templates_update_submit', page_locale()) : t('admin_templates_create_submit', page_locale()) }}
        </button>
        <button
            type="button"
            class="ui-button ui-button--ghost"
            hx-get="{{ form.reset_url }}"
            hx-target="#template-form"
            hx-swap="outerHTML"
        >{{ t('reset', page_locale()) }}</button>
        {% if form.preview_url %}
            <a class="ui-button ui-button--ghost" href="{{ form.preview_url }}">{{ t('admin_templates_preview', page_locale()) }}</a>
        {% endif %}
    </div>
</form>
