<div style="display:flex;flex-direction:column;gap:16px;">
    {% if preview.errors is not empty %}
        <div class="ng-alert ng-alert--danger">
            <p style="font-weight:600;margin-bottom:4px;">
                {{ t('admin_templates_preview_validation', 'de') }} / {{ t('admin_templates_preview_validation', 'en') }}
            </p>
            <ul style="list-style:disc;padding-left:20px;margin-top:4px;">
                {% for error in preview.errors %}
                    <li>{{ error }}</li>
                {% endfor %}
            </ul>
        </div>
    {% endif %}

    {% if preview.identity is not defined %}
        <p style="font-size:13px;color:var(--text-muted);">
            {{ t('admin_templates_preview_empty', 'de') }} / {{ t('admin_templates_preview_empty', 'en') }}
        </p>
    {% else %}

        <div class="ng-data-card" style="margin:0;">
            <div class="ng-data-card__header">
                <div>
                    <h3 class="ng-data-card__title" style="font-size:12px;text-transform:uppercase;letter-spacing:0.05em;">
                        {{ t('admin_templates_preview_identity', 'de') }} / {{ t('admin_templates_preview_identity', 'en') }}
                    </h3>
                </div>
            </div>
            <div class="ng-data-card__body">
                <p style="font-weight:600;margin-bottom:4px;">{{ preview.identity.display_name }}</p>
                <p style="font-size:12px;color:var(--text-muted);">
                    {{ t('admin_templates_preview_key', 'de') }} / {{ t('admin_templates_preview_key', 'en') }}:
                    {{ preview.identity.game_key }}
                </p>
                {% if preview.identity.steam_app_id %}
                    <p style="font-size:12px;color:var(--text-muted);">
                        {{ t('admin_templates_preview_steam_app_id', 'de') }} / {{ t('admin_templates_preview_steam_app_id', 'en') }}:
                        {{ preview.identity.steam_app_id }}
                    </p>
                {% endif %}
                {% if preview.identity.sniper_profile %}
                    <p style="font-size:12px;color:var(--text-muted);">
                        {{ t('admin_templates_preview_sniper_profile', 'de') }} / {{ t('admin_templates_preview_sniper_profile', 'en') }}:
                        {{ preview.identity.sniper_profile }}
                    </p>
                {% endif %}
            </div>
        </div>

        <div class="ng-data-card" style="margin:0;">
            <div class="ng-data-card__header">
                <div>
                    <h3 class="ng-data-card__title" style="font-size:12px;text-transform:uppercase;letter-spacing:0.05em;">
                        {{ t('admin_templates_preview_required_ports', 'de') }} / {{ t('admin_templates_preview_required_ports', 'en') }}
                    </h3>
                </div>
            </div>
            <div class="ng-data-card__body">
                <div style="display:flex;flex-wrap:wrap;gap:8px;">
                    {% for port in preview.required_ports %}
                        <span class="ui-badge ui-badge--neutral">{{ port.label ?? port.name }} · {{ port.protocol|upper }}</span>
                    {% else %}
                        <span style="font-size:12px;color:var(--text-muted);">
                            {{ t('admin_templates_preview_no_ports', 'de') }} / {{ t('admin_templates_preview_no_ports', 'en') }}
                        </span>
                    {% endfor %}
                </div>
            </div>
        </div>

        <div class="ng-data-card" style="margin:0;">
            <div class="ng-data-card__header">
                <div>
                    <h3 class="ng-data-card__title" style="font-size:12px;text-transform:uppercase;letter-spacing:0.05em;">
                        {{ t('admin_templates_preview_start_params', 'de') }} / {{ t('admin_templates_preview_start_params', 'en') }}
                    </h3>
                </div>
            </div>
            <div class="ng-data-card__body">
                <pre style="white-space:pre-wrap;font-size:12px;color:var(--text-muted);">{{ preview.start_params }}</pre>
            </div>
        </div>

        <div class="ng-data-card" style="margin:0;">
            <div class="ng-data-card__header">
                <div>
                    <h3 class="ng-data-card__title" style="font-size:12px;text-transform:uppercase;letter-spacing:0.05em;">
                        {{ t('admin_templates_preview_commands', 'de') }} / {{ t('admin_templates_preview_commands', 'en') }}
                    </h3>
                </div>
            </div>
            <div class="ng-data-card__body">
                <p style="font-size:12px;color:var(--text-muted);">
                    <span style="font-weight:600;">
                        {{ t('admin_templates_install_label', 'de') }} / {{ t('admin_templates_install_label', 'en') }}:
                    </span>
                    {{ preview.install_command }}
                </p>
                <p style="font-size:12px;color:var(--text-muted);margin-top:6px;">
                    <span style="font-weight:600;">
                        {{ t('admin_templates_update_label', 'de') }} / {{ t('admin_templates_update_label', 'en') }}:
                    </span>
                    {{ preview.update_command }}
                </p>
            </div>
        </div>

        <div class="ng-data-card" style="margin:0;">
            <div class="ng-data-card__header">
                <div>
                    <h3 class="ng-data-card__title" style="font-size:12px;text-transform:uppercase;letter-spacing:0.05em;">
                        {{ t('admin_templates_preview_env_vars', 'de') }} / {{ t('admin_templates_preview_env_vars', 'en') }}
                    </h3>
                </div>
            </div>
            <div class="ng-data-card__body">
                <div style="display:flex;flex-direction:column;gap:4px;">
                    {% for entry in preview.env_vars %}
                        <div style="font-size:12px;color:var(--text-muted);">
                            <span style="font-weight:600;">{{ entry.key }}</span>=<span>{{ entry.value }}</span>
                        </div>
                    {% else %}
                        <div style="font-size:12px;color:var(--text-muted);">
                            {{ t('admin_templates_preview_no_env_vars', 'de') }} / {{ t('admin_templates_preview_no_env_vars', 'en') }}
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>

        <div class="ng-data-card" style="margin:0;">
            <div class="ng-data-card__header">
                <div>
                    <h3 class="ng-data-card__title" style="font-size:12px;text-transform:uppercase;letter-spacing:0.05em;">
                        {{ t('admin_templates_preview_config_files', 'de') }} / {{ t('admin_templates_preview_config_files', 'en') }}
                    </h3>
                </div>
            </div>
            <div class="ng-data-card__body">
                <div style="display:flex;flex-direction:column;gap:8px;">
                    {% for entry in preview.config_files %}
                        <div style="font-size:12px;">
                            <p style="font-weight:600;">{{ entry.path }}</p>
                            {% if entry.description %}
                                <p style="color:var(--text-muted);">{{ entry.description }}</p>
                            {% endif %}
                        </div>
                    {% else %}
                        <div style="font-size:12px;color:var(--text-muted);">
                            {{ t('admin_templates_preview_no_config_files', 'de') }} / {{ t('admin_templates_preview_no_config_files', 'en') }}
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>

        <div class="ng-data-card" style="margin:0;">
            <div class="ng-data-card__header">
                <div>
                    <h3 class="ng-data-card__title" style="font-size:12px;text-transform:uppercase;letter-spacing:0.05em;">
                        {{ t('admin_templates_preview_plugin_paths', 'de') }} / {{ t('admin_templates_preview_plugin_paths', 'en') }}
                    </h3>
                </div>
            </div>
            <div class="ng-data-card__body">
                <div style="display:flex;flex-direction:column;gap:4px;">
                    {% for entry in preview.plugin_paths %}
                        <div style="font-size:12px;color:var(--text-muted);">{{ entry }}</div>
                    {% else %}
                        <div style="font-size:12px;color:var(--text-muted);">
                            {{ t('admin_templates_preview_no_plugin_paths', 'de') }} / {{ t('admin_templates_preview_no_plugin_paths', 'en') }}
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>

        <div class="ng-data-card" style="margin:0;">
            <div class="ng-data-card__header">
                <div>
                    <h3 class="ng-data-card__title" style="font-size:12px;text-transform:uppercase;letter-spacing:0.05em;">
                        {{ t('admin_templates_preview_fastdl', 'de') }} / {{ t('admin_templates_preview_fastdl', 'en') }}
                    </h3>
                </div>
            </div>
            <div class="ng-data-card__body">
                <p style="font-size:12px;color:var(--text-muted);">
                    {{ t('admin_templates_preview_fastdl_enabled', 'de') }} / {{ t('admin_templates_preview_fastdl_enabled', 'en') }}:
                    {{ preview.fastdl_settings.enabled ? t('admin_status_enabled', page_locale()) : t('admin_status_disabled', page_locale()) }}
                </p>
                {% if preview.fastdl_settings.base_url %}
                    <p style="font-size:12px;color:var(--text-muted);margin-top:4px;">
                        {{ t('admin_templates_preview_fastdl_base_url', 'de') }} / {{ t('admin_templates_preview_fastdl_base_url', 'en') }}:
                        {{ preview.fastdl_settings.base_url }}
                    </p>
                {% endif %}
                {% if preview.fastdl_settings.root_path %}
                    <p style="font-size:12px;color:var(--text-muted);margin-top:4px;">
                        {{ t('admin_templates_preview_fastdl_root_path', 'de') }} / {{ t('admin_templates_preview_fastdl_root_path', 'en') }}:
                        {{ preview.fastdl_settings.root_path }}
                    </p>
                {% endif %}
            </div>
        </div>

        <div class="ng-data-card" style="margin:0;">
            <div class="ng-data-card__header">
                <div>
                    <h3 class="ng-data-card__title" style="font-size:12px;text-transform:uppercase;letter-spacing:0.05em;">
                        {{ t('admin_templates_preview_dry_run', 'de') }} / {{ t('admin_templates_preview_dry_run', 'en') }}
                    </h3>
                </div>
            </div>
            <div class="ng-data-card__body">
                <ul style="list-style:disc;padding-left:20px;display:flex;flex-direction:column;gap:4px;">
                    {% for step in preview.dry_run_steps %}
                        <li style="font-size:12px;color:var(--text-muted);">{{ step }}</li>
                    {% else %}
                        <li style="font-size:12px;color:var(--text-muted);">
                            {{ t('admin_templates_preview_no_actions', 'de') }} / {{ t('admin_templates_preview_no_actions', 'en') }}
                        </li>
                    {% endfor %}
                </ul>
            </div>
        </div>

    {% endif %}
</div>
