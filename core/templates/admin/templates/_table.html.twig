<div id="templates-table" class="cust-ws-table-wrap" hx-trigger="templates-changed from:body" hx-get="/admin/templates/table" hx-swap="outerHTML">
    <table class="cust-table">
        <thead>
            <tr>
                <th>{{ t('admin_templates_table_template', page_locale()) }}</th>
                <th>{{ t('admin_templates_table_ports', page_locale()) }}</th>
                <th>{{ t('admin_templates_table_start_params', page_locale()) }}</th>
                <th>{{ t('admin_templates_table_commands', page_locale()) }}</th>
                <th>{{ t('admin_templates_table_switch_flags', page_locale()) }}</th>
                <th style="text-align:right;">{{ t('admin_templates_table_actions', page_locale()) }}</th>
            </tr>
        </thead>
        <tbody>
            {% for template in templates %}
                <tr>
                    <td>
                        <div style="display:flex;flex-wrap:wrap;align-items:center;gap:8px;">
                            <div style="font-weight:600;">{{ template.displayName }}</div>
                            {% set supportedOs = template.supported_os ?? template.supportedOs ?? [] %}
                            {% if supportedOs is not empty %}
                                {% set hasLinux = 'linux' in supportedOs %}
                                {% set hasWindows = 'windows' in supportedOs %}
                                {% if hasLinux and hasWindows %}
                                    {% set osLabel = 'Both' %}
                                    {% set osClass = 'ui-badge--info' %}
                                {% elseif hasWindows %}
                                    {% set osLabel = 'Windows' %}
                                    {% set osClass = 'ui-badge--neutral' %}
                                {% else %}
                                    {% set osLabel = 'Linux' %}
                                    {% set osClass = 'ui-badge--primary' %}
                                {% endif %}
                                <span class="ui-badge {{ osClass }}">{{ osLabel }}</span>
                            {% endif %}
                        </div>
                        <div style="font-size:11px;color:var(--text-muted);margin-top:4px;">
                            {{ t('admin_templates_game_key_label', page_locale()) }}: {{ template.game_key }}
                        </div>
                        {% if template.steamAppId %}
                            <div style="font-size:11px;color:var(--text-muted);margin-top:2px;">
                                {{ t('admin_templates_steam_app_id_label', page_locale()) }}: {{ template.steamAppId }}
                            </div>
                        {% endif %}
                        {% if template.sniper_profile %}
                            <div style="font-size:11px;color:var(--text-muted);margin-top:2px;">
                                {{ t('admin_templates_sniper_profile_label', page_locale()) }}: {{ template.sniper_profile }}
                            </div>
                        {% endif %}
                        {% if template.description %}
                            <div style="font-size:11px;color:var(--text-muted);margin-top:2px;">{{ template.description }}</div>
                        {% endif %}
                        <div style="font-size:11px;color:var(--text-muted);margin-top:6px;">
                            {{ t('updated', page_locale()) }} {{ template.updated_at|date('Y-m-d H:i') }}
                        </div>
                    {% set sync = template.shared_paths_sync ?? null %}
                        {% if sync and sync.seed is not empty %}
                            <div style="margin-top:6px;">
                                {% if sync.outdated %}<span class="ui-badge ui-badge--warning">shared_paths veraltet</span>{% else %}<span class="ui-badge ui-badge--success">shared_paths aktuell</span>{% endif %}
                            </div>
                        {% endif %}
                    </td>
                    <td>
                        <div style="display:flex;flex-wrap:wrap;gap:6px;">
                            {% for port in template.required_ports %}
                                <span class="ui-badge ui-badge--neutral">{{ port.label ?? port.name }} · {{ port.protocol|upper }}</span>
                            {% else %}
                                <span style="font-size:12px;color:var(--text-muted);">{{ t('admin_templates_no_ports', page_locale()) }}</span>
                            {% endfor %}
                        </div>
                    </td>
                    <td>
                        <div style="font-size:12px;color:var(--text-muted);white-space:pre-line;">{{ template.start_params }}</div>
                    </td>
                    <td>
                        <div style="font-size:12px;color:var(--text-muted);">
                            <p><span style="font-weight:600;">{{ t('admin_templates_install_label', page_locale()) }}:</span> {{ template.install_command }}</p>
                            <p style="margin-top:6px;"><span style="font-weight:600;">{{ t('admin_templates_update_label', page_locale()) }}:</span> {{ template.update_command }}</p>
                        </div>
                            {% for flag in template.allowed_switch_flags %}
                                <span class="ui-badge ui-badge--primary">{{ flag }}</span>
                            {% else %}
                                <span style="font-size:12px;color:var(--text-muted);">{{ t('admin_templates_no_flags', page_locale()) }}</span>
                            {% endfor %}
                        </div>
                    </td>
                    <td style="text-align:right;white-space:nowrap;">
                        <a
                            class="ui-button ui-button--ghost ui-button--sm"
                            href="/admin/templates/{{ template.id }}/preview"
                        >{{ t('admin_templates_preview', page_locale()) }}</a>
                        <a
                            class="ui-button ui-button--ghost ui-button--sm"
                            href="/admin/templates/{{ template.id }}/edit"
                        >{{ t('edit', page_locale()) }}</a>
                        {% if template.shared_paths_sync.seed is not empty %}
                        <button class="ui-button ui-button--ghost ui-button--sm"
                            hx-post="/admin/templates/{{ template.id }}/sync-shared-paths"
                            hx-swap="none">{{ t('admin_templates_sync_shared_paths_from_seed', page_locale()) }}</button>
                        {% endif %}
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="6" class="cust-table__empty">{{ t('admin_templates_empty', page_locale()) }}</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
