<div id="template-import" style="display:flex;flex-direction:column;gap:16px;">
    {% if import.success_message is not empty %}
        <div class="ng-alert ng-alert--success">{{ import.success_message }}</div>
    {% endif %}

    {% if import.errors is not empty %}
        <div class="ng-alert ng-alert--danger">
            <p style="font-weight:600;margin-bottom:4px;">{{ t('admin_templates_import_failed', page_locale()) }}</p>
            <ul style="list-style:disc;padding-left:20px;margin-top:4px;">
                {% for error in import.errors %}
                    <li>{{ error }}</li>
                {% endfor %}
            </ul>
        </div>
    {% endif %}

    <form
        style="display:flex;flex-direction:column;gap:12px;"
        hx-post="/admin/templates/import"
        hx-target="#template-import"
        hx-swap="outerHTML"
    >
        <div class="form-field">
            <label class="form-label">{{ t('admin_templates_import_label', page_locale()) }}</label>
            <textarea name="payload" rows="8" class="form-textarea" style="font-family:monospace;" placeholder='[{"game_key":"cs2","display_name":"Counter-Strike 2","description":"...","steam_app_id":730,"required_ports":["game","query"],"start_params":"-game cs2","install_command":"...","update_command":"...","env_vars":["SERVER_NAME=My Server"],"config_files":[{"path":"game/csgo/cfg/server.cfg","description":"Default"}],"plugin_paths":["game/csgo/addons/metamod"],"fastdl_settings":{"enabled":false,"base_url":"","root_path":""},"allowed_switch_flags":["+map","+maxplayers"]}]'>{{ import.payload }}</textarea>
        </div>
        <p style="font-size:12px;color:var(--text-muted);">{{ t('admin_templates_import_hint', page_locale()) }}</p>
        <div>
            <button type="submit" class="ui-button ui-button--primary">{{ t('admin_templates_import_submit', page_locale()) }}</button>
        </div>
    </form>
</div>
