{% extends 'admin/base.html.twig' %}

{% set pageTitle = 'Game Profiles' %}
{% set pageSubtitle = 'Port and slot enforcement profiles loaded from configuration.' %}
{% set activeNav = 'game-profiles' %}

{% block content %}
<div class="flex flex-col gap-6">
    <div class="ng-data-card">
        <div class="ng-data-card__header">
            <div>
                <h2 class="ng-data-card__title">{{ t('admin_game_profiles_title', page_locale()) }}</h2>
            </div>
            <div class="ng-data-card__actions">
                <span class="ui-badge ui-badge--neutral">{{ profiles|length }}</span>
            </div>
        </div>
        <div class="ng-data-card__body--flush">
            <div class="cust-ws-table-wrap">
                <table class="cust-table">
                    <thead>
                        <tr>
                            <th>Game key</th>
                            <th>Ports</th>
                            <th>Slots</th>
                            <th>Roles</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for profile in profiles %}
                            <tr>
                                <td>{{ profile.getGameKey() }}</td>
                                <td>{{ profile.getEnforceModePorts().value }}</td>
                                <td>{{ profile.getEnforceModeSlots().value }}</td>
                                <td>{{ profile.getPortRoles()|length }}</td>
                            </tr>
                        {% else %}
                            <tr><td colspan="4" class="cust-table__empty">No profiles loaded.</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{% endblock %}
