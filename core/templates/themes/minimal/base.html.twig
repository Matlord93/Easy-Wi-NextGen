<!DOCTYPE html>
<html lang="{{ page_locale() }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ page.title|default('Portal') }}</title>
    <link rel="stylesheet" href="{{ asset('ui.css') }}">
    <link rel="stylesheet" href="{{ asset('themes/' ~ (active_theme|default('minimal')) ~ '/css/theme.css') }}">
</head>
<body class="theme-shell theme-{{ active_theme|default('minimal') }}">
{% include 'cms/layout/_header.html.twig' %}
<main class="theme-main">{% block content %}{% endblock %}</main>
{% include 'cms/layout/_footer.html.twig' %}
{% include 'cms/layout/_cookie_consent.html.twig' %}
</body>
</html>
