<!DOCTYPE html>
<html lang="{{ page_locale() }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ page.title|default('Portal') }}</title>
    {% block head %}{% endblock %}
    <link rel="stylesheet" href="{{ asset('ui.css') }}">
    <link rel="stylesheet" href="{{ asset('themes/' ~ (active_theme|default('minimal')) ~ '/css/theme.css') }}">
</head>
<body class="theme-shell theme-{{ active_theme|default('minimal') }}">
{% if cms_layout.show_header|default(true) %}
{% block header %}
{% include 'themes/' ~ (active_theme|default('minimal')) ~ '/header.html.twig' ignore missing %}
{% endblock %}
{% endif %}
<main class="theme-main {% block main_class %}{% endblock %}">{% block content %}{% endblock %}</main>
{% if cms_layout.show_footer|default(true) %}
{% block footer %}
{% include 'themes/' ~ (active_theme|default('minimal')) ~ '/footer.html.twig' ignore missing %}
{% endblock %}
{% endif %}
{% include 'cms/layout/_cookie_consent.html.twig' %}
</body>
</html>
