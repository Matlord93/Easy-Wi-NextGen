{% extends 'themes/minimal/base.html.twig' %}
{% set cms_pages = [] %}
{% block header %}{% endblock %}
{% block footer %}{% endblock %}
{% block content %}
<section class="theme-wrap auth-box">
  <h2>Login</h2>
  {% for error in errors %}<p class="error">{{ error }}</p>{% endfor %}
  <form method="post" action="/login">
    <input type="hidden" name="target" value="{{ loginTarget|default('') }}">
    <input name="email" type="email" value="{{ form.email }}" placeholder="E-Mail" required>
    <input name="password" type="password" placeholder="{{ t('theme_login_password_placeholder', page_locale()) }}" required>
    <button type="submit">{{ t('theme_login_submit_btn', page_locale()) }}</button>
  </form>
  {% if registrationAllowed %}
    <a href="/register" class="theme-btn" style="margin-top:.75rem;">{{ t('theme_login_register_link', page_locale()) }}</a>
  {% else %}
    <p class="text-sm" style="margin-top:.75rem;color:#94a3b8;">{{ t('theme_login_registration_disabled', page_locale()) }}</p>
  {% endif %}
</section>
{% endblock %}
