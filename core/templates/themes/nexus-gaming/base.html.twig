<!DOCTYPE html>
<html lang="{{ page_locale() }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}{{ app_setting('site_title', 'Easy-Wi NextGen') }}{% endblock %}</title>
    {% block head %}{% endblock %}
    <link rel="stylesheet" href="{{ asset('ui.css') }}">
    <link rel="stylesheet" href="{{ asset('themes/nexus-gaming/css/theme.css') }}">
</head>
<body class="ng-body ng-portal-body">

{% set clanName = app_setting('branding_name', 'Easy-Wi NextGen') %}
{% set currentUser = current_user() %}
{% set socials = cms_branding.socials|default({}) %}
{% set reqPath = app.request ? app.request.pathInfo : '/' %}

{# Pages can override {% block shell %} to opt out of the portal wrapper (e.g. maintenance, auth) #}
{% block shell %}
<div class="ng-portal">

{# ══════════════════════════════════════════════ SIDEBAR #}
<aside class="ng-sidebar">

  <div class="ng-sidebar__logo-area">
    <a href="/" class="ng-sidebar__logo">
      {% if cms_branding.logo_path|default(false) %}
        <img src="{{ cms_branding.logo_path }}" alt="{{ clanName }}" class="ng-sidebar__logo-img">
      {% else %}
        <svg viewBox="0 0 40 40" fill="none" width="30" height="30">
          <polygon points="20,2 38,11 38,29 20,38 2,29 2,11" stroke="url(#slg)" stroke-width="1.5" fill="rgba(0,212,255,0.05)"/>
          <circle cx="20" cy="20" r="6" fill="url(#slg)"/>
          <defs>
            <linearGradient id="slg" x1="0" y1="0" x2="40" y2="40" gradientUnits="userSpaceOnUse">
              <stop offset="0%" stop-color="#00d4ff"/>
              <stop offset="100%" stop-color="#7c3aed"/>
            </linearGradient>
          </defs>
        </svg>
      {% endif %}
      <div class="ng-sidebar__logo-text">
        <span class="ng-sidebar__logo-top">Easy-Wi</span>
        <span class="ng-sidebar__logo-bottom">NextGen</span>
      </div>
    </a>
  </div>

  <nav class="ng-sidebar__nav">
    <a href="/" class="ng-sidebar__item {% if reqPath == '/' %}is-active{% endif %}">
      <span class="ng-sidebar__icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg></span>
      <span class="ng-sidebar__label">Home</span>
    </a>
    <a href="/blog" class="ng-sidebar__item {% if reqPath starts with '/blog' %}is-active{% endif %}">
      <span class="ng-sidebar__icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/></svg></span>
      <span class="ng-sidebar__label">Blog</span>
      <span class="ng-sidebar__sub">News &amp; Updates</span>
    </a>
    <a href="/events" class="ng-sidebar__item {% if reqPath starts with '/events' %}is-active{% endif %}">
      <span class="ng-sidebar__icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg></span>
      <span class="ng-sidebar__label">Events</span>
      <span class="ng-sidebar__sub">Turniere &amp; Events</span>
    </a>
    <a href="/teams" class="ng-sidebar__item {% if reqPath starts with '/teams' %}is-active{% endif %}">
      <span class="ng-sidebar__icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg></span>
      <span class="ng-sidebar__label">Team</span>
      <span class="ng-sidebar__sub">Mitglieder &amp; Roster</span>
    </a>
    <a href="/forum" class="ng-sidebar__item {% if reqPath starts with '/forum' %}is-active{% endif %}">
      <span class="ng-sidebar__icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg></span>
      <span class="ng-sidebar__label">Forum</span>
      <span class="ng-sidebar__sub">Community</span>
    </a>
    <a href="{{ currentUser ? (currentUser.type.value in ['admin','superadmin'] ? '/admin' : (currentUser.type.value == 'reseller' ? '/reseller' : '/customer')) : path('public_login') }}"
       class="ng-sidebar__item {% if reqPath starts with '/admin' or reqPath starts with '/customer' or reqPath starts with '/reseller' %}is-active{% endif %}">
      <span class="ng-sidebar__icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg></span>
      <span class="ng-sidebar__label">Dashboard</span>
      <span class="ng-sidebar__sub">Dein Bereich</span>
    </a>
    <a href="/servers" class="ng-sidebar__item {% if reqPath starts with '/servers' %}is-active{% endif %}">
      <span class="ng-sidebar__icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="8" rx="2"/><rect x="2" y="14" width="20" height="8" rx="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/></svg></span>
      <span class="ng-sidebar__label">Server</span>
      <span class="ng-sidebar__sub">Status &amp; Übersicht</span>
    </a>
  </nav>

  <div class="ng-sidebar__spacer"></div>

  {% if socials.discord|default(false) %}
  <div class="ng-sidebar__discord">
    <svg class="ng-sidebar__discord-logo" width="30" height="30" viewBox="0 0 24 24" fill="#7c85f5"><path d="M20.317 4.37a19.791 19.791 0 00-4.885-1.515.074.074 0 00-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 00-5.487 0 12.64 12.64 0 00-.617-1.25.077.077 0 00-.079-.037A19.736 19.736 0 003.677 4.37a.07.07 0 00-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 00.031.057 19.9 19.9 0 005.993 3.03.078.078 0 00.084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 00-.041-.106 13.107 13.107 0 01-1.872-.892.077.077 0 01-.008-.128 10.2 10.2 0 00.372-.292.074.074 0 01.077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 01.078.01c.12.098.246.198.373.292a.077.077 0 01-.006.127 12.299 12.299 0 01-1.873.892.077.077 0 00-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 00.084.028 19.839 19.839 0 006.002-3.03.077.077 0 00.032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 00-.031-.03z"/></svg>
    <p class="ng-sidebar__discord-title">Join our <span>Discord Server</span></p>
    <p class="ng-sidebar__discord-desc">Tritt unserer Community bei und bleib immer up to date!</p>
    <a href="{{ socials.discord }}" target="_blank" rel="noopener" class="ng-sidebar__discord-btn">Jetzt beitreten →</a>
  </div>
  {% endif %}

  <div class="ng-sidebar__socials">
    {% if socials.discord|default(false) %}
      <a href="{{ socials.discord }}" class="ng-sidebar__social-icon" target="_blank" rel="noopener" aria-label="Discord"><svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M20.317 4.37a19.791 19.791 0 00-4.885-1.515.074.074 0 00-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 00-5.487 0 12.64 12.64 0 00-.617-1.25.077.077 0 00-.079-.037A19.736 19.736 0 003.677 4.37a.07.07 0 00-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 00.031.057 19.9 19.9 0 005.993 3.03.078.078 0 00.084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 00-.041-.106 13.107 13.107 0 01-1.872-.892.077.077 0 01-.008-.128 10.2 10.2 0 00.372-.292.074.074 0 01.077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 01.078.01c.12.098.246.198.373.292a.077.077 0 01-.006.127 12.299 12.299 0 01-1.873.892.077.077 0 00-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 00.084.028 19.839 19.839 0 006.002-3.03.077.077 0 00.032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 00-.031-.03z"/></svg></a>
    {% else %}
      <span class="ng-sidebar__social-icon ng-sidebar__social-icon--dim" aria-label="Discord"><svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M20.317 4.37a19.791 19.791 0 00-4.885-1.515.074.074 0 00-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 00-5.487 0 12.64 12.64 0 00-.617-1.25.077.077 0 00-.079-.037A19.736 19.736 0 003.677 4.37a.07.07 0 00-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 00.031.057 19.9 19.9 0 005.993 3.03.078.078 0 00.084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 00-.041-.106 13.107 13.107 0 01-1.872-.892.077.077 0 01-.008-.128 10.2 10.2 0 00.372-.292.074.074 0 01.077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 01.078.01c.12.098.246.198.373.292a.077.077 0 01-.006.127 12.299 12.299 0 01-1.873.892.077.077 0 00-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 00.084.028 19.839 19.839 0 006.002-3.03.077.077 0 00.032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 00-.031-.03z"/></svg></span>
    {% endif %}
    {% if socials.twitter|default(false) %}
      <a href="{{ socials.twitter }}" class="ng-sidebar__social-icon" target="_blank" rel="noopener" aria-label="X"><svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg></a>
    {% else %}
      <span class="ng-sidebar__social-icon ng-sidebar__social-icon--dim" aria-label="X"><svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg></span>
    {% endif %}
    {% if socials.youtube|default(false) %}
      <a href="{{ socials.youtube }}" class="ng-sidebar__social-icon" target="_blank" rel="noopener" aria-label="YouTube"><svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg></a>
    {% else %}
      <span class="ng-sidebar__social-icon ng-sidebar__social-icon--dim" aria-label="YouTube"><svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg></span>
    {% endif %}
  </div>

</aside>

{# ══════════════════════════════════════════════ MAIN AREA #}
<div class="ng-portal-main">

  {# ── TOPBAR ── #}
  <header class="ng-topbar">
    <nav class="ng-topbar__nav">
      <a href="/" class="ng-topbar__link {% if reqPath == '/' %}is-active{% endif %}">Home</a>
      <a href="/blog" class="ng-topbar__link {% if reqPath starts with '/blog' %}is-active{% endif %}">Blog</a>
      <a href="/events" class="ng-topbar__link {% if reqPath starts with '/events' %}is-active{% endif %}">Events</a>
      <a href="/teams" class="ng-topbar__link {% if reqPath starts with '/teams' %}is-active{% endif %}">Team</a>
      <a href="/forum" class="ng-topbar__link {% if reqPath starts with '/forum' %}is-active{% endif %}">Forum</a>
      <a href="/servers" class="ng-topbar__link {% if reqPath starts with '/servers' %}is-active{% endif %}">Server</a>
    </nav>
    <div class="ng-topbar__actions">
      {% if currentUser %}
        <div class="ng-user-menu" id="ng-user-menu">
          <button class="ng-user-menu__toggle" id="ng-user-toggle" aria-expanded="false" aria-haspopup="true">
            <span class="ng-user-avatar">{{ currentUser.email|first|upper }}</span>
            <span class="ng-user-email">{{ currentUser.email }}</span>
            <svg class="ng-user-menu__arrow" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
          </button>
          <div class="ng-user-menu__dropdown" id="ng-user-dropdown">
            <a href="{{ currentUser.type.value in ['admin','superadmin'] ? '/admin' : (currentUser.type.value == 'reseller' ? '/reseller' : '/customer') }}" class="ng-user-menu__item">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
              Portal
            </a>
            <a href="/profile" class="ng-user-menu__item">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
              Profil
            </a>
            <a href="{{ path('public_logout') }}" class="ng-user-menu__item ng-user-menu__item--danger">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
              Logout
            </a>
          </div>
        </div>
      {% else %}
        <a href="{{ path('public_login') }}" class="ng-topbar__login-btn">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          Login
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
        </a>
      {% endif %}
    </div>
  </header>

  {# ── PAGE CONTENT ── #}
  <main class="ng-portal-content">
    {% block content %}{% endblock %}
  </main>

  {# ── PORTAL FOOTER ── #}
  <footer class="ng-portal-footer">
    <span class="ng-portal-footer__brand ng-gradient-text">{{ clanName }}</span>
    <span class="ng-portal-footer__copy">© {{ 'now'|date('Y') }} {{ clanName }} — Powered by Easy-Wi NextGen</span>
    <div class="ng-portal-footer__legal">
      <a href="/impressum">Impressum</a>
      <a href="/datenschutz">Datenschutz</a>
      <a href="/kontakt">Kontakt</a>
    </div>
  </footer>

</div>{# /portal-main #}
</div>{# /portal #}

<script>
(function(){
  var toggle = document.getElementById('ng-user-toggle');
  var dropdown = document.getElementById('ng-user-dropdown');
  if (toggle && dropdown) {
    toggle.addEventListener('click', function(e) {
      e.stopPropagation();
      var open = dropdown.classList.toggle('is-open');
      toggle.setAttribute('aria-expanded', String(open));
    });
    document.addEventListener('click', function(e) {
      if (!toggle.contains(e.target) && !dropdown.contains(e.target)) {
        dropdown.classList.remove('is-open');
        toggle.setAttribute('aria-expanded', 'false');
      }
    });
  }
})();
</script>
{% endblock %}

{% include 'cms/layout/_cookie_consent.html.twig' %}
</body>
</html>
