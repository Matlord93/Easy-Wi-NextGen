{% set clanName = app_setting('branding_name', 'Easy-Wi NextGen') %}
{% set year = 'now'|date('Y') %}
{% set socials = cms_branding.socials|default({}) %}

<footer class="ng-footer">
    <div class="ng-footer__inner">

        <div class="ng-footer__brand">
            {% if cms_branding.logo_path|default(false) %}
                <img src="{{ cms_branding.logo_path }}" alt="{{ clanName }}" class="ng-footer__logo">
            {% endif %}
            <span class="ng-footer__name">{{ clanName }}</span>
            {% if cms_branding.tagline|default(false) %}
                <p class="ng-footer__tagline">{{ cms_branding.tagline }}</p>
            {% endif %}

            <div class="ng-footer__socials">
                {# Discord #}
                {% if socials.discord|default(false) %}
                    <a href="{{ socials.discord }}" class="ng-footer__social" target="_blank" rel="noopener noreferrer" aria-label="Discord">
                {% else %}
                    <span class="ng-footer__social ng-footer__social--disabled" aria-label="Discord">
                {% endif %}
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M20.317 4.37a19.791 19.791 0 00-4.885-1.515.074.074 0 00-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 00-5.487 0 12.64 12.64 0 00-.617-1.25.077.077 0 00-.079-.037A19.736 19.736 0 003.677 4.37a.07.07 0 00-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 00.031.057 19.9 19.9 0 005.993 3.03.078.078 0 00.084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 00-.041-.106 13.107 13.107 0 01-1.872-.892.077.077 0 01-.008-.128 10.2 10.2 0 00.372-.292.074.074 0 01.077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 01.078.01c.12.098.246.198.373.292a.077.077 0 01-.006.127 12.299 12.299 0 01-1.873.892.077.077 0 00-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 00.084.028 19.839 19.839 0 006.002-3.03.077.077 0 00.032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 00-.031-.03z"/>
                    </svg>
                {% if socials.discord|default(false) %}</a>{% else %}</span>{% endif %}

                {# X / Twitter #}
                {% if socials.twitter|default(false) %}
                    <a href="{{ socials.twitter }}" class="ng-footer__social" target="_blank" rel="noopener noreferrer" aria-label="X">
                {% else %}
                    <span class="ng-footer__social ng-footer__social--disabled" aria-label="X">
                {% endif %}
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                    </svg>
                {% if socials.twitter|default(false) %}</a>{% else %}</span>{% endif %}

                {# YouTube #}
                {% if socials.youtube|default(false) %}
                    <a href="{{ socials.youtube }}" class="ng-footer__social" target="_blank" rel="noopener noreferrer" aria-label="YouTube">
                {% else %}
                    <span class="ng-footer__social ng-footer__social--disabled" aria-label="YouTube">
                {% endif %}
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
                    </svg>
                {% if socials.youtube|default(false) %}</a>{% else %}</span>{% endif %}

                {# Website (nur wenn konfiguriert) #}
                {% if socials.website|default(false) %}
                    <a href="{{ socials.website }}" class="ng-footer__social" target="_blank" rel="noopener noreferrer" aria-label="Website">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/>
                            <path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/>
                        </svg>
                    </a>
                {% endif %}
            </div>
        </div>

        {% if cms_footer_links|default([])|length > 0 %}
            <nav class="ng-footer__links" aria-label="Footer Navigation">
                {% for item in cms_footer_links %}
                    {% if item.url is defined and item.url is not empty %}
                        <a href="{{ item.url }}"
                           class="ng-footer__link"
                           {% if item.external|default(false) %}target="_blank" rel="noopener noreferrer"{% endif %}>
                            {{ item.label|default('Link') }}
                        </a>
                    {% endif %}
                {% endfor %}
            </nav>
        {% endif %}

    </div>

    <div class="ng-footer__bottom">
        <span>© {{ year }} {{ clanName }} — Powered by Easy-Wi NextGen</span>
        <div class="ng-footer__legal">
            <a href="/impressum" class="ng-footer__legal-link">Impressum</a>
            <a href="/datenschutz" class="ng-footer__legal-link">Datenschutz</a>
        </div>
    </div>
</footer>
