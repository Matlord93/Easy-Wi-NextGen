{% extends 'themes/nexus-gaming/base.html.twig' %}

{% block title %}Login – {{ app_setting('site_title', 'Easy-Wi NextGen') }}{% endblock %}

{% block shell %}{% block content %}
<div class="ng-auth-wrap">
    <div class="ng-auth-bg-grid"></div>
    <div class="ng-auth-glow"></div>

    <div class="ng-auth-card">
        <div class="ng-auth-card__header">
            <a href="/" class="ng-auth-logo">
                <svg viewBox="0 0 40 40" fill="none" width="32" height="32">
                    <polygon points="20,2 38,11 38,29 20,38 2,29 2,11" stroke="url(#ag)" stroke-width="1.5" fill="rgba(0,212,255,0.05)"/>
                    <circle cx="20" cy="20" r="6" fill="url(#ag)"/>
                    <defs>
                        <linearGradient id="ag" x1="0" y1="0" x2="40" y2="40" gradientUnits="userSpaceOnUse">
                            <stop offset="0%" stop-color="#00d4ff"/>
                            <stop offset="100%" stop-color="#7c3aed"/>
                        </linearGradient>
                    </defs>
                </svg>
                <span>{{ app_setting('branding_name', 'Easy-Wi NextGen') }}</span>
            </a>
            <h1 class="ng-auth-card__title">Willkommen zurück</h1>
            <p class="ng-auth-card__sub">Melde dich in deinem Account an</p>
        </div>

        {% for error in errors|default([]) %}
            <div class="ng-alert ng-alert--danger">{{ error }}</div>
        {% endfor %}

        <form method="post" action="/login" class="ng-auth-form">
            <input type="hidden" name="target" value="{{ loginTarget|default('') }}">

            <div class="ng-field">
                <label class="ng-label" for="login-email">E-Mail</label>
                <input class="ng-input" id="login-email" name="email" type="email"
                       value="{{ form.email|default('') }}"
                       placeholder="deine@email.de" required autocomplete="email">
            </div>

            <div class="ng-field">
                <label class="ng-label" for="login-password">Passwort</label>
                <input class="ng-input" id="login-password" name="password" type="password"
                       placeholder="••••••••" required autocomplete="current-password">
            </div>

            <button type="submit" class="ng-btn ng-btn--primary ng-btn--full">
                Einloggen
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
            </button>
        </form>

        {% if registrationAllowed|default(false) %}
            <p class="ng-auth-footer">
                Noch kein Account?
                <a href="/register" class="ng-link">Jetzt registrieren</a>
            </p>
        {% else %}
            <p class="ng-auth-footer ng-auth-footer--muted">Registrierung ist derzeit deaktiviert.</p>
        {% endif %}

        <a href="/" class="ng-auth-back">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M19 12H5M12 19l-7-7 7-7"/>
            </svg>
            Zur Startseite
        </a>
    </div>
</div>
{% endblock %}{% endblock %}
