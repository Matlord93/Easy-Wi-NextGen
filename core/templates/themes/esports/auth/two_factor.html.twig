{% extends 'themes/esports/base.html.twig' %}
{% set cms_pages = [] %}
{% block content %}
<section class="theme-wrap" style="max-width:880px;">
  <div class="theme-card auth-box" style="padding:1.5rem;">
    <p style="font-size:.72rem;letter-spacing:.2em;text-transform:uppercase;color:#67e8f9;">Sicherheit</p>
    <h2 style="margin-top:.4rem;font-size:2rem;">Zwei-Faktor-Anmeldung</h2>

    {% for error in errors %}<p class="error">{{ error }}</p>{% endfor %}

    <form method="post" action="/2fa_check">
      <input type="hidden" name="_token" value="{{ csrf_token('public_2fa_check') }}">
      <input name="otp" inputmode="numeric" pattern="[0-9]{6}" placeholder="Authenticator-Code" required>
      <button type="submit">Bestätigen</button>
    </form>
  </div>
</section>
{% endblock %}
