<header class="theme-header">
  <div class="theme-wrap">
    <h1>{{ app_setting('branding_name', 'Easy-Wi NextGen') }}</h1>
    <nav>
      {% set lang = app.request ? app.request.query.get('lang') : null %}
      {% set langSuffix = lang in ['de', 'en'] ? '?lang=' ~ lang : '' %}
      {% for item in cms_pages|default([]) %}
        {% set moduleSlug = item.slug in ['blog', 'events', 'team', 'forum'] ? item.slug : null %}
        {% if moduleSlug is null or module_toggles[moduleSlug]|default(false) %}
          {% set href = item.slug == 'startseite' ? '/' : '/' ~ item.slug %}
          <a href="{{ href }}" class="{{ item.is_active ? 'is-active' : '' }}">{{ item.title }}</a>
        {% endif %}
      {% endfor %}
      {% if module_toggles.blog|default(false) %}<a href="/blog{{ langSuffix }}">{{ t('cms_nav_blog', page_locale()) }}</a>{% endif %}
      {% if module_toggles.events|default(false) %}<a href="/events{{ langSuffix }}">{{ t('cms_nav_events', page_locale()) }}</a>{% endif %}
      {% if module_toggles.team|default(false) %}<a href="/teams{{ langSuffix }}">{{ t('cms_nav_team', page_locale()) }}</a>{% endif %}
      {% if module_toggles.forum|default(false) %}<a href="/forum{{ langSuffix }}">{{ t('cms_nav_forum', page_locale()) }}</a>{% endif %}
      {% set currentUser = current_user() %}
      {% if currentUser %}
        {% set panelPath = '/customer' %}
        {% set panelLabel = t('customer_portal', page_locale()) %}
        {% if currentUser.type.value in ['admin', 'superadmin'] %}
          {% set panelPath = '/admin' %}
          {% set panelLabel = t('admin_portal', page_locale()) %}
        {% elseif currentUser.type.value == 'reseller' %}
          {% set panelPath = '/reseller' %}
          {% set panelLabel = t('reseller_portal', page_locale()) %}
        {% endif %}
        <a href="{{ panelPath }}{{ langSuffix }}">{{ panelLabel }}</a>
        <a href="{{ path('public_logout') }}{{ langSuffix }}">{{ t('logout', page_locale()) }}</a>
      {% else %}
        <a href="{{ path('public_login') }}{{ langSuffix }}">{{ t('login', page_locale()) }}</a>
      {% endif %}
    </nav>
  </div>
</header>
