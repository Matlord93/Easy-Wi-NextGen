{% extends 'themes/fantasy/base.html.twig' %}
{% set cms_pages = [] %}
{% block header %}{% endblock %}
{% block footer %}{% endblock %}
{% block content %}
<section class="theme-wrap auth-box">
  <h2>{{ t('theme_2fa_heading', page_locale()) }}</h2>
  {% for error in errors %}<p class="error">{{ error }}</p>{% endfor %}
  <form method="post" action="/2fa_check">
    <input type="hidden" name="_token" value="{{ csrf_token('public_2fa_check') }}">
    <input name="otp" inputmode="numeric" pattern="[0-9]{6}" placeholder="{{ t('theme_2fa_placeholder_code', page_locale()) }}" required>
    <button type="submit">{{ t('theme_2fa_confirm', page_locale()) }}</button>
  </form>
</section>
{% endblock %}
