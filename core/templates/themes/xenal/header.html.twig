<header class="theme-header">
  <div class="theme-wrap xenal-topbar">
    <a href="{{ path('public_cms_home') }}" class="xenal-brand">
      <span class="xenal-brand__mark">X</span>
      <span class="xenal-brand__text">{{ app_setting('branding_name', 'Xenal Gaming') }}</span>
    </a>

    <nav class="xenal-nav">
      {% for item in cms_navigation|default([]) %}
        {% if item.url is defined and item.url is not empty %}
          <a href="{{ item.url }}"
             class="{{ item.active|default(false) ? 'is-active' : '' }}"
             {% if item.external|default(false) %}target="_blank" rel="noopener noreferrer"{% endif %}>
            {{ item.label|default('Link') }}
          </a>
        {% endif %}
      {% endfor %}

      {% set user = current_user() %}
      {% if user %}
        <a href="{{ path('public_logout') }}" class="xenal-nav__pill">Logout</a>
      {% else %}
        <a href="{{ path('public_login') }}" class="xenal-nav__pill">Login</a>
      {% endif %}
    </nav>
  </div>
</header>
