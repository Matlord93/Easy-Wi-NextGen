{% extends 'themes/xenal/base.html.twig' %}

{% block content %}
<section class="theme-wrap xenal-page-shell">
  <header class="xenal-section-head">
    <p class="xenal-kicker">Xenal CMS</p>
    <h1>{{ page.title }}</h1>
  </header>

  <div class="xenal-section-stack">
    {% for block in blocks %}
      <article class="xenal-card">
        {% include 'public/blocks/_block.html.twig' with { block: block } only %}
      </article>
    {% else %}
      <article class="xenal-card">Keine Inhalte vorhanden.</article>
    {% endfor %}
  </div>
</section>
{% endblock %}
