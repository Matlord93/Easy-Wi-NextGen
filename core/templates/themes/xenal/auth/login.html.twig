{% extends 'themes/xenal/base.html.twig' %}

{# No header on the auth page — matches the landing page look #}
{% block header %}{% endblock %}
{% block main_class %}xn-auth-page{% endblock %}

{% block content %}
<section class="xn-auth-outer">

  {# Brand mark at the top #}
  <div class="xn-auth-brand">
    <a href="{{ path('public_cms_home') }}" class="xn-auth-brand__link">
      <span class="xn-auth-brand__x">X</span>
      <span class="xn-auth-brand__name">{{ app_setting('branding_name', 'XENAL GAMING') }}</span>
    </a>
  </div>

  <div class="xn-auth-card">

    <p class="xn-auth-kicker">Clan Access</p>
    <h1 class="xn-auth-title">Login</h1>
    <p class="xn-auth-sub">Melde dich im Portal an, um auf Forum, Teams und Panel zuzugreifen.</p>

    {% for error in errors %}
      <p class="xn-auth-error">{{ error }}</p>
    {% endfor %}

    <form method="post" action="{{ path('public_login') }}" class="xn-auth-form">
      <input type="hidden" name="target" value="{{ loginTarget|default('') }}">

      <div class="xn-field">
        <label class="xn-field__label" for="login_email">E-Mail</label>
        <input
          id="login_email"
          class="xn-field__input"
          name="email"
          type="email"
          value="{{ form.email }}"
          placeholder="deine@email.de"
          required
          autocomplete="email"
        >
      </div>

      <div class="xn-field">
        <label class="xn-field__label" for="login_password">Passwort</label>
        <input
          id="login_password"
          class="xn-field__input"
          name="password"
          type="password"
          placeholder="••••••••"
          required
          autocomplete="current-password"
        >
      </div>

      <button class="xn-auth-submit" type="submit">Einloggen</button>
    </form>

    {% if registrationAllowed %}
      <p class="xn-auth-footer-note">
        Noch kein Konto?
        <a href="{{ path('public_register') }}" class="xn-auth-link">Jetzt registrieren</a>
      </p>
    {% else %}
      <p class="xn-auth-footer-note xn-auth-muted">Registrierung ist aktuell deaktiviert.</p>
    {% endif %}

  </div>

</section>
{% endblock %}
