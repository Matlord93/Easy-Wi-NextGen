{% extends 'themes/xenal/base.html.twig' %}
{% set cms_navigation = [] %}

{% block content %}
<section class="theme-wrap xenal-auth-wrap">
  <div class="xenal-card xenal-auth-box">
    <p class="xenal-kicker">Sicherheit</p>
    <h2>Zwei-Faktor-Anmeldung</h2>

    {% for error in errors %}<p class="error">{{ error }}</p>{% endfor %}

    <form method="post" action="{{ path('public_2fa_check') }}" class="xenal-auth-form">
      <input type="hidden" name="_token" value="{{ csrf_token('public_2fa_check') }}">
      <input name="otp" inputmode="numeric" pattern="[0-9]{6}" placeholder="Authenticator-Code" required>
      <button class="xenal-btn xenal-btn--primary" type="submit">Bestätigen</button>
    </form>
  </div>
</section>
{% endblock %}
